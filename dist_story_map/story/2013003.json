[
    {
        "type": "background",
        "background": "500800"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正當每個人都拚了命，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "試圖處理這場異變時……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n矛依未和克莉絲提娜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n抵達了那變得相當淒慘的『王宮』近處。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那是……？",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這到底是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "發生了什麼事？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "『王宮』幾乎半毀了……！",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n幾乎全都變成一座瓦礫山了呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "外加『王宮』建築物本身，",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n似乎大部分都被淹沒在那黑色的泥濘之中了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再怎麼說也無法在那令人作噁的泥漿裡游泳嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而且也沒有可以立足的地方，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來是無法更接近了吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但、",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "　{player}他們已經闖到『王宮』裡面了不是嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他們說不定都快要溺死在那像是黑泥巴一樣的東西裡面了啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果是這樣就得去救他們才行！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "令人提不起興致呢……",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我不太喜歡弄髒衣服。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔唔，",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳這一點還是完全都沒變啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那隨便妳了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算是我一個人我也要去！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "慢著慢著。",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒耐心的女人可不會受歡迎啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……準備迎擊了諾維姆，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事態緊急了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "蛤？",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n怎、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼回事？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳瞧瞧上頭。",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……與我等有著深厚因緣的存在，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那自詡為神的傢伙飛到半空中了喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我看看……？",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那是！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_011"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……哎呀。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_012"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳們倆，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "竟然還活著呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真是託你的福呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若這個世界失去了像我這樣的至寶，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那些庸俗之人可不就痛哭失聲了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因此我勉為其難的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如此苟且偷生了下來呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……『陛下』。",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我有一問相求，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的目的究竟是什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若你那一邊能為我帶來更多的愉悅……",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那麼就算是地獄的盡頭，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要我陪你闖到最後一刻也是無妨。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這可真是讓人欣喜的一言呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_016"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然而很遺憾，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "克莉絲……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就算解釋給現在的妳聽，我想妳也無法理解，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而我也下定決心不再去期待",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或相信任何一個人了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "剩下全部的事，",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我將會獨自",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "以我自身的力量來解決。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來是被人甩了呢，",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真遺憾……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我這話還算是說得挺認真的呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真那！　",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我不清楚你真正的企圖到底是什麼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但我才不會讓你稱心如意的啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你給我等著！",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我絕對會阻止你的陰謀，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好奪回我們那原本的世界的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵，",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊哈哈……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳可真是一點也沒變呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n如此可愛的諾維姆，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如此可憐的諾維姆。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "到頭來說穿了，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳就不是個當主角的料喔。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "無法理解自身的價值，",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被蒙蔽了雙眼也不去傾耳聆聽……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不但被事態牽著鼻子走，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還總是做著蠢事而失敗連連。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n即便如此也不願放棄，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "卻也不曾反省，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只是頑固地不斷重蹈覆轍。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還真是無藥可救了呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若是身旁沒有尾狗刀，究竟又能做到些什麼事？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "…………",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_024"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過，",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如同妳這般的小丑（Trickster）或許在故事中也是不可或缺的呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "倘若妳",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能不來妨礙我們正派與反派之間的事，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n要我在這兒放妳一馬倒也是無妨。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "畢竟若連個觀眾也沒有的話，",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_026"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "確實還挺冷清的……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n雖然我想應該很難受，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但妳就親眼見證到最後一刻，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n並且永遠烙印在妳的腦海之中吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將我們的這個故事――。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……？　",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你是什麼意思？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我可是完全聽不懂你在說什麼啊～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗯。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_028"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我想也是。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不懂也無妨唷，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過是段自言自語罷了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就連我也心累到",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "稍稍軟弱起來了嗎……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再會。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我還有著急事，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "得先走一步了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "慢著。",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你以為我會讓你逃掉嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我曾是如此忠誠地",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n愛慕著並且仕奉於你的麾下，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你卻一刀兩斷的將我切割……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還像是對待著蟲子般試圖奪我性命，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我豈能夠輕易的原諒你。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但畢竟你也曾是我打從心底愛慕之人，",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不會要你交出小命。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若不擱下個一臂一足你也休想離去。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哎呀真可怕。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_033"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n但真遺憾，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可沒有那個閒情雅緻能和妳玩了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳是一名『七冠』，",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "具有著相當龐大的力量……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所以也是個非常具有魅力的『飼料』就是了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但也因此若想吃了妳，",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "大概會遭到頑強的抵抗呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果為此而耗費精力簡直過於愚蠢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那我還不如去找些更易於吞食的『飼料』呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『飼料』？　",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "吞食？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n究竟在說些什麼……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "給我個能令人滿意的說明！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可沒那個義務呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_037"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過嘛，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若妳們真想妨礙我的話……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n儘管挺麻煩的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在不殺了妳們的程度下給妳們點教訓也無不可？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦？",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你不打算殺了我們嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還真高抬貴手了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可是差點被你奪去性命喔，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可沒有理由相信你的這一番話呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那又如何。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_040"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "與我又有何干。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n光憑張嘴的傢伙都能信以為真的人們，我已經見到厭煩了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n神也是很辛苦啊……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "吶，克莉絲，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳能夠明白我的心情嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……？　",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "究竟在說些什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "您這是還沒睡醒嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『陛下』？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "克莉絲提娜！",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？　",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了諾維姆，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別東張西望的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那位『陛下』只要一有機可趁，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是會對我們放出致命的一擊喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是啊，",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳看那邊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳看，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳看那……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呣……？",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦哦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從壟罩著『王宮』的黑色泥濘之中，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有什麼浮了出來！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那究竟為何？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好像是個黑色的箱子？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_046"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看來不再加緊些腳步不行了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等一下，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真那！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你要去哪裡，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們的話還沒有說完啊！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別想逃啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "逃？　",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_048"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳會錯意了呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是我放過了妳們唷……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n看在妳們倆於『前世』時，勉強還算是有派上了點用場，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這次我就",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "饒過了妳們倆。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再見了。",
        "unit_id": 106914,
        "voice": "vo_adv_2013003_049"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n若真有緣的話，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就再會吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊，",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_050"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給我等等！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n別就只是把想說的說完然後就消失不見啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這傢伙每次都這樣！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "退下，諾維姆！",
        "unit_id": 107111,
        "voice": "vo_adv_2013003_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那如同黑色箱子一般的玩意兒接近過來了……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n若被波及到了可不是受點小傷就能了事的啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚嗚～",
        "unit_id": 106113,
        "voice": "vo_adv_2013003_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到底是怎樣啦一個接著一個！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "完全搞不懂呀，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "誰來說明一下啦！",
        "unit_id": 106113
    }
]