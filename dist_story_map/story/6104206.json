[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "兔子族送給我的這副鎧甲，",
        "unit_id": 123811,
        "voice": "vo_adv_6104206_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n似乎讓我也踏入了新世界呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想不到用拳頭來戰鬥",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也挺不錯的。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊，",
        "unit_id": 123811,
        "voice": "vo_adv_6104206_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然我至今都自認是以自己的身體來戰鬥的……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但不論是戰鬥風格",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是與敵人的間距，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "用劍跟用拳的感覺都完全不同。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人不論到了幾歲",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都會有新發現呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我並不是為了迎合你的喜好才穿的……",
        "unit_id": 123811,
        "voice": "vo_adv_6104206_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過既然如此，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你就仔細地烙印在眼裡吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n因為穿不穿都全看我的心情，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "下次不知道什麼時候才能再看到我穿喔？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想不到你說的話",
        "unit_id": 123811,
        "voice": "vo_adv_6104206_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還挺一針見血的？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不論穿上了什麼樣的服裝，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種無法動搖的個性，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n才是真正的克莉絲提娜姐姐。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你還挺懂的嘛♪",
        "unit_id": 123811
    }
]