[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "三人在掃蕩了某層樓的魔物群後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就直接在該層樓稍作休息。"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦哦，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這石頭是怎麼回事……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真令人感興趣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n它蘊含了現存的識別魔法無法辨識的未知魔力！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮？",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n妳蹲在那種角落做什麼？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我在尋寶。",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在你們眼中或許認為我只是在收集石頭，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但我是在尋找沒有學術性，但卻可能具有魔術性意義的素材。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就如同{player}學弟是為了尋找自己的記憶來到這裡一般，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我則是為了尋找稀有的研究素材而來到這裡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呵呵，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不惜鞭策虛弱的身體到外頭來真是值得了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒想到會這麼大豐收，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這正是所謂「不勞而獲」啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果要說的話，",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該是「不勞而獲」才對吧，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……？",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我就是那麼說的啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊！",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的耶，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱歉！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為受身邊人的影響，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓我不禁染上會下意識訂正別人發言的習慣。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "討厭，好丟臉喔……",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等回去以後，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "得給璃乃一記教育性的頭錘才行呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，靜流。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我和他的目的就如我剛才說過的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那妳又是如何呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳來到這座塔的目的是？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以說，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是為了保護弟弟呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想也是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼我換個問題吧。",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n{player}今天要來這裡的情報，妳是從哪得知的？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳在進塔之前就遇到我們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這總不會是湊巧吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這不是湊巧，而是命運呢♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐可是無論何時都會挺身前去化解弟弟的危機喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是這樣啊……",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我了解了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n既然妳說是命運，那應該就是如此吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒辦法，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "每個人皆有各有自己的問題與想法。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n看來那似乎也不會因此對我們造成不利的損害，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也就不需要刻意去追究吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "隨妳高興吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯……",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n優妮真的很聰明呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最喜歡那樣的人囉♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是啊，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "停留太久也只會招致不必要的危險。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要多注意腳邊喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要不要和姐姐牽手一起走？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "把手握緊這樣，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們以前很常像這樣一起走呢♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "慢著。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳說握緊？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我剛才聽到了什麼擾亂風紀的發言。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼事？",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我和弟弟是家人，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以他可以盡情跟我撒嬌。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來，弟弟，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這裡很危險，來和姐姐緊緊靠在一起吧♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊……！",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "住手，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你們還不住手！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "太不檢點了！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是讓人大意不得，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳這毒婦！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n只要我的眼還是雪亮光明的，就絕不允許不純潔的行為！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "竟然說可以盡情撒嬌？",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳以為你們都幾歲了？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n都已經是堂堂的大人，還不在乎他人眼光",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在那黏黏膩膩的，簡直是瘋了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你們這些狂徒，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "給我知恥！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦咦～",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們是姐弟，這是很正常的事情呀～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我並不清楚一般「家庭」的範例。",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是和我聽聞的知識相互對照，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你們那行為應該有點脫離姐弟間的常識吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮，",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所謂的常識可是有多少家庭就有多少常識。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能夠寬容接受自己未知的常識才是多樣化的社會，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n成熟的姐姐是這麼想的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔唔唔，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "竟然耍小聰明強詞奪理……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳這傢伙想必是文科的吧？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但若是要比賽強詞奪理，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我這個優妮博士是不可能會輸的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼……",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我實在不想說這件事，但這也非不得以。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n聽好了，靜流，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳冷靜下來仔細聽我說。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "首先以前提來說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳和{player}並不是家人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳和他之間既沒有血緣關係，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在近親中也沒有人結為姻緣。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n根據本國的國語規則並不將那關係定義成姐弟，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也就是說，那是稱為外人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵。",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別這樣。",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n別用那一副我真愛開玩笑的微笑溫柔地俯視我。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯……",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就算妳那麼說，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但我就是{player}的姐姐呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳還是打算要繼續嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然如此，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就是{player}的小優妮。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "小、",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "小優妮？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n咦？咦？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那是什麼……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是怎麼回事？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳完全搞不懂對吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以就是那麼回事。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "完全搞不懂──",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個無法理解的情感，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n正是妳至今為止散布在世上的混沌。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "每當妳在宣傳妳是命運的姐姐這種虛言時，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這社會的所有人",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也都和現在的妳一樣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "陷入「這個人在說些什麼啊？」這種",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不明所以的感覺之中。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳要好好反省。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是高興吧，",
        "unit_id": 111011,
        "voice": "vo_adv_7015002_037"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "能夠注意到那一點就算是進步了一小步。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳很努力了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "靜流。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n別擔心，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳不需要感到焦急。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "今天的治療就到此為止吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太好了……",
        "unit_id": 104911,
        "voice": "vo_adv_7015002_038"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮好像也總算是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n理解我們了呢，弟弟♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人各自露出滿足的笑容，並持續探索塔。"
    }
]