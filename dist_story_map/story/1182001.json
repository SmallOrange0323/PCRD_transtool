        "name": "美空",
        "words": "\n接著互相殘殺……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "輸掉了呢。",
        "unit_id": 192011
    },
    {
        "type": "background",
