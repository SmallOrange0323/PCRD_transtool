    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}打工回來的路上──"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵★",
        "unit_id": 1,
        "voice": "vo_adv_1182001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n猜～猜我是誰？",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真是的──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_001"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我可不許你",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說忘了我唷？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我們一起經歷過",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那麼多次互相殘殺不是嗎★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是的★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_002"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "總覺得好久不見了呢，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真是的，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_003"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "討厭──★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不要用那麼害怕的表情",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "看著我嘛♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "現在的我",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不是【憤怒‧軍團】的成員，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n只是個普通的女孩子★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我不會做任何",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "會讓騎士同學生氣的事情喔？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_005"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那當然是……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "來跟騎士同學",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_006"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "約會的呀★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "哇★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_007"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不愧是騎士同學，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "已經很習慣跟女孩子相處了呢──♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯～",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_008"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那我們要做什麼呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n坦白說我以為我九成會被拒絕，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以沒有任何計畫♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "原來如此原來如此★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "總之",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就先在這附近隨意逛逛吧♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那麼，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_010"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我們就恩恩愛愛地",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "緊緊貼在一起──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_011"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "又沒關係。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "明明騎士同學",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "身邊的女孩子",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n總是一個換一個──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而、",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_012"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "且、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呀──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n就算騎士同學說不要──？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嘿★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "像這樣──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_013"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n恩恩愛愛地",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "緊緊貼在一起──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好的★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_014"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n瞬間移動～",
        "unit_id": 192011
    },
    {
        "type": "background",
        "background": "500840"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_015"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n畢竟是值得紀念的",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學和我的初次約會？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以我好想吃些特別美味的東西──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而且",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_016"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我現在有點",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "想吃和風料理的感覺？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "新鮮生魚片之類的，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "很不錯吧★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊。",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_017"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可是可是，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我們沒有釣竿跟魚餌。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那麼──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嘿咻★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_018"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "鏘──♪",
        "unit_id": 192012,
        "voice": "vo_adv_1182001_019"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不是爆破捕魚，",
        "unit_id": 192012
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而是加特林機槍捕魚喔～★",
        "unit_id": 192012
    },
    {
        "type": "dialogue",
        "name": "船員",
        "words": "唔喔！？",
        "unit_id": 1,
        "voice": "vo_adv_1182001_020"
    },
    {
        "type": "dialogue",
        "name": "船員",
        "words": "\n你們搞什麼啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "偷渡客嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_1182001_021"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n剛才是躲在哪裡！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯──",
        "unit_id": 192012,
        "voice": "vo_adv_1182001_022"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n引起騷動了呢。",
        "unit_id": 192012
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊★",
        "unit_id": 192012,
        "voice": "vo_adv_1182001_023"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我想到了一個好點子♪",
        "unit_id": 192012
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192012
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "把這些人當成魚餌──",
        "unit_id": 192012
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_024"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "開玩笑的嘛★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那麼就再一次──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_025"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "抱住♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "喂！",
        "unit_id": 1,
        "voice": "vo_adv_1182001_026"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n──呃，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "消失了！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船員",
        "words": "幽、",
        "unit_id": 1,
        "voice": "vo_adv_1182001_027"
    },
    {
        "type": "dialogue",
        "name": "船員",
        "words": "幽幽",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船員",
        "words": "幽靈！？",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501140"
    },
    {
        "type": "dialogue",
        "name": "幽靈？",
        "words": "我～",
        "unit_id": 1,
        "voice": "vo_adv_1182001_028"
    },
    {
        "type": "dialogue",
        "name": "幽靈？",
        "words": "好～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幽靈？",
        "words": "恨～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幽靈？",
        "words": "啊～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幽靈？",
        "words": "～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呀──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_029"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好可怕★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n騎士同學，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "救救我──♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦？",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_030"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n才沒這回事呢──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "來嘛來嘛，你仔細看看，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_031"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我的手指和聲音",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "都在發抖……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……啊哈。",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_032"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也是呢──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_033"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n原本想說「在鬼屋做出像女孩子一樣的舉止吸引男友的目光」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n是約會的經典行程……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就算問我遊樂設施裡的幽靈可不可怕，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_034"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "終究只是人假扮的嘛？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "只要我想破壞他們，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "三兩下就能破壞掉呢──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "飾演幽靈的演員",
        "words": "咿……！？",
        "unit_id": 1,
        "voice": "vo_adv_1182001_035"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_036"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我知道的啦★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_037"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "跟我想的有點不一樣呢──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "接下來",
        "unit_id": 192011
    },
