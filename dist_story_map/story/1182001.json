    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "回想起來，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_079"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我們",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "總是在互相殘殺呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這個嘛，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "對於喜歡糾纏人的我來說，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n即使如此也很愉快。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "和騎士同學",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_080"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "戰鬥的理由已經消失了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我也是，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "與其說喜歡戰鬥，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不如說我是喜歡被人搭理。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那樣的話……",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_081"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我也可以用戰鬥以外的方法，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n讓騎士同學來搭理我吧～？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這樣★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……呵呵♪",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_082"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "當然，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不只是這樣喔。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為啊──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_083"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "看起來非常有趣不是嗎，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "戀愛這回事★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "蘭法姐也是，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_084"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學周圍的女孩子們也是。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "比我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還要可憐的那個人也是……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "大家都沉浸在愛情裡。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "一下開心。",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_085"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "一下臉紅心跳。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "一下痛苦。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "總覺得大家，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "都帶著活在當下～的表情呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我雖然",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_086"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不太懂戀愛什麼的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是看到大家這麼生氣勃勃的樣子，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我總覺得，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "很羨慕啊──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "所以，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_087"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "總之先試試？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也不是這麼說，不過──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我想試試看",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_088"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "愛上騎士同學──這樣★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊哈★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_089"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n說不定不懂比較好喔♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我覺得不懂就表示",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學很正常嘛。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……我",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_090"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呢？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n至今為止……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "放棄了很多事情呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "談戀愛之類的。",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_091"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n活下去之類的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真心喜歡上別人之類的、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "讓別人喜歡上我之類的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過──",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_092"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "在這之前。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "看到了不管發生什麼事",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "都不會放棄、繼續戰鬥的騎士同學你們。",
