    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就覺得那麼我也稍微試著……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不要放棄看看吧。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……緊抱★",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_093"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我",
