        "voice": "vo_adv_1182001_094"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "喜歡",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學喔？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是千真萬確的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果要談戀愛的話，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "對象是騎士同學就太好了呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可是可是……",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_095"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "悸動",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_096"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "的感覺似乎還不夠。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果「緊抱」深愛的人，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "心臟也會「揪」一下，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或是覺得",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「心動★」吧。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……果然，",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_097"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還沒。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n現在的我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "對騎士同學的感情不是愛，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而是比較像喜歡呢──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可是啊可是啊？",
        "unit_id": 192011,
        "voice": "vo_adv_1182001_098"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n就像剛剛說的，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我不會放棄的♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n為了愛上騎士同學，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我接下來會加油──★",
        "unit_id": 192011
    },
    {
