    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵♪",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生你……",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也過得好嗎？",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣，",
