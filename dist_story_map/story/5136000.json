    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不光是幫助我修行，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n甚至還讓我閱讀了好多文獻。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "文獻啊……",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那的確是在蘭德索爾讀不到的呢，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n得來精靈族之村才行。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "多虧這樣我學到了很多喔。",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "包括精靈的事、大自然的事，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有瑪那的事。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當然，",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我的知識量肯定比不上",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "精靈族之村的村民或可可蘿……",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但跟以前的我比起來，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在知道得更詳細了。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此……",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳學到了更深入的內容了啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "精靈的存在和其擁有的力量，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既有很多不明之處又很複雜。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我明白妳為什麼要待在這裡這麼久了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這的確是修行呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚嗚……",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_041"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n對我來說是有點累人的修行呢～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "發抖發抖發抖……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也是啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是修行的話，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論如何都會想活動身體。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "各位，",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_043"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你們。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n願意聽我這麼任性的請求。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過少了一人……",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "公會的委託",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是不是變得很難接？",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "其實啊！",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_044"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們也進行了修行喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就在妳待在精靈族之村的這段期間裡♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是、",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_045"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是這樣嗎？",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "夥伴在修行的時候，",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們怎麼能悠哉度日呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛好前一陣子，",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_047"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不是設立了冒險者用的訓練所嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以我們兩個就去參加了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n無論是冒險者",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "或是觀眾都有好～多好多人！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "由於是國家設施",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以設備很齊全，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n參加者的水準也很高。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是很適合試試身手的地方。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……這樣啊。",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_049"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n妳們也去修行了呢。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總覺得好開心♪",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那樣的話，",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_050"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "該不會……",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生所說的「背面世界」，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳們也都還沒去嗎？",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這還用說嗎！",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_051"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼能丟下優衣",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就跑去冒險呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_052"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我不是那個意思啦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抱歉喔，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們很清楚你的情況。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以別在意。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生……",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_054"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當時沒辦法馬上前往「背面世界」，",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_055"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真抱歉。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n難得",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你特地邀請我們。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只是……",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_056"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n在出發去冒險之前，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想先好好學習。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為了能夠",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_057"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "確實幫上大家的忙。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我想找出只有我",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "能做到的事。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……而這一點，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "肯定很難一邊冒險",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一邊進行……",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然在旅途中的訓練也很重要，",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但是沉下心來",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好好地鍛鍊自己，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是同等重要的事。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是這麼回事吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好～！",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_059"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那麼，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們馬上回蘭德索爾去吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "接下來的冒險要去哪，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就等那之後再思考！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣、怜",
        "words": "嗯！",
        "unit_id": 1,
        "voice": "vo_adv_5136000_060"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……但是，",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_061"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣真的可以嗎？",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想要……",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_062"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "去冒險。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這種事，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是我可以想的嗎……",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣，",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_063"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "行李都沒問題了嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有沒有漏掉什麼東西？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_064"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n啊……",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒問題。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "行李拿好了，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也跟村民們都道別過了。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……衣服？",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_065"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "維持？",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_066"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我的打扮",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有什麼奇怪的──",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊。",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_067"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我、",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_068"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我我……",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我……！！",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n一直都穿著這身衣服嗎！？",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一直都是那身打扮啊……",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_069"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳該不會是忘記了吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因、",
