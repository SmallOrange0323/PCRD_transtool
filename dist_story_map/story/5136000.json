        "voice": "vo_adv_5136000_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……能聽到你這麼說真是太好了。",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "501220"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊！",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n各位～！",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "日和、怜",
        "words": "優衣！\n優衣！",
        "unit_id": 1,
        "voice": "vo_adv_5136000_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大家，",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好久不見了。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n謝謝你們來接我！",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當然要來接妳囉～！",
