    {
        "type": "dialogue",
        "name": "旁白",
        "words": "厄莉絲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在錯綜複雜的念頭和因果的交織之下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n誕生於「阿斯特朗傳奇」的存在，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n最後成了「一切的元兇」。"
    },
    {
        "type": "still",
        "still": "513600002"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後……"
    },
    {
        "type": "still",
        "still": "513600003"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一個人，\n「草野優衣」。"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "501200"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_000"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在與厄莉絲戰鬥後，經過了一段時間……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優衣隻身前往精靈族之村修行。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………呼。",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就練到這裡吧。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "唉呀，",
        "unit_id": 6511,
        "voice": "vo_adv_5136000_002"
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "優衣小姐。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "\n妳好。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "\n妳在冥想嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳好。",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在正好結束了。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為我要準備回蘭德索爾，",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n還想跟村裡的各位道別。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "這麼說來妳回蘭德索爾的日子，",
        "unit_id": 6511,
        "voice": "vo_adv_5136000_005"
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "就是今天呢。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "\n時間真是一眨眼就過了……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "請妳一定",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "要再來玩喔。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "\n村裡的每個人",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "村裡的女性",
        "words": "都會歡迎妳的。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝妳。",
        "unit_id": 115611,
        "voice": "vo_adv_5136000_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我一定",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會再來的。",
        "unit_id": 115611
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與此同時。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "約定好要去接優衣的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}暫時從背面世界返回，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正與怜跟日和一同前往精靈族之村。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哼哼哼～♪",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n真想趕快見到優衣呢～♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和。",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n離得太遠會很危險喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要是突然有魔物衝出來就糟了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一想到能見到好久不見的優衣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不小心就……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我明白妳的心情。",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這幾個禮拜以來，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣和我們都很專心地在修行。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們過去從來沒有這麼久",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都沒見到面呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是這樣啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以才會覺得過了非常久吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}。\n你也沒有去見她對吧？",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那時大家都嚇了一跳吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n當優衣說她想去精靈族之村修行的時候。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n而且還是要一個人去。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然我沒有詳細地問……",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但她之所以這麼做，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然是因為厄莉絲吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……恐怕是吧。",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這樣想感覺是最合理的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當時──",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "打倒終炎巨神，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要前往索爾之塔塔頂的時候。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們和優衣分開了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嗯。",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n變成優衣和厄莉絲獨處了吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "然後……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當我們趕到時……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……厄莉絲，",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經消失了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我能理解優衣因為那件事，",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而想要變強的心情。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……就連現在，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她肯定也對厄莉絲的事感到很後悔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……包含我也是。",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "別說拯救厄莉絲了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我連幫助受傷的優衣都做不到。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在關鍵時刻卻沒辦法待在她身邊。",
        "unit_id": 100311,
        "voice": "vo_adv_5136000_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們明明是夥伴的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有比這更窩囊的事了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我的想法，",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是一樣的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當時一定有我們能做到的事。",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一定有我們能更努力達成的事才對……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我什麼都，",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "辦不到……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生……",
        "unit_id": 100111,
        "voice": "vo_adv_5136000_025"
    },
    {
        "type": "dialogue",
        "name": "日和、怜",
        "words": "…………",
