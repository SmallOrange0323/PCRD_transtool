[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算打倒了。",
        "unit_id": 105911,
        "voice": "vo_adv_9031156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位都平安無事吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幸好這次凱留小姐也沒有被麻痺。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "觸電的小凱留我也很喜歡喲！",
