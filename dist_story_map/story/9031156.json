        "voice": "vo_adv_9031156_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "連泳裝都換好了，幹勁十足的樣子呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一般在這個時候，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她都會馬上駁斥",
