    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是真的非常期待在這裡渡假呢。",
