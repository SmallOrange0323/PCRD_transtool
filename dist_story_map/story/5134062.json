    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "初夢",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "許願啊……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我當然",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是回歸",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "初衷，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "許願成為Big Boss啦。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聰明的幫派成員才不會三心二意改變目標。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要推翻那個混帳老太婆老大，",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "成為大人物──祈梨大人，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來統領家族全員……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "明年的第一道曙光，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是【龍族巢穴】的黎明！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以說，",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "立刻來睡覺吧……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼啊……",
        "unit_id": 128311
    },
    {
        "type": "still",
        "still": "513406201"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈～哈哈哈！",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n終於……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祈梨大人我，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n終於名符其實地，獲得了公會長之位……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "成為了",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "家族的老大啦～！！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……話說回來，",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒有人出來迎接耶？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "明明Big Boss祈梨都出來露面了。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管哪個傢伙都沒有來打招呼，",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是不成體統！",
        "unit_id": 128311
    },
    {
        "type": "still",
        "still": "513406202"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀～",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "抱歉我來晚了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "老大。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n因為剛才在處理緊急病患……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "終於來了啊……",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n為什麼是密醫來跟我打招呼？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳什麼時候變成【龍族巢穴】的成員了？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳在說什麼呢？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "祈梨妳從今天開始，",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就是【暮光流星群】的老大喔……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻♪",
        "unit_id": 102711
    },
    {
        "type": "still",
        "still": "513406203"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥啊啊啊啊啊啊！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n是發生了什麼樣的奇蹟才會變成這樣啊！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我完全無法理解！！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不論妳怎麼想，",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這就是現實喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說老大……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想測試新的藥草，",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳有沒有",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "認識可以為科學",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "犧牲奉獻的人呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還有，",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我去討伐了被懸賞的魔物，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是沒有地方能夠放我帶回來的頭顱……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是否能夠借用",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n公會小屋的倉庫呢……？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫！？",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不要把血淋淋的頭帶回來啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還有",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才不認識",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n願意被瘋狂科學家當成白老鼠犧牲性命的人！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "難道這邊沒有其他正經的傢伙嗎！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊。",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n七七香跟杏奈好像很缺錢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "她們到處在找妳喔。",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n說是想問能不能先借公會的錢去用，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等下次收到賞金就會還。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剩下的人也是，",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "完全沒有半個像樣的人嘛！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n亂花錢實在不好啊，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真的是……",
        "unit_id": 128311
    },
    {
        "type": "still",
        "still": "513406204"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這裡本來的",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "公會長",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n是怎麼管束這些傢伙的啊？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不管妳要怎麼哭喊，",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在妳就是公會長。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果發現妳不適任的話……",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就由我來請妳退場。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……嘻嘻♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是覺得不安的話，",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也可以讓我們",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n先從互相了解彼此開始喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來吧，",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "祈梨妳願意",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我診斷看看妳的身體嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我對龍人族的身體構造",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很有興趣呢～♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫～！？",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我幹不下去了！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "繼續跟她們處在一起的話，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "肯定會被大卸八塊，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不然就是被追究責任，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "送進牢房！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不當老大也沒關係，",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n讓我回去【龍族巢穴】啊～！",
        "unit_id": 128311
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才剛過新年，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就做了這種糟糕的惡夢……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "肯定是因為我在除夕夜跟她們扯上關係啦，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可惡！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才不想承認這個夢是初夢，",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n睡回籠覺再作一個新夢蓋過去吧……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼啊啊……",
        "unit_id": 128311
    }
]