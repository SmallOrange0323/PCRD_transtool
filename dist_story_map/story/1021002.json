    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個、那個……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雞蛋和、胡蘿蔔……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n高麗菜、小松菜……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還有、肉……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n五花肉，和帶骨的……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘿、嘿嘿……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今天也讓我負責出門採買了呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我總是受大家照顧，感覺很不好意思……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一直想要多幫點忙……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好開心喔，我要加油呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我不喜歡人擠人，而且對路也還不熟……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然有一點點，又會再迷路的感覺……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過沒、沒事的，今天我可是確實帶著地圖呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一定可以，順利回家的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n完成採買的任務，回到【咲戀育幼院】……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n大、大家會讚美我，不、大家會很高興……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "當我說「我回來了」，大家出來迎接我說「歡迎回來」時，",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "都讓我好、好開心……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這是最、最棒的獎賞了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦、咦？",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n地圖有在身上，但是採買的清單不見了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "、啊……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咦，是掉在哪裡了嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎怎、怎麼辦……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯、那個，",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒事的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要買的東西，我還記得……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雞蛋、胡蘿蔔，還有什麼……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "小偷！",
        "unit_id": 311,
        "voice": "vo_adv_1021002_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇呀！？",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不不不、不是的！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然我扭扭捏捏的，或許看起來很可疑……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但我不是小偷，也有帶錢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咦，是{player}哥哥……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，好久不見……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥還記得我嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我是住在【咲戀育幼院】，受到哥哥照顧的胡桃……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，是怎麼了呢……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥好像被店員揪著衣領……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "吵、吵架是不好的唷……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "啊～小妹妹，妳認識這傢伙嗎？",
        "unit_id": 311,
        "voice": "vo_adv_1021002_016"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這傢伙啊，想不付錢就把商品帶走咧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n可惡的小偷，我要把你交給警察還是【哞哞自衛隊】那裡去！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，哥哥，不可以偷東西喔……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、不付錢的話……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會、會被逮捕的……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，我來替他付錢……！",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這次就、拜託你、那個……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "嗯……",
        "unit_id": 311,
        "voice": "vo_adv_1021002_020"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n好吧，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "下不為例喔！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好、好的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對不起，哥哥也道歉吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥，為什麼要偷東西呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒有乖乖付錢是不行的唷……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃、咦……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥好像愣了一下……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥知道什麼是錢嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，不、那個……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n正常來說，這不是應該大家都知道嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，是的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，哥哥不是帶著錢嗎……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n把、把那個交給店員不就好了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣的話，就可以用錢來換得商品……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，哥哥聽得懂我在說什麼嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃、那個……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥是從哪個國家來的呀……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "無論是錢，還是買東西的方法都不知道嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，失去記憶……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是、是什麼事情都不記得的意思嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖、雖然我不是很清楚，不過好像很辛苦……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是、是不是生病了呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "喂～",
        "unit_id": 1411,
        "voice": "vo_adv_1021002_030"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n你們站在店門口聊天，會妨礙我做生意耶。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n啊嗚，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對不起……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯那個，這邊是在賣食物的對吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "對啊，要買些什麼嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_1021002_032"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n算妳便宜唷♪",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，但是……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n剛剛慌慌張張的，我都忘記要買什麼了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "而、而且錢，也因為剛剛幫哥哥付錢而全都用光了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥要替我出錢嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，相對地也要我教哥哥怎麼買東西……嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……",
        "unit_id": 102111,
        "voice": "vo_adv_1021002_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我知道了，真拿哥哥沒辦法呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
