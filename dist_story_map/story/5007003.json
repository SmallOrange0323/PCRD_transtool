    {
        "type": "dialogue",
        "name": "傑克",
        "words": "遺忘了真正的萬聖節！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "失去貢品後，",
        "unit_id": 10511,
        "voice": "vo_adv_5007003_038"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "我也失去了力量……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n最後……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "變成孤零零的一個人。",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "所以今年，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "我要對那些遺忘我的人類復仇！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "若不在當天、",
        "unit_id": 10511,
        "voice": "vo_adv_5007003_039"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "靈界之門關閉之前",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n找到附身的對象，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "我將無法使出全力。",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n得再等上一年。",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "一定要避免那種結果！",
        "unit_id": 10511,
        "voice": "vo_adv_5007003_040"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n附身在靈力強大的傢伙身上，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "等到萬聖節結束，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n我的靈魂就會和宿主的身體",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "完全合而為一！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "最後再把蒐集到的糖果",
        "unit_id": 10511,
        "voice": "vo_adv_5007003_041"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "當成貢品吃掉……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n我的力量就能夠完全復活！　",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "在現世大鬧一番！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n給這些愚蠢的人類",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "一些顏色瞧瞧！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "被人類所遺忘……",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_042"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "原來傑克有這樣的過去呢。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那傢伙，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "說不定也是個可憐的傢伙。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家也有點",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_043"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "了解傑克的心情……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "在人家遇見忍和你之前，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子也沒有朋友……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是，",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_044"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就算這樣，也不能奪取忍的身體啊！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子沒有做那種事，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "也和大家成為了朋友！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一個人吃布丁，",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_045"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "在蘭德索爾閒逛雖然很開心，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "但認識大家以後，比原本還要開心好幾倍！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以，",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_046"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家一定要阻止傑克！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n按照這本日記的內容，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "若不在萬聖節結束前\n處置傑克的話，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍就永遠回不來了！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍會變傑克，傑克會變成忍來的～！",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_047"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那怎麼可以！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子的忍會消失不見來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個身體的主人",
        "unit_id": 108111,
        "voice": "vo_adv_5007003_048"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的那麼重要嗎？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍！？",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_049"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……不對，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是傑克來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我接到我手下魔物的報告，",
        "unit_id": 108111,
        "voice": "vo_adv_5007003_050"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說城堡裡有侵入者。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n回來一看，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "果然是妳們～",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是厚臉皮。",
        "unit_id": 108111,
        "voice": "vo_adv_5007003_051"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不但闖進城堡，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還偷看了我的日記！",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你這種擅自進入別人身體，",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_052"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n搶走小孩的糖果，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n拿走宮子布丁的傢伙",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒有資格說人家！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一定要搶回來！",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_053"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n不論是布丁，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "還是忍！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嘿嘿嘿，",
        "unit_id": 108111,
        "voice": "vo_adv_5007003_054"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "搶得到的話……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳就來搶吧～！",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "傑克，",
        "unit_id": 108211,
        "voice": "vo_adv_5007003_055"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你這樣是不對的！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳再等一下！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n人家一定會救回妳的身體的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了要救忍，{player}和宮子\n向傑克下了戰帖。"
    }
]