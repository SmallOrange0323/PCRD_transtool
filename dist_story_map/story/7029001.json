    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "跟隨開心地環顧四周，一面走在前頭的帆稀，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與雪菲慢慢地在塔的內部前進。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此原來如此。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大致上的構造，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就跟嘉夜和祈梨說的一樣呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真是的……",
        "unit_id": 106412,
        "voice": "vo_adv_7029001_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n如果是打算去露娜之塔冒險，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳應該一開始就直接告訴我們的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抱歉哦～",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n雪菲妳剛才不是也說了嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n有趣的地方妳想和大家一起去。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "回到公會小屋後，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳或許可以試著邀請大家呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "遊樂園或度假村都好。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我想她們一定會很高興的～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我會試試看的。",
        "unit_id": 106412,
        "voice": "vo_adv_7029001_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不知道大家會比較喜歡哪一邊呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不對！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲，抱歉哦，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先暫停一下。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n好像有客人來了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先讓不請自來的客人退場吧♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看～招！",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲可以一起幫忙嗎？",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我知道了。",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n至少讓我們能夠靜下來好好說話吧！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──呀啊！",
        "unit_id": 106411
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呼……",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣就結束了嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哇啊啊！？",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n根本還沒結束……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別搗蛋～☆",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_011"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是一樣厲害……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "敵人好像還會攻過來。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "接下來也只靠我們三人往上爬嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是下次再來──",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別擔心別擔心，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "難得都來到這裡了，就再多加把勁吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n如果是我和雪菲，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是不可能會輸給這種魔物的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們可是最強的龍人族。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "更重要的是──",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想問你一個問題……",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你知道這座露娜之塔，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是什麼樣的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "存在嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "說得也是呢～",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實我也不曉得♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為這座塔",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "實在是很異常的存在。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然至今為止，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我因為想探索",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而來過好幾次，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但能像這樣順利進來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "說起來還是第一次呢～",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說，",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳想談的事會講很久嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在正在戰鬥中喔……！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我知道哦～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲妳不是也很在意嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n明明是如此高聳的巨塔，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "卻在來到近處之前都沒發現它的存在。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我是",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很在意沒錯。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但那件事需要現在談嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是說，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和這裡的魔物有什麼關聯嗎？",
        "unit_id": 106411
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好了好了。",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別著急別著急♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這點程度不算什麼啦♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……這座塔",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "即使是在充滿謎團的阿斯特朗，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也是特別不可思議的地方。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要進入這座塔，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "必須和特定的人物一起行動才行喔，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我猜。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯。",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果不是跟你一起來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別說是進入這座塔內，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就連它的存在都無法察覺。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是不是被設下了這樣的機關呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我一開始",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還以為是我認識的某個人",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "做的好事吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但該說是手法",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有點太普通了嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是那種感覺，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓我覺得好像不太對。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦咦……？",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我倒是覺得把這樣的塔隱藏起來",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一點都不普通……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以這並不是",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "單純的惡作劇",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或找麻煩，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n而是身在某處的某人",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為你打造的地方……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這算是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的猜測吧。",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你是不是",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_025"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有想到什麼人……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n呃，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看你的表情是人選多到困擾呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想再重新拜託你們，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以幫我",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一起調查這裡嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n用了",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像是欺騙你們的方式，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我真心",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "覺得很過意不去哦～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真是的……",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我剛才也說過了，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "希望妳一開始就直接告訴我。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只要妳不嫌棄，我都會盡量幫忙的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟帆稀小姐之前幫助了我，",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_028"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這次輪到我幫助妳了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲……",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有你，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你們真的是好孩子呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "說得也是～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n一般通常該這麼說吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對不起～",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我一不小心",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就照平常的習慣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "做了拐彎抹角的事。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "若是不這麼做，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很多時候",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都沒人願意聽我的請求。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "平常的習慣……",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨她呀，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要我態度一放軟，就會被她爬到頭上呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果不在她察覺之前",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓她落入我的計劃裡，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n她是不會乖乖聽話的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦咦……",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_034"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "平時都是這個樣子嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那會不會",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有點可憐呢……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是呀～",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_035"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嘉夜就是這樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n一旦",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒有戰鬥，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她就會明顯表現出沒什麼幹勁的樣子。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是偶爾像這樣給她驚喜，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n帶她去魔物",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "會出現的地方，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她就會非常高興～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以我就忍不住",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "隱瞞目的地了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是、",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_037"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是這樣啊……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "既然她喜歡，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那就好了吧……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "事情",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是這樣……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是最後一隻了！",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的在說話的過程中就全部打倒了……",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_039"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n即使如此，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "她的呼吸也一點都沒亂……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不出我所料呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們繼續前進吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_041"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那邊是死路──",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……咦咦！？",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_042"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那種地方居然有隱藏樓梯……！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "快點快點，",
        "unit_id": 106711,
        "voice": "vo_adv_7029001_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "得動作快才行。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這座塔",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可能很快就要消失了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我們可不能太悠哉哦～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦，",
        "unit_id": 106411,
        "voice": "vo_adv_7029001_044"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦咦咦？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等等，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那到底是什麼意思……",
        "unit_id": 106411
    }
