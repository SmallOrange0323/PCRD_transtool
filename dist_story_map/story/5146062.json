[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "頭を冷やすべく街を散策していたクレジッタの元に、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n良くない知らせが届けられた。"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あーもうまったくもう！　",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_000"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "なんてことですの！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nやっぱり予感が的中しましたわ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "頼んでいた高級チーズの手配ミスだなんて！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "わざわざ国外のブランド品を発注したのが間違いでしたわ……",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_001"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "輸送中のトラブルに",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "受注数量の読み違え……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ダブルパンチなんて聞いてませんわよ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "こちらから受け取りに行く……？　",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_002"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "さらに高値で買い占める……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いいえ、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "どっちも間に合いませんわね……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "とはいえ、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あのレベルのチーズが他で手に入るかというと……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "お姉さんお姉さん、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_003"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "チーズのことでお悩みだべか？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "そんならうちのチーズ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "いかがだべ？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "え？",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_004"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……悪いけど、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_005"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "今子どものお店屋さんごっこに付き合っている暇は",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nありませんの。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "急いでますので、失礼。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ま、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_006"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "待ってけろ！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "オラ、立派な大人だど！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "それに、【牧場】ってギルドのギルドマスターやってるべさ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "今日は大人気のチーズを売りに来てんだ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ということは、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_007"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女のとこの商品を売り込むつもりですわね。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "確かに路線変更して地産地消で売れば、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n地元産の地味なチーズでもあるいは……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "しかし",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_008"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "街の商店に卸すのならともかく、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nわたくしのクリスマスに相応しいかどうかというと疑問ですわね。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "贈答用や高級料理に使える品じゃなくては意味がありませんわ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "疑うなら一度試食してみてけろ。",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_009"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\nしたっけお姉さんもぜってぇ気に入るはずだべ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ささ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "どうぞどうぞ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……はぁ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_010"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そもそも気分転換で街に来たんですから、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nちょっとくらいなら付き合って差し上げますわ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あ、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "む……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "え？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nな、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ななななんですの、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これ……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "なんまらおっかねぇ顔してるけんど……",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_011"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\nこれは……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "オラ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ウッカリしただか……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "もしやまた、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "牧場没収されたりしちゃうべか……！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "くっ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_012"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "よもやランドソルにこれほどの品があったなんて……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "【牧場】のチーズ、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いけ好かない貴族どもが騒いでいるだけだと",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n甘く見ていましたわ……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これはわたくしの調査不足ですわね……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……貴女、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_013"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "お名前は？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "オ、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_014"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "オラはマヒルってんだ……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "頼む、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "許してけろ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n牧場と命だけは",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "取らね",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ぇでけろ……！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "はぁ？　",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_015"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……何言ってるんですの？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "マヒルさん、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女のところのチーズ、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nぜひ今度のクリスマスイベントで取り扱わせてほしいのですが。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ほ、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_016"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ほんとだべか！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "もちろんお願いするべさ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "……って、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "取り扱い……？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\nさっきまで、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "なんまらおっかねぇ顔してたのに？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あれは己の不明を恥じたまでですわ。",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_017"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女のことを怪しげな行商人と甘く見たことはお詫びします。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "早速ですけど、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "仕入れのご相談をさせていただけますわね？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "お？　",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_018"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ええと、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "いつもは……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "こんなとこだべか。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "はああああああっ？　",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_019"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女バカにしてますの！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "え、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_020"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "オ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "オラなんか悪いことしただか？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_021"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええ！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "悪いですわよ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "極悪ですわよ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nこれほどのクオリティのチーズを、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nこんな安値で売るなんてどうかしてますわ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "そ、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_022"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "そうだべか……？　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "でもオラ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "安く提供して",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "たくさんの人に",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n手に取ってもらって、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "笑顔になってもらいてぇんだけど……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女の言いたいこともわかりますし、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_023"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "立派な志だと思いますわ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nでも、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これほどのチーズを作るには手間もコストも必要なはず。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これから先もみんなにおいしく食べてもらいたいなら、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_024"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n儲けられる機会にちゃんと儲けておきなさい。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "むやみに安売りするのは、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "客にも失礼ですわよ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "多少高くとも必ず買ってくれる。",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_025"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女には",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そういう顧客がついているのではなくて？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "だな。",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_026"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "お姉さんの言う通りだべ。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "でも……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "先ほど出会ったばかりですが、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_027"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n貴女の無欲ぶりからして",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "きっと儲けたところで",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n無駄遣いなどなさらないですわよね？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "も、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_028"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "もちろんだべ！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "そんなつもりで作ってねぇべさ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "それなら儲けた分は",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_029"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "設備投資や仲間にボーナスでもあげなさいな。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そうすれば巡り巡って",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "お客にもしっかりと還元できるはずですわよ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "お、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_030"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "お姉さん、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "スゲェ人だべな……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "オラ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "そこまで考えてなかったべさ……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "商人ならこれくらいのことは考えて当然ですわ。",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_031"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n売り方はわたくしが考えます。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "だから貴女は",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "おいしいチーズを作りなさい。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "わかっただ！　",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_032"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "お姉さんなら信用できるべ。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "よろしく頼むど！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "あ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "そういえばお姉さんの名前、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "まだ聞いてなかったべ。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "申し遅れましたわね。",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_033"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "わたくしクレジッタ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nランドソルの行政長官を務める",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "クレジッタ・キャッシュですわ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "よく覚えておきなさいな、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "マヒルさん。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "クレジッタ……",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_034"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ならクレクレだな！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "改めてよろしくだべ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "クレクレ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ク、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_035"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "クレクレ！？　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いきなりあだ名とか距離感おかしいですわよ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nそれに",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "クレクレって",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "物乞いみたいじゃありませんこと！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "すぐにお止めなさい！",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_036"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nさもなければ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "付き合いを考えさせていただきますわ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ちょっと待ってクリーム！　",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_037"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "せっかく構ンベールてくれたんだべさ、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "チーズで結ばれた縁、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "今後とも",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "よろチーズだべな！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ひいぃ！　",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_038"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "寒い、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "寒すぎますわ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "つまらないダジャレはやめなシャレ……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あっ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "お、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_039"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "クレクレ結構いけるでねぇか？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ち、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_040"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "違いますわ！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これは貴女につられただけで……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "なぁ、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_041"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "オラとお笑いコンビくまねぇか？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ビジュアル的にもいいデコボココンビになると思うべさ！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "絶対にお断りですわ！　",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_042"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "もう破談ですわ破談！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n貴女とはやってられませんわ……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ってもう！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nこれじゃ漫才のオチじゃございませんこと！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "あはは！　",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_043"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "やっぱりクレクレはお笑いの素質があるべ！",
        "unit_id": 103311
    }
]