        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對齁，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}你失去記憶了～！",
