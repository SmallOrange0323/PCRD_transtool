    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和【哞哞自衛隊】的成員們，乘船渡海來到海水浴場。\n真步一行人換上泳裝後，正在海灘上做準備。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為了避免太陽直接照射，",
        "unit_id": 110611,
        "voice": "vo_adv_5021001_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "插上遮陽傘",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "吧。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好，",
        "unit_id": 110611,
        "voice": "vo_adv_5021001_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣就行了。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好久沒出來玩了，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大家的心情好像都很不錯呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "風也很舒服，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是適合去海水浴的日子呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼、",
        "unit_id": 110411,
        "voice": "vo_adv_5021001_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼……",
