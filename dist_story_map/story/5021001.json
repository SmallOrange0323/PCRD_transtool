    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是、",
        "unit_id": 110411,
        "voice": "vo_adv_5021001_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是那樣沒錯啦……",
