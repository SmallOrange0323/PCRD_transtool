    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 110511,
        "voice": "vo_adv_5021001_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "　怎麼了～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "　真琴和真步的臉都好紅～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "算啦不管了，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
