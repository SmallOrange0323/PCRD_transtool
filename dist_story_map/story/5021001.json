    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "稱讚我們",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也可以的唷？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們今天穿的泳裝",
        "unit_id": 110611,
        "voice": "vo_adv_5021001_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼樣。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您看，",
