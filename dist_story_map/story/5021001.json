    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是個很好的暖身操呢～！",
        "unit_id": 110511,
        "voice": "vo_adv_5021001_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "吶公主，",
