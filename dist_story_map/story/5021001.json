    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴在公會裡，",
        "unit_id": 110511,
        "voice": "vo_adv_5021001_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也算是個相當喜愛玩偶的人呢～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哇哇哇不准說，香織！",
