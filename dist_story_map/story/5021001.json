    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "和瑪爾傑海岸有種截然不同的氛圍呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這片大海。",
