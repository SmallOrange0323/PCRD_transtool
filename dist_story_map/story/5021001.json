    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不可以排擠它們唷。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "畢竟真步真的很重視這些玩偶呢～",
