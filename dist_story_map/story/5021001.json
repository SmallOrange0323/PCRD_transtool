    {
        "type": "dialogue",
        "name": "真琴",
        "words": "想不到",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然要把公會小屋裡的玩偶",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n全部都給帶過來……",
