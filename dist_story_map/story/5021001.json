    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "夥伴多多，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "充滿活力很開心呀～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也知道公主很愛惜這些玩偶啦。",
