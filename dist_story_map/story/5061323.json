[
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼、",
        "unit_id": 115911,
        "voice": "vo_adv_5061323_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這傢伙實在是強得嚇人……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的呢～",
        "unit_id": 116011,
        "voice": "vo_adv_5061323_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再這樣下去，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們所有人都會被擊倒的～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "呵呵，",
        "unit_id": 7011,
        "voice": "vo_adv_5061323_002"
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "如果妳們沒有異想天開地",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "想跟妾身溝通的話，",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "\n這就會是一場更實際的對決吧。",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "\n",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "要是妳們還想繼續堅持，",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "最好要有決心這將會是一場性命的爭奪戰！",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為什麼……",
        "unit_id": 115811,
        "voice": "vo_adv_5061323_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為什麼妳要對戰鬥這麼執著！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳不是有心也會說話嗎！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "再戰鬥下去沒有任何意義啊！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "不要說得妳好像很懂！",
        "unit_id": 7011,
        "voice": "vo_adv_5061323_004"
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "這裡的支配者是妾身。",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "\n如果想達成妳們的心願，",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "就先用刀刃打倒妾身後再說！",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……啊啊，",
        "unit_id": 115811,
        "voice": "vo_adv_5061323_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我能夠明白。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "公主殿下那強烈的戰鬥意志，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n透露出了",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她對自己的姿態，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "以及對自己的心沒有自信。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我很了解",
        "unit_id": 115811,
        "voice": "vo_adv_5061323_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳的心情。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "光靠武力是不會有任何改變的。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n必須懷著自信，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "展現出活得像自己的美好才行！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為此……",
        "unit_id": 115811,
        "voice": "vo_adv_5061323_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我要先打倒妳！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n然後，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "引領出妳真正的心聲！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "呿，",
        "unit_id": 7011,
        "voice": "vo_adv_5061323_008"
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "妳以為那種歪理，",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "妾身會乖乖聽下去嗎！",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我要上囉，",
        "unit_id": 115811,
        "voice": "vo_adv_5061323_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳這個不聽人說話的公主！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，公主，",
        "unit_id": 115911,
        "voice": "vo_adv_5061323_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們好像也沒時間休息了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是啊。",
        "unit_id": 116011,
        "voice": "vo_adv_5061323_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們是",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪的支援。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就讓她見識一下",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "【哞哞自衛隊】的意志力吧～",
        "unit_id": 116011
    }
]