[
    {
        "type": "background",
        "background": "500800"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_2013005_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別就把我們冷落在這，然後就妳們自己鬧得這麼開心啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n給我好好說明清楚。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那位惹人憐的女孩子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "究竟是誰？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是叫似似花……",
        "unit_id": 106113,
        "voice": "vo_adv_2013005_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯吧，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是真軌他們去救的那個",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "『七冠』！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還記得我的事情嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……嗯，",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "某種程度來說。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但是我在",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「再構築」的時候，也只有守住三成左右的記憶，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剩下的多是靠著推測填補而來的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有將『前世』的記憶幾乎完整地保存下來的，",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n或許就只有妳了也說不定呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "諾維姆。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "儘管推測是因為妳擁有的超能力，",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "實際上是如何也無法知道呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算試著調查過【森林守衛】成員的那位超能力者，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n且進行過了考察後，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "仍舊連我也依然無法理解原理呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊。",
        "unit_id": 106113,
        "voice": "vo_adv_2013005_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "光是妳還記得諾維姆這個名字我就很高興了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "其他的人就連這件事都忘掉了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n大家都是用登錄在我戶籍上的名字……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "用『矛依未』來叫我的嘛。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想也是如此。",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶與真那先不談，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "光是克莉絲，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不論怎麼想，對「再構築」所造成的影響都是毫無招架之力吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "一直以來妳就是太過於天真，",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以才總是在緊要關頭失足呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克莉絲。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然沒有很懂，",
        "unit_id": 107111,
        "voice": "vo_adv_2013005_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但妳現在是在罵我對吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想吵架我可奉陪到底喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "現在不是自己人鬧內鬨的時候了吧，",
        "unit_id": 190711,
        "voice": "vo_adv_2013005_009"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "大嬸。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別客氣，",
        "unit_id": 107111,
        "voice": "vo_adv_2013005_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你就叫我一聲克莉絲姐姐也無妨唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你別來無恙呢，",
        "unit_id": 107111,
        "voice": "vo_adv_2013005_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你這小子總是一股腦的亂衝亂闖過了頭，看來是易於喪命的嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可讓人稍稍為你擔憂了些呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "嘿，",
        "unit_id": 190711,
        "voice": "vo_adv_2013005_012"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那妳就白操心了唷。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "雖然這樣說，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但老實講其實還真的蠻不妙的呀。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "和一開始預定的一樣，",
        "unit_id": 190711,
        "voice": "vo_adv_2013005_013"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我和拉基拉基兄一起，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n為了要破壞那洗腦魔法裝置所以大鬧了一番……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n但突然間在裝置裡頭睡得好好的那傢伙，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那霸瞳皇帝張開了眼啊。",
        "unit_id": 190711
    },
    {
        "type": "still",
        "still": "201300501"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那臭傢伙……",
        "unit_id": 190711,
        "voice": "vo_adv_2013005_014"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "明明就還躺在裝置裡頭，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n竟然毫不猶豫的就扔出攻擊魔法了呀。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "被那發偷襲擊中之後，",
        "unit_id": 190711,
        "voice": "vo_adv_2013005_015"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我和拉基拉基兄就完全沒轍的昏了過去。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "可惡，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "真丟人啊……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我明明就對自己強壯的身體挺有自信的啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我也深有同感。",
        "unit_id": 107311,
        "voice": "vo_adv_2013005_016"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n著實來講，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "敵人的力量",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "遠遠超過了這邊所能夠料想的程度。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "面對用無法反應的速度",
        "unit_id": 107311,
        "voice": "vo_adv_2013005_017"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "攻來的魔法連擊，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我們",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "似乎相當輕易地就昏厥過去了的樣子。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "原以為霸瞳皇帝是",
        "unit_id": 107311,
        "voice": "vo_adv_2013005_018"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "驅使著智略，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n使他人陷於計策之中的策士類型……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "看來他也不是省油的燈，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "就連武勇也絲毫不遜色呢。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你誇獎敵人是搞～什麼？",
        "unit_id": 190711,
        "voice": "vo_adv_2013005_019"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "可惡呀，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那個臭傢伙……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n下次如果讓我遇上了一定要揍扁他一頓！",
        "unit_id": 190711
    },
    {
        "type": "background",
        "background": "500800"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊哈哈。",
        "unit_id": 106113,
        "voice": "vo_adv_2013005_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放心吧大吾，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能讓你復仇的機會",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "意外的說不定很快就到了呢。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛剛，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真那……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "霸瞳皇帝他，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n朝著城鎮中心飛去的樣子被我們看到了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然不知道那傢伙到底想要幹嘛，",
        "unit_id": 106113,
        "voice": "vo_adv_2013005_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但也絕對不會是什麼好事情嘛……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "得阻止他呀，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓我們所有人同心協力。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "好咧！　",
        "unit_id": 190711,
        "voice": "vo_adv_2013005_022"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我可不會再輸了啊，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "不對，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "在還沒真的覺得是輸掉了以前都還不算輸啊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "只要最後贏了就算贏了嘛！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "呵呵。",
        "unit_id": 107311,
        "voice": "vo_adv_2013005_023"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "如此的思考方式",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "並不令人厭惡，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n大吾的發言",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "偶爾會說出真理呢。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……。",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_024"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……有什麼事嗎？",
        "unit_id": 107311,
        "voice": "vo_adv_2013005_025"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "小姐？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n您一直盯著我瞧，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "難不成是我的臉上有些什麼嗎？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不。",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "拉基尼卡東對吧……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n然而你的言行舉止，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "卻和我腦中的記憶不一致。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "似乎有種異樣的感覺，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唔～呣？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也罷，",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這事兒就先擱一邊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "霸瞳皇帝究竟有何打算也令人相當在意，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "挺令人不安。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該要追上去呢。",
        "unit_id": 107011,
        "voice": "vo_adv_2013005_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真軌……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我現在沒有辦法行動，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你來背我吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "好的！樂意之至！",
        "unit_id": 191011,
        "voice": "vo_adv_2013005_029"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "吾之君主，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "就由下臣來成為護送您前行的馬車吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘻嘻。",
        "unit_id": 106113,
        "voice": "vo_adv_2013005_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總之看起來每個人的小命都還保住了嘛，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n光這一點就已經很不錯了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我這可算是真的很擔心妳們的啊～……",
        "unit_id": 106113,
        "voice": "vo_adv_2013005_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也不是悠哉地講這種話的時候了嘛。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "得趕緊追上真那，",
        "unit_id": 106113,
        "voice": "vo_adv_2013005_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "追上那個霸瞳皇帝才行！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然不是很清楚那傢伙到底是飛向哪裡，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但還是知道大致的方向，所以就由我來帶路吧！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還能動的傢伙",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟我來！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好好。",
        "unit_id": 104911,
        "voice": "vo_adv_2013005_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這還真是的呀，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天看起來會成為相當漫長的一天呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "別發牢騷了我們也趕緊跟上吧，",
        "unit_id": 101112,
        "voice": "vo_adv_2013005_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所謂『打鐵趁樂』的那個嘛！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可惜差一點！",
        "unit_id": 104911,
        "voice": "vo_adv_2013005_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是『打鐵趁熱』唷，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下等人，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也與諾維姆小姐她們一同吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說得也是呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然想要把那昏睡中的小凱留，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n帶到哪個安全的房子中讓她好好睡一覺。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……。",
        "unit_id": 106015,
        "voice": "vo_adv_2013005_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完全沒有要醒來的跡象呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真令人擔心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n很擔心很擔心，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都讓在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "胸口擔心到快要裂開了一般。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這可不行呀，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若您惡作劇的話，就是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『壞壞』",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐會如此的深眠，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大概是不久前如此地大鬧了一番",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所導致的疲憊造成的吧……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如今，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓她好好靜靜地睡上一覺吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請您務必要早點甦醒過來呀。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而在那一刻到來前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人必定會伴於您身邊的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哇哇！",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然在這個節骨眼讓肚子叫出聲音來了呀！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……？",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……！",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n原來如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是因為我穿著『皇家裝備』啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難怪感覺已經很久沒有肚子叫得這麼大聲過了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是在{player}和小可蘿，",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n他們倆趕到牢房那把我救出來之後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們在前往王座之廳的途中才把這裝備拿回來的嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然說是自己的東西，",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但擅自把放在王宮裡頭的東西拿走，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總覺得",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不像是個公主殿下該做的事情就是了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若說要當回那個尤絲蒂亞娜‧F‧阿斯特賴亞，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還得要再稍微等一等了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在的我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是做為【美食殿堂】的貪吃佩可來面對戰鬥的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您愣在那兒",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是有什麼在意的事嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這種時候可是不能夠停下腳步的嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓我們趕緊追上大骨先生他們吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說得也是呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳怎麼了嗎？小可蘿？",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n竟然看著我笑了出來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難不成是我的臉上沾到飯粒了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要說有吃到白飯這件事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是好一陣子之前的事情了呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊沒有，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是在下失禮了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在見到貪吃佩可小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您穿回了『皇家裝備』之後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更是覺得這個樣貌",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才是最適合您的了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "見到您這個令人懷念的樣貌，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就連在下也不禁開心了起來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n於此再次鄭重地向您說道……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "歡迎您回來，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常謝謝妳！",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這都是小可蘿和你的功勞唷，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以那個肚子餓得咕嚕咕嚕叫的貪吃佩可才復活了唷☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過……",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】的那個貪吃佩可，",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還不能夠復活呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得等到我和小可蘿和{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留 4 人全部都到齊了以後才行呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105913,
        "voice": "vo_adv_2013005_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說的是！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們",
        "unit_id": 105812,
        "voice": "vo_adv_2013005_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也出發吧，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了讓每個人都能夠再一次，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一塊享用那美味的食物！",
        "unit_id": 105812
    }
]