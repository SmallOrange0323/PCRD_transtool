[
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "切嚕～～～～～～～～！",
        "unit_id": 13211,
        "voice": "vo_adv_5038301_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "吵死了。",
        "unit_id": 110811,
        "voice": "vo_adv_5038301_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n&遜斃了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的是遜斃了。",
        "unit_id": 110911,
        "voice": "vo_adv_5038301_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n遜斃了的聚合物。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那個連琪愛兒都無法接受。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_5038301_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "該怎麼說呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它那在時代裡逆行的模樣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "甚至會讓人產生某種鄉愁。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也許這是種對總而言之講求一致性的現代美感的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "反命題也說不定。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼跟什麼啊，真搞笑。",
        "unit_id": 110811,
        "voice": "vo_adv_5038301_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n學姐，妳搞不好能成為美食解說員。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就算難吃得要死的料理感覺妳也能面不改色地捧上天。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果硬要讚美那個東西的話，",
        "unit_id": 110911,
        "voice": "vo_adv_5038301_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n最多也只能稱讚它模仿了這時代的時尚教主琪愛兒的那部分而已。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這孩子真是太淺了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "竟然以為只要粉紅色配上切嚕～就能裝成琪愛兒。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來琪愛兒不是只有粉紅色跟切嚕～啊？",
        "unit_id": 110811,
        "voice": "vo_adv_5038301_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯！　",
        "unit_id": 111011,
        "voice": "vo_adv_5038301_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "玩鬧就到這裡為止了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它要來了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來吧，同志，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學習的時間到了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n麻煩你用一直以來的那個學術性強化。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有什麼湧現出來了～～～！",
        "unit_id": 111011,
        "voice": "vo_adv_5038301_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n哇，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇啊啊啊啊～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n突擊～！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "跟在我後面～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～",
        "unit_id": 110811,
        "voice": "vo_adv_5038301_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真是的，防禦力跟小嘍囉一樣的傢伙別一個人衝過去……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐真的是",
        "unit_id": 110911,
        "voice": "vo_adv_5038301_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只要一接收到學長的強化",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就會這樣莫名發狂耶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "琪愛兒，",
        "unit_id": 110811,
        "voice": "vo_adv_5038301_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要上囉～。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n要是讓學姐站上前線的話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等一下她又會哭著跑回來的。",
        "unit_id": 110811
    }
]