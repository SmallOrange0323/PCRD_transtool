[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這次的菜單，",
        "unit_id": 126511,
        "voice": "vo_adv_5213066_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是炸點心。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "將加入大量小麥粉與奶油製成的麵糰，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "放入砂糖椰子的香甜油脂中油炸後，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n便能做出一款口感酥脆，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "帶著樸實甜味，讓人上癮的點心。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "只要咬上一口，",
        "unit_id": 126511,
        "voice": "vo_adv_5213066_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "立刻就會湧起一股",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "懷念而溫柔的心情……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "從孩子到大人，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "無論是誰都能像被幸福包圍一樣，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n就讓我將這道經典點心，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "獻給各位享用吧。",
        "unit_id": 126511
    }
]