[
    {
        "type": "background",
        "background": "500151"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呼……\n總算是修好柵欄的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊真是的，到處都變得老舊的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "畢竟這也是個歷史悠久的牧場啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "似乎是從我好幾代前的祖先開始，就一直在這塊土地上畜牧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也沒什麼業者願意來到這種深山，\n就算來了也要多收費用……",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n變老舊的地方就只好自己修了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "託這點的福，我也變得很擅長做這種木工了啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，滿身塵土又流汗……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這樣根本不會有人想要娶我的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總不能讓\n【伊麗莎白牧場】長久延續下來的歷史，",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在我這一代畫下句點。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我得釣個好女婿\n來當繼承人才行。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可～是……我對這件事實在沒什麼興趣的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我得向莉瑪莉瑪學習，培養一點女人味才行。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看來也應該要好好打扮一下？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔，{player}！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n怎麼了啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n來【伊麗莎白牧場】有什麼事嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥該不會是\n為了要看我表演相聲特地上山來的吧？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～真害羞的啦！\n竟然有死忠粉絲，看來我也是個傑出的搞笑藝人的啦～♪",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，不是那樣？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，我只是搞笑一下而已……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯嗯，在做送信的工作啊？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥是為了送信到我們牧場跟精靈族的聚落，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n而在山區來回嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇，那真是辛苦的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的很勤勞耶，了不起、了不起。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n看來{player}不會讓老婆過苦日子的啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？\n因為牧場的設備變老舊了，",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我在當臨時木匠修理它們。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然這些東西，老早就過了使用年限了……",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n到處都破破爛爛的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還想找機會全部打掉，重建一次呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不行～{player}也還在工作吧。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n先做完自己的事情再幫助別人吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過好意我就心領啦～謝謝♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，{player}也是啊～",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過我也沒那麼辛苦的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n最近莉瑪莉瑪也會幫忙。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那孩子很有臂力，幾乎不需要男生來幫忙了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪、鈴鈴和栞栞都算只是住在這裡……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嚴格來說，\n她們不是【伊麗莎白牧場】的職員。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以讓她們工作其實是很不好意思的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，只要我加倍工作就好的啦♪ ",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇？\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為、為什麼要摸我的頭～？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，「這麼小就很了不起」？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我說過好幾次了，我的年紀可是比老哥大喔？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘻嘻。\n老哥，等我一下。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我有好東西要給老哥的啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊……為什麼拍手？我沒有要表演搞笑短劇啊。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唉呀，老哥想看的話我也是可以表演的啦，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但最近太忙了，都沒時間練習搞笑。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對不對……\n我要拿鮮奶給老哥喝的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥爬山上來，應該渴了吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現擠的鮮奶可是超美味的啦～",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n和市面上那些經過殺菌處理的不同，營養滿分。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鮮奶就是生命力的啦～哼哼♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "反正擠太多牛奶出來，最後也得丟掉。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，法律是那樣規定的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喝吧喝吧，不用客氣♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇哇……\n為、為什麼要飛撲過來啦！？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不能調皮搗蛋，我會修理老哥啊？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，我是說牛的奶，不是我的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還不會分泌母奶的啦……！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是的……\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥有時候真的很跳脫常識啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不，等等，剛剛那是在搞笑嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呃啊，我怎麼做了那麼無聊的反應啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯……看來老哥很天真啊。",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但那也是種才能，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可以搞笑搞到像呼吸一樣自然，真羨慕耶。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}，如果對搞笑有興趣的話，要當我的搭檔嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我正好在找搭檔的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，好好考慮一下吧～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "先以搞笑組合的關係建立羈絆，\n之後再來當我的老公……",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "開、開玩笑的啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛、剛剛那也是搞笑的啦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果老哥要當我的搞笑搭檔，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不吐槽的話，我會很傷腦筋的啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈，可以像這樣幻想未來的事情真是幸福的啦♪",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘿咻、嘿咻……",
        "unit_id": 103311,
        "voice": "vo_adv_1033003_036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n牛奶擠好啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
