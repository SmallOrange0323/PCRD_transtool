    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "你會這樣想",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_019"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也很正常。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "但是──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "並不是",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_020"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "那樣子。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n因為我沒有擁有",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "「族人」這種關係的存在。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "那也是",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_021"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "當然的事。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n因為你們稱為米奈娃的那個超AI的外表，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n就是以我的模樣去做的。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "雖然我很想說",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_022"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "這是侵害肖像權……",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n不過嚮導老君，可能只是為了",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "要給我這種",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n不好相處的人，一點教訓吧。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "那也是",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_023"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "當然的事。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n因為你們稱為米奈娃的那個超AI的外表，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n就是以我的模樣去做的。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "雖然我很想說",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_024"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "這是侵害肖像權……",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n不過嚮導老君，可能只是為了",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "要給我這種",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n不好相處的人，一點教訓吧。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "你會這樣想",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_025"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也很正常。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "但是──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "並不是",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_026"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "那樣子。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n因為我沒有擁有",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "「族人」這種關係的存在。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "還有嗎？",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_027"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "有點勉強",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_028"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也要把你送來這裡的理由，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "那就是──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "為了邀請你。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_029"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "要不要當我的公主騎士呢？",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_030"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n{player}。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我已經",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_031"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "有兩位公主騎士了。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n其中一位，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "你們好像也有和她對決過。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "只要稍微修改一下遊戲規則，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_032"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n要在一個皇冠下，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "配屬多位騎士",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也不是不可能的事。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "然後現在，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_033"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n曾經與我是朋友的人",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──遠野帆稀，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "她的位置空了下來。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我希望",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "你能替補她的位置。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "雖然把男性置於身邊，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_034"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "會讓我有點不安……",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "至於我願意",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "冒這個風險的理由，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "是因為你是英雄，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "{player}。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "呵呵。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_035"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n你還真謙虛呢。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "但是──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "把我的同輩跳躍王、",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_036"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "誓約女君、",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "變貌大妃、",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "霸瞳皇帝──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "還有",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "與米奈娃同化的",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "「世界的管理者」，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "全數制伏的",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "不就是你嗎。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "就算如此。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_037"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n那個能夠率領「大家」的核心人物，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "就是你。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "一般來說，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "這就是被稱為英雄的人。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "……你該不會以為，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_038"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n我是在收集可以用來侵略的棋子吧。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "如果是這樣的話，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我可能讓你誤會了。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我之所以",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_039"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "要求你成為騎士的理由，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "是因為，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "騎士要保護主人。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "沒錯──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我、",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_040"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "非常──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "非常害怕。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n一直、",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "一直以來──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n都害怕到",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "食不知味的程度。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "國際刑警所屬的聯合國，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_041"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "原本和我是互惠的關係。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n但現在他們卻拚命地要追捕我，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n又或者",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "是要殺掉我。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "除了我以外的",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_042"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "那六位七冠們。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "他們的才能",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "鮮明、",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "純粹，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "真的是──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "強大到讓人不可置信。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "簡直就是經過數十億年生命進化，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "孕育出的最精銳存在。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "然後，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_043"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "當然。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n{player}，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "你",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n對我來說，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也是相當令人畏懼的對手。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我並沒有說謊。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_044"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n如同我剛剛說的，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n我不太擅長",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "表現出自己的感情。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "如果真是那樣",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_045"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "就太好了。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "就像我剛剛說的，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "你是打倒七冠們與",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n同等傑出人物的英雄。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "然後──",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_046"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "現狀，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我的行為對你們來說",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n是種障礙，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "變成敵人也是沒辦法的。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "就算現在立刻攻擊我，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也一點都不奇怪。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "但是我",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_047"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "並不希望戰鬥。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n因為那是件",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "非常可怕的事。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "因為「我」",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_048"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "在這個世界是孤身一人。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "萬一我輸掉，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "沒有任何人可以繼承我的位置。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "沒辦法捲土重來，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "是真正的戰敗，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "遊戲結束。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "所以，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_049"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "至今我一直隱藏身影。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n上一次不是透過攝影機和麥克風，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "而是直接在人前現身……",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "是什麼",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "時候的事呢。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "連帆稀",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "都沒有看過我這個樣子喔。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "但是──",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_050"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "這樣的隱居",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "已經結束了。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "「試煉」與「準備」已經告一段落，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我要踏出步伐。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "與想要阻止我的人們，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "戰鬥的時刻到來了。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──為了",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_051"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我的願望。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "……呵呵。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_052"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "答對了──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "後半部分。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "令我感到「恐懼之物」。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_053"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──七冠",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──聯合國",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──人類",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──動物",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──空氣",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──食物。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "除了這些，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "還包含所有的一切。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "所有的東西。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_054"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n這世界上",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "所有的東西都令我害怕。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "因為，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_055"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我和「你們」不一樣。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n這顆星球──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "對我來說，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "並不是自身所誕生的星球。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "……咦？",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_056"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n你還沒理解嗎？",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "是我",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_057"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "把你召喚到「這裡」的。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "在協助者們的幫忙下，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "把你強制登出。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n使用超越這顆地球法則的力量──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "「超能力」。",
        "unit_id": 107411
    },
    {
        "type": "still",
        "still": "221309801"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "沒錯，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_058"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "這裡是──",
        "unit_id": 107411
    },
    {
        "type": "still",
        "still": "end"
    }
]