[
    {
        "type": "background",
        "background": "510500"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在一片沒有見過、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美麗的沙灘上醒來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在混亂的他面前從天而降的是，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "長著龍之翼的女性──"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──幸會。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_000"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n迷宮女王的公主騎士。",
        "unit_id": 107411
    },
    {
        "type": "background",
        "background": "510461"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「『幻境龍后』",
        "unit_id": 105831,
        "voice": "vo_adv_2213098_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個人，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是破壞拉比林斯達",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "安裝在嚮導小妖精身上的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "安全裝置，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n造成「禁錮」原因的人……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有錯吧？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "在打倒厄莉絲，",
        "unit_id": 106031,
        "voice": "vo_adv_2213098_002"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "終於要恢復和平了～",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "的時候來礙事的，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n也是那個幻境龍后對吧……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "而且還在這邊",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "散播那個什麼",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "奇怪的粒子……！",
        "unit_id": 106031
    },
    {
        "type": "background",
        "background": "510500"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "叫得這麼",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_003"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "畢恭畢敬……",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也對。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n你的話──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "你可以稱呼我為",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_004"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "「幻」哦。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "看起來是……",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_005"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "不會這樣叫我吧。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "……真可惜。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "作為第一次交流，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "反應不是很理想呢。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "……真可惜。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_006"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "作為第一次交流，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "反應不是很理想呢。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "抱歉。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_007"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n至今為止，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我一直沒有培養自己的對話技巧。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "所以特別是面對多愁善感的男高中生，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我不曉得應該要開什麼話題才好。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "雖然可能",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_008"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "算不上什麼賠罪──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n接下來這一小段時間，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我會回答你的問題。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "你應該有很多",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "想問的吧。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "這當然是",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_009"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "出於我的意志。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n不過我的協助者們",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也有幫忙。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我們鎖定你的座標，",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_010"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n然後進行強制轉移。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "想成是瞬間移動……",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "空間跳躍",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也可以喔。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "呵呵。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_011"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n這麼快",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "就戳到我的痛處了呢。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "{player}。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我不太常",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_012"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "在人前露面。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "如果不是像現代網路一樣那麼發達的話，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我的溝通能力",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "大概會更差吧。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "當然現在",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_013"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我也是非常緊張喔？",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "只是我的表情肌肉不發達的關係，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "所以可能看不太出來。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "呵呵。",
        "unit_id": 107411,
        "voice": "vo_adv_2213098_014"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n這麼快",
        "unit_id": 107411
