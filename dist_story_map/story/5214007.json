        "voice": "vo_adv_5214007_013"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從比賽的熱烈氣氛急轉直下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "墨丘利度假村陷入了一片混亂。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n之後，"
    },
