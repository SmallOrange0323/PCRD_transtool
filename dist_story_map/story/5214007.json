        "type": "dialogue",
        "name": "倭",
        "words": "\n就是這場混亂鬧劇的原因嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "大家是喝了那個才變得不正常的。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是這樣對吧？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "布武機。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "嗚哇啊啊啊～～～！",
