        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "多虧了有蜜桃碰撞淘汰賽，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n我不僅變得更喜歡姊姊，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
