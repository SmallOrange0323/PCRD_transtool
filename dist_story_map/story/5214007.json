        "type": "dialogue",
        "name": "布武機",
        "words": "\n就拿來用了而已啊～！",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "上個月，",
        "unit_id": 130012,
        "voice": "vo_adv_5214007_017"
    },
    {
