        "voice": "vo_adv_5214007_014"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "再次爆炸。」",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "「比賽過度激烈導致無人管理。」",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "「背後有神祕飲料？」",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "「疑似是未經許可進行販售。」",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n──好像是這樣喔，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──也就是說，",
        "unit_id": 130012,
        "voice": "vo_adv_5214007_015"
    },
