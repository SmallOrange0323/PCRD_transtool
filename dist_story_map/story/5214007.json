        "type": "background",
        "background": "501760"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天早上──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和倭、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "布武機會合的若菜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從晨報頭條中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n得知了一連串騷動背後究竟發生了什麼──"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "「墨利村",
