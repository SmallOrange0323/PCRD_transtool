[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新手冒險者莉莉，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以及作為前輩決定指導她冒險者相關須知的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這天，他們倆在蘭德索爾的郊外進行戰鬥的鍛鍊。"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "──喝、",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "喝呀──！",
        "unit_id": 125813
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "小魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呼、",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呼……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有、",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有成功打倒了嗎……？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "謝、",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "謝謝您，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……！",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過……",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這一切也都是拜兄長大人",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n替我進行強化以及提供建言所賜。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就算是這般小型的魔物，",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n若只有我一個人，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是絕對無法戰勝它的。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然……",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n若使用「黑天使之力」，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n確實能大幅提升",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "攻擊威力和速度……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但再怎麼說，",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那只是我偶然間得到的，應受忌諱之力。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "並且或許哪天就無法再使用此力量……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "既然如此，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我認為從自己原本的實力開始鍛鍊起，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "才是最好的做法。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "更何況，",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "即使力量提升了，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我自身所擁有的經驗",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n也不會因此有所變化。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就跟以往可可蘿小姐提過的一樣，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這與胡亂揮舞著",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "用不慣的菜刀無異……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……啊！",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n不、",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人替我進行強化則是另外一回事。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而且兄長大人的力量",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n與我的「黑天使之力」無法相比，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是更高潔清廉的存在。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "明明兄長大人特地給我這般力量，我卻無法充分發揮，",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "甚至連面對這種程度的魔物也陷入苦戰……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這全都得怪罪於",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我自己太過不成熟……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……！",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可、",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可是，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這樣一來……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……便",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "等同於是",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n更加浪費兄長大人您寶貴的時間呀。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "竟要為了我這種人……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……！",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n您真是既溫柔",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n又深思熟慮的人……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "明明我",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原本就已經欠了您許多還也還不完的恩情。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n若再繼續讓您……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "──不。",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_015"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n既然如此，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那我就更不應該",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "浪費任何一秒在此懊惱。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就還請您務必多多指教了，",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_016"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n請幫我進行特訓，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "讓我能充分運用強化之力吧……！",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好的……！",
        "unit_id": 125813,
        "voice": "vo_adv_1258002_017"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "～跑1000公尺～"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "喝啊啊啊……！",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_018"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "～跳遠～"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "喝啊啊啊……",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_019"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "──啊",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "！？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "～搬運巨石～"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呼、",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_020"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呼……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n好、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好重……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊啊……！？",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_021"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和莉莉進行訓練了一段時間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但莉莉仍無法順利充分運用力量。"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……呼……",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_022"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不好意思",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_023"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "讓您操心了，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "單論我的身體，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "並沒有什麼大礙……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "只是……",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_024"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就算我再怎麼不成熟，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n練習狀況應該也不至於如此不順遂，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這究竟是為什麼呢？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "當然，",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_025"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我十分明白，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不可能一朝一夕就練成",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n貪吃佩可小姐或凱留小姐那般靈活的身手。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但說不定……",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_026"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "果然要論資質，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我並不適合當一個冒險者吧……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這、",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_027"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這樣說",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "確實是也沒錯。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過，那個……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在我至今為止的",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_028"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "15年人生中……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我從未自己主動去",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "接觸過外面的世界。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "無論是所學習的知識、",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_029"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還是接觸的人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "全都是家裡挑選的。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "尤其是涉及粗魯行為的領域，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "家裡都避免讓我接觸……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "所以比起初學者，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我認為自己的狀況更像是，做為一名冒險者，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "連起跑點都尚未站上去……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "當然，",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_030"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我很感謝把我養育長大的雙親，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也明白把自己表現不佳的理由歸在家庭環境上，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是不太成熟的天真想法……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……我明白了。",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_031"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那麼，",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_032"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "接下來……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是要練習揮舞武器，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "對嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……？",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_033"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您怎麼了嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "為何要舉起劍……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "難道是我做了什麼",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "讓您感到不愉快的行為嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦咦！？",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_034"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n您的意思是，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要進行實戰練習嗎……！？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "什麼……",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_035"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這種事我辦不到！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我是不可能對",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人刀刃相向的……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "當然，",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_036"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我的身手還遠遠不及兄長大人……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但凡事",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都可能會發生萬一。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "若是我讓兄長大人受傷了……",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_037"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我絕對不會",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原諒自己。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我寧願",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "乾脆選擇自我了結……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦……？",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_038"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "希、",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_039"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "希望如此說不會太冒犯……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但我十分信任兄長大人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n世界上沒有其他人能令我如此信賴。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_040"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "或許可以說我崇拜著您。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "畢竟，兄長大人既是位英雄，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也是個偉大的冒險者，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n並且是拯救了我的人……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "夥伴……",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_041"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_042"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您方才也曾提過同樣的話。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但像我這樣的存在，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要被算進",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人的夥伴裡，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "恐怕是有些厚顏無恥……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "巨大的魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦！？",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_043"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n呀啊……！！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在、",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_044"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在蘭德索爾附近，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "竟然會出現如此大型的魔物！？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "比起這種事……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "得趕在魔物跑進鎮裡前",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_045"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "將其打倒才行！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "麻煩您了……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……！？",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_046"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "莫非，",
        "unit_id": 125812,
        "voice": "vo_adv_1258002_047"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是想藉機會讓我累積實戰經驗？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是太溫柔了……！　",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "既、",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_048"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "既然如此，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我將拿出目前的所有本事，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "去迎戰……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "喝啊啊啊啊！",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_049"
    },
    {
        "type": "dialogue",
        "name": "巨大的魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "唔……！",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_050"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n好強──",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n未料都已變成這個姿態，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "卻還不是魔物的對手……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "明明也已經請",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_051"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人替我進行過強化了。",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "果然",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "光靠我還是──",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "巨大的魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人！？",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_052"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊啊……",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_053"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您受傷了！？",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n真的非常抱歉，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都是因為我！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可是……！",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_054"
    },
    {
        "type": "dialogue",
        "name": "巨大的魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "唔……！",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_055"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n竟敢傷到",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人！",
        "unit_id": 125811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "！",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_056"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n唔",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人──",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_057"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "他應該是不想讓我擔心而故作沒事，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但方才的傷口恐怕不淺。",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "為了不再繼續成為兄長大人的負擔，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這次我必須確實充分發揮",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "他給我的力量才行……！　",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可是……！",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_058"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n到底該怎麼辦才好……！？",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "希望我相信他……",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_059"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "剛才兄長大人是這樣說的……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我想，那肯定不是",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要我盲目聽信於他。",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而是以能託付自己背後的冒險者身分──",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "以能夠攜手前進",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "的夥伴身分……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "然而，",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_060"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n已全身沾滿罪孽的我，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要和兄長大人並肩而行，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n光是此想法便可謂大不敬……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……唔……",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_061"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……如果，",
        "unit_id": 125811,
        "voice": "vo_adv_1258002_062"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這個想法能實現。",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
