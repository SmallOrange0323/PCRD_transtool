    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可璃亞和安涅默涅的旅程迎接關鍵時刻之時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一行人也在不遠處，\n持續與大群魔物展開交戰。"
    },
    {
        "type": "background",
        "background": "500562"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可惡……",
        "unit_id": 106011,
        "voice": "vo_adv_5207006_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "往那邊過去了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本沒完沒了啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "聰明狡詐的配合──",
        "unit_id": 125811,
        "voice": "vo_adv_5207006_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "即使如此。",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我也不會",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "讓你們繼續前進……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……嗯？",
        "unit_id": 129711,
        "voice": "vo_adv_5207006_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是。",
        "unit_id": 129711,
        "voice": "vo_adv_5207006_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家令幼蛇尾隨兩人身後……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然其腳步",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "突然加快了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼意思？",
        "unit_id": 106011,
        "voice": "vo_adv_5207006_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難道是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "目的地快到了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來好像不是啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為前方可是座高山喔？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "原來「欣特蘭德」此地，",
        "unit_id": 129711,
        "voice": "vo_adv_5207006_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "竟隱於深山之祕境──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n亦或此事，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "莫非另有緣由？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……璃亞……",
        "unit_id": 125811,
        "voice": "vo_adv_5207006_006"
    },
    {
        "type": "background",
        "background": "500212"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…………",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_007"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "可璃亞小姐──",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_008"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n妳",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不覺得冷嗎？",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……我不要緊。",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_009"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n安涅默涅小姐才是，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "妳沒事吧？",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──唔，",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_010"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "是的──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "可璃亞小姐──",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_011"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n從剛才開始……",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "就一直在",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "勉強自己吧。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "即使在路上絆倒……",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_012"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "即使遇到任何狀況。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n她全都",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "承受下來──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "全身遍體麟傷，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "腳步不停地往前走。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "都是，",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_013"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我的錯。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n我──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "一直不願意，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "相信她。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "因此……",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "將可璃亞小姐",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "逼到絕境……",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "早知道，",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_014"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "會變成這樣──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我要是",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "更早一點",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "說出來就好了。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……唉，",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_015"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可璃亞和安涅默涅"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "懷著各自的想法，持續朝深山邁步前進。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然後──"
    },
    {
        "type": "background",
        "background": "501682"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──這裡就是，",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_016"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "欣特蘭德……？",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "可是──",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_017"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "沒有任何地方，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "開著花。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n到處都沒看到……",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……是的。",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_018"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n安涅默涅小姐，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那個──",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "─",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_019"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "─對不起！",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_020"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n這是──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "其實，",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_021"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "叫做欣特蘭德的地方……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "根本就不存在。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "3000年只開一次的花也是，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "全部都是我編造的故事。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_022"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "想要和安涅默涅做朋友……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n想要抓住契機……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "所以",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "忍不住說了謊。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我明明知道，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這是不對的……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這趟旅程中，",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_023"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我把安涅默涅小姐耍得團團轉，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還傷害了妳。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "甚至害安涅默涅小姐受了傷……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "明明如此，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我卻覺得",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "很高興能一起旅行。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_024"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真的",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_025"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "很對不起。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "安涅默涅小姐",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "說得沒錯。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我並非表裡如一……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "根本不是",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "什麼好孩子。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "從以前開始……",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_026"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "當然",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "現在也是。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我只是看著別人的臉色，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "受到別人的期待，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就想要回應對方而已。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我一直……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "都不是",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "什麼聖女……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "可璃亞小姐──",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_027"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──請不要",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_028"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "道歉。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……咦？",
        "unit_id": 135311,
        "voice": "vo_adv_5207006_029"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "真要說的話──",
        "unit_id": 135411,
        "voice": "vo_adv_5207006_030"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我也一樣。",
        "unit_id": 135411
    },
    {
