[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個魔物……",
        "unit_id": 105911,
        "voice": "vo_adv_9008155_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n狂戰之狼",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是這附近魔物的老大呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為這傢伙肆虐，",
        "unit_id": 106011,
        "voice": "vo_adv_9008155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才讓山那頭的村莊與蘭德索爾",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n連接的交通斷絕。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來很強，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全神貫注一起上吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔喔～！",
        "unit_id": 105811,
        "voice": "vo_adv_9008155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很有幹勁呢，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "接受【公會管理協會】委託的",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是小凱留來著？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～嗯，",
        "unit_id": 106011,
        "voice": "vo_adv_9008155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把委託帶來的是我沒錯。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但其實……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次並不是【公會管理協會】的委託喔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有個因為「見不到住在那邊村莊的父母」而哭的孩子。",
        "unit_id": 106011,
        "voice": "vo_adv_9008155_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不知道",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該說是順勢，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是受到氣氛影響，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之就……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不小心脫口而出「我幫你！」了呢～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 105811,
        "voice": "vo_adv_9008155_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好溫柔喔～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_9008155_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "突然就變得很幹勁。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看起來比平常",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還要強悍又勇猛呢♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了那位孩子，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓我們來消滅魔物吧。",
        "unit_id": 105911
    }
]