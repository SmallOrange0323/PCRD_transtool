    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊、",
        "unit_id": 125812,
        "voice": "vo_adv_9008003_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呃、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我好好好、",
        "unit_id": 125812,
        "voice": "vo_adv_9008003_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好緊張，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有點結巴……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可是……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "得加油才行……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不然會給大家添麻煩……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉！",
        "unit_id": 126012,
        "voice": "vo_adv_9008003_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "快回想起來！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n只要我們使出全力認真面對，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n觀眾……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "聽眾就會是",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "最棒的盟友！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "確實、",
        "unit_id": 125812,
        "voice": "vo_adv_9008003_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如此……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這是製作人小姐教會我們的重要事情……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……",
        "unit_id": 125812,
        "voice": "vo_adv_9008003_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "各位聽眾，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "大家好。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n今日由",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們【幻變少女】擔任主播，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還請多多指教。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那麼，",
        "unit_id": 126012,
        "voice": "vo_adv_9008003_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "今天的話題是……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "來自遊俠協會的通知。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "協會似乎將開始招募這一期遊俠集訓的參加者。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n據我所聞，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這集訓好像是以嚴厲出名的呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "其中似乎也有可讓遊俠動物隨行的行程，",
        "unit_id": 126012,
        "voice": "vo_adv_9008003_007"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n詳情麻煩大家去向協會洽詢喔。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "公會管理協會那邊",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也有準備宣傳小冊子♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人",
        "unit_id": 125812,
        "voice": "vo_adv_9008003_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也擁有遊俠的資格對吧。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "聽說是和可可蘿小姐還有栞小姐一起獲得的。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也聽聞",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "當時出現了毛絨絨的兄長大人……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "汪汪兄長大人……！？",
        "unit_id": 125812,
        "voice": "vo_adv_9008003_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "想必",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是十分威風凜凜的模樣吧。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我也想",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "親眼拜見一次呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不過話說回來，",
        "unit_id": 126012,
        "voice": "vo_adv_9008003_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "聽說訓練嚴苛到有人脫逃……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥哥當時肯定也很辛苦吧？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "哇……",
        "unit_id": 125812,
        "voice": "vo_adv_9008003_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不愧是",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "即便是艱難險阻的嚴苛集訓，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n也能面帶笑容地完成呢……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n令我不禁也想參加同樣的集訓，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "努力鑽研精進自己……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "可以，",
        "unit_id": 126112,
        "voice": "vo_adv_9008003_012"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "變強嗎？",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n小樂也一起。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "璃亞、",
        "unit_id": 125812,
        "voice": "vo_adv_9008003_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "普蕾西亞。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n要不要",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "一起去報名這一期集訓呢？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "只要歷經千辛萬苦克服訓練課程，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們三人應該就能離兄長大人更近一步……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "哥。",
        "unit_id": 126112,
        "voice": "vo_adv_9008003_014"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "教我。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "遊俠。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "兩位……！",
        "unit_id": 126012,
        "voice": "vo_adv_9008003_015"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "現在還在現場直播呀……！　",
        "unit_id": 126012
