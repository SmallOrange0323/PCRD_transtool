    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "難不成",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "它打算恣意地奪走我們的靈魂！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那種事",
        "unit_id": 110611,
        "voice": "vo_adv_5021006_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是不會發生的。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主？",
        "unit_id": 110411,
        "voice": "vo_adv_5021006_051"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真步……",
        "unit_id": 110511,
        "voice": "vo_adv_5021006_052"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真的生氣了～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然敢隨便玩弄人家重要的夥伴們，",
        "unit_id": 110611,
        "voice": "vo_adv_5021006_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這份回禮……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不回不行呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "難得的機會，",
        "unit_id": 110611,
        "voice": "vo_adv_5021006_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就讓你盛大地",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n幫我們製造一些夏日的美好回憶吧。",
