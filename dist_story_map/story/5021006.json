        "voice": "vo_adv_5021006_047"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "它們聚集……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n成了一個超巨大的怪物啦！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "感覺到一股強大的力量～！",
        "unit_id": 110511,
        "voice": "vo_adv_5021006_048"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "光是待在附近，",
