    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我做不到～！",
        "unit_id": 110511,
        "voice": "vo_adv_5021006_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為我每天都看著公主細心地呵護它們！",
        "unit_id": 110411,
        "voice": "vo_adv_5021006_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以救出它們時，一定要讓它們保持完美的狀態～♪",
