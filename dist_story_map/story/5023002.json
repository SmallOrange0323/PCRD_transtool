        "voice": "vo_adv_5023002_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只有{player}學長和克蘿依學姐？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n小碧跑到哪裡去了？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我才想問呢！",
