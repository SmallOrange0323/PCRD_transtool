        "voice": "vo_adv_5023002_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不知道該跟班上的人",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說些什麼才好……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自我介紹也",
        "unit_id": 110711,
        "voice": "vo_adv_5023002_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "做得不好……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "課程也聽不太懂，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我真的不知道到底該怎麼辦才好……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……我說妳啊。",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_033"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好了～克蘿依學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_5023002_034"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這個等一下再說",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們先吃午飯好不好？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "確實。",
        "unit_id": 111011,
        "voice": "vo_adv_5023002_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n雖然我精確地分析發揮了效果",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "得以及早找到她，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但畢竟時間還是有限。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要聊的話也可以邊吃邊聊吧。",
        "unit_id": 111011
    },
    {
        "type": "still",
        "still": "502300201"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這麼說起來",
        "unit_id": 110911,
        "voice": "vo_adv_5023002_036"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們好朋友社的成員",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "難得一起吃午餐耶？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "仔細想想，",
        "unit_id": 111011,
        "voice": "vo_adv_5023002_037"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好像的確是如此。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n雖然我們",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "經常混在一起。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "放學後的公會活動就算了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n連午休也要經常聚在一起",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "吃飯的話實在太麻煩了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "會嗎？",
        "unit_id": 110911,
        "voice": "vo_adv_5023002_039"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒我很喜歡像這樣",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "跟大家一起吃飯呢～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔！",
        "unit_id": 111011,
        "voice": "vo_adv_5023002_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒那種",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "賺取好感度的手法也太露骨了吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n身為學姐的我也不能輸給妳……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮也想要跟大家一起吃飯呢～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不對，那種的就不必了。",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_041"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "為什麼連你也來搶著賺取好感度啊。",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_042"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你想變可愛嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n發現帥氣路線對你來說太勉強了嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哼～",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_043"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這樣啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來如此。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……我也，那個，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是不開心。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該說，",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也不是特別……？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n想聚在一起吃飯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只是如果妳們認真要這樣的話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我個人是覺得",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，也沒甚麼關係。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳聽到了嗎？優妮學姐！",
        "unit_id": 110911,
        "voice": "vo_adv_5023002_045"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n克蘿依學姐好狡猾！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "她根本是個狡猾的集合體！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可惡，",
        "unit_id": 111011,
        "voice": "vo_adv_5023002_046"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我錯看妳了克蘿依……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我一直深信妳不是那種",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會輕易捨棄冰山美人的矜持，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n急功好利的女人……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不知羞恥，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳這個毒婦！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喂，根本不知所云啊？",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "為什麼我只不過說了句，\n一起吃飯也可以",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就要遭受這種異樣的否定啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n能不能不要再搞這種，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "克蘿依不會說這種話的解釋戰爭。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊哈！　",
        "unit_id": 110911,
        "voice": "vo_adv_5023002_048"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家一起吃午飯真的很開心耶～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真好～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "越來越切嚕了呢～？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃，就算妳這樣含混著要我同意也不行。",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_049"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而且那個謎樣單字，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然妳很拼命想要讓它流行起來，不過那是不可能的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n未來永遠都不會有人用它的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 110711,
        "voice": "vo_adv_5023002_050"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為什麼妳們幾位",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總是待在一起呢？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n明明大家都是不同學年……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒有啦，",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們也沒有總是待在一起。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n的確我們常常待在一起，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為我們幾個在德蕾女高也是相當異樣的存在。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我……",
        "unit_id": 110711,
        "voice": "vo_adv_5023002_052"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "很羨慕妳們幾個。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我也想和妳們一樣",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跟某個人……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "變得感情很好。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然我覺得把我們當成參考可能不是很恰當。",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_053"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "剛剛，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳說妳不知道",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "跟班上的人要聊什麼對不對？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是……",
        "unit_id": 110711,
        "voice": "vo_adv_5023002_054"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是啊。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "像妳那樣害怕也無濟於事啊？",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_055"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳是短期入學，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "反正沒過多久就要說再見了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n太在意也只會弄得自己很累而已。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃，就是說，",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_056"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我想跟妳說的是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼回事……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～好麻煩。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐她啊～",
        "unit_id": 110911,
        "voice": "vo_adv_5023002_057"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是想要說",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小碧妳應該更誠實的",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "做自己就好了～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "請妳不要擅自替別人翻譯。",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_058"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克蘿依……",
        "unit_id": 110711,
        "voice": "vo_adv_5023002_059"
    },
    {
        "type": "still",
        "still": "502300202"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯，",
        "unit_id": 110711,
        "voice": "vo_adv_5023002_060"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說得也是……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n謝謝妳喔～",
        "unit_id": 110711
    },
    {
