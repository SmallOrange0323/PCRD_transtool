        "type": "dialogue",
        "name": "優妮",
        "words": "這種接近自我分析的推論。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "既然這樣，我們就馬上過去吧。",
