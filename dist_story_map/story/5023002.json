        "voice": "vo_adv_5023002_030"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳為什麼會待在這種空教室裡面呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "找妳找得超辛苦的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊……",
