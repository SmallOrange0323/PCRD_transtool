        "voice": "vo_adv_5023002_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n為了獎學金而組成的一個",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "充滿算計的公會。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n而現在已經如同字面上的意義，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "變成感情和睦的三人組了♪",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒那回事。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……唉。",
