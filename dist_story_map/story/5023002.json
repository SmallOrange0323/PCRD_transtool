    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐，狀況似乎是如此。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n害我白跑一趟，真沒勁～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳切換開關也太快了吧？",
