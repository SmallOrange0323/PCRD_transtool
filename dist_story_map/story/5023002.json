        "type": "dialogue",
        "name": "優妮",
        "words": "不、",
        "unit_id": 111011,
        "voice": "vo_adv_5023002_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是因為那個，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不可抗力的因素。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的研究室，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也就是『象牙之塔』，在舊校舍那邊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "離被統稱為新校舍的腹地有些距離。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是那樣。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "藉口就不必了。",
        "unit_id": 110911,
        "voice": "vo_adv_5023002_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不管那個了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n妳真的知道小碧去了哪裡嗎？",
