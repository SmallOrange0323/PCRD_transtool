        "name": "克蘿依",
        "words": "打擾了～",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "噫！？　",
        "unit_id": 110711,
        "voice": "vo_adv_5023002_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克克克、",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克蘿依！？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n{player}、琪愛兒、還有優妮你們……！？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們找妳找了好久呢～",
        "unit_id": 110911,
        "voice": "vo_adv_5023002_026"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小碧～♪",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5023002_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "果然是在沒什麼人在的地方。",
        "unit_id": 111011
