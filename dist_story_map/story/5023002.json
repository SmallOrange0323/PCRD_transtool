    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不需要道謝啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這是我自己決定要做的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是這麼一回事。{player}學弟。",
        "unit_id": 111011,
        "voice": "vo_adv_5023002_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n照顧你的好友碧",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就等同於",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n和你和睦相處是一樣的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這同時也是領取獎學金的條件，",
