        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎麼樣啊？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "跟我按照行動心理學所分析出來的結果一樣吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個，",
        "unit_id": 110811,
        "voice": "vo_adv_5023002_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這已經是第五個地點了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n根本只是單純的地毯式搜索而已。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各、",
        "unit_id": 110711,
        "voice": "vo_adv_5023002_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各位……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為什麼會？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那是我要說的話。",
