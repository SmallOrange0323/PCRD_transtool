        "voice": "vo_adv_1009007_075"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我就不會迷失方向！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就算有誤入歧途的人，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_076"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n只要我們讓他們走回正途就好……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對吧，吉格魯特！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "修特帕魯一邊說著，一邊展露著笑容。"
