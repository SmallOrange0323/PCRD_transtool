[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}散步時，\n慌慌張張的修特帕魯跑近他。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聽我說吉格魯特！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "「機關」……「機關」終於有明顯的的活動了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們熾炎戰鬼煉獄血盟暗黑團的宿敵「機關」，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n終於開始活動了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "當然啦！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我一直都在說真話！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不錯的反應！不愧是吉格魯特！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "根據情報顯示，近來聲稱來自「機關」的人，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "在這個大陸四處作惡。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "詳細的身分和成員人數暫時不清楚，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n但捉到那些傢伙都能獲得獎金。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因此已經有很多獎金獵人開始著手調查「機關」了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "既然那些傢伙已經行動了……那麼，我們也只能準備出擊！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們和「機關」決一勝負吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要和那些傢伙戰鬥，我需要同為暗黑騎士的你的力量。",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你會幫我嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喔喔！你願意幫助我呀！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我大概知道他們的基地在那裡！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "馬上出擊吧！",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……根據我的調查，「機關」的活動集中在火山一帶。",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因此我認為那些傢伙的基地肯定在這裡，不會錯的。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呃！感覺到魔力的波動……",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "在那裡呀！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n不用躲了！現身吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "哼哼哼……",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_011"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n竟然被你們發現了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……你們就是「機關」？",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_012"
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "沒錯！",
        "unit_id": 911,
        "voice": "vo_adv_1009007_013"
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n我們就是令世界陷入混亂的組織――「機關」！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "我們是被選中的人。在舊世界屬於統治者的我們，",
        "unit_id": 811,
        "voice": "vo_adv_1009007_014"
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n應該也要統治這個新世界才對。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n阻礙我們的人就把他消滅殆盡……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聽到了嗎吉格魯特！？果然世界上是有「機關」的！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_015"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n還有剛才那番話……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你們是想統治舊世界的，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n星之審判者……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "「機關」是審判者們為了征服這個世界而成立，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n是為了統治人類的機構……！我不會讓你們得逞的！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因為，我們是和「機關」對抗的人！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "什麼……！？",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_017"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n這麼說來，難道妳是……！",
        "unit_id": 1411
    },
    {
        "type": "still",
        "still": "100900101"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就是「熾炎戰鬼煉獄血盟暗黑團」團長……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n安妮羅潔‧馮‧修特帕魯！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n人稱「疾風之冥姬」 ！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可不要說你們忘記了在舊世界的最後之戰……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我們暗黑騎士的使命……就是要打倒星之審判者！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就算在這個新世界，我仍舊要和你們戰鬥！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "只要有我在，就不會讓你們為所欲為！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_020"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "疾風之冥姬……！",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_021"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n……多麼棒的角色設定！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n你們看看，她是最棒的人才呀！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "這讓人不忍直視的切身之痛……！",
        "unit_id": 911,
        "voice": "vo_adv_1009007_022"
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n我們正期待著事情這樣發展啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "……有架勢是好事。",
        "unit_id": 811,
        "voice": "vo_adv_1009007_023"
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n但是，憑妳一己之力阻止得了我們嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n不要小看我們「機關」的力量！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我會阻止給你看！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n就算是用我的生命作為代價！",
        "unit_id": 100911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "……話說，妳身旁的人是誰？",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_025"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "身旁……？",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_026"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊啊，他是……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "等一下！",
        "unit_id": 911,
        "voice": "vo_adv_1009007_027"
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "他這時候應該要自己報上名來呀！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "這樣子……比較帥氣啊！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不、不是……雖然我認同這樣子比較帥氣，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_028"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n但是吉格魯特他沒辦法……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "怎麼了？",
        "unit_id": 811,
        "voice": "vo_adv_1009007_029"
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "難道他……沒有回想起前世的記憶嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是這樣子沒錯……",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_030"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但他的確是我前世的盟友！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "一派謊言！",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_031"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "妳一定在說謊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n妳看看他的表情！他一副目瞪口呆的樣子！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "妳……是打算讓普通人參與我們的戰鬥嗎！",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_032"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n雖然由無恥的我們來說有點奇怪，但做人要懂得廉恥！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "等一下！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_033"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我沒有這個意思呀……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "應該是妳說了一點前世的事之後，",
        "unit_id": 911,
        "voice": "vo_adv_1009007_034"
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n看他沒有拒絕，就把他當作夥伴對吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "不，難道他只是被妳牽連進來而已？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你、你怎麼知道……",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_035"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "哈哈哈！我說中了啊！",
        "unit_id": 811,
        "voice": "vo_adv_1009007_036"
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n什麼嘛！看來妳也沒什麼了不起嘛！真不像樣！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "他會願意配合妳，只不過是在可憐妳而已！",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_037"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n他是為了孤獨而感到痛苦的妳，所以才和妳一起行動的！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "為什麼妳都沒有察覺到呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "我們和妳不同，我們共享著同一個世界與同一個前世！",
        "unit_id": 911,
        "voice": "vo_adv_1009007_038"
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n這份堅韌而苦痛的牽絆，你們戰勝得了嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "妳說啊！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這、這個…",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_039"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "…",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特……你果然是在可憐我吧……",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_040"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是這樣對吧。在這個世界上，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n根本沒有人能接受我的想法……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這我早就知道了不是嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……即便如此，我還是不自覺地對他撤嬌。",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_041"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這件事是時候該結束了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……他們說得沒錯，吉格魯特。",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_042"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "請不要勉強自己。你回到城鎮裡吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……非常感謝你一直以來的陪伴。",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_043"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你快走吧。我一個人和他們戰鬥就足夠了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特……！你……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_044"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……你這個人！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "報上名號了……難道！",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_045"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "你也和我們擁有同一種苦痛嗎……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "真棒……！",
        "unit_id": 811,
        "voice": "vo_adv_1009007_046"
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n我們一直在等待著像你們這樣的人！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但……吉格魯特呦。真的可以嗎？",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_047"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我仍然可以稱呼你為閃光的吉格魯特……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你仍是我的盟友嗎……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那是我們的誓言……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_048"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……謝謝，吉格魯特！我們之間已經不需要言語了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n因為我們有前世的牽絆啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……你們好好聽著！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_049"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這個男人，是閃光的吉格魯特！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "他和我在前世，用這個肉身戰鬥至最後一刻……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n他是擁有「第二連隊長」榮譽稱號的暗黑騎士！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "他就是閃光的吉格魯特……！？",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_050"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "原來如此……！事情越來越有趣了……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "那麼，賭上世界的命運，來場戰鬥吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們熾炎戰鬼煉獄血盟暗黑團，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_051"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n會消滅你們「機關」",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "的！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "有本事的話，就放馬過來吧！",
        "unit_id": 911,
        "voice": "vo_adv_1009007_052"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……謝謝，吉格魯特。你果然是我的盟友。",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_053"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "現在正是我全力回報我們的友誼之時……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "儲藏在我瞳孔中的魔力……全部釋放！！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_054"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n極・魔瞳開眼……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "等一下……她的魔力是怎麼回事！？",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_055"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "難道她是認真地想打倒我們嗎！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "──從黑暗湧出的魔力，扭曲世界並成為我的力量吧……",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_056"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n以疾風之顎屠殺靈魂，帶來閃電使烏雲覆蓋蒼穹！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雷鳴為歡愉的叫聲！奔馳、奔馳、奔馳吧！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_057"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n貫穿所有阻礙物，在黑暗中誕生的天之光啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "妳這樣太狡猾了！可惡！",
        "unit_id": 911,
        "voice": "vo_adv_1009007_058"
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n現在沒有魔法能和這強大的魔力相抗衡……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "這個是什麼鎖呀！？快、快解開！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你們的靈魂，已被詛咒之鎖束縛住了……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_059"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n魔刃呀，消滅罪人吧！「滅光鎖縛燒魂刃雷霸」！！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "這是什麼力量……！",
        "unit_id": 811,
        "voice": "vo_adv_1009007_060"
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n竟然可以打敗我們……！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "機關成員３",
        "words": "嗚、嗚哇哇哇哇！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "怎麼可能！",
        "unit_id": 911,
        "voice": "vo_adv_1009007_061"
    },
    {
        "type": "dialogue",
        "name": "機關成員２",
        "words": "\n我們「機關」是永垂不朽的啊啊啊啊！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "但是，很快就會再有像我們這樣的人出現……！",
        "unit_id": 1411,
        "voice": "vo_adv_1009007_062"
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "機關成員１",
        "words": "嗚哇哇哇哇……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我的魔瞳……是無敵的！",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_063"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵呵呵……哈哈哈……哈──哈哈哈！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……我的魔力已用盡了……",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500091"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……吉格魯特呦，這次也辛苦你了。",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_064"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n順利地把他們交出去了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "其實……已經證實他們說自己是機關，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_065"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n應該是被我寫的書所影響。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "根據他們的供詞……他們看了冥風戰記後，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_066"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n沉浸在青春期特有的胡思亂想中，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "結果便打著「機關」的名號四處作惡……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "他們覺得日常生活很枯燥，所以藉著我的書，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_067"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n將自己想像成世界犯罪組織的成員……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……我和他們戰鬥時，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_068"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n不知不覺中竟然覺得十分快樂……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我沒有資格批評他們。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我一直渴望著能參與賭上世界命運的一戰……",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_069"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n而這個想像竟然實際出現在我的眼前……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那個時候，我心中有股無法形容的興奮之情。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是我並不是像他們一樣，打算破壞現實，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_070"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我完全沒有這個想法！這一點，請你要一定要相信我……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是，我的妄想……而形成的作品，讓他們走上了扭曲的道路。",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_071"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這是不可原諒的……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我可能得要停止這樣的妄想了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然你這樣說……但如果我走錯一步的話，",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_072"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n可能已經變成他們那樣了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不，以後我也有可能變成那樣……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……謝謝",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_073"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是啊……",
        "unit_id": 100911,
        "voice": "vo_adv_1009007_074"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我有吉格魯特――你在身旁。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "只要你這個因靈魂羈絆相繫的盟友在，",
