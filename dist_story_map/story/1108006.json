        "voice": "vo_adv_1108006_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n尤其是那樣涉世未深的大小姐。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n面對這樣的經驗，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該會更覺得可怕吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真可憐。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
