[
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "星期天的早晨。\n沒有待辦行程的克蘿依，\n在尋找單日的打工。"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "『輔助派送業務，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "日薪可談，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "性別年齡不限』",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗎……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n雖然搞不太清楚，不過就選這個好了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "聯絡地址是……",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "所以，",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_002"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n只是搬運行李或信件到牧場",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這樣簡單的工作。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "詳情妳直接詢問",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "現場的人就好了。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我知道了――。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳隸屬於F組。",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_004"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n組長已經在大馬路上等著了，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "快點過去。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "另外問一下，",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳有戰鬥經驗嗎？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啥？",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不，雖然不知道你為什麼這麼問，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算有吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n因為我是在較複雜的環境長大的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "大概還能處理。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這樣啊，",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那萬一發生了什麼事應該也處理得了呢。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "其實在路途上――",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "在地圖的這附近有目擊到",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n魔物的通報呢。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "第一次聽說。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n原來會出現啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那裡。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "之前想野餐之類的",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n有帶弟弟們去過，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我只記得是座悠閒寧靜的森林啊――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就是啊。",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n發出注意警告，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "也不過是幾天前的事。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "警告。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雖然這麼說，",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過也只是一隻離群的魔物",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "在徘徊而已。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雖然",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "騎士團好像已經立刻去討伐了，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n但目前連找都沒找到。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "反過來說，",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能碰到那傢伙的機率",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "也不大就是了。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n只要不是運氣太差，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "應該能",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "平安度過吧。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n不用想太多。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，無所謂啦反正我也什麼都不知道……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊啊、",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "還有。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "關於妳的組的組長――",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "――雖然也許有點粗心，",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_016"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過很認真工作，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "以做人處事來說",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是個好人。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n幫我好好",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "照顧他。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "麻煩妳啦。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "　什麼意思？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n咦，不是反過來嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n怎麼反倒要我來照顧……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "帶領？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哈哈哈。",
        "unit_id": 1011,
        "voice": "vo_adv_1108006_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你在笑什麼。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，我不懂我不懂，完全無法理解。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n到底是什麼人物，那個組長。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來是這樣――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "組長是這個人啊――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，又來了。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n怎麼又是你啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n該說是命運嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而且雖然稱作是「組」，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "成員卻只有一個人。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n加上我也勉強只有兩個人。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那不就只有一直在迷路的人&店員雙人組嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那當然！",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_023"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "讓有迷路問題的人當配送員的話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我們國家的郵政系統就會出問題了啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "全蘭德索爾的人都要驚呆了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，不……",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等一下……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n該不會，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你每次說迷路的時候，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "都是正在配送工作中……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_025"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還是算了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不要問好了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有可能會出現我無法解決的嚴重社會問題。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "欸――",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼轉換一下氣氛――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我是今天來幫忙的臨時工克蘿依。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "請多指教～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "和平常的立場相反，總覺得有點混亂……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "{player}不覺得嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好天真無邪啊。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了，不過……",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是無所謂啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_030"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哎呀，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "抱歉。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n剛剛突然很火大，下意識就拔出短劍了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n而且差點就要繞到背後刺穿喉嚨了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦？",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "　不是指這個？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "　因為可能會遇到魔物？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n啊啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "擔心我的安全嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話也省略太多了吧……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "無所謂。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就先出發吧――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n嗯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要運送到牧場的行李就是這個吧？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嘿咻。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_034"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒關係啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我也是來工作的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你姑且也算是個組長。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦？",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_035"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那你都說成這樣了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就交給你了……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那傢伙是怎樣……",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_036"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "工作時，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "看起來就可靠了點嘛……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哼……",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_037"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真囂張。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好，我收回之前說的話。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n完全不可靠――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這個組長，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "馬上就迷路了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，騙人吧。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為，我記得",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就我拿到的地圖――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "――你看，果然。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_040"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n已經相當偏離規定的路線不是嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很拼命。（笑）",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_041"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，那什麼藉口，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_042"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "超無法理解。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n有聲音傳來，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼的――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "少女的聲音",
        "words": "呀啊啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_1108006_043"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "――！",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n有人被襲擊了！？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "不、",
        "unit_id": 2911,
        "voice": "vo_adv_1108006_045"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "不要啊啊！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "噫，",
        "unit_id": 3111,
        "voice": "vo_adv_1108006_046"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "不要過來――！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那些女孩子……！",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "明明發出了注意警告，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "在這種地方做什麼――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "同年級的學生。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "當然。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_049"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我衝過去引開注意力，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n{player}趁那段時間把那些女孩子――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊！？",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n等等……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是什麼，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "身體變的超級輕……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n咦？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "　是你的魔法……？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了無所謂，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等再聊！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這樣的話就能馬上結束……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呼！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗……",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_052"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好煩啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怪物。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "玩鬧過頭了唷。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "啊，",
        "unit_id": 2911,
        "voice": "vo_adv_1108006_053"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "啊啊啊……？",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "　克蘿依……？",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你看。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_054"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我的朋友，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在很害怕啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可以安靜一點嗎。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗呼……",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_055"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "已經沒事了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n沒受傷吧？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "沒、",
        "unit_id": 3111,
        "voice": "vo_adv_1108006_056"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "沒、",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "沒事……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳要顫抖到什麼時候。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_057"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就說沒事啦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "魔物已經完全打扁囉。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n吶，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還站得起來嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "咿咿咿！",
        "unit_id": 2911,
        "voice": "vo_adv_1108006_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦……？",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_059"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_060"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來如此。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "比起魔物，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "能夠輕鬆打倒魔物的我比較可怕啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，也對。",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_061"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "無所謂。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總之，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳沒事就太好了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好了，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_062"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "父母會擔心的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "早點回去――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "那、",
        "unit_id": 3111,
        "voice": "vo_adv_1108006_063"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "那個，",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "這個……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "該怎麼說……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "再、",
        "unit_id": 3111,
        "voice": "vo_adv_1108006_064"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "再會！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好有禮貌啊。",
