        "voice": "vo_adv_1108006_068"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "太好了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，",
        "unit_id": 110811,
        "voice": "vo_adv_1108006_069"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這麼說來{player}也是呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不是很帥嗎，",
