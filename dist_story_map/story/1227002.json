        "type": "dialogue",
        "name": "女子",
        "words": "鏡華，",
        "unit_id": 5412,
        "voice": "vo_adv_1227002_026"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳能使用那種魔法嗎……！？",
        "unit_id": 5412
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是……",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是的。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這個啊，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是原創的魔法……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "原創！？",
        "unit_id": 5312,
        "voice": "vo_adv_1227002_028"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n意思是妳自己創造了魔法嗎！？",
        "unit_id": 5312
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不，",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "創造的人並不是──",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "鏡華",
        "unit_id": 5412,
        "voice": "vo_adv_1227002_030"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "還真是不管什麼都辦得到呢！",
        "unit_id": 5412
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "算了，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n之後再說明也行吧……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "前陣子，",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在我去找{player}商量之後，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們一起想了",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要在夏令營使用什麼樣的魔法才好呢。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "然後，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}所想到的是──",
        "unit_id": 122711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯～",
        "unit_id": 103611,
        "voice": "vo_adv_1227002_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然我是很感激你的幫忙，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但關於要教大家的魔法，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該如何是好呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "攻擊魔法要是受傷了會很危險。",
        "unit_id": 103611,
        "voice": "vo_adv_1227002_034"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……感覺能在海中使用的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "厲害魔法……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 103611,
        "voice": "vo_adv_1227002_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……能在水中",
        "unit_id": 103611,
        "voice": "vo_adv_1227002_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呼吸的魔法？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我可沒聽說過那種魔法啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1227002_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是凱留小姐",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "原創的！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n好、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好厲害……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果有那個，",
