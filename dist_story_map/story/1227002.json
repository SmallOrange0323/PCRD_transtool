        "voice": "vo_adv_1227002_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯♪",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那麼現在起，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為了將要在夏令營",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "提交的學習課題，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我想來開始進行魔法的練習了。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "終於啊！",
        "unit_id": 5412,
        "voice": "vo_adv_1227002_021"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "會是什麼樣的魔法呢……！",
        "unit_id": 5312,
        "voice": "vo_adv_1227002_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個嘛，",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n今天",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要練習的魔法──",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "──是",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "水上步行。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "水上步行是……",
        "unit_id": 5312,
        "voice": "vo_adv_1227002_025"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "在水面上行走的魔法！？",
        "unit_id": 5312
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n那種魔法",
        "unit_id": 5312
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "就連教科書上都沒記載啊……！",
        "unit_id": 5312
    },
