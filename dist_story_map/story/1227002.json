    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}。",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你過來這邊一下。",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請坐在那裡。",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要跪坐喔。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你還記得，",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n今天是要來這裡做什麼的嗎？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哦，",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你記得呢。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n明明記得，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "卻還像那樣大玩特玩呢。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才不是！",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大錯特錯！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你果然忘了呢！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我就在想是不是那樣！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是夠了。",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "身為大人，這是怎樣？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還像小孩子一樣，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "跟大家一起玩鬧。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在這片海中，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你看起來可是最開心的那一位喔？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明是個大人，都不覺得羞恥嗎？",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "會覺得吧？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n既然如此，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就請你",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好～好反省。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "自由時間也差不多該結束了。",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……得展現魔法給大家看才行。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要麻煩你……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "幫忙了。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為了盡量不被大家發現，",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你要從遠處使用那不可思議的力量。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "問我為什麼……",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那是因為，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大家",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "都覺得我能使用厲害的魔法……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以不就不能被他們看見",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我失敗的場面了嗎。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總、",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總之！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你要按照約定",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好好幫忙喔！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……雖然這樣可能很奸詐，",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但我",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是大家的隊長。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好了──",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請大家集合──！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "小組的大家都到齊了嗎？",
        "unit_id": 122711,
        "voice": "vo_adv_1227002_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n身體不舒服的人要舉手喔。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "沒有問題──！",
