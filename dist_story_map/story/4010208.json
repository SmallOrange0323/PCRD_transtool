    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊！",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "找到你了小哥！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "明明每次都不請自來，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n要找你的時候又都找不到人！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才不是",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「有事嗎？」吧！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你以為今天是什麼日子！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……你不知道嗎？",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還真是一如往常笨笨的！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真拿你沒辦法，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就直接告訴你吧。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "今天是！",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我的！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "生日！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵。",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "更加盛大地",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為我慶祝吧！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n平時都是我在照顧小哥。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥也一定超想為我慶祝的對吧！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可以嗎……？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說的也是！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就給小哥一點展現氣魄的機會吧！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼？",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還可以買禮物……？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "明明是我不請自來的，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓你做到那種程度的話，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還真是會",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有點良心不安……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等、",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等一下！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒有叫你這麼精力充沛地慶祝──",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哇啊啊！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n為什麼！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "路過的人",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也一起加入了！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對不起，",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "普通一點！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n普通地慶祝就好了～～～～～！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀啊～～～～～～～～～～～～～～～～～～～！",
        "unit_id": 106631,
        "voice": "vo_adv_4010208_009"
    }
]