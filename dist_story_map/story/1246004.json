    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好的，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那黑咖啡就給你～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我喝咖啡拿鐵～",
        "unit_id": 101532
    },
    {
        "type": "still",
        "still": "124600402"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……嗯，",
