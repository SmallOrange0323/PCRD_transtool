        "voice": "vo_adv_1246004_038"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝你♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那麼，我們晚點再見囉～",
        "unit_id": 101532
    },
    {
        "type": "background",
        "background": "510131"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過了一段時間後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在約好的時間點回到會合地點──"
    },
    {
        "type": "still",
        "still": "124600401"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "讓你久等了～",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_039"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n來，",
