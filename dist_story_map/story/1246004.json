        "voice": "vo_adv_1246004_042"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你嘴巴真甜～♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我就是想聽你這麼說，所以很努力打扮，我很開心喔～",
