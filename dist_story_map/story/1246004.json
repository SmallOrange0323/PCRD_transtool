    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "新年的假期就到此結束。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n從明天開始，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "又要幹勁十足地努力工作囉～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯，",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_063"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很開心喔♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你還記得",
