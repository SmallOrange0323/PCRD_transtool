    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來，{player}。",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_043"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你可以選杯咖啡嗎～？",
