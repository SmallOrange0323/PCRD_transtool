        "voice": "vo_adv_1246004_049"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "難道你是因為被誤認成我弟弟，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_050"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n所以才努力裝大人，在逞強嗎……？　",
