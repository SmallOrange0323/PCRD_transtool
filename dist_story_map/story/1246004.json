        "voice": "vo_adv_1246004_032"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們很難被看成一對情侶呢。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……對了，{player}。",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_033"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n在遇到我們之前，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你原本是要去辦什麼事嗎？",
