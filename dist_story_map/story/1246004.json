        "voice": "vo_adv_1246004_044"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "另一杯是咖啡拿鐵。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n{player}，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你比較喜歡甜甜的咖啡拿鐵吧～？",
