[
    {
        "type": "background",
        "background": "500191"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "玩完歌牌遊戲，等孩子們都回去後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n美里與{player}一起整理環境。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}，\n抱歉，還讓你留下來幫忙整理環境。",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不知從什麼時候開始，",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我就很常拜託你幫忙……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "身為老師，我應該要再振作一點～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哇啊，我好開心，",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "感覺你已經是個很可靠的大哥哥了～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n聽你這麼說，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我可能真的會一直拜託你幫忙呢♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "話說回來……",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這個暖桌",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的很棒呢～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n初音若看到了，肯定會很高興地躲進去睡午覺♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……？",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你說要我也坐進暖桌試試看？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n因為新年期間工作忙碌，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "希望我好好休息……？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你真是個",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "體貼的好孩子～♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，我就恭敬不如從命囉……♪",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n老實說，我也很想稍微體驗一下呢。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯，",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "只要往暖桌的棉被裡坐……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嘿咻……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "…………呼，",
        "unit_id": 124611,
        "voice": "vo_adv_1246004_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好舒服……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……舒服到彷彿看到一道亮光……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呀～～～？",
        "unit_id": 124611
    },
    {
        "type": "background",
        "background": "510130"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嘿咻……！",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嘿咻……！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "滾呀滾呀滾♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n呵呵，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "頭的部分應該這種大小就行了。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "接著只要把這顆雪球擺上去，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雪人就完成了～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "太棒了～！",
        "unit_id": 231,
        "voice": "vo_adv_1246004_009"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n快點把雪球擺上去～♪",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "…",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "…嘿咻……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一個人搬很重的。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我也一起來……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唔、",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呀啊！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀哎呀，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是{player}啊。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……呵呵，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝你一把抱住我。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我差點就要滑倒了～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n幸好雪人的頭",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也平安無事～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……那個，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我已經沒事了，你可以放開我囉？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n一直維持這種姿勢，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "讓人覺得有點難為情……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝你～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你也要幫忙把雪人的頭擺上？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，請你扶著另一邊……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嘿咻！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好了～",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雪人完成囉～♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "哇，",
        "unit_id": 231,
        "voice": "vo_adv_1246004_016"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "好可愛～～！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n美里老師、",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "大哥哥，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝你們！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "太好了～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那老師要稍微休息一下♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣啊？",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那我們到那邊的長椅坐一下吧。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對了，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我還沒跟你賀新年呢。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "新年快樂♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "剛過新年就能遇到你，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n感覺今年會是個很棒的一年……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒什麼啦♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "怎麼了嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n突然握住老師的手……！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可能有點凍僵了。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n所以，你要幫我把手搓暖吧。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你真的很體貼呢♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "美里老師，",
        "unit_id": 1231,
        "voice": "vo_adv_1246004_023"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "新年快樂。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n今年也請妳多多指教。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這位媽媽妳好，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "新年快樂♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "幼兒園明明還在放假，",
        "unit_id": 1231,
        "voice": "vo_adv_1246004_025"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "這孩子卻一直吵著說要見美里老師……",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n打擾到妳與家人相聚的寶貴時間，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真的很抱歉……",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "？",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_026"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "妳是說",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "家人嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "是啊，",
        "unit_id": 1231,
        "voice": "vo_adv_1246004_027"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "我今天才知道，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "原來妳有個這麼可愛的弟弟。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "美里老師，",
        "unit_id": 231,
        "voice": "vo_adv_1246004_028"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝妳～！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "掰掰～♪",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真是受妳照顧了～！",
        "unit_id": 1231,
        "voice": "vo_adv_1246004_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不～",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_030"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那麼，下次我們在幼兒園見囉～♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_031"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在他人眼裡看來，我們似乎就像是一對姊弟～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n就年齡而言，會被誤認為姊弟也是正常的……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看來……",
