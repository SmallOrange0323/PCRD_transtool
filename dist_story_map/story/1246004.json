    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101532,
        "voice": "vo_adv_1246004_040"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對吧。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為很冷，所以想說買杯咖啡什麼的……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我也有買你的份喔～",
