        "voice": "vo_adv_1246004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也變得越來越成熟可靠了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n其實我也有感覺到喔。",
