[
    {
        "type": "background",
        "background": "502332"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞，",
        "unit_id": 131711,
        "voice": "vo_adv_5150411_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳應該有話要跟大家說吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這次",
        "unit_id": 190912,
        "voice": "vo_adv_5150411_001"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我的惡作劇造成各位的困擾，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我深感抱歉。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳有乖乖說出來呢～♪",
        "unit_id": 131811,
        "voice": "vo_adv_5150411_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n向人賠罪也是很重要的哦～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗚嗚",
        "unit_id": 190912,
        "voice": "vo_adv_5150411_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難得的夏天耶……",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這樣夏天會在我只能顧著低頭道歉中結束的……",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……妳在說什麼啊。",
        "unit_id": 131711,
        "voice": "vo_adv_5150411_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n夏天還沒結束吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐……？",
        "unit_id": 190912,
        "voice": "vo_adv_5150411_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也是很期待的哦。",
        "unit_id": 131711,
        "voice": "vo_adv_5150411_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "期待這個大家都",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "樂在其中的",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "暑假。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "機會難得，",
        "unit_id": 131811,
        "voice": "vo_adv_5150411_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們就讓城鎮再稍微維持這個樣子，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n然後來享受一下跟平時不一樣的蘭德索爾吧～♪",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是這麼回事。",
        "unit_id": 131711,
        "voice": "vo_adv_5150411_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n來，走囉，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……嗯♪",
        "unit_id": 190912,
        "voice": "vo_adv_5150411_009"
    }
]