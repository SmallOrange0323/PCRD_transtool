[
    {
        "type": "background",
        "background": "500023"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "約定的日子終於到來，望前往了約好見面的地方。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "果然還是太早來了啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "距離約好的時間還有很久呢……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "期待到沒辦法待在家裡所以跑出來了，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總覺得像小孩子一樣有點丟臉呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是這也沒辦法啊？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這是我第一次跟男生一起過聖誕節，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n當然會很期待呀！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "衣服已經都搭配好了、",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "禮物也確實準備好了、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n想去的店跟活動也確認過了！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "身為偶像",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "必須一直將達到完美作為目標呢！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不對，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我會不會做過頭了？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會不會嚇到他啊？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n應該、沒問題吧？",
        "unit_id": 111611
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抵達了會合地點的",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n聖誕樹下了……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但、",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是這裡有好多人啊！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算是聖誕季，人也太多了吧……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯？　",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}！？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼？　",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明離約好的時間還有很久呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我好像也沒有資格說別人呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "仔細一看好像在準備什麼活動呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個不是【慈樂之音】的海報嗎！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我完全不知道欸？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到底是在做什麼呢，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在這種地方？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像是在做唱片的促銷活動呢。",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是不是盯上了聖誕季的人潮呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們的製作人",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還真是準備萬全呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也沒必要在約會前打工吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這真的很像{player}會做的事呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然想要去幫忙，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是我出去感覺會引起騷動，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n反而會造成困擾，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是偷偷地觀察他工作吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "搭建臨時的販賣攤位，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "準備傳單跟周邊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n招攬客人還有為到場的粉絲整隊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了在寒冷的天氣中讓活動成功，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n大家都好拼命呢……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為有大家在背後支持我們，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們才能盡情地做自己的工作呢，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "得好好感謝他們呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "喂喂，",
        "unit_id": 1411,
        "voice": "vo_adv_1116002_017"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "不會吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "活動馬上就要開始了啊，怎麼辦啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎、",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼了？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有突發狀況？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "唱片的播放器居然故障了，",
        "unit_id": 1411,
        "voice": "vo_adv_1116002_019"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "這可是新歌的促銷活動啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n沒有歌的話根本辦不下去啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "為什麼沒有確認啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "非、",
        "unit_id": 1111,
        "voice": "vo_adv_1116002_020"
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "非常抱歉……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "\n我會馬上準備新的播放器。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "就算你說要準備，",
        "unit_id": 1411,
        "voice": "vo_adv_1116002_021"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "是想回去辦公室拿嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n那樣來不及吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "喂、",
        "unit_id": 1411,
        "voice": "vo_adv_1116002_022"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "喂等等……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "跑掉了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "那個打工的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "知道辦公室在哪裡嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，稍微等等！",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "關於這部分無可奉告！",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我知道！",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我知道所以你冷靜一點！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我剛剛都聽到了。",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "播放器，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "壞掉了對吧？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但就算是要去拿替換的播放器，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不管多麼快都來不及的。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就用現在有的東西來應對吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "交給我吧，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我已經有想法了。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一起合力",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "渡過這個難關吧！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "勇氣的翅膀　",
        "unit_id": 1,
        "voice": "vo_adv_1116002_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "向天空展翅～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "欸欸――，",
        "unit_id": 1011,
        "voice": "vo_adv_1116002_030"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "是小望的清唱！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "唱得好棒啊！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "好像只有今天這場活動",
        "unit_id": 311,
        "voice": "vo_adv_1116002_031"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "\n可以聽到的限定版本喔。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "不枉我在大冷天跑來！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "唉呀，",
        "unit_id": 1111,
        "voice": "vo_adv_1116002_032"
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "一時之間還真是不知道如何是好呢，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "真是幫上大忙了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "\n客人們也都",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "很滿意呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "可是你啊，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "是從哪裡弄來這種稀有音源的？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "作戰好像很成功呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家都沒想到居然是本人在",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "販賣處裡面唱歌吧？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為有得到{player}的能力強化，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以沒有麥克風也能唱出音量，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喉嚨也沒有問題。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一直以來都是受到大家的支持，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次要換我來努力了！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "辛苦了。",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "活動成功結束真是太好了呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不客氣。",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然出了一些狀況，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但是順利結束真是太好了呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也吸引到了粉絲以外的客人，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n唱片也完售了，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "努力有回報呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是呢，",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可不能覺得已經結束了喔？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們的約會現在才要進入正題呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛剛",
        "unit_id": 111611,
        "voice": "vo_adv_1116002_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唱了很多歌現在狀況很好呢，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要好好的享受了呢！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "成功渡過了意外事故，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n情緒更加高昂的望，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次下定決心，要完成一場最棒約會。"
    }
]