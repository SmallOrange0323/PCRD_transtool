[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如此祭典盛會，",
        "unit_id": 129711,
        "voice": "vo_adv_5213084_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "百姓之心自是歡騰雀躍。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若要為前來的老老少少，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "烹製皆大歡喜之料理……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此事著實令奴家頗費思量。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "要令萬人心花怒放，",
        "unit_id": 129711,
        "voice": "vo_adv_5213084_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實乃難中之難。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "且先為那可愛的孩童們，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "備上一道撩撥童心之佳餚吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若得騎士閣下相助，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "定能成就一道美味之品。",
        "unit_id": 129711
    }
]