[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後，\n【美食殿堂】一行人依照計畫來到了海邊，\n享受「迷人的南國之旅」。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}～！快過來快過來♪",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你看，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這樣的淺灘也有魚游泳耶！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從我的腳縫間滑溜溜～地游走，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真是嚇了我一大跳！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是紅色的那條！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我是說那邊那條黃色的魚，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有看到嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為牠非常漂亮，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以想讓{player}也看看呀！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n來，把臉靠過來這裡一點～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嘿，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有機可乘！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "潑水～☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈！",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起哦，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把水潑到你身上了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為{player}，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不知道為什麼都不走進海裡來嘛♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果讓你全身濕透的話，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你就會做好無論弄到多濕都行～的覺悟了吧？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓全身沾滿鹹鹹的海水，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起盡興地玩吧！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然{player}因為失去了記憶，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也許會覺得大海詭譎多端而感到害怕……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但其實並不可怕哦～",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n被陽光曬到發燙的肌膚浸泡在水中，真的很舒服～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼都看起來閃閃發光的，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常的美麗……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈嗚！？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "討厭，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然趁人家在說話的時候潑水呢！？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過沒關係，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "誰叫一開始先潑水的是我呢……！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿～嘿～",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是報仇的報仇！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我潑我潑～☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很好玩對吧～，{player}♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈，",
        "unit_id": 107811,
        "voice": "vo_adv_1075002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他們就像小孩子一樣",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "玩得不亦樂乎呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "玩得開心是很好啦～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過照他們那樣的玩法，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到了傍晚就會累得動不了了啦。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 107811,
        "voice": "vo_adv_1075002_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正貪吃佩可總是精力充沛，應該是沒什麼問題。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "倒有點擔心{player}～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙平常明明就正正經經的，今天怎麼有種脫序的感覺？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 107611,
        "voice": "vo_adv_1075002_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下原本就覺得主人是個開朗的人。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就像貪吃佩可小姐那樣……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以與其說是和平常不同，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不如說展現出了本性吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們所熟悉的，",
        "unit_id": 107611,
        "voice": "vo_adv_1075002_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個溫柔穩重的主人好像慢慢地在改變……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n本來對於主人變回原本樣子的這件事，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下有些微害怕的感覺。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但看到主人現在像小孩子一樣玩鬧的樣子後，",
        "unit_id": 107611,
        "voice": "vo_adv_1075002_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n整體來說，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不覺得討厭或可怕。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論怎麼改變，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人就是主人吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 107811,
        "voice": "vo_adv_1075002_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也是「小孩子」吧，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別盡想那麼複雜的事情，就也變成笨蛋玩在一起如何？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是開心的假期哦，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去玩水吧～♪",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 107611,
        "voice": "vo_adv_1075002_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也對呢，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐所言甚是。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留～！",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿～！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不要光是兩個人感情很好地聊著天，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "過來一起玩吧♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要把海星",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "扔到拖拖拉拉的人身上哦！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看招看招☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還不快住手！",
        "unit_id": 107811,
        "voice": "vo_adv_1075002_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要亂丟生物啦，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠很可憐耶！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 107811,
        "voice": "vo_adv_1075002_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可真的很幼稚耶，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n常常說些像是大家一定要在一起～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種撒嬌的話。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明是【美食殿堂】裡年紀最大的說。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1075002_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐和主人差不多年紀呢……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n外表很美麗，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有種成熟姐姐的感覺。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有魅力，",
        "unit_id": 107611,
        "voice": "vo_adv_1075002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又漂亮……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有尊貴的氣質。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是位理想中的女性，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下很是羨慕。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啦，",
        "unit_id": 107811,
        "voice": "vo_adv_1075002_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙只看外表的話的確很不錯啦。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但一說話就像個呆子。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳是不是又說我壞話了？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老是說別人壞話，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會被討厭的唷～？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我還是永遠都最愛妳了啦！",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n快過來快過來，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "給妳一個抱抱哦～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "煩耶，熱死了啦。",
        "unit_id": 107811,
        "voice": "vo_adv_1075002_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳那種怪力，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被妳緊抱住的人骨頭會斷掉的……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難得開開心心出來旅行，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "途中受傷的話也太慘了吧？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次沒問題的啦。",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳看妳看，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我只有普通人的腕力而已。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇？",
        "unit_id": 107611,
        "voice": "vo_adv_1075002_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不可以緊緊抱著主人……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位都穿著泳裝，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的舉止有點太大膽了哦。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦……",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說來的確是肌膚緊貼在一起，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像不太好呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起哦{player}，我馬上移開～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚呀啊！？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 107811,
        "voice": "vo_adv_1075002_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "危險！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可那傢伙，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被海浪絆住腳了嗎……？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼呀！？",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝、",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你哦，{player}！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝你幫忙扶住我～！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇、哦！？",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼～",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛才真是危險！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "差一點就跌倒了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝你抓住我的手扶住了我，\n{player}♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你可以就這樣",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把我直接拉起來嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個姿勢的話，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像沒辦法靠自己的力量起來呢！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻煩你了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一二三，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿咻～☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哦，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}意外地很有力氣呢！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為是男孩子的關係吧♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為這附近有些珊瑚什麼的，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果跌倒壓壞它們的話可就糟糕了呢～。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n摔得太用力的話，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有可能被貝類之類的東西劃傷皮膚的。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你幫了我一把哦，{player}。",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留剛剛說的沒錯，",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好不容易開心地出來旅行卻受傷的話就太慘了呢……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會謹慎一點，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "注意不要玩到得意忘形了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和【美食殿堂】的大家度過的第一個假期、",
        "unit_id": 107511,
        "voice": "vo_adv_1075002_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "第一次的大海！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果能夠成為一段在往後回想起來時，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都沒有留下任何遺憾的美好回憶就好了……♪",
        "unit_id": 107511
    }
]