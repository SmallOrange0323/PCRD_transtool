[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，\n怜與{player}為了尋找能進一步"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "引出公主型態之力的方法，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在王都中查閱著書籍。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到這裡竟然也沒有……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來王宮的書庫裡沒有什麼值得參考的資料呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我本來還期待能在那裡",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "找到點線索的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你特地來幫我，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n卻接連都只是白忙一場。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼能不在意呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我佔用了你寶貴的時間，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不能就這樣一無所獲的回去。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也明白，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "漫無目的地尋找是沒有意義的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然明白，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還是無法就這樣毫無作為。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接下來要去哪裡找呢……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦咦！？",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嚇了我一跳。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真突然啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我懂你的意思。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可是，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不知道【憤怒‧軍團】",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼時候又會攻過來。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說實話，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們沒時間原地踏步了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正因如此，現在……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在你看來，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在的我太過拼命了呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如此替我著想。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n埋首於某件事就容易忘我，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是我的壞習慣呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說是休息，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我該怎麼做才好？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n若要休息，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "單純什麼都不做也是一種方法……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真傷腦筋。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過確實是該休息一下了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總之先去吃點東西，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想想該怎麼休息吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼了？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "走，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們快去找餐廳吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一意識到自己的狀態，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "肚子就突然變得非常餓呢。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我開動了。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……嗯。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真好吃。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "欸，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你剛才說",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要我休息，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n究竟",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼做才稱得上是休息呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "休息也算是行動的一種。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說完「立正」",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的下一步是什麼？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是「稍息」",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "學校應該有教過吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所謂的「什麼都不做」",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "本身也是一種行為。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然後，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼樣的行為",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對現在的我而言算得上是休息，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n又能否為我的下一個行為帶來更好的結果……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就是在考慮這些。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是像這樣",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "攝取營養價值高的食物，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n然後盡可能不消耗體力嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該進行冥想，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "培養專注力呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對現在的我而言最合適的休息方式",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "究竟是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有這回事啦。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我只是深信，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一旦決定做某件事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只要全力以赴，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就總會",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有辦法完成罷了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "工作自然不用說，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就連興趣、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "娛樂也是。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論是釣魚、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是劍術，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我都抱持著這樣的心態……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不知道除此之外的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "生活方式呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為以前在老家，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n自己付出的努力",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是無法留下持續性的成果，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我這個人的存在本身就不會被認可……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在為數不多的自由時間裡，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我連玩樂都會全力以赴……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以前我經常",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和祖父一起去釣魚呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就在練完劍之後。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好懷念啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我已經有一段時間",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒去釣魚了呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "海釣的話免不了在外過夜，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n若是附近的河邊倒是沒問題……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好主意。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得和你在一起，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n去悠閒地釣個魚也不賴呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等我們吃完飯",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就拿上釣具去河邊吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真期待呢。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和怜帶上自己的釣具來到了河邊。\n兩人並肩坐在岸邊開始釣魚……"
    },
    {
        "type": "still",
        "still": "180300201"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "魚都不上鉤呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "糟糕……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有點",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "睏了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……是我的錯覺嗎，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我現在好像",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正往他身上靠……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我之前來的時候，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然算不上是大豐收，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但還是有釣到一些魚……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……真不可思議。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明總是告誡自己",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要保持著備戰狀態，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但像現在這樣什麼也不做時，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n竟然會希望這樣的時光能一直持續下去。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放在以前，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果像現在這樣無所事事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我甚至會感到焦慮不安。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會將祖父教會我的釣魚持續到現在，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n大概也是為了約束那樣的自己吧……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我說，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你不會覺得無聊嗎……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就好。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……都釣不到呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但是，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我現在、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想就這麼待著……",
        "unit_id": 100311
    },
    {
        "type": "still",
        "still": "180300202"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在你身邊、",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再多待一段時間……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就這樣度過平靜的時光……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "暫時、",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "忘記一切……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_041"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯嗯……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我該不會是、",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "睡著了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你刻意沒叫醒我的吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也就是說，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們都沒釣到魚呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論是魚還是大自然，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都不會按照人類的意志行動。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也會有這種時候啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就知道你會這麼說。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……真的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很謝謝你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天多虧有你，我才能稍微喘口氣。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟最近都沒怎麼好好休息，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天算是徹底放鬆了呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "祖父一定也",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和我一樣，在練劍與工作的空檔，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n藉著釣魚得到了放鬆吧……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……話說回來，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "祖父給我的技法書，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我還沒複習過呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼會這樣。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這就是所謂的「當局者迷」嗎！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "快回鎮上去吧！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "祖父指導我劍術的時候，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "給了我一本秘傳的技法書。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那上面",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或許會有什麼線索。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我為什麼沒想起那本書啊……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連我自己都能感受到，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在的我無論是精力還是體力都十分充沛。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這都是多虧了剛才有和你一起好好休息。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，",
        "unit_id": 100311,
        "voice": "vo_adv_1803002_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們快出發吧！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那本書",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一定也能成為你的力量。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們兩人今後",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也一起變得更強吧！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，為了尋找怜從祖父那裡得到的技法書，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人快步趕回了蘭德索爾。"
    }
]