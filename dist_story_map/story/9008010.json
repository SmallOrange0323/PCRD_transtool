[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這麼說來，",
        "unit_id": 100311,
        "voice": "vo_adv_9008010_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "莉莉妳們所屬的【幻變少女】，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n幫了許多公會的忙呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是。",
        "unit_id": 125812,
        "voice": "vo_adv_9008010_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在兄長大人的指導下，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我們替大家提供了幫助。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然還不曉得，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是否真的有幫上了忙……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100311,
        "voice": "vo_adv_9008010_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也可以",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "拜託妳們幫個忙嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如果有我能辦到的事，",
        "unit_id": 125812,
        "voice": "vo_adv_9008010_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那我很樂意。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "究竟是要做什麼呢？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "替他進行劍術修行……",
        "unit_id": 100311,
        "voice": "vo_adv_9008010_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最近沒什麼時間陪你練習，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以很久沒訓練了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你一定進步了吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_9008010_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就要看你的表現了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到底進步了多少……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我很期待看到成果喔！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個，",
        "unit_id": 125812,
        "voice": "vo_adv_9008010_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "所以說……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "怜小姐是",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人的劍術指導員嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n也就是……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人的",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "師傅大人嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還、",
        "unit_id": 100311,
        "voice": "vo_adv_9008010_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還沒有到被稱為師傅的程度啦。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有時間的時候教他而已……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "怎、",
        "unit_id": 125812,
        "voice": "vo_adv_9008010_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "怎麼會……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也就是說我在不知道您是師傅的情況下，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "隨意地稱呼了您的名字。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n真是太失禮了，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常抱歉。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "從今以後，",
        "unit_id": 125812,
        "voice": "vo_adv_9008010_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請讓我稱呼您為",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「大師傅」……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就、",
        "unit_id": 100311,
        "voice": "vo_adv_9008010_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就說不是師傅了！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那既然",
        "unit_id": 125812,
        "voice": "vo_adv_9008010_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是兄長大人",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "的老師……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就該稱「大姐大人」？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那也有點太誇張，",
        "unit_id": 100311,
        "voice": "vo_adv_9008010_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望妳正常地叫我的名字就好……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……對了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳們也募集其他的委託看看吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正在收聽廣播的觀眾們，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一定也有事情想委託妳們幫忙。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊……",
        "unit_id": 125812,
        "voice": "vo_adv_9008010_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來如此，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不愧是大姐大人。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如果有什麼是我們這些蒙昧無知之人能幫忙的──",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n請務必，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "來信給我們。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我也會誠心誠意地，",
        "unit_id": 125812,
        "voice": "vo_adv_9008010_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "輔佐兄長大人進行劍術修行……！",
        "unit_id": 125812
    }
]