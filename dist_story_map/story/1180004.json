    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「給我等一下！",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是你先撞到人的耶，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那什麼態度──！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「雖然多虧有mimi，所以似乎能順利溝通……",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我說你們日本少年，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n撞到人也不會說聲對不起嗎？」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「哼。",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n算了，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有乖乖道歉就好了。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「這正巧是個好機會。",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你稍微",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "陪我一會兒吧。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n反正你應該很閒吧？」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「你那是怎樣啦，露出一臉厭惡的神色。",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我也不會要你",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "做免錢白工。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我會確實給付工資，就當作買你的時間。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "更何況……」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「我現在",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "碰上了一點小困難。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我手上裝置的導航系統似乎有點怪怪的……",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n害我迷路到這種住宅區裡。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「呵呵。",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n反應很快嘛，可幫了大忙。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「這麼說來，",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我還沒做自我介紹呢。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我是──」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「我是",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "克蕾雅‧波洋希亞。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是名投資客。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還請多指教了，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "異國的少年。」",
        "unit_id": 118031
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「給我等一下！",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n我說怎麼這麼久都還沒到",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n目的地的椿丘大飯店哪！？」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「既然你不曉得在哪，",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n一開始就別說要帶路啊！！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「唔……",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "沒想到我竟會犯這種失誤。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n拜託路過的學生幫忙是否就是個錯誤決定了呢……」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「……唉。",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n都已經像這樣",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "特地從雪梨遠道而來了，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "卻還比約定時間晚到，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "不曉得會被怎樣取笑哪……」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「這是因為……」",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「……我要洗刷自己的汙名。",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n要報仇雪恥。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "…………",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「剛才也提到過，",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n我是",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "靠投資討生活的。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「現在這時代可便利了。",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "只要有預測世事變化的能力，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "再加上一點點運氣，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n即使足不出戶，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "也能累積莫大的財富。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「沒錯，",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "就是你想的那樣。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n我便是",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "經由投資，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "從幾乎身無分文，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n爬上億萬富翁地位的。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "……然而……」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「大概是我太得意忘形了吧。",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_034"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "竟然不小心……",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "相信了從未見過面、",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n只有透過網路聯繫的對象。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "我賺到的資產，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "有一大半都被搶走了。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「而多虧如此，",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "我那之後就變得徹底不相信他人。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n才會像這樣，不僱用當地導遊，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "選擇用自己的眼睛判斷，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n親自找一個看起來人還不錯的少年",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "來幫我帶路。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「而最後，",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_036"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "騙走我錢的那個詐欺師也銷聲匿跡了。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "今天約好要見面的又是另外一位……",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "透過網路斥責、",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n取笑",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "可憐的我，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "一個不可饒恕的傢伙。」",
        "unit_id": 118031
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「好啦！",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n總算是抵達椿丘大飯店了！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「有勞你帶路了，",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "少年。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n然後……」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「來，",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_039"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "我們上吧！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「你怎麼一臉呆樣？",
        "unit_id": 118031,
        "voice": "vo_adv_1180004_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "都到這地步，我們算是患難與共了。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n你也和我一起",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "殺進去吧！」",
        "unit_id": 118031
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1180004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "克蕾琪塔",
        "unit_id": 190011,
        "voice": "vo_adv_1180004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗎……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然在蘭德索爾的時候也是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但在那世界，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她也是個怪傢伙啊～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1180004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種記憶……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n到底是從哪冒出來的？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許是因為對你來說，",
        "unit_id": 190011,
        "voice": "vo_adv_1180004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這段記憶一點也不重要，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又或者是……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1180004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看來今天就到此為止了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然有點在意，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但算啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次再見囉。",
        "unit_id": 190011,
        "voice": "vo_adv_1180004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然她是個怪傢伙，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也別對其太嚴苛哪～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n否則很可憐耶。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唔、",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_047"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔～嗯……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……啊！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "剛、",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_049"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "剛才的究竟是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "失去意識了嗎……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然完全搞不清楚",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_050"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "到底發生了什麼事……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……但比起這個！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "來吧，",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你快說！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n快點仔細告訴我！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n能夠討公主殿下歡心的方法～！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}被克蕾琪塔糾纏了好一段時間不放……"
