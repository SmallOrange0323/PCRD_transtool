    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當{player}一個人獨自走在街上……"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下！",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n小心一點哪，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "撞到人是不會──",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……噢。",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n原來是你啊。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你好啊。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好的，",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再見。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……給我等一下！",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你給我稍等一下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這正巧是個好機會。",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你稍微",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陪我一會兒吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n反正你",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "應該很閒吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你那是怎樣啦，露出一臉厭惡的神色。",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也不會要你",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做免錢白工。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我會確實給付工資，就當作買你的時間。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "更何況……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我從以前開始，",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就對你挺有興趣的喔？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就說你別擺出那種厭惡的表情啦！",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n真是的，有夠失禮耶！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你聽好了。",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為了避免誤會，我就先說明清楚，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我剛才說的興趣，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可不是那種",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "男女間的在意介意會錯意，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我對你完～～全",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒那個意思唷？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……我只是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然你有點，",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "應該說是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "非常地超級不可靠……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但你畢竟是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "守護陛下的騎士。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因此對於你是怎麼受到陛下青睞的，",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "非常有興趣……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不是！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我是說，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "弄清楚你的人品，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n對我而言",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是件非常重要的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦？",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這、",
        "unit_id": 118011,
        "voice": "vo_adv_1180004_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這道光是什麼呀！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咿咿咿咿～！？",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當{player}一個人獨自走在街上……"
