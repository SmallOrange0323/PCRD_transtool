    },
    {
        "type": "background",
        "background": "500161"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今日的檢測目標終於全數達成了──"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "你們倆",
        "unit_id": 1411,
        "voice": "vo_adv_1226003_006"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "真的做得很好喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n優衣一開始很僵硬，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "但中途開始就變得積極主動了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n還幫忙提出了一些改善方案，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "在各方面都很活躍！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我今天確定了。",
        "unit_id": 1411,
        "voice": "vo_adv_1226003_007"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n這一定會是場成功的慶典。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "太晚了啦。",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_008"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n拜託在借錢之前就先確定好啊。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我很高興",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有幫上兩位的忙。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "所以，",
        "unit_id": 1411,
        "voice": "vo_adv_1226003_010"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "你們明天",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "會繼續過來對吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "檢測項目",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "還剩下一半。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_011"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "沒辦法的話也可以拒絕喔？",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……當然沒問題。",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n如果能幫上忙的話，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我很樂意。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "夫妻",
        "words": "太好了！",
        "unit_id": 1,
        "voice": "vo_adv_1226003_015"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "我說啊，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_016"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "你們兩個待會有空嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……？",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有的。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "把那當作額外獎勵實在不好意思，",
        "unit_id": 1411,
        "voice": "vo_adv_1226003_018"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n不過那真的是看了不吃虧的美景。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n我還要替明天做準備，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "就讓專務帶你們過去吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……美",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "景？",
        "unit_id": 122611
    },
    {
        "type": "background",
        "background": "500282"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優衣和{player}兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n跟著專務來到了海灘的外緣──"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這種地方",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有棧橋？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "很意外吧，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_021"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這裡以前似乎是個碼頭。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n我們要走到這座棧橋的最前面去。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "雖然腳邊是有亮光，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "但還是要小心點，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "畢竟這很舊了。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好、",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好的……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "好，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_023"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "到囉……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "怎麼樣啊！",
        "unit_id": 6511
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "………………！！！！",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們被星星……",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "包圍著！？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "很厲害吧？",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_026"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n這裡海面不可思議地平靜，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n所以星星映照在水面上，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "就能看見360度的星空。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "頭上跟腳下，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "全部都是",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "星星……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n漂亮到",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都快不曉得……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "自己身在何處了……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "……呵呵，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_028"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "妳喜歡",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "真是太好了。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n其實啊，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這裡是我",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "充滿回憶的地方。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n算是我們夫妻的",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "原點吧。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩位的……？",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──啊，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這麼說來，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不小心",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "聽到了。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n兩位在說",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這次慶典是你們",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "多年來的夢想的事……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對、",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我不是故意要偷聽的──",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "是這樣嗎？",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_032"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "沒事，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "不要緊的。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n反倒是我覺得不好意思，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "讓妳聽到那種事。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不會，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒那回事……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你們說要為了情侶們",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "舉辦活動。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我想兩位能有這種想法，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n一定是因為有經歷過",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "美妙的戀情……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "讓我覺得很羨慕。",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_035"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "…………",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_036"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "咦，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_037"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "妳說我們？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "經歷過美妙的戀情？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "哈哈，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "怎麼可能。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "就算講委婉一點，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "那也是最爛的戀情。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……？",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_038"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "妳想嘛，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_039"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "我們是精靈族跟人類在交往。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n所以周遭都強烈反對，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "相關人士全都",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "得罪光了。",
        "unit_id": 6511
    },
    {
        "type": "background",
        "background": "500282"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "他的狀況也是一樣。",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_040"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n由於實在太辛苦了，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "所以我們",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "有談過「到此為止分手吧！」",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n而那地方",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "就是這裡。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼會這樣……",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_041"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "呵呵，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_042"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "不過呢……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "妳看，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這片星光很耀眼吧？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "它會把一切全～都照亮。",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_043"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n把內心深處裡裡外外",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "全～都照亮。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "我當時",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_044"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "無論如何都沒辦法",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "對自己的感情說謊。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "因為我就是抹滅不掉",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "「喜歡」啊。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不會吧……",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_045"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "只有這份感情……",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_046"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "我就是拿它沒轍。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "明明別談什麼戀愛，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "人生就會輕鬆很多的說～",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "………………！",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_047"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "總之",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_048"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "正因為如此吧？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n當時也有點賭氣，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "就想說要為了夾在戀愛與人生之間，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n左右為難的情侶們舉辦活動。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "可能是有經歷過那段時期吧，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_049"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n所以多少能體會",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "優衣妳的心情。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……？",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_050"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "我們家那口子說希望你們明天再過來，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_051"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n而我也希望你們能來，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "不過",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "真的不用勉強喔？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "什、",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_052"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "什麼勉強，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才沒有那回事……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_053"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "先生……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這樣啊，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_054"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "你都有注意到啊。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n很棒喔，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "看來是我多管閒事了呢。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "接下來",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "你們就兩個人享受這片景色吧。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "然後",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_055"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "優衣。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n妳",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "被開除了。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……？",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_056"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "下次面試",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_057"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "不只要問有沒有在交往，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n還要再個別仔細地",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "問清楚才行呢，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "嗯。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_058"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "等優衣妳誠實面對自己的感情之後，",
        "unit_id": 6511,
        "voice": "vo_adv_1226003_059"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n我想我們很快就能再見面了……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "不，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "我們一定要再見面！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "加油喔，優衣，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "那我先走囉！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_060"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_061"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我沒……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "事……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_062"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "奇怪？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我到底是",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "眼淚……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "流個不停……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……對、",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_063"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我沒事……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對了，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是有東西跑到眼睛裡了……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不對，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_064"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是的……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "感到安心了。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n對不用再說謊",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "感到安心……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是我卻開口又想說謊……",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_065"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然只是稍微蒙混了一下，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我得鼓起勇氣來……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你聽我說，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_066"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等這個情侶慶典舉辦了，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_067"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要不要一起來玩？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n下次就，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "以客人的身分參加。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒有。",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_068"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果是當客人的話，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想就不用勉強自己了。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n而且一定會",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "玩得比今天還要開心。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這就是",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_069"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我真實的想法……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你願意跟我一起來嗎？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的嗎？",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_070"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n呵呵，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有鼓起勇氣真是太好了。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那就，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_071"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "約好了。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_072"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生你一定會遵守約定的。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不過不是的，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這約定，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是我對自己說的。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "下次要",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_073"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再更坦率一點，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "鼓起更多勇氣……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒事，",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_074"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你別在意。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我跟我自己的約定，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "確實遵守的。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在星光照耀之下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優衣像是在慰勞自己、愛惜自己一般，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n將手放到了自己的胸前。"
    }
]