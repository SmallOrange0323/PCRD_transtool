        "words": "好過分～",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那這招如何！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘿～擠過去擠過去！",
        "unit_id": 122611
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "情侶騎馬打仗────！",
        "unit_id": 1411,
        "voice": "vo_adv_1226003_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生快跑～！",
        "unit_id": 122611,
        "voice": "vo_adv_1226003_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "脖子被勒得很緊？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哎呀對不起……！",
