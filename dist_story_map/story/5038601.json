    {
        "type": "dialogue",
        "name": "美冬",
        "words": "停下來！　",
        "unit_id": 104811,
        "voice": "vo_adv_5038601_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "快給我停下來，好朋友X！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "它已經不接受我們的操控，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "完全暴走了……！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "設計圖明明畫得很完美啊，",
        "unit_id": 103211,
        "voice": "vo_adv_5038601_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "到底是為什麼呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳們有確實照著設計圖去製作吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……那……",
        "unit_id": 104611,
        "voice": "vo_adv_5038601_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那是當然喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只是，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那個喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "即使是同一張設計圖，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但不同的人看，還是會出現認知不同的情況喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難不成，",
        "unit_id": 104611,
        "voice": "vo_adv_5038601_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那個就是原因喵？　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不對，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不可能喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不然是那個……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我有確實裝好喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難不成是那個喵！？　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那個是絕對不可少的喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳怎麼了，珠希！？",
        "unit_id": 103211,
        "voice": "vo_adv_5038601_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳的眼神",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎麼游移得那麼厲害！？",
