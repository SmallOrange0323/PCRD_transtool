    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……應該……",
        "unit_id": 103411,
        "voice": "vo_adv_5038601_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不是我造成的吧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我完全沒有印象。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為我完全喪失了那一部分的記憶，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以再怎麼想，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "應該都與我無關！",
        "unit_id": 103411
