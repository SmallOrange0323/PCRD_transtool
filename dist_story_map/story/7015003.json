[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我說優妮，",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "聖德蕾莎女子學院",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是個什麼樣的地方？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳說什麼樣的地方，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還真是丟了個很籠統的問題來呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個嘛……",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為是所傳統學校，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以那種墨守成規的校風我是不喜歡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n雖是這麼說，但學生們都是青春少女，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以大家都很怡然自得地歌詠青春。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若是說我的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n則是關在舊圖書館棟的私人研究室，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n一整天",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "都在書本與文學的包圍中度過嚴肅的生活──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是這樣啊。",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "然後呢然後呢？",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}的學園生活",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是什麼樣的感覺呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這位家長真是一看就知道她對什麼感興趣了。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然是他的事情，妳去問他不就行了嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是那樣說沒錯，",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是弟弟",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "總是開一些奇怪的玩笑，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n都不肯認真回答我的問題呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "──像是什麼玩笑？",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "像是社團學姐做的小型飛空艇",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在教室裡爆炸，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還有以那個為基礎製作的巨大機關人偶",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "破壞了校舍等等的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "他居然說了那樣的無稽之談。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我問他學了些",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼東西，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他就說了",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "切嚕語？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這種虛構的語言名稱……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "※說法眾說紛紜。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我最近打算舉辦",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n自主性的家長教學參觀去看看弟弟的樣子。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐是個特別的姐姐，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "學院應該也會許可才對。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "解析班，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她到底在說些什麼啊？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只是單純也對於",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「學校是個怎麼樣的地方呢」",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有興趣罷了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "學校上課的時候都教些什麼東西呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "誰曉得呢。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n因為我很少參加一般課程啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n和大家在一起聽老師上課，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也只有入學後的一小段──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "──嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "靈光乍現了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "靜流，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然妳想知道，我就來告訴妳吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就以實踐的方式。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\nOK羅塞塔，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "敲響鐘聲吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "♪砰～",
        "unit_id": 1,
        "voice": "vo_adv_7015003_018"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是什麼鐘聲？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "（喀啦喀啦。）",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗨，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓各位久等了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是特別講師，優妮。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有什麼東西開始了！",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "各位，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請回座位坐好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n欸～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "今天要上的課是國語。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇啊！",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這就是學校上課的樣子！？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n弟弟怎麼辦？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐和弟弟變成同學了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我有預感愛與青春的一大校園戀愛喜劇，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "即將要開幕了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請安靜，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不要竊竊私語。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "欸～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請翻開課本第24頁。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別在意那種小細節，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "用空氣課本就行了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呃……",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n空氣課本的第24頁、",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "第24頁……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "（沙沙、",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沙沙。）",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦咦？",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟你怎麼了？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "忘記帶課本了？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一起看姐姐的課本吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "把空氣桌子靠在一起，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿咻……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "（喀達、",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喀達。）",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不好了～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我在課本第24頁",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "寫了我喜歡的弟弟的名字～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "討厭，弟弟，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不可以看～～～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "（啪沙啪沙啪沙、",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咚喀咚喀！）",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請安靜，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n別自己製造效果音，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也別自己演出空氣戀愛喜劇。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "欸～",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼開始上課。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "上次",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學習了關於「姐姐」這個詞彙，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以這次",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來學習有關「弟弟」這個詞彙的正確用法。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "各位同學，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有人",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "能夠說明「弟弟」這個詞的意思嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有～！",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，靜流。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是指姐姐在世界上最珍視的",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "男孩子！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "答錯了，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這堂課並不是哲學課。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若是查閱國語字典，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n可查到",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "弟弟即是「同父母而年紀比自己小的男子」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼說來，靜流。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_037"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳和{player}並沒有滿足這項條件呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是有滿足命運所以沒問題！",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……好難啊。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_039"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好吧，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就退個一百步來想，「姐姐」還沒有關係。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "畢竟這個詞",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也有「親暱稱呼年輕女性的俗稱」這層廣泛的意思。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n青梅竹馬的姐姐，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也能省略稱為「姐姐」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是「弟弟」",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_041"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這詞就沒辦法了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "擴大解釋得太過頭了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼稱呼在戶籍上沒有親緣且比自己小的一般男子，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n講白一點，這是某種遊戲（玩法）。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "老師，",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_042"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我聽不懂妳在說什麼～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是我才不想被妳說的",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_043"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "台詞排行榜第一名，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是算了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聽好了，靜流。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_044"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我打個比方來說──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不僅擁有這副嬌小軀體",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "都隱藏不住的成熟大人的性感魅力，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n而且還經常",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "被社會上的人評價為「如女豹一般的女人」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不管被如何形容成「如女豹一般」，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我都是個人類，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "並不是「女豹」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳懂了吧，靜流。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_046"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n相同的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「如弟弟一般的男孩子」",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也絕對不會變成「弟弟」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯……",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_047"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n可是優妮又不是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「如女豹一般的女人」……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "閉嘴，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_048"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "該爭論的點不是那裡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聽好了。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_049"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n{player}對妳來說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在國語上只是個外人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n稱呼他弟弟是言語的錯亂。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "身為國語科的教師，我無法容忍這個問題。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是優妮又不是女豹……",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_050"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就叫妳閉嘴了，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_051"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳這傢伙想必是理科的吧？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n夠了，妳乖乖聽女豹說的話。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗷嗚～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦咦～？",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_052"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那姐姐我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該怎麼稱呼弟弟才好？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "叫他外人先生，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_053"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為他是外人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那姐姐我呢？",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_054"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳叫外人小姐，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_055"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為妳是外人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔……",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_056"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別對教師露出那種反抗的眼神。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_057"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學校教育有時候",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "必須壓抑自我的意識",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來強迫自己配合團體社會。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "軍隊不許思考。",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_058"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n來，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "乖乖服從我說的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "開始。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "外人先生外人先生！",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_059"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是外人先生的外人小姐喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你怎麼了，外人先生！",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_060"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果有什麼困擾，要跟外人小姐說喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為外人先生是外人小姐的外人先生啊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你可以儘管跟外人小姐撒嬌喔，外人先生！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如何，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_061"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "感覺很正常吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯～",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_062"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣感覺有點像在對外人耶。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那當然，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_063"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為你們是外人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，",
        "unit_id": 111011,
        "voice": "vo_adv_7015003_064"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "遲早就會習慣吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳不需要急，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "人生可以從頭來過無數次。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "今天的治療……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正，是授課就到此為止吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太好了！",
        "unit_id": 104911,
        "voice": "vo_adv_7015003_065"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮好像總算",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n理解姐姐我們了呢，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人之間依舊毫無進展，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "三人就這樣繼續探索。"
    }
]