    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……嗯、",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_003"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯……？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "………………",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_004"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……Zzz……",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_005"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_006"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真是的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n吵死人了……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……呼啊啊……",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_007"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_008"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這種事。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n一看就知道了吧～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "笨蛋。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我呀～",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_009"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "可不是365天每天二十四小時",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n都在喝著茶看你吵吵鬧鬧的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我也是有要做的事。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……呼啊～",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_010"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……不過嘛。",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_011"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "有救到真是太好了呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那個孩子。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n雪菲。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_012"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哼。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n瞧你在那邊笑嘻嘻的～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我看你",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_013"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "還很想繼續辦歡迎回來派對之類的吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n雖然你可能覺得，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "在下一個世界應該能救到其他消失的玩家，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n而且已經跟當地的公主大人",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "變得要好了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就認為會很輕鬆，但是……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真正辛苦的，",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_014"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是從現在開始。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n要是大意的話馬上就會死掉喔～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我說真的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊……",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_015"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯是啦。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n說不定會死呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n看起來你現在只有自己",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "一個人……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……話說。",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_016"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我這邊",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "也差不多該……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "──啊～",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_017"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n是我這邊的事。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……好了。",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_018"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n就跟平常一樣。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "接下來──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是「吉歐‧尼布爾黑爾」",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "吧？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "黑暗且陰涼，",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_019"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n充滿殭屍跟骨頭之類的傢伙，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n雖然看起來又是個麻煩的地方──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……但也是最後的背面世界。",
        "unit_id": 193211,
        "voice": "vo_adv_2209098_020"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你就好好努力吧～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n英雄。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「米奈娃的禁錮」結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過了一陣子。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n世界恢復了和平──乍看之下是如此。"
    },
    {
        "type": "background",
        "background": "510260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在尋找可可蘿與「長老」一事陷入瓶頸之時。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "收到了初音的聯絡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而前來探望栞的{player}、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "希留耶"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在深月的帶領下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於大學醫院旁邊的研究棟見到了昏睡中的夥伴。"
    },
    {
        "type": "still",
        "still": "220809901"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可、希留耶",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2209098_021"
    },
    {
        "type": "background",
        "background": "510450"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呃……",
        "unit_id": 103832,
        "voice": "vo_adv_2209098_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n貪吃佩可小姐、",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "希留耶、",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「栞……",
        "unit_id": 105831,
        "voice": "vo_adv_2209098_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我失態了。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是……」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「不只是小雪菲。",
        "unit_id": 105831,
        "voice": "vo_adv_2209098_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "除了這棟研究棟裡沉睡的人們以外，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在全世界……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有著",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒辦法從那個世界回來的人們。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「多虧了深月小姐，",
        "unit_id": 105831,
        "voice": "vo_adv_2209098_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再次深刻體悟到",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們必須去做的事。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為此所需要的線索。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……那個。",
        "unit_id": 106031,
        "voice": "vo_adv_2209098_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "照剛才深月的話聽起來，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n首先要找到《阿斯特朗傳奇》主要伺服器曾經使用過的，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n什麼模組的零件對吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是開發代碼──",
        "unit_id": 105132,
        "voice": "vo_adv_2209098_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "「埃忒耳模組」呢。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n雖然在外部",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也被叫做核心模組就是了。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "埃忒耳……",
        "unit_id": 103832,
        "voice": "vo_adv_2209098_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那好像",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是神話裡神的名字……？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真不愧是栞。",
        "unit_id": 105132,
        "voice": "vo_adv_2209098_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n果然是愛讀書的人呢。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──在希臘神話中有著白色羽翼的天空神，",
        "unit_id": 105132,
        "voice": "vo_adv_2209098_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "埃忒耳。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n科學史方面，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也是揮發劑「醚」的語源，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n而在古代",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "則被認為是充滿於宇宙虛空中的",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "神聖物質「乙太」。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "印度的神智學中，",
        "unit_id": 105132,
        "voice": "vo_adv_2209098_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "則是把和後者的超物質「乙太」",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n差不多相同的東西",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "稱為「空界」的樣子。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n著名的「宇宙本源」",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是從那邊……",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105132,
        "voice": "vo_adv_2209098_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「深月小姐……？」",
        "unit_id": 105831,
        "voice": "vo_adv_2209098_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "{player}。",
        "unit_id": 105132,
        "voice": "vo_adv_2209098_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n還有各位。",
