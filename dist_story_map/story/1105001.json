    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夏季的某一天，\n{player}正在蘭德索爾的廣場上散步。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊～",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有了有了！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "找到你了～！　",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我本來還覺得很快就能找到呢，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n{player}還真是神出鬼沒呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過在蘭德索爾跑來跑去",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也是不錯的運動呀～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？　",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你要幫我擦汗嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}你人真好呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我們走吧！",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好了啦好了啦～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直，",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直～♪",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "抵～達～！",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？　",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎麼了嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n為什麼露出好像踩到眼鏡蛇的表情～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你以為跟之前一樣",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要去火山嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天不是喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "夏天去火山實在太熱了嘛～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天啊，",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在那邊的舞台有舞會喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家一起吃吃喝喝熱熱鬧鬧，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一起跳舞的宴會喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "其實啊，",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我被人拜託在宴會上演奏呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "說是請我",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "演奏故鄉的樂器～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以啊，我想要讓{player}也聽聽看我的演奏，",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就把你帶過來啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……這麼說起來，",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有點強行就把你給拉來了，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你會有其他事情要辦嗎？　",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為找到{player}太開心了，\n不小心就",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一頭熱起來了呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "太好了～",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不要總是衝動行事，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我經常被霞這樣說呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是這樣嗎～？　",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那以後有什麼事情的時候，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我都會帶{player}一起去喔～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有空的話沒關係對吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我放心了～！",
        "unit_id": 101711,
        "voice": "vo_adv_1105001_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼那麼，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我去換衣服囉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n說到海邊",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "當然就是泳裝囉～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "久等了～！",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "陽光直接照射到肌膚上",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真是舒服呢～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？　",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為什麼一副不可思議的表情～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跟平常沒什麼差別？",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才沒這回事呢～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "布料比較少，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "材質也不一樣喔――？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來來來，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "摸摸看～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對吧～",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不一樣對吧～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "懂了的話就好～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "換上泳裝之後",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總覺得能聽見海洋的聲音呢～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "過來吧～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "過來吧～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "像是在這麼說呢～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但是，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我要好好忍耐想衝進海裡的衝動。",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n派對是晚上開始，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以得趁現在好好練習呢～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這就是今天",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要演奏的樂器喔～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這個叫作三線喔～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "形狀很有趣吧～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在我的故鄉，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "每個小孩都會跟爺爺奶奶學習怎麼彈～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我一演奏啊，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不論人還是動物，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就連魔物都會開始跳舞喔～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那就",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "稍微來彈彈看吧～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "～♪",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊！",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "唉呀～",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n弦剛好就斷掉了呢～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "明明就有經常在換弦呢～？",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "時機真糟呢～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？　",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "比起正式上場的時候斷掉要好～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "時機可以說是不錯嗎～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊～",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒有帶替換用的弦來呢～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～。",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真是困擾啊～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "誰嗎……",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_032"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "誰啊？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個啊～！",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_033"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "記得應該是",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在這邊～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嗚喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有了有了～♪",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_035"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這孩子的鬍鬚很強韌又有彈性，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_036"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n正好可以拿來當樂器的弦呢～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看起來毛髮也～",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_037"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很濃密～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很可愛吧～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嗚喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？　",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_038"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很危險？　",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒問題的～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這孩子只是警戒心很強，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不會攻擊人的～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_039"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就算說「請給我鬍鬚～」，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n好像也不是這樣",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就會乖乖給我的氣氛呢～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這種時候",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_040"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就要用這個啦～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n該讓三線出場囉～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然有一根弦斷掉了，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_041"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過只要這樣彈～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘰歐歐歐歐歐！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你看～",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_042"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "牠變得乖乖的了吧～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這些孩子啊，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "用這些長長的鬍鬚",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來感受聲音喔～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "聽到好聽的聲音的時候啊，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_043"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就能傳達彼此的感情了喔～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘰歐歐歐歐歐！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_044"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好癢喔～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_045"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可以給我一點你的鬍鬚嗎～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呀喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝～",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_046"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "幫大忙了呢～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那就",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在這裡換弦吧～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "把這邊捻在一起、",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_047"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那邊纏起來、",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這裡綁起來，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "然後再把弦台立起來，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一點一點的調音～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "弄成和弦的話～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "完成～♪",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_048"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣就完好如初，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不對，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "變成比之前還要好的聲音了～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "稍微彈彈看吧～♪",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_049"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如何～？　",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "身體好像要擅自動起來～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不用忍耐，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跳起舞來就好了喔～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕哦哦哦哦哦！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你看，",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_051"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這些孩子們也很開心呢～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "～♪",
        "unit_id": 110511,
        "voice": "vo_adv_1105001_052"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後好一段時間，\n森林中迴盪著悅耳的音色。"
