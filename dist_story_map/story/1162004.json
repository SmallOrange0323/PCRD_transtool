[
    {
        "type": "background",
        "background": "501280"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "動靜兼備的祭典「聖學祭」\n以好朋友社所屬的「賢淑」組獲得勝利畫下句點，\n校內已經開始進行收拾工作。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "受到大會營運委員會指名的克蘿依\n和好朋友社分開後，指揮著收拾工作。"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "聽我說～",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "請A班負責那邊的最後檢查──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "C班抱歉，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "麻煩把這個廢材丟到那裡去──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}幫忙執行著琪愛兒提案的後夜祭企劃，\n為了通知克蘿依而來到她的身邊。"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "奇怪，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "{player}原來你還沒回去啊？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n怎麼了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有什麼事嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你一臉看起來像是被拜託跑腿的小孩子一樣。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是喔～",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "後夜祭是嗎……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n原來琪愛兒要辦這種活動啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還真辛苦她這麼用心啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣也很符合那傢伙的風格。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "OK，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不錯嘛。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n既然如此，跟她說等全部收拾完後，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我也會過去跟她會合。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "奇怪，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等一下……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n咦，這附近是不是在發光啊？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼了怎麼了，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這道光是怎麼回事……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這種感覺好像似曾相識呢，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是什麼來著……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我想想……",
        "unit_id": 116211
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "歡迎光臨～",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_007"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "──咦，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_008"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "什麼嘛，是{player}啊。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "辛苦啦，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "聽說你今天又要來幫忙是吧？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我午班上到五點，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_009"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "所以差不多要下班了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那就這樣，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "剩下的直到關店前都拜託你了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "什麼？",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_010"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "喔喔，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "阿斯特朗？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我可能會登入，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "但今天應該很晚才會開吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我等一下",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_011"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "要做家裡的晚餐，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "還有學校作業要寫。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "反正就是",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "還有很多",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "其他事要做。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "算是吧。",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_012"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "反過來說，感覺也滿充實的？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那我走了。",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_013"
    },
    {
        "type": "background",
        "background": "510272"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那之後，{player}工作到了關店時間。"
    },
    {
        "type": "background",
        "background": "510362"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當他回家走在河邊的路上時，\n與身穿慢跑服、正在跑步的花子擦肩而過。"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "呼、",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_014"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "呼……！",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "呼、",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "呼……！",
        "unit_id": 110832
    },
    {
        "type": "still",
        "still": "116200401"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "呀啊啊啊啊！",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_015"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎、",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_016"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎麼了……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "喔，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是你啊，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嚇了我一跳……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "抱歉，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_017"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我太集中了沒注意到你。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "而且我音樂也放得很大聲。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "話說啊。",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_018"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那個啊。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你可以不要一邊大叫一邊追在我背後嗎？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n問題已經不是我會嚇到然後發出像是萌角色一樣的聲音了，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n我是單純覺得有危險而毛骨悚然，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "還以為你是可疑人物。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_019"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n不，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你問我在做什麼……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "看了不就知道了嗎？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "雖然是沒差啦，但反過來講，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我除了慢跑以外還像是在做什麼？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "沒錯，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_020"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我基本上每天都會慢跑。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n嗯，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "平常大概都是在這個時間跑吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "畢竟",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_021"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "要是得等到上學、打工和家事結束，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n一定都差不多會拖到這個時間啊。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "喔，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_022"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "對啊，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "也是啦。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n雖然要說辛苦也挺辛苦的，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "該怎麼說呢，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "從小時候到現在一直持續下來，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我已經習慣了吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_023"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "「真了不起」是指什麼？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "為什麼要這麼說，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這沒什麼吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n呃，因為，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我又不是為了別人才來跑步的。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "沒有啦，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_024"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "與其說是鍛鍊……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這只是",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "為了穿衣服好看啦。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "以我喜好的衣服來說，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "還是身體結實一點看起來會更帥。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n所以這也沒辦法啦，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是我自己的堅持。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "應該說，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_025"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我基本上",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "也不討厭活動身體啊。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n算是一種紓壓，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "也可以打發時間。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "就只是這樣而已。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "當然，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_026"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我也會偶爾想偷懶。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "但是這種運動習慣一旦開始了，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n不持續做下去，反而會有種浪費的感覺。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "畢竟對辛勤的打工少女來說，身體是資本。",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_027"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n我得保持健康，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "因為我也不想給家人添麻煩。",
        "unit_id": 110832
    },
    {
        "type": "still",
        "still": "116200402"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是嗎？",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_028"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n唔～",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那我就老實接受你的稱讚吧，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "謝啦。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "對了，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_029"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你也來試試看吧？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "慢跑。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n雖然一開始可能會覺得很累，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "但做久了就會逐漸習慣的。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n只要開始嘗試，就會意外覺得沒有想像中那麼辛苦。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "什麼嘛～",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_030"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你那語氣，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n聽起來絕對不會開始吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "真拿你沒辦法。",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_031"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n既然如此，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "直到你習慣為止，就由我來監視你。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "就這麼說定了，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_032"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "總之，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "明天這個時間要來這邊集合。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不是，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_033"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你給我聽懂一下。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n我的意思是",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我會和你一起跑。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎樣。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你有什麼不滿嗎？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "……不過，",
        "unit_id": 110832,
        "voice": "vo_adv_1162004_034"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "像這樣偶爾兩人一起跑步，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n跑起來應該會滿開心的吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n雖然我也不太清楚啦。",
        "unit_id": 110832
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1162004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1162004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n等你醒了之後就會全部忘記，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過話又說回來，克蘿依這個人",
        "unit_id": 190011,
        "voice": "vo_adv_1162004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管在那裡還是這裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都是平常雖然只會嫌累或麻煩，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻只有在保護真正重要的事物時會努力不懈呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 190011,
        "voice": "vo_adv_1162004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該不會其實是反過來呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或許她是因為要為了重要事物而努力，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以才節約使用花在其他事物上的能量？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，",
        "unit_id": 190011,
        "voice": "vo_adv_1162004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣太過於美化她了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那單純只是那孩子的個性啦",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "個性。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然她有一點彆扭，",
        "unit_id": 190011,
        "voice": "vo_adv_1162004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有時喜歡嘲諷人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但骨子裡其實很認真，是個非常溫柔又努力的人。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這就是這位名叫克蘿依的女生的個性吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1162004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我也不太清楚啦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501280"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "奇怪……",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_042"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是怎樣，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我怎麼又睡著了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呼啊……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這種情形發生夠多次了吧，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我已經膩了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_043"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "跟之前一樣，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n雖然做了奇怪的夢，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我卻完全記不得……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好啦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "{player}你也快起來～",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "然後呢？",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們剛才在說什麼來著？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "後夜祭？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喔喔對了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "後夜祭是吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_045"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這主意還不錯啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我要參加。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我們好不容易保護住了棲身之處，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我本來就還想再在勝利的餘韻中沉浸久一點。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哎，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該怎麼說呢？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n雖然我不太喜歡說這種話，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n但硬要說借用某人的說法的話──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好朋友社是永恆不滅的！",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好俗喔。",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真好笑。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n算了，怎樣都好啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……不如說，",
        "unit_id": 116211,
        "voice": "vo_adv_1162004_049"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣真的超棒的。",
        "unit_id": 116211
    }
]