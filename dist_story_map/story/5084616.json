    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "該怎麼辦呢……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n雖然常說能睡的孩子長得快，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但你有點賴床過頭囉……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是不是因為你總是太努力了，",
        "unit_id": 101512,
        "voice": "vo_adv_5084616_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n所以累積了一些疲憊呢……？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我想一定是那樣的，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但老師還是很擔心呢……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101512,
        "voice": "vo_adv_5084616_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為你是乖孩子，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以會快快好起來的吧……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我會相信你、",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我會等著你的……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "拜託了……",
        "unit_id": 101512
