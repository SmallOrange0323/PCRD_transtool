    {
        "type": "dialogue",
        "name": "千惠",
        "words": "哇啊，",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_000"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "好時髦的店。",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我感覺到了種沉穩成熟？",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "的氛圍！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "騎士先生要點什麼？",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_001"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "蛋糕跟瑪芬全都很可愛喔♪",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "咦？",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_002"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n這是、",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "整塊大蛋糕？",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "哇啊……",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_003"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "哇啊～！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "謝謝你，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "騎士先生♪",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "騎士先生能幫我祝賀啟動日，",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_004"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n我非",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "常開心♪",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "……啊，",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_005"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "難道現在的我，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n連蛋糕都能吃下去了嗎！？",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我很憧憬",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_006"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "吃蛋糕呢！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "平常都沒辦法吃，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n即使吃了也只能靠數值理解味道。",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "事不宜遲……",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_007"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我開動了──！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "啊嗯。",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "～～～～！",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_008"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "真好吃～♪",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n大家都是吃這麼甜又美味的蛋糕",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n來慶祝生日的啊！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "不光是蛋糕，",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_009"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "還有禮物啊？",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "嗯──",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "要什麼呢？",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n說到禮物，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "果然──",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "還是想要跟騎士先生擁抱！",
        "unit_id": 126431,
        "voice": "vo_adv_4010218_010"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "嘿嘿♪",
        "unit_id": 126431
    },
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510352"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "辛苦了。",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n跟你一起，",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "工作果然就會很順。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是種",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "效率可以提升二、三倍的感覺吧。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "成果超乎我的預期，",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是幫了我大忙。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n而且總覺得你今天特別有幹勁呢。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可是，",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你為什麼突然說要幫我工作？",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "難道是零用錢花光了？",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "受",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不了，",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不能這樣啦，",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要好好節制啊。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦……？",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n今天的確",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是我的生日……",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你是為了我",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "才這麼賣力工作的啊？",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝、",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝你……",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總覺得",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "很不好意思。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也可以不那麼努力，",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "更輕鬆地慶祝啊……",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵，",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "什麼意思嘛。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這種甜言蜜語只對我",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有用喔。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……本來",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "工作後就該趕緊",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "回家的……",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但畢竟今天是特別的日子，",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "浪費一下時間也沒關係吧。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼，",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "為了能完整收下你的努力。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n接下來就單獨",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "來開個生日宴會吧。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵，",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝你！",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n那",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們走吧。",
        "unit_id": 104833
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "接下來的護送",
        "unit_id": 104833,
        "voice": "vo_adv_4010218_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就交給你囉♪",
        "unit_id": 104833
    }
]