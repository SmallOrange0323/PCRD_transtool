        "words": "那麼就得將洞再擴大一些才行了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是呢。",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n然後……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那好像也是這隻盆栽混蛋的目的呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105812,
        "voice": "vo_adv_5036003_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這就表示「盆栽小花」，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n它也想要回到那邊的意思嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像是。",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是目前的狀況，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎是能量還不夠，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且好像光是要開啟這大小的洞就用盡全力了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "能量……？",
        "unit_id": 112611,
        "voice": "vo_adv_5036003_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是不知道它原本是怎樣啦……",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但在這個世界中的「盆栽小花」，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像能從演唱會上觀眾們的熱情中獲得能量。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是這樣嗎！",
        "unit_id": 112411,
        "voice": "vo_adv_5036003_044"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n竟然可以從觀眾的熱情中獲得力量……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "簡直就",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "像是偶像一樣呢♪",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嘛，",
        "unit_id": 112511,
        "voice": "vo_adv_5036003_045"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但它和我們不一樣，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n「盆栽小花」不能自己開演唱會嘛。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟它就只是個盆栽嘛☆",
        "unit_id": 105812,
        "voice": "vo_adv_5036003_046"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊……",
        "unit_id": 112611,
        "voice": "vo_adv_5036003_047"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那麼，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "「盆栽小花」把\n新人偶像們全都抓走了的理由，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "難不成……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯。",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算想要熱情的能量，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但只靠妳們【new generations】，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一次所能夠炒熱的觀眾也還是有限。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那些即使只有一點點想要成為偶像的孩子們，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也被它用魔法的花粉操縱，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聚集起來",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "並且進行訓練。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "它似乎是想用這種方法來獲得更多觀眾的熱情。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而在下等人想要救出被囚禁的人們，",
        "unit_id": 105913,
        "voice": "vo_adv_5036003_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此被操縱了的凱留小姐一行人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n方才才會試圖阻撓吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果剛才的話都是真的……",
        "unit_id": 112511,
        "voice": "vo_adv_5036003_051"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那還真不得了呢，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這個「盆栽小花」。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n明明一臉傻呼呼的樣子。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個嘛，",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我懂妳們懷疑的心情。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我當然也一樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果沒有被這傢伙操控過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也沒有機會知道剛剛那些事。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "話說回來……",
        "unit_id": 112411,
        "voice": "vo_adv_5036003_053"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我有件事很在意，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "凱留。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啊？",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_054"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "剛剛妳是說，",
        "unit_id": 112411,
        "voice": "vo_adv_5036003_055"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n「那些即使只有一點點想要成為偶像的孩子們」",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "這樣",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "對吧？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊。",
        "unit_id": 112611,
        "voice": "vo_adv_5036003_056"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n這表示，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "凱留凱留妳……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟有此事。",
        "unit_id": 105913,
        "voice": "vo_adv_5036003_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來您也想成為偶像嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105812,
        "voice": "vo_adv_5036003_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣的嗎小凱留？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊啊啊啊——！",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_059"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許也沒有不是也說不定！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只有一點點啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的就只有一點點而已啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "更何況像我這種歲數的女孩子一般來說，",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_061"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都會想要像偶像一樣穿上漂漂亮亮的衣服受人寵愛吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n多少都有這樣想過吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊哈哈……",
        "unit_id": 112411,
        "voice": "vo_adv_5036003_062"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嘛，",
        "unit_id": 112511,
        "voice": "vo_adv_5036003_063"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "雖然偶像並不是那麼簡單呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不不，",
        "unit_id": 112611,
        "voice": "vo_adv_5036003_064"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我懂唷，凱留凱留的心情！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原本就已經是偶像的凜未央卯月三人先不講……",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_065"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有可蘿仔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼妳們兩個，",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有被「小球根」給抓走呀！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們完全沒有想過",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要當偶像之類的嗎！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913,
        "voice": "vo_adv_5036003_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "作為主人的隨從之事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是一切。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若主人如此期望，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼要同時擔任偶像與隨從，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也會樂意為之。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的話，",
        "unit_id": 105812,
        "voice": "vo_adv_5036003_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "繼承家業應該是第一目標吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且漂亮的衣服我也穿習慣了嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然我也不是真的對偶像一點興趣都沒有喔？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種兩光的安慰還不如不要講——！",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那隻盆栽混蛋，",
        "unit_id": 106012,
        "voice": "vo_adv_5036003_070"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然讓我受到這種恥辱……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n果然我還是用攻擊魔法把它燒個精光好了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "妳、",
        "unit_id": 112411,
        "voice": "vo_adv_5036003_071"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "妳冷靜一點呀，凱留。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "對啊。",
        "unit_id": 112611,
        "voice": "vo_adv_5036003_072"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "剛才妳用貓屬性當賣點，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "也是真的很可愛唷？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯嗯。",
        "unit_id": 112511,
