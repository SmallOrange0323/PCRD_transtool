[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠飛走了……",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是個相當棘手的對手呢。",
        "unit_id": 105911,
        "voice": "vo_adv_9040156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚，",
        "unit_id": 105811,
        "voice": "vo_adv_9040156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "烤雞串……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可，",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳怎麼突然就衝出去了呀！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n很危險耶！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為",
        "unit_id": 105811,
        "voice": "vo_adv_9040156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是第一次見到的格里芬嘛。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我有義務確認牠吃起來是什麼樣的味道！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那什麼鬼義務呀！",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且，格里芬說穿了跟大型鳥類沒什麼兩樣呀？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也不是什麼特別需要珍視的存在吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才沒那回事呢！",
        "unit_id": 105811,
        "voice": "vo_adv_9040156_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肉質確實是像雞肉一樣多汁，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但更富含油脂，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n表層炸過以後，口感酥酥脆脆，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肯定會是極品烤雞串！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "差點忘記了。",
        "unit_id": 105911,
        "voice": "vo_adv_9040156_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n之前品嚐過的格里芬烤雞串，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "堪稱一絕，無庸置疑。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真的吃過啊，",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們兩個……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最重要的是！",
        "unit_id": 105811,
        "voice": "vo_adv_9040156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "做成湯品更是不得了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "湯的色澤很清澈，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "味道卻很濃郁，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兼具了鳥類和野獸的優點！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果弄成水炊……",
        "unit_id": 105811,
        "voice": "vo_adv_9040156_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定很讚☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_9040156_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肯定很讚。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吞口水……",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼嘛。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n聽了這種話題……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿嘿，",
        "unit_id": 105811,
        "voice": "vo_adv_9040156_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留肚子也餓了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為聽妳們討論，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像很好吃似的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我這只是戰鬥過後的疲憊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……",
        "unit_id": 105911,
        "voice": "vo_adv_9040156_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那我們",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就準備用餐吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的！",
        "unit_id": 105811,
        "voice": "vo_adv_9040156_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先吃飯，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "盯……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……妳在看什麼。",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們要是能抓到",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個稀有物種的話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就能得到公會管理協會發放的獎勵，對吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_9040156_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該沒有錯。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們就展開調查，順勢抓住稀有物種，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n然後狠狠地向花凜敲詐一筆。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好耶！",
        "unit_id": 105811,
        "voice": "vo_adv_9040156_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "人家最喜歡小凱留了☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱抱～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……",
        "unit_id": 105911,
        "voice": "vo_adv_9040156_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然感情很好呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱抱～",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "夠了，別黏過來！",
        "unit_id": 106011,
        "voice": "vo_adv_9040156_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真受不了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃飽了就趕緊追上去吧！",
        "unit_id": 106011
    }
]