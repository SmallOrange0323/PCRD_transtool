[
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你這傢伙……",
        "unit_id": 121611,
        "voice": "vo_adv_5090301_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個渾蛋，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我決不會放過你的！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你竟然有臉",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一直隨心所欲到今天啊……！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "我能隨心所欲",
        "unit_id": 16011,
        "voice": "vo_adv_5090301_001"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "是因為我有能力啊。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n同為壞人，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "是你們跟我的格調不同！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "格調不同……",
        "unit_id": 121611,
        "voice": "vo_adv_5090301_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗎。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這點我同意。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你才是沒格調的人啦，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "三流賭徒！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "──步未未，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳退下！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這傢伙就由我來教訓……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……不。",
        "unit_id": 121511,
        "voice": "vo_adv_5090301_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也要一起戰鬥喔，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "祈梨……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "步未未，",
        "unit_id": 121611,
        "voice": "vo_adv_5090301_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳……！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我……",
        "unit_id": 121511,
        "voice": "vo_adv_5090301_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "總是",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只能在一旁看著……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我想要改變……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我想要成為，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "能抬頭挺胸站在祈梨身旁的朋友……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……也算上我啦，",
        "unit_id": 106511,
        "voice": "vo_adv_5090301_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "兩位。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！？",
        "unit_id": 121611,
        "voice": "vo_adv_5090301_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不要緊嗎！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳已經渾身是傷了……！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我只要一不留神就隨時會倒下去……",
        "unit_id": 106511,
        "voice": "vo_adv_5090301_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "身為打手卻只能在旁邊看別人打架，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我當然不可能會接受啊……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這才是",
        "unit_id": 121611,
        "voice": "vo_adv_5090301_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜……！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……步未未，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳也準備好吧！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯！",
        "unit_id": 121511,
        "voice": "vo_adv_5090301_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "讓我們開始",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怪盜團最後的工作吧！",
        "unit_id": 121511
    }
]