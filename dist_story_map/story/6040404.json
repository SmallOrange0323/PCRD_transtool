    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看到在努力的鈴",
        "unit_id": 103811,
        "voice": "vo_adv_6040404_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺真的很新奇呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n要是平常也那樣子就好了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然會這麼想，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但也很懷念懶散的鈴，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是複雜的心境呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒錯呢！",
        "unit_id": 103811,
        "voice": "vo_adv_6040404_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "　畢竟是那個鈴啊！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……呃，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣子算是好事嗎。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯～",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的很複雜呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果一直給她獎勵的話，",
        "unit_id": 103811,
        "voice": "vo_adv_6040404_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她會願意繼續努力下去嗎……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺她會找個漂亮的理由，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一邊持續收下獎勵",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一邊繼續偷懶呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n鈴真的是……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "什麼事情都沒有。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "能夠為了自己努力也是件好事……",
        "unit_id": 103811,
        "voice": "vo_adv_6040404_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但如果能夠為了他人而努力，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就更厲害了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n雖然鈴自己大概沒有發現吧。",
        "unit_id": 103811
    }
]