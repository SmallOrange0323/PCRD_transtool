[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "手上拿著從女性那裡獲得的優待券，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n純與{player}來到了那間超級熱門的餐廳。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊，",
        "unit_id": 124212,
        "voice": "vo_adv_1242004_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真幸福。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我們竟然能夠坐在這間很難預約得到的餐廳裡，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且還是在聖誕節時期過來用餐呢。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實我之前就一直很關注這間餐廳。",
        "unit_id": 124212,
        "voice": "vo_adv_1242004_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，光是預約就要等上一年，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再加上我一身鎧甲也不符合穿著規定，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n肯定會吃上閉門羹。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我原以為自己是跟這間餐廳無緣了，",
        "unit_id": 124212,
        "voice": "vo_adv_1242004_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在能夠坐在這裡真是幸福。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，少年，你也盡量多吃……",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦……",
        "unit_id": 124212,
        "voice": "vo_adv_1242004_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這道光是怎麼回事？",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "若是聖誕節的演出，未免也太刺眼了……",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚哇！",
        "unit_id": 124212
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊……",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年，是你啊。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你說我看起來很沒精神？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實我碰到了很不得了的事……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我待會要去參加",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在購物中心舉辦的一場演出。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n當然，我是很高興有這樣的機會……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可以請你看一下這張傳單嗎？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊。",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我原以為是一般的戰隊英雄秀，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒想到竟然是少女動畫的真人演出。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且，我所要演出的角色",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是主角Pure Pure Lip……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是這樣沒錯啦……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你看看傳單上所畫的",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "Pure Pure Lip。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……臉",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會完全露出來，對吧。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年，你真敏銳。",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是這樣……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你看看傳單上所畫的",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "Pure Pure Lip。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n臉整個都露出來了。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我事前已明確告知，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不接露臉的演出。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他們似乎是誤以為我不接以素顏見人的演出。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我平時就戴著面具，還以為他們會懂我的意思……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "結果並沒有懂。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "接下通告時，沒有仔細確認，這的確是我的疏失。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n身為專業人士，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如今也沒辦法開口回絕。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n然而，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一想到要在一大群觀眾面前露臉……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唉。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……我說少年啊，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你有沒有想到什麼好點子？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來如此……",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是這樣！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我去詢問主辦單位看看！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他們認為我在開玩笑，當場就被拒絕了……",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來如此……",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是這樣！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果是扮演魔物，就會穿布偶裝。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我去問問看能不能讓我換角色！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "扮演魔物的熟男大叔反過來問我，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n難道要由我去扮演美少女戰士嗎？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我被反駁得無話可說。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不行了，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真的是束手無策了……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我就要在購物中心",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "公開露臉了……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n呵呵……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哈哈哈……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "除了面具外？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……唔！！",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那張傳單",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以給我看一下嗎？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這美少女戰士的畫風……",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為是少女動畫，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以髮型很醒目豔麗，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嘴唇豐滿彈嫩，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "眼睛也閃閃發亮。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只要仿照這般畫風，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "善用妝容及假髮來打扮……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就能達到",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等同戴著面具的效果……！？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年，這真是個好點子！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，我要順便拜託你一件事……",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請你幫我上妝！！",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別擔心。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我比你更沒有自信。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我平時",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都戴著面具，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對妝容或髮型完全一竅不通。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也不想拜託其他人，",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為這樣會被他們看到我的真面目。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n至於你，早已見過我的真面目了。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再說……",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果是你，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就算沒把我的妝畫好，我也不會介意。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以，萬事拜託了，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝你。",
        "unit_id": 104732,
        "voice": "vo_adv_1242004_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就知道你會幫我這個忙。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，我們就趕緊到準備室去吧。",
        "unit_id": 104732
    },
    {
        "type": "still",
        "still": "124200401"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……純真小淑女的美少女戰士，",
        "unit_id": 104733,
        "voice": "vo_adv_1242004_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "Pure Pure Lip登場。",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你那混濁黑暗的心，",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就由我來抹上正義的唇彩吧……",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………偷瞄。",
        "unit_id": 104733,
        "voice": "vo_adv_1242004_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不行，",
        "unit_id": 104733,
        "voice": "vo_adv_1242004_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我完全記不住台詞。",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖說剛剛很衝動地請少年幫我上妝……",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但現在冷靜想想，",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年正輕觸著我的臉。",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "頭髮……",
        "unit_id": 104733,
        "voice": "vo_adv_1242004_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "臉頰……",
        "unit_id": 104733
