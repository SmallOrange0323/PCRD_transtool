[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我雖然也是出生在老虎族，",
        "unit_id": 100512,
        "voice": "vo_adv_6104105_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但如果像這樣過著傳統的生活，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不知道我會成長成什麼樣的人呢？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓我有點好奇呢。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯──",
        "unit_id": 100512,
        "voice": "vo_adv_6104105_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然老虎族有著「力量就是正義」的價值觀……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但那跟我的正義互不相容。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不畏強權、",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "幫助弱小！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這才是我追求的正義！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔，",
        "unit_id": 100512,
        "voice": "vo_adv_6104105_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "老虎族的確有許多很有實力的人呢……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但、",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也是有在逐漸變強的喔～？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "明天會比今天更好，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "未來會比明天更好！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我一定會變得更強的！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那、",
        "unit_id": 100512,
        "voice": "vo_adv_6104105_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那可就傷腦筋了！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是沒遇見虎虎的話就不會有現在的我，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我這麼說一點也不為過！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為虎虎是我的夢想、憧憬……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也是我心中永遠的英雄！",
        "unit_id": 100512
    }
]