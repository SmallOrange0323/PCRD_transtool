[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "突然不來參加偵探打工的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了查明他這麼做的意圖，霞展開了調查。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼……",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼我會在這種地方──",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──為什麼，",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我會來到海邊！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "由於助手先生有事情瞞著我，才試著一路跟蹤他，",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒想到會來到海邊……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼助手先生要來海邊……？",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n剛剛有看到載貨的馬車，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以他應該是來這裡沒錯……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖說是在送貨，",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但請助手先生一個人運送這麼多次不是很奇怪嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯嗯，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我越來越在意了……！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說到當事人……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來海邊的人太多了，完全找不到他。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就先來觀察四周……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "欸～欸～這位姐姐。",
        "unit_id": 213,
        "voice": "vo_adv_1157002_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n啊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在叫我嗎……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有什麼事？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "姐姐",
        "unit_id": 213,
        "voice": "vo_adv_1157002_009"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳是偵探嗎？",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔！？",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n妳、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳為何會這麼想……？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因為明明在海邊，",
        "unit_id": 213,
        "voice": "vo_adv_1157002_011"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "卻沒有穿泳裝，",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n還用放大鏡到處看，",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我才想說姐姐是不是偵探。",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔……",
        "unit_id": 101411,
        "voice": "vo_adv_1157002_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這身服裝太顯眼了嗎……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "俗話說入境隨俗、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "藏木於林。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來沒辦法了……！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──很好！",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這身裝扮應該能完美混入人群之中。",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是被助手先生發現，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓他逃走的話就得不償失了。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我的變裝術也很有一套呢。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……雖然只是換上泳裝而已。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼就重新開始尋找助手先生的下落吧。",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不過，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這連打聽情報都不需要呢。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生他是穿著鞋子",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "搬運著很大的貨物。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而這裡是沙灘。",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要是抱著重物走動，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "應該會留下比較深的腳印。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要能找到這樣的腳印……",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是這個吧。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不會錯，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是助手先生的鞋印。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵呵～",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n可別以為能逃過偵探的觀察力……！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你就做好心理準備吧，",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生……！",
        "unit_id": 115711
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來到了蠻偏僻的地方呢。",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n感覺是連海邊的遊客都不會靠近的角落……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "欸嘿嘿。",
        "unit_id": 911,
        "voice": "vo_adv_1157002_023"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n送貨的小哥，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "我們就在這裡解決吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有聲音……？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "你沒有被別人跟蹤吧？",
        "unit_id": 811,
        "voice": "vo_adv_1157002_025"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "\n要是這個狀況被人看見的話……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "嘻嘻嘻……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那、",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那些一看就很可疑的男人是誰啊……！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n而且，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在那裡的是……助手先生！？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "那麼，送貨的小哥，",
        "unit_id": 911,
        "voice": "vo_adv_1157002_027"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "讓我看一下吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n我們慣例委託的那玩意兒……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "喔喔，",
        "unit_id": 811,
        "voice": "vo_adv_1157002_028"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "就是這個沒錯呢……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "小哥你做事還是一樣牢靠啊。",
        "unit_id": 911,
        "voice": "vo_adv_1157002_029"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n這可是高級品……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n只有大城鎮才能找到",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "品質這麼高的貨品！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好可疑的對話……！",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n再說，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "慣例的那玩意兒是什麼……？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "嘻嘻嘻……",
        "unit_id": 811,
        "voice": "vo_adv_1157002_031"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "真讓人期待啊……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "\n那群來海邊玩的人所發出的尖叫聲……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總、",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他們應該就是助手先生的交易對象了。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然不是光靠外表來判斷……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但實在很可疑……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有種很危險的預感……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "難道說，",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生被他們騙了嗎……？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在不知情的狀況下被利用去做壞事……",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生那麼善良，感覺很有可能……！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原本以為只是單純的送貨工作，",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這狀況說不定很糟糕啊……！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先跟在了助手先生後頭……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接下來該怎麼辦。",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "萬一",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生真的被捲進了事件之中，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我身為偵探一定要阻止他……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 115711,
        "voice": "vo_adv_1157002_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生是個認真又老實的人，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是知道",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "自己參與了犯罪……",
        "unit_id": 115711
    },
    {
