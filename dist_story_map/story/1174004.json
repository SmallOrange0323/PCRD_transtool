        "voice": "vo_adv_1174004_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣啊。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n既然如此，我邀請你來就值得了。",
        "unit_id": 117411
    },
