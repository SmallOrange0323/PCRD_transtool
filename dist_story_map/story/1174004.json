[
    {
        "type": "background",
        "background": "500280"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與紡希來到祕境之島的隔天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在清晨的沙灘上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "出現了紡希獨自收集著「星之碎片」的身影。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我還想說是誰，",
        "unit_id": 117411,
        "voice": "vo_adv_1174004_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原來是騎士先生啊。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你是早上起床散步嗎？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我呢，",
        "unit_id": 117411,
        "voice": "vo_adv_1174004_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在接續昨天的事。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n「星之碎片」",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還沒全部找齊嘛。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是，還剩下那麼一點，",
        "unit_id": 117411,
        "voice": "vo_adv_1174004_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "無論怎麼找也找不到呢……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "朝陽也快完全昇起來了。",
        "unit_id": 117411,
        "voice": "vo_adv_1174004_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯～",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "陽光真耀眼。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過好像有點太耀眼了──",
        "unit_id": 117411
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "要來囉──！",
        "unit_id": 1,
        "voice": "vo_adv_1174004_004"
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "看──球！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "休想得逞！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "勉強接到球了！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來──",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你把球打上去！！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "呵呵，",
        "unit_id": 1,
        "voice": "vo_adv_1174004_008"
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "我們先",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "得一分啦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "\n照這情況看來，我們第二局",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "或許也能直接拿下勝利呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚唔唔……！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你剛才為什麼沒接到球啊！？",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "又說「對不起」……",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你的道歉我已經聽膩了！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "聽好了！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不論以何種形式，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不讓球落地是最重要的！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不要等在原地，要衝去接球啊！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "聽懂了嗎！？",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "好啦好啦，",
        "unit_id": 1,
        "voice": "vo_adv_1174004_012"
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "紡希。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "\n妳這樣責備他，他也太可憐了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "我們正愁著人數不足，",
        "unit_id": 1,
        "voice": "vo_adv_1174004_013"
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "這個人就自願加入了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "\n不可以對他發脾氣啦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說得那麼事不關己……",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我明明從頭到尾都反對騎士先生加入！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然而！！　",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說什麼「想和他打好關係，",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請教有關怜大人的事♪」！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n根本就沒有打算要好好玩沙灘排球嘛！？　",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有騎士先生也真是的！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就算剛好是打工的休息時間，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也別這麼輕易地答應嘛！　",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊……",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我真恨那個",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在分組時出了布的自己。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不如說，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "更恨那個當時同樣出了布的騎士先生！　",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你站起來！！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們下次一定要得分喔！？",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "球打上去了！",
        "unit_id": 1,
        "voice": "vo_adv_1174004_019"
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "右邊",
        "unit_id": 1,
        "voice": "vo_adv_1174004_020"
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "有空隙喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "\n嘿！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "糟糕！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來不及了！！　",
        "unit_id": 117431
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等！？",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哪有人用臉去接球啊！？",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "Stop、Stop～！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "暫停一下！！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我說你啊！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n雖然是叫你衝去接球，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但也該有個限度吧！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……你不是故意的？",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那就好。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n比起這個，讓我看看你被球打到的地方。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……嗯，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有一點點紅，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過似乎沒有受傷。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是，",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這都是我的錯。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我對騎士先生說得太過分了……",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "得好好反省才行……",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，騎士先生。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n關於剛剛說的話……",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你怎麼突然這麼有幹勁啊！？",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "「多虧了紡希，我終於能碰到球了？」",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……你這個人永遠都這麼積極樂觀呢。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣啊……",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然你這麼有幹勁，",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也不需要手下留情了！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們來盡情得分吧！！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "我把球托上去了！",
        "unit_id": 1,
        "voice": "vo_adv_1174004_030"
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "\n盡全力打過去吧！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "我要上了……！",
        "unit_id": 1,
        "voice": "vo_adv_1174004_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "休想得逞！！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "很好！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你把球打上去！！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "做得好！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來就由我來……",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喝啊啊啊！！！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_035"
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "友人1",
        "words": "哇呀……！",
        "unit_id": 1,
        "voice": "vo_adv_1174004_036"
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "不、",
        "unit_id": 1,
        "voice": "vo_adv_1174004_037"
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "不愧是紡希。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "友人2",
        "words": "真是漂亮的扣球……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哼！",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在就驚訝還太早了！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們才正要開始反擊呢！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對吧，",
