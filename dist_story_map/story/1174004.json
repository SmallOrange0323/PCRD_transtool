    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就誇誇你這份毅力吧。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說實話，",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我對你刮目相看了。",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真不愧是騎士先生！",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……咦？",
        "unit_id": 117431,
        "voice": "vo_adv_1174004_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你該不會是害羞了吧？",
        "unit_id": 117431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我只是在說客套話耶？",
