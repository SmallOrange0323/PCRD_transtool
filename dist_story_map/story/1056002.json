[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}作為流夏打工的魚店助手，\n陪流夏一同前往海岸附近的城鎮批貨。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了，",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "終於到了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "今天也請多多指教囉！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過其實也就只是批貨搬魚而已。",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "放鬆點沒關係。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "喔喔，",
        "unit_id": 1411,
        "voice": "vo_adv_1056002_002"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "這不是流夏嗎。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "……原來如此，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "消息還沒有傳到蘭德索爾啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼啦？",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一臉愁眉苦臉的樣子。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "發生什麼事了？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "其實……",
        "unit_id": 1411,
        "voice": "vo_adv_1056002_004"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "我今天沒有魚可以賣給妳。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一尾都沒有？",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_005"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "是啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1056002_006"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "一尾都沒有。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……發生什麼事了？",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_007"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "事情是這樣……",
        "unit_id": 1411,
        "voice": "vo_adv_1056002_008"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "從昨天開始，附近的海岸一帶出現了凶暴的魔物，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n害我們無法出海捕魚。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "而且那隻魔物，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n牠的移動範圍橫跨了我們鎮跟鄰鎮。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也就是說，",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就算想去鄰鎮買也沒用……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "沒錯。",
        "unit_id": 1111,
        "voice": "vo_adv_1056002_010"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "我們的城鎮也是一團糟……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你是",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "鄰鎮的……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "不只是我們漁夫。",
        "unit_id": 1111,
        "voice": "vo_adv_1056002_012"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "像你們這樣來買魚的人，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n也都深受其害！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "可惡！",
        "unit_id": 311,
        "voice": "vo_adv_1056002_013"
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "再這樣下去根本做不了生意……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "\n難道沒有辦法可以打倒那隻魔物嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "辦法我們早就都試過了！",
        "unit_id": 1411,
        "voice": "vo_adv_1056002_014"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "鄰鎮的你們應該也早就舉雙手投降了吧！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n如果能輕鬆解決的話，我們早就做了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n難道你連這個道理都不懂嗎！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "你說什麼？你這個混帳！",
        "unit_id": 311,
        "voice": "vo_adv_1056002_015"
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "就算你不說，我也很清楚！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呱呱叫吵死人了，",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "成何體統！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你們年紀也不小了，這種時候吵架能解決問題嗎！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要吵的話，就去別的地方吵！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "抱歉……",
        "unit_id": 1111,
        "voice": "vo_adv_1056002_017"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "我們能做的都做了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n可是啊！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "不管射箭還是魔法，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "都沒效……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "魔法也不行？",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這下可麻煩了……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣的話，",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能解決牠的就只剩我一個人了吧……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唉唉……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒辦法。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那隻魔物，",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就由我來收拾吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "咦咦！？",
        "unit_id": 311,
        "voice": "vo_adv_1056002_021"
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "可、",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "可是真的不要緊嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "\n雖然妳手上握有武器，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "但流夏，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "妳只是個賣魚的吧！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "管它是賣魚的還是騎士，",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只要能打倒魔物，職業是什麼都無所謂吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，我有個條件",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是我打倒魔物，魚要算我便宜一點喔？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "沒、",
        "unit_id": 1411,
        "voice": "vo_adv_1056002_023"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "沒問題。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "如果妳能幫我們打倒牠的話，要多便宜都沒關係。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "成交。",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "交給我吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯……？",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真稀奇，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是地震嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "不，不對！",
        "unit_id": 311,
        "voice": "vo_adv_1056002_026"
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "這是──",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "牠來了！",
        "unit_id": 1111,
        "voice": "vo_adv_1056002_027"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "大家快逃！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼快就上門了？",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "省了我去找的功夫。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你竟然替我擔心，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥你人真好。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你冷靜一點。",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別擔心，有我在。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "像這種魔物，",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我已經交手過好幾次了，沒什麼。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥你退後一點吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥！",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看樣子你是認真的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好，我知道了！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一下就好。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你去引開牠的注意力！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "危險！",
        "unit_id": 1411,
        "voice": "vo_adv_1056002_033"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "那位小哥",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "看起來呆頭呆腦的，想不到還真有膽識！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "他是在拖延時間吧，",
        "unit_id": 1111,
        "voice": "vo_adv_1056002_034"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "流夏到底在幹嘛啊！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 105611,
        "voice": "vo_adv_1056002_035"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "小哥快逃啊！！",
        "unit_id": 1411,
        "voice": "vo_adv_1056002_036"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "啊啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是現在──！",
        "unit_id": 105612,
        "voice": "vo_adv_1056002_037"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "──呼！",
        "unit_id": 105612,
        "voice": "vo_adv_1056002_038"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一之太刀，",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雫冽掃！",
        "unit_id": 105612
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "喔喔喔！",
        "unit_id": 311,
        "voice": "vo_adv_1056002_039"
    },
    {
        "type": "dialogue",
        "name": "漁夫3",
        "words": "太厲害了！！　",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 105612,
        "voice": "vo_adv_1056002_040"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還沒結束！",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
