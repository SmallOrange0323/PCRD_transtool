    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和我們一起去旅行吧♪",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「唔呃，",
        "unit_id": 2113,
        "voice": "vo_adv_5100101_001"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音！",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "喂喂，妳這樣太突然了吧！？」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們",
        "unit_id": 123111,
        "voice": "vo_adv_5100101_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "決定要去一個",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很遠的地方旅行喔。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "以小時候聽到的一個故事作為依據，",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到遙遠的地方去旅行。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n由於地圖上也沒有記載，",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也不曉得",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "能否真的",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "成功抵達目的地……",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "或許路上會有危險的魔物在呢。",
        "unit_id": 123111,
        "voice": "vo_adv_5100101_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "又或者是，",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "猛獸……？",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請您來陪咱們一起旅行吧。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n畢竟有備無患，",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可得確實做好萬全準備才行哪！",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯♪",
        "unit_id": 123211,
        "voice": "vo_adv_5100101_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n便當、伴手禮，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還有點心！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n旅行該帶的物品全都完美準備好囉！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「聽好了，綾音，先冷靜一下。",
        "unit_id": 2113,
        "voice": "vo_adv_5100101_005"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "妳是要去旅行！",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不是去野餐啊！」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個我知道啦！",
        "unit_id": 123211,
        "voice": "vo_adv_5100101_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉你自己不是也一副滿心期待的樣子嗎！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「確實是這樣沒錯",
        "unit_id": 2113,
        "voice": "vo_adv_5100101_007"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "啦……」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好擔心呀。",
        "unit_id": 123111,
        "voice": "vo_adv_5100101_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不曉得能否成功抵達目的地？",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "綾音小姐、",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "噗吉先生。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還有……",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家，",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會盡全力加油的！",
        "unit_id": 123111
    },
    {
