        "voice": "vo_adv_5100101_010"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "就包在我身上吧！」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "真步＆綾音",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5100101_011"
    },
    {
        "type": "dialogue",
        "name": "真步＆綾音",
        "words": "\n「真步真步的神奇旅程！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真步＆綾音",
        "words": "旅行的少女與邊境的大樹」",
        "unit_id": 1
