[
    {
        "type": "background",
        "background": "501683"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼……",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那魔物",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是難纏啊……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我跟惠理子明明都同心協力戰鬥了，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "居然還會花這麼多時間。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "每天一直戰鬥，身體好痠痛啊……",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡～！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是啊……",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也很難忍受。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "居然勉強了這位大人的這件事實！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊……",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真想趕快回去……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我想快點為他準備熱騰騰的料理……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "想趕快讓他好好泡澡……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我想趕快、",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "趕快……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n將這位大人帶到沒有敵人、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "能和我",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "兩人一～直獨處的空間，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n把他關在裡面！！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "先、",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "先不論妳的理由，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "想要回去這件事我也同意。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這些全都是因為",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "魔物一直討伐不完啦！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡～！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "混蛋魔物～！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可惡的魔物……！",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n之所以無法獨佔這位大人，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n全都是那隻畜生的錯！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚喔喔喔！",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我開始覺得不爽了！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n現在的我感覺可以把那傢伙打個落花流水啊！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真巧呢，",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也一樣。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天將會是……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那傢伙的死期。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒錯！",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿嘿……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們一定要打倒那傢伙喔，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子！！",
        "unit_id": 129811
    }
]