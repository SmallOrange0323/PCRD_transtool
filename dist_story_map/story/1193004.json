    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然是越多越好！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "希望今後",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_048"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "與哥哥之間的情感可以變得更好，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n身為妹妹的我，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃不，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就算不是這樣也沒關係。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想繼續一起過",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_049"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "美好的聖誕節……！　",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們明年也",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一起過",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聖誕節吧，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……嘿嘿……",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_051"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你可以跟我",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "勾手指做約定嗎？",
        "unit_id": 101131
    },
    {
