[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾的某街角，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n答應要陪璃乃念書的{player}前來赴約。"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要好好念書！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖說現在正值聖誕季，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但這兩件事是",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "毫不相干的！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我可要好好專心念書！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……話是這麼說……",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但我卻忍不住偷懶起來，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以才請哥哥過來一趟。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請你務必緊盯著我！",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "拜託你了！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "老實說，",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "預定要做的問答集已經堆積如山了……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊啊啊──！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這真教人絕望……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不，",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很清楚，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這全是我自己的錯！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一下跑去打工，一下又栽進編織的世界，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很罕見地在念書上敷衍了事……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這是我早就知道的事，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我不會找藉口的！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是！",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在應該還來得及挽回！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我要好好做……！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是這麼一回事。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果有哥哥在我身邊，",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我就有動力把自己逼到極限！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這樣一來，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就逃不了了！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "況且，",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天我們之間的距離……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "似乎也比平時還來得近，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會打起精神來的！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很好，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天馬上就從這裡開始……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "…………",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥……",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我還得、",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好好念書、",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "才行……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請你再多",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "陪在、我身邊……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "…………呼……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我還清醒著……",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "棲息在蘭德索爾周遭",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "森林地帶的魔物，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "已知就有好幾種。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n請回答在這之中，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好食植物性養分的",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "四足獸魔物的種類名稱，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n以及簡明扼要地呈現出",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該種類之特徵行動的……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個是……",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "偽裝成陷阱題的",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "送分題呢……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在這裡可以",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "多賺到一些",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "答對題數……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯嗯……",
        "unit_id": 119311,
        "voice": "vo_adv_1193004_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥……？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不知怎地，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "覺得好刺眼……",
        "unit_id": 119311
    },
    {
        "type": "background",
        "background": "510272"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥、",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在這邊！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你快看！",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "閃閃發亮！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n很有燈飾的氛圍呢！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "快點快點！",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要是走散了就糟了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那裡有張空的長椅，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要不要去坐？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就在那裡，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們走吧！",
        "unit_id": 101131
    },
    {
        "type": "still",
        "still": "119300401"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "太好了，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "幸好有坐到！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你說用不著這麼慌張？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n被你這麼一說，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "或許是這樣吧！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在可是和哥哥在約會呢！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我希望可以盡可能地好好享受這段時光！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也知道，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n自己用不著這麼焦急。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也不想白白浪費任何一分一秒。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是只屬於我們兩個人的時光啊。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n能像這樣一起來看聖誕節燈飾。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥與",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妹妹！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就只有我們兩個人！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在這般情境下，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有誰還能耐住性子啊。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n再說，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "金幣似箭，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "得好好善用時間才行！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥也覺得很開心吧？",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n呵呵呵，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你是逃不過妹妹我這雙眼睛的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還請老實地承認吧？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你也覺得很開心？",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……太好了！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我從以前就一直很想來看",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這場燈飾。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n啊，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然是想和哥哥兩個人",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一起來看！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為忙著念書，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那個，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然有點不好開口說……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但我今年可是",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "卯足了幹勁在準備呢。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很高興",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥能夠陪我一起來。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這簡直就像在做夢一樣，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我好像說得有點太誇張了吧？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "據說這場燈飾",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是以星座為主題。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如果仔細找找，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "似乎可以發現有許多星座隱藏在其中。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "像這樣往上看，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就好像在觀看天象儀。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這裡是",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "小熊座，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那裡是",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "天鵝座……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n而那個是，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "南十字星……？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原來如此，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不管季節或",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "緯度，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n實際上在這裡不可能看到的星座也",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "被鑲嵌在裡頭呢。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在燈飾的另一側，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也可以看到星星喔……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n想不到連真正的星空也看得到，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是奢侈的享受！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "…………",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個……",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你會不會覺得",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有點冷啊？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在是冬天",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "的夜晚，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們又待在戶外。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "肯定會覺得冷，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對吧？",
        "unit_id": 101131
    },
    {
        "type": "still",
        "still": "119300402"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以為了哥哥……",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我有準備",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "禮物喔！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我原本是想編織一對同款圍巾，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過後來想說機會難得，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們一起圍一條圍巾也很讚！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "連我自己也覺得這是個好主意，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你覺得呢？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這樣暖和嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聽到哥哥這麼說，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就放心了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "覺得很暖和。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感受得到哥哥的體溫……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒關係，沒關係！",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們可以像這樣兩個人一起出來，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n對我來說就是最棒的聖誕禮物了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會好好褒獎你的。",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_042"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "開玩笑的啦，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對妹妹來說，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這也是難得的體驗！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以說，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥也覺得，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "與妹妹，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n來看這場燈飾……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……這樣的聖誕節約會……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n很快樂嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "太好了，",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你笑了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天真是個好日子……",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_045"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是最棒的一天。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我原本是打算",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_046"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在這之後就回家，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一起吃",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聖誕蛋糕的……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想這就等到",
        "unit_id": 101131,
        "voice": "vo_adv_1193004_047"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "下次有機會再來安排吧！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n今後的樂趣，",
