    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很不錯呢～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次似乎稍微有點大人的氛圍？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是打算超越兄妹",
