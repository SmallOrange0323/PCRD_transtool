    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "あのね、",
        "unit_id": 128411,
        "voice": "vo_adv_5134422_000"
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "正直に言うとね。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "結局、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "最後まで宇宙空間で",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "隕石と激闘を繰り広げてました！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "多分、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "ホントにただの夢を見てただけっぽいかも！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "うん、",
        "unit_id": 128511,
        "voice": "vo_adv_5134422_001"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "私も無茶を言って悪かったよ。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nそもそもは、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ハツネさんの緊張を解くためのアイデアだったのに。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "その夢は見なかったことにしてほしい、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "忘れよう。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "でも、",
        "unit_id": 128311,
        "voice": "vo_adv_5134422_002"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "不安は消えたんじゃないですか？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "さっきまでよりは顔色もよくなってるですよ。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "隕石を壊すこと自体はできたから。",
        "unit_id": 128411,
        "voice": "vo_adv_5134422_003"
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n同じやり方はできないけど、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "自信は十分ついたよ！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "それだけで十分だ。",
        "unit_id": 128511,
        "voice": "vo_adv_5134422_004"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "元々、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "リラックスして本番に臨んでもらうのが目的だったしね。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "あとは現実で隕石を砕くだけです。",
        "unit_id": 128311,
        "voice": "vo_adv_5134422_005"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nあたしたちなら、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "きっとなんとかなるですよ。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n知らねーですけど。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "うん",
        "unit_id": 128411,
        "voice": "vo_adv_5134422_006"
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "うん！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "それじゃあ、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "改めて……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "みんなで、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "隕石を壊すぞ～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "お～！！",
        "unit_id": 1,
        "voice": "vo_adv_5134422_007"
    }
]