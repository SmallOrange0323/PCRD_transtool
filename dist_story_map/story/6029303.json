    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個叫做克莉絲提娜的女人，",
        "unit_id": 111711,
        "voice": "vo_adv_6029303_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她真的是人類嗎？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就連身為吸血鬼的妾身",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都覺得她是個很怪的人。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "的確，",
        "unit_id": 111711,
        "voice": "vo_adv_6029303_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "很明顯的，她一直都在做享樂的行為。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但依然可以",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "理性地判斷事情這一點，真的不簡單。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想要成為聖誕老人的話，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她很可能是一個強大的競爭對手。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這點妾身真的搞不懂。",
        "unit_id": 111711,
        "voice": "vo_adv_6029303_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為何那麼嚴厲又激進的女人",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "會成為偶像的製作人……？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真要說起來",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她比較像是和妾身一樣，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "企圖征服世界的人才對阿……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然！　",
        "unit_id": 111711,
        "voice": "vo_adv_6029303_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就覺得奇怪。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n沒有人能騙過",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身這傳說的吸血鬼！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你聽好了！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬啊！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在確定安全之前，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不要離開妾身的身邊喔！",
        "unit_id": 111711
    }
]