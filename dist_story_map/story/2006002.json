[
    {
        "type": "background",
        "background": "500353"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃～？",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n抱歉，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓妳久等了！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n育幼院附近，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n沒有看到像是馬車的東西耶……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會不會是等得不耐煩，",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以先走掉了呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦～呵呵呵呵呵！",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳這麼說就太侮辱我了哦，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在累積了許多社會經驗以後，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我也變得比較能夠忍耐了呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這高亢的笑聲……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n秋乃，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼晚還笑這麼大聲，會吵到鄰居哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真對不起呢！",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "話說",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳在看哪邊啊，咲戀？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我在這裡哦～？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳說這裡……",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我只有聽到聲音但沒看見妳人耶？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳到底在哪啊？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就說了，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在這裡哦！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在上面！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我在妳的正上方哦！",
        "unit_id": 103211
    },
    {
        "type": "still",
        "still": "200600201"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖然這還只是",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "處在開發階段的試作品而已呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只是因為狀況十萬火急，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n所以我才硬要父親大人借給我的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖然目的地的牧場在那座山上，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但只要從空中飛過去，一瞬間就會到達囉♪",
        "unit_id": 103211
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500353"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "的確是這樣呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n幫大忙了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n感覺能夠",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大幅縮短移動時間。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳明明平常是個少根筋的人，",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但總能以一般人想不到的方法",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得出最佳解答呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳那是在誇我嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還是在損我呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "先別說那麼多了，快搭上來，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "時間就是金錢呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "　\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "平常總一副",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "高高在上的樣子對我說教的人，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不就是妳嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這下被妳反將一軍了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是妳要我搭上去，",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我該怎麼做才好呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n如此龐然大物，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n沒有辦法在這個錯綜複雜的小鎮上著陸吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊……",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "該怎麼辦才好，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我沒有考慮過這一點呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉唷，",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種事要先想好啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為什麼你總是在這種",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n最重要的地方少根筋呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想想哦，",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n如果妳能放下繩梯還是什麼東西的話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也許就能自己爬上去？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊啊。",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那個的話我隨時都有準備哦。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希～？",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n前陣子我們潛入黑心資產家的房子裡用的繩梯，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n放在哪裡呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "黑心資產家……？",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n該不會在做些見不得人的買賣吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "絕對沒有。",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我總是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "走在名為正義的道路上呢，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這點妳也知道吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我秋乃・紫藤，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n是絕對不會做出",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "愧對上天的事情！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我把繩梯固定好了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳快點爬上來吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我從沒來沒有過攀爬的經驗，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以有點不安。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那我來幫妳吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咻嚕咻嚕～……",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_028"
    },
    {
        "type": "background",
        "background": "500353"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "落地！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們一起爬吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請將手給我♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝、",
        "unit_id": 102811,
        "voice": "vo_adv_2006002_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝妳。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才一陣子沒見，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳就學會了這～麼奇妙的技能啊？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵呵。",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們彼此彼此吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "過去的我們，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_032"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就只是可愛的大家閨秀而已……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在踏上各自的人生旅途以後，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們也應該各有各的收穫才是。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵呵，接下來我們就來確認這點吧，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_034"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\nMy friend.",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "移動時間並不長，",
        "unit_id": 103211,
        "voice": "vo_adv_2006002_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n一邊和妳聊聊天，轉眼間就會到了呢♪",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼。",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n秋乃小姐還是和以前一樣，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n像暴風一般呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好好哦，是飛空艇，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我也好想搭搭看♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過這種事，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還是等到平息一切、恢復和平後再……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，",
        "unit_id": 102111,
        "voice": "vo_adv_2006002_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n鈴莓姐姐……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "怎麼這麼吵～？",
        "unit_id": 102311,
        "voice": "vo_adv_2006002_040"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我嚇了一跳以後，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就醒過來了～……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起哦，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n畢竟現在是大半夜嘛。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不小心把",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家都吵醒了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過妳們不用擔心哦，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n再回去乖乖睡覺吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這樣啊～",
        "unit_id": 102311,
        "voice": "vo_adv_2006002_043"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我還以為，『闇影』又出現了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚哇，",
        "unit_id": 102111,
        "voice": "vo_adv_2006002_044"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好可怕……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "人家最近一到晚上就會很不安，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n有點睡不飽呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣啊，真是可憐的孩子。",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，沒問題的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n妳放心吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為了讓大家能度過安穩的夜晚，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我和大小姐都在努力呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一定也是。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，",
        "unit_id": 102111,
        "voice": "vo_adv_2006002_047"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "{player}哥哥……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n已經回來了嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊……",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還沒有哦。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n他好像晚一點才會回來。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "似乎在比較遠的地方發生了一些意外，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n害他無法及時回來的樣子呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然……",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n得用這種說法，\n想辦法蒙混過去。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但要是說出真實情況的話，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_051"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n反而會讓孩子們感到更加地不安。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請你趕快回來吧，{player}。",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_052"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n希望你平安無事……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n包含我在內，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "都很擔心你呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_2006002_053"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n{player}哥哥他，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n還沒有回來嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 102311,
        "voice": "vo_adv_2006002_054"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥的房間裡面，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n有傳出一些聲音耶……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可是，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "應該不可能才對……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該不會，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是『闇影』又出現了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "噫耶……？",
        "unit_id": 102111,
        "voice": "vo_adv_2006002_057"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n討厭討厭，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好恐怖……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯～。",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "去稍微看看狀況哦。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n妳們兩個，要乖乖待在這裡哦。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果狀況危急的話，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就丟下我趕快逃跑。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要是遇到什麼事情，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就大聲呼喊哦。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯、嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_2006002_060"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n鈴莓妳也要小心哦，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n如果妳害怕的話，我也可以陪妳一起去哦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈。",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_061"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我沒問題的哦，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "綾音。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請妳放心……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鈴莓姐姐會把所有讓妳們感到害怕的東西，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_062"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n全部都",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "趕跑的哦。",
        "unit_id": 102511
    },
    {
        "type": "still",
        "still": "200600202"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（心跳加速……）",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_063"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}，\n你已經回來了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_064"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "回話……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n看樣子，\n或許真的是『闇影』或魔物闖進來了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好、",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_065"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好可怕！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過孩子們，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n應該比我更害怕、更不安才對！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐已經拜託我顧家了，",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_066"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我得想個辦法處理這狀況才行！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}～？\n我要進房間了哦？",
        "unit_id": 102511,
        "voice": "vo_adv_2006002_067"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果你在房間的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請回應我一下好嗎～？",
