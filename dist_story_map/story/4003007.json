[
    {
        "type": "background",
        "background": "500405"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～",
        "unit_id": 105913,
        "voice": "vo_adv_4003007_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯哼。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "第四次的【美食殿堂】吃遍之旅即將開始。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……說是這麼說啦。",
        "unit_id": 105913,
        "voice": "vo_adv_4003007_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但可真奇怪呢，還沒看到貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這方面的事情她應該會守信的，",
        "unit_id": 105913,
        "voice": "vo_adv_4003007_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該不會遲到或是要放鴿子吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還放鴿子咧。",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳有時候都會用一些很奇怪的詞呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_4003007_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問是哪裡奇怪呢，都會的說話方法真是難。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不用在意那麼多吧，用詞只要聽得懂就好……",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說起來這個貪吃佩可，到底是跑哪去了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也許不應該直接約在目的地集合呢，",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她會不會迷路了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是，遇到魔物的襲擊了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請避免說這些觸霉頭的話。",
        "unit_id": 105913,
        "voice": "vo_adv_4003007_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過如果是貪吃佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n遇到大多數的魔物都可以打退回去才對。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真虧她那麼強呢。",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以我才會這麼辛苦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……？",
        "unit_id": 105913,
        "voice": "vo_adv_4003007_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐，有時候會說些不好懂的話呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喂～，大家好～！",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對不起，我遲到了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳啊……",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n叫人到這裡來，自己就不應該遲到啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到底是去哪做了什麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼全身都濕了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道妳是游泳游過來這裡的？",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真有活力～……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是嫌麻煩，用魔法一飛就過來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。在下跟主人，是搭船過來的喔。",
        "unit_id": 105913,
        "voice": "vo_adv_4003007_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為主人暈船，還有些焦急呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這附近的海流很劇烈，船可是晃得很嚴重呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也是搭船到這裡來的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在攻略秘境之前稍微做了些事前準備。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實這次的祕境『蒼海孤塔』，",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果不按照特定步驟走，好像就打不開正確的出入口了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我先到當地，實際將步驟給練熟了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還真累人呢～。",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要先閉氣潛下海到水中的遺跡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還得在限制時間內按下好幾個開關之類的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是麻煩的事情已經全都搞定了，",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為我想把時間都用在找食材上呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳啊，真的是講到吃就會拼命……服了妳了。",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然妳先去處理了一些事情，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們這趟也就比較輕鬆了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過。希望妳不要每次都自己上，也可以叫我們一起啊。",
        "unit_id": 105913,
        "voice": "vo_adv_4003007_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們都是【美食殿堂】的夥伴吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果有困難的話也想一起分擔的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀～……",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是小凱留妳每次都嘮叨一大堆的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n太麻煩了所以我乾脆自己先處理掉嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這就是妳多心囉。",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也不討厭大家一起邊吵邊逛祕境啊～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n邊走邊吃美味的食物啊什麼的啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下次，就不要這麼見外囉。",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管什麼事情，我們就一起面對吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好。",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過現在沒時間想下次了、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為這次的『蒼海孤塔』可是一直鬧出人命的凶險秘境呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一旦疏忽馬上就會沒命！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是在塔的最頂層，好像有連神都會上癮的珍品食材！",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有時候神會來品嘗食材，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n每次一來就會弄得天翻地覆慘絕人寰啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喏，這是吃遍之旅吧？",
        "unit_id": 106012,
        "voice": "vo_adv_4003007_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼非得挑這種問題多多的難關呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "抱歉，我還是先回去好嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣不行喔～",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留不是說不討厭這種吃遍之旅的嗎！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是聽得很清楚呢，還覺得很高興呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來來，今天也要快樂地一路吃遍呢～！",
        "unit_id": 105812,
        "voice": "vo_adv_4003007_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n來嘗遍天下的美食吧，我們一起來……☆",
        "unit_id": 105812
    }
]