[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_5084611_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您是要睡到什麼時候呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就這樣一直沒有醒來……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不行哪！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算只是假設，也不能這樣想的哪。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "從以前開始，",
        "unit_id": 101011,
        "voice": "vo_adv_5084611_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沉睡不醒這事",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都是公主小姐負責的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這可以算是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一種傳統囉？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要是再不醒來，",
        "unit_id": 101011,
        "voice": "vo_adv_5084611_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就換人家化身為王子先生的角色，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n用親吻",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喚醒您……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不行哪！",
        "unit_id": 101011,
        "voice": "vo_adv_5084611_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "由於太過寂寞，害人家產生丟人的想法了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您要早點醒過來唷～",
        "unit_id": 101011
    }
]