    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n感覺還真不可思議……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看起來環境很整齊呢，",
