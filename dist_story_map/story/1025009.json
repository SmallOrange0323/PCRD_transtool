    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是你一喝下去，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "馬上壓著喉嚨並抬頭仰望天花板耶……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……不能灰心，",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只要洗刷汙名就好了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "接著來打掃房間吧！",
