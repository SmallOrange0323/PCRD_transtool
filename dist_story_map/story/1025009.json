        "type": "dialogue",
        "name": "鈴莓",
        "words": "這才是女僕的作風♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "先泡壺完美的茶～",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是怎麼了？",
