        "voice": "vo_adv_1025009_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n其實要說明起來還挺丟人的……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……我搞砸了。",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是這樣的，",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我在咲戀育幼院",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一如往常地犯冒失，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "弄壞了很重要的東西。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然大小姐要我不用在意，",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但我實在是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難以原諒自己……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那是……",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很重要的東西啊……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "於是，",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我就這樣頭也不回地",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "衝出育幼院了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是，",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我又仔細想了想，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "發現自己除了育幼院外無處可去，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就在這時，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "剛好看見了{player}……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的……！",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一切都好突然……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣真的沒問題嗎？",
        "unit_id": 102511
    },
