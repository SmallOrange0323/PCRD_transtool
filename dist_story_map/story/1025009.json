        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n竟然讓我借住【美食殿堂】的公會小屋……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……你說我可以自由使用？",
        "unit_id": 102511,
        "voice": "vo_adv_1025009_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的很感謝你。",
