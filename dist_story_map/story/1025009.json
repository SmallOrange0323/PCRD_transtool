        "voice": "vo_adv_1025009_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我想讓{player}見證這一點。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿，",
