        "voice": "vo_adv_1025009_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以一看見{player}就不小心……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃……",
