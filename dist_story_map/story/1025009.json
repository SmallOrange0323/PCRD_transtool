    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不對，這是……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "魔物的……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……還是當作沒看到吧。",
