[
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正當【伊麗莎白牧場】的成員們忙著做牧場溫泉"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n的開張準備時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n似乎遇到了什麼問題而傷透腦筋。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真傷腦筋啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "該怎麼辦才好呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果我再",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "多努力一點……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可是現在",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "需要小栞再多做一點傳單才行啊。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我會盡快把工作做完的，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "交給我來吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家怎麼一臉煩惱的樣子啊，",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼了？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "發生了什麼事嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴！　",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳來得正好！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什、",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼什麼？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如果是麻煩事的話我可不要喔？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣啊……",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看來還是得靠我們幾個想想辦法了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是啊。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n畢竟鈴天天發傳單應該也累了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～真是的！　",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "到底是怎樣啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳們不說我怎麼知道是怎麼回事！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先說說看嘛！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是嗎？　",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就是啊，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們在整理倉庫的時候",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n找到了熟成過的起司，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好像可以拿來當成給客人的伴手禮。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可是起司的香味",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也吸引了很多老鼠過來。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以得要有個人在這裡看守以防起司被老鼠吃掉。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但我們幾個",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "手邊都有工作抽不開身。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的確",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為傳單發完了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以正無事可做。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴，",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然我知道妳應該也很累了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過妳能不能",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "幫忙看守起司呢？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "…………",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果妳真的很累的話",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不用勉強沒關係！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "看守的工作也不輕鬆嘛！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對啊。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我只有做做傳單而已，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還是讓我來看守……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳們不用那麼顧慮我沒關係啦。",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我來做吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我來看守起司。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的可以嗎！？",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖說是警衛，不過對手是老鼠吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這根本不算什麼啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的可以嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳不用勉強喔？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就是說啊。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n鈴妳一直",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "走來走去應該也累了吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我沒事的！　",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖說這工作的確很麻煩，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不過畢竟我們人手不足，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "能做的事我還是會去做的！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這件事就交給我！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳們去忙自己的工作吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴，",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的很謝謝妳。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等工作告一段落我們也會來幫忙！",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以不用勉強也沒關係喔。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "…………妳們幾個",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "到底是怎麼看我的啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是很感謝妳們願意幫忙啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那就先這樣囉～鈴鈴。",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n起司就交給妳啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好好好。",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳們就放一百二十個心吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過就是起司而已，就由我來保護吧。",
        "unit_id": 102611
    }
]