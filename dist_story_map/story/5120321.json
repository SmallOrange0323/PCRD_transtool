[
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這股氣息……",
        "unit_id": 126211,
        "voice": "vo_adv_5120321_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是怎麼回事……？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那傢伙的力量增強了嗎！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞，",
        "unit_id": 126311,
        "voice": "vo_adv_5120321_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美肌在顫抖……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不快點制止那個會很不妙呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳的美肌連那樣的感應能力都有嗎……？",
        "unit_id": 126211,
        "voice": "vo_adv_5120321_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "狀況很危險是事實，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要是繼續放著不管，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那傢伙的力量似乎會無止盡地增強。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有了！",
        "unit_id": 126311,
        "voice": "vo_adv_5120321_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就用我的美麗來引開他的注意如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我說妳啊，",
        "unit_id": 126211,
        "voice": "vo_adv_5120321_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是以為靠美麗就無所不能吧？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "設法制止那傢伙增強力量正是關鍵所在。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n為此，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "無論是美麗還是什麼都行，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雪啊，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快上吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……伊莉亞，",
        "unit_id": 126311,
        "voice": "vo_adv_5120321_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳不會是懶得應付我，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n才想說總之先慫恿我就好了吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好了上吧，",
        "unit_id": 126211,
        "voice": "vo_adv_5120321_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雪啊，統御美麗之人！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n讓那傢伙看看咱們的力量！",
        "unit_id": 126211
    }
]