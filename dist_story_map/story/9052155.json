[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能接到綠洲村莊的調查委託是很好啦……",
        "unit_id": 106011,
        "voice": "vo_adv_9052155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是根本完全找不到",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那最關鍵的祭壇嘛！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "根據村民們所說的話，",
        "unit_id": 106411,
        "voice": "vo_adv_9052155_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應該確實是在這附近沒錯。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我記得",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是只要調查祭壇有沒有異常變化就可以了吧？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "懷疑會不會是因為祭壇所祭祀的精靈發了狂，",
        "unit_id": 106411,
        "voice": "vo_adv_9052155_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n導致綠洲附近",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "突然開始出現魔物",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然村長是這麼說的……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105911,
        "voice": "vo_adv_9052155_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺不太到精靈之力這點很令人在意。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該說",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚至是非常微弱……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105811,
        "voice": "vo_adv_9052155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在尋找祭壇的同時",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也順便確保了充分的食材，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真幸運！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n任務完成後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就用這些新鮮的食材來做料理吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我等一下。",
        "unit_id": 106011,
        "voice": "vo_adv_9052155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳指的是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳剛才拿來的魔物肉吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚……",
        "unit_id": 106411,
        "voice": "vo_adv_9052155_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為了不必吃到魔物肉，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n從綠洲村莊買了那麼多的食物竟然都已經沒了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "量還是估太少了……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105811,
        "voice": "vo_adv_9052155_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留小雪菲妳們看，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個是不是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是我們在找的祭壇？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂白癡佩可！",
        "unit_id": 106011,
        "voice": "vo_adv_9052155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳別想蒙混過去喔──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼回事！？",
        "unit_id": 105811,
        "voice": "vo_adv_9052155_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突然有沙塵暴……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看看、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看不見前面了～～！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！",
        "unit_id": 105811,
        "voice": "vo_adv_9052155_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沙塵暴裡",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有魔物出現了！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "似乎",
        "unit_id": 106411,
        "voice": "vo_adv_9052155_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是不想讓我們接近祭壇呢……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀？",
        "unit_id": 105811,
        "voice": "vo_adv_9052155_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺有熱～烈的視線",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "盯著我拿著的肉耶！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那隻魔物",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會也肚子餓了吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在不是悠哉地聊什麼肚子餓不餓",
        "unit_id": 106011,
        "voice": "vo_adv_9052155_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的時候吧！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n它要來囉！",
        "unit_id": 106011
    }
]