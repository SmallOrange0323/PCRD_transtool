    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新手冒險者公會【幻變少女】。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n還不成熟的她們希望可以盡速變強，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n幫助{player}等人一起討伐魔物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而{player}在聽聞此事後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便請一些夥伴的公會幫助她們訓練。"
