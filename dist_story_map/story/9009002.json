        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "烤到。",
        "unit_id": 126112,
        "voice": "vo_adv_9009002_010"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n五分熟。",
        "unit_id": 126112
