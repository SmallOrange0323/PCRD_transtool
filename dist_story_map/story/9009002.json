    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……就這樣，由於莉莉等人的關係，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n使得錯誤的撈金魚文化在吉歐‧格黑納流傳開來了。"
