        "voice": "vo_adv_9009002_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普蕾西亞♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n加油！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "金魚？",
        "words": "嘰嘎嘎嘎嘎嘎嘎嘎嘎！！",
