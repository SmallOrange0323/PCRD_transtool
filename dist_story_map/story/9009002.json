    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看起來很難飼養……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_9009002_008"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n接下來，",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "試味道。",
        "unit_id": 126112
    },
