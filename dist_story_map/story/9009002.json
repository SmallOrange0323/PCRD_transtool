    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "像鰭一樣的手腳……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n宛如從地獄深處",
        "unit_id": 126012
