    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n不是有些食物長得不怎麼樣，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但卻很好吃嗎♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n肯定沒有問題的。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對吧，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普蕾西亞。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
