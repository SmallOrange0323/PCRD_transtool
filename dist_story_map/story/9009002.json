        "voice": "vo_adv_9009002_001"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n準備、",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "捕撈。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "金魚？",
        "words": "嘰嘎嘎嘎嘎嘎嘎嘎嘎！！",
        "unit_id": 1,
        "voice": "vo_adv_9009002_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就差一點了，",
