        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "雖然身體的確是金色的……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但這個",
