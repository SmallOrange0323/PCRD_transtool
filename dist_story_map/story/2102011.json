        "words": "\n貴族們的士兵也快到這裡來了吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噁……",
        "unit_id": 106012,
        "voice": "vo_adv_2102011_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然沒做什麼虧心事，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但在那之前我們還是先離開這吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "豪紳那張方方正正的臉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可不想要在睡前看到它啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們也一樣，",
        "unit_id": 102711,
        "voice": "vo_adv_2102011_069"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不想要接近屬於那一塊領域的人們呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯！",
        "unit_id": 100911,
        "voice": "vo_adv_2102011_070"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我們可是行走於冥府魔道的集團，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "和國家權力",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可說是不共戴天嘛！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反倒是貪吃佩可小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_2102011_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您不顧王宮跑到這來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會有事嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2102011_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於那件事我自有辦法♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n話說回來小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很謝謝妳！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯嗯！",
        "unit_id": 100111,
        "voice": "vo_adv_2102011_073"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果我們沒有可可蘿的話，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛剛真的就很危險了呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_2102011_074"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "非常感謝妳的努力……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……怎麼了？",
        "unit_id": 100311,
        "voice": "vo_adv_2102011_075"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可可蘿，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳的臉色似乎不太好……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……非常不好意思。",
        "unit_id": 105913,
        "voice": "vo_adv_2102011_076"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n老實說從方才開始，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就一直拼命忍耐著……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎也到此為止了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！？",
        "unit_id": 100211,
        "voice": "vo_adv_2102011_077"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n可可蘿，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳沒事吧！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔！？",
        "unit_id": 106012,
        "voice": "vo_adv_2102011_078"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳被魔物打傷了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這種事妳早點說啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_2102011_079"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非是那麼一回事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知是否是因為公主型態的副作用，",
        "unit_id": 105913,
        "voice": "vo_adv_2102011_080"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常令人感覺到了飢餓感。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下已經……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肚子快要餓扁……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2102011_081"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變成餓餓蘿",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "了……",
        "unit_id": 105913
    },
