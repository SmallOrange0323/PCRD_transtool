[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "流夏久違的回到自由的日常生活中，\n此時她正打算到城鎮的郊外睡個午覺。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不錯不錯，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "睡意順利地湧上來了……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那當然。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "擊退妖刀之類的事件終於平息，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總算能夠悠閒度日了呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，你沒事的話要不要一起來？",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我身旁的貴賓席還空著喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說好玩的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只是開玩笑啦。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……你怎麼啦，",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一臉傻楞楞的樣子。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼事？",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你儘管問。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "噗哈！",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你、",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你突然問這什麼問題啊！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那時候……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我講這個並不是那個意思……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當下一不小心說出了真心話……",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看他一臉漫不經心的樣子，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一開口話鋒就很敏銳呢這小子……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然這的確是我的真心話，可是……",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等一下等一下！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為什麼我得這麼慌張呢！？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那，",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那件事就算了吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你看，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "陽光這麼耀眼。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我要睡囉！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……真奇怪。",
        "unit_id": 105611,
        "voice": "vo_adv_1056008_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "明明刺眼得讓人睡不著……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼會、",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼睏……",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的……",
        "unit_id": 105632,
        "voice": "vo_adv_1056008_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼會這樣呢……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n在會長面前又不好拒絕……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦，",
        "unit_id": 105632,
        "voice": "vo_adv_1056008_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你來買東西？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我嗎？",
        "unit_id": 105632,
        "voice": "vo_adv_1056008_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我正在……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "散步中。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n……那就先這樣囉。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天──"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "啊！",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_013"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "你，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "你是那個常和流夏大姐頭在一起的人！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "我是",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "流夏大姐的小弟！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "你是因為擔心大姐頭，",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_014"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "才跑來的吧！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "\n真不愧是大姐頭看上的男人！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "大姐頭常常",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "跟我提到你的事！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "不過，",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_015"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "就算是商店街的會長請託，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "\n還真的去參加相親……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "大姐頭人真是太好了。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "怎麼了嗎？",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_016"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "你怎麼僵住了……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "難道你不知道這件事嗎！？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "大姐頭也真是的，怎麼可以這樣！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "其實",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_017"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "那個相親對象",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "是個很糟糕的傢伙！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "表面上裝得像個誠懇的男人，",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_018"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "但私底下在做的，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "是連我們小混混都會怕的壞事呢。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "我是相信大姐頭一定可以應付喔？",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_019"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "但畢竟對方是那種人，我還是很擔心……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "我本來跟死黨商量好，",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_020"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "要去破壞相親，卻被大姐頭發現……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "所以才會在這裡束手無策……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "如果是你這被大姐頭認同的人，",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_021"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "這件事，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "\n說不定你能幫得上忙！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "這是相親地點的地圖！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "大姐頭",
        "unit_id": 1331,
        "voice": "vo_adv_1056008_022"
    },
    {
        "type": "dialogue",
        "name": "小弟",
        "words": "就拜託你了！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}照著手上的地圖，\n急忙趕到相親會場──"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你剛剛",
        "unit_id": 105632,
        "voice": "vo_adv_1056008_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說什麼……？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "在妳身邊晃來晃去的那些小混混。",
        "unit_id": 1031,
        "voice": "vo_adv_1056008_024"
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "\n那些傢伙就放著不要管就好了。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "反正他們也不會成為善良百姓。",
        "unit_id": 1031,
        "voice": "vo_adv_1056008_025"
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "\n人渣就該過得像個人渣一樣才對啊。",
        "unit_id": 1031
    },
    {
        "type": "still",
        "still": "105600801"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不說話，你就一個人在那裡嘮嘮叨叨地高談闊論……",
        "unit_id": 105632,
        "voice": "vo_adv_1056008_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n真正的人渣到底是誰啊！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這爛到根的性格，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我現在就把它斬斷！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "噫噫噫噫噫！",
        "unit_id": 1031,
        "voice": "vo_adv_1056008_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是人都會犯錯。",
        "unit_id": 105632,
        "voice": "vo_adv_1056008_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但是，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "每個人都該有個改過自新的機會！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那幾個傢伙外表看起來那樣，",
        "unit_id": 105632,
        "voice": "vo_adv_1056008_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但現在努力洗新革面，正經地活著！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "妳、",
        "unit_id": 1031,
        "voice": "vo_adv_1056008_030"
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "妳冷靜一點嘛！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "不過講了幾句小混混蠢小鬼們的壞話而已，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "\n有必要氣成那樣嗎！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "而且，",
        "unit_id": 1031,
        "voice": "vo_adv_1056008_031"
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "妳要是把我惹火了，剛剛講的那些人可是不會置之不理的！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "\n妳的店跟那條商店街可就不保囉！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔～是這樣嗎。",
        "unit_id": 105632,
        "voice": "vo_adv_1056008_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你剛剛一直自豪地說會罩你的人，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n昨天在電話裡跟我說了。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你若是個沒骨氣的傢伙，砍了也無妨。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "啊……？",
        "unit_id": 1031,
        "voice": "vo_adv_1056008_033"
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "妳、",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "相親對象",
        "words": "妳說謊！",
        "unit_id": 1031
