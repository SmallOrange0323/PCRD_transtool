[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原以為牧場的工作",
        "unit_id": 121411,
        "voice": "vo_adv_6088103_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一點都不淑女，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n想不到真正嘗試過才發現是個很棒的工作呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "作為一位成熟的淑女，就是該挑戰各種事物。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對啊，",
        "unit_id": 121411,
        "voice": "vo_adv_6088103_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "成熟的淑女就連動物的心都能虜獲。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……雖然好像反倒都是",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "牛在關愛我，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但我決定不去深究了。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然那樣也不錯，",
        "unit_id": 121411,
        "voice": "vo_adv_6088103_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但我還是",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "比較想當個在城裡\n賣力工作的淑女。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "或許那樣也能夠幫助到牧場……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我是不是受秋乃小姐的影響太深了啊？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "多喝牛奶真的很重要呢……",
        "unit_id": 121411,
        "voice": "vo_adv_6088103_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唔！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才沒有那種事咧！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你幹嘛裝傻要我要吐槽啦？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n跟真陽小姐搭檔搞笑的人只要有你一個就夠了。",
        "unit_id": 121411
    }
]