    {
        "type": "dialogue",
        "name": "旁白",
        "words": "莫妮卡和{player}兩人一道去買東西。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "聽好了，",
        "unit_id": 105311,
        "voice": "vo_adv_1053008_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不可以繞道去別處喔。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們沒有多餘的錢去買其他沒用的東西喔。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒錯……我們沒有多餘的錢，",
        "unit_id": 105311,
        "voice": "vo_adv_1053008_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到這路上居然有點心店……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不行！",
        "unit_id": 105311,
        "voice": "vo_adv_1053008_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不能被點心誘惑！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然都看到了點心店，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n逛一下無妨吧……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哇！",
        "unit_id": 105311,
        "voice": "vo_adv_1053008_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好、好耀眼……！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這道光芒，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "以前也……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哇啊啊啊啊！！",
        "unit_id": 105311,
        "voice": "vo_adv_1053008_004"
    },
    {
        "type": "background",
        "background": "510340"
    },
    {
        "type": "still",
        "still": "105300801"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我還以為是誰，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來是閣下。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你來買東西嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我呢……只是辦點事情而已。",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_006"
    },
    {
        "type": "dialogue",
        "name": "小學生",
        "words": "隊長～！",
        "unit_id": 131,
        "voice": "vo_adv_1053008_007"
    },
    {
        "type": "dialogue",
        "name": "小學生",
        "words": "快看快看～！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔、",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個是什麼點心啊？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看起來味道不錯呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "小學生",
        "words": "嗯，",
        "unit_id": 131,
        "voice": "vo_adv_1053008_009"
    },
    {
        "type": "dialogue",
        "name": "小學生",
        "words": "非常好吃喔～",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣啊。",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那我等一下也買來吃吃看吧。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼可能呢！",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只是他們隨便亂叫的。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼是他們陪我呢！？",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n正常來想，應該是相反的吧！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "他們呢……",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該怎麼說，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就像是我的朋友。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "他們常常邀我一起玩，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我總是很難拒絕。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今天也是他們說想來懷舊點心店。",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我沒辦法才陪著來的。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼？",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說我太溫柔……了嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不管說什麼最後都會去陪人家？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "本、本來就是！",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n因為我很溫柔，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以才陪他們一起來！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "並不是因為想要一起玩，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "或想吃點心之類的。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎！？",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n怎麼突然",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這麼說？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼？",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為總是得到我的幫助……？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我沒有做什麼值得被感謝的事情。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n只是恰巧",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "與閣下的目的一致而已。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說還是要謝謝我",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣啊，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那就買些懷舊點心給我吧。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真的可以嗎？",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就所有的種類都各買一個吧。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不管哪一種都讓我很想嚐看看呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼這麼慌張？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n閣下好像沒有特別說只能買幾個吧？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "小學生",
        "words": "什麼什麼～",
        "unit_id": 131,
        "voice": "vo_adv_1053008_022"
    },
    {
        "type": "dialogue",
        "name": "小學生",
        "words": "\n哥哥，",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "小學生",
        "words": "要買點心給我們嗎～？",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "小學生們",
        "words": "我也要、我也要～！",
        "unit_id": 1,
        "voice": "vo_adv_1053008_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下好像快哭出來了，",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒事嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼？  ",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說錢包的錢會用光光，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然閣下說要表達感謝，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那就只好認命了呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不過話說回來，",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "想表達感謝的人還有我呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下",
        "unit_id": 105331,
        "voice": "vo_adv_1053008_026"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "每次都會幫助我，\n我、也是，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是很感謝啦……",
        "unit_id": 105331
    },
