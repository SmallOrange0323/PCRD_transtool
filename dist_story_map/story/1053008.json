        "voice": "vo_adv_1053008_030"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我也是剛醒來。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看起來，我們是在路上睡著了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "之前，",
        "unit_id": 105311,
        "voice": "vo_adv_1053008_031"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也發生過這樣的事情……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n閣下不會是做了懷舊點心店的夢了吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
