    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳說還沒聊完……",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n從剛剛就一直聊個不停不是嘛！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咕唔唔唔…………",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_004"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n最近忍和小伙子實在太要好了……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n該、該不會……忍對小伙子……！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不、不會的，不可能有那種事！",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_005"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n忍還是個離不開爸爸的孩子嘛。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n真令人煩惱呀。嗯嗯……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然後啊……",
        "unit_id": 103111,
        "voice": "vo_adv_1031005_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "什麼！！！？？？",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "抱、抱歉，{player}！",
        "unit_id": 103111,
        "voice": "vo_adv_1031005_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我稍微絆到腳了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍和小伙子、忍和小伙子、忍和小伙子……！！！",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_009"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嘎喔喔喔喔────！",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸、爸爸！？",
        "unit_id": 103111,
        "voice": "vo_adv_1031005_011"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呀──！房子被魔法給摧毀了！",
        "unit_id": 411,
        "voice": "vo_adv_1031005_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "快、快逃──！",
        "unit_id": 311,
        "voice": "vo_adv_1031005_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "住、",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "住手！爸爸！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不要在城鎮裡使出魔法！！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嘎喔喔喔喔────！",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "父、父親失控了！",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n他好像失去了自我……怎、怎麼會變成這樣？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "在大鬧的魔物就是那個骷髏頭嗎！？",
        "unit_id": 711,
        "voice": "vo_adv_1031005_017"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "目標是擊退骷髏頭！全軍突擊────！！！",
        "unit_id": 712,
        "voice": "vo_adv_1031005_018"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嘎喔喔喔喔────！",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_019"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "哇――――――！！！",
        "unit_id": 711,
        "voice": "vo_adv_1031005_020"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "連王宮騎士都被打倒了！？",
        "unit_id": 311,
        "voice": "vo_adv_1031005_021"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這樣下去蘭德索爾會毀滅的！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那是惡魔使者……古戰場的火焰……這世界要崩壞了……",
        "unit_id": 411,
        "voice": "vo_adv_1031005_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎、怎麼辦……",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n父親是傑出的靈媒，魔力強大到非比尋常。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n根本沒有方法可以阻止失控的父親……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只是……為什麼父親會失控到如此地步呢？",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n要說父親喜歡的東西，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我只能想到女人、女人和女人而已了……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……咦？你說我嗎？",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n父親的確非常溺愛我……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊！該不會是剛剛我……",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那、那個……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為我一把抱、抱住了{player}你……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸真是的，竟然因為那種事情而失控……",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是那樣的話就沒有辦法阻止了……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也、也是。",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸！不要再破壞城鎮了！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我和{player}，",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不是像爸爸你誤會的那種關係！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我對{player}……那個……該怎麼說……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦！？",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我做不出那種事情的！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……要讓我父親看到我討厭你的樣子？",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒、沒辦法！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為我、我對{player}你……那、那個……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀――――！",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "―――――――――――啾―――――――――――",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "哇！",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對對對、對不起！",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因、因為我跌倒了，結果碰到{player}的………！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、我我我、我！！！？？？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "什什什什麼────────！",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可、可是，這是碰巧的！是個意外！",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而、而且是碰到臉頰！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n請、請你不要在意！！！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小小小小小、小伙子――――――！！！",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_038"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n饒不了你饒不了你饒不了你！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我絕對饒不了你――――――――！！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸你安靜一點────！",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_039"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嘎喔―――！！！！",
        "unit_id": 2411,
        "voice": "vo_adv_1031005_040"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "太、",
        "unit_id": 311,
        "voice": "vo_adv_1031005_041"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "太好了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n那個女孩打倒魔物了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這、這樣子，這個城鎮……這個世界就得救了！！！",
        "unit_id": 411,
        "voice": "vo_adv_1031005_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "抱、抱歉，{player}！",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我、我現在幫你把臉頰擦乾淨，不要亂動喔！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……欸？我父親不再失控真是太好了？",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_044"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那一點都不重要！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我、我……！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "該怎麼辦好……！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "可以向你們問一下話嗎？",
        "unit_id": 711,
        "voice": "vo_adv_1031005_045"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n我們收到了證詞說這個魔物和你們有關係……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "比起那件事，{player}，",
        "unit_id": 103112,
        "voice": "vo_adv_1031005_046"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n請、",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請不要誤會喔！",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "剛、剛剛那個只是個意外而已……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果，{player}和心慌意亂的忍一起，\n受到了騎士團漫長的例行盤問……"
    }
