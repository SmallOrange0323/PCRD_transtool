[
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "玩著怪盜遊戲的小鬼們……",
        "unit_id": 16011,
        "voice": "vo_adv_5090321_000"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "你們",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "是否夠格跟我戰鬥……",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n就用這個收藏品來測試看看吧！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼……！？",
        "unit_id": 121611,
        "voice": "vo_adv_5090321_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n奇怪的拉霸機一台接一台跑出來了啦！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "這是買來迎擊入侵者用的東西。",
        "unit_id": 16011,
        "voice": "vo_adv_5090321_002"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n這玩意",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "可是很貴的哦。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n但也因為如此，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "是我自豪的收藏品啊。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那真是太可惜了呢？",
        "unit_id": 106511,
        "voice": "vo_adv_5090321_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n因為你那自豪的收藏品，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n會被我們全部打爛！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣會造成多少億盧幣的損失呢？",
        "unit_id": 121611,
        "voice": "vo_adv_5090321_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈哈～！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "想想就叫人興奮呢！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "哼哼哼……",
        "unit_id": 16011,
        "voice": "vo_adv_5090321_005"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "做得到就試試看吧！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "……話說回來，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "感覺不到步未的氣息……",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n是躲在哪想趁機偷襲我嗎？",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "……在那嗎！？",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "被發現了……！！",
        "unit_id": 121511,
        "voice": "vo_adv_5090321_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "果然還是要先",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "把這些拉霸機打倒才行……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "還真是不能大意啊……",
        "unit_id": 16011,
        "voice": "vo_adv_5090321_007"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "唯獨妳，我一定要在這把妳解決掉，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "步未！",
        "unit_id": 16011
    }
]