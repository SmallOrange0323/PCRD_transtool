[
    {
        "type": "background",
        "background": "501590"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧一行人恢復了理智，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n準備重新開始團體露營──"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚嗚……",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在我們吃著蘑菇的時候，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "火堆熄滅了……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒問題的，",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我和純準備了一堆柴火。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n振作起來，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "重新準備吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小優花梨說得沒錯，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "假還長得很呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n先升火重新開始露營，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓心情冷靜下來吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦～！？",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你要回去了嗎？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這這這這、",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這是為什麼啊！？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哦……",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你帶野營道具，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只是怕搜索我們的時間拖得太久……？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣啊……",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你來露營區",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "並不是為了度假……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣的情況，",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們也不能硬要你留下來呢……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………請、",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請等一下！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我……",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "之前都是在",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n心情非常沮喪的時候，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一個人進行這個稱作露營的活動。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "收集掉在地上的木材，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "搭帳篷、製作椅子，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘴饞的時候開心品嘗想吃的東西，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "然後，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "晚上靜靜眺望著星空……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的露營",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是這樣獨自一人度過的活動……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然我本身",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "覺得那樣也是過得蠻開心的。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這次優花梨小姐和純小姐邀我一起參加，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "讓我知道了跟別人一起露營的樂趣！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "並列著搭起帳篷，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "討論對方使用的道具，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n大家分頭準備要吃的料理，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "圍坐在火堆前，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "七嘴八舌談天說地……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然各方面來看，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "料理是嚴重失敗了……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是！",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "三個人一起露營",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "非常開心！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這種事",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在我一個人露營的時候，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n簡直無法想像！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我獨自一人一直進行的露營，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n有著單人露營才能體會得到的樂趣……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跟優花梨小姐和純小姐三個人一起進行的團體露營，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n有著只有我們三人才能體會得到的樂趣……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也就是說……",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "加入了{player}的四人團體露營，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想應該也能體會到前所未有的樂趣吧！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我相信一定，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能體驗到日常生活感受不到的暢快感，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有平常難以啟齒的事情，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n應該也敢開口聊吧……！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以說，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}的意下如何？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……來、",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "來跟我們一起……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露營吧？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……啊！",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝你！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你也在的話，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "相信露營應該……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是絕對會很開心的！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我來幫忙紮營吧！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n也麻煩優花梨小姐妳們一起幫忙了！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "純、優花梨",
        "words": "嗯！\n好！",
        "unit_id": 1,
        "voice": "vo_adv_5094007_022"
    },
    {
        "type": "background",
        "background": "501592"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……來，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各位，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請喝咖啡。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n趁還沒冷掉之前享用吧。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯，",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "非常好喝哦。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n濃郁的香氣中",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還帶有微微的甜味呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……嗯！",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這跟平常在工作中喝的",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "截然不同耶！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵呵，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真高興能看到大家喝得這麼開心！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒枉費我用心地泡咖啡了！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "小碧，",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以把這些咖啡豆分給我們的公會嗎？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我會請秋乃付妳開的價錢！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不用啦！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想要多少我都可以給哦！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟我也一直受領班和珠希照顧啊！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說到泡得好喝的祕訣……",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n除了當然要照正確步驟沖泡外，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還要在心中",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「變好喝……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "變好喝……」",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣默念！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "透過與咖啡豆心靈相通，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就能引出其本身的美味哦！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聽起來真有趣。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我會跟公會的所有人一起試看看的。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哎呀～",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "過去連想都沒想過，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我竟然能跟別人分享這個味道呢！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團體露營",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真棒……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊…………",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳說得",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一點都沒錯……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為我正在消化特休啊……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是小智她們叫我放假。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然我不需要，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我不能無視體恤我的部下的建言。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "起初我是做著高地訓練來度過假期，",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過在遇到小優花梨之後，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓我發現到休息的重要性。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "假如我沒放假，",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總是繃緊神經的話，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這股緊張感應該也會傳染給部下們吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那樣一來，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "遇到萬一就有可能會動彈不得……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "透過我更有彈性的執勤態度，",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n應該可以替整個團隊帶來",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正面的效果吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "把這次的露營作為教訓，",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我決定往後",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在合理的範圍內",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "放假休息。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "光只有我這麼悠哉也沒意義。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n未來我想以體恤團員的名義，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "跟大家一起露營呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}也來找出",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_042"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "屬於你自己開心享受露營的方式吧。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要在火堆前重新面對自己也行，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_043"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要吐露平常說不出口的事情也行，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請你盡情地自由度過吧！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要是有任何能幫上忙的地方，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_044"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我會盡全力努力幫的！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_045"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "之前在蘭德索爾，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我還擺出很失禮的態度……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那是BB團不該有的舉止……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_046"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想也為那件事道歉，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "透過露營好好招待你。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我還不敢以",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_047"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "優花梨小姐和純小姐的朋友自居，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但、",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是我覺得我們是露營夥伴。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "或許靠我一個邊緣人",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_048"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "成不了大事……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_049"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跟露營夥伴一起的話，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想{player}也能過得很開心吧。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "露營夥伴……",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_050"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聽起來真棒。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "跟酒友不太一樣，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是令人覺得很舒服的關係呢。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是互相",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都不用太拘謹的關係呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘿嘿，",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_052"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能聽妳們這麼說讓我放心了。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "很高興能交到露營夥伴！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也想跟{player}",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_053"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "當BB團的同志",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "兼露營夥伴！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "…………我說，",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_054"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "抱歉在你們相談甚歡時插嘴……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是差不多該來準備吃飯了吧？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "跟魔物戰鬥，",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_055"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還有重新紮營，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "搞得我肚子餓了……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咖啡雖然好喝，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但麥酒還是讓我難以割捨……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "再加上，",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_056"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "像這樣四個人露營讓我發現到一件事。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所謂的露營暢飲，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n並不光是在露營區喝著麥酒就好了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也要享受景色和對話……",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_057"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "像這些露營才有的下酒菜，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n正是能改變人生的露營暢飲啊。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因此，",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_058"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "既然現在交到了三個露營夥伴，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我想一定能喝到最棒的那一杯吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這都是你們露營夥伴的功勞，",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_059"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝你們。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以說……",
        "unit_id": 122211,
        "voice": "vo_adv_5094007_060"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就是這樣，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們來吃飯吧？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "大家也都肚子餓了吧？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼說也對。",
        "unit_id": 104715,
        "voice": "vo_adv_5094007_061"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "既然也和少年會合了，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們就來吃飯吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這次就別再煮蘑菇了。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那就來煮露營餐吧！",
        "unit_id": 122111,
        "voice": "vo_adv_5094007_062"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n讓我為大家",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "大展廚藝！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人開心用完餐後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n暢談了起來──"
    }
