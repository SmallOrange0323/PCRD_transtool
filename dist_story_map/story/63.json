    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不錯呢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就奉陪吧。",
        "unit_id": 106012
    },
