[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "多虧有了「美食獵人號」，",
        "unit_id": 105812,
        "voice": "vo_adv_0000063_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "移動真的變得好輕鬆喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這都是小飯糰願意替我們賣力拉車的功勞♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n接下來也要麻煩你囉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "小飯糰",
        "words": "嗶、嗶咕～♪",
        "unit_id": 9611,
        "voice": "vo_adv_0000063_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "美食獵……",
        "unit_id": 106012,
        "voice": "vo_adv_0000063_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那該不會是這個移動式公會小屋的名字吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "美食獵人……",
