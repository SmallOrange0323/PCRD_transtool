        "voice": "vo_adv_0000063_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是追求美食之人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的意思吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下覺得這是非常適合在下等人【美食殿堂】的名字。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是說啊，就是說啊♪",
        "unit_id": 105812,
        "voice": "vo_adv_0000063_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是我昨天想到三更半夜才想出來的喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難怪半夜一直聽到窸窸窣窣的聲音……",
