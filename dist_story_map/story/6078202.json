[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "黑暗老師的魅惑……",
        "unit_id": 104512,
        "voice": "vo_adv_6078202_000"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "真是太刺激了……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n害得空花",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "差點就要忘我地變成學生了～",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "什麼！？",
        "unit_id": 104512,
        "voice": "vo_adv_6078202_001"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "讓空花去學校……！？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "也就是像，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "「把妳的身體當作筆記本，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "在每個角落寫滿我的字」",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "這樣嗎！？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "何等的虐待狂！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "你想拿橡皮擦在空花身上擦來擦去對吧！？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "啊，",
        "unit_id": 104512,
        "voice": "vo_adv_6078202_002"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "那對虐待狂先生不管用是吧。",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "感覺就是，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "彷彿整顆心被抓住後，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "不斷被咕嘰咕嘰搔癢，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "既讓人心急，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "又酸酸甜甜的砰然心跳感……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "流口水……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "是、",
        "unit_id": 104512,
        "voice": "vo_adv_6078202_003"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "是嗎？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "謝謝你，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "受到虐待狂先生普通地誇獎，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n空花會感覺",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "心變得輕飄飄的……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "這是，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "魅惑嗎……？",
        "unit_id": 104512
    }
]