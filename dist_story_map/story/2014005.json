    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳就是個",
        "unit_id": 106011,
        "voice": "vo_adv_2014005_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨蛋，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "擅自主張，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又愛腦衝。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明很喜歡隨便就朝人黏上來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可是卻完～全～不聽人講話……",
