    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我在想如果妳是全開著「皇家裝備」的力量和陛下打了一場的話，",
        "unit_id": 106011,
        "voice": "vo_adv_2014005_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n肚子也差不多快餓扁了才對。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我在一間因這騷動而毀掉的房子中撿到的，",
        "unit_id": 106011,
        "voice": "vo_adv_2014005_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然是條烤得半焦的麵包……",
