[
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在借助了變貌大妃・似似花的幫忙下，【美食殿堂】的成員們"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n又再一次成功地從霸瞳皇帝的手掌心中逃了出來，但……"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經拉開這麼遠的距離了，",
        "unit_id": 105911,
        "voice": "vo_adv_2014005_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該暫時安全了吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而畢竟對手是那位霸瞳皇帝，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若要說安心似乎又還言之過早……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 106011,
        "voice": "vo_adv_2014005_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我先去把這附近的魔物掃除乾淨了喔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n正好是順便想洩恨一下的心情！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思……",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳唷，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106011,
        "voice": "vo_adv_2014005_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算不用你在那邊囉嗦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也知道啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨蛋！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……又再說，",
        "unit_id": 106011,
        "voice": "vo_adv_2014005_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……現在，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你的那張臉，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我沒辦法直視啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我到底是怎麼了啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過就是額頭上稍微……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "了一下而已啊！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我說小凱留呀……",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……痛……！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊痛痛痛……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_2014005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您振作點……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿……",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起呀。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一鬆懈下來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就突然腿軟了呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "痛痛痛……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仔細一瞧，",
        "unit_id": 105911,
        "voice": "vo_adv_2014005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您可是受了不少傷呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是在下發現得太遲了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "立刻，",
        "unit_id": 105911,
        "voice": "vo_adv_2014005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就替您使用恢復魔法。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖有些失禮，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而還請您借給在下那份力量。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若只依靠在下的魔力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許得花上不少的時間……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……對不起。",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我又",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "給大家添麻煩了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明和大家一起",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "同心協力的話，絕對會比較好。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我心裡，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明也是明白這件事的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但一看到那傢伙……",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一看到霸瞳皇帝的身影後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的腦筋就一片空白了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要把那傢伙給打倒，",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就全部都能結束了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在拯救了父皇和母后，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有大家之後……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就能回到溫暖的家了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我一這麼想，",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "眼裡",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就只剩下那傢伙的身影，其他什麼都看不到了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在那之後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就只是忘我地追在他的後頭，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後揮舞著手中的劍……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是……",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我完完全全，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一點都不是他的對手……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就連要傷到他一點皮毛，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也辦不到……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……或許",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是那樣也說不定……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我呢，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的有能夠幫助大家的力量嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對，",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在能不能派上用場之前。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n若霸瞳皇帝又出現在我眼前……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我又會",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼都忘光光，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後一股腦突擊而去了也說不定……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……像這樣的我，",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一點也沒有",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓你們對我這麼溫柔的價值。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我根本就只是一個，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拖油瓶而已呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_2014005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的這一番話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一點都不像貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總是樂觀開朗，",
        "unit_id": 105911,
        "voice": "vo_adv_2014005_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管遇上危急時，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『很不妙呢』",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也能如此笑著跨過的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不才正是貪吃佩可小姐您嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可、",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n霸瞳皇帝他……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛剛",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼說了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說我不管是頭腦還實力，",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "全都不夠。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說像這樣的我就算率領整個國家，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "早晚也會自我毀滅的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那句話……",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在的我，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒辦法斷言和否定他。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不只是這樣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "甚至在我的心裡，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「說不定他說的是對的。」也不禁這麼去想了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然每次",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都是我在說你",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「明明就那麼軟弱呢。」",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……但真正軟弱的……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是明明還有這件皇家裝備能夠依賴，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n卻還是……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼都做不到的我啊……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_2014005_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算你和小可蘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n把像我這樣的人給丟下也沒……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呣伊！？",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "201400501"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呣嘎，",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呣咕嘎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n哈、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈嗚啊？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐！？",
        "unit_id": 105911,
        "voice": "vo_adv_2014005_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明幾乎有我一整條的手臂長欸……",
