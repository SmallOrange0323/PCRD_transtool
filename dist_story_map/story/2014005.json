        "voice": "vo_adv_2014005_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就只是被陛下講了幾句壞話，",
