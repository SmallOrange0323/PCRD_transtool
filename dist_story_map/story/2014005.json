    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "――不是啦，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼妳……！？",
