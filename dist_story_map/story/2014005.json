    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以說啊……！",
        "unit_id": 106011,
        "voice": "vo_adv_2014005_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓我們一起改變吧，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可……！",
