    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是一次又一次的講給妳聽了嘛。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……",
        "unit_id": 105811,
        "voice": "vo_adv_2014005_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……可是。",
        "unit_id": 106011,
        "voice": "vo_adv_2014005_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣的妳，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
