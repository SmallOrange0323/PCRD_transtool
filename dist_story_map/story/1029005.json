[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望找{player}商量某件事。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你覺得……這個如何？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我試著為新歌寫了歌詞。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是一首情歌喔……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然是我的經紀人要我寫的，\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但這是我第一次寫情歌歌詞，所以想聽聽你的意見……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個……不是讚美吧？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「喜歡你喜歡到肚子都要叫了」這樣的歌詞，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是不是不太好啊……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n「千變萬化」和「孤軍奮戰」這樣的歌詞好像不太行呢？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……果然這樣不像是情歌吧？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想把戀愛的感覺寫進歌詞，但又不太了解……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唉……\n我自己也很清楚，",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你也覺得這個歌詞完全不行吧……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但這也沒辦法，偶像是禁止談戀愛的。",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明就沒談過戀愛，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n要怎麼才能寫出情歌呢！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "戀愛不是那麼簡單的東西吧。\n即使以假裝談戀愛的心情來寫，也寫不出好歌詞……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就說了，不要說得那麼簡單嘛。",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我是偶像，所以不能交男朋友啊。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是說怎麼？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你願意當我的練習對象嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！？你、你剛才說什麼？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你真的願意讓我練習嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哼……我聽得很清楚喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在要反悔也來不及囉！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那就這麼決定了！\n為了更加了解什麼是戀愛，我們兩人來約會吧！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_012"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天――――"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼～我們開始約會吧。\n可以的話，我是希望約會能由男生主導啦，",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過{player}有約過會嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒有嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你沒有女朋友啊？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，我說太好了是指……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只、只有我沒有戀愛經驗的話，那就太不公平了",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我、我沒有別的意思喔，你不用太在意。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼～今天的約會就由我來主導吧。",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我在舞台劇和小說中看過如何約會，交給我吧。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼首先……你覺得去購物如何？",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨。",
        "unit_id": 411,
        "voice": "vo_adv_1029005_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇！這件衣服好可愛啊！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n吶，你覺得如何？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的嗎？\n呵呵，既然你都這麼說了，",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我就買下它囉～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這位客人，那件洋裝",
        "unit_id": 411,
        "voice": "vo_adv_1029005_020"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n搭配這款包包會顯得更可愛喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的耶！\n啊，那雙鞋子跟這件衣服好像也很搭！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是買這麼多提得動嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你要幫我提東西嗎？\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那就麻煩你啦。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "那麼，要不要也選購這款飾品呢？",
        "unit_id": 411,
        "voice": "vo_adv_1029005_023"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這頂帽子也相當適合您喔。\n我想您的同伴也會喜歡喔～",
        "unit_id": 411,
        "voice": "vo_adv_1029005_024"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這把劍您看如何？\n和男友各買一把就太棒了呢～",
        "unit_id": 411,
        "voice": "vo_adv_1029005_025"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這邊的鎧甲也很受情侶歡迎喔～",
        "unit_id": 411,
        "voice": "vo_adv_1029005_026"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "謝謝您的惠顧～！",
        "unit_id": 411,
        "voice": "vo_adv_1029005_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "洋裝、包包、飾品、帽子、鞋子、劍和鎧甲……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我、",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是不是買太多了啊？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}，會不會很重？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀！？\n{player}重到被壓垮了！？\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你、你沒事吧！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱、抱歉啊。",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n東西買得有點多。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你一直稱讚我嘛。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還被店員說你是我男朋友……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n像那種店員啊，都很會說話呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是……我們真的看起來像情侶嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你肚子餓了吧？來吃中餐吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為表歉意，飯錢我來出！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "瞧你吃得津津有味呢。\n呵呵呵。看你吃成這樣，身為請客的人也很開心喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、我嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不用了啦，我喝飲料就好。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你也知道我在減肥啊。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀！肚、肚子叫了……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管了啦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}，那個分我吃！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嚼嚼……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊～好好吃～！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也吃看看那個吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}，抱歉喔。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……吃完飯後？\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果你願意的話，要不要去看戲呢？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n其實昨天我有思考過約會行程喔。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看完戲後，\n我們去打撞球如何？ 還是打保齡球比較好？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n之後去牧場騎馬、去海邊、去山上……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哼～哼，你看你看！這份完美的行程表！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n一個行程一小時完成的話……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，好像沒算到移動的時間？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒問題，沒問題！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為我也不知道下次什麼時候才能休假嘛。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難得放假，想跟你一起做的事我全部都要做！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！？難、難道下雨了？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看戲是沒問題，但海邊、山上和牧場就……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚……太可惜了。",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那剩下的時間……我們來聊天吧？",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵呵，結果最後也沒去看戲，",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n只是聊天時間就不夠了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但是我相當地開心喔！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天謝謝你喔。\n雖然我原本無法想像練習約會會是什麼樣子……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但嘗試之後卻出乎意料地開心！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且……\n我也發現了許多你的優點。",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我之前對你一點也不了解呢……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？你也發現了我的優點了嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是、是喔……總覺得很開心呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！\n我覺得好像寫得出情歌的歌詞了！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我會試著努力的。謝謝你！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後――――"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "完、完成了！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我好像寫得很好呢！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_049"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「希望你能看向我」「希望你能察覺」「我想告訴你」，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是像這樣能夠體會女孩單戀心情的歌詞！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他也差不多要來了，\n我要趕快拿給他看！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好期待啊～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？咦？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_051"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這、這個歌詞……給他看……？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "給他看……給他看的話，總覺得……",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n非常地害羞！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說到底為什麼當初我會寫",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種女孩子單戀著別人的歌詞呢！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "――哇！？\n{player}！？\n怎、怎麼啦！？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？歌、歌詞嗎……？",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對、對喔，跟你約好今天要給你看的……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那是，那個……嗯……還沒……完成……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼能給你看啦～！！",
        "unit_id": 102911,
        "voice": "vo_adv_1029005_056"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果望也沒能把新歌的歌詞給{player}看。"
