[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束新年嚮導工作的可可蘿，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與{player}一起回到了繁華街。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "攤販幾乎",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都開始收攤了呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "新年的熱鬧氣氛",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到今天就要結束了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能夠在今天，",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像這樣與主人一同度過新年的其中一天，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下感到非常地幸福。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔，",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人今年的第一個神諭……？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們到這邊的長凳坐下吧……",
        "unit_id": 111911
    },
    {
        "type": "background",
        "background": "510140"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "祝您新年快樂，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_003"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "竟然讓主人您特地過來，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_004"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真是不好意思。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "想必您",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還有其他的安排吧……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯。",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_005"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n吃飽睡、睡飽吃，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "除了懶散地看新年搞笑節目之外，沒有其他安排啊。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這也是一種",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "很有新年感覺的度過假期的方式呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您是說在下嗎？",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_006"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "畢竟",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下也沒有能在休假時一起玩樂的朋友，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n所以剛才在畫動物們的寫生。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那其實是在下的寒假作業，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_007"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n也許是因為新年的關係，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "幾乎沒有其他客人在，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n作業進行得非常順利。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "天氣偏冷這點雖然可惜，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_008"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但可以清楚聽到動物們的叫聲，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "令人心曠神怡。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯……",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_009"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "正好剛打完草稿，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "畫到一個段落了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而且，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "既然是主人的邀約，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下便無法拒絕。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也可以當作繪圖日記的題材，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_010"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還請務必讓在下陪同。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下記得",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_011"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親應該有一些很有新年氣氛的玩具。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下立刻去拿來。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "沒想到……",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_012"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "居然又是在下贏了……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為何主人您",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_013"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "每一局都會踩中好幾次",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n返回起點的格子呢？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "加上這次",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就是第十次的比賽了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但主人",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "卻連一次都沒贏過就結束了……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n雖然雙六",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是個運氣成份很大的遊戲，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但這到底是……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這麼說來，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "寒假作業中",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n有一年之計在於元旦",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這樣一句話。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "再這樣下去，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人的一年",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n是不是就會變成輸個不停的一年了呢？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "可不能讓事情變成這樣，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n我們換個",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就算是主人也能贏的遊戲吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下先暫時回家",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "去找別的東西過來。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "讓您久等了，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人。",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "111900401"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呃……",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您是指這身和服嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親說難得的新年，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就拿出來給在下穿了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "因為這是兒童用的和服，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "所以並不會太難穿。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "即使如此，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下還是邊用mimi支援才穿好的。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖說是新年，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但到去年為止",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下都還沒有機會出門，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "像這樣",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "穿上和服還是第一次呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您、",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您覺得適合在下嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是……",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_022"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這樣啊。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能獲得您的稱讚，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下覺得非常光榮。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下還想說",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_023"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是因為人靠衣裝、佛靠金裝的關係，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n但既然主人都這麼說了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下就相信",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您所說的話了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "先不管這件事了，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_024"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我們接下來打板羽球吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這個的話，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就不會被運氣所左右，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "可以發揮彼此的實力來遊玩。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "來，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_025"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "從主人開始吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n請瞄準在下前方這裡，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "把球打過來吧。",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "111900402"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊啊！",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_026"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n主人，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您要打去哪裡！？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "沒想到。",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_027"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人也是",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "第一次打板羽球啊。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您可能要再放鬆力道，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_028"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "輕鬆地把球給打出去會比較好。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "別往在下頭上打，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這次一定要",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "往在下前方輕輕地",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "打過來……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "又打歪了！？",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_029"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但是，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下這次一定接得到……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嘿！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "打中了！",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_030"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下成功接住主人的球了！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "來，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_031"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "接下來",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "請主人也打回來吧！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "漂亮地揮空了……",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_032"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……嘻。",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_033"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊啊，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_034"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "失禮了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這並不是在取笑主人揮空了！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下只是",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_035"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "覺得能像這樣玩樂很開心。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n就像剛才所說的，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下沒有在新年時期外出遊玩的經驗。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下今天才第一次知道，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_036"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "新年是個快樂的日子。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還是說，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是因為和主人一起度過，所以才感到快樂嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能在一年之初",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_037"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "像這樣從主人身上學到一件新事物，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n真是令人非常開心。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "再次鄭重地跟您說聲",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_038"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "今年也請多多指教。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在新的一年，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下仍舊會繼續服侍主人……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "什麼？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "輸掉遊戲的處罰嗎？",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_039"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "板羽球的確是有",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_040"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n贏家要在輸家臉上塗鴉的傳統……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "咦咦！",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_041"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您是說連處罰也要照做嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下這裡",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_042"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "正好有用來寫生的顏料和筆，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n但在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "實在無法在主人臉上塗鴉！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊啊，",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_043"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您怎麼擅自把在下的寫生用具拿出來……！？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "請您別笑著",
        "unit_id": 105931,
        "voice": "vo_adv_1119004_044"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "把筆交給在下啊～！",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "穿和服的可可蘿～！",
        "unit_id": 190011,
        "voice": "vo_adv_1119004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真是的！　",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼會那麼可愛啦～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真沒想到居然會收到",
        "unit_id": 190011,
        "voice": "vo_adv_1119004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你給的紅包呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能夠讓可可蘿露出與她年紀相仿的笑容的人，",
        "unit_id": 190011,
        "voice": "vo_adv_1119004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也只有你了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "竟然在別人認真學習的時候邀人去玩，",
        "unit_id": 190011,
        "voice": "vo_adv_1119004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n身為大人實在很有問題……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過這次就睜一隻眼閉一隻眼放過你吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你",
        "unit_id": 190011,
        "voice": "vo_adv_1119004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今年也會遇到各種事情，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但可可蘿就拜託你囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1119004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝謝你的紅包～",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來您醒來了呢，",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您這次夢到的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是什麼樣的夢呢？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這、",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種話，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對在下實在太過獎了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您能這麼想，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下覺得很高興。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了主人",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而盡心盡力，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是在下的職責……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身為主人的『嚮導』，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下要把這個夢當作是一個美好的開始。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的過得非常充實。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了讓今年也能成為美好的一年，",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好地支援您的，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好了，",
        "unit_id": 111911,
        "voice": "vo_adv_1119004_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "天色也暗了，開始變冷了，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓我們手牽手，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "互相",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幫彼此暖著手回家吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從{player}與可可蘿牽在一起的手中傳來的溫度，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n令人忘卻了冬天的寒冷，而感受到新季節的來臨。"
    }
]