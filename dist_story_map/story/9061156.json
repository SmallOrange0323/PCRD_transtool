[
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦，",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我至今",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "到底",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算穩定下來了呢。",
        "unit_id": 105913,
        "voice": "vo_adv_9061156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物已經打倒了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請安心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "穩定下",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "來……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n難不成我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又變成小嬰兒了……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次持續滿久的呢～",
        "unit_id": 106012,
        "voice": "vo_adv_9061156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n發生很多事情很辛苦的喔──",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣啊……",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我這次",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又搞砸了呢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對不起……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用道歉啦。",
        "unit_id": 105812,
        "voice": "vo_adv_9061156_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次都是多虧小雪菲",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n被魔物施放的石化魔法，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也成功解除了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "石化魔法！？",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那麼危險的狀況下……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我一直都是小嬰兒的狀態嗎！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚……",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "果然",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣下去不行呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n在關鍵時刻下變成那樣的話。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會拖累到大家的……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在大家努力奮戰的時候，",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n只有我沒辦法戰鬥……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真沒出息……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105812,
        "voice": "vo_adv_9061156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在說什麼呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛才的小雪菲",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也十分可靠的唷──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的。",
        "unit_id": 106012,
        "voice": "vo_adv_9061156_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嚇了一跳了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "平常只會一直哭的小嬰兒雪菲，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n竟然會為了我們戰鬥。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是啊！",
        "unit_id": 105812,
        "voice": "vo_adv_9061156_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說要保護我們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n勇敢面對魔物了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼，",
        "unit_id": 105913,
        "voice": "vo_adv_9061156_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然發生那種事情……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒辦法親眼見到雪菲小姐的成長，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是非常遺憾……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……",
        "unit_id": 105913,
        "voice": "vo_adv_9061156_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n變成小嬰兒的雪菲小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也成長為重視夥伴",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又溫柔的好孩子了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "與其說是成長……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個原本就只是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一時性的幼兒退化而已……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣啊。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n變成小嬰兒的我也能",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "像那個樣子……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n好好地",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "戰鬥了啊……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊。",
        "unit_id": 106012,
        "voice": "vo_adv_9061156_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不管在什麼時候，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都是獨當一面的【美食殿堂】的一分子。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不需要說那種話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來責備自己的唷。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留……",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和大家的羈絆，",
        "unit_id": 106412,
        "voice": "vo_adv_9061156_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一直都在支撐著我。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只要是為了大家就能加油。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許是因為這樣，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "才有辦法戰鬥的呢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿……",
        "unit_id": 105812,
        "voice": "vo_adv_9061156_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也一樣呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要跟大家在一起，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能發揮出超強的實力！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以大家今後，",
        "unit_id": 105812,
        "voice": "vo_adv_9061156_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也要一直在一起喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們5人在一起，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才是完整的【美食殿堂】！",
        "unit_id": 105812
    }
]