[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊啊啊――！",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_000"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――啊吼吼吼吼吼！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "終於打倒了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還好嗎，",
        "unit_id": 100311,
        "voice": "vo_adv_7005002_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯。",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "突然從背後",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n一下子出現了這麼強的魔物，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是嚇了一大跳。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果騎士先生沒有替我察覺到的話，",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就會很危險呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也想跟你道謝呢。",
        "unit_id": 100311,
        "voice": "vo_adv_7005002_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是謝謝你救了紡希。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有時候也有溫柔的一面呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以我就說他不是壞人了吧？",
        "unit_id": 100311,
        "voice": "vo_adv_7005002_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……可能是吧。",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n前陣子",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也說：『如果是我的話一定可以成為真正的偶像』，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如此誇讚我呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100311,
        "voice": "vo_adv_7005002_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希應該也",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n並不是真的討厭他。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他能夠接受真實的我。",
        "unit_id": 100311,
        "voice": "vo_adv_7005002_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希如果能跟他加深友情一定能……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你一個人打算要去哪裡呀！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我說過不要隨便去",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我看不到的地方吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不聽我說的話，",
        "unit_id": 105411,
        "voice": "vo_adv_7005002_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我真的會把你綁起來唷！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不……，",
        "unit_id": 100311,
        "voice": "vo_adv_7005002_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感情要變好，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看樣子還要花很多時間呢……",
        "unit_id": 100311
    }
]