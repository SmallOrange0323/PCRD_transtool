[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了感謝主人的照顧，",
        "unit_id": 105913,
        "voice": "vo_adv_4012004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下幫忙打掃。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼事不宜遲……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "掃啊掃，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擦啊擦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "唉──",
        "unit_id": 132512,
        "voice": "vo_adv_4012004_001"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "可可蘿真能幹。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "沒想到她居然只跟彩羽差了一歲。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是另一個世界的事嗎？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "唔……",
        "unit_id": 132412,
        "voice": "vo_adv_4012004_002"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "什麼嘛，小苑。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n比起彩羽，妳更喜歡可可蘿啊……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯、",
        "unit_id": 132512,
        "voice": "vo_adv_4012004_003"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "幹嘛生氣？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "難道是吃醋了～？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……才不是，",
        "unit_id": 132412,
        "voice": "vo_adv_4012004_004"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n小苑這個笨蛋……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "受不了，",
        "unit_id": 132512,
        "voice": "vo_adv_4012004_005"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我最喜歡的肯定是妳啊～",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n來，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我給妳摸摸頭，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "過來這邊～？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……嗯。",
        "unit_id": 132412,
        "voice": "vo_adv_4012004_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……",
        "unit_id": 105913,
        "voice": "vo_adv_4012004_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位感情真好。",
        "unit_id": 105913
    }
]