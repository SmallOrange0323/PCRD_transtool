    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並不是因為有{player}在才引起問題，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而是多虧了{player}",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才能順利解決喔！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是那樣想，",
        "unit_id": 127911,
        "voice": "vo_adv_5132000_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那{player}正是",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓聖誕節成功，",
        "unit_id": 127911
    },
