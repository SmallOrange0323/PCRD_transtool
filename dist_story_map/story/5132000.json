[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在距離聖誕節僅剩幾天的蘭德索爾，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n皇家主辦的聖誕節活動即將迎來最後的準備階段。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被任命籌措舉辦活動的克蕾琪塔，今天"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n預定和貪吃佩可一起視察城鎮。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊……！",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真美好，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "太美好了！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "由擁有極致商業頭腦的我",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為陛下所準備的聖誕節，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "正確實",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "朝著完成的方向前進！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是在今天的視察中能得到陛下的認可，就等同於必然獲勝了！",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n聖誕節當天她一定會流下感動的淚水的！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "必定會！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大力保證！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就是那樣！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下的感動是屬於我的了！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "伴隨最棒的一刻，陛下對我的評價當然也會暴漲，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而我肯定將成為陛下名符其實的最大忠臣！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "多麼完美的計畫！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不僅是活動的準備，",
        "unit_id": 6111,
        "voice": "vo_adv_5132000_003"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "竟然連這方面都打了如意算盤。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真不愧是克蕾琪塔小姐，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您真是商人的表率。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "現在就連妳的諷刺都讓我聽得很舒暢啊。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳就看著",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我達到更高境界的模樣吧！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "唉，",
        "unit_id": 6111,
        "voice": "vo_adv_5132000_005"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "以我個人來說，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要是有加薪，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n不管境界是高處還是地底，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我都無所謂就是了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喂！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳不要在這個時機點說什麼地底之類的不吉利言論啦──",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐，",
        "unit_id": 127911,
        "voice": "vo_adv_5132000_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓妳久等了！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我試穿了",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳為我準備的服裝……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如何？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊！",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您的模樣是多麼美麗……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並且還加上了氣質與高貴，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "簡直有如女神降臨啊！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "把超一流的材料、設計師和",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "裁縫師全都找齊是值得的。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下的美麗被以最棒的形式襯托出來了呢！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算說是這次活動最精彩的畫面都不為過！",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n蘭德索爾人民的心也都會被緊緊抓住的！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 127911,
        "voice": "vo_adv_5132000_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳誇過頭了啦。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說的克蕾琪塔小姐才是，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "禮服很漂亮呢☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "說的沒錯呢。",
        "unit_id": 6111,
        "voice": "vo_adv_5132000_012"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "以克蕾琪塔小姐這樣喜歡裝飾的人來說，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n這是一件有節制暴發戶興趣的",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "好服裝。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n明明不擅長減法，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真是相當努力了呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……真是的，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳就不能偶爾坦率地稱讚我嗎？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話說回來妳啊，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "至少在聖誕節盛裝打扮一下如何？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我會當作是員工制服幫妳支付治裝費喔。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不了，",
        "unit_id": 6111,
        "voice": "vo_adv_5132000_014"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "只要沒必要，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那種事我就心領了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "在有需要的情況下，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要是",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您也能另外支付追加津貼就好了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……妳不講情面的樣子",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "倒是很爽快呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 127911,
        "voice": "vo_adv_5132000_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我平常很少穿",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種優雅的禮服，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以很擔心合不合適啊。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……那真是多謝了。",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_017"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您怎麼了？",
        "unit_id": 6111,
        "voice": "vo_adv_5132000_018"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "露出那種極不痛快的表情。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n不是應該要坦率接受",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "難得的讚賞嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我並沒有年輕到會因為少年的讚美而心情劇烈起伏。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "比起那種事……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "少年，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你果然在呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "總覺得是意有所指的口吻呢。",
        "unit_id": 6111,
        "voice": "vo_adv_5132000_020"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "他不都總是",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "在陛下身邊嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是啊，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果是平時，那還算是能容許的範圍。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但是……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "現在這時候並不合適。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下也知道吧？",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "過去的聖誕節\n曾數度發生大規模騷動的事。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並且也知道過去所有的現場",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "全都有少年在的事。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
