        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒、",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒有……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只是陛下感謝的話語",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "讓我很感動而已。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_052"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下的話中沒有謊言，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "她感到十分高興。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但是，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我在雁過拔毛的商業圈生存至今，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n陛下可無法糊弄我的眼睛啊。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那……",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是沒有徹底滿意的表情呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "作為皇家主辦的聖誕節活動，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_054"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明明是連我都自豪完美無缺的程度了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一個真正意義上讓陛下滿意的聖誕節……",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_055"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要將誰都無法模仿的特別聖誕節獻給陛下，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "究竟需要什麼呢……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……欸……啊……"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦……？",
        "unit_id": 127911,
        "voice": "vo_adv_5132000_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們剛剛",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有沒有聽見什麼？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您、",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_057"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您快別說了啊！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是錯覺，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，是錯覺啦！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "來吧，陛下，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們繼續視察吧？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我還有很多想讓您看的地方，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "像是愛之廣場的裝飾之類──",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "別開玩笑了啊！",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_058"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n竟然在活動開始前就有麻煩！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "現在就讓我裝作沒看到不知道來忽視吧……！　",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呼欸",
        "unit_id": 1,
        "voice": "vo_adv_5132000_059"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊嗚……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 127911,
        "voice": "vo_adv_5132000_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個聲音……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是小嬰兒",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的哭聲呢。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是媽媽發生了什麼事嗎？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦？",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_061"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "小嬰兒……？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊真是的！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 127911,
        "voice": "vo_adv_5132000_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐！",
        "unit_id": 127911
    },
    {
        "type": "background",
        "background": "500893"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好像是從這一帶傳來的……",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_063"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "拜託是我聽錯了才好。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這時候發生麻煩什麼的，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "絕對、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "絕對……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊……嗯……啊……欸啊……",
        "unit_id": 1,
        "voice": "vo_adv_5132000_064"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_5132000_065"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是從那個方向傳來的！",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_066"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我知道。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要上囉。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n發現麻煩後就要立刻解決",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並回歸活動的視察。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呃。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚啊！",
        "unit_id": 50912,
        "voice": "vo_adv_5132000_067"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚啊！",
        "unit_id": 50912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚啊啊……！",
        "unit_id": 50912
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……啊啊，",
        "unit_id": 128011,
        "voice": "vo_adv_5132000_068"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真不敢相信。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼為什麼、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼在這種地方、這個時間點，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "會有小嬰兒被人置之不",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "理啊──！",
        "unit_id": 128011
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是這座城市沒錯嗎？",
        "unit_id": 1,
        "voice": "vo_adv_5132000_069"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "特務Q。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "沒錯喔，特務V。",
        "unit_id": 51011,
        "voice": "vo_adv_5132000_070"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "那傢伙就在這座城市。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "那我們就快點吧。",
        "unit_id": 51111,
        "voice": "vo_adv_5132000_071"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "要是落到別人手裡就麻煩了啊。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "嗯。",
        "unit_id": 51011,
        "voice": "vo_adv_5132000_072"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "因為這座城市的命運",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "就掌握在我們手中──",
        "unit_id": 51011
    }
]