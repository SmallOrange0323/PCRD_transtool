    {
        "type": "dialogue",
        "name": "花凜",
        "words": "感謝大家的蒞臨♪",
        "unit_id": 118511,
        "voice": "vo_adv_9004201_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如大家所知，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "現在蘭德索爾全城上下",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n正洋溢著慶祝4周年",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "的歡快氣氛！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們能這麼和樂融融地慶祝，",
        "unit_id": 118511,
        "voice": "vo_adv_9004201_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "都是多虧",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "平時接取公會管理協會委託",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n的大家。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "於是！",
        "unit_id": 118511,
        "voice": "vo_adv_9004201_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們寄送了特別的邀請函給",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所有為了蘭德索爾而盡心盡力",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "的公會成員們！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對於收到邀請函的各位，",
        "unit_id": 118511,
        "voice": "vo_adv_9004201_003"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們將發出更加危險的委託……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "只是說笑的而已。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們公會管理協會懷著",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "平素的感謝，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n準備了特別的活動！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 118511,
        "voice": "vo_adv_9004201_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "還存有疑慮嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "似乎不太相信呢。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請將那顆警戒心",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "發揮在今後的委託吧。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n今天請大家放下顧慮，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "輕鬆享受吧♪",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在接下來的猜謎中，",
        "unit_id": 118511,
        "voice": "vo_adv_9004201_005"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "出的題目都是",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "由公會管理協會準備的，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n請大家一面加深彼此情誼，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一面同心協力作答。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們準備了許多豪華獎品，",
        "unit_id": 118511,
        "voice": "vo_adv_9004201_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所以請努力答出正確答案♪",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 118511,
        "voice": "vo_adv_9004201_007"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "大家就一起",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "盛大地",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "享受4周年吧！",
        "unit_id": 118511
    }
]