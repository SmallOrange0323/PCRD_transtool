    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "初夢への願いか。",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_000"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "こ",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "こはもちろん、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "名探偵として",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "さらなる難事件を",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n解決することを願うとしよう。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "もちろん、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_001"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "助手くんも一緒だ。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n名探偵には優れた助手が必要だし……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "じ、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "事件解決を通して、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "絆も深まるかもしれないしね！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "それじゃあ、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_002"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "明日も早いし",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "休むとしよう。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "……すぅ",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "……すぅ……",
        "unit_id": 128511
    },
    {
        "type": "still",
        "still": "513406301"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "う……",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_003"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ん……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ああ、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_004"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "すまない助手くん。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "長丁場だったから、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "少し集中力が切れかけていたようだ。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "今回尾行している相手は、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_005"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "用心深いことで有名だからね。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "こちらに気付かれないよう、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "慎重に行動する必要がある。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "だから私たちは今、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_006"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "このように対象の斜め後ろから、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nカップルを装って",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "群衆に溶け込みつつ尾行しているわけだ。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "どうだい、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_007"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "これなら絶対にばれないだろう？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "こういった地道な調査こそが",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "探偵の腕の見せ所だ。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "推理をするにも、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_008"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "手がかりは多い方が……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "えっ？",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_009"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nし、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "しまった、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "会話に夢中で気付いてなかった……！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ええっと、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_010"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "こうなったら……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "わ、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "私を抱きしめてくれ助手くん！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nイチャついてる恋人みたいな感じでやり過ごそう！",
        "unit_id": 128511
    },
    {
        "type": "still",
        "still": "513406302"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "そ、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_011"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "そうだね！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nそうやって覆いかぶさるように",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n抱きしめてくれれば、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "お互いの顔も隠せるし……！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "だが、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_012"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ちょっと息苦しいかも……！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "いや、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "抱きしめ方が悪いわけじゃないんだが……！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "いろいろと、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "刺激が強いというか……！",
        "unit_id": 128511
    },
    {
        "type": "still",
        "still": "513406303"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ええっ、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_013"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "なぜもっと密着してくるんだい！？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nこれ以上過激なことをされたら、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "余計目立って……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n助手くん！？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ダメだ、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_014"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "人の往来だってあるんだぞ！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n破廉恥な行為は慎んで……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "あっ……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ああっ……！",
        "unit_id": 128511
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "はっ！",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_015"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "……は～……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "なんだ、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "夢だったのか……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "新年早々、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "息を切らせながら起きる羽目になるなんて。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "しかし、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_016"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "あの夢は",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "結局何を暗示していたんだろう？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "探偵として仕事はしていたし、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "助手くんとは……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "…………",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_017"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ま、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_018"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "まぁ、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "世の中解けない謎が一つくらいあってもいいだろう！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "流石に助手くんと、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "この謎に挑むわけにもいかないしね……",
        "unit_id": 128511
    }
]