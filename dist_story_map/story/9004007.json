[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接受花凜委託而繼續幫忙的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了大江戶町。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個，",
        "unit_id": 105111,
        "voice": "vo_adv_9004007_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有這個，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "以及那邊的中藥，有多少要多少。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n如果能幫我送到平常的那個地址，那就太好了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n萬事拜託了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_9004007_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是{player}呀。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "居然又在這裡相遇，我可嚇了一跳呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我是為了進中藥的貨而來的，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯……",
        "unit_id": 105111,
        "voice": "vo_adv_9004007_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為公會管理協會的委託……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你還真是老好人耶。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這也是你的優點。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍──！！",
        "unit_id": 103011,
        "voice": "vo_adv_9004007_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n請助我一臂之力！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是的……",
        "unit_id": 103011,
        "voice": "vo_adv_9004007_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "其實",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我和公會的大家一起",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來到這裡……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n但雪忽然就動彈不得了……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……為什麼",
        "unit_id": 105111,
        "voice": "vo_adv_9004007_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "用那種眼神看著我？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種善行",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "並不包含在我的專業領域裡……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "既然你都開口了，那就沒辦法了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "患者在哪？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就在這裡唷，",
        "unit_id": 1,
        "voice": "vo_adv_9004007_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "醫生♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n還有{player}。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……雖然我希望是我聽錯了，",
        "unit_id": 105111,
        "voice": "vo_adv_9004007_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但這聲音該不會是",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雪吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒錯唷♪",
        "unit_id": 100811,
        "voice": "vo_adv_9004007_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我映照在",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "水面上的身影",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "實在太過美麗了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "令人移不開雙眼，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以我就被困在這裡了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "醫生",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果願意當我的主治醫生的話，我覺得",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就會痊癒了♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉……",
        "unit_id": 105111,
        "voice": "vo_adv_9004007_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我已經拒絕那件事了，對吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n假如讓我一直講同樣的事，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就安排雪來實驗新藥哦？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不喜歡那樣的話，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就不要再為難那孩子了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是的──",
        "unit_id": 100811,
        "voice": "vo_adv_9004007_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "醫生好強硬喔。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過沒關係。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我沒有要放棄，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只是決定今天先就此打住而已。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "反正也充分感受過",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美麗了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那就再見啦♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦哦──！",
        "unit_id": 103011,
        "voice": "vo_adv_9004007_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雪又活動自如了──！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不愧是將軍，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "醫生也很厲害呢！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的。",
        "unit_id": 105111,
        "voice": "vo_adv_9004007_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我可是很頭痛的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "差不多該回去了……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥～♪",
        "unit_id": 100611,
        "voice": "vo_adv_9004007_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等等，",
        "unit_id": 102211,
        "voice": "vo_adv_9004007_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還是算了吧……！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n就說很難為情了呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那個，哥哥♪",
        "unit_id": 100611,
        "voice": "vo_adv_9004007_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n能在這裡遇見哥哥，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里好高興哦～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "話說，我們",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有點困擾……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實",
        "unit_id": 100611,
        "voice": "vo_adv_9004007_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們去泡了聽說對養顏美容很有幫助的溫泉，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們原本就很可愛了，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "結果又變得更可愛了♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好困擾哦～♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真的嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_9004007_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太好了～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n呵呵，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請一直看著接下來",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n會變得更可愛的茜里哦，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "～～～～！！",
        "unit_id": 102211,
        "voice": "vo_adv_9004007_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n啊啊，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "忍不下去了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你也制止一下茜里嘛──！！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……唉。",
        "unit_id": 105111,
        "voice": "vo_adv_9004007_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的，你認識的人",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n都是些能與【暮光流星群】並駕齊驅的有趣孩子呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "深月辛苦地應付個性強烈的患者們，\n而{player}將那身姿記在腦中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並收下活動紀錄，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "前往了下一個目的地。"
    }
]