[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鎮上跟村裡的各位，",
        "unit_id": 103811,
        "voice": "vo_adv_6040406_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咲戀育幼院的孩子們\n捐贈的金錢，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的讓人非常、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "非常地感激呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "得好好回應",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家的心意才行呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒錯呢。",
        "unit_id": 103811,
        "voice": "vo_adv_6040406_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我希望能讓來泡溫泉的人們，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也看看真正的【伊麗莎白牧場】呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看看我們那既熱鬧又溫暖，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一如往常的容身之處。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "多虧了她到各種城鎮和村莊去兜售時，",
        "unit_id": 103811,
        "voice": "vo_adv_6040406_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "和非常多的人\n交流過呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不只如此，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也因為真陽\n她為人很溫暖的緣故。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "別人可沒辦法模仿呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "報恩……",
        "unit_id": 103811,
        "voice": "vo_adv_6040406_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "應該要做什麼才能回報呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n大家會開心的事情……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這個嘛，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "既然這樣的話，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我就來想想要怎麼樣能讓",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家在泡溫泉時",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "能更加舒服的方法吧。",
        "unit_id": 103811
    }
]