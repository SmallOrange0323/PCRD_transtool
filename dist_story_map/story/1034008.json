[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}抱著醉倒的優花梨，\n正前往公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸嘿嘿～。\n對不起呢～。",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n還讓你送姐姐回去～。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "迷有關～係啦～。\n就算我喝太多，你也會像這樣守護我嘛……",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……吶，",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}。\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我阿……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦？ ",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好刺眼！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n是太陽出現了什麼異狀嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呀啊啊啊！",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_004"
    },
    {
        "type": "still",
        "still": "103400801"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呀！？\n啊――……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝、謝謝――。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨邊這麼說，\n邊將手中大量的罐子藏在身後。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊嗚，你果然還是注意到了呢……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我想至少在休假時，",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n要邊喝酒邊看動畫――的……",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，從大白天就開始喝酒的女性……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n很掃興吧？",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……謝、謝謝……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你偶爾也會不經意地這樣說呢……",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？ 啊，是公司的上司打來的電話。",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，明天會議上要用的資料？",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n啊、啊――，資料，資料呢。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n完成了，完成了。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，你明天一早想看，",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以請我先準備好……？",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我、我知道了――。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "怎、怎麼辦。",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我完全忘了要做資料……",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今、今晚不想想辦法的話……！",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n嗚嗚",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "，但是在家做是不行的啊――！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為誘惑太多，沒有辦法集中精神工作啊――！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是的，到底該怎麼辦……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對、對了！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "接下來讓我去你家！",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_015"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510092"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚――，不行不行。\n這樣會做不完啊～！",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚嗚，謝謝……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n跑來你家真是對不起呢。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為在我房間的話，絕對無法集中精神……",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝……肚子餓了呢。\n",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……嚼嚼……好好粗。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯……好舒服……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你真溫柔呢。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……好！\n我再稍微努力一下！",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝你！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "發送郵件……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼哇，結束了～！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝你的幫忙喔！\n那麼，我們來乾杯慶祝吧！ 你要用果汁喔！",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_022"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "數小時後――"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呀，你真素變得可靠惹呢～。",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n明明這麼年輕，好厲害！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦――，偶沒有喝太多喔――。",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n完全迷有問題ㄧ～。比起這個～。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "泥有女捧友嗎～？",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒有的話～，你喜歡的類型是～？",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n素哪種女孩啦～。喂喂～。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我該睡了……？\n",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……我才不睡呢。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喂……你覺得成熟的姐接……怎摸樣……？",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "泥不想登上成人的階梯嗎……？",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你所不知道的成人階梯……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n那就是……",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "？",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……啪。\n…………呼嚕――。呼嚕――。",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯呀……",
        "unit_id": 103431,
        "voice": "vo_adv_1034008_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n偶對你……",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}邊微笑地看著精疲力盡的優花梨，\n邊替她蓋上棉被……"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好――的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1034008_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "毫無例外的，\n當你醒來以後會幾乎忘了夢的事情。",
        "unit_id": 190011,
        "voice": "vo_adv_1034008_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但若是這次的內容，至少會留下幸福感也說不定呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即使你不願意，醒來後仍忘記夢的內容也一樣喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1034008_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明明在同一屋簷下徹夜未眠，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真是不解風情的兩人呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，無所謂……\n希望有一天你們兩人會得到回報。",
        "unit_id": 190011,
        "voice": "vo_adv_1034008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也無非是這樣祈求的，嗯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼這次就先聊到這裡，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1034008_036"
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦？ 這裡是公會小屋……？",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_037"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊……早安。",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_038"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n剛剛的是……夢？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……我們又做了一樣的夢嗎……？",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_039"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n等等",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "，雖然不太記得，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但我在夢裡是不是說了奇怪的話！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喂，喂！？",
        "unit_id": 103411,
        "voice": "vo_adv_1034008_040"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你為什麼看起來這麼開心！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也告訴我啊～！",
        "unit_id": 103411
    }
]