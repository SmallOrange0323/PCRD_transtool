[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被牠逃到河裡了呢。",
        "unit_id": 105911,
        "voice": "vo_adv_9028156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過看來",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次的傳聞目標，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎也是和龍大相逕庭的生物。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 105811,
        "voice": "vo_adv_9028156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺比之前的傳聞還要更準確了呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就這樣繼續調查下去的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總有一天一定……♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這哪是什麼龍啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9028156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說到底那種生物",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能被到處目擊到啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確，",
        "unit_id": 105911,
        "voice": "vo_adv_9028156_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至今為止的目擊資訊",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也都十分模糊。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟這座島",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "四處都是一些尚未明朗的事物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為這些未知的恐懼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才助長了謠言吧……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正是如此我們才會肩負這份工作，",
        "unit_id": 105811,
        "voice": "vo_adv_9028156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n進行島上的調查☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們盡早消除掉",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家內心的不安吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可，",
        "unit_id": 106011,
        "voice": "vo_adv_9028156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還以為妳的腦子裡除了吃以外什麼都沒在想……",
        "unit_id": 106011,
        "voice": "vo_adv_9028156_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "況且，",
        "unit_id": 105811,
        "voice": "vo_adv_9028156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "實地探勘也就是通往美食之路！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們發現的美食，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有朝一日一定會被端上全世界的餐桌！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了那一天，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "首先以品嘗龍肉的滋味為目標吧♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……那一瞬間對妳另眼相看的我",
        "unit_id": 106011,
        "voice": "vo_adv_9028156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是笨蛋呢。",
        "unit_id": 106011
    }
]