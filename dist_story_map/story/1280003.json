[
    {
        "type": "background",
        "background": "501461"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蕾琪塔和{player}憑著氣勢與毅力吃完了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n滾雪球風格的聖誕節限定甜點套餐（相當十人份的量）。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "離開店家的兩人在夕陽下的街道上慢慢散步……"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我、",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們最終還是努力全部吃完了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然覺得衣服腰圍好像要被撐破了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但不管是撐破或是吐出來，\n我都盡力忍住了，不然實在太浪費……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嘔。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "看來我好一陣子",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不會想再吃任何的甜食了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們已經預訂了聖誕節活動用的蛋糕，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且還是能滿足陛下的極致品質和份量……！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感覺先",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "抱持著這是預支過年變胖的額度會比較好……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明年的我應該會想辦法解決吧！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一定可以的！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "絕對要成功！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嘔。",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嘔。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n差點就讓雪球變成雪崩了……！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n現況看來不該發出太大的聲音啊。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "現在就先",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做點什麼讓肚子消化一下比較好……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你的臉色看起來也不算太好，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們等彼此的胃都比較舒暢之後再解散吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好啊，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好啊。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這提議感覺蠻不錯的。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但是！",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我話先說在前面！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不許櫥窗購物喔？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然講得很好聽，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但不掏錢出來就是只逛不買罷了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "用購物兩字騙人簡直不可原諒！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可笑得讓人腹痛！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "基於以上原因，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我們應該是為了要買某個東西而四處逛逛！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有購買意願的話，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就不會只是想看看，而是會認真挑選！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這才是正確的避開風險！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一大聲說話，胃又……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "！這不是因為",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可笑……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好了好了，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖說要逛逛，但要怎麼辦呢？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我基本所需的東西全部都有了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "希望能找到些靈感。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還真是因應聖誕節的單純發想呢。",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼我想想……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要送陛下什麼禮物……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是說……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那些我早就已經準備好了啊。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要給那些貴族的禮物也準備好了……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然全部都是用經費買的。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再來是要給【王宮騎士團】和侍奉於王宮的相關人士的",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n獎金也都安排好了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "意外收入也算是禮物的一種吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "送禮物給秘書一號？",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可是也有給她獎金喔！",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且她今天工作也有加班費可以領。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且重點是，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我跟她",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只是雇主與秘書的關係而已，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "除此之外什麼都不是。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也就是說，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我跟她不是會送禮物的那種親密關係。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算週末",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我會請她喝一杯，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那也只是",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我跟她約定好她不能省略敬稱的條件──",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話說回來……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n上週末我跟秘書一號沒有一起去喝酒呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "實在是因為工作累積太多了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你你你──在說什麼啊～？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "別擔心，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們是默契十足的夥伴！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可以說是心有靈犀，溝通無礙！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總之，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們是稍微粗心犯錯也可以一笑置之的那種關係啦！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……話說回來，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我平常就",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "很受她照顧也是事實吧～？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我絕對不是",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為了想把沒有遵守約定的事一筆勾銷\n而送她禮物……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "絕對不是因為那樣的原因！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但是！！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "藉這個機會！",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n將我感謝的心情化為實物應該蠻不錯的吧！！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蕾琪塔開始尋找"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n能討好秘書一號的禮物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是……"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "玩偶……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "太過可愛了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不考慮。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "墜飾……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可能會被追究有何含意，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "駁回。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "蝴蝶結髮帶……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好像有點太幼稚了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不好。",
        "unit_id": 128011
    },
    {
        "type": "background",
        "background": "501462"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "在煩惱的同時，一轉眼天色都黑了呢……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這一切都是秘書一號害的！",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n因為她都不太跟我聊興趣愛好之類的話題！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是獎金。",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然她總是面無表情，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一本正經的樣子，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但她可是我的秘書，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然會很愛錢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還有就是……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n準時下班和",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "特休假，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "別人請喝的麥酒跟章魚芥末，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大概就是這些了吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然如此，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要送有特別包裝的瓶裝麥酒禮盒組嗎……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還是乾脆",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "送現金應該也不錯。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "把錢藏在點心禮盒裡……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我以前常常會這樣做呢，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真懷念。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "先把這件事放一邊。",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_034"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總之，得要買點東西才行，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不然就要變成只看不買的人了！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯？",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "少年……！",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_036"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那樣可不行。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n會造成收禮方困擾的話就不能叫送禮了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那只是硬塞我單方面的善意罷了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但我還是很感謝你提供的建議，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只是我想要",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "更實際的──",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}順著克蕾琪塔的視線看過去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n發現那裡有間文具店。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……送筆記本，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_039"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "應該可以吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我和她都很喜歡用筆記本，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n而且我也知道她愛用的是哪牌的產品，也有實際看到。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只是……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_041"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這會不會，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有點太實用了？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一點都沒有禮物貴重華麗的感覺……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有真心誠意的話，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_042"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你是想這麼說吧？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也是，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我也沒有熱情到那個地步……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但我覺得……",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_043"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n她收到這個應該",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不會感到困擾。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再說再說，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_044"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算是聖誕節，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也不一定要送很特別的東西吧！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "送筆記本？",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_045"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那不是很好嘛！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不如說送這個剛剛好，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也符合預算！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然這麼決定的話，",
        "unit_id": 128011,
        "voice": "vo_adv_1280003_046"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那就快點買一買吧！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "店員～",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以麻煩你一下嗎～？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蕾琪塔順利地買到了禮物。"
    },
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著來到了隔天……"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好，",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_047"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大功告成了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……呃，",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感覺之前好像也曾講過",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "類似的話。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_049"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "早安。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_050"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號早安。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳昨天加班辛苦了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一切都是為了加班費。",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_051"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐妳……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n看起來有充分休息到呢，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真是太好了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳可以別在我回答之前就先用我的臉色來判斷嗎？",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_052"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "應該說，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳能藉此判斷正確這件事也讓人火大。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號，",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我已經全部看過包含各種報告書在內，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n製作資料和要確認的物品了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再麻煩妳做後續處理。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我明白了──",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_054"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "咦？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_055"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……克蕾琪塔小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_056"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n這些文件中夾帶的包裹是什麼？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊，",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_057"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那是所謂的禮物，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過不是什麼了不起的東西喔？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐？",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_058"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "送我禮物？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀哎呀哎呀，",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_059"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我沒有什麼特別的意圖喔？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n況且",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這也不是什麼高單價的東西嘛？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "…………",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_060"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這算是補償嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n因為我們上週末",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "沒辦法去喝酒。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚唔……！",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_061"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳這個人，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還是一樣精明過人……！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是克蕾琪塔小姐的表情完全出賣了妳喔。",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_062"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那我就先確認一下包裹裡面是什麼。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_063"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "原來是筆記本。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這個大小很剛好，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我就心懷感激地收下這份好意了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這樣啊……",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_064"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那就好。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳以後就不要隨身帶著那本告密便條本，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n用妳手上那本當作工作上的愛用筆記本吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "可是，",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_065"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n這兩件事是",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "兩碼子事。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n「每週末請我喝一杯」的約定是",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一定要遵守的喔。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔唔唔……！",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_066"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳給我多顧慮一點人情啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不過……",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_067"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "看在這份禮物的份上，",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_068"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n到這個週末為止，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我會先暫緩省略敬稱的行為。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我很期待您",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_069"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "連同上週份一起的請客喔。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n克蕾琪塔……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳剛才就馬上打算省略敬稱了吧！？",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_070"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是敗給妳了……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那我就先去工作了喔。",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_071"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n好了好了，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "工作工作。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等，",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_072"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳別逃避話題啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_073"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感覺她是沒有感到困擾……",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_074"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n至少她看起來沒有產生負面情緒……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊好煩心，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果這是賄賂，對方的反應就很好理解了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總覺得冷靜不下來……",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_075"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n會送聖誕禮物的人們，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n每年都會經歷這樣的感覺嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是太令人震驚了……！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………不過。",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_076"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過……",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_077"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n好像也不是那麼……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "討人厭的感覺、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_1280003_078"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您怎麼了？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n從剛剛開始您的手就停下來了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什、",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_079"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼事情都沒有！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好了好了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "今天也要俐落地工作！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "畢竟聖誕節快到了！",
        "unit_id": 118011,
        "voice": "vo_adv_1280003_080"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "事前要準備的工作還有很多！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "聖誕夜是不等人的──！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和開心聖誕節以及禮物都無緣的克蕾琪塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和往年不同的聖誕節氣氛，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n讓她自己也有點坐立難安……"
    }
]