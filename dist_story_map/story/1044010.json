    {
        "type": "dialogue",
        "name": "旁白",
        "words": "傳說的吸血鬼取回她全盛時期力量的隔天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾面臨她征服世界的野心，迎來了極致的混亂──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "並沒有那回事。"
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如何？",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你有帶那個東西過來嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這刺鼻的臭味！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n的確是那可恨的大蒜料理！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是……",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身必須要試試……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n吃了這道大蒜料理之後，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是不是還能保持現在的力量……！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵……",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你以為妾身是誰！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是傳說的吸血鬼……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "伊莉亞‧奧恩斯坦喔！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "大蒜什麼的",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "根本不足為懼！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "儘管來吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔，",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不，等等。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對這種東西是需要心理準備的……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等等！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這可不是鬧著玩的！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不是鬧著玩的啊",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊啊──！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呣咕！",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔嗚嗚嗚嗚嗚……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔、",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔唔！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕嘟……",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如、",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如何！？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦……",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼事也沒有！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒有變小……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "克服了大蒜喔！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n哈～哈哈哈哈──！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在此！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "宣布傳說的吸血鬼",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "完全復活！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然如此，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有一件必須要做的事……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是征服世界！",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你怎麼露出",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那種表情？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你好像有什麼話想問妾身？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔？",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你想知道具體的願景啊。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n首先，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是宣布統御黑夜之人的復活，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n讓人民向妾身跪拜！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那之後嗎？",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也對呢，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那之後是……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "偷瞧。",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這傢伙",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是喜歡妾身的……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對吧？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也就是說，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "他想問的並不是政務，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而是和妾身之間的事吧。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "征服世界後的妾身會變得很忙，",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以他是擔心會被置之不理吧……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n真是的，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還真愛撒嬌啊。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且，",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這傢伙也是男人，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n應該也會堅持",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要由他主動表達心意。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如此一來，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "先為他做好準備，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也是身為統治者的氣度啊……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也不是不明白他會在意身分的差距……",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n既然這樣，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要想讓這傢伙如願以償，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那在距離征服世界還有餘裕的現在，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就不能浪費這段時間……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為此首先，",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要有浪漫的情境！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "像這傢伙這種有點遲鈍的類型，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n用氣氛來影響他是很重要的吧。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "話雖如此，",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這裡可是在公會的眾目睽睽之下，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也就是說，需要的是……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "新的城堡",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吧。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不是在這裡，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而是要準備新的據點喔！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "首先要",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "進行事前調查啊……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "去吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬們啊！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n去尋找適合咱們的城堡吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "使魔們",
        "words": "嘰──！",
