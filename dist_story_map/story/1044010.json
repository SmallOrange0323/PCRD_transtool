    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過了幾天後……"
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "終於找到了喔！",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n非這裡莫屬的城堡！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以，",
        "unit_id": 104411,
        "voice": "vo_adv_1044010_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要去看看城堡內部了喔！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "眷屬們啊！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "出發！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
