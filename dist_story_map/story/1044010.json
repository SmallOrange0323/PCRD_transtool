    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對【惡魔偽王國軍】的大家的親愛之情，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n還有對這傢伙的特別感情……",
