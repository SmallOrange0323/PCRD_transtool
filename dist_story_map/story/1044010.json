        "voice": "vo_adv_1044010_055"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是所謂的",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "打擊嗎？",
