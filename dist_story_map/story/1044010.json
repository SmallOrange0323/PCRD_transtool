        "voice": "vo_adv_1044010_054"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這傢伙所說的，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是親愛之情的喜歡……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n跟妾身的喜歡並不一樣",
