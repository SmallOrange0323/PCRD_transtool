[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拉比林斯達正在一邊進行塔的解析，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊與班比、{player}一起往上層前進。"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不過，",
        "unit_id": 122311,
        "voice": "vo_adv_7028002_000"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "塔裡居然會有星星真是奇怪！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從你也這麼想吧？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年的話應該記得吧？",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n索爾之塔的塔頂",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也是這樣的氛圍。",
        "unit_id": 106815
    },
    {
        "type": "background",
        "background": "501650"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就「露娜之塔」這個名稱來看，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n它的原型也應該是索爾之塔沒有錯。",
        "unit_id": 106815
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "跟「索爾」──「太陽」相對的「露娜」──「月亮」是嗎……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是取了個意味深長的名字呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這座塔在被「再構築」之前，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "本來連個影子都沒有。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這裡恐怕，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該說肯定是",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在那件事發生後才被建造出的塔吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但究竟",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是誰為了什麼而建的……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這點還是完全不明啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然是能建造這麼大規模建築物的人，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n應該可以鎖定出一定程度的人數來推測是誰。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是那樣的話我就不會特地來調查了呀～",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……不，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "說不定我只是失去了記憶，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實真的是我！？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "拉比林斯達，",
        "unit_id": 122311,
        "voice": "vo_adv_7028002_008"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "妳可以蓋出這麼大的建築物嗎？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好厲害喔～！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒有沒有，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我開玩笑的啦！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我才不會做這種事呢！？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然我也不是辦不到類似的事，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "即使如此，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所需消耗的勞力，\n也不是沒有目的卻能隨便付出的呀。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真那嗎？",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唉呀～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這我也不肯定啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟整頓了蘭德索爾街道中基礎建設的人也是真那，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那傢伙還挺以效率至上的呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「哎呀，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這裡用來眺望愚民剛剛好呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n把王座搬到塔頂上吧，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我從今天開始要住這裡」。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你覺得他會說這種話嗎？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對我有可能會說？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……也是。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然這只是我的直覺……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但我有種這座塔是為了少年你而設計的感覺。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我不認為真那會特地做這種事。",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "果然應該不太可能會是真那建造的吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哈哈♪",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那樣也是挺有趣的呢！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就這種可能性來思考的話……",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會是有身懷超強技術的某人從天空另一端飛過來，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n為了打發時間而建了這座塔嗎？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最後被留下的就是這座露娜之塔……",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n「殘留於阿斯特賴亞大陸的神祕建築物！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n調查隊為了探究謎團踏入其中……！」",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……不，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉啦！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我只是開玩笑說說看而已！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不要用那麼冷淡的眼神看我嘛～！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只不過",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這裡有魔物出沒……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有魔物被「設置」在這裡，這點很令人在意。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你也知道，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n進入塔內需要發動傳送魔法。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要正常進出是不可能的。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……那麼，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "魔物究竟是從哪來的呢？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總不可能會無中生有突然長出來，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n既然如此，想成是有人設置的，應該比較自然吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且隨著上層逐漸被解放，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就會被換成更強的敵人，這樣的等級設計……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "設計都是有理由與用意的。",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這座塔",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會與少年的記憶有所關連的原因又是什麼？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n是誰",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了什麼目的……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……嗯～",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不行啊～！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要立下假說，線索還太少了！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然感覺得出塔的設計帶有某種用意……",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但現階段，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要達成解讀還有困難啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟假說和隨便亂猜的想像是不同的。",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就算想推論，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "光憑現有的情報還不夠吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "建造這座塔的目的……",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果沒搞清楚設計者的意圖就輕易出手干預，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n反而造成事情更麻煩，那也很令人傷腦筋。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果這裡真的只是沒用處的贅物，",
        "unit_id": 106815,
        "voice": "vo_adv_7028002_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那我就可以用權能隨意處置了。",
        "unit_id": 106815
    },
    {
