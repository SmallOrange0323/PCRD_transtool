[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}打算陪空花練習跳舞，\n而來到她工作的地方……"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "…………",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸？",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n啊、虐待狂先生……怎麼了嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "練習跳舞……？",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊，剛剛你有叫空花的名字對吧？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不好意思，稍微發呆了一下……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "空花，今天輪到妳打掃更衣室對吧。",
        "unit_id": 411,
        "voice": "vo_adv_1045006_003"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n趕快去掃喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "…………",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_004"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "空花！",
        "unit_id": 411,
        "voice": "vo_adv_1045006_005"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n妳聽到了嗎！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n打掃了喔，打掃！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸……",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對、對不起！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n馬上就去！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "啊啊……",
        "unit_id": 411,
        "voice": "vo_adv_1045006_007"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "這孩子到底怎麼了？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n最近一直都在發呆呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n又常常說覺得胸口附近悶悶的……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "喂，你知不知道為什麼？",
        "unit_id": 411,
        "voice": "vo_adv_1045006_008"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "嗯，嗯……",
        "unit_id": 411,
        "voice": "vo_adv_1045006_009"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n雖然是這樣沒錯……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "這樣的話，反倒還好呢……",
        "unit_id": 411,
        "voice": "vo_adv_1045006_010"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "特別是最近的樣子很奇怪喔。",
        "unit_id": 411,
        "voice": "vo_adv_1045006_011"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n不會是遭遇了什麼奇怪的事吧？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "你……",
        "unit_id": 411,
        "voice": "vo_adv_1045006_012"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n知道最近【哞哞自衛隊】和【王宮騎士團】，\n在管制一種特別的草嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "如果使用那種草，就會看見幻覺，",
        "unit_id": 411,
        "voice": "vo_adv_1045006_013"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n而且會感覺異常興奮喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "但是身心也會被搞壞……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "然後，空花她啊……",
        "unit_id": 411,
        "voice": "vo_adv_1045006_014"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n最近在夜深人靜大家都睡著的時候，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n被看到她外出的樣子喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "該不會是從賣家那邊，",
        "unit_id": 411,
        "voice": "vo_adv_1045006_015"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n一直在購買那種草吧？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "……你覺得我想太多嗎？",
        "unit_id": 411,
        "voice": "vo_adv_1045006_016"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "但是那種草的副作用，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n就是發呆、胸口悶的症狀喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "你看，這不就符合空花現在的情形嗎？",
        "unit_id": 411,
        "voice": "vo_adv_1045006_017"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "我很擔心那孩子啊。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n你可以幫我調查一下那孩子到底在幹嘛嗎？",
        "unit_id": 411
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……太好了，",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "沒有人。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n趁現在……",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這裡也……沒有人呢。",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那、那麼馬上！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊！已經受不了了！",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "今天忍了一整天，一直想要這個！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花沒有這個就活不下去了！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請趕快",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "讓空花變得舒服吧！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀、",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_022"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊啊啊！！虐待狂先生！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生為什麼會在這裡！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "什、什什、什麼都沒有！",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這裡什麼都沒有喔！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花沒有藏什麼東西──",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊，",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_024"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不可以看啦！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "被、被發現了……",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_025"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花一直在看色情書刊……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不、不是！不是的！",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這麼多的色情書刊，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "都不是空花的東西！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好像是別人丟在這裡的……",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "都是些一般商店買不到的，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n亂七八糟不三不四的書……空花無意中發現。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……因、",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "因為被虐待狂先生鍛鍊過的關係，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n一般等級已經無法滿足空花了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在店裡買到的東西，空花也覺得不過癮……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就在這裡發現了",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_029"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花的世外桃源！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n所以當然要每天晚上跑來這裡呀？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "等、",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_030"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "等一下啊！！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "居然要把這麼棒的書燒掉！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不不不要啦！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_031"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n撕破的話，空花就沒辦法好好看了！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花不能沒有這些書……",
        "unit_id": 104511,
        "voice": "vo_adv_1045006_032"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要空花做什麼都可以，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請放過它們吧！！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}掙脫了空花的阻止，\n把所有的書都處理掉了。"
    }
]