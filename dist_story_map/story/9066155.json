[
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嗯，",
        "unit_id": 126013,
        "voice": "vo_adv_9066155_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "野營跟",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "小飯糰的飯都準備好了♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "接下來我們",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就在【美食殿堂】的大家回來之前",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "看好行李吧。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "話雖這麼說。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "嗯……",
        "unit_id": 125813,
        "voice": "vo_adv_9066155_001"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "莉莉。",
        "unit_id": 126113,
        "voice": "vo_adv_9066155_002"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n在想事情。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "哥的事。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊……",
        "unit_id": 125813,
        "voice": "vo_adv_9066155_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "妳、",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "妳怎麼知道的？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵。",
        "unit_id": 126013,
        "voice": "vo_adv_9066155_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n因為莉莉",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "今天也是一樣，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n一直盯著哥哥看啊♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那、",
        "unit_id": 125813,
        "voice": "vo_adv_9066155_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那種事……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然確實如此……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但我是……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在想如果要成為像兄長大人他們一樣的一流冒險者，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n該做些什麼。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "只是在重新思考這件事而已。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是這樣嗎？",
        "unit_id": 126013,
        "voice": "vo_adv_9066155_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也跟我們談談吧♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n畢竟集思廣益總是比較好嘛，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對吧？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "要，",
        "unit_id": 126113,
        "voice": "vo_adv_9066155_007"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n怎麼做？",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嗯……",
        "unit_id": 126013,
        "voice": "vo_adv_9066155_008"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "經驗不足當然也是原因……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們轉換觀點來看好了。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n例如",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不是看我們【幻變少女】，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n而是聚焦在【美食殿堂】的「特徵」如何？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人他們的",
        "unit_id": 125813,
        "voice": "vo_adv_9066155_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "特徵……？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "例如說",
        "unit_id": 126013,
        "voice": "vo_adv_9066155_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥的「寬宏大量」之類的。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那應該是",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對公會的氣氛造成巨大影響的原因……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對吧？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n像這樣子把要素列出來，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "搞不好就能發現什麼事。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來如此……",
        "unit_id": 125813,
        "voice": "vo_adv_9066155_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "說起來，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "跟我們比起來，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n【美食殿堂】的各位好像有更多的",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「積極互動」。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那就是",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "他們能夠「泰然自若」的原因嗎？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "「熱鬧」。",
        "unit_id": 126113,
        "voice": "vo_adv_9066155_012"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n「搞笑」。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「包容一切的母性」。",
        "unit_id": 125813,
        "voice": "vo_adv_9066155_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n「蘭德索爾第一的權力」。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n然後是，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呃……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「會突然失控」……？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "「貓」。",
        "unit_id": 126113,
        "voice": "vo_adv_9066155_014"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n「傲嬌」。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呃，",
        "unit_id": 126013,
        "voice": "vo_adv_9066155_015"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "雖然我覺得妳說的沒錯……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但要是被凱留小姐聽到的話，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "她應該會生氣吧。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n話說回來，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "感覺內容好像越來越偏了……？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "兔子。",
        "unit_id": 126113,
        "voice": "vo_adv_9066155_016"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "兔子……",
        "unit_id": 126013,
        "voice": "vo_adv_9066155_017"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "有嗎？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n【美食殿堂】有代表兔子的人嗎？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "魔物。",
        "unit_id": 126113,
        "voice": "vo_adv_9066155_018"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n兔子的。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "咦……？",
        "unit_id": 1,
        "voice": "vo_adv_9066155_019"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "……………………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "………………吞口水。",
        "unit_id": 1,
        "voice": "vo_adv_9066155_020"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──吼喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "呀啊啊啊啊啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_9066155_021"
    }
]