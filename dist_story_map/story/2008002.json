[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n早安，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "發生什麼事了嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您怎麼突然彈起身呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "夢到什麼可怕的事情了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下並沒有聽到些什麼……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難不成是睡糊塗了嗎？主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是一位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓人放不下心的主人……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比起這件事。",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n呃～",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳咳。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "200800201"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【拉比林斯】的兩位，",
        "unit_id": 105911,
        "voice": "vo_adv_2008002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人看起來睡得有些不自在……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位如果可以，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "趕緊從床上下來可就幫了大忙了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可能不行唷～！",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n畢竟是許久不見的",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}嘛！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}{player}，",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n真的好想你呀～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想見{player}你卻見不到，",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n想摸也摸不到，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "害得姐姐的心都快要碎滿地了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是！",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": " 在渡過了千千萬萬的困難後！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n現在，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}和姐姐終於能夠在一起了呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這就是Happy ending吧，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿嘿嘿嘿嘿……♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "別再說什麼腦袋有毛病的話了，",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n說真的趕快從棉被裡面出來啦。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n吼呦真是的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還真是不能夠釣魚親親呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是『掉以輕心』",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唷，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……而且。",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n實際上{player}哥哥的記憶，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也幾乎沒有回想起來的跡象。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這麼沒有防備的和他接觸的話，還不知道會發生什麼事喔。",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "弄個不小心，腦袋瓜會變成石頭也說不定。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也一樣啊！",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "明明也很想蹭蹭又磨磨哥哥的呀，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但還是像這樣拚了老命的忍耐住了……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "給人家自重一點啊，姐姐。",
        "unit_id": 101112
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯啊～",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不要這麼殘忍的把{player}和我分開嘛！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n壞壞～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐和{player}，",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是注定一輩子都要在一起的喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們有著任誰也斬不斷的深厚血緣羈絆唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "明明就完全沒有血緣關係吧，",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐妳和我都一樣……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會長也還在休眠狀態中，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真發生什麼事情可沒辦法應付呀。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "講真的不好再這樣鬧下去了啦。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚嗚。",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n可是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "人家寂寞難耐嘛。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "當{player}和其他的女人在那邊演青春戀愛喜劇時，",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我可是被埋在那無趣的事務工作底下忙到壓力超大、喘不過氣欸。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要這麼說我還不是也一樣。",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "再怎麼說，我們【拉比林斯】",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也算是個祕密社團嘛。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該說是只能在檯面下做些無趣的工作？",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n必須得在暗巷小弄間躲躲藏藏來行動也是沒辦法避免的嘛？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是嘛總而言之，",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "大家都沒出什麼事就好。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這個據點嘛應該還算挺安全的才對，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這方面就請放心吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好了啦姐姐，",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n差不多其他人也該是要起床的時間了……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們一起去準備大家的早飯吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚嗚，",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這次就算了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "反正從今天開始就是那臉紅心跳同居生活了嘛！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還有的是機會，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我可會攻到你招架不住的唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "做好覺悟吧，{player}！",
        "unit_id": 104911,
        "voice": "vo_adv_2008002_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n馬上就會讓你了解，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能有個姐姐是多麼難能可貴的！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n若說人一輩子中有什麼不可或缺的要素，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就一定是姐姐了……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好啦好啦。",
        "unit_id": 101112,
        "voice": "vo_adv_2008002_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "傻話就說到這趕快走了啦。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼先這樣，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不好意思打擾囉～♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然有點不太懂，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但還真是靜不下來的兩位呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【拉比林斯】的人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該說是給人的第一印象不好嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在不久前還曾突襲過在下等人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也因此以為她們是個危險的團體。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但似乎，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和主人的感情很好的樣子……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n且還被其中一人叫做哥哥……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就此看來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是一些良善的人們呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過於大意總是不好的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仍不知道她們是何方神聖呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總覺得，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像有些心不在焉的樣子……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是還沒睡醒，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以沒辦法好好釐清現況嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼就讓在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿為您來說明♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昨日，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了與『七冠』的似似花這號人物接觸……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "動身造訪了",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一個被稱為研究設施的地方。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而最後，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為各種緣故，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "研究設施發生了爆炸。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而在下等人",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "偶遇了矛依未小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並在她的引導之下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n最後暫時在【拉比林斯】的這據點，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍作歇息與休憩。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到這裡，不知道您還是否有印象呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【拉比林斯】是個祕密社團，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而這據點規模也較為狹小……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若大批人馬聚集起來想必會過於擁擠。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此決定與忍小姐等人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "暫時分道揚鑣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且若將她們幾位，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n捲進了我們所面臨的事端之中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必也不是什麼好事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而似乎忍小姐一行人，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也決定要去調查看看，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那座遭受過爆炸的研究設施呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今後也繼續維持著情報的交流，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一塊好好的相處吧～",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她們也如此的說道了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n乍看之下儘管有些可疑，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但實際上卻是相當和睦且熱情的人們呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "記得沒錯的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是【惡魔偽王國軍】？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n忍小姐的公會，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有著一個會令人畏懼三分的名字呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寡聞不才在之前不曾有所耳聞。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但她們就如同會自稱為惡魔般不可思議一樣，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n每個人也都是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相當和藹可親的呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然昨日所遇之事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能否用「玩」來表現還有待商榷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但若是與她們一塊同聚，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就連在下也會不禁一同雀躍了起來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若今後能以友人、",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以身為同個世界中生活的同胞……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大家一起，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "互助扶持的話，想必是件圓滿之事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～！",
        "unit_id": 106112,
        "voice": "vo_adv_2008002_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n{player}，起床了沒？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n有很多事情還得說清楚，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快點到餐廳這裡來！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃，什麼？",
        "unit_id": 106112,
        "voice": "vo_adv_2008002_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們倆是睡在一起的嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n感情還真好耶。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，並不是這樣……",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n由於主人他睡得似乎沉了一點，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此才近身嘗試能否搖醒主人他。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再怎麼說，",
        "unit_id": 105913,
        "voice": "vo_adv_2008002_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是身為來客，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若做出什麼擾亂風紀之事，說什麼也不得體。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒什麼關係吧？",
        "unit_id": 106112,
        "voice": "vo_adv_2008002_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": " 就只是睡在一起嘛……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒做些什麼見不得人的事的話，沒人會說閒話的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比起這件事。",
        "unit_id": 106112,
        "voice": "vo_adv_2008002_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還有事要說清楚的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以快來餐廳吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然是順便，",
        "unit_id": 106112,
        "voice": "vo_adv_2008002_050"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但在吃早餐前還有一點時間，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n途中也帶你們和拉比林斯達那傢伙見見面吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙一直睡得死死的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以大概是說不上什麼話就是。",
        "unit_id": 106112
    }
]