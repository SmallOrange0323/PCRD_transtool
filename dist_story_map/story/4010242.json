    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的……",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n突然說要我來幫忙整理房間，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你到底在想什麼啊？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你這個人每次約好了時間都會遲到，",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "作業也老是丟著不寫，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n真的很會讓人操心耶……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "照這樣看來，",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "他不記得今天是什麼日子吧。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……害我還有",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "一點點期待的說……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀啊～！？",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你幹嘛！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嚇、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嚇我一大跳！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "害我都不小心大聲尖叫了啦！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "原來你",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "記得我的生日嗎？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你叫我來是……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝……！",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n嘿嘿……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的有",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "被驚喜到了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可、",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你還是嚇到我了！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n嚇人是不好的行為，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請你反省！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你看看，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我都被你嚇到腿軟，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "動彈不得了啦！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這是幹嘛？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說是動彈不得，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但也不至於……！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "變、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "變態──",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……不對。",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這是公主抱，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "他就像王子一樣──",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "──但這種舉動",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "果然還是太過刺激了，不行！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呼……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "變態可疑分子────────！",
        "unit_id": 103631,
        "voice": "vo_adv_4010242_010"
    },
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喔，",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_011"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "死黨公。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n突然叫我出來",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是怎麼了嗎？",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "景色？",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_012"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "聽你這麼一說，",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這高處的視野",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還真不錯啊。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雖然冷風陣陣，",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但應該就快要停了。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "倒不至於讓人待不住。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……啊。",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_013"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "去冥府的醫院報到那段時期",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "好像也是這樣的季節。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n用那雙比現在還短的腿",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "一步一步費力地走著……",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……算了，",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_014"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "當我沒說。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "都是過去的事了。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "忘了吧。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "話說回來，",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_015"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n你今天",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "到底是在搞什麼鬼啊？",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "啊啊，",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_016"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "確實是到了那個時期……",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……等等，",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我有跟你透露過我的生日嗎？",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n……",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也罷。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "倒也不必",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "糟蹋你的一番好意。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "再說，",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_017"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這景色",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我也挺喜歡的。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "跟那些有形之物不同，",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "死後應該也能帶著上路吧。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "謝啦，",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_018"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "{player}。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "生日這東西，",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "對我而言只是個充滿陰霾的壞日子……",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不過多虧你為我帶來了一陣風，",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "讓我覺得心裡",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "稍稍",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "舒坦了點。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喂喂喂。",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_019"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n再繼續這樣欠你人情下去的話，",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n到時我恐怕就連付給三途川擺渡人的六文錢都湊不齊了啊。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "算了……",
        "unit_id": 135931,
        "voice": "vo_adv_4010242_020"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "有道是",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "好人做到底嘛。",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n{player}，既然你這麼閒",
        "unit_id": 135931
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就陪我去掃墓吧──",
        "unit_id": 135931
    }
]