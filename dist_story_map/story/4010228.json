[
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510392"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "晚安，",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n謝謝你願意",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在這種深夜還過來。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n只是……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "平時常見到的那些幽靈們說",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想慶祝我的生日。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然讓成為幽靈的人們",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "慶祝誕生之日，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺很複雜……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他們跟父親一起，",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還說什麼",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「女兒的生日就辦得豪華點吧」……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就變得這麼多人了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是，",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "多到感覺可以埋住這個庭園……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但沒事的，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "裡面沒有危險人物。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n他們現在正在各自",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "暢談呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……對不起。",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n對於看不見的你來說，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是很寂寥的光景吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但就是、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我希望……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你也能來。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……這是我個人",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "的願望。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你。",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個小盒子……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "禮物嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我能打開嗎……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……這是",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……戒指、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "設計是圓圓又可愛的骷髏頭。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n比父親還要討人喜歡呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "各位，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎麼了？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n……要我",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "戴上戒指？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "大家",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎麼拍手了……！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那、",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺周遭都嗨起來了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "方便的話，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可以把",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這只戒指……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "戴到我手上嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "──用你的",
        "unit_id": 103131,
        "voice": "vo_adv_4010228_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "手。",
        "unit_id": 103131
    }
]