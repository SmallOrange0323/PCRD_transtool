        "voice": "vo_adv_5136061_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "看起來是滿像的。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n但是不仔細端詳看看的話無法斷言。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "日和",
