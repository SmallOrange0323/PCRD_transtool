    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "志那都妳覺得呢？",
        "unit_id": 100311,
        "voice": "vo_adv_5136061_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也是在誤差範圍內嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………",
