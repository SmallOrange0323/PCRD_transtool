        "unit_id": 100111,
        "voice": "vo_adv_5136061_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "反正感覺暫時也不能做什麼呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是啊──",
