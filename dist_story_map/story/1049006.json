        "words": "喔……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "公會長千叮嚀萬囑咐……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "叫我不要隨意接觸{player}～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼自以為是……",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是現在",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我也只能乖乖聽那個人的指示了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n並不是單純的失去記憶，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n更像是陷入一種",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「不可思議的感覺」。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "萬一不小心給他多餘的刺激，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也不曉得會發生什麼事。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了能和{player}",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n恢復成原本那樣感情要好的姐弟關係……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在必須要",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "克制自己才行。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我必須忍人所不能忍，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n隔絕{player}。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，可是，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不行……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我這是戒斷症狀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n路上的每一個行人",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看起來都像{player}。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "一～二～三～",
        "unit_id": 111,
        "voice": "vo_adv_1049006_008"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "木頭人♪",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "哇！\n哈♪",
        "unit_id": 211,
        "voice": "vo_adv_1049006_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好像",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有小孩子在玩耍呢……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "小孩子真好，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n活力充沛",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "又幸福……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "令人忍不住",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n回憶起往事呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好像",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就和那些孩子差不多歲數的時候吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我和{player}",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "命運般的邂逅了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們住得很近～",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，真懷念。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我的雙親",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為工作繁忙，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "老是一個人孤伶伶的……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "把{player}當作親弟弟來照顧，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n填補了內心的空虛。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們就像親姐弟一樣",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一起長大。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對。",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就算我們沒有血緣關係，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n對我來說，他已經是家人了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我很希望",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}也是這麼想的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "重逢的時候，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是真的很開心。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n卻把這一切都忘記了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一切都是",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n荒謬又莫名其妙的異變所造成的……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "痛恨著這個事實。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "正因為沒有血緣關係，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我和{player}之間的羈絆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就只剩回憶了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但現在",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "卻連這層連繫也被剝奪了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等到{player}",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "恢復記憶……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n或許真的會",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很普通地",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n忘記了我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也說不定。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只不過是個",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n小時候關係曾經很要好的鄰居姐姐。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果記憶不是以這種蠻橫的手段被剝奪的話，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "或許還有機會回想起來。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對。",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們只要重新增進感情，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n製造比以前更多的回憶就好了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就目前的情況來看，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n相當困難啊……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "無論現在",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "累積了多少回憶，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一旦{player}恢復記憶，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n「現在」的記憶或許會消失不見。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果增進感情",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也只會再次被遺忘的話……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "保持距離才是明智的選擇。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "否則",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也只會受傷而已。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "公會長的想法",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是正確的，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我心裡也很明白啊。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n啊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？\n{player}？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你是{player}對吧？",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這不是我的幻覺吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我好想你呀～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對、不對。",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我不能和他見面！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我要和他保持距離！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，",
        "unit_id": 104911,
        "voice": "vo_adv_1049006_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能見到面就很開心嘛！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n之後受傷",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有什麼大不了的！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
