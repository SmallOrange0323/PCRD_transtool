    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "果然還是沒辦法從這個宿命中逃脫嗎……！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "我……",
