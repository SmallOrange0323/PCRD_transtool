        "words": "閉上眼睛，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "那些畫面都還歷歷在目……！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "霞，",
