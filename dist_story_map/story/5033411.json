    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我是不會忘記的，",
        "unit_id": 112211,
        "voice": "vo_adv_5033411_004"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這段身為魔法少女的日子……！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "霞……",
