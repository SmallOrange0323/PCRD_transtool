        "name": "委員長",
        "words": "妳應該嚇到了吧？",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "因為廢柴班的程度低得驚人。",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "但是",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "安魔學裡糟糕的就只有那一班而已，妳可不要誤會喔。",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "呵呵，",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_071"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "凱留同學，",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "那個班級並不適合妳呢。",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n妳願不願意轉來我們升學班？",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然很高興受到邀請，",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是好像沒辦法呢。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n似乎只剩廢柴班有多的名額。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "這種小事很好解決的。",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_073"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "只要把我們班裡最無能的人",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "踢去廢柴班就好了♪",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……？",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_074"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "對吧，",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_075"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "這樣比較好啦凱留同學。",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n我馬上就去拜託校長處理吧♪",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n只要我說一聲，馬上就……",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_076"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒關係啦，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我待在廢柴班就好。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "咦，",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_077"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "為什麼？",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "事先也不曉得班上有沒有合拍的人，",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_078"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就被隨機丟進教室所產生的不自由感，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這也是學園生活的樂趣吧？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那些傢伙，走著瞧吧……",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_079"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我一定要讓他們刮目相看！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "等等！",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_080"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "妳不用留在那種垃圾堆，和那群無能待在一起啊！",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "俗話說近朱者赤什麼的……",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "這樣子妳也會變得無能喔！？",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "和妳一起來的",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_081"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "那個外表浮誇的無能女，",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n和那個一直悠哉傻笑的無能男",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "倒是很適合那班啦！",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……無能？",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_082"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳從剛才開始就一直在那邊說無能無能的，",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_083"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是在",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "自我介紹嗎？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "……什麼？",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_084"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n妳是什麼意思，",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "凱留同學？",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所謂的無能，",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_085"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是指無法達成目標的人不是嗎。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n然後",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的目標，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是把我拉進升學班對吧？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳以為用剛才那種說法",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_086"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有辦法達成這個目標嗎？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……對於我的朋友。",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_087"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那樣嘲笑我朋友的傢伙所在的班級，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳難道覺得我會想進去嗎？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "……啊！",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_088"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳再說一次鈴奈和那傢伙的壞話看看，",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_089"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到時候妳就等著瞧。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "嘖……",
        "unit_id": 1215,
        "voice": "vo_adv_5126001_090"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "真是得寸進尺……！！",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n我再也不會邀妳了！",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那真是太棒了呢。",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_091"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蛋───",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶～～～～♪♪♪♪♪",
        "unit_id": 127312,
        "voice": "vo_adv_5126001_092"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！！",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_093"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n咦，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鈴奈，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳為什麼會在這裡……！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼嘛～",
        "unit_id": 127312,
        "voice": "vo_adv_5126001_094"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "妳有好好",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "把我們當朋友嘛～！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好高興喔～～♪",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家也很喜歡凱留寶喔！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超喜歡！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喜歡到不行！！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以說別抱上來啦……！！",
        "unit_id": 127212,
        "voice": "vo_adv_5126001_095"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好難呼吸……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "嗯，",
        "unit_id": 1,
        "voice": "vo_adv_5126001_096"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "本來以為是個難相處的傢伙，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n但凱留人還挺好的嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "凱留，",
        "unit_id": 1,
        "voice": "vo_adv_5126001_097"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "我剛才對妳的說話方式有點傷人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n真對不起……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良學生",
        "words": "……哼！",
        "unit_id": 814,
        "voice": "vo_adv_5126001_098"
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "嘿嘿，",
        "unit_id": 915,
        "voice": "vo_adv_5126001_099"
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "雖然因為擔心而追了上來，",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "但是看來不要緊呢。",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "\n",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "大家",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "回教室去吧──！",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然笨拙，但凱留還是被班上的同學所接納。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而，她的學園生活才正要開始。"
    }
]