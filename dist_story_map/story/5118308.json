[
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "呵呵呵……",
        "unit_id": 17512,
        "voice": "vo_adv_5118308_000"
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n嘻嘻嘻嘻……",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n啊──哈哈哈！！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "突、",
        "unit_id": 125611,
        "voice": "vo_adv_5118308_001"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "突然是怎麼了呀？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "被逼到絕境，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "反而亢奮起來了嗎？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "哈哈哈……",
        "unit_id": 17512,
        "voice": "vo_adv_5118308_002"
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "是啊，",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "我承認我很興奮喔。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n雖然我可沒被逼到什麼絕境呢。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "賭上自身的存在意義，",
        "unit_id": 17512,
        "voice": "vo_adv_5118308_003"
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "竭盡智力的充實感！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n一個錯誤便會致命的緊張感！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "原來如此，",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "這就是所謂的戰鬥嗎……",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "我親身明白了這一點！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "莫夫似乎也開始習慣戰鬥了呢。",
        "unit_id": 125711,
        "voice": "vo_adv_5118308_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "他逐漸掌握感覺的現在，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是最難纏的啊。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……莫夫！",
        "unit_id": 125511,
        "voice": "vo_adv_5118308_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n對於學會了戰鬥的你，",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們還要教你一件事！",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n那就是──",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "完全的敗北！",
        "unit_id": 1,
        "voice": "vo_adv_5118308_006"
    }
]