    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來傷口都痊癒了呢。",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "它在剛剛的戰鬥中",
        "unit_id": 128911,
        "voice": "vo_adv_5136302_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該也學習成長了吧。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "必須要小心謹慎才行……！",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學習……",
        "unit_id": 128711,
        "voice": "vo_adv_5136302_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難道說，",
        "unit_id": 128711,
        "voice": "vo_adv_5136302_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是我們做了奇怪的動作，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n它也會學起來嗎？",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "欸，",
        "unit_id": 128911,
        "voice": "vo_adv_5136302_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個嘛……",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "或許是？",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是吧？",
        "unit_id": 128711,
        "voice": "vo_adv_5136302_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那麼，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果故意讓它學習奇怪的東西……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也許就能輕易打倒它了！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個作戰本身就很怪了。",
        "unit_id": 128811,
        "voice": "vo_adv_5136302_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "居然會想到這種事……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是被埃拉影響了嗎？",
        "unit_id": 128811
    }
