    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "絶対に問題を解決してみせちゃうんだからねっ☆",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "うん、",
        "unit_id": 113311,
        "voice": "vo_adv_6044205_001"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "モチのロンだよ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "『願い竹』を手に入れるためにって目的はあるけど、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n困った人は助けるのが",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "魔法少女の生きる道、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "なのだー！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "んー、",
        "unit_id": 113311,
        "voice": "vo_adv_6044205_002"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "本命の推しが居るのに、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "別の人を推しちゃうってこと。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n人の勝手なのかもしれないけどさ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "誰かを悲しませちゃうのは",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nよくないよねぇ。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "愛を信じる魔法少女としては、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "放っておけませんなぁ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "んむむ、",
        "unit_id": 113311,
        "voice": "vo_adv_6044205_003"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "その辺はナナカちゃんもうまく説明できないけどさ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "一度好きになっちゃったら、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "簡単には嫌いになれないものなのよ。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
