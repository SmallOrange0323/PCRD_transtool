        "voice": "vo_adv_6044205_000"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ぜーったい許せない！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nこの正義のサイカワサイツヨ魔法少女ナナカちゃんが",
        "unit_id": 113311
