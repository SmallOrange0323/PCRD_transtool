    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你好。",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我來晚了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經超過我們",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原本約好的時間好久了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n都怪家裡的生日派對遲遲不肯結束。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過已經沒問題了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……其實",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也不能說沒問題啦。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n畢竟",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是偷偷溜出來的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也這麼覺得啊。",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也沒辦法嘛。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為我太期待了──",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟你一起開生日派對。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是不好意思。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還得借用你們家來開派對。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……因為我希望",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "盡可能待在私人的空間裡。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔！",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊、",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就打擾了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n反正也不是第一次……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我完全",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒問題。",
        "unit_id": 100332
    },
    {
        "type": "background",
        "background": "510092"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n準備了蛋糕",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有禮物……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我很開心。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能夠近距離看到送禮物的人的表情，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是很寶貴的經驗。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我真心覺得……像這樣跟你一起過生日，",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無比珍貴、",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無可取代的回憶。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……要是我能夠一直待在這裡，",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n直到今天這個特別的日子",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "結束為止就好了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哪有那麼美的事。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的手機從剛才就一直響個不停。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……！",
        "unit_id": 100332,
        "voice": "vo_adv_4010237_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵、",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵呵……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你還真大膽呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我下定決心了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天我們一起",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "享受這場生日派對到最後吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟我又長了一歲，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不能永遠都當一隻乖乖的籠中鳥嘛。",
        "unit_id": 100332
    }
]