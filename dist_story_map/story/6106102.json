[
    {
        "type": "background",
        "background": "510370"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "子どもたちと店番をしたり訓練をしたり……",
        "unit_id": 105311,
        "voice": "vo_adv_6106102_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "有意義ではあるのだが、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n一ギルドの長としては、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "少しくらい尊敬の念というものを感じたいのだ。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "……貴公はどう接するのが適切だと思う？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "同じ目線で……",
        "unit_id": 105311,
        "voice": "vo_adv_6106102_001"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "確かに、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "見習いとはいえ栄えある",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n我がギルドの一員なのだから、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "対等に接することが望ましいな。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "……まさかと思うが私が子どもっぽいからではないよな、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "うむ。",
        "unit_id": 105311,
        "voice": "vo_adv_6106102_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "やはり年長者として、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "模範的に振る舞わなくてはな。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n年長者のこの私が、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "時に優しく、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "時に厳しく導いてやらなくては。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふふ、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "年長者か……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "実に甘美な響きだ。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "気に入ったぞ！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "へっ！？　",
        "unit_id": 105311,
        "voice": "vo_adv_6106102_003"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "お、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "お母さんの気持ち……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いやしかし、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それでは貴公がお父さんということになるのでは……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あっ、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "やっ、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なんでもない！　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "まあその、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "努力はしてみよう……",
        "unit_id": 105311
    }
]