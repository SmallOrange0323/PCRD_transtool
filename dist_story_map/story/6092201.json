    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "よし、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "じゃあ私が寝るから",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "しばらく見ててね☆",
        "unit_id": 113311
    }
