    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "あー、",
        "unit_id": 113311,
        "voice": "vo_adv_6044201_002"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "なるほどそう来ましたかー！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "分かっておりますなー！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n一緒に砂のお城を作ってから真ん中に穴を掘ってみようって言って",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "掘り\n進んだところでお互いの手がギュッ☆　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "これですな！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "いいですぞー！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "うーん、",
        "unit_id": 113311,
        "voice": "vo_adv_6044201_003"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "なくはないけど",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "好感度的には",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "微妙な選択肢ですな。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "あ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "でも寝顔を見て",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "「こいつ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "意外とかわいいじゃん……」",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "みたいな\n展開はあり得るかも！　",
        "unit_id": 113311
