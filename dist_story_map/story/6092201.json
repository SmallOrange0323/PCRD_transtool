        "words": "わーい！　",
        "unit_id": 113311,
        "voice": "vo_adv_6044201_001"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "どっちがおっきいヤドカリさん見つけられるか競争～！",
        "unit_id": 113311
