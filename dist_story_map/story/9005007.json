[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲覺得在街上已經收集不到更多情報了，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是來到某個地方拜訪友人。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來如此，",
        "unit_id": 104412,
        "voice": "vo_adv_9005007_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "送給那傢伙的禮物啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n找上妾身是很正確的判斷。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟妾身乃是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那傢伙的主人嘛！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈～哈哈哈！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "除了伊莉亞小姐以外，",
        "unit_id": 106412,
        "voice": "vo_adv_9005007_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我也想要聽聽【惡魔偽王國軍】",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的大家",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有什麼想法。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "送布丁喲。",
        "unit_id": 100711,
        "voice": "vo_adv_9005007_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然很開心妳會來問我們……",
        "unit_id": 102212,
        "voice": "vo_adv_9005007_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但那傢伙喜歡",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "的東西……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我才",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "更想知道呢……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對了。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "忍可以",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "用占卜來找答案吧？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "送布丁喲。",
        "unit_id": 100711,
        "voice": "vo_adv_9005007_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "當然可以……",
        "unit_id": 103113,
        "voice": "vo_adv_9005007_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "換作平時",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我或許會這麼說，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但這個問題還是別用占卜為妙吧。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n靠著一個憑空冒出來的答案去準備禮物，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這麼做毫無意義。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "送布丁喲。",
        "unit_id": 100711,
        "voice": "vo_adv_9005007_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果是茜里的話，",
        "unit_id": 100611,
        "voice": "vo_adv_9005007_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "應該會送親手做的貼身衣物。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "然後茜里自己",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也穿同款的♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "在看不見的地方穿著同樣的東西，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真令人臉紅心跳～♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "送～",
        "unit_id": 100711,
        "voice": "vo_adv_9005007_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "丁～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "喲",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n為什麼要無視人家來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "送禮就是要送布丁！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就決定送一個比山跟海都要大的布丁喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為宮子肯定會說布丁啊……",
        "unit_id": 103113,
        "voice": "vo_adv_9005007_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "問也是白問……",
        "unit_id": 102212,
        "voice": "vo_adv_9005007_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對吧？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯……",
        "unit_id": 100611,
        "voice": "vo_adv_9005007_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "除了布丁之外還有什麼提議嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒有喲。",
        "unit_id": 100711,
        "voice": "vo_adv_9005007_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n只要有布丁就行了。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "來，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "趕緊給宮子布丁喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "宮子呀……",
        "unit_id": 104412,
        "voice": "vo_adv_9005007_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在是在討論要送什麼給那傢伙耶……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵。",
        "unit_id": 106412,
        "voice": "vo_adv_9005007_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要是大家都可以像宮子小姐這樣，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n給我一個",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "簡單明瞭的答案",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就好了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……",
        "unit_id": 104412,
        "voice": "vo_adv_9005007_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雪菲呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看來妳已經問過許多人的意見了，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但一直這麼做有用嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_9005007_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咱們每個人跟那傢伙的交情",
        "unit_id": 104412,
        "voice": "vo_adv_9005007_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "各有不同，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對於他喜歡什麼、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不喜歡什麼",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也各有各的見解才是。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳問到了那麼多意見，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可有找到哪個滿意的答案嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "伊莉亞小姐……！",
        "unit_id": 106412,
        "voice": "vo_adv_9005007_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一直都弄錯努力的方向了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈哈哈！",
        "unit_id": 104412,
        "voice": "vo_adv_9005007_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n儘管感謝妾身、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "尊敬妾身吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳要是願意的話，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也可以將妳收為部下喔？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不，",
        "unit_id": 106412,
        "voice": "vo_adv_9005007_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這就免了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聽了伊莉亞的建議，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲重新調整思考方向。"
    }
]