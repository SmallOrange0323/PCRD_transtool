[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼，",
        "unit_id": 105911,
        "voice": "vo_adv_9044155_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛好找到了一個洞窟，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是幫了大忙呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "突然下起暴風雪嚇了在下一跳，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算可以放心了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之，",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先一邊取暖一邊好好休息吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我要用魔法生個火，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有什麼能燒的東西嗎──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可去哪了？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留～！",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "過來一下～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡有通往深處的道路喔～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說要生火了吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳跑到哪裡了啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9044155_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難得來了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也試著往裡面走吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且這條路",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎漸漸通向地底的方向。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在地熱的作用下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有可能會比這裡還溫暖。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說的也是，",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且就算待在這裡也很無聊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n動一動身體還會比較暖和。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那就決定出發吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這座洞窟",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還蠻深的呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說不定",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "前面還會有夢幻食材！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真令人期待☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_9044155_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正如在下所預料的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變得溫暖起來了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也變得越來越暗了呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這時候",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就使用照明魔法……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦，",
        "unit_id": 105911,
        "voice": "vo_adv_9044155_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能夠看到很遠的地方了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不愧是凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常可靠。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只不過是不想跌倒而已啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "變亮之後我才發現，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這座洞窟……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們不覺得",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "四處都在閃閃發光嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然是很漂亮啦……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這是怎麼回事啊？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是……",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "寶石！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好棒……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放眼望去",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "四下全部都是寶石！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "得趕快撿起來！",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果有這麼多寶石，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "帶回去賣掉瞬間就是億萬富翁了呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點，",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們也別發呆，一起撿啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只要有這麼多寶石，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管是多高級的食材都能吃到飽了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可以吃到肚子撐滿為止唷！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的嗎！？",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是我嚮往中的那種食物或這種食物……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個很大一塊的似乎不錯呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "用力……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拔不出來……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說不定是被什麼東西卡住了呢。",
        "unit_id": 105911,
        "voice": "vo_adv_9044155_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起來拔吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也來幫忙！",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n三個人一起拔",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總能拔起來了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳們！",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要拔囉～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "用力！",
        "unit_id": 1,
        "voice": "vo_adv_9044155_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拔不出來耶……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再試一次看看吧。",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "它都稍微有動了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺這次一定能成功。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那麼，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "預備……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "用力！！！",
        "unit_id": 1,
        "voice": "vo_adv_9044155_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拔不……",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "出來啊……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "地面好像在晃動……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等、",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要掉下去了……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底發生什麼事了啦！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇！",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_026"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙怎麼回事……！",
        "unit_id": 106011,
        "voice": "vo_adv_9044155_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也太大隻了吧……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇！",
        "unit_id": 105811,
        "voice": "vo_adv_9044155_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "全身閃閃發光！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是寶石魔物一樣耶！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
