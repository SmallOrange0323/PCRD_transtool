    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……呼、",
        "unit_id": 131611,
        "voice": "vo_adv_1312003_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呼……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長、",
        "unit_id": 131611,
        "voice": "vo_adv_1312003_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "大人……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "（倒下）",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在海邊展開的妳追我跑，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以美空的勝利告終……"
    },
    {
        "type": "background",
        "background": "501033"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呼～",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_002"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好好運動一番了呢★",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "莉莉也",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_003"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "在沙灘上跑了這麼久，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "已經變成是修行了吧★",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "能幫助她修行，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真是太好了♪",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你是指什麼～？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我說笑的……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……莉莉",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_005"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還真厲害呢。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n她真的是個",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "令人難以置信的",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好孩子。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "為了幫助消失的人，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_006"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n而那麼努力地",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "想要變強。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "明明她完全不適合",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "戰鬥這種事……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……而且，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_007"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "最重要的是，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n明明我",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "讓她做了壞孩子……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n她應該會想責怪我才對，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但她卻試圖以理性壓抑那種心情。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說真的，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_008"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我應該要向她學習才對吧──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然是這麼想的，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但大概辦不太到呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "有啦──",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然有一部分是因為我很容易放棄……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但總覺得，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "她就像是不同世界的居民",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "一樣呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "選擇……",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_010"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊。",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_011"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n你是說讓莉莉、",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可璃亞和普蕾西亞，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n成為墮落角色的事嗎？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……嗯──",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_012"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我記得",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那時候是……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "對了對了，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_013"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為我覺得",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n要是厄莉絲大人能夠現身在幕前，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n那樣大概",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "會跟【憤怒‧軍團】的大家打起來，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "所以……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我想",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_014"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "光靠我一個人要跟騎士同學和優衣玩，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n應該會有──點",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "辛苦吧。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "畢竟彌勒先生",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說他不擅長",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "準備棋子。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然騎士同學",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_015"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可能會覺得有點生氣……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但實際上",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就是那樣呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "畢竟，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_016"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我不太擅長",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "操縱一般的魔物之類的？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n怪奇怪靈不是自動型的，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以很難讓它在我看不見的地方",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "大鬧呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為這樣，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_017"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "厄莉絲大人",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n就製造了「能自己召喚闇影",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "的角色」給我喔。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然那，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "比較像是從廢棄檔案中",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "抽取出來的就是了。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_018"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "角色就像是空蕩蕩的容器，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n因此需要放入",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "消失玩家的靈魂。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n而那",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就是莉莉她們……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……咦？",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_019"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n你不是在說這個",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗎？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊──",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_020"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是這種意思啊。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而不是在說為什麼會需要戰力。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……嗯～",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_021"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n是為什麼呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_022"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我並沒有在裝傻喔？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n老實說，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我是真的不知道。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為厄莉絲大人",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "交付給我的「消失靈魂」，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "碰巧就是那３人。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那之中",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_023"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "有小P……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "普蕾西亞在。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我就想那似乎能成為",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "應付難纏的阿澤爾德先生的王牌",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "吧──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n當時",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我並沒有想太多呢。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過……",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_024"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "被重新問起了，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n厄莉絲大人是出於什麼理由",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "挑選",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "小R、",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "小P和小Q的，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我就不太清楚了呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯──？",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_025"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n會是什麼呢……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是那３人",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "除了都是好孩子之外，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "幾乎沒有共通點吧？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……難道說，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_026"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這跟與厄莉絲大人合體的",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "米奈娃也有關係？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或者，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還有什麼其他的……？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……對不起。",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_027"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n目前看來，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我好像沒有其他",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "能夠告訴你的情報。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要是無論如何都想知道的話，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_028"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "問問看厄莉絲大人可能會比較快呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果是騎士同學的提問，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我想她什麼都會樂意說的。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊。",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_029"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不過厄莉絲大人",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "已經不是管理者了吧。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那麼",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可能沒有辦法什麼問題都回答你呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_030"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……厄莉絲大人。",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_031"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "她似乎沒有徹底消失，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真是太好了呢。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "已經不再是管理者、",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_032"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不再可憐，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n變得像一般的女孩子一樣……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說不定──",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_033"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不只是蘭法姐，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我跟厄莉絲大人",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或許也能成為朋友……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "開玩笑的。",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_034"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "搞不好，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "會演變成以騎士同學為中心，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "血肉模糊的相互殘殺也不一定呢★",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦？",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_035"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n是指我跟厄莉絲大人",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "最初相遇的時間點嗎？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那是在……",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_036"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我想說「米奈娃的禁錮」",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "什麼的，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好像很好玩呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就算無法回到現實，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我也沒有什麼留戀之類的？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "於是我……",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_037"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就取得了mimi──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "透過超能力，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "跟很懂電腦的人",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "成為「朋友」──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「潛入阿斯特朗！」",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "了──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "結果，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_038"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我相當驚訝呢──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "乍看之下感覺就是",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n一般的奇幻世界呢……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "魔法什麼的，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_039"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "跟我所使用的超能力",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "有點相似。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "該說是模擬嗎？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或者說，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是設法讓超能力在虛構的世界中重現……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "總之，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_040"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為那樣，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我對於這是如何創造出來的──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "產生了興趣。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "開始調查後，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我得知世界被重置了好幾次，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n還有感覺像被重新打造過的事。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "試著追蹤了那個痕跡後，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_041"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我就找到了。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就是騎士同學也知道的",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那座地下城堡。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "正確來說，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_042"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "厄莉絲大人比起住在那，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不如說有９成時間都是睡著般的",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "休眠狀態就是了。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我記得是在騎士同學你們",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "打倒霸瞳皇帝時，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還要……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "再更早一點吧。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "當時的厄莉絲大人",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_043"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "內心支離破碎。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "明明擁有驚人的力量，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "然而她自己卻什麼都做不了。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n真的很可憐──",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……話說，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_044"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n事到如今，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也不需要那種回顧了吧。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_045"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我剛剛也說了。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "當時",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "什麼都辦不到，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "又可憐的厄莉絲大人，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n已經不存在了。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦？",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_046"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n跟我嗎？",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……啊哈。",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_047"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n是這樣的嗎……",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果厄莉絲大人",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_048"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "對於我，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n有她對騎士同學在意程度",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "的百億分之一，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那種事或許",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也有可能呢。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然她現在喪失力量，",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_049"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "在那座城裡似乎大多處於沉睡狀態，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n但要是我哪天整理好心情了，",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或許也可以",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "去看看呢。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "前提是",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "沒有被厄莉絲大人拒絕",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就是了。",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……呵呵。",
        "unit_id": 131214,
        "voice": "vo_adv_1312003_050"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n總覺得今天的騎士同學",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "很積極呢～",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131214
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是對剛剛問了很多問題的我",
        "unit_id": 131214
    },
    {
