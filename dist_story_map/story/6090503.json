[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ノウェムは無鉄砲で、",
        "unit_id": 107011,
        "voice": "vo_adv_6056503_000"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "危ういところがあります。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "何か無茶をしでかさないように、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n貴方の方でも気にかけてあげてください。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ええ、",
        "unit_id": 107011,
        "voice": "vo_adv_6056503_001"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "そうしてもらえるとこちらとしても助かります。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\nノウェムは貴方に気を許しているでしょうから、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n意見も素直に聞き入れるでしょう。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴方も無茶はしないように。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "……私にとって、",
        "unit_id": 107011,
        "voice": "vo_adv_6056503_002"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ノウェムは必要となる可能性が高いだけです。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "利用価値からの判断であって、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴方が思うようなものでは……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "なんですか",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "その笑顔は。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "違うと言っているでしょう。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "断じて違います。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ええ、",
        "unit_id": 107011,
        "voice": "vo_adv_6056503_003"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "彼女も一人で何もできないほど弱くはありません。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ですが、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "支えが必要な時もある。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "今回は気だるげな相棒がいないので、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n貴方にその役目を託したいのです。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "頼みましたよ。",
        "unit_id": 107011
    }
]