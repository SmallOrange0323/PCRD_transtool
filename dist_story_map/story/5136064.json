[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "志那都與接下送貨委託的怜一起行動，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了牧場。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "動物們和平度日的牧場景象……",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_000"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "真不錯啊。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在人多的城鎮裡",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不太能靜下心來……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我就在這裡稍微休息一下吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唉～～～",
        "unit_id": 1,
        "voice": "vo_adv_5136064_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真陽也真是的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真希望她能好好地考慮一下適材適用呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……嗯？",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n那不是……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "工作這種事，",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明只要讓想做的人去做就皆大歡喜了啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要不要，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不想動啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……唔。",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_005"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……難道",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她就是",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這個世界的鈴嗎。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我下意識地就躲了起來……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不過這個判斷應該是正確的。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……至少，",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我所知道的她，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是個厲害的警衛。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "甚至連黑社會都知道她的名號。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "人稱",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_008"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "「傳說的橡子遊俠」……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n企圖危害牧場",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "而被她抓住的壞蛋",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "數不勝數……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n在她的監視之下沒有惡人能逃走……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在這個世界的我，",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "只是個來路不明的可疑人物。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……而且我自己一個人，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就連展開對談都做不到。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "要是被她盯上就麻煩了……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～～～",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "天氣真好～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這是世界在對我說",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "「還是休息吧」",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒辦法……",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然原本是想要來工作，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是我已經不行了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就照世界所說的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來睡個午覺～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……睡午覺？",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_012"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n她剛剛是說要睡午覺嗎……？　",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "陽光暖呼呼的好舒服……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "晚安了～～～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她、",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_014"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她真的在睡覺嗎？",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那個",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "傳說的遊俠居然在睡覺……？　",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "吸～～～",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼～～～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼嚕～～～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……不，",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_016"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不能掉以輕心。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這也可能",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是欺瞞敵人的偽裝。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "趁還沒被發現之前",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "離開這裡吧……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……站住，",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳逃不掉的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "唔！！",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_018"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "竟然……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "被發現了……！？　",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……果然無法從傳說的遊俠手中逃掉",
        "unit_id": 135613,
        "voice": "vo_adv_5136064_019"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是嗎。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……我還以為自己已經領悟了隱藏氣息的技巧……",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_020"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n真是不簡單。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……呵呵呵，",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "抓到啦",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "紅豆麵包～～～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我開動了～～～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………是夢話……？",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_022"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這……",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔嗯……！？",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n咦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳是什麼人？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗯？",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_025"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n呃，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那個……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我……",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_026"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我是路過的",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "劍士。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "對了，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我是怜的親戚。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "絕不是",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "可疑人士。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣子啊。",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳是牧場的客人嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那請自便～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這……",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_028"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "先、",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_029"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "先等一下。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然由我說這種話說很奇怪……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但妳",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是警衛。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n應該要對我抱持懷疑比較好。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒事沒事。",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為大姐姐的來歷",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我大概猜到了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……短短一瞬間就能夠掌握到這種程度嗎。",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_031"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n果然是傳說的──",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看這個捧哏的犀利程度……",
        "unit_id": 102611,
        "voice": "vo_adv_5136064_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我看",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳就是要當真陽搭檔候補的諧星吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "咦，",
        "unit_id": 135614,
        "voice": "vo_adv_5136064_033"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不是的！",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後的一段時間裡，鈴與志那都兩人一來一往的逗哏與笨拙捧哏"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n響遍了牧場。"
    }
]