[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "歐啦啦啦啦！",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_000"
    },
    {
        "type": "still",
        "still": "200800301"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n攻擊太粗糙啦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "每一招都一樣！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n進攻中得再多加點緩急呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以你的力量，",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要能揍到一拳，任誰都會輕易倒下吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但若打不到人就沒有任何意義唷！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你看看你，",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再多用一點腦袋啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還是說你連腦子都是肌肉嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "試著讓我再更加愉悅一點啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這個小木偶！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "嘎啊啊，",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_004"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "真讓人不爽啊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n今天就是妳的忌日啦，看我怎麼把妳欠揍的嘴臉揍扁！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦？",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好壞……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n大吾，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連女孩子的臉你也打嗎……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "咦咦咦！？ ",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_006"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但不是啊，這是戰鬥訓練啊？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n而且不是妳自己叫要我不要放水的嗎？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "話又說回來，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳這年紀還能叫『女孩子』嗎！？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊？",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟說了不該說的話。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n宰了你喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "唔哦哦！？",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_008"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n妳劍別亂揮啊，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我這可是兩手空空欸！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n被砍到真的會出人命啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "放心吧，",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "孩子！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就只會把你那說錯話的小舌頭割下來而已啦！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈哈☆",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～……",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不要鬧得這麼誇張嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們兩個。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個【拉比林斯】的據點……",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然是由拉比林斯達使用『物件變更』",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這個怪能力所造出來的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但當事人",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在可是意識不清啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "若真被拆了也沒人能修理喔。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會不會",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哪天這個『物件變更』的能力突然就消失，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n讓整個據點都崩塌了也說不定啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦呀。",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n早啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "矛依未♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "不是什麼『矛依未』",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_014"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是『諾維姆』才對吧。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "人家不是要我們這樣叫她的嗎？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "別盡是故意說一些惹人厭的話嘛，",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_015"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n個性這麼差可交不到朋友嘿。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵哈哈，",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我打從娘胎出生就是這個性，想改也改不了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過確實是有些失禮，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "向妳謝罪……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "諾維姆♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒關係啦。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我已經習慣了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而且如果真要說，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "『矛依未』反而才是本名勒。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但對這名字",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也沒有什麼美好的記憶……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為沒有意味才叫矛依未，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n像這樣",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有個討人厭的諧音，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以才希望能夠叫我諾維姆就是。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說回來你們倆，",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n已經是吃早餐的時間了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "結束訓練",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "去餐廳吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我先",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "帶{player}他們和拉比林斯達見個面。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "早餐嗎？",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_020"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "太好啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n被這個大媽拖著來陪練，肚子早就已經餓扁啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你說誰大媽啊！",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n下次再讓我聽到那個單字，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就把你碎屍萬段當早餐給吃了啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n懂不懂敬老尊賢啊，無禮之徒。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈。",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但是嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "意外地相處得挺融洽的，讓人放心多了……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們果然，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "基本上都還算是些好傢伙嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說得妳好像知道些什麼一樣。",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但也好……",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟妳把我從地下監獄救了出來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還提供了一個能確保安全的地方。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就先暫時",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當做報妳這個恩與義，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不會給妳多添什麼亂子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且，",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有大吾這個小伙伴能夠戲弄，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不算過得太無趣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "蛤？",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_026"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n妳也不想想被強迫要陪妳亂的我該如何是好！？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘻嘻。",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然怎樣都可以，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但下次",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "找個別的地方來訓練吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n畢竟拉比林斯達也還沒醒來……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n若不小心傷到了她，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就不好了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "睡得太多似乎會害死腦細胞的樣子呀，",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以才好心特別故意在附近打打鬧鬧，看能不能把她給吵起來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話又說回來這個據點，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實在小過頭了根本沒有能訓練的地方。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "別出去外頭，",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_029"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "還被這樣叮嚀了勒。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啊～啊，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "明明好不容易能夠逃出那王宮的地下監獄了。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "結果，還是得窩在這濕冷的洞穴裡啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過我們，",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應當還得再追加上件逃獄之罪，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n照這來看被人給通緝也是理所當然的嘛。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在事情稍稍緩和點前，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們也只能在這裡給人家添麻煩了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別總是說些任性的話了，",
        "unit_id": 107111,
        "voice": "vo_adv_2008003_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就好好享受難得的逆境嘛……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "好啦好啦。",
        "unit_id": 190711,
        "voice": "vo_adv_2008003_032"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳這傢伙不論何時何地都很能享受欸，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "某方面讓人真羨慕勒。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘻嘻。",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這感覺還真奇妙～",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我竟然會和這些傢伙在一塊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再加上",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基和拉比林斯達，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也在同個屋簷下一起生活呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n若是以前的我，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "根本沒有辦法想像呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎，隨便了。",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n{player}你們幾個，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟我來吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n帶你們見見拉比林斯達吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯，",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來吧來吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然因為克莉絲提娜她們打得太誇張，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n弄得地面到處都是殘破碎石了就是，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "小心一點別被絆倒囉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你可是相當重要的存在呢，",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果受了傷可就不好啦。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯嗯？",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為什麼不好好聽人家的話啊……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是叛逆期喔？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是嘛，",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "本來我們和你就是敵對的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算失去了記憶，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對我的那警戒心，說不定還留了一點下來。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是這回事？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是因為克莉絲提娜她們的訓練太猛烈了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n導致腿軟了所以才動不了嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才這點程度就嚇傻了可不太妙欸。",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那兩個人，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還只是在鬧著玩而已呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這樣真的沒問題嗎～？",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真讓人擔心啊……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "振作一點呀，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "主角。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105913,
        "voice": "vo_adv_2008003_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然曾聽聞過幾次這個名字，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但拉比林斯達這號人物究竟是？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n昨晚，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當我們剛造訪這據點時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎也沒有機會拜會到她。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "簡單說，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是祕密社團【拉比林斯】的頭頭唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對你們來說，也是個沒辦法視而不見的重要人物吧，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以別忘了好好去認清楚人家的長相喔。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且，",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "究竟拉比林斯達和『晶』有多麼的一致……，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n又還能夠記得多少之前的事情，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n她究竟是為了什麼目的而行動，這些全都還是個謎。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『晶』……？",
        "unit_id": 105913,
        "voice": "vo_adv_2008003_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個名字在下還有一點印象，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若沒記錯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是『七冠』之一？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦。",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n已經追查到了『七冠』這個名字了啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們幾個。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過嘛，",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟在這個世界中，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這是個不能無視的存在嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n再怎麼樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也不可能完全沒有關聯呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎，都好。",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也說過好幾次了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉比林斯達處於休眠狀態，所以也沒辦法講上話。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n趕緊去看一看她長什麼樣子，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就一起去吃早餐吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "至於詳情，",
        "unit_id": 106112,
        "voice": "vo_adv_2008003_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晚些我再一塊解決就行。",
        "unit_id": 106112
    }
]