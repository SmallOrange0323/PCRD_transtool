        "type": "background",
        "background": "501510"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊！",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真的！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這裡原來是",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "通往舞台的近路。",
        "unit_id": 121311
