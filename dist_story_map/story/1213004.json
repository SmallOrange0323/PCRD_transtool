        "type": "dialogue",
        "name": "胡桃",
        "words": "有好多",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "美味的食物呢♪",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那麼，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你要先吃一會再走嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我先繫好繩子，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "免得你跑太遠。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們也",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "稍微休息一下好了。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "妳在看哪……",
        "unit_id": 121311
    },
