        "voice": "vo_adv_1213004_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我雖然有上過舞台，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但還是第一次",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "坐上觀眾席。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "舞台上",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "看起來原來是這樣子的……",
