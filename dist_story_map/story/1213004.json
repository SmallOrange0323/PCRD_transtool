    {
        "type": "dialogue",
        "name": "牛",
        "words": "哞──"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "話說回來，",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "今天天氣真好……♪",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n牧場的",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "空氣很新鮮，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "而且天空晴朗無雲，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "讓人捨不得離開這裡。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "今天的工作",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "差不多到這裡結束了。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n太陽下山後",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "把牛牛帶回牛舍……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n１、",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "２、",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "３……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥、",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n牛牛少了一隻！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "剛剛本來還在這裡的，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "最小的那隻……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "牛牛、",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "牛牛！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n你跑到哪去了呢……？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "看得見的範圍內都沒有……",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那邊的柵欄……",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "該不會",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "壞掉了吧？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們去看看吧。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……這裡",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "日照充沛，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "長了很多牧草。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n牛牛來這邊吃草，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "似乎是因為想吃更多",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以才移動的。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果牠在這裡吃草……",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那應該會往這邊走。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "腳印有留下來哦，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你看。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "找到牛牛了！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "太好了……",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還以為你不見了。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這樣不行哦，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不可以突然跑掉。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "牛",
        "words": "哞──"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "想吃這邊的草嗎？",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呵呵！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想也是。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這裡有油菜、",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "三葉草",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "和蒲公英。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n開滿春天的花朵，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還有很多鮮嫩的牧草。",
        "unit_id": 121311
    },
