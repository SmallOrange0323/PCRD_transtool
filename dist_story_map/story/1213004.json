    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好大的花束……！",
        "unit_id": 102131,
        "voice": "vo_adv_1213004_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這是",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "送我的嗎？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎麼辦？",
