    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過我很高興",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "自己選擇挑戰！",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "其實",
        "unit_id": 102131,
        "voice": "vo_adv_1213004_027"
    },
