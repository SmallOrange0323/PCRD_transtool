    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "比從舞台上往下看",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還高了不少。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "而且",
        "unit_id": 121311,
        "voice": "vo_adv_1213004_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有點刺眼……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……！？　",
        "unit_id": 121311
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
