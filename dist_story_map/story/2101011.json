    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "終於，",
        "unit_id": 191111,
        "voice": "vo_adv_2101011_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "終於，\n你們跨越到『全新的可能性』了。",
        "unit_id": 191111,
        "voice": "vo_adv_2101011_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謀略之星，",
        "unit_id": 191111,
        "voice": "vo_adv_2101011_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "已然殞落。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是故黑暗，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "於世界降下了全新之影。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "天選之人們，",
        "unit_id": 191111,
        "voice": "vo_adv_2101011_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n究竟能否繼續向前邁進？",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n亦或是，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "又得回頭重新來過？",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "然而我所能做的，",
        "unit_id": 191111,
        "voice": "vo_adv_2101011_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就只有",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "靜靜地守望著而已——",
        "unit_id": 191111
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "早呀♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "早，",
        "unit_id": 106414,
        "voice": "vo_adv_2101011_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哈嗚～♪",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您醒過來了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然只有一下下，但你睡著了唷。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "方才你冷不防就趴倒在地了，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "著實令人嚇了一跳……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啊。",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說你啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是喔，",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那就好……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你又稍微更能說話了嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "言語的遣詞談吐，",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又再更精進一步了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真是太棒了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了……！",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n欸嘿嘿，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "照這個進度，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "應該馬上",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就能變回那個帥氣的騎士先生了呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳說的沒錯。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟還是希望{player}",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是個能夠守護我們背後的存在嘛……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生，",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你還很睏嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……還是說，",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您正想要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n將夢到的夢境回想起來呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噓。",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n稍微安靜一下可蘿仔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有人過來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚～？",
        "unit_id": 106414,
        "voice": "vo_adv_2101011_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是腳步聲呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n男人有",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "五個人……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "豪紳議長，",
        "unit_id": 4312,
        "voice": "vo_adv_2101011_023"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "請往這裡！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哎呀，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_024"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "真是的……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "真是充滿霉味的地方啊！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n我的高級靴子可都弄髒了……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噁，",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……咳咳！",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_026"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n很好很好，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "看來你們似乎很安分呢，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "反賊們！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你是剛剛，",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在廣場的時候帶走佩可小姐的那個人……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若沒記錯，",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是被稱呼為豪紳的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一位貴族的人士？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "沒錯。",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_029"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n我乃",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "蘭德索爾貴族議會議長，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "豪紳侯爵！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼……",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說你是議長啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真那大人不在之後的混亂中，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你混得還算挺不錯的嘛……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哦呀哦呀？",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_031"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n我還想會是誰，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "這不是以『前陛下』的肚裡蛔蟲自居的",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那隻獸人女孩嗎？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n妳又為何會在這樣的地方呢？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎樣啦，",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在那邊假惺惺！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你這人，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在我開庭時的旁聽席上一直偷笑對吧，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我全都記的一清二楚啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哼哈哈哈哈。",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_033"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n在飼主消失以後，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n這可終於被送到該送到的地方了呢，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "妳這隻獸人女孩。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "野獸果然",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_034"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "還是在籠子裡最合適了呢。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "在擁有悠久歷史的王宮中，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "竟然讓有獸臭味的獸人到處逛大街，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n在當時我就非常的不是滋味了啊！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這傢伙……！",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太過分了……！",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就算不用",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "講成那樣也……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚～！",
        "unit_id": 106414,
        "voice": "vo_adv_2101011_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……過去，",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "曾從真步小姐口中聽聞過。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來此人，便是擁有典型蘭德索爾貴族思想的人物……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n的模樣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……豪紳議長，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望你能聽我們一言。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n方才，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你雖然稱呼我等為反賊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然而此處沒有任何一個人，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有做出過那樣的行為。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對呀！",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n像這樣把我們關進了牢裡，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定是有什麼誤會！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯沒錯！",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓貪吃佩可……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓尤絲蒂亞娜來跟我們說說！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那樣的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "三兩下就解決了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哼哈！",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_042"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n繼前陛下之後，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "這次是打算向尤絲蒂亞娜陛下諂媚了嗎？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "看來對掌權者搖尾巴是妳最擅長的事了呢，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "妳這隻獸人女孩。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說什麼！",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n先不說陛下，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我對貪吃佩可才沒有搖過什麼尾巴啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "很好很好！",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_044"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n那麼就沒有",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "讓尤絲蒂亞娜陛下",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n特地親臨如此汙穢場所的必要了呢。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "更不用說，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_045"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "陛下本來就是繁忙之身。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "做為蘭德索爾的議長，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "豈能讓陛下因為此等",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "雞毛蒜皮小事而耽誤了政務。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "沒錯……",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_046"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不過是對你們這些貨色",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n降下制裁之類的蒜皮小事……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n靠我與【黃金之手】的部隊就足夠了！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "制裁……！？",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等等，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望你別如此擅自主張！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "更何況，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們沒有任何該被逮捕的理由，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n方才不就講過了？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "瞧妳這話！",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_049"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n就是因為「有些什麼」所以你們這些傢伙",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "才會被送進這個大牢啊。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "通緝犯",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "與其賊黨！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "通緝犯……！",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你講的那個人，",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是我對吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那你說在這裡頭，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底又有誰是啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那就是……",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那就是？",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_053"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那就是，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_054"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "妳。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n龍人族的女孩子。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……雪菲？",
        "unit_id": 106414,
        "voice": "vo_adv_2101011_055"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "喔喔。",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_056"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "沒錯。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n妳似乎被稱為雪菲呢。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "原先雖然被預想是一名單獨犯，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "但沒想到竟有如此多的夥伴啊！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你說雪菲",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_057"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是通緝犯……！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "沒錯。",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_058"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n罪狀是",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "『暗殺王族未遂』。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "暗、",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_059"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "暗殺王族未遂……！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這種事，",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_060"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一定是你們哪裡搞錯了！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雪菲她，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼可能",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "做得出那樣的事情！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對呀～！　",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_061"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管是這傢伙還是{player}，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都和嬰兒沒兩樣……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不論是寵物的妖精，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是掉到地上的東西都往嘴裡塞，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n他們現在可是只有這種程度的智能啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "『現在』的話，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_062"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "或許是這樣沒錯。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那麼……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "若是說半年前呢？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……？",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "半年前……",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是如此，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那便是霸瞳皇帝仍健在的時期。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也意味著是雪菲小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n尚未與在下等人相遇前之事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……那麼，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若雪菲真有",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n『暗殺王族未遂』此一事……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "便表示，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她是以霸瞳皇帝為目標嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被這麼一講……",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真的有過呢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下的暗殺未遂事件。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但當時我出了城外，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以詳情我也不是很清楚……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "照這樣講的話！",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_067"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n如果對霸瞳皇帝出手了就算有罪，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那們我們不就也——",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呣咕！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳等等，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和！　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜、",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_069"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n為什麼妳要塞住我的嘴巴呢？　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "打倒了霸瞳皇帝的人，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是貪吃佩可和王宮騎士團的士兵們……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對一般人",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這樣告知的，妳忘了嗎？　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_071"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對耶……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "比起引起騷動，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而導致我們冒險者的工作變得困難，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n還倒不如把我們的名字給隱瞞……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "最後好像是這樣決定的嘛。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_072"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n並且，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對我們個人來說是如此……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而在那場決戰之中，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還有【動物苑】的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真琴和香織兩位在場。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她們兩位獸人族的人，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n如果被曲解成打倒了蘭德索爾的統治者的話……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或許會演變成戰爭，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或是什麼棘手的狀況也說不定。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是呢……",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_074"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一直以來都沒有什麼感覺。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但看到了像是那個貴族一樣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼討厭獸人的人之後……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就不覺得這只是想太多了而已呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那邊，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_075"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "妳們在講什麼悄悄話！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n是在討論如何推卸責任嗎！？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不是呀，",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_076"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不是那麼一回事呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對啊，",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_077"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "倒不如說正好相反",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的感覺……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……嗯？",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_078"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "算了。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n你們能找什麼話來推卸責任，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "大概都不難料想……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "「前陛下是篡位之王，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_079"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "所以是無罪的才對。」之類的。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "「而且，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "這個龍族的女孩子又不是我們的同伴。」之類的……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "差不多就這類的說詞吧。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "然而，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_080"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n入侵王城之罪。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "破壞公物之罪。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "傷害士兵之罪……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n這些罪狀是不會因此消失的。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "更何況，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_081"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "這個龍族的女孩子與她的賊黨，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n也沒有人能夠保證",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不會再次企圖要刺殺王族。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n因此，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不由本人來對你們降下制裁可不行啊……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼這樣！　",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_082"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣也太強硬了……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哪有什麼強硬不強硬！",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_083"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "我身為一名顯貴紳士，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "若不好好保護公主‧尤絲蒂亞娜陛下！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不好好保護這個國度，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那怎麼可以！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "【黃金之手】部隊，",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_084"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "上箭！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n穿過這監牢的欄縫，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "把這群逆賊，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "用那正義之矢予以制裁！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "——是！",
        "unit_id": 4312,
        "voice": "vo_adv_2101011_085"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什……！",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_086"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、",
        "unit_id": 106012,
        "voice": "vo_adv_2101011_087"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你打算在這裡直接處刑我們嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就連開庭都沒有……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哦？",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_088"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "妳希望有個審判嗎？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那麼就在此處，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "開一個公平的簡略法庭給你們吧！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "陪審團【黃金之手】的各位！",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_089"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n你們的意見是！？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "有罪！",
        "unit_id": 4311,
        "voice": "vo_adv_2101011_090"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "有罪！",
        "unit_id": 4312,
        "voice": "vo_adv_2101011_091"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那麼判決！　",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_092"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "有罪！　",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "死刑！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n刑罰為死刑！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n即刻執行死刑！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "是！",
        "unit_id": 4311,
        "voice": "vo_adv_2101011_093"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n立即執行！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "住、",
        "unit_id": 100111,
        "voice": "vo_adv_2101011_094"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "住手呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗚，",
        "unit_id": 100311,
        "voice": "vo_adv_2101011_095"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼做才好……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！？",
        "unit_id": 100211,
        "voice": "vo_adv_2101011_096"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2101011_097"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您退下！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "噠嗚～！",
        "unit_id": 106414,
        "voice": "vo_adv_2101011_098"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "——放箭！！",
        "unit_id": 191411,
        "voice": "vo_adv_2101011_099"
    }
]