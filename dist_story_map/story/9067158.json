        "voice": "vo_adv_9067158_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞什麼嘛，那些刺蝟們！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還很有精神耶！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是的。",
        "unit_id": 126013,
        "voice": "vo_adv_9067158_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n而且……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "正在拖著若菜小姐。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想逃跑嗎！？",
        "unit_id": 105811,
        "voice": "vo_adv_9067158_011"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "噫呀啊啊啊！？",
        "unit_id": 130111,
        "voice": "vo_adv_9067158_012"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n告、",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "告辭了～！",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不愧是能當車輪用的刺蝟……",
        "unit_id": 125813,
        "voice": "vo_adv_9067158_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n好厲害的速度。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼。",
        "unit_id": 106011,
        "voice": "vo_adv_9067158_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒關係啦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種雜碎跟雜碎魔物",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "隨時都能打倒。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本不用追也……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……那個，",
        "unit_id": 126013,
        "voice": "vo_adv_9067158_015"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "凱留小姐。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我們那些",
        "unit_id": 126013
