    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……雖然看起來是因為",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "遭到自己夥伴的爆擊而重創……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
