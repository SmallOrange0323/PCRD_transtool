        "voice": "vo_adv_9067158_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼了嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_9067158_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我說刺蝟啊，",
        "unit_id": 105811,
        "voice": "vo_adv_9067158_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然小小的……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽說很好吃耶。",
        "unit_id": 105811
