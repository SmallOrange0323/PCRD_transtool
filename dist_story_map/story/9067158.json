    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後這麼大一隻的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不曉得會多有飽足感……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可、普蕾西亞",
        "words": "流口水。",
        "unit_id": 1,
        "voice": "vo_adv_9067158_007"
    },
    {
        "type": "dialogue",
        "name": "刺蝟型魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 50311
