[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～今天也是好天氣呢……♪",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這麼舒服的下午，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就該什麼也不做無所事事的躺著啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊啊",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太棒了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n【伊麗莎白牧場】……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真想一輩子都生活在這裡。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼啊",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要站在那裡啦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n陽光不都被你遮住了嗎。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難得我心情很好，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n正在曬太陽的說？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……啊？",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒錯哦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是鈴。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "隸屬於叫做【哞哞自衛隊】的公會，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "現在外派到這個【伊麗莎白牧場】來。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然沒什麼人知道，但兩邊好像是類似於同盟，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有著合作關係的公會呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "由於收到了守衛牧場～的委託，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以【哞哞自衛隊】派遣我過來。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，我是沒什麼幹勁整天無所事事啦……",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為牧場，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "非常和平嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就算我不特別戒備，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也沒什麼問題。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "比起這件事。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你，找我有什麼事情？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你在做送信的工作對吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "然後今天，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n特地送來這座山上的牧場？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那還真是，辛苦你了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好好的認真工作很偉大呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是模仿不來的呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔嗯……",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為有寄給我的東西，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以你在找我？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以一開始才問了我的名字對吧～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為要下山到城鎮很麻煩，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以我常常使用郵購呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說我訂了什麼貨呀，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n橡子禮盒組之類的？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我非常喜歡哦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "橡子……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不是郵購的商品，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是信件？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "誰寄來的呢。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我即使在城鎮時也足不出戶，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n可沒什麼認識的人啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是媽媽嗎……因為她很愛操心，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n常常會寫信問我「最近還好嗎？」等等的呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "把信給我吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n謝謝～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "工作辛苦了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是誰寄來的信件呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那是什麼反應……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n到了這個年紀了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還稱呼母親叫媽媽很奇怪嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然像小孩子撒嬌一樣很害羞，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但我最喜歡媽媽了嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為媽媽住在城鎮裡，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以我們已經一陣子沒見面了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只有這點，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "與其說是有些寂寞，也許該說是不滿吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀算了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就叫你給我信啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，謝謝。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我看看，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是誰寄來的信……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……呃，是【哞哞自衛隊】寄來的信。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是什麼呢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有種討厭的預感。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真不想讀啊……",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳的牧場優雅生活結束了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "回到城鎮來～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如果是像這樣的通知我該怎麼辦呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真討厭啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我明明打算一輩子都住在這裡的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "名字是？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔嗯，{player}？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然很抱歉，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但這封信能幫我隨便扔在某個地方嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……不行？",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼至少能代替我讀信嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有你作為緩衝的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不管寫著多麼殘酷的內容，我也不至於即死！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為喪失記憶所以讀不了字嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那是，真的嗎……？",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n一定很辛苦吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我不太明白。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那就沒辦法了呀。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我只好瞇著眼睛，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "自己讀信了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚……",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n上面寫著，要我下山一趟到城鎮裡做活動匯報，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n順便到【哞哞自衛隊】的據點露個臉。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真討厭啊，好麻煩。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_042"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n只是要匯報活動的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n明明不用特地到鎮上，寫信就能解決了不是嗎……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我說，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}也這樣覺得吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀算了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_044"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n看來也不太像緊急傳喚，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在被催促之前就無視好了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "即使因此被【哞哞自衛隊】給開除，",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也是沒辦法的嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣一來的話。",
        "unit_id": 102611,
        "voice": "vo_adv_1026001_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我要做的就只有重新加入【伊麗莎白牧場】，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n成為這邊的人就好了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是絕對，",
