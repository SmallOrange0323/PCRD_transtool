[
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼、",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是強悍！",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這個人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "，口氣明明如此平穩，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "動作卻非常的迅速！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要一個不小心，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就馬上會敗下陣來了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果在這裡敗下陣來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所有的計畫就都前功盡棄了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了未來！　",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了伙伴！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能夠再次和最喜歡的人們",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起圍在餐桌旁！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕不會在這裡輸掉……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "意外地挺能撐呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是真的很想救出妳的友人呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我實在不想繼續欺凌一個乖孩子了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望妳能早點放棄",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "趕緊去睡覺了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不！",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就寢的時間還早得很，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正因為是乖孩子所以不會就此睡去！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就算這樣也得逼妳去睡，",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "儘管難過但這是我的職責。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然很可憐。",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳再繼續掙扎下去的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n察覺到這騷動",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "的其他衛兵們也會趕到。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是一群對妳們沒有任何想法的傢伙們，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會毫不猶豫的把妳們殺了吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "畢竟入侵『王宮』可是大罪，",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像那樣的應對可是極為正常的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而我的意思是時間已經到囉，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不會再手下留情了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到剛才為止，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然都只是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "手下留情……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉了呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_010"
    },
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀啊……！？",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哎呀，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "糟了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n出手的方向有點弄錯了呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n結果讓那孩子往地下監獄的方向滾下去了啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "下去回收她，",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然後再把她綁起來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "任務就完成了。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……。",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……嗚，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚咕。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從樓梯上摔落後，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有幾秒的時間",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "失去意識的樣子。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不妙！　",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "腳步聲慢慢接近了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是名為純的那位騎士追過來了吧！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得趕緊起身擺好架勢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做出應對才行！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還沒",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完全失去希望！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人在這廣大的世界裡相遇，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才不是為了在這種地方迎來終結！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣沒錯吧，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的各位！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可……",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘿",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "醬……？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下從那樓梯上摔落……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道是福是禍，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "掉進了地下的監獄裡頭了呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而在一旁的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是囚禁著貪吃佩可小姐的牢房！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊、",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下一直都好想見您……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多麼狼狽不堪，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您竟然會變成這副模樣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您美麗的長髮、",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "衣物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都已如此髒亂不堪了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是天地不容的惡行，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對誓死抗議到底！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝。",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然從似似花那裡，",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有簡單的聽說過了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們大家，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的來救我了呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼亂來……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿才是，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳這不是傷痕累累了嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣不行唷～",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要更愛護自己一點呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果身體有哪裡傷到了，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是沒有辦法打從心底去享受美食的喔。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那才是最悲慘的唷，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "遠比我現在這樣還要慘喔。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明那樣就好了，",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把我的事情全部忘記了也沒關係呀。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是連想都沒想就衝了出去，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "傻傻的被人家給抓到了喔。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對我無言以對，",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "放著不管，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最後再把我忘記就好了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果妳們還願意偶爾想起我，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就覺得很幸福了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，以前",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像有一起吃過飯的那個，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "名字記得好像是，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "念起來好記又可愛的那個，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總是肚子餓得咕嚕咕嚕叫的",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個小貪吃佩可……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這綽號是小可蘿替我取的呢。",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常喜歡喔……♪",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n別、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "別再勉強自己說話了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在就讓您從裡面出來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算要把這鐵柵欄破壞掉。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很遺憾，",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那是不可能的唷。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就順便連妳一起捉起來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n然後和{player}少年一同扔進大牢裡吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇呀？　",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到處都沒見到主人的身影，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我忘了我還把他丟在路上呀……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣可不行～",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這陣子",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "似乎莫名的迷糊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總是做些迷糊的事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人他，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎還保有一命……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的樣子呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣就安心了，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過眼前的現況依舊不樂觀。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人他因失去意識倒地不起，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而在下又滿身瘡痍，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐則",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還在牢中。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而【拉比林斯】，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與食客的大家……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n則是為了破壞那個洗腦魔法裝置，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正努力不懈、奮勇向前吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會像是童話故事一般，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n於在下等人處於危機之際，正巧現身救援吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "洗腦？　",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊這麼說來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確還有那樣的裝置呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『王宮』勢力的那些人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來很有可能是被洗腦了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此純小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n她才會連對主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也絲毫不留情面的嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不……",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許只是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相當看重",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自身職責的人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也說不定。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "純小姐",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算受到洗腦，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n依舊是對在下等人的性命，有所顧慮的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一位溫柔之人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以的話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不想在這種情況與您相遇。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好了。",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我想妳們也都已理解現況",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "，雖然都講了很多次",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但就在這裡結束吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "上頭……",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "從長廊上",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "傳來著大量的腳步聲，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我想大概是我的部下們，察覺到了騷動",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正火速趕來呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不會再讓妳繼續拖延下去了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓我趕緊收拾吧。",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "201100401"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不！",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下直到最後一刻為止，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕不會放棄！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論是多麼絕望的狀況，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要發生了奇蹟就有辦法解決！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而在下的主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是能夠引發那種奇蹟的人！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下如此深信著，",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為此侍奉於主人左右！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n儘管最初是因為愛梅斯大人所託付，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是現在……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是出於真心！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是不明事理的孩子呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……那麼就沒辦法了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "講不聽的孩子，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只能動手來教訓了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n拜託妳快逃吧，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算只有妳一個人也好！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的事就不用管了，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我怎樣都沒關係了啦！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才不是怎樣都沒關係！",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n每次每次您都像這樣淨說些傻話！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您就別再說了，貪吃佩可小姐！",
        "unit_id": 105911,
        "voice": "vo_adv_2011004_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就算是在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "偶爾也是會生氣的呀！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呀啊！",
        "unit_id": 105813,
        "voice": "vo_adv_2011004_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總是很溫柔的小可蘿",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然發火了……！？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感情還真好呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2011004_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但妳們真的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "搞清楚狀況了嗎？",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "end"
    }
]