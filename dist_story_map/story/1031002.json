[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，{player}。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好久不見。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喔，小伙子！你看起來還蠻有精神的嘛！",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_001"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n趕快去死一死吧！！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，不可以突然說那麼粗魯的話。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那樣很沒禮貌的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哼……我才不想和小伙子扯上關係呢。",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n和男人說話的時間是人生最大的浪費！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "明明就已經死了……",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，我父親原本是傑出的靈媒，",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "工作時因為失誤，結果變成了現在骷髏頭的樣子。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "即使他已經死了，靈能力還是很強，",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以現在也繼續在做驅邪之類的工作喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也經常幫忙父親，",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n像今天接下來我們也準備去驅邪。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "最近好像在同一個地方經常出現幽靈，引起了一些騷動。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們接到了好幾件類似的委託，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以決定到目擊現場看看。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不管是一件還是好幾件，都隨便啦！",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_009"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我會接下這個委託……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是因為聽說幽靈是「美女」！！！",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸……",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_011"
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有好幾件目擊情報的地方就是這裡。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，幽靈好像是晚上的時候比較容易出現，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我們等一下吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不必擔心喔。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我父親和我一直都在做驅邪的工作，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而且從來沒有失敗過。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "到目前為止我們收到的委託，全部都解決了喔。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……除了讓我父親變成骷髏頭的事件以外就是了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不必擔心喔。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為我父親是靈媒，驅邪對他來說是易如反掌，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而且一直以來我也幫忙好幾次了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請你先回去吧。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也不曉得今天會不會運氣好碰到幽靈，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n在這裡會很無聊的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……你要一起等等看？",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這樣呀。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那就請你躲在這裡等吧。",
        "unit_id": 103111
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……………………",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，好像有東西來了！那個是……",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「…………」",
        "unit_id": 101821,
        "voice": "vo_adv_1031002_020"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喔喔！美女出現了！",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_021"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這次的委託真是棒呆了！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n喂──！幽靈小姐────！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n如果爸爸趕快幫忙驅邪那倒也是沒關係……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「好，做得很好。」",
        "unit_id": 101821,
        "voice": "vo_adv_1031002_023"
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "好、好痛──！這、這傢伙怎麼回事！？",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_024"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n難道不是幽靈嗎！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是幽靈？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這、這麼說起來……",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_026"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n最近好像聽說，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n有人型魔物在附近出沒的傳聞……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，那種魔物被稱為「闇影」……",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "難不成這就是闇影嗎？原來不是幽靈，是魔物呀？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「呵呵，適合我嗎？」",
        "unit_id": 101821,
        "voice": "vo_adv_1031002_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n「好，趕快繼續囉──！」",
        "unit_id": 101821
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n「要小考囉。」",
        "unit_id": 101821
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "呃啊！糟、糟糕……不是幽靈的話驅邪就沒用了！",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_029"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n忍！總之我們先逃跑吧！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「你得再更有禮貌一點。」",
        "unit_id": 102821,
        "voice": "vo_adv_1031002_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「好像很好玩──！我也要我也要！」",
        "unit_id": 102321,
        "voice": "vo_adv_1031002_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還、",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有其他這麼多闇影！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，我們被包圍了！怎麼辦！？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}你趕快自己逃走吧！",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為你和這次驅邪一點關係也沒有……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我來當掩護！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我太大意了……",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}你本來還為我擔心的……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在讓你捲入這個麻煩真是抱歉……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「好癢喔。」",
        "unit_id": 101821,
        "voice": "vo_adv_1031002_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "糟、糟糕，攻擊從後面過來了！",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀啊────！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "！",
        "unit_id": 103111
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}！",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你、你沒事吧！？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "竟、竟然傷害了{player}……！",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我絕對饒不了這些闇影！",
        "unit_id": 103111
    },
    {
        "type": "still",
        "still": "103100201"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我絕對會守護這個人！",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n喝──────！！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 101821,
        "voice": "vo_adv_1031002_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "打、打倒牠了？我……變強了？",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不對，更重要的是下一個闇影……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n喝──────！！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 102821,
        "voice": "vo_adv_1031002_042"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼、呼、呼……",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這樣應該全部都打倒了吧……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍、忍！好厲害喔！",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_044"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n想不到妳打倒了這麼多魔物！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n真不愧是我的女兒！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不。不是的，爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_045"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n剛剛拼盡全力的是{player}喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "什麼？小伙子不是只在旁邊呆呆地看著……嗎？",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_046"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n小伙子，你怎麼滿頭大汗的？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然不知道那是魔法還是什麼……",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_047"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不過{player}讓我的力量增強了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對吧，{player}？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "……這把劍可以提升忍的能力？",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_048"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我雖然無法相信……但這次也只能相信了。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過相對地，{player}也會變得很辛苦對吧？",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_049"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n在我戰鬥時，你一直看起來很痛苦……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你，{player}。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_050"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哼──每次小伙子都陪著驅邪的話，",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_051"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我就可以很悠哉……而且也能降低忍的危險……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n管他小伙子是會很辛苦還是很痛苦，怎樣都沒差……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔！等等！",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_052"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n可是我不能接受小伙子待在忍的身邊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這一點需要想想……真讓人苦惱……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸……",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_053"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n如果你對{player}說些沒禮貌的話，我不會原諒你的喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咿！忍好恐怖！！",
        "unit_id": 2411,
        "voice": "vo_adv_1031002_054"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，今天真是謝謝你了。",
        "unit_id": 103111,
        "voice": "vo_adv_1031002_055"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n下次換我來守護你。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我一定……一定會守護你的。",
        "unit_id": 103111
    }
