    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美食的國際博覽會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「蘭德索爾國際博覽會」閉幕數日後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾的眾多人民齊心協力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "努力重建。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在這些人當中──"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咻。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼～～～～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的居民１",
        "words": "陛下──！",
        "unit_id": 1411,
        "voice": "vo_adv_1383002_001"
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的居民１",
        "words": "這邊的瓦礫",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的居民１",
        "words": "也拜託您清除了──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的居民２",
        "words": "這邊倒下的樹也是！",
        "unit_id": 4911,
        "voice": "vo_adv_1383002_002"
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的居民２",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的居民２",
        "words": "為了方便搬運，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的居民２",
        "words": "請幫忙折斷──！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～！",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我知道了☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿～♪",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然一開始",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還被客氣地說",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「不敢麻煩陛下」，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但現在就如你所見！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "勝利的「耶」☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然是因為靠瓦礫雜技，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "展現了即戰力的關係嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「打工獲取信賴法‧",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "第一天就展現能力」，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真是效果顯著呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……還有，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「皇家裝備」的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這頂皇冠的力量。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然在貪吃劍折斷的狀態下，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想使出「火力☆」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會有",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "困難，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但要是沒有這件裝備，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就無法發揮力量。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "近期會找時間去修好它，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過當務之急是重建蘭德索爾。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "軟軟的肉…………",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在被克蕾琪塔小姐發現之前，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也要努力減肥才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再這樣下去，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "衣服全都要重新製作了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可滿臉羞紅。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n──在她背後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "黏著大大的膠帶。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這件事"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "要回溯到幾個小時前──"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咻。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼～～～～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你也一起幫忙的話會很有幹勁呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿──",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_013"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嘶啦！"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咻…………",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n稍～～微",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來這裡一下……",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我變胖了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！？",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可以這樣盯著女孩子的身體看喔？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然跟男生說這件事也很奇怪……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是我最近",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "穿衣服",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就覺得好緊喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子附近",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "稍～微",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有點令人在意。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛才的聲音……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是背後",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的衣服縫線……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊！？",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可以這樣盯著看啦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為至今為止",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都沒發生過這種事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我想原因大概是我的貪吃劍……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "平常我吃的食物",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會成為它的糧食，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但它現在斷掉了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就沒辦法進食。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "結果，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是這軟軟的肉。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然遲早會想辦法解決，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但克蕾琪塔小姐說過。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「時間",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是金錢」，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在最要緊的是重建蘭德索爾，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓大家恢復日常生活！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是從木匠師傅那裡借來的膠帶，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "給你。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實這捲膠帶，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是連裂開的岩石都能黏住的強力道具。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以請你",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "用這個",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "幫我黏住背後的縫線嗎。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}。\n那麼，",
        "unit_id": 105812,
        "voice": "vo_adv_1383002_026"
