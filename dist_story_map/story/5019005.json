    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "他一定能打起精神的。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雨吉？",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_039"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_040"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是雨神大人。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那是人家幫他取的暱稱～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "鈴奈，",
        "unit_id": 110111,
        "voice": "vo_adv_5019005_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳見到雨神大人了？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對啊，",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_042"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "剛才見到的，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "他好像沒什麼活力。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦！？　",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_043"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那麼重要的事情妳要先說啊！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈哈哈，",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_044"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "抱歉抱歉。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "美咲做的甜點太好吃了，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我整個忘得一乾二淨！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那樣的話，",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_045"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也沒辦法嘛……！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "然後啊，",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_046"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我聽說好像還有",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "另一個精靈。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_047"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "島上的人",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像沒說耶？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也記不清楚了～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小伊緒妳記得嗎～？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是啊，",
        "unit_id": 110111,
        "voice": "vo_adv_5019005_048"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那時候",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我只聽到雨神大人的名字。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是，",
        "unit_id": 110111,
        "voice": "vo_adv_5019005_049"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳的確聽到他說",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還有另一個精靈吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們請村長先生過來，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "詳細的詢問一下吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "鈴奈，",
        "unit_id": 110111,
        "voice": "vo_adv_5019005_050"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在等村長先生過來時，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n能不能告訴我，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你們聊了什麼？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好！",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_051"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "請問",
        "unit_id": 511,
        "voice": "vo_adv_5019005_052"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "有什麼不便之處嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "村長先生，",
        "unit_id": 110111,
        "voice": "vo_adv_5019005_053"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "抱歉勞煩您過來。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n話不多說，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們不是要問雨神大人，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而是想問關於晴神大人的事情？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "你、",
        "unit_id": 511,
        "voice": "vo_adv_5019005_054"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "你們從哪裡知道那名字的！？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "看你的反應，",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_055"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "似乎蠻可疑的呢。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不、",
        "unit_id": 511,
        "voice": "vo_adv_5019005_056"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不是……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鈴奈說她和雨吉見面，",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_057"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "直接聽他說的喔。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雨吉是",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鈴奈幫雨神大人取的暱稱。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n順帶一提，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個晴神大人的",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "暱稱好像是晴吉喔。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好了，",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_058"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要坦白就趁現在！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n快點說你到底隱瞞了什麼！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "怎麼會……",
        "unit_id": 511,
        "voice": "vo_adv_5019005_059"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n沒想到……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "妳會直接見到雨神大人，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "還聽說了晴神大人的事情……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "祕密瞞不下去了呢。",
        "unit_id": 511,
        "voice": "vo_adv_5019005_060"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "看來",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "拜託鈴奈小姐",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "或許是正確的選擇。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這話什麼意思？",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_061"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "關於那件事，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_062"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我現在告訴你們吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n首先，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "請問各位目前聽說多少事情了？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "說到每年都會舉辦儀式，",
        "unit_id": 110111,
        "voice": "vo_adv_5019005_063"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但今年只有雨吉甦醒過來？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也是！",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_064"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "原來如此。",
        "unit_id": 511,
        "voice": "vo_adv_5019005_065"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n我想原因大概是",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "祈禱的力量不足以讓",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n兩隻精靈都甦醒。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我也不清楚為什麼會聚集不到足夠的力量。",
        "unit_id": 511,
        "voice": "vo_adv_5019005_066"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n我們",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "跟平常一樣，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n祈禱今年也能",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "在夏天時賜與這座島嶼恩惠……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "後來雨吉就一直是一個人生活呢。",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_067"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "他看起來好難過，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "連人家看了都覺得不忍～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雨吉和晴吉，",
        "unit_id": 110111,
        "voice": "vo_adv_5019005_068"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n是非常要好的朋友呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓他一個人太可憐了……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "是啊。",
        "unit_id": 511,
        "voice": "vo_adv_5019005_069"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n而且，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "現在島上下雨的原因，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n就是因為只有雨神大人甦醒了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "只有雨吉甦醒有什麼問題嘛～？",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_070"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "雨神大人和晴神大人",
        "unit_id": 511,
        "voice": "vo_adv_5019005_071"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "掌管著天氣。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "可是，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "那僅限於他們二位都在的時候。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "若是只有他們任一位，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_072"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "力量將會失衡，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n島上的天氣就會逐漸惡化。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_073"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然會下一陣子的雨，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等夏天結束後，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雨吉又會沉眠了吧？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不是那樣的。",
        "unit_id": 511,
        "voice": "vo_adv_5019005_074"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦咦，",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_075"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還有後續嗎？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "傳說是他會就這樣被那股力量給吞噬，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_076"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n然後失控、失去自我。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "現在",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "雨神大人何時會變成那樣也不奇怪吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "要是他變成那樣，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_077"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這座島上的天氣就會變得狂暴，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "據說會變得無法住人。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦！　",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_078"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不會吧吧吧吧！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "因為，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_079"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "為了島上的未來，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n才企劃了明天的活動，並賭上了一切。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "每年，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_080"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "在這座島的海水浴場開幕日，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "都會聚集很多的觀光客。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我想那樣應該很足夠了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但還是小心為上……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "為了聚集更多的祈禱之力，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_081"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n我才想說找蘭德索爾的知名藝人過來。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "所以，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "跟島上的年輕人徵求意見之後――",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就決定找鈴奈了吧！",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_082"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "是啊，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_083"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "就是如此。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n大家異口同聲的",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "推薦了鈴奈小姐。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "沒想到",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "那樣的名人會願意來我們這樣的小島……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯？",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_084"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n可是啊，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然這樣為什麼你不一開始",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就跟我們說雨吉的事情？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你早點說就好了啊～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "那是……",
        "unit_id": 511,
        "voice": "vo_adv_5019005_085"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我認為不能",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "因為島上的情況",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n給鈴奈小姐造成",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "額外的壓力。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "所以",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "才閉口不提……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但是，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_086"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我利用了你們是事實……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n欺騙了你們，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "實在",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "非常抱歉……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不要緊不要緊！",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_087"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "只要有人家的粉絲，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不管是哪裡我都去！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "的確，",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_088"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喚醒沉眠的精靈，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n還是解決島上的天氣什麼的，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "並不是模特兒的工作……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是如果那樣能讓大家露出笑容，",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_089"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那就算是模特兒的工作！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "鈴奈小姐……",
        "unit_id": 511,
        "voice": "vo_adv_5019005_090"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "……那麼，",
        "unit_id": 511,
        "voice": "vo_adv_5019005_091"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "請讓我再拜託妳一次。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n請妳在明天的活動上，號召聚集的觀光客，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n務必要",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "喚醒晴神大人！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "雨神大人已經到極限了……",
        "unit_id": 511,
        "voice": "vo_adv_5019005_092"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n再這樣下去，這座島上",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "將不在有夏天……！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好！　　",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_093"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "交給我吧！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我會讓哭泣的雨吉",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "露出笑容的！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "而且，",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_094"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "來這座島上的",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不是只有人家！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "當然囉！",
        "unit_id": 110211,
        "voice": "vo_adv_5019005_095"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "受到我的美貌吸引，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n再怎麼不情願也一定會甦醒的！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "交給我吧！",
        "unit_id": 110111,
        "voice": "vo_adv_5019005_096"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "身為老師，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我會保護大家的。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也拜託了！",
        "unit_id": 110011,
        "voice": "vo_adv_5019005_097"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我很期待喔！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人在弄清楚島上的天氣與工作邀請的真相後，\n重新打起了精神，準備起明天的活動。"
    }
]