[
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──啊！？",
        "unit_id": 100211,
        "voice": "vo_adv_9006526_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n光之精靈",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "消失了……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是……！",
        "unit_id": 100111,
        "voice": "vo_adv_9006526_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n彌勒的能力，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "魔力無效化！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，真是的，",
        "unit_id": 106011,
        "voice": "vo_adv_9006526_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙的能力",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然很棘手……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……但是，",
        "unit_id": 105911,
        "voice": "vo_adv_9006526_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和之前不同。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來並非",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所有的魔法或強化都會被消除。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這到底是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "原來如此！",
        "unit_id": 106411,
        "voice": "vo_adv_9006526_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n因為不能完全停止索爾魔珠的功能，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以演算無效化是有限制的！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此☆",
        "unit_id": 105811,
        "voice": "vo_adv_9006526_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟對方只剩一顆索爾魔珠了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然如此，",
        "unit_id": 100312,
        "voice": "vo_adv_9006526_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是好機會……！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "趁現在",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連續進攻吧！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n即使部分攻擊遭到無效，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也要攻擊到對本體造成傷害！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "「好！」\n「嗯！」",
        "unit_id": 1,
        "voice": "vo_adv_9006526_007"
    }
]