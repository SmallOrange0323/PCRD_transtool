    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──泰美斯銀嶺‧地下某處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那裡有位女性，為了恢復而陷入沉睡。"
    },
    {
        "type": "background",
        "background": "501620"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……嗯……",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……在米奈娃的安排下",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "復活的這副身體……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n雖然很緩慢，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但甦醒的周期正在縮短。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n力量開始逐漸恢復……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "當然，",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "性能還遠遠不及我身為世界管理者的那個時候。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n但這不是問題……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我絲毫不想",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再次回到",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個時候。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "更重要的是……",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只要像這樣",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "持續恢復……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我遲早能夠離開這座城堡。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然後",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "與騎士先生",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一起生活……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這樣的未來",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "或許也會到來……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果帶著這樣的心情，",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再次入睡……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n一定能夠夢見，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不同於以往的開心夢境。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……你說對吧，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……？",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有某人的",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "氣息……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這種封閉的地方，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能夠來的人有限。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……莫非是──",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎──",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "厄～",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "莉",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "絲♡",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n來～～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "玩～～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "吧♡",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──光之壁啊。",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊啊～",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "突然就展開護盾，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "反應也太冷漠了吧～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……回去。",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "討厭～",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "至少和我聊一聊嘛～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n話說，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先把護盾解除吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果不解除，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就用龍之殞滅！連同城堡",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "毀、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "掉、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唷♪",
        "unit_id": 106711
    },
    {
        "type": "still",
        "still": "220900401"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳來做什麼……",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "遠野帆稀。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n該不會……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是因為曾經被我打倒過，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而來復仇的？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣的話，",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳來得正是時候。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我現在",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有與妳戰鬥當時那樣的力量。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n妳應該能輕鬆地成功復仇吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過……",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "當然的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我也會盡全力",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "來抵抗。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "討厭啦～",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是的，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳別這麼快下定論啊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我來這裡的理由，",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在一開始就說過了吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "玩～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "吧♡",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……無法理解。",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n再說妳應該很恨我",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "才對吧？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳說",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我恨妳，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該是有誤會呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當然，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我對自己最喜歡的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「原本的《阿斯特朗傳奇》」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n被人改寫掉的這件事是有不滿……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過這",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好像也不是厄莉絲的責任？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n當時",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真要說的話……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的心態比較偏向",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "身為一個遊戲玩家，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n想挑戰看看",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不可能打贏的遊戲Boss吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然最後輸掉了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就算如此。",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這也不構成妳來找我玩的理由。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦～？",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "厄莉絲和我已經經歷",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "交朋友過程中的那種互動了嘛？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……啊？",
        "unit_id": 129011,
        "voice": "vo_adv_2209004_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我說，",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是那個啊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n在河邊互毆之後，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "兩人眺望著夕陽，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n「你",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還挺行的嘛」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「哼，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你也是啊」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "的情節。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳不知道嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊～",
        "unit_id": 106711,
        "voice": "vo_adv_2209004_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抱歉抱歉，",
        "unit_id": 106711
    },
