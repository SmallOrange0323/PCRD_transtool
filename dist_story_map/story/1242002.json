        "type": "dialogue",
        "name": "母親",
        "words": "請等一下。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n希望妳能告訴我妳的名字！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我的名字不重要。",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_071"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "祝你們一家",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "幸福美滿。",
        "unit_id": 124212
    },
    {
        "type": "background",
        "background": "500025"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呼，",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_072"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "想不到自己會見證到",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這超乎想像的一幕。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能夠幫上忙真是太好了。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……呵呵。",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_073"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……？",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_074"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為寶寶的體溫還殘留在手上。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我從沒抱過",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_075"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小嬰兒。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我一直以為我這雙手是用來守護王宮，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "打倒王室之敵的手……",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……當我抱著那名孕婦奔跑時，",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_076"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n完全不知道該對她展露什麼樣的表情，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該說些什麼話。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，我從少年你身上",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "找到了答案。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "首先，",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_077"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你曾對我說要露出笑容，對吧？",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然，",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_078"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "表情也很重要。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，當時那名孕婦",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為太痛苦而雙眼緊閉，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以我就在想，這次",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或許不是因為表情的關係。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即便如此，多虧了你，",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_079"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還是讓她得以放下心來。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你知道為什麼嗎？",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為你還為她做了一件事。",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_080"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你當時",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_081"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很溫柔地握住了",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她的手。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_082"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為你很自然地就這麼做，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以根本沒察覺到吧。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真是個心地善良的少年。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……比起話語和表情，",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_083"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有時手的溫度，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或許更能傳達出心情。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想這應該沒錯。",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_084"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n連聽不懂話語的嬰兒",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也感受到了我的心情。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_085"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖說這也是結果論，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我很慶幸自己沒有穿著平時的鎧甲。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "若是戴著厚重的手甲，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我大概也沒辦法感受到人的溫暖。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "！！",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_086"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……不，",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_087"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話不能這麼說。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對我而言，家訓是絕對不能違背的。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……希望",
        "unit_id": 124212,
        "voice": "vo_adv_1242002_088"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "施加在我身上的變裝魔法能盡快解除。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "純轉過身背對著{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不讓他察覺到自己臉上略顯哀傷的笑容。"
    }
]