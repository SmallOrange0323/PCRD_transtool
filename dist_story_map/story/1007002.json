[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在散步的時候……"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "那邊的人給我站住！",
        "unit_id": 711,
        "voice": "vo_adv_1007002_000"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "你……很可疑耶？非常非常地可疑。",
        "unit_id": 711,
        "voice": "vo_adv_1007002_001"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "為了處罰你所以判你死刑！",
        "unit_id": 711,
        "voice": "vo_adv_1007002_002"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "\n如果不想死的話――",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "就把布丁交出喲～！",
        "unit_id": 711,
        "voice": "vo_adv_1007002_003"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "\n你不交出來就是死刑來的～",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "\n快拿出布丁喲～！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "你、你怎麼知道宮子附身在這個人身上來的！？",
        "unit_id": 711,
        "voice": "vo_adv_1007002_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯～已經露出馬腳的話也沒辦法了～",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子這次只好放棄了喲～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咻………………",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_006"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天――\n{player}買完東西之後――"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611,
        "voice": "vo_adv_1007002_007"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "呀──！\n有魔物！？",
        "unit_id": 411,
        "voice": "vo_adv_1007002_008"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "牠跑去那邊了！",
        "unit_id": 311,
        "voice": "vo_adv_1007002_009"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "\n站在那邊的人，危險啊！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "呱歐──我要吃掉你喲！",
        "unit_id": 1611,
        "voice": "vo_adv_1007002_010"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "\n不想被吃掉的話就交出布丁來的～！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "…………",
        "unit_id": 1611,
        "voice": "vo_adv_1007002_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚……還以為穿上魔物的玩偶裝，",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n就能騙倒你了……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為什麼你知道是宮子呢～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊！",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n說起來",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}你是所謂靈感很強的人來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是因為那樣才知道是宮子的嗎！？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "…………",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "失、失敗來的～！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚～～奪取布丁作戰失敗來的～……",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n可是宮子還是很想吃布丁的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……既然這樣只好使出殺手鐧喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那就是附身到你身上喲～",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嘿，看宮子的～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "耶～成功了喲～！",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這樣宮子就能隨便操控這傢伙的身體來的～！",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "用這傢伙的錢去買布丁來的～",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_018"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n能買多少就買多少喲～！",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這是一場布丁盛典喲～♪",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁店老闆～！",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n從這一頭到那一頭所有種類的布丁都拿來喲～♪",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "錢不成問題來的～！通通拿來──！快拿來喲～♪",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯～？",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這傢伙拿著什麼東西呀？",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是商店的袋子……裡面是什麼來的～？",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，是布丁來的～！",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_021"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哇，宮子根本不需要來買的～",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這傢伙正好有布丁來的，真是賺到了喲～嗯哼～♪",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……咦？",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_022"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是為什麼這傢伙拿著布丁呢？",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n總共有兩個布丁和兩支湯匙來的～",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊！宮子想起來了，",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_023"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我們約好要一起去玩的……",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……這該不會，是要給宮子的吧？",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_024"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "…………",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_025"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯～",
        "unit_id": 100011,
        "voice": "vo_adv_1007002_026"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子不要附身了～",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你就是你喲～",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_027"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "振作一點～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這裡看起來有幾根手指頭來的？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……藏在衣服裡面所以看不到？",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_028"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "很好很好，你很正常來的～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "才、才不是喲～！",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_029"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子遠比你",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "更有魅力來的～！\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "噗――――！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子擅自附身到你身上真是抱歉喲～",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_030"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吶吶，那個布丁……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "果真是為了宮子買的嗎？",
        "unit_id": 100711,
        "voice": "vo_adv_1007002_031"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "耶～是布丁來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n我們一起吃吧～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和{player}一起開心吃著布丁的宮子，\n感到心滿意足。"
    }
]