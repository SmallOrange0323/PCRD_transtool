[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對晶甚感好奇的諾維姆，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定要向同為七冠的變貌大妃探聽她是個什麼樣的人。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "似似花，",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我問妳。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n妳覺得",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "晶她是個",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "什麼樣的人啊？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我知道她好歹是七冠，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "所以很優秀。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "沒錯，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_001"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "無能之輩是沒辦法擔任七冠的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n她有著出眾的才華，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "也具備持續專研的毅力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是喔～",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "她果然很厲害嗎！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n那麼，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "妳們成為敵人以前，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "妳很尊敬",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "跟信任她囉？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "不，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_003"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "並沒有，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "一點也不會。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "如果要排不能信任的七冠排名，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n她毫無疑問地是第一名。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……是喔……",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_004"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "妳好像有話想說？",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_005"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不，",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_006"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "沒什麼。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "她那裡讓妳無法信任？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "在能力方面不是沒問題嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n詳細告訴我吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "她跟周遭人的溝通相當有問題。",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_007"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n舉例來說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "跟她確認工作進度，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "她只會回「普通」。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "問她和合作廠商交涉起來感覺如何也是",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_008"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "「普通」，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n確認處理客訴的結果也是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "「普通」，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "叫外賣的時候，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "看了菜單也是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "「普通」……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "總之她祕密主義到家，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_009"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "從不透露自己的情報。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "但儘管如此，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "她所提出的成果卻總是「最棒」的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "可疑之處實在太多了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "不可能信任她。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "與其說是祕密主義，",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_010"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我覺得她只是在敷衍回應而已……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "算",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "了，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我知道似似花有多辛苦了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n順便問一下，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這種八卦還有多少？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "這個嘛，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_011"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "請稍等一下。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "我應該",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "有把她對我的折磨，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n記錄在文件檔裡……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "還、",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_012"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "還有建檔喔！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n妳也太會記仇了吧！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "這樣的話，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_013"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "妳就和晶在同一間辦公室共事看看吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "只要配合她的突發奇想，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "睡個幾天晚上的睡袋，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n妳應該就能理解我的感受了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "唔，",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_014"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這我可能不太想……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "但是，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "最後妳還是有陪她，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n不就代表妳們關係不錯嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "……不知道為什麼，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_015"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "每當有其他成員在工作上陷入困難，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n她就會不知從哪聞訊前來協助。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "所以，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "我也不是沒有受過她幫助。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "我從不覺得我們關係很好，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_016"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "但欠著人情不還",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "感覺也很差。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "我們之間",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "只是盡最基本的道義……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "就只是這樣而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "哦哦！",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_017"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "感覺",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這樣的關係很酷耶！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n既然這樣，與其記錄埋怨她的事，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "留下這種互相幫助的回憶，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n不是比較不火大嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "……我和她，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_018"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "已經是敵人了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "現在才去緬懷過去，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "也不會改變現狀。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "也是……",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_019"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "抱歉。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "因為",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "看妳講起來好像很高興，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我就脫口而出了。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "換個話題吧。",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_020"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n妳只要記得，晶是七冠裡祕密最多、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "最不值得信任……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "是個十分可疑的女人就好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這樣啊，",
        "unit_id": 106114,
        "voice": "vo_adv_5111605_021"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我知道了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不過，要論可疑，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "似似花果然也……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "啊。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "……剛剛妳好像有要說什麼，",
        "unit_id": 107011,
        "voice": "vo_adv_5111605_022"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n似乎，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "是對我有些看法，是吧？",
        "unit_id": 107011
    },
    {
