    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "人、",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_000"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "人……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "好多……！",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "請請請問，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "今天的目的地",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "真的是這裡嗎……？",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "充、",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_001"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "充滿陽光般的壓力感覺比平常還強……！",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "明明是生日，為什麼我會",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "在這裡……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "呃，",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_002"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "咦、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "咦？",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "在對面的是……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n幸運鼠跟、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "怪怪鼠！？",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n為、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "為什麼",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "命運樂園的孩子們會在這……！？",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "是、",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_003"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "是嗎！？",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我平常不會靠近這一帶，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "所以不知道……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "啊啊，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "大家果然都很可愛……♪",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "咦！？",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_004"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "不不不不不、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "不可能啦！",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "不、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "不是的，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我其實很想過去，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "但",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "像我這樣的陰沉角色，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n若要衝進那個人群中，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "就需要心理準備……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "……可、",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_005"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "可是……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "恕、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "恕我僭越，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "畢竟今天是我的、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "生日。",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "只是一下下的話……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我靠近、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "也沒關係吧……？",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "哇！？",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_006"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n等等、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "等一下～！！",
        "unit_id": 125631
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "呼……",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_007"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "大家都好可愛……♪",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n說、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "說今天是我生日，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "他們還跟我一起拍照，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n為我慶祝……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "鼓起勇氣真是太好了……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "那、",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_008"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "那個，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "今天真的很謝謝你……！",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "你事先就調查了",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "今天的活動吧。",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我、",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_009"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我剛搬來時從沒想過，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n竟能迎來這麼快樂的生日……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "這一切，",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "都是多虧了這個人……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "吧。",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "謝、",
        "unit_id": 125631,
        "voice": "vo_adv_4010223_010"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "謝、",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "謝謝你……！",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "那個……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我會一──直珍惜",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "今天拍的照片的！",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n因為這是我",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "在這座城市收到的第一份生日禮物……",
        "unit_id": 125631
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "嘿嘿。",
        "unit_id": 125631
    }
]