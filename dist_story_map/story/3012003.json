[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由莫妮卡率領的\n【純白之翼 蘭德索爾分部】\n正面對著至今不曾遇過的危機──"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……有件事情我實在無法接受。",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "挑食是不好的呦。",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我果然還是該準備一下",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n餐後的甜點嗎……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒錯，果然還是需要甜點……",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "──",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才不是咧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我想講的話才不是這個。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對於我們未來的公會活動",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我想要提出些問題。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "公會活動不是進行地很順利嗎，\n",
        "unit_id": 100811,
        "voice": "vo_adv_3012003_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳有什麼不滿呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……對呀。多虧了公會活動的福，",
        "unit_id": 104511,
        "voice": "vo_adv_3012003_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我們才能夠在這邊享受料理呢。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳們這些人呀，",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是不是搞錯了什麼事情。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "冒險者公會本來的目標是打倒強大的魔物、",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n提升等級，為求能在緊急狀況時守護百姓，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而不斷磨練自己的功夫。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是像我們這樣從早到晚，",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n都只埋頭在採集方面的委託裡，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不就沒辦法達成原來的目的了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "欸～可是呀～",
        "unit_id": 100811,
        "voice": "vo_adv_3012003_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n人家我，不想參加激烈的戰鬥。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是傷到這美麗的身體可就糟糕了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……如、如果是植物系魔物的話",
        "unit_id": 104511,
        "voice": "vo_adv_3012003_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n我還蠻想戰鬥看看的……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻、嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "空花，",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "注意一下自己儀態啊。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妳的口水流到菜裡頭了。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哎呀！",
        "unit_id": 104511,
        "voice": "vo_adv_3012003_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對、對不起……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "知道就好。",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_015"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，妮諾不可以呦。",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那是增加辣度的醬汁……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "科科科，妮諾對於這種程度的辣，",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n當然是完全沒問題的……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我吃。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好、",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好辣呀！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以我就跟妳說啦……",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、我馬上拿水過來。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……你們這些人，",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n到底為什麼會想加入公會呀。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下也告誡她們幾句吧。",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是的，閣下實在太過寬容了。",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "連閣下都這麼說嗎……",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咳咳……總之呢，",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "明天我們要在普拉諾平原實施特別強化訓練！",
        "unit_id": 105311
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天──"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哈……哈……",
        "unit_id": 100811,
        "voice": "vo_adv_3012003_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "汗水淋漓的我……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n怎麼會這樣性感又美麗呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……嗚，發現疲累到無法動彈的空花後，",
        "unit_id": 104511,
        "voice": "vo_adv_3012003_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n妳打算盡情玩弄空花是吧！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻、嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在腰部綁上一條長長的布，然後快跑讓布不要碰到地面！",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻趴趴趴！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……我們難得到這幾乎不會出現魔物",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_028"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n的草原裡好好進行訓練……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……這群傢伙們有心想要認真做嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂喂，妳們再開玩笑的話，",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_029"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我可要追加訓練菜單囉。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_030"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，怎麼了……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這不可能的吧……",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_031"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這個地方可是──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "哇呀！？",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_032"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是、是魔物耶！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼一回事！？",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_033"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這種強力的魔物，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n應該不會出現在這邊才對呀──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊！話說回來……",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_034"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n由於不遠處的森林之主最近消失了，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n所以這附近好像變得會出現強力的魔物了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳說什麼！？",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_035"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……如果真是這樣的話，就是我的判斷錯誤了。",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_036"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我居然會犯下這種錯……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不過，在這邊懊惱也無濟於事。",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_037"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "大家注意！我們先撤退吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n現在的我們並沒有勝算。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，遇到魔物也完全不緊張的我……",
        "unit_id": 100811,
        "voice": "vo_adv_3012003_038"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼會這麼帥氣又可愛呢！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "現在不是講這種話的場合！",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_039"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不快點逃跑的話可是非常危險的。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒問題的。",
        "unit_id": 100811,
        "voice": "vo_adv_3012003_040"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我呀，可以魅惑大部分的魔物。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是吧？你不會襲擊我吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好、好厲害！",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_041"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n牠從雪身邊逃跑了！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過那個方向可不妙呀！",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_042"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "空花，魔物要跑到妳那邊了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "當空",
        "unit_id": 104511,
        "voice": "vo_adv_3012003_043"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "、空花被魔物襲擊時……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生突然出現，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對空花說『妳知道該怎麼回禮吧？』──",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "奇、奇怪了……",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_044"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n魔物從空花身邊逃開了？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……雖然不知道怎麼一回事，",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_045"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n似乎牠判斷不該跟空花扯上關係……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過那個方向是！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大家為什麼一直大聲叫呢？",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_046"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是在辦祭典嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可惡，沒辦法了。",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_047"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n既然這樣就只好由我來……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，拜託你掩護我了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妮諾，魔物出現了！",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_048"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n妳快趁我擋住牠時逃走──！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咦？魔物？",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_049"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "──啊，莫妮卡小姐",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n妳別過來這邊。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "魔、魔物消失了！？",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_050"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "發生了什麼事呀！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是……地洞陷阱？",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_051"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……真是太危險了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我差點就跟魔物一起掉進去了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……啊啊，我本來打算用來捕獵晚餐的陷阱",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_052"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這下就派不上用場了……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個魔物，可以吃嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、那個……",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_053"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我想牠應該不太適合食用……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "姆姆姆……",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_054"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n讓妮諾晚餐泡湯的罪可是非常重的。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "覺悟吧！",
        "unit_id": 103011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……哼，",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_055"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我又砍了些",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n無聊的東西呢。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不過呀，這到底怎麼一回事。",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_056"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然說是偶然，但她們居然打倒了",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那個兇惡的魔物。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大家，好厲害呢。",
        "unit_id": 105511,
        "voice": "vo_adv_3012003_057"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯哼",
        "unit_id": 103011,
        "voice": "vo_adv_3012003_058"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要我出手的話\n就是這麼簡單。",
        "unit_id": 100811,
        "voice": "vo_adv_3012003_059"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "奇、奇怪了……",
        "unit_id": 104511,
        "voice": "vo_adv_3012003_060"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n魔物跑到哪裡去了？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "或許，這些公會成員們，",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_061"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "身上擁有非常棒的潛在能力",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n也說不定……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不過這麼一來，",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_062"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我終於能送個像樣的報告回本國了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "太棒了！",
        "unit_id": 105311,
        "voice": "vo_adv_3012003_063"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "太棒太棒了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n哈哈哈哈！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "原本充滿不安的【純白之翼 蘭德索爾分部】\n的未來\n似乎也出現了一絲的希望──"
    }
]