    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "明明很不幸",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "卻很幸福……？",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這是什麼感覺……",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好可怕。",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好像會上癮啊，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好恐怖喔，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊！",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里，振作一點！",
        "unit_id": 124111,
        "voice": "vo_adv_5106322_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那不是真的。",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那些幸福或不幸",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都不是茜里的感受！",
        "unit_id": 124111
    },
