        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是同時……",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "自己內心好像",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也被剝奪了……",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "明明很幸福",
        "unit_id": 124011,
        "voice": "vo_adv_5106322_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "卻很不幸……",
