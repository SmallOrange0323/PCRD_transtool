        "name": "貪吃佩可",
        "words": "我結束撒嬌了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若再繼續說喪氣話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是會被小凱留罵的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果大家來幫忙我的話。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n各種事務好像都能很快解決呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且有時間的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還可以盡情邊走邊吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你應該知道我的食慾很厲害吧。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是為了食物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是會非常非常麻煩大家哦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是……",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我自己一個人可以做到的事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有很多呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "必須要把那些事一個一個地解決，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n直到我遇到無法獨自解決的問題時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到時候…………",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就會順從",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你的好意，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請大家幫很多很多的忙。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們解決問題之後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家再一起享用美味的魔物料理吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "失禮了。",
        "unit_id": 1,
        "voice": "vo_adv_1804001_067"
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "\n我來幫您打掃了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "那個，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "咦？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}快躲起來……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "………………",
        "unit_id": 1,
        "voice": "vo_adv_1804001_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈……",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被發現了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}他\n什麼壞事都沒有做唷，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以不要逮捕他……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "尤絲蒂亞娜大人。",
        "unit_id": 1,
        "voice": "vo_adv_1804001_071"
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "\n我明白您正值花樣年華，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "\n但身為王女，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "男女單獨二人共處一室，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "實在是不太好唷。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………咦？",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_072"
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "但向上面報告",
        "unit_id": 1,
        "voice": "vo_adv_1804001_073"
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "情況變得麻煩就不好了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "\n我會當作什麼都沒看見，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "請兩位多聊一下吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "\n但請不要過頭了唷。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非、",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "那麼，",
        "unit_id": 1,
        "voice": "vo_adv_1804001_075"
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "我",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "僕人長",
        "words": "先去打掃其他地方。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "走掉了……",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_076"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們會被那樣看待呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但看起來真的是那樣呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_077"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在對你來說還有點太早了呢……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_078"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們好像還可以多聊一下呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能再多陪我一下嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_079"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再多聊一會兒",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再回去吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可表面雖維持平靜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但雙耳早已染得通紅。"
    }
]