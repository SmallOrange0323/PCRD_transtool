[
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "忙著善後【憤怒‧軍團】接二連三襲擊的貪吃佩可，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n會在公務空檔之際，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n到王宮附近偷偷地享受短暫的歇息。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_000"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "沒有異常，",
        "unit_id": 711,
        "voice": "vo_adv_1804001_001"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "嗯。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n回守衛所吧——",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……呼。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總算離開了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "守衛巡邏很嚴謹，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身為王女應該要感到高興才對，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是這麼森嚴的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想躲開守衛耳目也是樁苦差事～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想趕快找個安靜的地方休息呀。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了讓自己合乎王女的舉止，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "整個肩膀都僵硬了呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好想盡情活動身體。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要去捕獵魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後做成料理，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最後再吃掉……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔！？",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n又是守衛嗎！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？　{player}？",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太好了～～…………",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你怎麼會出現在這裡！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "有人的聲音……？",
        "unit_id": 711,
        "voice": "vo_adv_1804001_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "　那裡！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "　有誰在那裡嗎！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　負責守衛的人回來了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快躲起來！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "……",
        "unit_id": 711,
        "voice": "vo_adv_1804001_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好久不見呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能看到你有精神的樣子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是高興呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你到底為什麼會出現在這裡呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛好是我發現你所以才沒事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒有許可就闖進王宮，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有可能會被逮捕的哦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難不成，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你明知有危險但還是要來見我嗎……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀呀，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來你只是迷路呀……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種情況就算是說謊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也要回覆「對呀」才可以喔？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過嘛，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "誠實也是很重要，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你果然還是這樣繼續保持下去吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣啊。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知不覺……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那你絕對是迷路了吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "……是錯覺嗎？",
        "unit_id": 711,
        "voice": "vo_adv_1804001_017"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n等等回到守衛所，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "還是慎重一點請求加派人力吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，已經沒事了，可以出來了唷。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖說沒事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但只要繼續待著，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺就會引起騷動，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然希望你趕快回去，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是要你自己回去應該有些困難吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿和小凱留",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也不在附近的樣子……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了！",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　等我王女的工作結束後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就送你回公會小屋吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在那之前可以答應我會機靈一點嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很棒的回答。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了不讓王宮的人發現你，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n去我的房間吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請保持安靜唷。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我有充分掌握巡邏時間",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以應該沒有問題，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是剛剛守衛說要增派人力呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來有確實答應我要變得機靈呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝你。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然沒想到會變成這種情況，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過真高興能見到你。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "獨自一人很寂寞呢。",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為王宮的人會很緊張，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以沒辦法邀請大家過來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管是王女的工作",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或是眾多的會議，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要是有益的事我都很樂意執行，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是不規律的吃飯時間讓我很受不了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "王宮的料理雖然好吃，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是還要試毒和講求形式真的很麻煩。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真希望能和你們一起自由自在地",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "享用魔物料理～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開玩笑的，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不應該說這些呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了守護【美食殿堂】和【破曉之星】的大家，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我必須要和豪紳們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "持續努力交涉才行！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不行，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "顧著聊天結果守衛又要過來了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快點到我房間吧。",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好了，",
        "unit_id": 105812,
        "voice": "vo_adv_1804001_031"
    },
