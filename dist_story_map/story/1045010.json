        "name": "空花",
        "words": "這是……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "什麼意思……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "如果虐待狂先生",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_077"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "願意讓空花覺得痛苦，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花是樂意之至……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_078"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "戒指？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_079"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "莫非",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是這個戒指……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "因為空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "只要跟虐待狂先生在一起，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就會不由得興奮起來，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n進而觸發詛咒是嗎……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這種事……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_080"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "明明就不在意啊。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是真心在為空花著想……？　",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_081"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "原來",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是這樣啊。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_082"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "太過自我中心了。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n都沒有考慮到虐待狂先生的心情，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "總是",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "自顧自地享受快感……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……太……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_083"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "太好了～～～！",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_084"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還以為自己被虐待狂先生討厭了，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n害得空花連嘻嘻嘻和流口水都沒心情……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_085"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你為什麼不跟空花明說呢？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n只要把話說清楚……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不對……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_086"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "想想也是呢。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n就算虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "叫空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「不要靠近你」",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n只要像這樣在路上看到你……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花應該還是會忍不住湊過來吧。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "畢竟",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_087"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "把空花的一切都摸透了。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_088"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花明白了，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "會把這個「詛咒的戒指」拿掉。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_089"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不想讓你擔心。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "所以，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_090"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就是……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你可以……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "跟空花一起",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "去尋找拿下戒指的方法嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "再次",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_091"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一起……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……呵呵♪",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_092"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "噢嗚……！",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_093"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "沒事的，",
