    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "空花在洞窟深處取得了戒指，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但戴上之後卻怎麼樣也拿不下來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不僅如此，那枚戒指還會對空花施以強烈刺激。"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "啊啊，",
        "unit_id": 4911,
        "voice": "vo_adv_1045010_000"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "之前告訴妳那件事的確實是我……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "但想不到",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳還真的把它給找出來了，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "而且",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "還戴在",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "手上……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花聽說有刺激性，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就不禁──",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "噫！",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "又酥麻起來了～！",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "現在全身顫抖～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "……我說空花，",
        "unit_id": 4911,
        "voice": "vo_adv_1045010_004"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳真的不要緊嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "人家都說那東西",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是「詛咒的戒指」。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n連我們這些做魔導具生意的人",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "都不敢去碰它啊。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不知道……",
        "unit_id": 4911,
        "voice": "vo_adv_1045010_005"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "畢竟在這之前應該沒有人曾經戴過它。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n我猜上頭八成是",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "被施了什麼麻煩的魔法。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "總之，",
        "unit_id": 4911,
        "voice": "vo_adv_1045010_006"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我也會",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "再跟同業打聽看看的，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n妳就先安分點，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "盡可能不要觸發詛咒吧。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n也不知道還會發生什麼事。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好、",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好的……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「給我安分點……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我不會害妳的」，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "把空花壓在牆上──",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "流、",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "流口水……♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n不可以啦虐待狂先生，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在這種地方～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "無言地盯著空花看……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那種冰冷的眼神",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好讚……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻～♪",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_011"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "話說回來，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這個戒指果然被詛咒了呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "而且",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好像是在空花心跳加速的時候",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "詛咒就會發動……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要是就這麼",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一直戴著它的話，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花不知道會有什麼下場呢～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖說是詛咒，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但這點程度的疼痛",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對空花而言是獎勵……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呃不是，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是沒什麼大不了的，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n那麼也就不必急著找到辦法把它拿下來吧……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對了，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n今天要去討伐稀有魔物嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "聽說",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那種魔物",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好像會噴出一種，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n只會溶解衣服的",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "奇怪液體……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要是不慎被那種液體噴到，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花就會變成見不得人的模樣～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n然後，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生就會緊盯著空花說：",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「布料還沒溶光光不是嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "再去給牠多噴一點──」",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "噫啊啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "又開始酥麻了～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "而且",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "感覺比先前更加強烈……♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好驚人的攻勢……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是的，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "宛如虐待狂先生的猛攻一般……♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……咦？",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_022"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你怎麼了嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n幹嘛突然退開……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為什麼要離開空花身邊～？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦……？",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_024"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n……奇怪，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_025"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "跑走了。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "發生什麼事了嗎……？",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──隔天。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "只會溶解衣服的魔物",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還真厲害……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "被折磨得好慘喔……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "只有空花一個人實在沒什麼心跳加速的感覺……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "果然",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還是要有虐待狂先生在身邊才行。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個背影！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一想到他人就出現了，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不愧是虐待狂先生～！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生～！",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_029"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生，",
        "unit_id": 104511,
        "voice": "vo_adv_1045010_030"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你今天有空嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
