[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "話說，",
        "unit_id": 109911,
        "voice": "vo_adv_6017110_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "有一種調味料",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "叫做美乃滋――",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "蘭德索爾也有這種調味料嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呵呵，",
        "unit_id": 109911,
        "voice": "vo_adv_6017110_001"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我喜歡美乃滋，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過還不算美乃滋迷。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "美乃滋迷，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "若沒有美乃滋",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就會受不了吧？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n因為昴就曾經變得很奇怪。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "原來如此，",
        "unit_id": 109911,
        "voice": "vo_adv_6017110_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "難不成它其實是很知名的調味料？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這樣昴",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就不用忍受戒斷症狀之苦了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯……",
        "unit_id": 109911,
        "voice": "vo_adv_6017110_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "如果沒有的話",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就請拉姆製作好",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "在蘭德索爾推廣好了？",
        "unit_id": 109911
    }
]