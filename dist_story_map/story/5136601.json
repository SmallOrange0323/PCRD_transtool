[
    {
        "type": "background",
        "background": "501322"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ある異変が静かに進行するランドソル。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nムイミは謎の少女との接触のあと、異様な感覚に襲われていた。"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "う～ん……",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_000"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "さっきからなんか頭がぼうっとする……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "街で起きてる異変と関係あるのか？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_001"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "だとしたら、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ちょっとマズいかもしれないな……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nアタシまであんなふうになるっていうのか……？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "にしてもなんなんだ、",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_002"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "この感覚……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "どこか温かくて、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "切なくて……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……なつかしい？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_003"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "あれ……？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_004"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nなんか、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "目の前が",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "真っ白に……？　",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……オク、",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_005"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "トー……",
        "unit_id": 106116
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "──っ！？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_006"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n危ない危ない、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "いまアタシ一瞬、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "寝てたか！？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ん～、",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_007"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "なんだ……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "アタシ、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "いつの間に外に……？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "しかもなんか、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "周りがぼやけてる？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "これってやっぱ、",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_008"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "夢……？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nそれにしては、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "意識がちゃんとあるんだよな。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "まぁ",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_009"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "なんでもいいか！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n無理に考えるのはアタシのガラじゃないし、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nとりあえず元の場所に戻る方法を探すとするか！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……とはいえ",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_010"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "目につくものといえば、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "『アレ』くらいなんだよな。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "うん。",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_011"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nやっぱり、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "よく分からない不思議な結晶がいっぱい浮いてる。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "明らかに普通じゃないよな、",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_012"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "この結晶。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "妙な力を感じる気はするけど……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "それよりも不思議なのは……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……やっぱり、",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_013"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "なつかしい気がする。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "でも",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_014"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "こんなものを見たことはないし、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "これ自体がなつかしいというよりも……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nアタシの心に、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "直接……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "話しかけてきてるような？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_015"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "触ってみるか。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "大丈夫だよな？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_016"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n触った瞬間",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ドカーン、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "といったりしないよな？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "オクトーがいたら",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_017"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "「もっと慎重にいこうよ～」",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "とか言ってたんだろうな。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "いや、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "「面倒だから無視しない？」",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "かもしれないな。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ははっ。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "でも",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_018"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ここにはアイツはいない。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nだったらアタシは、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "アタシを信じるしかないもんな。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "じゃあ、",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_019"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "いくぞ……！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "触れた瞬間、結晶は光り輝き、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nムイミの心に懐かしい光景をよみがえらせる──"
    }
]