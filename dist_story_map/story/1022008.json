[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}發現了很認真地，\n凝視著某個東西的依里。"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "盯……",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？你問我在做什麼？",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你看，這間店家呀，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n有在賣很可愛的玩偶呢……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，好刺眼啊……",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n什、什麼！？怎麼回事！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個光跟那時候的一樣！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊、啊啊啊啊！！",
        "unit_id": 102211
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯……",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個玩偶好可愛喔……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇！？原、原來是你啊……",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不要突然叫我啦！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n嚇了一跳呢！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？你問我在做什麼？",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n沒、沒什麼啊！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我才不是想要那個玩偶……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只是……你看，擁有這種玩偶的話，",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n感覺好像比較像個女生……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什、什麼呀，那個眼神！",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我像個女生一樣不行嗎！？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哼，沒差！",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n反正你一定也覺得我，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n一點都不可愛吧！？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "反正在我的房間裡，",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n都是滿滿的遊戲攻略本！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有意見嗎！？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那又怎樣！",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n和你的房間做比較，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n一點都沒安慰到我！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是、是吧！",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n只要有遊戲攻略本，其他都不需要――",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呃，現在是在說像不像女生的問題！",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n和攻略本好不好沒有關係吧！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？想要的話，就去買？",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所、所以我根本沒有說過想要啊……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而且……這個熊寶寶，",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n價格很貴呢……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n實在買不下去……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "蛤？",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你叫我等一下……？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n欸，什麼？你要去哪裡呀！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊啊，真是的……走掉了……",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "到底怎麼回事？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n居然叫我在這裡等……真是太硬來了。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可、可是……",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那傢伙的強勢，總是幫到我的忙，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n有時候我還是得好好道謝才行……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚嗚……還是覺得很害臊啊。",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n要直接說的話，有點……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣的話――",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇！？已、已經回來了？",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n速度好快啊？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你去做什麼了？",
        "unit_id": 102232
    },
    {
        "type": "still",
        "still": "102200801"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸！？",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n玩、玩偶！？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要給我……？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎麼會有這個？",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……從遊戲中心抓娃娃抓來的！？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嘿、嘿……很厲害嘛。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……剛剛我也說了，",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我才不是想要玩偶……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但、但是，既然你給我，我就收下吧！",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那個……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n謝……謝……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "桑葚很軟Q！",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "聽、聽不懂嗎？",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n桑葚很Q……桑Q",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n就是Thank you啦！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什、什麼！？",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你想說這笑話很無聊嗎！？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為什麼說得一點感情都沒有！",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你絕對不是那樣想的吧！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "難、難得我對你說出了謝謝……",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我不理你了！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊、但是……那個，欸……",
        "unit_id": 102232,
        "voice": "vo_adv_1022008_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n總之我會好好珍惜這個玩偶的！",
        "unit_id": 102232
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊～好有趣喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1022008_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n依里真沒有說笑話的天分呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "上次也說過了，",
        "unit_id": 190011,
        "voice": "vo_adv_1022008_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這是按照你和依里的記憶所製作的「夢」唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n請期待下次的「夢」呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1022008_033"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "玩偶……好可愛……",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_034"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯嗯？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這裡是哪裡……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "該、該不會我又和你一起，",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_035"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n傻傻地發呆了吧……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們在街上做什麼啊？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊嗯，對喔。玩偶嗎……",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_036"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？你也做了一樣的夢？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？你要買玩偶給我……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_037"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我剛說了呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我不想要玩偶啦！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是、那個……",
        "unit_id": 102211,
        "voice": "vo_adv_1022008_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你要給我的話，我只好收下了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好啦，快點去買吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是{player}和依里，\n一起去挑選玩偶了。"
    }
]