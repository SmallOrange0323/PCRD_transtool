[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾的聖誕節結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n眾人開始忙於事後的收拾工作。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "──那邊的人！",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大件物品不要一個人搬！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n作業時要確實地和周圍的人做好溝通！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "聽好囉？",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "在收拾完並做好帳之前，活動都還不算結束！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為了不讓陛下幸福的聖誕節泡湯，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n誰都絕對不許出意外或受傷！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……克蕾琪塔小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自從和小律相遇的那天起，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就幾乎沒有休息一直在工作，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天也親臨現場監督收拾工作。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她明明可以把這些後續的收拾工作交給別人，",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自己去休息的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請讓她去做吧。",
        "unit_id": 6111,
        "voice": "vo_adv_5132007_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "和小律分離這件事，她表面雖然看起來不以為意，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n但內心似乎意外地大受打擊。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下！別說了，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳這是在抹黑我啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我只是想把接下的工作負責到最後一刻罷了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再說妳也看到了吧？",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "派對結束後",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n他又從嬰兒的樣子變回了小小的古代遺物。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "說到底，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那根本也不算人類，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我是不可能會對他產生感情的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以說，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那不是分離，而是將東西歸還。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……這樣啊。",
        "unit_id": 6111,
        "voice": "vo_adv_5132007_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "結果到最後",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是將小律託付給特務先生了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道他平安回去了沒……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "哼，",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_010"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "妳很在意那東西的去向嗎？公主。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是當然……",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "特務先生！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們……",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不是已經完成古代遺物的回收工作了嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為什麼還在這啊。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "真是難過。",
        "unit_id": 51011,
        "voice": "vo_adv_5132007_013"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "難得戰友特地來向你們報告後續狀況，",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "\n",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "我認為你們可以再表現得歡迎我們一點。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是少了你們捅出的婁子，我們也不必被迫浪費多餘的勞力和金錢，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒想到你們還敢自稱是我們的戰友，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不禁讓我有點羨慕起你們的膽識了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於小律……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "嗯，",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_016"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "「自律型幸福實現機」在回收後，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "又重新被慎重地封印起來了。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "\n",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "如果沒有出什麼意外，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "那東西大概不會再出現在世上了。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們特地跑來就是想跟我們說這種事嗎？",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是辛苦你們了呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "重點不是那裡。",
        "unit_id": 51011,
        "voice": "vo_adv_5132007_018"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "而是在即將被封印的前一刻，",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "他說了一句話。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "\n他說",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "「克欸依塔」。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_019"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "覺得寂寞嗎？",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_020"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "衣著華麗的女子。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並沒有。",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是，我覺得安心多了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這下事情終於結束了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "說實話，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我還想跟你們求償各項損害的費用，\n還有害我胃痛的精神賠償呢？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但我就選擇原諒你們吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因為我為人寬宏大量。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "妳還真是冷漠呢，",
        "unit_id": 51011,
        "voice": "vo_adv_5132007_023"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "衣著華麗的女子。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那是當然的。",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然過程看起來像是我順勢成為了他的母親，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但他應該是認為",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "比起年輕的陛下，我是更適合當母親的人選，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n基於這種現實的考量",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "才選擇我的吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "不過，說得也是，",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_025"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "「自律型幸福實現機」會本能地選擇渴望得到更多幸福的人，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "\n並實現其幸福。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "\n",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "代表妳就是如此渴望幸福吧。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……你說得還真是過分呢，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但我也懶得否定你了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以我對那孩子沒有抱持任何感情。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我認為……",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個說法",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不太對。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當時",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比任何人都還要早一步趕到小律身邊的人，\n就是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我覺得小律一定明白。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐其實是位心地善良的人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並且配得上母親這個身分。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "特務先生也說了對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小律會選擇渴望得到更多幸福的人。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "照這個說法的話，",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小律一定會",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "選擇我才對。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我是公主嘛，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是無時無刻都在期望國民的幸福喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這麼一說確實是。",
        "unit_id": 6111,
        "voice": "vo_adv_5132007_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小律這次",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變成了小嬰兒的樣子。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他不選擇身為公主的我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而是選擇想讓扮演媽媽的克蕾琪塔小姐獲得幸福，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是理所當然的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "原來如此。",
        "unit_id": 51011,
        "voice": "vo_adv_5132007_035"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "本以為那只是個麻煩的自動機械，",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "\n但卻意外的",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "有人情味呢。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "真有趣。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下……",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_036"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我真是太丟人了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n竟然讓您花費心思，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "理解我到這種地步……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然把自己裝成為了目的不擇手段的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n冷血商人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但其實是一位不做壞事，\n也不會隨便傷害別人的人不是嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "至少現在是這樣。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟妳是個連一名天真的公主都暗殺不掉的大好人。",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那孩子一定也是喜歡上了妳這點☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "太好了呢，",
        "unit_id": 6111,
        "voice": "vo_adv_5132007_039"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您被誇獎了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……這樣的讚美",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "實在是讓我心情極其複雜……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但我姑且就先收下吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "反正所有事情都圓滿解決了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也謝謝特務先生你們",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "特地來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "告訴我們這件事！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "託你們的福，我稍微安心一點了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "真敏銳呢，",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_042"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "不起眼的少年。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "沒錯，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "\n",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "照理來說古代遺物是一種不能讓一般人得知的存在。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "為此，",
        "unit_id": 51011,
        "voice": "vo_adv_5132007_043"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "才有像我們這樣的特務在，",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "\n",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "但其中也有不少案例像這次一樣，",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "導致古代遺物的存在露餡的情況發生。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "如果碰上這種情況，",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_044"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "我們就會竄改該對象的記憶，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "\n將古代遺物相關的情報抹消。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_045"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "難道說……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "沒錯。",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_046"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "反正都要消除了，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "\n所以不管跟你們說多少祕密都不成問題。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "放心吧，",
        "unit_id": 51011,
        "voice": "vo_adv_5132007_047"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "這不會感到任何疼痛，",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "一瞬間就結束了。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "\n",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "好了，",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "是時候道別了。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔……！",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n至少只有陛下也好，請快逃走！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這裡就由我──！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於小律的記憶",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "必須由克蕾琪塔小姐記住才行！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡還是由我──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那個，",
        "unit_id": 6111,
        "voice": "vo_adv_5132007_050"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不是說這個一瞬間就會結束嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "說、",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "說起來……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼事",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都沒發生呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是怎麼回事？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "呼，",
        "unit_id": 51011,
        "voice": "vo_adv_5132007_052"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "真是傷腦筋，",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "特務V。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "看來裝置似乎故障了。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "那還真是令人困擾啊，特務Q。",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_053"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "這樣我們就沒辦法竄改記憶了。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "\n沒辦法，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "回去拿新的裝置過來吧。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "等一下，特務V。",
        "unit_id": 51011,
        "voice": "vo_adv_5132007_054"
    },
    {
        "type": "dialogue",
        "name": "特務Q",
        "words": "可是我們從明天起就開始放寒假了。",
        "unit_id": 51011
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "怎會如此……",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_055"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "因為這個緣故，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "我們會好一陣子無法過來，",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "\n關於古代遺物的事情，還請你們保密。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "我們約好囉，",
        "unit_id": 51111,
        "voice": "vo_adv_5132007_056"
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "戰友們。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "特務V",
        "words": "那麼再見了。",
        "unit_id": 51111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……他們走掉了呢。",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "放過我們一馬的意思嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也有可能是那兩個飯桶真的搞砸了也說不定，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_058"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過算了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那太好了。",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次的聖誕節，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正因為多虧有小律在，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才會變得如此精彩。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "託小律的福，",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才讓我們得以跟身邊的人變得更親近，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "締結了更強韌的羈絆。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對我來說，",
        "unit_id": 105812,
        "voice": "vo_adv_5132007_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個聖誕節本身",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是最棒的禮物了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下，",
        "unit_id": 118011,
        "voice": "vo_adv_5132007_062"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您說的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
