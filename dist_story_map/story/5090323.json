[
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "原來如此……",
        "unit_id": 16011,
        "voice": "vo_adv_5090323_000"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "挺能打的嘛。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "我就認可妳們吧。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "妳們是",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "值得我使出渾身解數的對手。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n接下來我要拿出真本事上了……！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "唔喔喔喔喔喔喔喔！！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔……！",
        "unit_id": 106511,
        "voice": "vo_adv_5090323_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這就是「龍之卵」真正的力量嗎……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這還真是相當不妙呢……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "……那麼。",
        "unit_id": 16011,
        "voice": "vo_adv_5090323_002"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "我準備好要殲滅妳們了……",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n最後，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "我只問一個問題。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "步未。",
        "unit_id": 16011,
        "voice": "vo_adv_5090323_003"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "我對妳的評價真的很高。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "雖然這是不可能的假設……",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "但假設妳打贏",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "我，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n妳今後……",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "打算",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "怎麼使用妳的能力？",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……我、",
        "unit_id": 121511,
        "voice": "vo_adv_5090323_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也不太知道。",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只是……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "想在角落",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "守護我值得尊敬的人……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "守護我重要的人……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣就",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "非常足夠了……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "……",
        "unit_id": 16011,
        "voice": "vo_adv_5090323_005"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "哼哼哼……",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "哈～哈哈！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "真是太無趣了！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n竟然把妳如此出色的才能，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "浪費在那種小事上！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "妳果然",
        "unit_id": 16011,
        "voice": "vo_adv_5090323_006"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "只是個沒用的小角色！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n妳不過就是個配角般的存在，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "步未！！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……也許，",
        "unit_id": 121511,
        "voice": "vo_adv_5090323_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就像是你說的吧……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "步未未！",
        "unit_id": 121611,
        "voice": "vo_adv_5090323_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才沒有那種事，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "絕對沒有！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳才不是什麼沒用的小角色，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我敢肯定！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為步未未妳是超級無敵厲害的……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怪盜啊！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且……",
        "unit_id": 121611,
        "voice": "vo_adv_5090323_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算妳真的是配角好了！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那又怎麼樣！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到時，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳就成為能蓋過主角光彩的配角",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不就行了嗎！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "祈梨……",
        "unit_id": 121511,
        "voice": "vo_adv_5090323_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝謝妳。",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……我已經",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不要緊了！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為我",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "下定決心了！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我要在這裡，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "粉碎賭場王的野心！",
        "unit_id": 121511
    }
]