[
    {
        "type": "background",
        "background": "501200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}等人要離開可可蘿故鄉的前一天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n村子裡的精靈族人們為了可可蘿舉辦了一場歡送會。"
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "這是剛採下來的貴重藥草。",
        "unit_id": 3311,
        "voice": "vo_adv_1155003_000"
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "\n",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "如果在回去路上受傷的話就能派上用場，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "妳就收下吧。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀哎呀，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此貴重的藥草……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常感謝您。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "回蘭德索爾的路那麼長，",
        "unit_id": 6511,
        "voice": "vo_adv_1155003_002"
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "\n藥草什麼的",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "路上隨便都有啦。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "而且",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "那個沒受傷就沒用了嘛。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "比、",
        "unit_id": 6511,
        "voice": "vo_adv_1155003_003"
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "起、",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "那、",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "個……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "更重要的是食物！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "畢竟妳說有個夥伴是大胃王嘛，",
        "unit_id": 6511,
        "voice": "vo_adv_1155003_004"
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "乾糧我也準備了非常多，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "裝到馬車裝不下為止，都帶走吧！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非、",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常感謝您。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐肯定也會非常高興的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可可蘿姐姐！",
        "unit_id": 5411,
        "voice": "vo_adv_1155003_006"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "還有這是剛剛才採下來的水果！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "是我從種子開始種的喔！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會細心品嚐的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n謝謝妳。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這個也拿去吧。",
        "unit_id": 1,
        "voice": "vo_adv_1155003_008"
    },
    {
        "type": "dialogue",
        "name": "成人3",
        "words": "來，",
        "unit_id": 1,
        "voice": "vo_adv_1155003_009"
    },
    {
        "type": "dialogue",
        "name": "成人3",
        "words": "這個。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "成人3",
        "words": "\n只是為了可可蘿而織的帽子喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是、",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然在下一個人返鄉時，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也總是收到許多東西……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這次",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是與主人你們一起回來，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以各位村民，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像也比平常還要更熱忱呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "平常總是",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下照顧主人，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到會在主人面前展現出",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被像孩童般對待、受到照顧的樣貌……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身為主人的隨從，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下感到",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有些不踏實。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然成功完成了精靈的進化儀式，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於村中",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仍算是年幼的一輩。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在周遭自幼照顧在下的",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大人眼中，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仍認為在下還跟小孩或小孫女一樣……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然在下",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也經歷過了許多事，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "認為自己有所成長，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但以實際年齡而言，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎還無法被當成大人對待呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說的沒錯。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這眾多禮物，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位擔心在下的證明吧……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然如此，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了讓各位能打從心底安心地為我們送別，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n同時當作這場歡送會的謝禮，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就請他們觀看在下成長後的樣貌吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能獲得如此肯定的讚賞，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常感謝您。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人能在一旁守候，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也十分安心。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……各位，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否能給在下一些時間呢？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "要做什麼呀？",
        "unit_id": 6511,
        "voice": "vo_adv_1155003_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位替在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "舉辦了這場歡送會，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "著實感謝。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也請讓在下",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n表達一點感謝的心意給各位。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了能讓各位安心地送別，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下誠心誠意地",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "獻上感謝的祝福。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請各位",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "務必看到最後。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……狂風之精靈啊。",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請以溫柔的恩惠之息，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "撫觸同胞們的臉頰吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "哦哦……！",
        "unit_id": 1,
        "voice": "vo_adv_1155003_028"
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "這就是",
        "unit_id": 3311,
        "voice": "vo_adv_1155003_029"
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "進化之後的精靈啊……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "長大了……",
        "unit_id": 6511,
        "voice": "vo_adv_1155003_030"
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "可可蘿她真的長大了呢……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來都很開心，真是太好了。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哎呀？",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有位沒見過的精靈也聚過來了呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這幼小的精靈，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並不是在下召喚來的……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是怎麼回事呢？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……！",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那孩子是……",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n該不會",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是在那之後……？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此。",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身為他所憧憬的對象，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下可必須完美達成這個職責才行。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n絕不能",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "背叛那時對他所說的話呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐、",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n共同生活、",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "共同跨越困難，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n共同分享無數喜悅的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "家人羈絆……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【破曉之星】的各位……",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不顧危險趕來，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那充滿勇敢與",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "溫柔的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "閃耀羈絆……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以及……",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n比起任何事物都還要重要，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無可取代的在下的主人。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下於此刻，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再次打從心底感受到",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能這樣與您並肩的幸福。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從這個村子",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "孤身一人踏上旅程，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到遙遠的蘭德索爾……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下能找到",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己的歸屬，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都要歸功於",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與各位所構築的羈絆。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是因為有著奉獻此身也無怨無悔的夥伴，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下才能",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "成長得如此堅強、善良。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與各位共同築起的羈絆……",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對在下而言，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那正是",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至高的祝福。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由那祝福所獲得的力量，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要對這個故鄉報恩。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "狂風之精靈啊！",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請用流轉不止的羈絆之風，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "守護這座村子吧！",
        "unit_id": 115511
    },
    {
        "type": "background",
        "background": "501200"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_048"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "嗚嗚……",
        "unit_id": 1,
        "voice": "vo_adv_1155003_049"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "明明彷彿到昨天為止都還是個吸著奶嘴的孩子，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n竟然已經在不知不覺間變得這麼優秀了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "在王都成長到能獨當一面了呢……",
        "unit_id": 3311,
        "voice": "vo_adv_1155003_050"
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "我們",
        "unit_id": 6511,
        "voice": "vo_adv_1155003_051"
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "應該已經不用再替她擔心了。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "……畢竟",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "她有了重要的夥伴。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "好的。",
        "unit_id": 6511,
        "voice": "vo_adv_1155003_052"
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "既然主人是{player}先生的話，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "\n可可蘿的未來肯定會很幸福的。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "今後也要請你",
        "unit_id": 3311,
        "voice": "vo_adv_1155003_053"
    },
    {
        "type": "dialogue",
        "name": "成人1",
        "words": "多照顧可可蘿了！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "呼……",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_054"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "呼……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……方才的精靈，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是您召喚出來的吧？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是、",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_056"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是的。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "在那之後，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我把我的想法全都跟父母說了。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "在那之後，",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_057"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "雖然不知道是為什麼……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我就覺得",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "現在的話精靈應該會回應我。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "然後嘗試之後，",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_058"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我真的就成功跟精靈締結契約了！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "精靈回應我的感情，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "把力量借給我了！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這肯定",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是您的心之風向",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "改變了的關係吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "平常而言，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並沒有辦法看見精靈的姿態。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈總是",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "守候在我們的身邊。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您一個人勤奮修行的努力，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n肯定也被那個精靈",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看在眼裡。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是這樣子啊……！",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_062"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "雖然還不能自在地驅使……",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_063"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n但我想為可可蘿小姐的啟程",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "獻上祝福。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我認為那就是……",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_064"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n這樣的我，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "也能在身為村子裡的精靈族的現在",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "所能辦到的職責。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您成功地",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完成了那個職責呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您那想要激勵人的溫暖心意，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實地傳達到了",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的心中。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "太好了……！",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_067"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我會繼續努力，",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_068"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "將來總有一天",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "要追上可可蘿小姐！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "然後，",
        "unit_id": 5311,
        "voice": "vo_adv_1155003_069"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我想為了我們的故鄉",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "跟在未來等著我的夥伴們，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n變得能夠善用力量！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是您，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定沒問題的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "欸，",
        "unit_id": 6511,
        "voice": "vo_adv_1155003_071"
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "可可蘿～！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "來這邊～！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "再多說一些蘭德索爾的事",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "成人2",
        "words": "給我們聽！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "妳主人也在等妳喔──！",
        "unit_id": 1,
        "voice": "vo_adv_1155003_072"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n說些能讓我這老人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "也能振奮起來的冒險故事吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_073"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然沒問題。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那確實是……",
        "unit_id": 115511,
        "voice": "vo_adv_1155003_074"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與【美食殿堂】的各位",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n前往名為瑪爾傑海岸的海時所發生的事──",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "圍繞著可可蘿的歡送會"
