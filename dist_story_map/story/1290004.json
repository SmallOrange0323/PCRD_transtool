        "words": "\n──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……來了呢。",
        "unit_id": 129013,
        "voice": "vo_adv_1290004_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……謝謝你。",
        "unit_id": 129013,
        "voice": "vo_adv_1290004_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "光之精靈啊──",
        "unit_id": 129013,
        "voice": "vo_adv_1290004_003"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "\n──嘎喔喔喔喔喔！\n──嘎喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129013,
        "voice": "vo_adv_1290004_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呼。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "今天就到這裡吧，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "好的。",
        "unit_id": 129013,
        "voice": "vo_adv_1290004_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……要「變回去」",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "囉。",
        "unit_id": 129013
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "好了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為這裡是我所設定的假想領域──",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我的夢境中。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以能夠無限制地改變物件。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n地形",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和魔物的配置……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都可以隨意變動。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "作為確認自己目前能用什麼戰鬥方式的實驗場來說。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……已經足夠了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "從騎士先生那裡獲得的力量。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不是在「外面」的話，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "果然……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是無法滿足",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……我很期待。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和騎士先生一起去冒險的話……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n回憶和情報都能夠增加。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這麼一來，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無論何時",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都可以在夢境中重現。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你來我這裡的話，",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不管哪裡都可以去喔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呵呵。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……啊，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "其實呢。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我有一個，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "怎麼樣都去不了的地方……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那就是──",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不對，",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "說不定……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n收集記錄片段的話……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就有可能……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然不知道……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "準不準確。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但也許能重現出來。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我想試看看，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可以嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "謝謝。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那麼……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我試試看喔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「重現」──",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_021"
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「現實」……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_022"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我是打算，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "重現出來的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "重現得像嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生？",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n你怎麼了？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n是頭痛嗎？",
        "unit_id": 129011
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生！",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這是……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "排斥反應？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n為了不讓人輕易認知到現實……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "應該十分了解現實才對。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……但是怎麼會。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n只是看到重現出來的景色，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就產生這種反應……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不管有多深的認知。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_027"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n都會受到超越認知的過度修正嗎……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「認知修正」……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那應該",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是再構築的時候，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n為了實現草野優衣的願望",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──希望冒險能永遠持續下去──\n而追加的程式。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就連現在，",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_029"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個程式也頑強地殘存著。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而且和那時候相比，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有哪裡不太一樣。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n似乎能感受到像是針對性的感覺……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "又或者，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是某種意志……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "話說回來……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "居然會在夢境中睡著。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n要是我的力量沒有恢復，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n現在一定",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經被彈出夢境之外了……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生醒來後……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_032"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會變得怎麼樣呢……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有時候，",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個嚮導小妖精，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會讓騎士先生\n看見現實的夢境這件事",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我是知道的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果說，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "現在的情況，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "與那個相近的話……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "或許有辦法。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_034"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n讓我們的相遇……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "從最初開始……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_035"
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊……",
        "unit_id": 1,
        "voice": "vo_adv_1290004_036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "醒來了嗎……？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抱歉呢，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "擅自",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "讓你躺在我的腿上。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n因為你看起來睡得不太舒服……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_039"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你不記得……",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_040"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "了嗎？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_041"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…不，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒關係。",
        "unit_id": 129031
    },
    {
        "type": "still",
        "still": "210901001"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "現在和那時候。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_042"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n已經完全不同了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼……",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_043"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就從初次見面，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "開始吧。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "初次見面。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_044"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我是厄──",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "用厄莉絲的身分，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_045"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真的可以嗎？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n雖然是虛擬的，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但接下來要在「這邊」和騎士先生度過呢……？　",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_046"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "其實……",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_047"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我想不起來了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "自己的名字。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……嗯。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_048"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_049"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我希望你可以，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n用你想要稱呼的名字來叫我呢。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝謝。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不小心……",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_051"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說謊了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對不起，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "騎士先生。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只有現在而已……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就原諒我吧。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼……",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_052"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的名字是？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "{player}……",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_053"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n嗯，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我記住了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請多指教喔。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_054"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n{player}。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我其實，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_055"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不太了解這座城鎮。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你可以帶我逛逛嗎。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在那途中，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_056"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也能想想我的名字就好了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……呵呵。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隱藏名字的厄莉絲，和{player}一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n走在虛擬的椿丘街道上……"
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……椿丘高中。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_057"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣啊，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你是就讀那所高中呀。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n學校好玩嗎？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_058"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n再多說一點。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n告訴我更多，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的事情……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……雖然有提到草野優衣的危險。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_059"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但這是能夠深入了解現實中的騎士先生的，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "絕佳機會。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說的也是。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_060"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那就去找間店……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………糟了。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_061"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我並沒有所有建築物的資訊。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_062"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n有許多外表看起來正常，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "內部卻空無一物的建物。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我忘了這一點……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果騎士先生選擇的店家，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_063"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "剛好就是那虛有其表的建物……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可能會與認知產生矛盾，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "導致這個夢結束。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那種情況……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一定要避免掉才行。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_064"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…那個，{player}。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n比起店家，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我聽說有更好的地方。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我們去那邊看看吧？",
        "unit_id": 129031
    },
    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是美好的地方，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_065"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對吧。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就和我聽說的一樣……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "比起建物和飲料食物，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_066"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "植物的資訊很充足。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是因為將阿斯特朗的植被當作範本了吧。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在這裡的話，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "能夠應付大部分的扭曲。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "算是……",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_067"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喜歡吧。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我也不清楚。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只是知道很多關於花的知識。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很了解花",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_068"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "的人……？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_069"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一定，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_070"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是我比較了解。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我的話，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "從學名到分布地區，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就連花語都瞭若指掌。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n例如……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這種花的",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "花語是思念，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也就是紫菀花……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……沒錯。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_071"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個時候……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n被草野優衣所踐踏，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只屬於我和騎士先生的理想鄉中……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也綻放著這種花……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……不只是這個。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_072"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "關於這裡所有植物的事，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我都能教你。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……就由我來為你，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "更新既有的知識。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n厄莉絲把放眼可見的所有植物的知識"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n都告訴了{player}……"
    },
    {
        "type": "background",
        "background": "510351"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後……"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "時間已經非常晚了呢。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_073"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "其實，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_074"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我還想要再延續一下這段時光……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但是現在的我，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "已經沒有辦法",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "繼續維持重現了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "{player}，今天很謝謝你。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_075"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我真的……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "非常開心。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還能再見的。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_076"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只要你如此期望。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……無論何時都能。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_077"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…那麼。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "再見了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不能說沒有遺憾。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_078"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n因為騎士先生……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒有叫我的名字。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_079"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那就保留到下次見面吧。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n騎士先生的話，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一定會記得的。",
        "unit_id": 129031
    },
    {
        "type": "still",
        "still": "129000401"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "────",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_080"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "剛剛",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_081"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "的……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n難道是……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "紫苑",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_082"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "愛莉……",
        "unit_id": 129031
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "129000402"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "……嗯。",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_083"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "我是……",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_084"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "紫苑愛莉。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n因為你用這個名字呼喚我了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "從今天開始，",
        "unit_id": 129031,
        "voice": "vo_adv_1290004_085"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "我的名字就是……！",
        "unit_id": 129031
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_086"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n早安，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呵呵，",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_087"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "別在意。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_088"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_089"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n沒有可以在「現實」中生活的肉體。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "想觸碰到你的話，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "除了這個人造的世界之外，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都無法辦到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只有在這個世界，",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_090"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我才有可能",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和你結為連理。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不管我多麼地憎恨、",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "多麼地避諱……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n也只有",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在這座名為《阿斯特朗傳奇》的牢獄中才能做到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_091"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我得到了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n得到了你只為我，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所思考而生的東西。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "紫苑愛莉。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_092"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "唯獨這個名字，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不會被任何人奪走。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就算是",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_093"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有實際軀體、",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "總有一天會消逝的資訊……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n只有這份禮物會永遠留存。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "咦",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_094"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……沒關係。",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_095"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不用道歉。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "果然……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_096"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我真的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "很喜歡你。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "最喜歡你了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要我放棄這份感情，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我做不到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即便又再一次地，",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_097"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無法實現。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n即便不被允許。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即便最後……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "甚至，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會陷入絕望。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使如此……",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_098"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使如此，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再一次就好。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想再一次試著",
        "unit_id": 129011,
        "voice": "vo_adv_1290004_099"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "愛上你。",
        "unit_id": 129011
    }
