    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我感覺到有熱～情的視線在看著我呢……♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "曝露在這麼強烈的氣息下",
        "unit_id": 126211,
        "voice": "vo_adv_5120204_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "仍一如往常嗎。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "跟雪在一起",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真的會讓人鬆懈下來呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為害怕緊張",
        "unit_id": 126311,
        "voice": "vo_adv_5120204_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "無法變美麗啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……真是直率啊。",
        "unit_id": 126211,
        "voice": "vo_adv_5120204_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n雖然妳這個人極為難搞，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但在這種情況下或許還滿可靠的呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞，",
        "unit_id": 126311,
        "voice": "vo_adv_5120204_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可要好好跟著我喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "別看我的背影看到入迷囉♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……可靠和難搞相互矛盾呢。",
        "unit_id": 126211,
        "voice": "vo_adv_5120204_005"
    }
