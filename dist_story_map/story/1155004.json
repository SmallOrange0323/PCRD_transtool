        "voice": "vo_adv_1155004_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔唔……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到會在這個地方",
        "unit_id": 115511,
        "voice": "vo_adv_1155004_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與主人一起",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接受來自愛梅斯大人神諭……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這肯定是某種吉兆的象徵呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……♪",
