        "voice": "vo_adv_1155004_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次好像是第一次",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "返鄉停留這麼長一段時間……",
        "unit_id": 115511
    },
    {
