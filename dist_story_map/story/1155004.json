        "voice": "vo_adv_1155004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "於我們所努力的目標，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在那個幸福結局之後呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了能讓小可可蘿在「那邊」",
        "unit_id": 190011,
        "voice": "vo_adv_1155004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也能與無可取代的夥伴們",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "建立羈絆，\n你可要好好努力才行啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這件事是除了你之外誰也辦不到的……",
