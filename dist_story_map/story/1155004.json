        "voice": "vo_adv_1155004_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使用那份力量",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為主人與重要的夥伴努力。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n替各位進行支援，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是在下的職責。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將不會再次放開",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與主人牽起的手。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……請讓在下重述一遍。",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_073"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是受到偉大的愛梅斯大人差遣而前來的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「嚮導」……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "名叫",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "保護主人的安危，",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_074"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從早晨到夜晚……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從出生到死亡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "誠心誠意地照顧主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是在下的職責。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以說……",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_075"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今後也請與在下繼續一同編織",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_076"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "屬於咱們的故事吧……♪",
