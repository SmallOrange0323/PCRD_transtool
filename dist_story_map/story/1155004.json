[
    {
        "type": "background",
        "background": "501220"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}等人要離開村子的當天早上──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可可蘿正在幫忙{player}收拾行李。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 115511,
        "voice": "vo_adv_1155004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您有沒有遺忘了什麼東西呢？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡距離蘭德索爾非常遠，",
        "unit_id": 115511,
        "voice": "vo_adv_1155004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是留在這裡忘了帶走，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是一件大事。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昨晚",
        "unit_id": 115511,
        "voice": "vo_adv_1155004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在主人安睡時，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下擅自製作了",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "攜帶物品的檢查表。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請看，",
        "unit_id": 115511,
        "voice": "vo_adv_1155004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您對照這張表，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n確認所有東西",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否都有帶上。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦……？",
        "unit_id": 115511,
        "voice": "vo_adv_1155004_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那道光是……！",
        "unit_id": 115511
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "啊──累死了──！",
        "unit_id": 6632,
        "voice": "vo_adv_1155004_005"
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "我們去家庭餐廳吧！",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "學生2",
        "words": "好主意耶，",
        "unit_id": 6732,
        "voice": "vo_adv_1155004_006"
    },
    {
        "type": "dialogue",
        "name": "學生2",
        "words": "我想吃聖代～！",
        "unit_id": 6732
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_007"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……啊，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_008"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "{player}先生！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不好意思，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_009"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還請您原諒在下突然來訪。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那個……",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_010"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "其實",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下有事想找您商量，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "才會像這樣",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在校門前",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "等待。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……還請您",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_011"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "以嚴肅的心態來聽這件事。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下所說的商量，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "關於交朋友",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這件事。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "明明都已是小學五年級生了，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_012"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "卻還抱著這種困擾，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "著實感到羞愧……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但在下能商量這件事的，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就只有",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您而已了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "如同您所知道的，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_013"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下是與",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親一起生活在封閉的研究所中。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "或許因為如此，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下對於現在當紅的藝人",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "或流行的事物都很生疏，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n也沒有什麼共通的話題。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "更別說是",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下的用字遣詞總是冒失突兀……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "所以，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "與同年紀的同學之間，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下總是不由自主地感受到距離，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "無法掌握互動方法，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也找不到加入話題的契機……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為了能與父親並駕齊驅……",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n為了更加了解這世界，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就算會勉強自己，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是否也該加入同學們的圈子呢……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但是，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那不會變成在偽裝自己嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "如此這般，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下總是會",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "獨自為此問題陷入兩難。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "勉強自己偽裝所建立的關係，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是否",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能稱得上是真正的友情呢……？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "懇請您給在下",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "一些建議。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "請務必讓在下聽聽",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "交友廣泛的您有何看法。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "{player}先生？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n請問是要去哪裡呢？",
        "unit_id": 105931
    },
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這裡是……？",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_022"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您認為在下所問之事的答案，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就在這裡嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好、",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_023"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好的……",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "115500401"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是的。",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_024"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n與主人相遇時的事，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就如同昨天的記憶般清晰。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_025"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "於車站前因不曉得回家的路",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而不知所措時，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是主人拯救了在下。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_026"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "做夢也想不到，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "竟然會在那種場合",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n遇見",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下的主人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您的意思是，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_027"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "現在不需要",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "勉強自己去迎合周遭……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這樣嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "確實",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_028"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "如您所說呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下所認識的世界，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "幾乎只有小學與動物園。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這個世界上",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_029"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "肯定居住著",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "比這個城鎮還要多好幾千……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n還要多好幾萬倍的人們。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那麼，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_030"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在某處肯定也有人",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "願意接受",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這樣的在下……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "相遇",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_031"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就如同被命運絲線所牽引一般，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n相互對話、",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "分享心情，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n肯定也存在能像這樣深交，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而在下尚未認識的友人……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也就是說，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_032"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就算現在是毫不相干的人，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "只要有那麼一點契機，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n也能夠與其交心。您是想這樣告訴在下嗎？",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "115500402"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就像在下和主人這樣……♪",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_033"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵……",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_034"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "總是被主人",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "拯救呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下迷失於人生之路時，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_035"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n是走在前方的主人成為指標，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "替在下照亮了應進之路。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_036"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "往後或許仍會如此……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但是，",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_037"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為了能夠追上主人，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下也會更加精進。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n這也是……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為了在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "未來將要遇見的，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "仍未謀面的朋友。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為了將來",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_038"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人與各位迷失目標時，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能夠做為指標引導方向……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "非常抱歉。",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_039"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下是否說得太超過了……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好、",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_040"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好的！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "被主人這樣期待，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "讓在下的心底有股力量",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "伴隨責任感湧上來了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下",
        "unit_id": 105931,
        "voice": "vo_adv_1155004_041"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "想要更加更加地成長。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n以後還要請您多多指教囉，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人♪",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊啊啊～～～～～",
        "unit_id": 190011,
        "voice": "vo_adv_1155004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿她呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1155004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不管什麼時候看……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管看幾次都真讓人受不了呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那楚楚可憐的大眼睛……！",
        "unit_id": 190011,
        "voice": "vo_adv_1155004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n緊緊噘起的嘴角……！！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "清秀長髮間微微露出的小巧耳朵……！！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……呼～",
        "unit_id": 190011,
        "voice": "vo_adv_1155004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你等我一下喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我先冷靜一下……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "………………",
        "unit_id": 190011,
        "voice": "vo_adv_1155004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好啦，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "久等了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來……",
