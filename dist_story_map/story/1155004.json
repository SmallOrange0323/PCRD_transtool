        "voice": "vo_adv_1155004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也看到了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「那邊」的小可可蘿啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n跟你以外的人還是沒有任何交集。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果沒發生什麼意外，",
        "unit_id": 190011,
        "voice": "vo_adv_1155004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你肯定會帶她與其他人建立友誼吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但很可惜的，",
