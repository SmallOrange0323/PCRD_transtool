        "voice": "vo_adv_1155004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要在「那邊」相遇，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n肯定會是稍遠的未來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
