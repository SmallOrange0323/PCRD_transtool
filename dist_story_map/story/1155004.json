    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是……",
        "unit_id": 115511,
        "voice": "vo_adv_1155004_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得這次",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下能以開朗的心情，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n向故鄉的同胞們",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好地道別。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這肯定是因為",
