        "voice": "vo_adv_1155004_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想盡早",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回到主人身邊，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n又想要在這",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令人懷念的故鄉",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "停留得再久一點點……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總會有著",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這兩種心情。",
