        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……以及",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有另外一件必須做的事。",
        "unit_id": 115511
    },
    {
        "type": "background",
        "background": "501200"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您久等了，",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是遺忘了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而是在下決定將其留在此處。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那件服裝將成為指標，",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_068"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做為在下的一部分",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "留在故鄉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此一來，",
        "unit_id": 105913,
        "voice": "vo_adv_1155004_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個村子的存在，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "往後也將持續賦予在下力量……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是這麼認為的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想要",
