        "voice": "vo_adv_1155004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜託你囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501220"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔、",
