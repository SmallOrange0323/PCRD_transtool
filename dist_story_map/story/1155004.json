        "voice": "vo_adv_1155004_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 115511,
        "voice": "vo_adv_1155004_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒事的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是什麼大事……",
