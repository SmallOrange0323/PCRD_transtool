        "voice": "vo_adv_1155004_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對於能與主人相遇這件事，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n打從心底由衷地感到幸福。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若願望能夠成真，在下希望……",
