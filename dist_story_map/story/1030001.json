[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在平原上，因為一時大意而被一群魔物給包圍。\n在他做好覺悟要決一死戰時，聽到了一道不知從何而來的聲音。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "登登登登登，",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n第一～生猛海鮮比目魚……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "第二～毛手毛腳色大叔……",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "第三，浮世泳圈無形洞！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n待我秘技一招破！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n噠噠噠！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看招！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "突然有少女說著那謎樣的招牌台詞，\n從身旁的樹上跳了下來。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那邊的旅行者……",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "救兵登場是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "忍法・分身之術！咻啪啪啪！！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚嗚嗚，竟然沒有效是也……",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "既然如此……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "秘劍・啾燕斬！！",
        "unit_id": 103011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……放心吧，我是用刀背砍的。",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過魔物也被我一掃而空是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而，少女並沒有注意到，\n在她身後還有一隻魔物。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵……無須言謝，",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在下……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只是無名小卒，不足掛齒是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我明白恩人後會無期讓你掛意不下，",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是，請不要阻止我離開是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "忍者是用背影來表達一切的是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……欸？",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚哇！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "從後面偷襲，真是卑鄙的魔物是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣的話，就用秘劍・三日月斬……",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊～～～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的魔力已經都用光了是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是太大意了！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣的話……我只能切腹以死謝罪了是也……！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……欸？你說冷靜一點？",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "難不成你有什麼好對策是也？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……！？什、什麼……",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這股從身體深處湧上來的力量……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這該不會是ーーー！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯！就是現在！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看我的秘劍・五月雨斬！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n咻嚕嚕嚕嚕嚕！！！",
        "unit_id": 103011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "太棒了是也～！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n一招逆轉，我漂亮地將魔物給打倒了是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我能夠辦到這件事……",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一定是因為你乃將軍是也～！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只要有將軍在的話，",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n大家的力量都會大幅增強是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不不、一定就是那樣是也～",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "將軍你又來了，怎麼這麼謙虛是也",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "將軍你不用說得那麼清楚也沒關係。",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只要跟你在一起力量便會自然湧出，證明了你乃將軍是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈――這麼說的話直到剛才為止，",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我對將軍做了很多失禮的事……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抖抖抖……",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要、要被斬殺了是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我不想被賣到惡代官手裡是也！！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我不想發出啊～呀～的叫聲，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n然後被扯下腰帶轉啊轉是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真、真的嗎……！？",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "將軍真是溫柔是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有了，請讓我就這樣",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n成為將軍的部下吧！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "遲遲未報上姓名，我乃妮諾是也！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "接下來請多多指教是也！",
        "unit_id": 103011,
        "voice": "vo_adv_1030001_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，請和我一起統一天下是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾好像有什麼誤會，但{player}卻被她的氣勢壓過，\n直接就讓她成為自己的部下了……"
    }
]