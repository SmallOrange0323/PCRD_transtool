[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天吉塔與{player}聽說到，\n有人想要委託騎空團工作，\n於是前往鬧區。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你好─！",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n聽說有工作想要委託我們……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哦哦，",
        "unit_id": 311,
        "voice": "vo_adv_1057007_001"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們就是騎空團啊！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n來的正好！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這間店一直受到惡德伊商會的騷擾，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n希望你們能幫忙保護這裡！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "惡德伊商會……",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就是最近在蘭德索爾跨足各種事業的",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那一間商會呀……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那些人打算從我手裡搶走這間店還有這塊土地！",
        "unit_id": 311,
        "voice": "vo_adv_1057007_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n所以就每天來騷擾……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "害我都做不成生意了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好過份……",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "45我瞭解了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "交給我們吧！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦唷哦唷，",
        "unit_id": 1,
        "voice": "vo_adv_1057007_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這是怎麼著？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n今天可一定要請你把這裡讓出來啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是誰！？",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_006"
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "我是惡德伊。",
        "unit_id": 911,
        "voice": "vo_adv_1057007_007"
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "惡德伊商會的惡德伊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "\n不好意思請問妳是……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "那位店長的熟人嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我叫吉塔。",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_008"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n是受到這個人委託，要保護這間店的騎空團！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "騎空團……",
        "unit_id": 911,
        "voice": "vo_adv_1057007_009"
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "這樣啊，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "這邊也出招了呢……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "\n不過我們的想法似乎非常像呢。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "各位，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "該你們出場了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "店長啊！",
        "unit_id": 1011,
        "voice": "vo_adv_1057007_010"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n你要是不老實點離開的話……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "場面可就會難看了哦？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "那邊那兩個小鬼，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "可沒辦法當我們的對手喔！？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咿……！",
        "unit_id": 311,
        "voice": "vo_adv_1057007_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "快、快幫幫我！\n這些傢伙，就是受惡德伊所託來收走我的店的公會。\n拜託了，幫我趕走他們！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "店長請你退下！",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_012"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n這裡就交給我們！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不會再讓你們恣意妄為了！",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_013"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "由我們來當你們的對手！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "很有種不是嘛！",
        "unit_id": 1011,
        "voice": "vo_adv_1057007_014"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "不過我們也是拿錢辦事！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "可不會手下留情，認命吧！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n你們幾個，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "動手！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "部下們",
        "words": "唔喔喔喔喔喔喔！",
        "unit_id": 1,
        "voice": "vo_adv_1057007_015"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要來了！",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_016"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "準備好！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "部下１",
        "words": "喔啦啊！",
        "unit_id": 1,
        "voice": "vo_adv_1057007_017"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就是那裡！",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_018"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "噠啊！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "部下１",
        "words": "唔喔啊！",
        "unit_id": 1,
        "voice": "vo_adv_1057007_019"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "對手不過就是兩個小鬼，搞什麼東西啊，蠢貨！",
        "unit_id": 1011,
        "voice": "vo_adv_1057007_020"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n這可不是遊戲！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "給我盡全力上！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對方公會人很多，要小心！",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_021"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯！謝謝！",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_022"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不要讓戰鬥波及到店家，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "慢慢遠離這裡吧！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "部下２",
        "words": "喔啦！",
        "unit_id": 1,
        "voice": "vo_adv_1057007_023"
    },
    {
        "type": "dialogue",
        "name": "部下２",
        "words": "差不多該給我去死了吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "唔……！",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_024"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這傢伙！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "部下２",
        "words": "嘎啊！",
        "unit_id": 1,
        "voice": "vo_adv_1057007_025"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "呼、呼……",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_026"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你沒事吧……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了……",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_027"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "再稍微陪我努力一下……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "對手只不過是兩個小鬼，到底什麼時候才能解決！",
        "unit_id": 1011,
        "voice": "vo_adv_1057007_028"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n既然這樣就由我來了結……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n喂，就是妳！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "要不要和我一對一決鬥！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "決鬥……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_029"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "是啊沒錯。",
        "unit_id": 1011,
        "voice": "vo_adv_1057007_030"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "要是妳贏，我們再也不會對這間店出手。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "不過要是妳輸了，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "就把店交出來，然後解散騎空團！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "惡德伊先生，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "這樣沒問題吧？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "唔姆……",
        "unit_id": 911,
        "voice": "vo_adv_1057007_031"
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "就隨你高興吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "不過呢，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "請你可千萬不要輸掉了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這麼亂來的決鬥，",
        "unit_id": 311,
        "voice": "vo_adv_1057007_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "誰要接受呀！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n他們一定會耍什麼小手段的！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……我瞭解了。",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_033"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這場決鬥，我接受。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "為什麼……！",
        "unit_id": 311,
        "voice": "vo_adv_1057007_034"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "繼續這樣下去，",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_035"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不久就會輸給人數差距……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n說不定會有陷阱，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這一點我當然知道。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過這對我們來說，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "也是有機會的……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就算勝算再怎麼低，",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_036"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n也一定得成功……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "哈！",
        "unit_id": 1011,
        "voice": "vo_adv_1057007_037"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "看來妳也蠻瞭解什麼是分個輸贏嘛。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "上前來吧！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……我去去就回。",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_038"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "這個硬幣落地的聲音就是決鬥開始的信號。",
        "unit_id": 1011,
        "voice": "vo_adv_1057007_039"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "\n可以吧？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我知道了。",
        "unit_id": 105711,
        "voice": "vo_adv_1057007_040"
    },
    {
        "type": "dialogue",
        "name": "公會長",
        "words": "那我就扔了……",
        "unit_id": 1011,
