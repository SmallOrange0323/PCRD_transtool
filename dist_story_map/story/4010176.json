    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是",
        "unit_id": 104232,
        "voice": "vo_adv_4010176_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "演唱會的門票？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n因為我之前邀請過你……？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊……",
        "unit_id": 104232,
        "voice": "vo_adv_4010176_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是指聖誕節那時候",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是嗎。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你還記得啊……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的，",
        "unit_id": 104232,
        "voice": "vo_adv_4010176_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那天我也很開心……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n原來你",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也有同樣感受啊。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺今天",
        "unit_id": 104232,
        "voice": "vo_adv_4010176_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也會成為開心的一天。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "會變成比上次……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "更加美好的一天。",
        "unit_id": 104232
    },
    {
