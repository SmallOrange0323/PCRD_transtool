        "words": "雖然你說",
        "unit_id": 104232,
        "voice": "vo_adv_4010176_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天的計劃",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「全包在我身上」……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我可以請問",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是要做什麼嗎？",
