    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "吃自助餐？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n還有蛋糕嗎……？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼多……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵。",
