[
    {
        "type": "background",
        "background": "500158"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "講一講就突然變成是要大家對初夢許願……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我怎麼會可會有",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那種遠大的目標嘛～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再說就算許願了，也不一定能夢到想做的夢嘛。",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不要想太多，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好好睡一覺應該比較容易做好夢啦……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "事情就是這樣，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼晚安了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼……",
        "unit_id": 102611
    },
    {
        "type": "still",
        "still": "513406401"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔嗯唔嗯……",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "奇怪，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我不是睡了嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為什麼會站在這種地方啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來捏捏看",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "尾巴好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……我捏！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不會痛……",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這樣看來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我現在難道是在作夢嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是也沒有發生什麼在夢中才會發生的事，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說不定是因為什麼願望都沒有許，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "才變成了無聊的夢吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是反過來想，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這不就是個好機會，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n能夠盡情地懶散不被打擾嗎……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣想的話，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也是個不錯的初夢呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼就先",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "躺下來……",
        "unit_id": 102611
    },
    {
        "type": "still",
        "still": "513406402"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n平常如果躺在這種地方，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n絕對會被莉瑪莉瑪或小栞她們念呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽應該會誤以為我在搞笑，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n對我吐槽吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還有零食跟飲料就完美了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但總之就先睡個回籠覺吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "晚安……",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……唔嗯唔嗯",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……咦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是睡在這種地方的嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "直到剛才",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像都還待在完全不同的地方……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n對喔，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "會不會是因為在夢中又睡了覺，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以才搞錯了嗎。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過算了，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "現在起床還太早，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就睡個回籠覺……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這真的是回籠覺嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n會不會",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實是第三次睡覺啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "或許只是我不記得而已，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但實際上睡的次數還要再更多……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我現在到底",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是在現實之中，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是夢裡呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我覺得不管哪邊都無所謂，",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但為了知曉真相，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就再度進入夢鄉吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……這裡毫無疑問是現實，",
        "unit_id": 103813,
        "voice": "vo_adv_5134064_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以請妳快點起床吧，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴。",
        "unit_id": 103813
    }
]