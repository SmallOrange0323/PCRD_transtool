    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與貪吃佩可等人一同探索露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n眾人在塔內費時四處探索，但卻毫無斬獲，只有疲勞不斷地在累積……"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這座塔、",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是怎樣……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都爬了好幾層了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻還是沒到頂層……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是該……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "稍微、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "休息一下……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "休息的時候就順便來吃便當吧♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我用了稀有魔物的食材，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n精心製作了特製三明治！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吧，",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我想也是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給妳準備就會這樣……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大概是因為累了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天感覺吃那個，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像也無所謂了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……各位，",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請等一下。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛剛",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那邊",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像有東西在發光。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的耶……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果是魔物的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會打擾我們的吃飯時間的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "過去看看。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常感謝您，",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果感覺到危險，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請馬上呼叫在下們。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我看看……",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……？",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "400900101"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來不像魔物，",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過這究竟是什麼呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "造型是方塊狀的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我從來沒看過這種東西。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留、",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可以過來一下嗎～！？",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹嘛，",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的有魔物嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳該不會想說，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想拿來當三明治的餡吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可惜，",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並不是那樣。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家知道這個神祕的物體",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是什麼嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是個由細小零件所組成，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n呈現立方體形狀的構造物。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還從中央發出光芒……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會不會是某種魔法道具？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只要滿足特定條件，零件就會解體四散，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後可以獲得裡面的寶物……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之類的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔～",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光用看的也搞不懂它是什麼東西呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳可以用魔法想辦法調查，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n查明它到底是什麼嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也拜託您。",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果這和主人的記憶有所關連，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那可不能置之不理。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "慢著慢著，",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是陷阱怎麼辦？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不要",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "第一個碰它呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果一定要的話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們猜拳決定才公平！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不錯耶，感覺很好玩～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那大家願賭服輸！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剪刀、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "石頭……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可等人",
        "words": "布！",
        "unit_id": 1,
        "voice": "vo_adv_4009001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我出石頭♪",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下出石頭。",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我出剪刀。",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然得出了公平公正的結果，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就麻煩妳調查囉♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用擔心，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是某種陷阱，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們會盡全力救妳的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那不是當然的嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是丟下我不管，我做鬼也不放過你們。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呃，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之，我先來調查中央的部分。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個零件",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能拆掉嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "奇怪？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我一碰到零件，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "它好像就自己打開了……！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我要被光吸進去了～！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是……",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "危險！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請快把手伸過來！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要是被吸進去，不曉得會發生什麼事！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噫～！？",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對不准放手喔！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不是在演戲，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們看得出來吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們知道……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但吸力太強了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "連我們都要被拉進去了～！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n便當",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還放在",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對面的說～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種東西",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就先別管了啦～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不行了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所有人都要被吸進去了～！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔喔喔……",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_028"
    },
    {
        "type": "background",
        "background": "501921"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好痛……",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們沒事吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n特別是小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳的肩膀還好嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還、",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還以為手要被拉長了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞什麼啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且周遭的景色也變得完全不一樣了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n剛剛那是傳送型的陷阱嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡的氣氛很嚴肅，",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和至今為止的樓層都不同呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只不過，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比起那個……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一大群……",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且每一隻",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來還都很強！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "得趕緊回到原本的樓層！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這點我也贊同，",
        "unit_id": 105811,
        "voice": "vo_adv_4009001_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是這個立方體，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在把我們吐出來之後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就一點反應也沒有了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是沒辦法執行戰術性撤退了呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說",
        "unit_id": 106011,
        "voice": "vo_adv_4009001_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒辦法……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那那",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那這下該怎麼辦啦！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不是吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會要正面迎戰那群魔物！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這可不是用孤軍奮戰可以形容的喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "超不得了啦！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然沒辦法逃跑，",
        "unit_id": 105911,
        "voice": "vo_adv_4009001_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那只能一戰了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請先集中精神，度過眼前的危機。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也請您做好準備。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    }
]