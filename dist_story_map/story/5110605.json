[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在街上閒晃時，諾維姆向尾狗刀開口搭話。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂，尾狗刀。",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我從以前就一直很在意……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你的實力",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "到底是算強？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "還是算弱啊？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦，",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "應該不算是弱……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就普普通通吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可以輕鬆應付一些雜兵，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n不過，和諾維姆比起來，我就算是很嬌弱了～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你果然",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是在敷衍我吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n你只是因為嫌工作麻煩",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "才沒有拿出真本事對不對？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "既然這樣，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就讓我稍微驗證一下吧～",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喂！",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_003"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "總算找到你們了！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n來和我一決勝負吧！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哇啊，",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "他是什麼時候來的……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳早就注意到，卻故意不說的吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嘿嘿，",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_005"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我剛剛就看到他朝我們衝來了。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n好喔，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我們接受挑戰！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾狗刀，由你上吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦～",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "為何我非得要聽話接受他的挑戰啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n才不要，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "太麻煩了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "如果不這麼做，",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_007"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我就沒辦法知道你的真本事了嘛！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "別介意，你就上吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你們不管是誰要上，我都沒差！",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_008"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n最好是你們兩個聯手攻過來！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就說我才不要。",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我要先走一步了……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唔，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳別阻擾我開溜。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不，",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_010"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我不會讓你溜走的！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我今天一定要見識一下",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你的真本事！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你認命點接招吧！",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_011"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "吃我一拳！",
        "unit_id": 190711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哇啊！",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "等等！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n就說我是負責動腦筋的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不適合做體力活啊！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不！",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_013"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是你隱藏了真正的實力！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n這我很清楚！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以我說～",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "根本沒這回事。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n諾維姆，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳為何對我抱有這樣的期望啊？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "因為你",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_015"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是我的搭檔，一定要很強才行啊！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "啊，尾狗刀！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "看前面！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "看前面！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "當本大爺的對手可不能大意啊！",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_016"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n得手了！",
        "unit_id": 190711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唔",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_017"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊！？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "很好！",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_018"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這拳打得響亮……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "唔呃！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂！",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_019"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你對我的搭檔做什麼啊！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這是……",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_020"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "為什……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "麼啊……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好痛好痛……",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_021"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唉……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n他從背後成功地突襲了我呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "啊，",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_022"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "糟了……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我不小心就……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n呃、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "大吾這傢伙",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "昏死過去了……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾狗刀，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "怎麼辦……？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_023"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "大吾剛才說了，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們兩人聯手也沒關係，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以是他自己太大意了呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n並不是我們的錯吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就、",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_024"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就是說啊……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n總之……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們趕緊……",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_025"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "逃離這裡吧！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆與尾狗刀丟下昏過去的大吾，一溜煙地逃離了現場。"
    }
]