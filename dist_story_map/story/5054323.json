[
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "實、",
        "unit_id": 114411,
        "voice": "vo_adv_5054323_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "實在是很累人呢……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟我們",
        "unit_id": 114511,
        "voice": "vo_adv_5054323_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "持續戰鬥了這麼久嘛。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這種疲勞感和熬夜處理工作有得一拚呢……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我懂……",
        "unit_id": 114611,
        "voice": "vo_adv_5054323_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "連續忙碌好幾天，",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "身心都會很疲憊呢。",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n最近正好又是繁忙時期……",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒錯沒錯，",
        "unit_id": 114511,
        "voice": "vo_adv_5054323_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "每次聖誕時節，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n進貨量都是平時的數倍，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "常常為了要確認貨物而東奔西走……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還得處理再怎麼努力也不會減少，",
        "unit_id": 114411,
        "voice": "vo_adv_5054323_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n疊得像小山般的文件……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我有好幾次都快受不了了，",
        "unit_id": 114511,
        "voice": "vo_adv_5054323_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但很不可思議的，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "每次都會重新振作呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是啊！",
        "unit_id": 114411,
        "voice": "vo_adv_5054323_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而且，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要有心，還是能完成的！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳說的沒錯。",
        "unit_id": 114511,
        "voice": "vo_adv_5054323_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們快點把",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這件事做完……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "再好好地",
        "unit_id": 114411,
        "voice": "vo_adv_5054323_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "放鬆一下吧！！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……那麼各位，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們拿出幹勁，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "把敵人收拾乾淨吧！！",
        "unit_id": 114411
    }
]