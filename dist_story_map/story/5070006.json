[
    {
        "type": "background",
        "background": "500366"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從島上回來的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在書桌前奮力趕工剩下的作業，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但距離暑假結束已經沒剩多少時間。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就{player}大人的作業進度來看，",
        "unit_id": 102711,
        "voice": "vo_adv_5070006_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼想都不可能來得及交……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳怎麼可以說那種洩氣話呢，惠理子！",
        "unit_id": 104914,
        "voice": "vo_adv_5070006_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n弟弟現在做的是習題對吧？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要我們幫忙寫就來得及！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說得也是。",
        "unit_id": 102711,
        "voice": "vo_adv_5070006_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您的暑假",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可不能被作業破壞。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚嗚～",
        "unit_id": 104914,
        "voice": "vo_adv_5070006_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你是個品行端正的弟弟，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐非常開心，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不過姐姐還是想幫忙耶。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有沒有什麼事能幫忙啊……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有沒有什麼能為",
        "unit_id": 102711,
        "voice": "vo_adv_5070006_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人做的事……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流、惠理子",
        "words": "……啊！",
        "unit_id": 1,
        "voice": "vo_adv_5070006_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要……",
        "unit_id": 102711,
        "voice": "vo_adv_5070006_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不要讓暑假結束就行了……",
        "unit_id": 104914,
        "voice": "vo_adv_5070006_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "動手吧。",
        "unit_id": 102711,
        "voice": "vo_adv_5070006_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "走吧。",
        "unit_id": 104914,
        "voice": "vo_adv_5070006_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不，",
        "unit_id": 104914,
        "voice": "vo_adv_5070006_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼事都沒有！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "重要的是，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們待在這裡會讓你沒辦法專心對吧。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就是說啊。",
        "unit_id": 102711,
        "voice": "vo_adv_5070006_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們先告辭了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們相信",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您一定會完成作業。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們走囉，",
        "unit_id": 104914,
        "voice": "vo_adv_5070006_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟。",
        "unit_id": 104914
    },
    {
        "type": "background",
        "background": "500365"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳做好心理準備了吧，",
        "unit_id": 104914,
        "voice": "vo_adv_5070006_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "惠理子？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_5070006_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是愚蠢的問題呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流、惠理子",
        "words": "這一切……",
        "unit_id": 1,
        "voice": "vo_adv_5070006_015"
    },
    {
        "type": "dialogue",
        "name": "靜流、惠理子",
        "words": "都是為了弟弟！\n都是為了大人！",
        "unit_id": 1,
        "voice": "vo_adv_5070006_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人，",
        "unit_id": 102711,
        "voice": "vo_adv_5070006_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "祝您健康永久……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "再會了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐",
        "unit_id": 104914,
        "voice": "vo_adv_5070006_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會永遠思念著弟弟的喔……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對努力完成作業的{player}的背影"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "投以悲壯的眼神後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n惠理子與靜流靜靜離開了。"
    },
    {
        "type": "background",
        "background": "501110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "朝陽剛升起的早晨。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在即將迎來新學期的月光學院裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n出現了兩個穿著不得體的人。"
    },
    {
        "type": "dialogue",
        "name": "靜流、惠理子",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5070006_019"
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "那個～",
        "unit_id": 4911,
        "voice": "vo_adv_5070006_020"
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "兩位小姐……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "妳們看起來不像是我們學校的學生，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "穿成這樣是在做什麼？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "我們游泳池已經沒有對外開放了，",
        "unit_id": 4911,
        "voice": "vo_adv_5070006_021"
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "\n妳們就算待在這裡也進不去喔？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要有我們在，",
        "unit_id": 117111,
        "voice": "vo_adv_5070006_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "暑假就不會結束！！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們不會讓它結束！！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "…………啥？",
        "unit_id": 4911,
        "voice": "vo_adv_5070006_023"
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "我聽不懂妳們在說什麼，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "但妳們不快點離開的話，我會很困擾。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我不走。",
        "unit_id": 117011,
        "voice": "vo_adv_5070006_024"
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "為什麼？",
        "unit_id": 4911,
        "voice": "vo_adv_5070006_025"
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "就算待在這裡，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "也進不了游泳池喔？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們的要求只有一個。",
        "unit_id": 117111,
        "voice": "vo_adv_5070006_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是不要開始始業式！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果你們硬要開始，",
        "unit_id": 117011,
        "voice": "vo_adv_5070006_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們就會破壞這個學校！",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "不要說那麼可怕的話嘛。",
        "unit_id": 4911,
        "voice": "vo_adv_5070006_028"
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "\n叔叔基於責任，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "必須叫【王宮騎士團】來管秩序了喔。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒關係。",
        "unit_id": 117011,
        "voice": "vo_adv_5070006_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n無論出現什麼樣的敵人，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們都不會撤回要求。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "妳們確定嗎？",
        "unit_id": 4911,
        "voice": "vo_adv_5070006_030"
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "\n叔叔我",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "校工",
        "words": "真的要報案囉！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "接到報案，我還以為是惡作劇……",
        "unit_id": 712,
        "voice": "vo_adv_5070006_031"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n沒想到居然真的有兩個穿著泳裝的女人。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n這是什麼惡夢嗎……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "我也有看見，",
        "unit_id": 711,
        "voice": "vo_adv_5070006_032"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "所以很遺憾的，這並不是在做夢呢……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n總之，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "就稍微強硬地請她們離開吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "唔！？",
        "unit_id": 711,
        "voice": "vo_adv_5070006_033"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "隊長，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "請看其中一個女人！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n那、",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "那是……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "破壞者！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "不不，",
        "unit_id": 712,
        "voice": "vo_adv_5070006_034"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "破壞者怎麼可能會在這種…………",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "還真的！！！！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n那不管怎麼看都是破壞者不是嗎！！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "立即",
        "unit_id": 712,
        "voice": "vo_adv_5070006_035"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "用通訊魔法請求支援！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n休假的人也通通叫起來！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "把能來的人通通找來！！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "還有附近一帶也要封鎖！",
        "unit_id": 712,
        "voice": "vo_adv_5070006_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也太誇張了……",
        "unit_id": 117011,
        "voice": "vo_adv_5070006_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "明明只要接受我們的要求，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們就什麼都不會做的說……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "報告，",
        "unit_id": 711,
        "voice": "vo_adv_5070006_038"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "兩個營前來支援……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "不過，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n真的有必要來嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "聽說是破壞者，",
        "unit_id": 711,
        "voice": "vo_adv_5070006_039"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "我還以為是什麼三頭六臂的怪物，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n結果只是一個普通的女人不是嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "那種小角色",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "靠我一個人就足夠了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n喂，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
