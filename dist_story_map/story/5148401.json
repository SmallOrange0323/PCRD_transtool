    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "目をかっぴらいて、",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_000"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "よ～く見ておくです！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "【ドラゴンズネスト】大幹部、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "イノリさまの晴れ着姿ですからね！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "この姿、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ご来光のごとく拝むといいですよ！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "……まぁ、",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_001"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "正直に白状すると。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "より強そうなデザインにするべく",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nカヤぴぃにもアドバイスをもらったですよ。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "アピールポイントは、",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_002"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "もちろん",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "柄です！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "強くて渋いギャングの魅力が伝わるよう、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "細かく指示したですから。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "気に入ったなら、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "有料で写真を撮らせてやってもいいですよ？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "えっ、",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_003"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "本気にするんじゃねえですよ！　",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "しかも",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "一緒に撮る！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ちょっと待つです、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ポーズも渋い感じのを考えないと……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "しかめっ面で",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "腕組で……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "よし！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "とりあえず、",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_004"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "このおめでたいイノリさまを",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "崇めやがれです！",
        "unit_id": 128311
    }
]