    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}接受公會管理協會的委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n造訪了某間房屋。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一、二、三，",
        "unit_id": 104311,
        "voice": "vo_adv_9004002_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一、二、三……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿嘿，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主，怎麼樣呢？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我引導得還不錯吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯……",
        "unit_id": 101011,
        "voice": "vo_adv_9004002_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的跳得好美呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "簡直就像童話故事的公主",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "出現在眼前一樣。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "被公主稱讚，感覺雖然不壞……",
        "unit_id": 104311,
        "voice": "vo_adv_9004002_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但怎麼說呢──",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我的背不禁癢了起來啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真琴",
        "unit_id": 105213,
        "voice": "vo_adv_9004002_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不必那麼害羞啦♪",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "接下來，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能不能麻煩妳當我的搭檔呢？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311,
        "voice": "vo_adv_9004002_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪好像很開心耶，真是太好啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我一直很嚮往",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這般閃閃發光的世界呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒錯。",
        "unit_id": 105213,
        "voice": "vo_adv_9004002_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能和大家一同\n度過這麼美好的時光，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "簡直就像夢一場♪",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家",
        "unit_id": 102611,
        "voice": "vo_adv_9004002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像都跳得很開心耶。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "比起自己親自去跳，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我還是喜歡在一旁看別人跳舞。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_9004002_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看來大家都很開心，真是太好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對吧，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你、",
        "unit_id": 104311,
        "voice": "vo_adv_9004002_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你來了！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n好歹也打聲招呼吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_9004002_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總算來了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是的──好慢哦──",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是等得很不耐煩，差點就要睡著了耶。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴只不過是在那邊發懶而已的啦？",
        "unit_id": 103311,
        "voice": "vo_adv_9004002_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "來，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這東西是要交給老哥的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……啊，",
        "unit_id": 102611,
        "voice": "vo_adv_9004002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果你接下來要回去的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就背著我一起走嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很順便呀。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴～～？？",
        "unit_id": 105213,
        "voice": "vo_adv_9004002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呿──",
        "unit_id": 102611,
        "voice": "vo_adv_9004002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "用不著那麼生氣嘛……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n只是開個小玩笑而已。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你接下來要去別的地方吧。",
        "unit_id": 104311,
        "voice": "vo_adv_9004002_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你還是一樣，似乎很忙的樣子呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大家下次",
        "unit_id": 105213,
        "voice": "vo_adv_9004002_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一起辦一場茶會吧♪",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還有好多開心的事情在等著呢，太棒了～！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "以後也請多多指教了哦。",
        "unit_id": 101011,
        "voice": "vo_adv_9004002_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下次再見囉～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}離開富麗堂皇的舞廳，\n動身前往下一個目的地。"
    }
]