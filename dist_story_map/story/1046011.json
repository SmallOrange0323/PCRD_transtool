    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——立志向『惡心疵聯合商會』對抗的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n珠希和{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一面進行調查，也繼續在鯛魚燒店工作。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯，",
        "unit_id": 104611,
        "voice": "vo_adv_1046011_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n今天沒什麼客人上門喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！　",
        "unit_id": 104611,
        "voice": "vo_adv_1046011_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那裡有個熟面孔喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂——！　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "買點鯛魚燒怎麼樣喵——！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "常客",
        "words": "……抱歉呢，",
        "unit_id": 1411,
        "voice": "vo_adv_1046011_002"
    },
    {
        "type": "dialogue",
        "name": "常客",
        "words": "珠希。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "常客",
        "words": "\n最近正在減少開支呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、",
        "unit_id": 104611,
        "voice": "vo_adv_1046011_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那還真可惜喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "下次再來喵——！！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我知道喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046011_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "事情可沒這麼簡單喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "惡心疵聯合商會底下的組織",
        "unit_id": 104611,
        "voice": "vo_adv_1046011_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "都已經調查完畢了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "數量實在是太多了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果逐一擊破，",
        "unit_id": 104611,
        "voice": "vo_adv_1046011_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n讓他們提高警覺的話，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就會變得很難潛入了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊～煩死了！",
        "unit_id": 104611,
        "voice": "vo_adv_1046011_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n到底要怎喵辦～～！！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 104611,
        "voice": "vo_adv_1046011_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我好像看見光了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我動太多腦了，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "終於開始產生幻覺……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不對，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}！！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你的身體好像在發光……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵啊啊啊啊啊啊！？",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "表面的光澤……",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "甘甜的香氣……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "完美的形狀……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "簡直是塊寶喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "居然做得出這樣的鯛魚燒，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不愧是超級名店喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n店裡的鯛魚燒，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "完全不是對手喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "然而，",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還是犯下了無可挽回的錯誤了喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "居然沒有絲毫警戒，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就把鯛魚燒賣給我了喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "事後再來好好驚訝吧喵！",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了這把鎮上鯛魚燒店的口味都偷回來的",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n「連同口味的祕密也一起品嘗喵作戰」",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "被偷走了自己的口味而感到驚訝吧！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "居然能想出如此完美的作戰，",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我還真是可怕喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果在別的世道，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "或許會當上怪盜或義賊之類的，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n讓自己的名號震驚世界也說不定喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哦，",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實我有一點",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "憧憬著為了窮困的人而戰的義賊喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怪盜不錯喵～♪",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n打著幻影貓",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "之類的名號，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n華麗地將至寶佔為己有喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "事不宜遲。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n趕快來分贓到手的寶物喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來～",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我來餵你吃，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把嘴巴張開喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喔，",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難不成順便在害羞喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也是啦，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "被如此美貌絕倫的姊姊",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n餵食什麼的，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這也是沒辦法的喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……哦～",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "關於這點有什麼疑問嗎？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n請你詳細地講給我聽喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "順帶一提！　",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "身高太矮之類的，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n和年齡對不上之類的，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這種話說一句就要被抓一次的，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n奉勸你謹言慎行喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "很聽話很乖喵！",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n來，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵呼呼……",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總感覺，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n兩個人做這種事還挺開心的喵～♪",
        "unit_id": 104631
    },
    {
        "type": "still",
        "still": "104601101"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "接下來，",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我也嚐一口吧……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯～！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "超級好吃喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n內餡尤其是極品喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這間鯛魚燒，",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "似乎特別注重內餡喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了不掩蓋餡料的風彩，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "特地調整了外皮……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "簡直是匠心之作喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這項技術要不要用在店裡的鯛魚燒……",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n怎麼了喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難不成，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這樣認真鑽研的樣子，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不像平常的我喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈哈！",
        "unit_id": 104631,
        "voice": "vo_adv_1046011_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我自己也這麼覺得，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以沒關係啦喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
