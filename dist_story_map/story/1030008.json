[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍、將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "城鎮外面好像蓋了新的遊樂場！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "遊・樂・場！將軍大人、遊樂……",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這些詞語聽起來就讓人非常興奮是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我現在坐也不是、站也不是，太興奮了是也～！",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們趕快去啊、現在馬上去啦……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚哇！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "跌倒的妮諾抓著{player}的身體，\n直接往街道旁的階梯倒下去。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呀，要掉……",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咦？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n身體被奇怪的光包起來了是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哇啊啊啊啊啊啊────！",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_004"
    },
    {
        "type": "still",
        "still": "103000801"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！今天我們可是來到了要完成統一天下時，",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n絕對無可避免的關卡是也～！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒錯，就是遊戲中心！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過這裡的遊戲可不能等閒視之是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒錯！有些戰鬥是絕對不能輸的！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這可是場決定天下走向的大戰是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就是如此，請將軍拿著這個刀型的遊戲手把！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "開始囉！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這可是體感型武士劍術動作遊戲，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n「大和神劍Ⅱ」是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚呀、嘿～！嚇啊～！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這一關據說只要攻擊相撲選手256次",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n便能將他打倒是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "怎麼能在這裡輸給你是也！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n搭欸欸欸！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯，雖然我已經很努力了，",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但敵人也非尋常人物。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有如是鶴翼之陣是也……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊、啊！被幹掉了！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這樣的話……那就只好使出忍法・接關之術是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n咻啪啪啪啪！噹啷噹啷噹啷！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，這也是為了統一天下而必須要做的犧牲是也……",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n黃金色的、黃金色的饅頭……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "喂、老兄，100日圓而已就給她玩啊！",
        "unit_id": 1,
        "voice": "vo_adv_1030008_016"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "對啊、對啊！讓她過關嘛！",
        "unit_id": 1,
        "voice": "vo_adv_1030008_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "謝謝大家！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我越來越熱血沸騰了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我們現在熱情高漲……！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n將軍，就是現在！使出必殺技是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哇───！好厲害！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "多麽靈巧又高難度的必殺技是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哇～！以非常細微的動作在揮動刀子是也！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_020"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "真的假的啊，",
        "unit_id": 1,
        "voice": "vo_adv_1030008_021"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "太厲害了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "\n好像有彈簧裝在肩膀裡面一樣！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "果然不愧是將軍是也────！",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍使刀的技術太厲害了，",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n連遊戲手把也發出嘎吱的慘叫聲了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……嘎吱……慘叫聲？",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_024"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "喂～！",
        "unit_id": 1,
        "voice": "vo_adv_1030008_025"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n你把我們的遊戲手把弄壞了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n給我賠錢～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呀～",
        "unit_id": 103031,
        "voice": "vo_adv_1030008_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對不起是也─────！！",
        "unit_id": 103031
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？這是我給你的禮物！你做了個好「夢」嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1030008_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這是我依照你跟妮諾以前的記憶創造出來的「夢」，",
        "unit_id": 190011,
        "voice": "vo_adv_1030008_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n原來現在的你會採取這樣行動呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我看了也很開心呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1030008_029"
    },
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咦！",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_030"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這裡是哪裡？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……剛剛的是在做夢嗎？",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_031"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "已經是晚上了……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個時間，",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_032"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n遊樂場已經關閉了是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是……",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_033"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天在夢裡，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n跟將軍一起玩了好多東西呢！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以……我非常開心喔！",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_034"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "能待在將軍身旁……",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我是打從心底覺得開心是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "明天再好好地去遊樂場玩一場是也！",
        "unit_id": 103011,
        "voice": "vo_adv_1030008_036"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n將軍 ♪",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}不管是在不可思議的夢裡還是在現實中，\n都與妮諾一起玩樂過著快樂的日子。"
    }
]