    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼事啊",
        "unit_id": 116511,
        "voice": "vo_adv_6066103_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我和嘉夜夜的關係嗎？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那種事看就知道了吧！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才、",
        "unit_id": 116511,
        "voice": "vo_adv_6066103_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才沒有",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總是待在一起呢！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就算",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜不在，我也能獨當一面的！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……應該吧。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你、",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你幹嘛用那種眼神！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不准這樣看我啦！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不愧是小哥！",
        "unit_id": 116511,
        "voice": "vo_adv_6066103_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對我們觀察入微呢。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n因為只要有我和嘉夜夜在就天下無敵了嘛！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n記好嘍，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "龍人族中的最強組合，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是我和嘉夜夜！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什、",
        "unit_id": 116511,
        "voice": "vo_adv_6066103_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼～！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你說這什麼話啊！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不如說我平時都在阻止嘉夜夜失控耶？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥看人的眼光也太差了吧！",
        "unit_id": 116511
    }
]