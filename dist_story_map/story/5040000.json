    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真陽結束了兜售的工作回到了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n氣氛一如往常恬靜的【伊麗莎白牧場】。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我回來啦～",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "歡迎回來～",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？　",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴竟然出來迎接我，還真是難得。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來妳這麼期待我回來啊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才不是在等真陽啦。",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是因為訂的遊戲",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "差不多要送到了才出來等的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果妳有多餘的空閒的話，",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "偶爾也跟我一起",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n到鎮上去兜售吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "很有意思喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那倒是免了。",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說起來，妳還真有辦法這樣每天都拿著笨重的行李",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n到鎮上去呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要想到鎮上人們開心的表情，",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這些東西的重量根本沒什麼啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且，",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也多虧大家買了很多回去，所以回程是很輕鬆的～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "用那台攤車的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴應該也能拉得動啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪比我更能勝任那種工作吧。",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且真陽也能輕鬆一點。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪她其他的工作已經做得夠多了啦。",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也不能把她帶到人很多的地方去啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "既然我們幾個都可以接受的話，",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我想大家也沒問題的～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "習慣就好～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "習慣就好。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我巡視結束囉，",
        "unit_id": 103811,
        "voice": "vo_adv_5040000_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳今天回來得真早。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我回來了～",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒有啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最近這一陣子",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n印有伊麗莎白牧場標記的商品都賣得飛快呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我一個人能夠帶出去的量，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "瞬間就賣光光了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也很想幫上妳的忙……",
        "unit_id": 103811,
        "voice": "vo_adv_5040000_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可是卻只能想像出自己礙手礙腳的畫面。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞已經做夠多的工作了，妳別介意啦。",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "兜售的工作我請鈴鈴幫忙就好啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼結論會變成這樣啊。",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這應該去找莉瑪幫忙的嘛～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "鈴鈴和莉瑪莉瑪聽起來差不多嘛，一定可以的啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳在亂扯些什麼的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果莉瑪莉瑪自己也想要去鎮上的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n請她幫忙說不定也不錯呢……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那就去問問看莉瑪吧！",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n莉瑪在哪裡啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳要找莉瑪的話，",
        "unit_id": 103811,
        "voice": "vo_adv_5040000_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我剛剛看到她正在森林裡睡得很香喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "竟然撇下我跑去偷懶。",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不可原諒，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪這傢伙。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳有什麼資格說別人啊……",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n莉瑪莉瑪可是幫我們做了很多粗重的工作，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n偶爾會打個瞌睡也很正常的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦～",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太狡猾了吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說什麼狡猾，",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真要說的話鈴鈴妳啊……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊！",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "　該不會是我的遊戲送到了吧！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我話還沒有說完的啦！",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是的，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴真是讓人傷腦筋。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "遊戲♪　",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "遊戲～♪　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天要來玩個通宵囉～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 13311,
        "voice": "vo_adv_5040000_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你不是來送…………",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "遊戲……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "的吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "開始徵收家畜。",
        "unit_id": 13311,
        "voice": "vo_adv_5040000_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊？　",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "家畜……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "徵收？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "等一下！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5040000_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你、",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你們是幹嘛的！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n從哪兒冒出來的！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們被團團圍住了！？",
        "unit_id": 103811,
        "voice": "vo_adv_5040000_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳就是【伊麗莎白牧場】的公會會長嗎？",
        "unit_id": 13311,
        "voice": "vo_adv_5040000_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我就是公會的會長，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "找我有什麼事嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽，",
        "unit_id": 102611,
        "voice": "vo_adv_5040000_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這個人，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像說什麼要徵收家畜耶！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊……？　",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "徵收？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "意思是要把我們的牛都帶走嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n為、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不要抵抗。",
        "unit_id": 13311,
        "voice": "vo_adv_5040000_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "否則可是會吃苦頭的。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "別說是抵抗了，",
        "unit_id": 103311,
        "voice": "vo_adv_5040000_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我根本都還搞不清楚發生了什麼事……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽！　",
        "unit_id": 103811,
        "voice": "vo_adv_5040000_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳看那邊！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
