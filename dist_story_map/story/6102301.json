[
    {
        "type": "background",
        "background": "501870"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇哈──！",
        "unit_id": 123711,
        "voice": "vo_adv_6102301_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我好興奮呀～！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒想到",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "竟然可以和超人氣的直播主一起行動！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感覺這次的文化祭，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會成為有別於過往的文化祭喔！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那當然囉！",
        "unit_id": 123711,
        "voice": "vo_adv_6102301_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "全蘭德索爾規模最大的",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n同人誌販售會就辦在蘭祭裡嘛！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且會有許多",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n非常稀有的同人魔導書，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "光是這一點就很有參加的價值囉！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然！",
        "unit_id": 123711,
        "voice": "vo_adv_6102301_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為有趣的直播主非常多，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果一個一個慢慢看，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就算時間再多\n也不夠，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以我大多會",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "同時開好幾個視窗在看呢～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我能一次開五個視窗\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "追那些我粉的直播！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該說，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "五個視窗",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "已經是極限了啦！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那還用說！",
        "unit_id": 123711,
        "voice": "vo_adv_6102301_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟大家都懷抱著",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要讓觀眾看得開心的心意啊！\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你如果有興趣，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要不要我告訴你我推薦的直播主？\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說不定會因為看得太開心而熬夜睡不飽喔！",
        "unit_id": 123711
    }
]