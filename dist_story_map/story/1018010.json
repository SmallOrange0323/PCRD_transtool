    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鬧區裡正在舉行美食活動。\n{player}撥開混雜的人群，\n向不久前剛抵達碰面地點的伊緒搭話。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "…………啊，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "早安！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "抱歉，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我剛才只是在想點事情。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我有發呆這麼久嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過別在意。",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n今天是",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了答謝你前陣子協助我進行教學參觀，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓我們盡情玩得開心吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像這樣和你一起出來玩，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "說不定也能轉移注意力。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒什麼！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "今天前來本會場的各位，",
        "unit_id": 311,
        "voice": "vo_adv_1018010_005"
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "\n要不要來參加邊走邊吃蓋章集點活動呢～？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "只要收集吃料理而得到的集點章，",
        "unit_id": 311,
        "voice": "vo_adv_1018010_006"
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "\n就能交換精美的獎品喔～！　",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "集章卡在這裡～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要不要玩玩看蓋章集點活動？",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個嘛，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難得都來了，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們也參加看看吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓你擔心了嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不過我沒事的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "走，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "轉換心情好好玩樂吧！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "分店的店員1",
        "words": "好，",
        "unit_id": 411,
        "voice": "vo_adv_1018010_009"
    },
    {
        "type": "dialogue",
        "name": "分店的店員1",
        "words": "集點章一個。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "分店的店員1",
        "words": "\n謝謝惠顧～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看起來很好吃呢～",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也開動了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嚼嚼……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嚼嚼…………",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "…………吞下。",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！　",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒有，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是的！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是那樣的……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……也是呢，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "人家說把心事說給別人聽之後，心情會舒暢點，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就讓你聽聽我的心事好了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n能讓我說出這種事情的人，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也只有你了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實呀，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我在邀請你參加這個活動之後，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有參加了學生時期的同學會。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我好久沒有和以前的同學們見面了，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是大家都有男朋友，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "聽說大家出去都是雙雙對對的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看大家開心聊著男朋友的事，讓我感到好羨慕，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我也",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "希望自己有一天",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能交到可以對朋友說的男朋友。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不知不覺，就發現自己滿腦子都是這些事了，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "才會比平常還容易發呆和冒失的樣子呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "抱歉，還跟你說這些話！",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我今天是想回報你才邀你出來的，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "結果卻讓你擔心了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個是",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "約會的邀請……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們可是老師和學生。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼能夠真的去約會～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也是男孩子，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也是呢……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那不是少女漫畫常見的橋段嗎！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不行不行，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那怎麼行！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "距離活動結束還剩一點時間～！",
        "unit_id": 311,
        "voice": "vo_adv_1018010_021"
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "蓋章集點活動蓋滿集點卡的人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "\n麻煩",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "活動職員",
        "words": "請盡早去交換獎品～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不好了！",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n集點章還沒完全收集到！　",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們動作快點吧！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "小姐！",
        "unit_id": 1411,
        "voice": "vo_adv_1018010_023"
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "\n你們看起來好像很困擾呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難得來參加活動的說……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "呵呵呵……",
        "unit_id": 1411,
        "voice": "vo_adv_1018010_025"
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "要不要用",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "我店裡的章魚燒來解決妳的煩惱啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那種事做得到嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_026"
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "啊啊！　",
        "unit_id": 1411,
        "voice": "vo_adv_1018010_027"
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "偷偷跟妳說，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "其實我食材還有剩……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "所以，",
        "unit_id": 1411,
        "voice": "vo_adv_1018010_028"
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "小姐你們還差的集點章數量的份，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "\n我一起賣給你們算你們便宜，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "你們可以多買點回去吃嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "\n……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "有困難時就是要互相幫助，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "對吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我吃！　",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嚼嚼、嚼嚼！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊嗯，",
        "unit_id": 101811,
        "voice": "vo_adv_1018010_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "裡面好燙好濃稠～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "都要被燙傷了～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "跟我預料的一樣，",
        "unit_id": 1411,
        "voice": "vo_adv_1018010_031"
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "吃得很可口呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "分店的店員2",
        "words": "好，",
        "unit_id": 1411
    },
    {
