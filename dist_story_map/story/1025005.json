[
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿咻，嘿咻。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，行李好重！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是，只要再加把勁！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太好了～終於能看見蘭德索爾了呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好遠～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還以為在日落前到不了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是我奇蹟似地沒有搞砸，",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也沒有遇到魔物，順利來到這裡！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我今天的運氣好像很好～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，但因為是我……",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有可能在最後關頭掉進意想不到的陷阱，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "犯下讓一切都白費的致命錯誤呢！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不要鬆懈，努力到最後一刻吧～！",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "加油加油♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀哇！？",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n啊，嚇我一跳，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不要突然叫我啊～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你是……嗯，{player}？",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是巧遇呢，你在這裡做什麼呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，今天天氣的確很好呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我也已經熱到流汗了呢……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果不偶爾運動的話，對身體不好呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沐浴在陽光下悠閒地散步，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我覺得很棒～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？{player}……，",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你不到店裡買食物，而是狩獵附近的動物、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n摘水果來張羅嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "感覺很野性呢……",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難道你很窮嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊！",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這麼說來，我身上有今天早上做的餅乾！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果你肚子餓，不介意的話請吃吧～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我很不擅長做菜……",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以可能不怎麼好吃就是了♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯，總之……",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n城鎮外會有魔物等出沒，很危險喔～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯，雖然我也沒資格說你啦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我有些私事在身……",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以回故鄉村落去了一趟喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然在深山中，但大致上是能步行前往的距離。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以我不想浪費搭乘馬車的費用，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n決定步行往返。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這附近的魔物很溫馴，也不怎麼強呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以即使是我也能應付，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只要不進到森林，就沒有那麼危險喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖說疏忽大意可是大忌～",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n近來，我也有聽說魔物異常增多的傳聞。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是……",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我有必須",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "從故鄉帶回的物品，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以下定決心來個小旅行。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我在故鄉住了一晚，現在才剛回來。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐也很忙，",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我不希望",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "連我也不在【咲戀育幼院】呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為擔心孩子們，必須快點回去。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你要幫我搬行李？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀，嗯，真是幫了我大忙……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但{player}，",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n前些日子也幫我提東西了對吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼對我這麼好呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明我曾經用魔法把你轟飛，",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n給你添麻煩……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你真是個好人呢♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼……我就先謝謝你的幫忙囉。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有{player}幫忙搬行李的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我就能早點回到【咲戀育幼院】。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n男性果然很可靠呢……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我什麼事都想試著自己做，",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以忙不過來……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我總是搞砸、造成別人的困擾。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "偶爾也該依賴一下別人對吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025005_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為我遇見了{player}這樣的好人……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "果然，今天我的運氣好像很好♪",
        "unit_id": 102511
    }
]