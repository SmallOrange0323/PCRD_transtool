[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某個大晴天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}等人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了幫忙音樂劇團的公演，\n動身前往村子的劇場。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "話說回來，",
        "unit_id": 102311,
        "voice": "vo_adv_5100601_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒想到噗吉會有出演音樂劇的一天！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「喔？",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_001"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "怎麼？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳忘記我在繆思小鎮的精彩表現了嗎──？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒有忘記喔！",
        "unit_id": 102311,
        "voice": "vo_adv_5100601_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那時候的噗吉",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "超帥氣的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「當時真步公主",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_003"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "和綾音看起來也很可靠喔。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n正因為有兩位在，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我才能下定決心",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "參與音樂劇。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是呀。",
        "unit_id": 101011,
        "voice": "vo_adv_5100601_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那時候",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "劇團的各位",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也相當高興呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還能像這樣見到面，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是令人高興的緣分哪。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是啊是啊，",
        "unit_id": 102311,
        "voice": "vo_adv_5100601_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真的是這樣！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n音樂劇也很令人期待，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我最期待的是",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "能再見到劇團的成員們！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「是啊！",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_006"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我也這麼覺得……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "嗯？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "噗吉先生？",
        "unit_id": 101011,
        "voice": "vo_adv_5100601_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「……不，",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_008"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "是我多心了。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n一瞬間有種那傢伙在的",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "感覺……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "你說的「那傢伙」，",
        "unit_id": 101011,
        "voice": "vo_adv_5100601_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是指植物羊先生嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「是啊。",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_010"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不過那傢伙現在去旅行了，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不管怎麼說，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "都不可能那麼巧在這裡見到面。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_5100601_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "畢竟不久前才收到",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "牠說下次旅行要去",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "深山的信呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「對吧。",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_012"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "果然是錯覺吧！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n植物羊",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不可能會在這裡的。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "大姊姊你們，",
        "unit_id": 211,
        "voice": "vo_adv_5100601_013"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "認識植物羊嗎？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_5100601_014"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "熊熊先生、熊熊先生！",
        "unit_id": 211,
        "voice": "vo_adv_5100601_015"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n難道你就是",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "噗吉先生嗎？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「沒、",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_016"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "沒錯！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我就是噗吉大人啦！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n這麼快就有我的粉絲了嗎……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "真不虧是我！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉，你冷靜一點。",
        "unit_id": 102311,
        "voice": "vo_adv_5100601_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "根本沒有人說是你的粉絲！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「啊，",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_018"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "抱歉抱歉。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "所以說，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "小妹妹妳為什麼",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "認識我？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我們是初次見面吧？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯！",
        "unit_id": 211,
        "voice": "vo_adv_5100601_019"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "其實啊！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我是從植物羊那邊聽說的！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "小妹妹妳",
        "unit_id": 101011,
        "voice": "vo_adv_5100601_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "認識植物羊先生嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯！",
        "unit_id": 211,
        "voice": "vo_adv_5100601_021"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "植物羊是我的救命恩人",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "喔！",
        "unit_id": 211
    },
    {
        "type": "background",
        "background": "501840"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那個啊，",
        "unit_id": 211,
        "voice": "vo_adv_5100601_022"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "之前啊……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因為爸爸有工作，\n所以我們去了有點遠的地方。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "青蛙先生玩偶也有一起去！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因為爸爸要我當個乖孩子等他，",
        "unit_id": 211,
        "voice": "vo_adv_5100601_023"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "所以我就在噴水池附近，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n跟青蛙先生一起等喔，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "然後附近馬車的馬先生啊，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n就突然跑了起來呢！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "等我注意到的時候，",
        "unit_id": 211,
        "voice": "vo_adv_5100601_024"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "馬先生已經跑到好近的地方了……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n雖然大家",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "都大叫要我快逃，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n但是我害怕到沒辦法動了。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那時候，",
        "unit_id": 211,
        "voice": "vo_adv_5100601_025"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我真的覺得",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "「要被撞上了！」喔。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n所以我怕得",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "閉上了眼睛。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n然後……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "危險！",
        "unit_id": 16612,
        "voice": "vo_adv_5100601_026"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我聽到有人這樣說。",
        "unit_id": 211,
        "voice": "vo_adv_5100601_027"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "但是，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不管經過多久，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "馬車都沒有撞上我。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n我覺得奇怪，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "才發現是植物羊啊，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "衝進了我跟馬先生之間，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n幫我把馬先生擋下來了。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "痛痛痛痛痛……",
        "unit_id": 16612,
        "voice": "vo_adv_5100601_028"
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "沒事吧？",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "……嗯嗯，",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "太好了！",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "沒有受傷呢。",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "馬兒也是，",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "謝謝你願意停下來。",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "植物羊",
        "unit_id": 211,
        "voice": "vo_adv_5100601_029"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "超級帥氣喔！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "然後啊，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "植物羊在我還嚇一跳的時候，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n幫我把青蛙先生撿回來了。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "「雖然青蛙先生被馬車壓到了，",
        "unit_id": 211,
        "voice": "vo_adv_5100601_030"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不過只要把這個放進去就行囉。」",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n植物羊邊這樣說邊給了我綿毛。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "軟綿綿地跟棉花糖一樣！",
        "unit_id": 211
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「妳就是在那時聽說了我的事情嗎？」",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_031"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯！",
        "unit_id": 211,
        "voice": "vo_adv_5100601_032"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我聽了噗吉先生你們的事，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n還有玩偶亞瑟的事情。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "植物羊",
        "unit_id": 211,
        "voice": "vo_adv_5100601_033"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "在害怕和嚇一跳的心情從我心裡消失前，",
