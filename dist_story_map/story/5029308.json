[
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 111711,
        "voice": "vo_adv_5029308_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還站得起來啊！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n多麼驚人的執著呀……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "再這樣下去可是會被牠們壓制的！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒想到牠們竟然能讓我打得這麼盡興！",
        "unit_id": 111511,
        "voice": "vo_adv_5029308_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可以的話我也想要一直享受這無止盡的戰鬥，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但要是聖誕節就在這當中結束了，我也會有點困擾。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "拜託你們！馴鹿先生！",
        "unit_id": 111611,
        "voice": "vo_adv_5029308_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "冷靜下來好嗎！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不行，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "牠們已經聽不到我們說的話了。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "克莉絲提娜！",
        "unit_id": 111711,
        "voice": "vo_adv_5029308_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "望！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n現在正是讓牠們見識",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咱們候補聖誕老人實力的時候了！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓我們一起",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "創造聖誕節的奇蹟吧！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "奇蹟啊。妳還真浪漫呢，",
        "unit_id": 111511,
        "voice": "vo_adv_5029308_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "伊莉亞‧奧恩斯坦。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我純情的少女心都被妳觸動了……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製、製作人……",
        "unit_id": 111611,
        "voice": "vo_adv_5029308_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一邊揮劍一邊談論著少女心，好像有點……！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天是個會發生奇蹟的日子沒錯呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定要用我們的力量戰勝牠們！",
        "unit_id": 111611
    }
]