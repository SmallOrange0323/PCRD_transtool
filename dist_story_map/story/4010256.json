    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝你今天邀請我！",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我一直很期待",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "能跟你一起出來玩♪",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嘿嘿，",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_001"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "像這樣幫我慶生，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我真的很開心呢！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "畢竟我現在是自己一個人住，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還好沒有變成一個孤單的生日呢～",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過，",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有點沒想到",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "只有我們兩個呢……？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "班上的大家還說什麼",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "「兩個人好好相處喔～」",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "之類的話。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是的，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "明明不用那麼顧慮我的……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊，",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_003"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "剛才的話",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不用放在心上！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那麼，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "今天打算去哪裡呢？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "冒險是指，",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "一起玩遊戲嗎？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不是的話，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是指在這邊的世界冒險？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "原來如此，",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這樣啊……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "與其說是出去玩，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "更像是",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "一場小小的旅行？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不錯耶，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這個提議！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "感覺超有趣的♪",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "雖然來到這邊之後，",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "跟大家一起去了各種地方玩……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "但還是有很多沒去過的地方呢。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n全新的冒險，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "光是想像就讓人興奮不已！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好～",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就這麼決定了。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "禮物就是特別的冒險旅行！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "超棒的！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "目的地的話嘛，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想想……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯！",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_008"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "聽起來",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "超棒的！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我最喜歡的景色……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就是最好的生日禮物！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝你！",
        "unit_id": 105731,
        "voice": "vo_adv_4010256_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那就",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "出發吧！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我們一起去尋找",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "能成為一生回憶的藍天吧！",
        "unit_id": 105731
    }
]