[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一面度過短暫的快樂時光，\n{player}正在\n品嚐惠理子特製的巧克力。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 109011,
        "voice": "vo_adv_1090004_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還有巧克力喔。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請您盡情地享用喔……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是瘋狂地放入了我的愛情的",
        "unit_id": 109011,
        "voice": "vo_adv_1090004_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "巧克力呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "從{player}大人享用的量，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就能看出他對我的愛有多深……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 109011,
        "voice": "vo_adv_1090004_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n櫥櫃裡面好亮？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這道光是",
        "unit_id": 109011,
        "voice": "vo_adv_1090004_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼回事……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯嗚嗚，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好刺眼啊……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呀啊啊！",
        "unit_id": 109011
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我們今天來約會吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有一個無論如何都想去的地方。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了情人節，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要準備各式各樣的材料，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請您陪我出去採購吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您問那樣稱得上是",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "約會嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我是這樣認為的，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這就是約會呀。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n來，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們走吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在這邊的巷子裡，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n有間品項齊全的店呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您剛才就一直在偷瞄店裡，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n是在看什麼呢？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那邊放著的是高麗人參……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是能夠強健體魄，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還具有美容功效的",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "高級多年生植物。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "然後這個是蝮蛇……",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n和高麗參一樣，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "具有強健體魄的功效……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "欸，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您不知道這是中藥的原料嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其他還有蚯蚓的粉末",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和刺蝟的皮呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "該不會……",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n對藥物的材料感興趣嗎……？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是嗎……",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會買怎樣的材料？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這讓您很在意呀。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那個是",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "少女的祕密……",
        "unit_id": 102731
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "首先我們去那間店吧。",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_014"
    },
    {
        "type": "background",
        "background": "510330"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……呵呵，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您露出了很少見的表情呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這間店裡",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有著很齊全的\n各式各樣的香料。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看不出這裡是在賣香料的嗎？",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在這種地方意外地",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會賣\n很稀有的東西喔。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您喜歡妖艷的香氣嗎？　",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還是喜歡",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "刺激的香氣？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "原來您喜歡妖艷的香氣呢……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n「安全」指的是使用期限嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那樣的話您不用擔心。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就選這個令人如痴如醉的香氣吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣一來，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人也……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "原來如此，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您喜歡刺激的香氣呀……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "的確沒錯，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "強烈的香氣有著讓人無法抗拒的魅力呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "用這個材料的話，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會感覺到舌頭發麻般的刺激喔。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人的喜好，\n我又多知道一個了……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們前往下一間店吧。",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_023"
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這次是那邊的……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對不起，我突然停了下來。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什麼事都沒有。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們走吧……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我走路方式有點怪？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……您看得還真仔細呢。",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其實是",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的鞋子有點摩擦到了……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過，",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這點程度不要緊的。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還請您不要在意……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？　",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您要背我走嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這提議實在是很令人高興，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過讓您做到這程度實在是……",
        "unit_id": 102731
    },
    {
        "type": "still",
        "still": "109000401"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呀！　",
        "unit_id": 102731,
        "voice": "vo_adv_1090004_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
