        "voice": "vo_adv_5031002_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果那是下個檢查站的題目的話，",
        "unit_id": 107111,
        "voice": "vo_adv_5031002_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可不能把這小子交給妳們呀～",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這是戰場啊啊啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_5031002_059"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "選手們正在爭奪1位男性！",
        "unit_id": 1,
        "voice": "vo_adv_5031002_060"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n這恬不知恥又讓人羨慕不已的情景",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "正在眼前上演──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "觀眾中也有流著血淚、",
