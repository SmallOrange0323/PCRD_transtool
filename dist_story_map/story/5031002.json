        "words": "比賽",
        "unit_id": 1,
        "voice": "vo_adv_5031002_000"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "進入2區！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "　在這區，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "選手必須要完成",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "2個檢查站提出的題目。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這場競速賽……",
        "unit_id": 1,
        "voice": "vo_adv_5031002_001"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "只有跑速和體力是無法獲勝的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n目前排名",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "第一名，克莉絲提娜選手。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "第二名，莫妮卡選手。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n第三名，秋乃選手！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "　其他公會選手們",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "則繼續在後面追趕～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感謝你仔細的狀況說明！",
        "unit_id": 107111,
        "voice": "vo_adv_5031002_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "各位觀眾，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我正是克莉絲提娜☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "第一名正是我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲提娜‧摩根！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "竟然還整個大聲復誦一遍，",
        "unit_id": 103211,
        "voice": "vo_adv_5031002_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是庸俗呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我馬上就會把妳從第一名拉下來！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "以我來看，",
        "unit_id": 105311,
        "voice": "vo_adv_5031002_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "兩位都很大聲就是了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "　那個是……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "前3名的選手好像",
        "unit_id": 1,
        "voice": "vo_adv_5031002_005"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "已經到達中間點了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "令人在意的題目內容是！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我看看……",
        "unit_id": 105311,
        "voice": "vo_adv_5031002_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「將你心目中的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "款待用料理帶到檢查站」",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔？",
        "unit_id": 107111,
        "voice": "vo_adv_5031002_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我心目中的款待用料理嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "太簡單了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在馬上",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把王宮專屬主廚叫來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓他做出款待用全餐！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼！？",
        "unit_id": 103711,
        "voice": "vo_adv_5031002_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "　沒、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒時間浪費在那種事情上啦！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳想讓我的辛苦白費嗎！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "克莉絲提娜阿姨！",
        "unit_id": 100511,
        "voice": "vo_adv_5031002_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我覺得",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "虎虎脆片很不錯！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不是叫妳別喊我「阿姨」嗎？小姑娘♪",
        "unit_id": 107111,
        "voice": "vo_adv_5031002_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那就把那個加到款待用全餐裡吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "王宮專屬主廚！？",
        "unit_id": 103211,
        "voice": "vo_adv_5031002_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "　這我可不能輸……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就讓紫藤家專屬主廚來當妳們的對手！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼。",
        "unit_id": 107111,
        "voice": "vo_adv_5031002_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過就只是商人雇的主廚，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳以為能跟我們對抗嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "衛兵！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "　現在馬上就叫王宮主廚去準備款待用全餐！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n給我做好輸了就要掉腦袋的準備！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "沒想到沒想到──！",
        "unit_id": 1,
        "voice": "vo_adv_5031002_013"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "　明明題目並沒有說要進行料理對決，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n她們卻擅自",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "更改了內容！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n就在她們爭執不休時，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "落後的選手們也到達檢查站了～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我心目中的款待用料理？",
        "unit_id": 103611,
        "voice": "vo_adv_5031002_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "　……那樣的話……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "哎呀！",
        "unit_id": 1,
        "voice": "vo_adv_5031002_015"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "　就在這時，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "【小小甜心】的鏡華選手",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n已經把某個東西帶來了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 103611,
        "voice": "vo_adv_5031002_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這是……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我媽媽讓我帶來當點心的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "杯子蛋糕。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然外面賣的杯子蛋糕也很好吃，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是我最喜歡的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還是媽媽做的……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這",
        "unit_id": 1,
        "voice": "vo_adv_5031002_017"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "毫無疑問的是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "款待用料理啊啊啊啊啊啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n沒想到是由後來居上的鏡華選手",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "第一個通過考驗！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼辦……",
        "unit_id": 103811,
        "voice": "vo_adv_5031002_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果題目是要推薦的書，我馬上就能拿出來了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞！",
        "unit_id": 103311,
        "voice": "vo_adv_5031002_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "　這個如何！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "　牧場特製起司！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這個精心製作的起司，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要是蘭德索爾的人",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n應該至少都吃過一次！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽！！",
        "unit_id": 103811,
        "voice": "vo_adv_5031002_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n的、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的確，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這個起司不但味道醇厚，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "營養也相當豐富……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "吃了之後就會打起精神，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的確是個能當作款待用料理的好東西。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的身體狀況能變好的其中一個原因",
        "unit_id": 103811,
        "voice": "vo_adv_5031002_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也是因為",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "吃了這麼新鮮的食物……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我心目中的款待用料理",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就是牧場的起司！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "原來如此！",
        "unit_id": 1,
        "voice": "vo_adv_5031002_022"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "　這的確是大家都很熟悉的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "款待用料理！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n栞選手",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "以第2名通過！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 105311,
        "voice": "vo_adv_5031002_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只要拿出自己覺得是款待用料理的食物就行了吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n既然這樣，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們【純白之翼】",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "正在討論要不要正式採用的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這個乾麵包如何！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個是緊急糧食吧……",
        "unit_id": 103011,
        "voice": "vo_adv_5031002_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這麼乾巴巴的東西如果被採用的話，",
        "unit_id": 100811,
        "voice": "vo_adv_5031002_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我的胃會哀嚎的唷？",
        "unit_id": 100811
    },
    {
