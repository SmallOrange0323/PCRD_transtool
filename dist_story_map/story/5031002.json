    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳不要來硬插一腳！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳也是來硬插一腳的吧！",
        "unit_id": 103611,
        "voice": "vo_adv_5031002_056"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}要和我",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "跟栞一起走！",
