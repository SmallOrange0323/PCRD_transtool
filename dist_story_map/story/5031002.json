        "voice": "vo_adv_5031002_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　這個人絕對只是想這樣做而已吧──！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "實在是太野蠻了……",
