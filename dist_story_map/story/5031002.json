        "voice": "vo_adv_5031002_061"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "咬牙切齒的人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n我身為男性，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "也是同樣的心情啊啊啊啊！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對了，這樣正好！",
        "unit_id": 107111,
        "voice": "vo_adv_5031002_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不如",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就賭上這小子來場決鬥吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "公主大人☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等、等一下，",
