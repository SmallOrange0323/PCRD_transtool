[
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "從這魔物身上……",
        "unit_id": 117311,
        "voice": "vo_adv_5072308_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以感受到前所未有的力量……！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們既要唱歌跳舞，還要對付它，",
        "unit_id": 117411,
        "voice": "vo_adv_5072308_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n或許會有些吃力呢……！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行喔，妳們兩位！",
        "unit_id": 117211,
        "voice": "vo_adv_5072308_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們還站在舞台上，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "眼前更有滿滿的觀眾。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以說，我們要",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "繼續唱歌、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "繼續跳舞！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這全都是為了讓大家展露笑容！",
        "unit_id": 117211,
        "voice": "vo_adv_5072308_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為我們可是偶像啊！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 117311,
        "voice": "vo_adv_5072308_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我就知道望會這麼說。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就請妳盡情揮舞那把劍吧！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們會全力支援妳的！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就讓對手",
        "unit_id": 117411,
        "voice": "vo_adv_5072308_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好好見識一下我們隊長的本事吧！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來就輪到小望主場囉！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來吧，各位！",
        "unit_id": 117211,
        "voice": "vo_adv_5072308_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n絕對不要移開視線，看好囉！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這就是，",
        "unit_id": 117211,
        "voice": "vo_adv_5072308_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "慈樂之音的演唱會舞台！",
        "unit_id": 117211
    }
