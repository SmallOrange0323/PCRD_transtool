    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "平時雖然很亂來，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但這種約定",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "卻是一定會遵守的。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼……",
        "unit_id": 104211,
        "voice": "vo_adv_2109001_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "她會不會是",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "被捲入什麼麻煩中了呢？",
        "unit_id": 104211
