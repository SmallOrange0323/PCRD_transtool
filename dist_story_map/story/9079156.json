    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "姐、",
        "unit_id": 102111,
        "voice": "vo_adv_9079156_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "姐姐好厲害……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "把魔物打倒了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不，",
        "unit_id": 135614,
        "voice": "vo_adv_9079156_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "一點都不厲害……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我沒辦法像胡桃那樣去演……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "結果，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "什麼都沒改變……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我還是那個沒用的自己……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "姐、",
        "unit_id": 102111,
        "voice": "vo_adv_9079156_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "姐姐……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……",
        "unit_id": 102111,
        "voice": "vo_adv_9079156_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "大祓科戶風！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "！？",
        "unit_id": 135614,
        "voice": "vo_adv_9079156_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n胡桃，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳是在……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿，",
        "unit_id": 102111,
        "voice": "vo_adv_9079156_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "忍不住想模仿一下，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n姐姐太帥了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不用什麼演技，",
        "unit_id": 102111,
        "voice": "vo_adv_9079156_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n姐姐原本的樣子就很棒了喔。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135614,
        "voice": "vo_adv_9079156_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "竟、",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "竟然被這麼年幼的孩子安慰了。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "實在太沒用了……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇……！？",
        "unit_id": 102111,
        "voice": "vo_adv_9079156_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我是想鼓勵妳的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135614,
        "voice": "vo_adv_9079156_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "抱歉。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n剛才我本就應該",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "靠胡桃的話重新振作起來才對。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "唉，",
        "unit_id": 135614,
        "voice": "vo_adv_9079156_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我真是無可救藥啊。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n胡桃明明稱讚我很帥的。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n不能自我意識過剩，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "得先坦率地接受胡桃的話才行。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "胡桃，",
        "unit_id": 135614,
        "voice": "vo_adv_9079156_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "謝謝妳。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳給了我勇氣喔。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n雖然這次失敗了，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但我會積極訓練下去。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "訓練的第一步，",
        "unit_id": 135614,
        "voice": "vo_adv_9079156_012"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "為了讓現在的自己拿出自信……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我想先從習慣露出",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "自己的真面目開始。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "──我是志那都。",
        "unit_id": 135613,
        "voice": "vo_adv_9079156_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n請多指教。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好的，",
        "unit_id": 102111,
        "voice": "vo_adv_9079156_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "志那都小姐。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "重新自我介紹一下，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我是胡桃。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n請多多指教呢♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……話說回來，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可不可以把我護送到",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "安全的地方呢……",
        "unit_id": 102111
    }
]