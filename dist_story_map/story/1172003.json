        "words": "讓人看到煩惱的一面……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是你的話應該就沒關係",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……剛才說的事情，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_067"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "希望你能當成我們兩人之間的祕密。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為偶像得要一直閃閃發光的才好。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是為了把難過和悲傷的心情吹跑，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_068"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓大家露出笑容喔！",
        "unit_id": 117211
    },
    {
        "type": "background",
        "background": "500691"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "謝謝你們。",
        "unit_id": 1212,
        "voice": "vo_adv_1172003_069"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n真的是不知道",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "該怎麼和兩位道謝才好……",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請妳",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_070"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不要放在心上。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能回到媽媽身邊，真是太好了呢！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗯！",
        "unit_id": 213,
        "voice": "vo_adv_1172003_071"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "大姐姐，",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "謝謝妳～！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "妳救了我的寶貝女兒。",
        "unit_id": 312,
        "voice": "vo_adv_1172003_072"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "請一定要",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "讓我道謝。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "\n方便的話，",
