    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在巡演地點的海灘上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n望和{player}聊起今天的計畫。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之前跟",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再之前的假日都引起了騷動，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我今天",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定要悠哉地度過假日！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以說呢，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們就悠閒地在海邊散步吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以什麼都不做來度過時間也很奢侈呢♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還可以悠哉欣賞沒入海中的夕陽。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n等到了晚上之後──",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那個……",
        "unit_id": 1212,
        "voice": "vo_adv_1172003_003"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不好意思。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有什麼事情嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "請問你們有沒有看到一個小女孩？",
        "unit_id": 1212,
        "voice": "vo_adv_1172003_005"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我在找我女兒，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "大概",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "有這麼高……",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "小女孩？",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們沒看到……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "那",
        "unit_id": 1212,
        "voice": "vo_adv_1172003_007"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "她是不是沒到這個方向來呢……",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "很抱歉，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "打擾你們了。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請等一下！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳的女兒走丟了嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "是的，",
        "unit_id": 1212,
        "voice": "vo_adv_1172003_009"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "她不久前還跟我待在一起的，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "但我才一下子沒盯著她，她就跑不見了……",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個……",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果妳不介意的話，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可以讓我們也來幫忙找嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "咦？",
        "unit_id": 1212,
        "voice": "vo_adv_1172003_011"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "可是，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "這樣太麻煩你們了……",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果妳女兒是和媽媽走散的，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想她現在一定也覺得很不安。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣的話，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想趕快找到她，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓她放心下來。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝。",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我相信你一定會願意跟我一起找的。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真抱歉，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "變成要你幫忙了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "不好意思，",
        "unit_id": 1212,
        "voice": "vo_adv_1172003_014"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "很謝謝你們。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我們",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就往這個方向沿著海岸找找看。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個方向",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就拜託你了！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一段時間後，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們再回這裡會合喔！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你那邊如何？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有找到嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也沿著海岸走到了遙遠的另一端，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "卻沒有收穫。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那位媽媽",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說她要再去樹林那邊看看。",
