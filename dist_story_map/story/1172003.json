        "words": "掰掰～！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_080"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也會",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓自己變得更加出名，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n努力讓妳也能認識我的！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
