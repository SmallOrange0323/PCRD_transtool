    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會不會是往城鎮那邊跑了？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但這個可能性好像不高……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "奇怪？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你來這邊一下！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是……",
        "unit_id": 117211
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒想到海灘居然與這種地方是連通的。",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她是不是不小心闖進這裡的深處了？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的耶。",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好小的腳印……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她一定是不小心跑進這裡了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後還有另一道……",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "魔物的腳印吧？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沾過海水的腳印還很濕，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像是剛剛才經過這裡的。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n狀況可能有點不太妙……！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "快走吧！",
        "unit_id": 117211
    },
