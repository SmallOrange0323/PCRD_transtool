    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "請告訴我妳的名字……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "單純是我想幫忙而已。",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_073"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳就當成是這樣吧──",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "說到這個，",
        "unit_id": 1,
        "voice": "vo_adv_1172003_074"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "有傳聞說剛才有人在這片沙灘上看到望望喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "怎麼可能啊，",
        "unit_id": 1,
        "voice": "vo_adv_1172003_075"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "立於巔峰的頂尖偶像，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n哪會特地跑來人潮眾多的海灘來……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "呃，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "嗯？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯，",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_076"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們在海灘上到處跑，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還想完全不露餡，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣的確是",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想得太美了呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我明明想",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_077"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "悠哉地度過接下來的休息時間啊～",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n話雖如此，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再這樣下去，好像又會造成大騷動。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……事情就是這樣，{player}！",
        "unit_id": 117211,
        "voice": "vo_adv_1172003_078"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "準備好，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要跑囉！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "唱歌的大姐姐，",
