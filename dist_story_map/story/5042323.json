[
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很好，",
        "unit_id": 100113,
        "voice": "vo_adv_5042323_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "連闇影也打倒了！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就這樣順勢一口氣……",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "黑之王",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 13411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106612,
        "voice": "vo_adv_5042323_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這股瘴氣是怎麼回事啊！？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n強度是之前所無法比擬的！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此……",
        "unit_id": 106711,
        "voice": "vo_adv_5042323_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "牠把所有瘴氣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都朝向了我們……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這大概就是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "黑之王的全力……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不對，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該說是最後的垂死掙扎吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳、",
        "unit_id": 113011,
        "voice": "vo_adv_5042323_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳是說，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "牠的力量比至今為止都還要強嗎？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎怎怎、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎麼辦啊～！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這超乎了我的想像。",
        "unit_id": 4611,
        "voice": "vo_adv_5042323_004"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n再這樣下去，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "很不妙呢……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……沒事的！！",
        "unit_id": 112911,
        "voice": "vo_adv_5042323_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "璃、",
        "unit_id": 100113,
        "voice": "vo_adv_5042323_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "璃乃？",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為",
        "unit_id": 112911,
        "voice": "vo_adv_5042323_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這裡有救世主……",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不對，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為這裡有這麼多",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n想拯救這個世界的人啊！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們的心意……",
        "unit_id": 112911,
        "voice": "vo_adv_5042323_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們的意念，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是不會輸的！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "璃乃……",
        "unit_id": 4611,
        "voice": "vo_adv_5042323_009"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳說得對！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我們的心意，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "不會輸給任何人！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是說啊！",
        "unit_id": 100113,
        "voice": "vo_adv_5042323_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我也一樣，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我超喜歡這個世界！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼！",
        "unit_id": 106612,
        "voice": "vo_adv_5042323_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然如此我就奉陪到最後吧！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來，",
        "unit_id": 112911,
        "voice": "vo_adv_5042323_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們走吧！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "去保護這個世界！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "好──！！",
        "unit_id": 1,
        "voice": "vo_adv_5042323_013"
    }
