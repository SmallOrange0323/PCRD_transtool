[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可在同一時間，\n正以蘭德索爾的公主身份，\n出席了貴族們的會議。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗯……？",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛剛",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼感覺好像",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聽到遠處傳來了{player}的聲音……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是我的錯覺嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "……那麼，",
        "unit_id": 191411,
        "voice": "vo_adv_2101002_002"
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "\n蘭德索爾市街第7區，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "以及第8區的重建事業就按原計畫，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "\n由【里士滿工商會】來主導進行，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "沒有問題吧，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "陛下？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_003"
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "……尤絲蒂亞娜陛下？",
        "unit_id": 191411,
        "voice": "vo_adv_2101002_004"
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "\n這麼做沒有差錯吧？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就那麼辦吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "……真是的。",
        "unit_id": 191411,
        "voice": "vo_adv_2101002_006"
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "您這麼漫不經心可會讓人很困擾的，陛下。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "您就是點了一個頭，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "蓋了一個章，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "\n也都將會關係到非常多人民的明日，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "這點還望您能夠銘記在心。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好、",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……你不用擔心，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我都明白的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然王宮裡頭那些被霸瞳皇帝奪走了記憶的人們",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都能夠想起來我才是真正的尤絲蒂亞娜了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而雖然這當然是一件好事……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過……",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為父皇與母后長時間",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n被設置在了那個能夠奪走魔力的裝置之中，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以雖然保住了一命，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但意識卻還沒辦法恢復。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我也只能放下劍，",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後拾起羽毛筆和玉璽……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n僅管還不習慣但我也只能硬著頭皮，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "做為國家的代表忙著這些國事。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明白的……",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這都是為了讓那些在霸瞳皇帝之亂下受到迫害的人們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可以盡早",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "恢復到原本的生活當中。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了讓生活在這個城裡的人們，",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可以安心的在屋簷下，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃著那些美味的飯菜……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要盡我最大的努力去幫助他們。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "那麼您的這份心情，",
        "unit_id": 191411,
        "voice": "vo_adv_2101002_013"
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "就讓我們用行動來表示吧。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "我等貴族議會",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "也將竭盡全力，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "助陛下您一臂之力。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族議長",
        "words": "\n我說的是吧，諸位？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "是的，",
        "unit_id": 1,
        "voice": "vo_adv_2101002_014"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "豪紳議長！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n這一切，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "都是為了蘭德索爾的明日！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "蘭德索爾的公主，",
        "unit_id": 191411,
        "voice": "vo_adv_2101002_015"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "尤絲蒂亞娜陛下，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "萬歲！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "蘭德索爾的公主，",
        "unit_id": 1,
        "voice": "vo_adv_2101002_016"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "尤絲蒂亞娜陛下，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "萬歲！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……沒錯。",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n蘭德索爾的公主殿下，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這便是現在，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是本來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我所擁有的正式身分。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然對宮裡的人們來說，",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是理所當然的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然而最近，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我卻不太能夠做為",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那吃遍美食的公會【美食殿堂】",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一員的貪吃佩可出去活動了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "尤絲蒂亞娜陛下，",
        "unit_id": 191411,
        "voice": "vo_adv_2101002_019"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "萬歲！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "尤絲蒂亞娜陛下，",
        "unit_id": 1,
        "voice": "vo_adv_2101002_020"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "萬～歲！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜。",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那明明就是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真正的名字……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但現在總覺得，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽起來有一點奇怪。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那些願意叫我貪吃佩可的大家……",
        "unit_id": 105812,
        "voice": "vo_adv_2101002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都在做些什麼事呢……？　",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "510221"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……騎士先生，",
        "unit_id": 1,
        "voice": "vo_adv_2101002_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "騎士先生……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊，",
        "unit_id": 1,
        "voice": "vo_adv_2101002_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你終於起來了呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真是的，大家都回去了唷。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我？　",
        "unit_id": 1,
        "voice": "vo_adv_2101002_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在看你的睡臉呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n嘻嘻，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很可愛唷。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不論看多久",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "都不會膩。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為……",
        "unit_id": 1,
        "voice": "vo_adv_2101002_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我呀，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n從很久以前開始，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就對你……",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510072"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵。",
        "unit_id": 1,
        "voice": "vo_adv_2101002_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n呵呵呵……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "{player}你呀……",
        "unit_id": 1,
        "voice": "vo_adv_2101002_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這可不行唷？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n怎麼可以像那樣，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "把臉埋進女孩子的這裡呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是的，",
        "unit_id": 1,
        "voice": "vo_adv_2101002_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真拿你沒辦法呀。",
        "unit_id": 1
    },
    {
