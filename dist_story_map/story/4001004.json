    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀啊？",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n妳什麼時候跑到在下背後的？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜託你了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請讓精神錯亂的貪吃佩可小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n恢復正常！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為大概只是因為這奇怪的霧，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以被攪亂神智了而已！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n用凱留小姐的魔法，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該可以……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咿！？",
        "unit_id": 105911
    },
    {
        "type": "background",
        "background": "500362"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈哈哈。",
        "unit_id": 106011,
        "voice": "vo_adv_4001004_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去死去死去死！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n反正每個人都是非死不可啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是早晚的問題啊！",
        "unit_id": 106011,
        "voice": "vo_adv_4001004_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就死在這吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n大家全都去死吧……☆",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "500362"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦耶！？",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n連凱留小姐都神智不清了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不要施展攻擊魔法！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "搞不清楚狀況了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為什麼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼要將在下抱起來呢？……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您也神智不清了嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不想要這樣！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只有主人，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直是那麼溫柔可靠……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請維持在下所愛的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人原本的樣子！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚嗚……",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，什麼事？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為危險，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了要先暫時避難。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才抱起在下嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只有在下跟主人還保持正常。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有受到這個",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奇怪的霧所影響呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為主人是",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「特別的存在」，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還能理解……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，為什麼連在下也？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是不是因為有愛梅斯大人的庇佑呢，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n由於在下的虔誠而賜下恩典……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "愛梅斯啊，",
        "unit_id": 1,
        "voice": "vo_adv_4001004_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n現在「那傢伙」是這麼稱呼自己的？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的肩膀上，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有個感覺小巧可愛的小姐？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "小巧可愛？",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是在稱讚我嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "第一印象是很重要的！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "感覺是個很乖的孩子呢～",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我或許也能理解菲歐為何如此疼愛了♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "菲、",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "菲歐？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯～",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那傢伙現在自稱愛梅斯吧……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那是我們「嚮導小妖精」原型的名字，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過聽說是失敗品，所以被廢棄了呢！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那傢伙是將撿到的原型資料融合，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n作為強化自身的材料了吧！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是這麼回事吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為那傢伙從以前開始，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就很擅長搞這種小把戲呢！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……？",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抱歉！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一直自言自語，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是我的壞習慣呢？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我總是這樣自顧自的說不停，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈哈！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是別因為我很自我中心，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就討厭我喔？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n因為妖精不討人喜愛的話，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就會消失的！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "話說回來。",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_028"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我是「嚮導小妖精」涅比亞，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你們是何方神聖啊？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "解除這個房間封印的人，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_029"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就是你們嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "涅比亞……",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是您的大名嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是不是就是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "封印在三樓的那個",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「什麼」",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在不是悠閒聊天的時候！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐跟凱留小姐……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奇怪？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼嚕、",
        "unit_id": 105811,
        "voice": "vo_adv_4001004_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼嚕……♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼嚕，",
        "unit_id": 106011,
        "voice": "vo_adv_4001004_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼嚕……♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "睡、",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "睡得正香呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是您讓他們睡著的嗎，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "涅比亞大人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯。",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_035"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我使用「嚮導小妖精」的權限，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n把帳號暫時凍結了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "現在似乎到處都是莫明其妙的狀況，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_036"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "而我的權限也不是說多大……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "反正，應該沒多久就會醒來了吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "比起那個……",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_037"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n吶，你是{player}對吧？\n你還記得我嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "跟我多說點事情吧。",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_038"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我一直是籠中鳥，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "現在完全搞不清楚狀況！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「完全搞不清楚狀況」",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們要說的呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問您認識這位大人嗎，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該怎麼辦……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在完全",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "搞不清楚情況了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總之先將貪吃佩可小姐她們，",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n帶到安全的地方去吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊～",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_042"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那邊放著不要緊的。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "在我被封印的同時，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n連附近的『幻影湖之霧』也被一起關進來了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "只要接觸到那東西，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_043"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就會暫時變得怪怪的。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我會先回收『幻影湖之霧』，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_044"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我想他們醒過來後就會恢復神智了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "比起那個，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_045"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可以告訴我現在這個世界變成什麼樣子了嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐那傢伙跑哪去了？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我已經",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "快要抑制不住滿出來的好奇心了！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……？",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_046"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位～？",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_047"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n不、不要緊吧？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "花凜小姐！",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡很危險，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請在樓下等著！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "可是，",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_049"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我聽到各位的尖叫聲……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n到、",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "到底情況如何呢？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呀………",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_050"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n好、",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "好像有個小生物呢？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我叫涅比亞！",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_051"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯嗯……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "看來妳好像",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是這棟建築的",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "管理員？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "抱歉啊，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_052"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "沒付房租就一直這麼白住。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但這可不是我的錯唷，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我只是犯點小錯就被關起來了？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這裡",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_053"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就像是我們「嚮導小妖精」的監獄喔。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n一旦故障發生時會暫時被隔離在此，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n並被修復至能再次使用的狀態。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "原本應該是這樣的。",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_054"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我卻一直被放置不管，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n快要無聊死了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然樓下有菲歐的氣息，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_055"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但不論我怎麼呼喚",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那傢伙都沒回應。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "菲歐………",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_056"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我對這個名字沒什麼印象呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不過被封印在樓下的「什麼」………",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_057"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n似乎使用了空間轉移的魔法陣，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n已經不知道跑到哪裡去了",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哼嗯……",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_058"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這樣的話帶我一起去就好了嘛，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難道連這點餘力都沒有嗎",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "話說。",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_059"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "該不會是忘記我了吧，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那個傢伙。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過算了！",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_060"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n久違地恢復了自由之身，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我的心情非常好！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "現在無論怎麼被對待我都會原諒、",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_061"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有什麼願望我都會為你實現♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "願望……",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_062"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那個，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "總之像是關於您是什麼人物等等，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n如果能夠先詳細說明一下就太好了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "還有，如果三樓",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_063"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "能像平常一樣使用就好了～",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有何不可呢？",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_064"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "反正這棟建築，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n也不是我的所有物……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就隨你們用吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我也要隨心所欲～",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_065"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n好好享受久違的自由♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "吶吶，{player}！\n你帶我四處看看吧！",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_066"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就我所見，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_067"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n世界似乎徹底變得不一樣了？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "現在完全是狀況外呢！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不對。",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_068"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我可以暫時",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "與你們一起生活嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我也沒其他地方可去，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "如果能住在這裡就好了♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "看來你們，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_069"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n似乎和菲歐有因緣……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "只要和你們一起，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_070"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n或許還能再見到那傢伙。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n可以吧，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不會給你們添麻煩的啦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣……",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還真是自顧自的說話呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "涅比亞大人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼辦呢？",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也只是借用這棟建築物而已……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "交給【公會管理協會】的",
        "unit_id": 105911,
        "voice": "vo_adv_4001004_073"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n花凜小姐決定吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "咦、",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_074"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "唔～？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果只是讓妖精住下的話，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我想應該沒什麼問題。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但是相對地，",
        "unit_id": 190811,
        "voice": "vo_adv_4001004_075"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "還有很多事情……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n例如你是何方神聖等等，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "通通交代清楚吧。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_076"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "協議成立！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "暫時要受各位關照了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那個，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "花凜？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有妖精棲息的建築物是會繁榮的喔，",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_077"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "絕不會讓妳們覺得發現我是會帶來厄運什麼的！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "請多指教唷！",
        "unit_id": 190911,
        "voice": "vo_adv_4001004_078"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "讓我們相親相愛吧，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n作為同居人……♪",
        "unit_id": 190911
    }
]