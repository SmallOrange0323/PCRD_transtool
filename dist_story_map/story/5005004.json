[
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "珠希、美冬和{player}，\n因為想再開拓這座島，\n所以打算踏入之前從未去過的島之洞窟。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了進一步發展這座島，",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "再度組成了珠希探險隊喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "貓咪們",
        "words": "喵──！",
        "voice": "vo_adv_5005004_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等一下珠希，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可以不要把我攪和進奇怪的探險隊嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過這裡，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好像是自古以來就存在的洞窟呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總覺得，有種不一樣的氣氛喵。",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n對了喵，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把這裡做成神殿如何喵～？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "然後把我們當作神明一樣祭祀喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貓神明喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不錯呢！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "做成溫泉也不錯呢？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n洞窟溫泉這種東西，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也別有一番風味唷。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那也不錯喵～",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "洞窟溫泉一定又可以大賺一筆喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好猶豫喵～……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯？",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的耶喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這個是，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一疊紙……？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是呢。",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要注意不要滑倒才行……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "奇怪？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n那裡好像掉著什麼東西？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然很古老，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但這個是筆記本啊！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是在我們之前的人留下來的東西，",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n終於找到了喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是呢！",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這筆記本的主人不曉得怎麼了……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這裡應該沒有很強的魔物才對……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "趕快來讀讀看",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這本筆記本喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯……",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "什麼什麼……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「在我們海盜團飄到這座奇妙的島一陣子後。",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n夥伴們連日享受著酒池肉林的宴會，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n只有我調查了這座島，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "查明了真相。」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「這座島，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這座島本身就是魔物。」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「島上的人會感受到這裡是……",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "能實現所有願望的夢之島，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但我們在這座島上享受的東西，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n實際上",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只是這個叫做『島鯨』的魔物所製造出的幻覺……」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎、",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼會有這種事喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過的確是，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "自從來了這座島之後，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一切都順利地太不正常了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "冷靜思考後，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就覺得以貓咪們做出來的成品來說，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n珠希宮殿和訓練場",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也都完善到太不自然。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "從一開始，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "讓我們看到的就都是幻想呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過……",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "即使是幻想，如果我們不覺得是那樣的話，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n也不能完全說是幻想吧喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼說也……",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "算、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "算了。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我要繼續往下唸了喔。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「我曾經，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "無數次嘗試過逃離但是都失敗了。」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「雖然一起飄來島上的夥伴們開心地在島上生活著，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n不過最後都以異常的速度衰弱死掉了……」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「島鯨是，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "以人的欲望作為養分生存的魔物。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n因此，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "會挑選欲望強烈的人並吸引他們過來……」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「然後，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "進入島上的人類會被榨取欲望，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n在短短的時間內死去……」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "再這樣下去我們馬上都會死嗎喵！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，等等！？",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還有後續呢！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「不過，某一天，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我突然靈機一動。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n對無力的我來說",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是無法打倒島鯨的。」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「於是，",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就決定來和島鯨談判。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我拜託牠放了我一人，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "作為交換，\n我會向外宣傳這座島的傳聞，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "吸引強烈欲望的人們進來。」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「所幸談判很順利。",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這個筆記，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是怕如果有個萬一，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以把這件事的始末做為出發前的紀錄留下來。」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "…………原來如此……",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_028"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以，這座島的傳聞才會在海岸那裡傳開呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 107911,
        "voice": "vo_adv_5005004_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "根據這本筆記所紀錄的，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n好像是可以和島鯨對話的喵……？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼……",
        "unit_id": 108011,
        "voice": "vo_adv_5005004_030"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們應該採取的行動是……",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同時間，在瑪爾傑海岸──"
    },
    {
        "type": "dialogue",
        "name": "觀光客",
        "words": "那、",
        "unit_id": 1011,
        "voice": "vo_adv_5005004_031"
    },
    {
        "type": "dialogue",
        "name": "觀光客",
        "words": "那個是什麼……？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "觀光客",
        "words": "\n是鳥嗎，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "觀光客",
        "words": "還是魔物……？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "觀光客",
        "words": "不……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "觀光客",
        "words": "嗚啊啊啊啊啊！",
        "unit_id": 1011,
        "voice": "vo_adv_5005004_032"
    },
    {
        "type": "dialogue",
        "name": "觀光客",
        "words": "\n飛空艇",
        "unit_id": 1011
    },
    {
