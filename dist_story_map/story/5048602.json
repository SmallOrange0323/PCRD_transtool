[
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦，",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳怎麼",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "又在看拉菲寫的信呀？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜、",
        "unit_id": 102211,
        "voice": "vo_adv_5048602_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只要反覆看她寫的信，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不知道為什麼，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我就會充滿活力和勇氣，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "忍不住",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就這麼做了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實我也一樣♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "光是想像拉菲努力的身影，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就覺得心裡暖暖的，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "湧上一股幸福的感覺。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "然後呀，",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我要作為一名天使，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "把這份幸福分享給大家。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只要看見大家的笑容，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我又會感到更幸福。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "幸福就這樣不斷循環，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "最後全世界都會變得很幸福，多美妙呀！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呵呵，",
        "unit_id": 102211,
        "voice": "vo_adv_5048602_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里果然很厲害。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n妳已經是一名出色的天使了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊就顧著誇我，",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳才是最棒的天使啦♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n身為雙胞胎天使的一份子，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也感到很驕傲喔！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……妳也說得太誇張了吧，",
        "unit_id": 102211,
        "voice": "vo_adv_5048602_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "既然我們現在有活力也有勇氣了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那就得好好加油囉！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯。",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們要把",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "多好多幸福送給蘭德索爾的每一個人！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "美少女天使",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "即刻降臨♪",
        "unit_id": 100611
    }
]