    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你很在意泳裝的圍巾，",
        "unit_id": 113211,
        "voice": "vo_adv_6044309_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你竟然不懂這身打扮的意義……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我體內既然蘊藏著黑暗之力，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可就不能毫不隱藏而直接外出。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "必須使用這個控制裝置",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "調整與光之能量間的平衡！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……才、",
        "unit_id": 113211,
        "voice": "vo_adv_6044309_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "才沒那回事！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不過是條圍巾，根本不算什麼！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我老早就習慣",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這種程度的煉獄之炎了。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "別小看我……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "抱歉，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你可以去幫我買個冰嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯，",
        "unit_id": 113211,
        "voice": "vo_adv_6044309_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒有錯！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "很抱歉沒有對吉格魯特解釋。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "若是你也想調整能量，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要立刻跟我說喔！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵呵呵。",
        "unit_id": 113211,
        "voice": "vo_adv_6044309_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒想到你能注意到這身打扮的亮點……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你很行嘛，吉格魯特！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你要不要也戴戴看？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就把備用品借給你吧！",
        "unit_id": 113211
    }
]