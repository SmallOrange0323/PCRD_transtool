[
    {
        "type": "background",
        "background": "500532"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到森林深處的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n找到了籠罩悲傷氣氛的露娜。"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_000"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……啊。",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_001"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_002"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n……大哥哥早就知道了嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_003"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜，聽到了唷。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n那個老婆婆，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "殺了露娜的爸爸和媽媽。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "她說了吧……",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_004"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我聽到了唷。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……為什麼？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……這是真的嗎？",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_005"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_006"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "老婆婆",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_007"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "是不好的人嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但是，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "她的三明治很好吃……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……露娜，",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_008"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "搞不清楚了。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "露娜低著頭垂下臉來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}叫了她，她也不回話。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "覺得露娜和老婆婆直接當面談比較好的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n離開露娜身邊前往尋找老婆婆。"
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……",
        "unit_id": 611,
        "voice": "vo_adv_1114006_009"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n……你怎麼了，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "怎麼這個表情。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……啊，",
        "unit_id": 611,
        "voice": "vo_adv_1114006_010"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "難不成",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個孩子發生了什麼……！？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……是啊。",
        "unit_id": 611,
        "voice": "vo_adv_1114006_011"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n你說得對。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就這樣一直逃避，",
        "unit_id": 611,
        "voice": "vo_adv_1114006_012"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "什麼都不會改變的。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我自己也知道。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……但即使知道，",
        "unit_id": 611,
        "voice": "vo_adv_1114006_013"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "也沒能做到。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "之前都一直這樣。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我能做的事，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就是烤麵包而已。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……我一個人的話，",
        "unit_id": 611,
        "voice": "vo_adv_1114006_014"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就會",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "繼續這樣下去吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "繼續痛苦著……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……多虧有你推我一把，",
        "unit_id": 611,
        "voice": "vo_adv_1114006_015"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我才能往前呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "所以，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "謝謝你呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我不知道會變成怎麼的情況……",
        "unit_id": 611,
        "voice": "vo_adv_1114006_016"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n但我會去和那個孩子談談。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "好好地",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "正面對談……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……你能帶我",
        "unit_id": 611,
        "voice": "vo_adv_1114006_017"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "去她那裡嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "麻煩了。",
        "unit_id": 611,
        "voice": "vo_adv_1114006_018"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n謝謝你……",
        "unit_id": 611
    },
    {
        "type": "background",
        "background": "500532"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "到達露娜洋房附近的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n等待著{player}的，竟是魔物的咆哮聲。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……啊。",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_019"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那……！？",
        "unit_id": 611,
        "voice": "vo_adv_1114006_020"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n是魔物嗎……！？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "怎麼會……",
        "unit_id": 611,
        "voice": "vo_adv_1114006_021"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "明明不曾出現在這附近的說……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "別過來唷……",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_022"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不要過來……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "魔物慢慢地接近著露娜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}緊握住劍。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可是，魔物的動作一瞬間加速了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n魔物襲向露娜――"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "危險！",
        "unit_id": 611,
        "voice": "vo_adv_1114006_023"
    },
    {
        "type": "background",
        "background": "500532"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "呃！",
        "unit_id": 611,
        "voice": "vo_adv_1114006_024"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "老婆婆……！？",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_025"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "老婆婆跑到魔物前，保護了露娜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}用劍斬了魔物。"
    },
    {
        "type": "background",
        "background": "500532"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "老婆婆……！",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_026"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "　",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "老婆婆……！？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……太好了。",
        "unit_id": 611,
        "voice": "vo_adv_1114006_027"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "妳沒受傷吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "妳沒事吧？",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_028"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n會不會痛……！？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊啊。",
        "unit_id": 611,
        "voice": "vo_adv_1114006_029"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n只是一點擦傷而已。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……真是幫了大忙。",
        "unit_id": 611,
        "voice": "vo_adv_1114006_030"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n如果你不在的話，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "現在我就會被當成食物了呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_031"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "對不起。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "剛剛在發呆著……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "沒有辦法，",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_032"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "好好使用我的力量……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "對不起……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "錯的不是妳唷。",
        "unit_id": 611,
        "voice": "vo_adv_1114006_033"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……而是我。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114006_034"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……那個，",
        "unit_id": 611,
        "voice": "vo_adv_1114006_035"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "聽我說。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n小姐……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是我唷。",
        "unit_id": 611,
        "voice": "vo_adv_1114006_036"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n是我……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "殺了妳的父母。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "如果我更可靠的話……",
        "unit_id": 611,
        "voice": "vo_adv_1114006_037"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那天我就會去呼救。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n那樣的話，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "妳的父母",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "說不定就會得救。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n都是我的錯……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……請原諒我，",
        "unit_id": 611,
        "voice": "vo_adv_1114006_038"
    },
    {
        "type": "dialogue",
