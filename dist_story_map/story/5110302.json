[
    {
        "type": "dialogue",
        "name": "樂園守護者",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 17111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "出現了！",
        "unit_id": 125014,
        "voice": "vo_adv_5110302_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家別大意！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哼，",
        "unit_id": 124911,
        "voice": "vo_adv_5110302_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣正好！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有出拳的價值是再好不過的了。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我可是不會輕易被擊倒的喔？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……只聽妳的發言，不管怎麼想都像極了壞人呢，",
        "unit_id": 124811,
        "voice": "vo_adv_5110302_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘉夜。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 124911,
        "voice": "vo_adv_5110302_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為我是幫派成員啊！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在不用管什麼有什麼頭銜了！",
        "unit_id": 125014,
        "voice": "vo_adv_5110302_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們是",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "絕對不會輸的！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要知道這個就夠了！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵。",
        "unit_id": 124811,
        "voice": "vo_adv_5110302_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "矛依未就是矛依未，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "很像是正義的一方呢。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啥！？",
        "unit_id": 125014,
        "voice": "vo_adv_5110302_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳這樣說，我會很困擾！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我可是世界第一的大壞蛋！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈──哈哈哈哈！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈──哈哈哈哈哈──！！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如何！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣就很像是壞蛋吧！？",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……也就是說，",
        "unit_id": 124811,
        "voice": "vo_adv_5110302_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在戰鬥前放聲大笑，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是矛依未理想中壞蛋該有的特點是吧……",
        "unit_id": 124811
    }
]