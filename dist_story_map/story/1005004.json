        "voice": "vo_adv_1005004_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嚼",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嚼♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呼哈，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "多謝款待！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n真是美味～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不好意思，{player}。",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n總覺得對你很抱歉。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n結果到最後",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓你一直陪著我到太陽下山了呢？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「魔法少女鈴鈴噹」的秀，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n也看到最後了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "完全變成了粉絲，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n還一起到店裡找她的周邊商品呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我手上根本沒什麼錢，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只能夠買一些小東西。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你看，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我買了有鈴鈴噹圖案的橡皮擦、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n手帕，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還有馬克杯。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "粉紅色的，好可愛。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這對我來說",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有點新鮮。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我房間",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的感覺很男孩子氣，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "光是這個就讓我有些雀躍了呢……♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總而言之，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我今天",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真的很開心哦，\n{player}。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像突然多了個感情很好的哥哥一樣，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很開心～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為我是獨生女。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n{player}，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為什麼要對我",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這麼好呢……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "算了，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "原因不重要。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "連晚餐都讓你請，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n受了你不少的照顧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這份恩情，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我一定會一直記在心裡的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「正義的夥伴」可是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很注重禮節的哦～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呵呵♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只是，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "光受你照顧好像也不太好。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n被男生請客，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n也有種奇妙～的感覺……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "吃飯那些的錢，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我會找時間還你的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n下個月同一天拿到報酬時，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個時候我們再見面吧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "然後啊，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n如果可以的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "希望你",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可以再和我玩……♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，{player}？",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n想說你怎麼都不回話……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n難不成是睡著了是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "畢竟今天走了很多的路，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還大玩特玩了一場呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再怎麼說也是會累的呢～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗚哇？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這、",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這道光是什麼？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好刺眼……！",
        "unit_id": 100511
    },
    {
        "type": "background",
        "background": "510010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你看你看，{player}大哥！",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n有好多的老虎！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這間動物園裡的",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n老虎和獅子很有名呢～♪",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而且還有很多像是，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "布偶之類的周邊商品！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你看，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "從這放眼望去",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "全部都是群聚的老虎和獅子～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哼哼。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "老虎和獅子，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n如果打起來的話，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像是老虎比較強！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "果然",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_024"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "虎虎是最強的……！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "比百獸之王還要強，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "無敵的戰士！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……大哥？",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n咦，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "跑去哪裡了？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦、",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦咦咦……？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "難道說，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我變成走失的孩子了嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥～！",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你在哪裡啊，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在的話請你回我一聲！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚哇啊啊啊～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚啊？",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n哦哦，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像從哪裡傳來了大哥的聲音！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "從哪裡呢？",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是這裡嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是在玩捉迷藏嗎～♪",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "找到了！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥～",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我不喜歡你人突然就跑不見哦？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥……",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n到處都找不到，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n走散了。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_032"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n好不安。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥～？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗚噫呀！？",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大、",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請不要無聲無息地站在我的背後啦！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我是個",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很容易被嚇到的人哦……？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n剛剛都找不到你的人，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你跑去哪裡了？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊哈哈。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_036"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因為我一直盯著老虎的布偶看，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你以為我想要，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以就跑去買了是嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你要送給我",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_037"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "當禮物嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "謝、",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_038"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "謝謝。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然很開心，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但又覺得有點不好意思呢～？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "退回去又覺得怪怪的，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n而且我也真的很想要這個布偶……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那我收下了，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我會好好珍惜的。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "謝謝你，大哥。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "最喜歡你了……♪",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "都難得來動物園了，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一直待在伴手禮店閒逛",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也不是辦法呢。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要不要，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_042"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "去逛逛其他的地方嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只不過……",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_043"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我們兩個也沒有什麼理由，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "非要一起行動不可。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只是碰巧在動物園遇到，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_044"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n兩人就自然而然地在伴手禮店挑起東西了而已。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過大哥，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_045"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為什麼你",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會一個人在動物園裡啊？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我是為了",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_046"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "來看在附近",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "遊樂園所舉辦的英雄秀～",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只不過，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在那之前得先想辦法打發時間才行。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為憑同一張票也能夠進來動物園裡，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_047"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所以我就想",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「偶爾也來這邊看看吧～」",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就過來了。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過{player}大哥是為了什麼？",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_048"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你喜歡動物是嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_049"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「喜歡動物的人都是好人」，\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這句話",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是虎虎說的！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在電視上！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}大哥，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_050"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你果然是個好人對吧？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是個Nice guy對吧？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_051"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n大哥只是",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "剛好因為幫忙純",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在進行表演的英雄秀……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "然後作為報酬，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_052"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n拿到了",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可以在附近的娛樂設施裡……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "自由遊玩的免費票券啊。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為票券是雙人票，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_053"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n雖然能夠再和一名女孩子一起進來……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但遺憾的是，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_054"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有可以邀請的對象，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只好獨自進來，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "到處晃來晃去對吧？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嘿～？",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_055"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥你，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有女朋友嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真意外～",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_056"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n感覺大哥",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還蠻常",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "和女孩子待在一起的說？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊哈哈。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_057"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不要那麼沮喪嘛。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "特攝節目裡的英雄，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_058"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n大多也都因為忙於拯救世界",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而沒辦法交女朋友！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n也沒有辦法約會！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以沒問題的！",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_059"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請你不要那麼沮喪，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n都難得來動物園了～♪",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_060"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n大哥",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為動物園到處都是情侶羨慕得不得了……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n顯得很沮喪呢。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "畢竟，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_061"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這裡有種像約會地點的感覺嘛。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯～",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_062"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那不然，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣好了。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我來和",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "寂寞的大哥",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "來場約會。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我還只是個小孩，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_063"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n可能也沒有什麼女孩子的感覺。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是我",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_064"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "最喜歡大哥了！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以說，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我陪你一起玩吧♪",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……不可以嗎？",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_065"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n感覺",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不需要我？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇哇，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_066"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請不要突然抱過來啦！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你一直說謝謝，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是在跟我道謝嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "欸嘿嘿。",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_067"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "對「正義的夥伴」來說，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n幫助有困難的人是理所當然的！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以說大哥，",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_068"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請不要沮喪……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不管是假日，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還是動物園，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n都和我一起盡情享受吧～♪",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "來，我們快走！",
        "unit_id": 100531,
        "voice": "vo_adv_1005004_069"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一直盯著布偶看也不是個辦法，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "接下來",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們就去見見真正的老虎吧～♪",
        "unit_id": 100531
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，辛苦你了。",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛才看見的，是如同夢境一般的情景哦。",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以你和你結下羈絆的對象……",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次是以茉莉的記憶為基礎所構成的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大概像是電影之類的東西哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在不用那麼在意也沒關係哦。",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反正你醒來以後，馬上就會忘記了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只不過……",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你還真是丟人呢，{player}。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "竟然讓小學女生對你說：",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n「因為很可憐所以和你約會」……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n既顧慮你的心情還陪你玩。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，開心的話就再好不過了。",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是個乖孩子呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "茉莉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然說出口的話大多像是從特攝節目中現學現賣的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但她卻打從心底深信著那些漂亮話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "善良又率直，",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是純真呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這現實裡，並不像電視節目那樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n將骯髒以及血淋淋的事物都過濾掉了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而茉莉，",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或許會因為這樣而受到傷害也說不定呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……要好好地注意並保護著她哦，\n{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_081"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對獨自在動物園閒逛，",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_082"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n且寂寞的你親切地伸出關心的手……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對這小小的「正義的夥伴」，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要好好的報恩哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子溫柔地陪在你的身邊……",
        "unit_id": 190011,
        "voice": "vo_adv_1005004_083"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那孩子要是心情不好的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n下次就輪到你去幫助她了哦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呼嚕、",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_084"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呼嚕……♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_085"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呼啊？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "睡著了嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總覺得，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_086"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像做了個很美好的夢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一個像是女孩子會作的，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n和最喜歡的男生",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一起約會～這種感覺的夢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯……",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_087"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n既然要夢的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我還比較想夢見成為英雄的夢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我果然",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_088"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還是有點奇怪吧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……{player}？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_089"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}也睡著了呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你的嘴角，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "口水流出來了哦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也是？",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_090"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚呀，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是丟臉！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "擦擦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_091"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在睡著的期間，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n已經完全",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "天黑了呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是晚回家了的話，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_092"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n爸爸和媽媽會擔心的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我還真是個",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "壞孩子呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯？",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_093"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你說「茉莉是好孩子哦」，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗎……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_094"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不敢當！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了能讓你這麼覺得，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我相當努力！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我還沒有辦法做得很好。",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_095"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但我要成為好孩子、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好人……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "與善意畫上等號的，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_096"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「正義的夥伴」。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那是我，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一直以來的夢想。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……所以說，",
        "unit_id": 100511,
        "voice": "vo_adv_1005004_097"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我沒有像普通女孩子一樣，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n和帥氣的男生約會的閒暇時間。",
        "unit_id": 100511
    }
]