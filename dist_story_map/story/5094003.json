    {
        "type": "dialogue",
        "name": "碧",
        "words": "跟山上的氣氛很搭呢～",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "香氣濃郁，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還帶有微微甜味……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這最適合拿來放鬆了。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟平常工作前喝的，",
        "unit_id": 122111,
        "voice": "vo_adv_5094003_037"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n都是帶著苦味，拿來提神的品種。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在不同的地點和時間下，",
        "unit_id": 122111,
        "voice": "vo_adv_5094003_038"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是要跟著更換豆子種類才行呢！",
        "unit_id": 122111
    },
