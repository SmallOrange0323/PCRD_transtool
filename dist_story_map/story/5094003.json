    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚嗚……",
        "unit_id": 122111,
        "voice": "vo_adv_5094003_042"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我很習慣失敗，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不過沒把失敗當成失敗的打擊真的好大……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我原本覺得自己已經習慣都會的生活而有所成長……",
        "unit_id": 122111,
        "voice": "vo_adv_5094003_043"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n看來我完全會錯意了！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太自我感覺良好了！",
        "unit_id": 122111
