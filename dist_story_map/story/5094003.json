    {
        "type": "dialogue",
        "name": "碧",
        "words": "唉……",
        "unit_id": 122111,
        "voice": "vo_adv_5094003_044"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "明明我其實是毫無溝通能力，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不擅長交際，很笨拙的邊緣精靈族啊……",
