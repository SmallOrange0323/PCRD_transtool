    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自己是怎樣的人了……！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這就是我！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "本來的真正自我！",
