    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟最近",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "每天都跟很多人往來啊……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊……！？",
        "unit_id": 122111,
        "voice": "vo_adv_5094003_041"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這也就是說，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我身為邊緣人每天過得是失敗的！？",
        "unit_id": 122111
