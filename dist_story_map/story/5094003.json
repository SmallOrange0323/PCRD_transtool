        "type": "dialogue",
        "name": "碧",
        "words": "才能讓心靈得以休息啊～",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不知有多久……",
        "unit_id": 122111,
        "voice": "vo_adv_5094003_040"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒能像這樣一個人靜靜地度過了……？",
