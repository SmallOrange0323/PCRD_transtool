    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨想在露營區喝到最棒的那一杯，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而和純一同開始砍柴──"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "準備了這麼多，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "柴火應該很夠用吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在吃飯前",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "先來休息一下吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "她在這兩個小時，",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一直片刻不停息地砍柴，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "卻連個氣都沒喘……？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "鎧甲裡面真的有活生生的人在嗎……？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "先不說這個了……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊～",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我好渴……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳就好好補充一下水分吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咕嚕……咕嚕……咕嚕……咕嚕……！",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_005"
    },
    {
        "type": "still",
        "still": "509400301"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……噗哈────！！",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼～～",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是通體舒暢～～",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n運動過後的酒特別好喝呢～～",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這就是最棒的──",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我覺得不太對……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這跟被秋乃耍得團團轉之後喝的酒味道一樣……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "到底要怎樣才能喝到最棒的那一杯啦～～！！",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我今天已經不想動了～～！！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦！？",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "全身瞬間失去力氣……？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n她砍柴那時的氣勢跑哪裡去了……？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不對，",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該說她脫掉外殼，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "進入休息狀態才比較正確吧……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該不會",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這就是小智要求我的",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "休息形式……？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯～？",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "團～長～？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n怎麼啦～？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "幹嘛站著不吭一聲～？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n快脫掉那個頭盔，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喝點水吧～",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以稍微……",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "聽我說說話嗎？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好啊！",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "談心最適合拿來當麥酒的下酒菜了！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n今天不必客氣！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有話就直說吧！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這、",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就不客氣了……",
        "unit_id": 104715
    },
    {
        "type": "background",
        "background": "501591"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……就是這麼回事。",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然照小智她們說的休假了，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我不知道怎樣休息……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "原來那時的團員們",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "說了那種話啊……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是一群替上司著想的部下呢！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也這麼覺得，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她們是我自豪的部下。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "既然如此！",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n妳就要！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n好好休息！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我雖然是很想這麼做……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以我說，",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳太硬梆梆了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我不是在說鎧甲喔，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是妳的性格啦。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳以為光來到露營區，",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就能讓人放鬆嗎？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n妳知不知道什麼叫在什麼場合做什麼事啊？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "露營區是遊樂設施，",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "應該是盡情享樂的世界啊。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然而妳卻一直訓練訓練，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "練個不停……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "純作為一個上司，",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n可要全力接受智和茉莉的關心才行啊。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話是沒錯……",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還有，",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "看到純那樣子，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不是也會影響到士氣嗎？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "看到上司沒休息，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "底下的部屬也不敢休息啊。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以說！",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n才會希望妳該休息時就要好好休息啊！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這、",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我完全沒考慮到小智她們的心情……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那我到底",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該怎麼做才好……？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我有個好消息要報給妳知道──！",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就教妳一招",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "能好好放鬆的方法吧──！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "重要在於",
        "unit_id": 122211,
        "voice": "vo_adv_5094003_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "懂得調整輕重緩急！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n如果很難靠自己控制，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那就借用道具的力量吧！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哦！",
        "unit_id": 104715,
        "voice": "vo_adv_5094003_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "麻煩妳了！",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n到底要怎麼做呢？",
        "unit_id": 104715
    },
    {
