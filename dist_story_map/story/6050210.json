        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果他們能在那邊過得很好就好了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 114011,
        "voice": "vo_adv_6050210_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "去、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "去靈界？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的確蠻想念那些孩子的……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但要我去鬼怪的世界，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我需要一點心理準備……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確",
        "unit_id": 114011,
        "voice": "vo_adv_6050210_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無法想像那些孩子沒有精神的樣子，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他們會不會被其他鬼怪欺負呢……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是現在的那些孩子，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一定沒問題的吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明年、",
        "unit_id": 114011,
        "voice": "vo_adv_6050210_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那些孩子會成長多少呢？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了不被他們笑話，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們也得要好好努力了。",
        "unit_id": 114011
    }
]