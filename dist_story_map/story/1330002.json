        "name": "格蕾斯",
        "words": "兩個……",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "三個……",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嗚嗚。",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "八個……",
        "unit_id": 133014,
        "voice": "vo_adv_1330002_027"
    },
    {
