        "voice": "vo_adv_1330002_028"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……偷瞄。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_029"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……完全不行呢。",
