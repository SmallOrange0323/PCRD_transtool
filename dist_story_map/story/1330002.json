    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}來到了吉歐‧尼布爾黑爾後過了不久。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由於格蕾斯說想要答謝他協助調查溫泉，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因此{player}受邀前往了某間宅第。"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "抱歉讓你久等了，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_000"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "在這裡，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_001"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "在你的背後。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n來……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "請轉過身。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "殭屍１",
        "words": "喔喔喔……喔！！",
        "unit_id": 314,
        "voice": "vo_adv_1330002_002"
    },
    {
        "type": "dialogue",
        "name": "殭屍１",
        "words": "…………",
        "unit_id": 314,
        "voice": "vo_adv_1330002_003"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "哎呀哎呀騎士氏。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_004"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不是那邊。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是左邊。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "來，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "請轉過來。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "殭屍２",
        "words": "啊啊啊……啊！！",
        "unit_id": 917,
        "voice": "vo_adv_1330002_005"
    },
    {
        "type": "dialogue",
        "name": "殭屍２",
        "words": "…………",
        "unit_id": 917,
        "voice": "vo_adv_1330002_006"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……這個，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_007"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是怎麼回事？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我在問你剛才那冷淡的反應是怎麼一回事。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_008"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n冷淡到連幽靈都要感冒了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "為了讓你嚇一大……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_009"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "更正。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n為了好好招待你，我才請他們幫忙的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "結果你看，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "殭屍們的表情有多麼難過。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "殭屍群",
        "words": "總覺得，",
        "unit_id": 1,
        "voice": "vo_adv_1330002_010"
    },
    {
        "type": "dialogue",
        "name": "殭屍群",
        "words": "很抱歉……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "明明剛來到這裡時",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_011"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你還會被殭屍嚇到。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "難道說騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你已經習慣殭屍了？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "居然。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_012"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n……騎士氏，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你會不會適應得太快了點？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呼……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_013"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "既然如此，那我只好拿出我的",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "壓箱寶了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "來拜託我認識的吸血鬼──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……是嗎。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_014"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒想到不只是幽靈，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "居然連吸血鬼你都認識。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "難道說是那個嗎。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "看起來不太妙的傢伙幾乎都是朋友",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嗎。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過這種事怎樣都無所謂。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_015"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n就跟剛剛一樣哦騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n即便你有認識的吸血鬼，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "剛才的回應可不恰當呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……聽好囉？",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_016"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我舉個例子。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "「嘿嘿☆",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_017"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這是我第一次做的綠咖哩♪",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "噗呼☆」",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你會對笑著這樣說的女朋友",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "回答「我知道有間店的綠咖哩很好吃喔」",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這種話嗎？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不會吧？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "要懂得體貼。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "體貼。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………\n……",
        "unit_id": 133014,
        "voice": "vo_adv_1330002_018"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我　",
        "unit_id": 133014,
        "voice": "vo_adv_1330002_019"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "好　",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "恨　",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "啊　",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "～",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……偷瞄。",
        "unit_id": 133014,
        "voice": "vo_adv_1330002_020"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……哇，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_021"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "好生硬……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n你還先喊了聲",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "「啊」。",
        "unit_id": 133012
