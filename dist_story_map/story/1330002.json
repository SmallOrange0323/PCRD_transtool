    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "講出了如此低品質的「我好恨啊」。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……而且，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我的鬥志燃燒起來了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "今天，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_023"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "在導覽吉歐‧尼布爾黑爾的過程中。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我會想辦法讓你嚇一大跳。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "一定會讓你嚇到心跳加速。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_024"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n搞不好會心跳停止的程度。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "請做好心理準備哦。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵呵呵呵。",
        "unit_id": 133012
    },
    {
        "type": "background",
        "background": "502440"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……嗚嗚。",
        "unit_id": 133014,
        "voice": "vo_adv_1330002_025"
    },
    {
