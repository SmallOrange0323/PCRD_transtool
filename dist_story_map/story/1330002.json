    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "啵啵、",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_037"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "啵、",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "啵……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "啵啵啵……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………\n……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_038"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……咻──",
        "unit_id": 133014,
        "voice": "vo_adv_1330002_039"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "因為，",
        "unit_id": 133014,
        "voice": "vo_adv_1330002_040"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏你。",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嗚嗚。",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我能理解。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_041"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "畢竟我事前就說要來嚇你了嘛。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "如果提前知道",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那當然會有所準備呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n沒被嚇到也是沒辦法的事。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "而且……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "也差不多",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_042"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "該來揭曉謎底了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我會做這種事是有理由的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "其實呢。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_043"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我是在測試你哦，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是的。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_044"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n測試你的膽識。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我們今後，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_045"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "也會一同戰鬥吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n有些時候，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "或許會為了保護我們的公主",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n而請求你協助。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "所以說騎士氏。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_046"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我必須",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "要徹底地觀察你。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n判斷你是不是一個值得信賴的人。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……在守護重要之人時，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_047"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "如果會因害怕而退縮，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n那麼作為一起作戰的人，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是無法託付自身性命的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n雖然我已經死了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "而結果是……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_048"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "鏘鏘，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你合格了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n你那無論遇到什麼事都不會動搖的膽識",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是能夠信賴的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呦，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_049"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你這顆強心臟。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "毛茸茸的熊心豹子膽。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒錯。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_050"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "所以我的內心並沒有受創。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n即使沒有嚇到你也完全沒關係。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不痛不癢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "而且我，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_051"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "也還沒有拿出真本事。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "哎呀？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你該不會認為那就是我的全力了？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n怎麼可能呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我的亡靈之力",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "可不只是這樣。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "好了。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_052"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "事情就是這樣。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "因為你順利合格了，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "讓我來給你這個作為獎勵。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "給你。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_053"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "銀製小格蕾。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是的。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_054"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n只要收集５枚「銀製小格蕾」，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n就能拿到好東西哦。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_055"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "話說騎士氏。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_056"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我想請問一下，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n如果說我要送你東西，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "收到什麼你會比較高興呢？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那我送你一個吻如何呢？",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_057"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n不是親在臉頰，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "而是噗啾的那種。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "唔！！！",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_058"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_059"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵呵。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_060"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你剛才嚇了一大跳對吧？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n嚇到你的臉",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "變得這麼紅。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵呵。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_061"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "太好了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……啊。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_062"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "太過高興而不小心擺出了勝利姿勢，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "失禮了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "總而言之，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是我贏了呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "啊啊，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_063"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我騙你的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n還說什麼",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是測試膽識。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "因為我很不甘心了所以稍微嘴硬了一下。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_064"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我是真的很想讓你嚇一大跳，這還用說嘛。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "很好，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_065"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "看來今晚能睡得很香甜。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那麼騎士氏，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "再會囉。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_066"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "只不過。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_067"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n剛才的驚嚇方式",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "對我這個亡靈來說有點微妙呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n畢竟不是來自於恐怖的驚嚇。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……嗯。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_068"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_069"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "剛才那個果然還是不算數。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這次我一定要面對面來讓你嚇一大跳。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "以亡靈般的",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "真正恐懼，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "來嚇你。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵呵……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_070"
    },
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那麼……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_071"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "該怎麼來嚇你才好呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n總之先從講座開始？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "先讀點怪談故事",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "從頭開始了解何謂亡靈……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "貴安，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_072"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "杜蘭老爺子。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "格蕾斯，",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_073"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "妳剛回來嗎？",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n身為守護騎士的妳",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "居然沒待在薇歐莉特公主的身邊，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n到底是跑去哪裡閒晃了？",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "……我有聽說，",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_074"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "妳跟一個騎士少年走得很近。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n這是真的嗎格蕾斯？",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你這是在說什麼啊。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_075"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我只是把他當作來自異國的客人",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "鄭重地接待而已。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "只有這樣嗎？",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_076"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這是什麼意思，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_077"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那種好像有話卡在喉嚨一樣的講法。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "有話就直說如何？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……哎呀真抱歉。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "別說是喉嚨了，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你根本就沒有脖子呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "……咳咳。",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_078"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n妳別誤會了，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "格蕾斯。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "身為妳的祖父，",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_079"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "如果妳能有一個好對象",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n那固然是件令人高興的事，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "我也不會反對。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n但是，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "妳是守護騎士。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "守護薇歐莉特公主。",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_080"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n如果會影響到這份職責，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n我是絕不會認可這種輕浮的男女關係。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "Shut up.",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_081"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n你這無頭老頭。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "咦咦……？",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_082"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "正如我剛才所說。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_083"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "只是把他當作客人鄭重地接待而已。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n今天也不過是遵從公主的命令，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "為他導覽吉歐‧尼布爾黑爾。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "並沒有發生像老爺子你",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_084"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n想的那種事情，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "所以不必擔心。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "但、",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_085"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "但是妳回來時的表情。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n看起來卻一副含情脈脈、",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "臉頰泛紅的樣子啊……？",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……啊？",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_086"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "咿咿！？",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_087"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那只是你的錯覺。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_088"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是你看錯了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過說到底，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "老爺子你根本就沒有眼──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "我根本就沒有眼睛呢！！",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_089"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n呼哈哈，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "搶在妳之前說完了。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嘖。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_090"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "……咋舌！？",
        "unit_id": 52612,
        "voice": "vo_adv_1330002_091"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "老爺子。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_092"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "請停止那些無聊的玩笑話。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我先失陪了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……臉頰泛紅？",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_093"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "怎麼可能",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "會有那種事。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n因為我可是已經死了啊。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒有血液流動的臉頰怎麼可能會變紅，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "太蠢了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……明明，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_094"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "應該是這樣才對……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我偶爾，",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_095"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "會感覺到。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n應該已經失去的，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "心臟跳動的感覺。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "本應不會再動的心臟……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "噗通地。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏的……",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_096"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_097"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是個無聊的靈異現象呢。",
        "unit_id": 133012,
        "voice": "vo_adv_1330002_098"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面對這不可能發生的現象，格蕾斯微微顫抖著雙肩，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n身影朝向自己的房間消失而去──"
    }
]