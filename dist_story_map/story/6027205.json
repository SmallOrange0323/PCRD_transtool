    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "來這個島",
        "unit_id": 106511,
        "voice": "vo_adv_6027205_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也有一段時間了～",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不知什麼時候才能回到蘭德索爾……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然不是說無聊啦，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但總覺得……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒有喔？　",
        "unit_id": 106511,
        "voice": "vo_adv_6027205_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有你跟祈梨在，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "每天都過得很開心喔。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟揍人不一樣，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "魔物的話就可以毫無顧忌、盡情地打了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這裡是要多少有多少。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是讓人熱血沸騰……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔～",
        "unit_id": 106511,
        "voice": "vo_adv_6027205_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的確是有點",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過癮呢～",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "想回去做打手相關的工作想到整個人都蠢蠢欲動了呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我好想吃王都裡店家賣的甜食喔。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "回去以後我們再一起去吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呵，",
        "unit_id": 106511,
        "voice": "vo_adv_6027205_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種程度完全不累。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我還可以作更粗重的工作喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要是能來的",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "更有骨氣點的對手就好了……",
        "unit_id": 106511
    }
]