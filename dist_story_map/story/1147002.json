[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "回到蘭德索爾的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在熱鬧舉行新年廟會的繁華街上散步時，遇見了矛依未。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿，{player}！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你在這種地方做什麼？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是喔。",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我第一次像這樣光明正大的走在新年廟會上，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n正打算四處走走看看呢。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……對了！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然都遇到了，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你來替我介紹一下廟會吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到處都散發著好聞的食物香氣，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有許多看起來很有趣的攤位，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我從剛剛開始就看得眼花撩亂呢。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你應該",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很了解這些東西吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n會在這裡相遇也算是一種緣分。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今天就和我一起",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在廟會上玩吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我已經過了領壓歲錢的年紀了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這傢伙……",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個年紀跟她拿壓歲錢？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你好像",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比我年長吧……？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你該不會",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是在用那筆壓歲錢買東西吧……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n難道你其實",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是個挺壞的傢伙？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚、",
        "unit_id": 5311,
        "voice": "vo_adv_1147002_008"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚嗚……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……？",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂你看，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那個孩子……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呵呵，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "竟然比我早注意到那個孩子，還率先向他搭話，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n才剛迎來新年，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就做了這麼符合你作風的事呢。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我把裝著壓歲錢的紅包袋",
        "unit_id": 5311,
        "voice": "vo_adv_1147002_011"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "弄丟了……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚嗚。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那真是太遺憾了。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們該怎麼辦？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呵呵。",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就知道你會這麼說，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n白問了呢！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "帶我逛廟會的事就等會再說吧。",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n反正你一定也是",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這麼想的嘛！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那我們就",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快點找到壓歲錢，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n去吃好吃的東西吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放心吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我和這傢伙會幫你找到",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "壓歲錢的！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "真、",
        "unit_id": 5311,
        "voice": "vo_adv_1147002_017"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "真的嗎……？",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當然是真的！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以別再哭啦！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們現在就幫你找，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你能說出你剛剛都去了哪裡嗎？",
        "unit_id": 114711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……沒記錯的話，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他說他剛才在這附近對吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要找到這麼小的一個紅包袋，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "相當費力啊。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是你說要幫忙找",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我才跟過來的……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "照這樣看來，等我們找到，新年都要過完了吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "……",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……喂，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有看到剛才在轉角轉彎的男人吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們去追他。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別問這麼多了，相信我。",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "壞蛋的直覺告訴我他有問題！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別跟丟了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快跟我來！",
        "unit_id": 114711
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "……",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那邊那傢伙！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能打擾一下嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "！？",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他逃走了！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你儘管高興吧，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的直覺是對的！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別跑──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們從兩側包抄他！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "預備──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "哇啊！",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_030"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "你、",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "你們要幹什麼！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不就說了別跑嗎！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "誰叫你要無視我！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "在這種地方被陌生人搭話，",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_032"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "還突然被追趕！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n我當然會害怕地逃走啊！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的只是因為這樣？",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_033"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "是啊，沒錯！",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那這是什麼？",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "它剛剛從你的口袋裡掉出來了……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這無論怎麼看，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都是裝小孩壓歲錢的紅包袋吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "那、",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_036"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "那是……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "是我等一下要給",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "親戚小孩的壓歲錢啦！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔～",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……你另一邊的口袋也很鼓耶，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你的親戚有這麼多啊？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "是啊，沒錯。",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_039"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "我們家族裡有很多小孩……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "所以每年",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "新年的開銷都非常大，很困擾呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "所以，",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_040"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "就是這麼一回事，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "我現在得走了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n要跑遍所有親戚家不是件容易的事啊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哼嗯～",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是啊，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個紅包袋，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和我們剛剛遇見的小孩子",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不小心弄掉的那個有著一模一樣的紋路耶。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我還知道裡面裝了多少錢喔。",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不如乾脆",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把它打開來確認看看吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "唔……！",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還打算拿親戚當藉口嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n反正你口袋裡裝的那些紅包袋，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一定也是從鬧街的孩子們身上偷來的吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "……被發現就沒辦法了！",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_045"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n把我的壓歲錢",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "還回來吧！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "終於承認了啊，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這小嘍囉！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n要動手的話",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我奉陪！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放馬過來吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "什麼啊，",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_047"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "就只有一把小小匕首？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "憑這樣就想打敗我啊？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n真是新年以來的第一個大笑話！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "哈哈哈！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "既然妳掏出了武器，",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_048"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n那我",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "就用這把劍來讓妳嚐嚐苦頭！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……啊哈哈。",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈哈哈哈哈──！！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "有、",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_050"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "有什麼好笑的？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n知道自己必敗無疑，陷入瘋癲了嗎？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你就是因為這樣，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才只能當個偷小孩壓歲錢的小嘍囉啊！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "憑那麼小把的劍就妄想打敗我，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n讓你見識一下！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……顯現吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍──！！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼樣！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_053"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這就是我們壞人之間格調的差距！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "妳、",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_054"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "妳從哪",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "掏出那把大劍的……！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這麼好奇的話，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_055"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "作為新春特別福利，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就讓我這個大壞蛋諾維姆大人，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "教教你什麼才叫真正的幹壞事吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "……我、",
        "unit_id": 1111,
        "voice": "vo_adv_1147002_056"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "我認輸了！！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼嘛，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_057"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這就認輸了喔？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還真是徹頭徹尾的小嘍囉耶……",
        "unit_id": 114711
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "謝謝你們，",
        "unit_id": 5311,
        "voice": "vo_adv_1147002_058"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "哥哥姐姐！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n這是婆婆給我的寶貴壓歲錢……！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我們也沒做什麼啦。",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_059"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "非常感謝諸位這次",
        "unit_id": 711,
        "voice": "vo_adv_1147002_060"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "協助逮捕犯人！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我們接到了多起兒童詢問",
        "unit_id": 711,
        "voice": "vo_adv_1147002_061"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "是否拾獲壓歲錢的報案。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n也正打算在周遭加強巡邏。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "真的很感謝您的協助！",
        "unit_id": 711,
        "voice": "vo_adv_1147002_062"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊──真是的！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都說了我沒做什麼好事啦！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我只是",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓壞傢伙見識了我們之間的差距而已！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剩下的事就交給你們了，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再見啦！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "啊，",
        "unit_id": 5311,
        "voice": "vo_adv_1147002_065"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "那位姐姐",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "走掉了……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "本來還想好好和她道謝的……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "大哥哥，",
        "unit_id": 5311,
        "voice": "vo_adv_1147002_066"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "你能幫我和她說嗎？",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "就說",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "真的非常感謝她！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "那麼，再見！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "說到壞事……",
        "unit_id": 711,
        "voice": "vo_adv_1147002_067"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "啊，不，",
        "unit_id": 711,
        "voice": "vo_adv_1147002_068"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "算不上是事件……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "如您所見，",
        "unit_id": 711,
        "voice": "vo_adv_1147002_069"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我們【王宮騎士團】即使在新年\n也肩負著蘭德索爾的警備工作。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "但是，",
        "unit_id": 711,
        "voice": "vo_adv_1147002_070"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "有一名團員即便過了休息時間仍遲遲沒有回來……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n他在平時是比任何人都還嚴肅認真的男子。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "或許是難得受新年的歡樂氣氛感染，",
        "unit_id": 711,
        "voice": "vo_adv_1147002_071"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n丟下勤務在某處偷懶吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "若是發現了疑似偷懶的團員，",
        "unit_id": 711,
        "voice": "vo_adv_1147002_072"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n希望您能再通知我們！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "那麼，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我就告辭了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你真慢！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_073"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真虧你能和【王宮騎士團】的人聊這麼久耶！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真是奇怪啊，竟然向大壞蛋道謝……",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_074"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "見識到了真正壞人的他，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_075"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n未來或許會成為更十惡不赦的壞人吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以說，",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_076"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我完全沒有做任何一丁點的好事喔！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這都無所謂了！",
        "unit_id": 114711,
        "voice": "vo_adv_1147002_077"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n來吧，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們再多做點壞事，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好好享受這個新年──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "旁白",
