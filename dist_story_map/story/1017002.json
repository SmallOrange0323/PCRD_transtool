[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "still",
        "still": "101700201"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我要開動了～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊姆啊姆，真是太好吃啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀～這就是故鄉的味道啊！",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然不知道合不合你口味，不過你也來嚐嚐看吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "採收那些像苦瓜的東西時你有幫忙，這是給你的謝禮呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，果然如你所說呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要先試試看味道才對呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這東西的味道，果然和苦瓜有一點點不同呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果這種植物只是外表像苦瓜，",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那花功夫採集也沒什麼意義呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只會讓採下來的果實放著壞掉，賠了夫人又折兵啊～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以說呢，應該先採收一點點……",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "然後現場料理好，馬上嚐嚐看味道啊。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "能夠當作食材使用的話，",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n再來認真地採集這些像苦瓜的東西就好了～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，這行動真是合理呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過說不定單純只是你肚子真的非常餓了而已呢！",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我也已經餓到前胸貼後背了呢～算是剛剛好吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～你有帶廚具來真是幫上了大忙呀～",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你偶爾會到森林取得一些食材然後用來料理嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以才會在森林裡呀～真是野性十足呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚼嚼。",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～和苦瓜比起來，我覺得苦味有點不夠呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想這跟苦瓜應該是同科同屬的植物吧～",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但要用在料理裡頭感覺有點太甜了呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "唔，這或許是調味方式的問題吧～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我故鄉料理中常用的調味料，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你應該不可能帶在身邊吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也有可能是過熟了呢～和苦瓜相比，這個果肉更軟呢……",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過這東西的確可以當作食材呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要在料理方式下功夫，應該就能完美重現我故鄉的味道吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還是我應該採集一些種子之類，帶回去種看看呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n只要改良品種的話，應該就能更像苦瓜吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "拜託真步的話，她應該會讓我種在公會小屋的庭園裡吧～？",
        "unit_id": 101711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸？你沒有食欲嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你從剛剛開始，就不太動筷子呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你不用客氣，盡量多吃一點的呀～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀。",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n該不會不好吃吧……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～那真是太好了～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我離開故鄉的時間已經蠻久的了……",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以有點忘記這道料理的做法了呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對於料理好不好吃這一點，實在有點沒自信呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過也因為如此……",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "聽到你說料理很好吃，讓我安心了呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你要是喜歡我故鄉的料理的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我也會感到很開心呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～果然是這樣嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過這個苦味只要習慣後，可是會讓人上癮的呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是覺得苦的話那可以留下像苦瓜的東西，只要吃肉就好了～",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我剛剛呢～也獵了這附近的兔子肉加到料理裡頭囉～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "肉的味道全國上下都是一樣的～是鮮味的結晶唷～",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且那個像苦瓜的東西還能夠消除肉腥味，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n一起品嘗的話最好吃了呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚼嚼♪",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呼哈～吃飽啦吃飽啦！",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n多謝招待～☆",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "感覺全身都湧出活力了啦～讓人很想要跳舞呢♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們等等再來採收那些像苦瓜的東西，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "先來跳個舞幫助消化一下吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你要不要一起跳舞呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要大家笑笑地跟著節奏搖擺，就都是好朋友啦！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "世界和平～船到橋頭自然直啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "喂喂！",
        "unit_id": 811,
        "voice": "vo_adv_1017002_025"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n你們這些傢伙，在這裡幹什麼！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "這裡可是我們的地盤，",
        "unit_id": 811,
        "voice": "vo_adv_1017002_026"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "侵入者都要處以裸體鞭打之刑～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n哇哈哈！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀，搞什麼？",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們被感覺有點危險的人包圍起來了啦～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說回來我在【哞哞自衛隊】的勤務室裡，",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n有聽說過這附近被山賊劃為自己的地盤呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "他們好像偶爾還會去襲擊馬車……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "哇哈哈！沒有錯，我們就是讓小孩都嚇到不敢哭的流氓集團！",
        "unit_id": 811,
        "voice": "vo_adv_1017002_029"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n這座森林裡的東西，全部都是我們的戰利品！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "你們還要命的話，就把值錢的東西都交出來吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔～真是一目了然的壞蛋呢～？　",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～該怎麼辦才好呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "傷腦筋～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017002_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只有我的話應該能逃掉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但是把他和像苦瓜的東西都丟在這邊，",
        "unit_id": 101711
    },
    {
