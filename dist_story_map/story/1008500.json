[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？　",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你怎麼了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼在這裡。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哦，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來是想看我的美貌，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "才在這裡埋伏我呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯嗯，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我很了解你的感受哦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也是",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "每分鐘都要確認好幾次",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "自己的美貌，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不然會坐立不安呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你可以盡情地",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "享受我的美貌哦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是這樣啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這麼說來，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "今天是我的生日呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n所以你才在這裡等我啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎，",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那我就先謝謝你了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "難得的機會，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你想不想更深入感受一下",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "生日時的我的美貌？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n來，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可以再靠近點看沒關係……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "給你的回禮。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "今天的確",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是我的生日。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以說",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你想要慶祝美麗的我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n誕生到這世上嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "拿你沒辦法呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就讓你幫我慶祝吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n畢竟不是別人，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而是你的請求嘛。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就陪陪你吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你可以盡情的幫我慶生哦！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "當然。",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真厲害，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看得很仔細呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒錯，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我無論何時都很美麗！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……有點不一樣？　",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那句話我可不能當作沒聽到呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你是什麼意思？　",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我生日這天",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比之前更美了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n原來如此……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是指我的美貌",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "持續在進化",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "的意思吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你這人，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還真是說了一番好話呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "謝謝你。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美貌就是",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要有人真正懂它，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "才能更加耀眼呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n然後，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "懂得美貌的人",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "才有權利享受真正的美貌。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就",
        "unit_id": 100811,
        "voice": "vo_adv_1008500_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "允許你",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "今後也能在特等席觀賞我的美貌吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吶，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是撇開了眼，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就太浪費囉？",
        "unit_id": 100811
    }
]