[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}轉學進來後過了數天……\n大家今天也在上伊緒的課程。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家都差不多解出問題了嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀？\n你好像還沒寫呢？",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "臉好像也紅紅的……身體不舒服嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我稍微量一下你的體溫喔。\n",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓我摸摸額頭……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等等等一下！伊緒！",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n額頭貼額頭……！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "離太近了呀！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "妳用美色實在卑鄙！",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？美色……？",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n什麼",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "意思？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "妳是自然而然這麼做的嗎？\n",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼嘛，這樣不是最強的嘛……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？ 欸？",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我、",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我做了什麼壞事嗎……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～？人家搞不懂，",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼靠近的話，秀才無法集中精神吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這、這樣啊？",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我只",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是想看看他是不是發燒而已……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小伊緒實在有點大膽呢。",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n妳穿那麼低胸的衣服，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果往前彎的話，會被看光吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸、",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸欸！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n被看到了嗎……！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好、好害羞……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是如果穿普通的衣服，",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n胸部這裡很悶，實在穿不住……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是在挖苦人吧！？是刺激人吧！",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n妳是想和我吵架嗎！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸欸！？\n為什麼美咲要生氣呢？",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我只",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是說實話而已……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然很天然！\n",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也就是說，是天生性感的老師……好可怕……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哎呀哎呀美咲，先冷靜一下。",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "以後妳就會變大的。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總之小伊緒在旁邊的話，",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才無法專心，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "由人家來教你也可以喔？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊！只有鈴奈來教太狡猾了！",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n鈴奈",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "能教的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我也能教你！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸……那個……",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n妳們都有辦法好好教嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小事、小事！",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那首先由人家來！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，人家來教你九九乘法！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一乘一等於七……",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一開始就錯了啦！",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這、這只是個小失誤。",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n七的",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "乘法那邊再調整就好了吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "調整也不行！",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "，\n九九乘法裡面需要注意的是七的乘法！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "從七的乘法開始就會超難的喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可以說是九九乘法裡面的大魔王。\n如果可以打倒七的乘法，",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就等於征服了九九乘法喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明明是九九乘法，\n可不能忘了八和九的乘法呀……",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～！\n",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為八和九的乘法，實在難翻天，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家也搞不清楚啊。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那不就是不能教～",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……對嘛對嘛。\n那個",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_030"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "部分是不能漏教的。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，美咲。",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳在教{player}數學呀？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不是。\n我教",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "的是特別課程。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是關於戀愛教戰守則！",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "聽好了？\n只有追求是不行的。",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_034"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n有時",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也要欲擒故縱！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那應該不是在學校教的東西耶……？",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_035"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "誰，誰叫……",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_036"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我沒有擅長的科目可以教別人。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，這個應該是有幫助的喲！",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_037"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n對吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，人家也想聽感想！",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_038"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，人家教得九九乘法如何呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為什麼不敢直視我！",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_039"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "絕對是在說謊吧！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣啊～\n教人果然很難呢？",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_040"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……真是沒辦法。\n今天就暫時放棄了。",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_041"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這傢伙就由老師來教吧。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，果然還是那樣比較好。",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_042"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，總有一天我也要教秀才～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對呀……\n",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_043"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們也要為此好好地學習才行。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣啊。\n要教人的話，得要更努力念書才行呢。",
        "unit_id": 101611,
        "voice": "vo_adv_3015003_044"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好～美咲，努力念書吧～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是當然的",
        "unit_id": 105011,
        "voice": "vo_adv_3015003_045"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "！\n因為我比較努力！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，兩個人都這麼有幹勁……",
        "unit_id": 101811,
        "voice": "vo_adv_3015003_046"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n妳們認真念書的話，我也很開心。",
        "unit_id": 101811
    },
    {
