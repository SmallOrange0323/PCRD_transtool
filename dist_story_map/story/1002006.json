[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……優衣。妳該不會，",
        "unit_id": 104311,
        "voice": "vo_adv_1002006_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之後就只是請那傢伙喝茶然後就沒有下文了吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是在公會之家，兩人一起喝茶，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n之後目送有事要忙的騎士先生先離開……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就沒了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "果然啊……",
        "unit_id": 104311,
        "voice": "vo_adv_1002006_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳這樣的話，不管過多少年都只能在好朋友的關係下無疾而終喔？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳想要等兩人變成老爺爺老奶奶之後還在書店約會嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該不會吧……",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣妳不知道對方的想法，所以鼓不起勇氣。",
        "unit_id": 104311,
        "voice": "vo_adv_1002006_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳現在立刻去搞清楚那傢伙的想法吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "欸欸欸欸！",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_005"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……結局我被真琴趕出門了。",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n明明是我們兩人的公會之家的說……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就算叫我確認他的想法，但要怎麼做才好呢……",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果騎士先生在城鎮裡的某處就好了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！午、午安。這麼巧呀！",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那個。不知道可否稍微聊聊呢？",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果可以的話，我們換個地方說話吧？",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……到這裡應該就可以了。",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你陪我一起來這裡。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，謝謝你上次陪我一起逛街。",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我用上次買的魔法書努力用功，已經能使用更多種多樣的魔法了呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "像是這種魔法…",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "身體變得溫暖了吧？",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個魔法呀，可以讓人就算在寒冷的地方或是受寒氣攻擊都平安無事呦。是我之前就一直想學的魔法呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（……我在說什麼啊我！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n現在不是說明魔法內容的場合呀！）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（但是我不知道如何開口問呀！",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n幫幫我呀～！真琴……！！）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如、",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果有這個魔法，當有人在寒冷的地方感到困擾時",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就能幫助他了對吧……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣的話，我應該比之前更能幫上大家的忙吧……？",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是……這樣的嗎？",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "重要的人……",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛才你說的，我沒有聽錯吧……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（騎士先生，是這樣看待我的呀……）",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（……說是重要的人呢。我好高興……",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有一股暖流洋溢擴展到心坎裡……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生……你有沒有，喜歡的對象呢……？",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你聽到我剛才說的話了嗎！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這、這個……那個嘛……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（話說回來，騎士先生他失去記憶……",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說不定，他不知道喜歡是代表什麼意思……？）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……所謂的喜歡呀，就是當和某人在一起時會心跳加速，或是感到心頭暖洋洋……",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "想經常和那個人在一起的念頭，這就是喜歡呦。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當吃到美味食物的時候，",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n因為好吃所以希望再吃到的想法雖然也是「喜歡」，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但和我剛才說的……那種「喜歡」的意義是不同的呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……這是因為，",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我雖然也很喜歡日和和怜……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但有層次更加不同的「喜歡」存在的。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是不好意思呢。我沒辦法很明確的表達出來……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我知道喜歡的心情是如何，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但很難用語言來表達出來……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個……那個嘛……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（我我我我我……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你這樣問我，我該如何說出口……！？）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……現、現在是祕密！",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……總有一天會坦白的……請等待那天到來吧！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝……",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（……我要擁有更多的勇氣，",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "直到有天能將這份感情說出口……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "請你再等我一下下呦……騎士先生。",
        "unit_id": 100211,
        "voice": "vo_adv_1002006_034"
    }
]