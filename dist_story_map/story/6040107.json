    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然有點太過奢華了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過大家好像",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "連這點都很享受呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然搞不懂那個外觀到底是怎麼一回事，",
        "unit_id": 103311,
        "voice": "vo_adv_6040107_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但她不愧是藝術表演的專家呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就是所謂的",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "先見之明吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對我們來說",
        "unit_id": 103311,
        "voice": "vo_adv_6040107_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場的景色一點也不稀奇，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但對鎮上的人們來說，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想必就十分少見了吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果牛群們也在的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就能讓他們更開心了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們雖然也想要悠閒地泡溫泉，",
        "unit_id": 103311,
        "voice": "vo_adv_6040107_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但那也是之後的事情了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "全部結束之後，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家再一起泡溫泉吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過再怎麼說",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也沒辦法跟老哥你一起泡吧……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你說是我的話就沒關係？",
        "unit_id": 103311
    }
