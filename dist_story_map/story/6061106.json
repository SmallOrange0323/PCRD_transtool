[
    {
        "type": "background",
        "background": "501230"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "魔物的公主殿下",
        "unit_id": 105213,
        "voice": "vo_adv_6061106_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然既強悍又美麗，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但看起來卻很寂寞……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "同樣擁有一副野獸外表的我，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能夠感同身受。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "希望她能夠獲得幸福。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，",
        "unit_id": 105213,
        "voice": "vo_adv_6061106_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "羅伊德先生",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是好人。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只他記起公主殿下的事，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n一定能夠像以前那樣感情融洽。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們要相信他們兩人之間的羈絆！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是這樣、",
        "unit_id": 105213,
        "voice": "vo_adv_6061106_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗎……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她遇到我之後，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "似乎已經察覺到了",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "自己不是孤獨的，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以一定沒問題的。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所謂朋友的存在，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "影響力是很大的。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說得也是！",
        "unit_id": 105213,
        "voice": "vo_adv_6061106_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "下次我想介紹【伊麗莎白牧場】的大家給她認識。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n她們都是我的重要夥伴，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一定能夠跟公主殿下成為朋友的♪",
        "unit_id": 105213
    }
]