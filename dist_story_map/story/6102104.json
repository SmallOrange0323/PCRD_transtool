    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這場文化祭還有很多很多",
        "unit_id": 123611,
        "voice": "vo_adv_6102104_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "值得一看的地方……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n像是同人誌販售會、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "模型展示會，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還有直播主的訪談活動，我也很有興趣呢……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也是。",
        "unit_id": 123611,
        "voice": "vo_adv_6102104_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟【王宮騎士團】的前輩也有出攤，\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個我也很好奇呢……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且說不定還有其他魔法少女的同人誌……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "走吧！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我聽說，",
        "unit_id": 123611,
        "voice": "vo_adv_6102104_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "展示會上會展出萬聖節版的",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "鈴鈴噹模型！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "竟然可以用從360度",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "盡情欣賞穿著那套服裝的鈴鈴噹……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真是太期待了！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 123611,
        "voice": "vo_adv_6102104_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我除了",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "輝美小姐之外，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "其他直播主幾乎都不認識，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這說不定是個好機會。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不知道出場的會是什麼樣的人呢？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果很有趣的話，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會想看看那個人的直播呢。",
        "unit_id": 123611
    }
]