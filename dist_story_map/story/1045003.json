[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}發現了探頭探腦不知道在找什麼的空花。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼辦才好……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、這樣下去，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花的祕密花園，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "會因為好奇的眼光變得亂七八糟！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊，虐、虐待狂先生……！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n來得正好……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但、但是，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n拜託虐待狂先生幫忙",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是把雙刃劍……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "表面上是好心地來幫忙，其實……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是為了把日記內容當作把柄，然後把空花……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一輩子都當成聽話的奴隸！",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n……不、不過、這樣也很好……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "流口水。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……啊，不、不小心就。",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "其、其實……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花一直在找東西。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就、就是……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n每天帶在身邊的，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "重要的日記不見了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……要、要幫忙找所以要空花說出日記的特徵？",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這樣好嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！但、但是，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花只有一個請求……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n請、請絕對不要看內容……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝、",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝謝。",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那麼空花往這邊找，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "另一邊就拜託虐待狂先生了。",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚嗚……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "完全找不到……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊，虐待狂先生還好吧？",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n全身都是泥巴！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "究竟到什麼地方找日記了！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就算叫空花不要在意……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花還是會在意的啊……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "沒想到你會這樣拚命為空花找東西。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是為了空花搞成這樣還是找不到的話，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那這個地方已經沒希望了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為什麼你會",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這麼認真地想幫空花呢？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就算找不到，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n對虐待狂先生也沒有任何……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊，該、該不會……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是在扮演「拼命尋找」",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "的樣子，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n打算藉此勾引空花吧！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「妳體內沉睡的真我，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n也想被我找出來吧？」",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……流口水。",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_022"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸欸，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎、怎麼了？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "──找到了！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在那個方向……？",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_024"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是、",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_025"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是的！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n那就是空花不見的日記。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為什麼會在",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那麼高的架子上面呢……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "而且剛好有個高度恰好的凳子，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n就在它的下面。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、這樣的話，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花應該也拿得到……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_029"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那、那個……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_030"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生現在往上看的話就會看到空花的空花……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "總、",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_031"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "總覺得很害羞，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n所以請稍微低頭……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但、",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_032"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是也許空花想要你稍微抬頭……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n扭扭捏捏……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_033"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊……要失去平衡了……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好痛……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_034"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還、還好……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_035"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_036"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐虐虐虐、虐待狂先生，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "騎在空花身上了！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "該不會，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_037"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n你從一開始就打算要這樣做的吧！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花拼命尋找的日記，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_038"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n日記在架子上面，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n架子下面有凳子。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……空花一直被虐待狂先生",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_039"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "玩弄在股掌之間。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這真是個恥辱啊……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_040"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是這樣也很好……流口水。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「不准抵抗，如果乖乖聽話的話，",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_041"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n馬上就會結束」",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "青年說完就扯開了少女的衣服！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻、嘻嘻嘻……",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_042"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……空、空花知道了。",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_043"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花是第一次",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "所以請溫柔一點……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "欸，小、小姐。",
        "unit_id": 1411,
        "voice": "vo_adv_1045003_044"
    },
    {
        "type": "dialogue",
        "name": "酒館店員",
        "words": "\n我來沒關係嗎……？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸、",
        "unit_id": 104511,
        "voice": "vo_adv_1045003_045"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸欸欸欸欸欸欸！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幻想過頭的空花，\n沒有察覺在不知不覺中{player}已經回去了。"
    }
]