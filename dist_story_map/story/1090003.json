[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "情人節當天。\n在蘭德索爾城裡四處都\n飄著甜甜的香味。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之中，{player}\n一個人待在公會小屋休息時，\n聽見廚房傳來某種聲響。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}慢慢地接近發出聲響的\n方向――"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您好，{player}大人……",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我來借一下廚房喔。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您的精神非常好呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我想要",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓{player}大人\n品嘗剛作好的",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "巧克力，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n所以直接過來製作了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當然，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您不需要跟我道謝也沒關係……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們是命中註定要結合的人，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n不需要靠言語表達……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我只是想讓",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人\n感到開心而已……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我借用一下廚房，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人請去休息吧。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "首先要",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "把水煮沸……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這個材料是提味用的，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要和這裡的材料混合……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "等顏色改變後，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "把它攪拌到變得滑順為止，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n此時再加入提味，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "繼續攪拌到出現光澤……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "然後，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "再把巧克力放到滾水中加熱融化……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……啊啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "完成這個之時，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人就會成為我的俘虜……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不對，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "他已經是我的俘虜了呢……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "再來是放入我自己調配的",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n精心提煉的特製材料",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您不可以看啦。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這個試管裡",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是我祕傳的材料。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "完全沒有放",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對身體有害之物。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請您相信我，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "耐心等候吧。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會將好吃的巧克力拿過去給您的。",
        "unit_id": 109011
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓您久等了。",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這個就是",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的特製巧克力。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "味道如何？　",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是普通的巧克力吧？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "外觀很美吧？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "裡面也是喔。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您品嚐吧。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "吃這個還需要勇氣嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "欸，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然是我做的，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您也不需要這樣跟我客氣！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "把嘴張開……",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊～",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "味道如何呢？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "甜中帶著微苦，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "非常好吃嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我好開心……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您對身體會發生什麼事感到很不安嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什麼都不會發生的。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我根本沒有放任何的藥物進去。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那個試管裡……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "裝了什麼嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那裡面是對身體完全無害的",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n水果糖漿和利口酒。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這次只是",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "單純地",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "想讓{player}大人",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n品嚐巧克力……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您覺得如何呢？　",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我做的巧克力的味道。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀……",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就是想聽您這麼說才做的。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，我現在",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "覺得好幸福呀。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要{player}大人想吃的話，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不管是在何時何地，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要吃多少我都會做給您吃。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在想起來，",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我總是想要引起{player}大人的注意，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "時常感到焦慮不安。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n可是，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這次我覺得非常的滿足。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是因為只靠我的力量",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就被稱讚做得很美味嗎……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？　",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你說沒有加任何的藥物",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是真的嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要說的話只放了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我放了滿滿的",
        "unit_id": 109011,
        "voice": "vo_adv_1090003_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "叫作愛情的藥呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "旁白",
