[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊緒老師",
        "unit_id": 126311,
        "voice": "vo_adv_5120075_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "任何時候",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都在替學生著想的體貼，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是最為美麗之處。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有些迷糊的地方，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也可以稱作是一種",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "點綴在美麗之中的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n「可愛」。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "兩者兼具這一點",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "跟我有一點像呢♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "身為老師的她似乎因此在某些地方會有所顧慮，",
        "unit_id": 126311,
        "voice": "vo_adv_5120075_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但我認為可以再更大膽地",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "展現自我會比較好吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想想，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "例如像小惡魔一樣……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你有看過？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美咲",
        "unit_id": 126311,
        "voice": "vo_adv_5120075_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "仍身懷美麗的潛力呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "以成熟淑女為目標，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "天天努力不懈的姿態……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "太美了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "隨著年齡的增長，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該會變得更美、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更有魅力吧♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然她有時似乎想裝成熟",
        "unit_id": 126311,
        "voice": "vo_adv_5120075_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而導致白忙一場，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不過沒問題的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為無論何時，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都是當下最美啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得只要去磨練",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n自己所擁有的美麗就好了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "畢竟越是細心栽培的花，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "越會美麗地盛開呀♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說到鈴奈小姐，",
        "unit_id": 126311,
        "voice": "vo_adv_5120075_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她在蘭德索爾也是很知名的超級名模吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不愧是模特兒，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在美麗這方面",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒有可以挑剔之處！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "平時就很注重美容這點",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓人有一股親近感呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她似乎不擅長念書，",
        "unit_id": 126311,
        "voice": "vo_adv_5120075_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "試試看去增加美容以外的知識如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可不光是只有美容。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "試著想像一下吧，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能夠如詩人般",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n組織出優美詞彙的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "超級名模……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會擄獲更多人的芳心喔♪",
        "unit_id": 126311
    }
]