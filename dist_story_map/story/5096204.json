[
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是這附近嗎……",
        "unit_id": 122511,
        "voice": "vo_adv_5096204_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "魔物好多啊。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而且，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "似乎比剛剛更棘手了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果這座島被弄得亂七八糟的話，",
        "unit_id": 122411,
        "voice": "vo_adv_5096204_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就舉辦不了大賽了……",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們必須趕快把這些魔物給送回家才行！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓我們繼續加油吧──！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喔～！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "喔、",
        "unit_id": 122611,
        "voice": "vo_adv_5096204_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "喔～！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說得也是呢……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我也得好好加油才行……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……向來溫和的優衣居然燃起了鬥志……",
        "unit_id": 122511,
        "voice": "vo_adv_5096204_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是在這片大海，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "稍微改變了嗎？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這次我會努力戰鬥的！",
        "unit_id": 122611,
        "voice": "vo_adv_5096204_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果你願意幫我加油，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會很開心的喔。",
        "unit_id": 122611
    }
]