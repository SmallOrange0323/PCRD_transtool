[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和小栞碰完面的這幾天，初音還是依然\n想不到該送什麼禮物而苦惱著。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔，還是找不到什麼好禮物啊……",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這樣下去簡直失去做姐姐的資格了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看能不能問問和小栞關係比較要好的人……欸、啊啊！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n喂喂！你來做什麼啊？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣啊！真是太巧了，你來的時機正好！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "其實是有件事情想和你商量……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這件事情想請你幫我保密……",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是個相當於我的超能力的祕密呦……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "拜託了！和我一起挑小栞的禮物！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我這幾天一直想了好久，但還是想不到……",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊對了，小栞是我的妹妹！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "魔物！？這、這我還真沒想到……",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說你，竟然知道小栞的事情！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那我們一起去找禮物吧！",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "禮物♪給小栞的禮物♪",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哦哦！這個怎麼樣？魔物製成的標本！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，這樣啊……晚上看到感覺確實是挺嚇人的。",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，是吧♪",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……啊，不過太真實了或許她會覺得恐怖吧……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這個還是不要了。",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n禮物還真是難選啊……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "禮物？",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞！來得正好！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n其實啊，這次想給小栞……咦，是小栞！？本人！？是本人啊！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不要一直戳我的臉啊……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n嗚、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我是過來買東西的……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊你來做什麼啊？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們，",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這個……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "　那個，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對，沒錯！聽說開了一間東西很好吃的店，",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我和他一起來嘗嘗看了☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真好呢。",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也想和姊姊還有{player}，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一起去吃飯呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那下次大家一起去吧！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說回來公會的其他人呢？在別的店裡頭嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天大家都很忙碌，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就一個人過來了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "身體狀況也不錯，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "來散步一下。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸欸欸欸欸！？小、小栞妳一個人！？沒、沒問題嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n妳一個人回得去嗎？我送妳回去吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我沒事的姊姊。我一個人回得去的哦。",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這、這樣啊……",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞都這麼說了……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔哇～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "　果然還是放心不下啊！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "　我來送你回去吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我真的沒問題啦。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而且還會造成{player}",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的困擾……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "連{player}也……",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我明白了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也不好意思浪費你們的好意……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了──！一起回去吧！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "姐姐會負起責任好好送妳回去的！",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好久沒有像這樣，和小栞一起走走了。",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "自從分開後各自生活，就沒怎麼碰過面了。",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們，原本是一起在蘭德索爾生活的。",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，那天，姊姊她……",
        "unit_id": 103811
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞小栞小栞！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不得了了——！大事發生啦——！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咳、咳……姊姊發生什麼事了慌慌張張的？",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒事吧？是、是我太激動害的嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是我今天",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "比較容易咳嗽而已。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不過別擔心。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是什麼事呢？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！姐姐我居然被精靈之森的守護公會，",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "森林守衛給選上為成員了～☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇……姊姊妳好厲害……！恭喜妳了！",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_033"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是……成為森林守衛成員的話，",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就必須在精靈之森裡生活了……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是我，不能放著小栞一個人不管……",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以，我想去商量看看能否也可以讓小栞",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n在精靈之森裡生活！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姐姐……",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就算種族不同但妳是我最重要的妹妹，",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "分開生活什麼的，我是不會考慮的！　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……對不起哦，姊姊。我，不能過去。",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_038"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦……？",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "每次都讓姊姊保護我，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這樣下去是不行的……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或許這也是一個不錯的契機……",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_041"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我啊，想去動物苑工作。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸！小、小栞，為什麼！？",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_042"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難道妳討厭我了嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所以不想和我住在一起嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我最喜歡姊姊了哦。",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但正因如此，我不想給姊姊造成困擾……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我才不會覺得困擾！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_044"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我會保護小栞，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n是因為我最喜歡妳了，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以我擔心妳啊，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以說……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我一直都知道姊姊妳最疼惜我，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_045"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會為我著想呦。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但我想",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓最愛我的姊姊看見，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也能夠獨當一面。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也是想像姊姊一樣努力……",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_046"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "總有一天要讓自己成為能守護姊姊的人。這是我的願望，也是我的目標喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_047"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣啊。小栞，妳已經下定決心了呢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為努力的妹妹加油打氣，也是姐姐應該做的……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……我知道了。我會支持小栞的！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_048"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然要分開生活了，但小栞也會好好加油嘛！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……不生氣嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_049"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎麼可能生氣嘛！這可是小栞想做的事情呢！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_050"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，要是感到寂寞的話就來找我喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "姐姐一定會為了小栞飛過來的！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯……姊姊，謝謝妳。",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_051"
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "從那之後便開始分開生活了，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_052"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但放不下心的姊姊經常會來看我的狀況。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞妳發現啦？",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_053"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我知道的唷。因為是姊姊嘛。而且姊姊，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_054"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也不會刻意躲起來，就只是偷偷跟在我後面。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿……小栞真的是什麼都知道呢。",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_055"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣說起來，是我感到寂寞，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n才會想來看看小栞的臉♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊真是的……不過，我也很開心喔？",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_056"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n每次看到姊姊的臉，精神就來了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是、是嗎，那就太好了♪",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_057"
    },
    {
        "type": "background",
        "background": "500151"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "安全抵達囉♪",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_058"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊、",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_059"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你送我回家。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}也是、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "非常感謝你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難得聊得這麼多好開心啊～！",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_060"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那就先這樣囉，小栞下次再見喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，姊姊……",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_061"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯？什麼事？",
        "unit_id": 101211,
        "voice": "vo_adv_5001001_062"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "(……之前一直在意姊姊到底在想什麼……",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_063"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，要是有必要一定會自己開口跟我說的吧。)",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，沒什麼啦，",
        "unit_id": 103811,
        "voice": "vo_adv_5001001_064"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒什麼事情。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n再見囉，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊、{player}♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
