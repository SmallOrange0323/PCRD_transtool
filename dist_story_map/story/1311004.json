    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}等人盡情遊玩了水上步行球。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n玩累的三人，在岸邊稍作歇息。"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "啊～",
        "unit_id": 131111,
        "voice": "vo_adv_1311004_000"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "口好渴～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小卡里莎，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "去買個果汁來～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "為什麼",
        "unit_id": 191618,
        "voice": "vo_adv_1311004_001"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我要聽妳的話去跑腿啊。",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳就這樣",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "脫水乾掉吧。",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "咦～",
        "unit_id": 131111,
        "voice": "vo_adv_1311004_002"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真沒勁～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n話說，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我有點想睡……",
        "unit_id": 131111
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哦，",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_003"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "這不是小騎士嗎！",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n你在做什麼～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嘿～",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_004"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "有點好奇小騎士會用什麼角色～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n我啊～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "只會選正太角色♪",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n而且很愛聽被打時發出的聲音，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "所以基本上都會輸掉～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不錯哦～",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_005"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我也很喜歡♪",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "小騎士你",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "有玩新歌曲的大師難度嗎？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那個會玩到手斷掉，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "要有個心理準備比較好喔～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "是嗎～？",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_006"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不過，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我懂～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n我有時候，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "也會只盯著夾娃娃機看喔～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "想說搞不好會換獎品，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "總之先確認一下呢～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "有點無聊？",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_007"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那麼",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "要來跟我約會嗎～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n做些有夏日風情的事",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "感覺也很不錯呢～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不錯嘛～♪",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_008"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那要來",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "做什麼好呢～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "現在這個時間，",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_009"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "去海邊的話有點晚了呢～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n今天",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "也沒有舉辦夏日祭典……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "小騎士，",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_010"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "你有想做的事嗎？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "什麼都可以說哦～♪",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哦，",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_011"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "原來如此呢～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n你想看姐姐我的泳裝嗎～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯？",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_012"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "你說想學會游泳……？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "啊～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "說起來小騎士好像還不會游泳？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那麼，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "就讓我來訓練你吧～♪",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "啊，",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_013"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不過說到泳池的話，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "就要用那個嗎……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "啊～抱歉。",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_014"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n雖然",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我也想跟你說沒有問題～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不過～",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_015"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "難得",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "都來遊樂中心了。",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n就用賽車遊戲一決勝負吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我贏了就去放煙火。",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "小騎士贏了的話",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "就去游泳池～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "好強！",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_016"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我又輸了～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不過，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "接著是釣魚遊戲～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "糟糕……",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_017"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "已經這麼晚了。",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "遊戲實在太好玩了～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "結果是小騎士贏了啊……",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_018"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n現在這個時間",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "只剩夜間泳池了吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我們",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_019"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "就先回去拿泳裝吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n在車站前集合可以嗎？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "很好，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那就這麼決定了～",
        "unit_id": 123331
    },
    {
        "type": "background",
        "background": "510352"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哦～",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_020"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "久等了～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n準備好了嗎？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "姐姐我",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "也準備萬全～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "說起來，",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_021"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我還是第一次去夜間泳池呢～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n會有人去那裡",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "練習游泳嗎～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "如果姐姐我",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "被搭訕的話～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "你會保護我嗎？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯哼哼～",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_022"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "謝謝～♡",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n就靠你囉～♪",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那麼，",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_023"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "去搭電車吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n到了現場，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "換完衣服後",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "再到泳池邊集合，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "拜託囉～",
        "unit_id": 123331
    },
    {
        "type": "still",
        "still": "131100401"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "小騎士～",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_024"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "這邊這邊～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "啊哈。",
        "unit_id": 123331,
        "voice": "vo_adv_1311004_025"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n比起泳裝的感想，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "居然先注意到那邊啊～",
        "unit_id": 123331
    },
    {
