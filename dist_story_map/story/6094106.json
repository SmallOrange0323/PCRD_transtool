    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "お化け屋敷かぁ……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "考え始めるといろいろと難しいものですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "騎士さん、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "何かアイデアないですか？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "だからそのためにどうするか……",
        "unit_id": 113911,
        "voice": "vo_adv_6050106_001"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "いや、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "それも大切ですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\nまずは経験を積まないといけませんから。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "でも呼び込みは",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n騎士さんの仕事ですよ？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "責任重大です。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "がんばってくださいね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "お化け屋敷って基本的に直接接触厳禁なんですよ？",
        "unit_id": 113911,
        "voice": "vo_adv_6050106_002"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "でももし、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "レイ様にそんなことができたら……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "だめですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n気づかれて叱られる未来しか見えません。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "い、",
        "unit_id": 113911,
        "voice": "vo_adv_6050106_003"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "意外と荒っぽいアイデアですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\nえ？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "こんにゃくをほっぺに？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "そ、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "そうですか……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "まぁ、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "候補としては残しておきますね。",
        "unit_id": 113911
    }
]