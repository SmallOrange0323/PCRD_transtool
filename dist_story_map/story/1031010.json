[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "多管閒事的阿姨所引起的騷動結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n過了幾天，忍看到{player}在街上奔跑。"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那傢伙在做什麼啊？",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_000"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是吃了霸王餐在逃命嗎？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他才不會做那種事。",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但看起來也不像是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接了什麼工作的樣子……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你好，{player}。",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看你跑得那麼快，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是怎麼了嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鍛鍊",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為何突然想這麼做？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那、",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那並不是你的錯！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "反倒是我太不中用，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "才會讓你遇到那種事，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是抱歉……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會好好守護你，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "絕不再讓這種事發生。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可、",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喔喔，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_007"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這樣很好！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "只要你稍微爭氣點，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n就不必給忍添麻煩了。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n你就一個人跑到世界的盡頭去吧！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎麼辦，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為我的關係，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "給你增添多餘的操勞……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那天受到你的幫助，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我明明已經發誓下次要好好守護你了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣不行，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我得再更確實地……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是這樣。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "多管閒事的阿姨也曾說過，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n只想單方面地守護你是不行的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也要",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "多依賴你一點。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果方便的話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要不要一起來趟修行之旅呢？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳、",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_012"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳在說什麼啊，忍！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這種事當然是絕對不行！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我似乎說了很大膽的提議吧？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這種程度的改變肯定是有必要的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鍛鍊身體是件好事，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但若要應付幽靈，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "光只是這樣還不夠。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "重要的是，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "靈力與精神力",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也得想辦法提升才行。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂，忍，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_016"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這可不行喔？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我絕對不會答應的！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會去找尋可以同時鍛鍊這些能力的修行，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以，請再給我一點時間吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這點事本來就是我該做的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n只要能幫上你的忙，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我就很開心了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊……",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也是。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們一起加油吧……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_020"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳有在聽嗎？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n妳有在聽",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "爸爸",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "說的話嗎？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過了幾天後──"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓你久等了。",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "經過多方調查，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我終於找到最理想的修行方式了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那就是東國所流傳的",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「巡禮」。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "據說",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這種修行方式，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是走遍東國各地，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "被稱為「寺廟」的神聖場所。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為是長距離步行，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有助於增強體力與精神力，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而巡訪靈氣豐沛的場所，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "相信也有助於提高靈力。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只不過，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "蘭德索爾境內並沒有「寺廟」。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我想我們可以去尋訪",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "位於海邊或山上，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n靈力充足的地點來取代「寺廟」。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "確實原本就是很嚴苛的修行。",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果我們可以完成，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一定會有所成長。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哼，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_026"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就你一個人在修行中曝屍荒野吧。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你現在就給我死在路邊吧。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你不是已經答應這次的修行了嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "事到如今，請不要說這種話。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我的確是答應了。",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_028"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "因為只要小伙子能接受鍛鍊，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n忍就不用再管他了。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n但是，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我不准妳跟小伙子兩人一起去！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳想想看？",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_029"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就你們兩個人待在杳無人煙的大自然之中？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n身心都獲得釋放的男女會發生什麼事……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "啊啊啊──！",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_030"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我絕對不答應！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n你給我用死來賠罪吧，小伙子──！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n……唔，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咦？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你、",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你們別丟下我啊──！",
        "unit_id": 2411
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "第一個地點是位於",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這座森林深處的樹木。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "據說那是一棵",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "樹齡超過千年的巨樹喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "歷史悠久的樹木，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有時會有神明寄宿當中。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接觸這類樹木，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "應該有助於靈力的提升。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那麼，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們趕快過去吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "──說到森林，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你有聽說過這種傳聞嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在這世界上，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "存在著只要一踏進去，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就無法再踏出來，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "充滿怨念的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "魔之森林……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "別擔心，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這座森林是安全的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只是陰暗了點，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是那麼好走。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還請你盡可能待在我身邊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "惡靈們",
        "words": "──嘎喔喔喔！",
        "unit_id": 1,
        "voice": "vo_adv_1031010_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那是惡靈……？",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這裡應該不會有惡靈會出現才對……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總之，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "由我來除去那個惡靈。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你先離開這裡……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不對，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是這樣。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這次的修行",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是我們兩個人要一起達成。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果只有我一個人戰鬥，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣什麼都沒有改變。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不好意思，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可以麻煩你像之前那樣，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在我除靈時幫我強化並給予協助嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你。",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼，我們上吧！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "……",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_041"
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "──我們到了。",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接下來，就往位在這座海岸的洞窟前進吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那裡好像供奉著龍神的神像。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對了，你知道嗎？",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "海市蜃樓的產生，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n根據其中一種說法表示，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "似乎是由巨大的蛤蜊所引起的呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "巨大的蛤蜊",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然感覺有點恐怖，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但我還是很想見識一下。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……不，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_044"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那不是海市蜃樓，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是惡靈。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們一路走到這裡，不知已巡訪過多少個點了，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n卻總是有惡靈來襲。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖說在靈氣豐沛的地點附近，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_045"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "容易有幽靈聚集，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但像這樣頻繁地遇到惡靈來襲，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總覺得有點不太自然。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "唔！",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_046"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這次連魔物也出現了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是受到惡靈釋放出的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不良靈氣的影響嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是──",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_047"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就是這樣。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "再麻煩你像之前那樣，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n幫我強化並協助我對抗魔物。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "……",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_048"
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "惡靈們",
        "words": "──嘎喔喔喔！",
        "unit_id": 1,
        "voice": "vo_adv_1031010_049"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼……",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_050"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看來這是最後一隻呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "辛苦你了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你已經很習慣這樣的戰鬥方式，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "行動也變得靈活多了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這就是修行的成果──",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦……？",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_051"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們走了遠路，還一路戰鬥到這裡來，這也難怪了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n目的地的祠堂離這裡不遠，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，我們先午休一下吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對了……",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_052"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我有做了便當喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n希望菜色有合你的胃口……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咕、",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_053"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我原以為只要小伙子受到鍛鍊，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_054"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍自然就會離開他，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n為何我反而感到他們的默契越來越好，甚至比我與忍之間的默契還要好。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不僅如此，是因為他已經習慣戰鬥了嗎？",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_055"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這趟旅行與其說是修行，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n現在反倒越來越像是出來野餐的！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n就算我能為修行讓步，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "也絕不允許他們倆曬恩愛！　",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我已經看不下去了……",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_056"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小伙子。既然你那麼愛修行，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就由我來鍛鍊你吧！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸、",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_057"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這麼突然是怎麼了？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍妳不要插嘴！",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_058"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "走吧，小伙子！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這是你死我活的特別課程！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n給我受死吧──",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_059"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊啊！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "祠、",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "祠堂……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "什、",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_060"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "什麼？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我什麼都還沒有做啊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "打擾吾之沉眠的，是汝等這群無禮之徒嗎……！",
        "unit_id": 1,
        "voice": "vo_adv_1031010_061"
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "\n那好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "殺了汝等！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "無禮之者格殺勿論！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗚哇，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_062"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "供奉的幽靈跑出來了……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n而且這傢伙",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "看起來很強……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "要強行除靈嗎？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "當然不行！",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_063"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "非常抱歉。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我們會把祠堂修理好的，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還請原諒我們。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "不成！",
        "unit_id": 1,
        "voice": "vo_adv_1031010_064"
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "無禮之徒一律格殺勿論！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這、",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_065"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這傢伙還真小心眼……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n沒辦法了，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小伙子，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你就成為祭品為我們犧牲吧。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸……？",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_066"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咿！",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_067"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "因、",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "因為不這麼做的話那傢伙根本不願原諒我們啊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總之，這裡由我來想辦法，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_068"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請爸爸安靜點。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們一再打擾到您，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_069"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的很抱歉。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然不知這樣是否能獲得您的諒解，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但請容我",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為您跳一支舞。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "跳舞？",
        "unit_id": 1,
        "voice": "vo_adv_1031010_070"
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "吾長久以來在此地接受供奉，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "\n從未見過這類東西。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "\n好吧，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "汝就跳來看看吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "不過，跳完之後一樣要殺了你們！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這傢伙",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_071"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "應該不是受到供奉，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "而是被封印在這裡的吧？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼……",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_072"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我要開始跳了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "～～♪",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_073"
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "喔、",
        "unit_id": 1,
        "voice": "vo_adv_1031010_074"
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "喔……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "這是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "好美的舞蹈！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "\n吾之殺意",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "已逐漸消散……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼……",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_075"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "您覺得滿意嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "太棒了……",
        "unit_id": 1,
        "voice": "vo_adv_1031010_076"
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "實在太棒了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "\n汝等的罪過",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被祭祀的幽靈",
        "words": "全都一筆勾銷吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "非常謝謝您。",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_077"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們之後",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也會為您修好祠堂的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還請您",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "安穩沉眠於此吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哎呀，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_078"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "真是吃盡了苦頭呢。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你還敢說，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_079"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你以為這是誰害的？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "等、",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_080"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "等一下，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我是被冤枉的！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我想",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那應該不是我造成的……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小伙子，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_081"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "願意相信我嗎……？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n那好，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我今天就饒你不死，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "好好感謝我吧。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……既然你這麼說，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_082"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那我",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "明白了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_083"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對不起，我懷疑了你。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請你不要再突然亂發脾氣了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "呃，",
        "unit_id": 2411,
        "voice": "vo_adv_1031010_084"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我知道了……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我會好好考慮。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "話說回來，",
        "unit_id": 103111,
        "voice": "vo_adv_1031010_085"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "先不提爸爸的事，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "惡靈的襲擊很明顯地非常不對勁。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有上次那個多管閒事的阿姨也是，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這到底是怎麼回事？　",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然到最後惡靈和祠堂的謎團都沒有解開，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但這趟巡禮姑且算是順利地完成了。"
    }
]