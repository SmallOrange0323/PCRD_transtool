[
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}造訪了「象牙之塔」，\n但優妮似乎還沒找到新的研究主題，\n所以一直在桌前嘆著大氣。"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哈呼……",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎麼回事啊。",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n感覺今天翻頁的手指格外的沉重。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "遍布全身的倦怠感讓全身提不起勁，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "睡魔的惡作劇就像是春天的陽光一般奪走了我的注意力。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "換言之，講白一點——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是我好懶啊……",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是怎麼了呢？",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我今天一直在找那個答案。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的自我，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n現在為什麼會在這裡呢……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_1110008_006"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n我來回答！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n優妮博士",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "正在摸索新的研究課題！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "雖說如此，但一直想不到好點子，",
        "unit_id": 1,
        "voice": "vo_adv_1110008_007"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n意欲、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "衝動、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "積極性，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "全部都大幅降低！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n伴隨著思考遲鈍，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "開啟抑鬱模式了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "進入這個模式的人類，",
        "unit_id": 1,
        "voice": "vo_adv_1110008_008"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "感性會變得較如詩一般，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n並且容易沉浸於感傷中來重新審視自己的人生！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唉……",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n現在想想，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我為什麼會下山試圖成為一位學者呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果只是要讀書，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "撰寫理論的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在老師們的書房就夠了呀。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒有香氣的風，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒有進展的課題，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不起眼的房間。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我說啊，羅塞塔，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "此刻的天空是什麼顏色呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_1110008_012"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n我來回答！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n請您自己去看看窗外！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "意思也就是要我親眼確認嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唉呀唉呀，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在就連我養的魔像都反咬我一口，真是世風日下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看呀，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "{player}學弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n說來諷刺，與我陰晴不定的內心相反，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這片廣闊的天空，今天也是蔚藍得一朵雲都沒有呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "接著向下俯視，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "便能看見翠綠的上學路徑。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n正值青春年華的少女們，正發出桃色的歡呼聲，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n歡樂地踏著輕快的腳步離我遠去呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "簡直就自成了一幅畫嘛。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那才正是名聞遐邇的青春的一幕呀。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是我曾幾何時",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "憧憬過的薔薇色的校園生活呀。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "曾幾何時……",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "憧憬過的……？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊！",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想起來了！　",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對啦，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是那個啦！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個正是我心心念念的理想！",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是讓我丟下書本，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來到這城鎮最根本的理由！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哼，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果你要笑我不自量力就笑吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但是，我此刻就要",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "毫不隱瞞地告訴你真相！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯！",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我就是因為很憧憬傳聞中的學園生活，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以才來到這裡的！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "…………",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你在聽嗎，學弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n為什麼你一臉吃驚似地張著嘴僵在那裡？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你不知道嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是學園生活喔，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學園生活。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n據說這裡有一種",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "叫做青春的新鮮情緒。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是我想要青春一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "閉嘴，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我想要青春一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "和我去青春一下吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你是想說我睡眠不足嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎樣才算是充足呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n要是有人叫我睡覺，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的體質可是能睡很久很久。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在夢裡有半分清醒，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在現實則有半分昏睡，那人就是我。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在這個滿是謊言的世界，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "睡得迷迷糊糊度日，不過是剛好而已。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是喝了。",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喝的是有深月印記的精力藥水。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，那個我平常時就在喝了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n事到如今，你問這個幹嘛？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n怎麼回事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個好像看過又好像沒看過的神祕光芒……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊！　",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼說來，我聽說過。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n人們常將青春",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "比喻成光芒或光輝……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，",
        "unit_id": 111011,
        "voice": "vo_adv_1110008_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我等你很久了！",
