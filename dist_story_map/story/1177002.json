    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那真是",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "太剛好啦～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來來，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們走吧♪",
        "unit_id": 117711
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n變裝派對",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好期待呀～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我的故鄉",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也有萬聖節喔～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "小孩們會變裝，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "每年",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "都很熱鬧～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "蘭德索爾的萬聖節，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n比我的故鄉",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還更加更～加熱鬧呀～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以我",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一直都超期待，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n能參加蘭德索爾的變裝派對喔～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……奇怪？",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n有很多人",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "從市區那邊往這裡跑過來了～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這也是什麼萬聖節的活動嗎～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "幽、",
        "unit_id": 311,
        "voice": "vo_adv_1177002_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "幽靈出現啦～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "幽靈？",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n欸欸，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大哥。",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那邊發生了什麼事嗎～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 311,
        "voice": "vo_adv_1177002_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是啊……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n像是南瓜燈籠明明沒有人碰，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n卻突然",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "飄到空中……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "或是明明沒有人在的地方，",
        "unit_id": 311,
        "voice": "vo_adv_1177002_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n卻傳來女孩子的聲音……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n那邊一直發生可怕的靈異現象啊！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以大家",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才會害怕地逃跑啊～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n……咦？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那變裝派對怎麼辦……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "現在沒那個閒工夫了啦！",
        "unit_id": 311,
        "voice": "vo_adv_1177002_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n你們最好也不要靠近那邊。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n搞不好會被詛咒喔！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……雖然無可奈何，",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過變裝派對取消了真可惜～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我本來很期待的說……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……咦？",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你說只要我們解決幽靈騷動，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n變裝派對就有可能重辦？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "的確",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有可能耶～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這也是為了守護我們的萬聖節，",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n總之",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "先去現場看看吧──！",
        "unit_id": 117711
    },
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "到處都不見人影……",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家好像都逃走了～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "超安靜的～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n幽靈在哪裡呢～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……啊！",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "危險，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "快躲開──！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚇我一跳……",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n南瓜燈籠居然忽然飛過來……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n{player}，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你沒事吧～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈……",
        "unit_id": 1,
        "voice": "vo_adv_1177002_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……聽得到笑聲",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "卻看不見身影啊～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這場騷動果然",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是幽靈搞的鬼呢～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "欸，",
        "unit_id": 1,
        "voice": "vo_adv_1177002_022"
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "你們兩個。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "跟我一起玩吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來玩是指……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇哇！？",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n又有南瓜燈籠飛來啦～！？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不管怎樣，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "先集中精神閃躲吧──！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "啊哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_1177002_025"
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "大姐姐好～厲害！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "\n那，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "這招怎麼樣？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇！",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "驚險躲過了～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喂──！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "快住手啊──！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "咦～？",
        "unit_id": 1,
        "voice": "vo_adv_1177002_027"
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "為什麼？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "\n明明很好玩呀！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "看招！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "唔唔唔……",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然想阻止她惡作劇，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過看不見對方也無計可施……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "先",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "爭取點時間來擬定策略吧～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n嘿，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "躲到這裡來～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_1177002_030"
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "奇怪？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "\n你們跑去哪裡了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女幽靈",
        "words": "大哥哥和大姐姐？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呼，",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "躲在這裡應該不會被發現～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是",
        "unit_id": 117711
    },
