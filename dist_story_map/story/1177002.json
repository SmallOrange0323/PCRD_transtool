    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我就想說～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好想找{player}一起去喔～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……你打工下班了，",
        "unit_id": 117711,
        "voice": "vo_adv_1177002_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "接下來正好有空閒嗎？",
