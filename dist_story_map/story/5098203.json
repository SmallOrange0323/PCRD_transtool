[
    {
        "type": "dialogue",
        "name": "禊",
        "words": "太好了……！",
        "unit_id": 122811,
        "voice": "vo_adv_5098203_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n總算在門關閉之前，",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n把小繆送回去了。",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯。",
        "unit_id": 122711,
        "voice": "vo_adv_5098203_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……小繆，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要保重喔。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "繆～？",
        "unit_id": 1,
        "voice": "vo_adv_5098203_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……咦？",
        "unit_id": 122911,
        "voice": "vo_adv_5098203_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n剛才",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是不是有聽到小繆的聲音？",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊好像也……",
        "unit_id": 122811,
        "voice": "vo_adv_5098203_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "聽到了？",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "一定是錯覺吧。",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "小繆",
        "words": "繆繆～！",
        "unit_id": 8411,
        "voice": "vo_adv_5098203_005"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "咦咦──！",
        "unit_id": 1,
        "voice": "vo_adv_5098203_006"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "\n小繆！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "為、",
        "unit_id": 122811,
        "voice": "vo_adv_5098203_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "為什麼？",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n我們",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "有確實地送走牠了吧？",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "難道……",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "有什麼地方做錯了？",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "呀！？",
        "unit_id": 1,
        "voice": "vo_adv_5098203_008"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "妳們",
        "unit_id": 122911,
        "voice": "vo_adv_5098203_009"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "看！",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n那邊",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "又出現一道大門耶。",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "剛才那道門",
        "unit_id": 122711,
        "voice": "vo_adv_5098203_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還到不了另一邊的世界嗎……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "小繆、",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊、",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "美美！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我們再挑戰一次吧！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "小繆",
        "words": "繆～！",
        "unit_id": 8411,
        "voice": "vo_adv_5098203_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要去其他世界果然很難呀──",
        "unit_id": 122811,
        "voice": "vo_adv_5098203_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過，",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "讓我們努力到最後吧！",
        "unit_id": 122811
    }
