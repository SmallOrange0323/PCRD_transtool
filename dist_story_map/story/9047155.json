[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811,
        "voice": "vo_adv_9047155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n既然小雪菲都跟我們會合了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就來開個慶祝歡迎會吧♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確呢。",
        "unit_id": 105911,
        "voice": "vo_adv_9047155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了在這座",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "艾爾皮斯島繼續同心協力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一定要來辦場盛大的歡迎會。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝……",
        "unit_id": 106411,
        "voice": "vo_adv_9047155_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但大家",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不必勉強自己喔。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，我說妳們啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9047155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n講那什麼悠哉話！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811,
        "voice": "vo_adv_9047155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留不願意嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳不想辦小雪菲的歡迎會啊。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚……",
        "unit_id": 106011,
        "voice": "vo_adv_9047155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不反對辦歡迎會，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但這裡可是位在飛龍地盤的正中央喔？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在我們討論這種事情時，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞不好附近早就──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔喔，",
        "unit_id": 105911,
        "voice": "vo_adv_9047155_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的有飛龍……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真不愧是凱留呢，",
        "unit_id": 106411,
        "voice": "vo_adv_9047155_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n有種很習慣冒險的感覺。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還、",
        "unit_id": 106011,
        "voice": "vo_adv_9047155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還好啦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在不是奉承我的時候啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_9047155_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了辦歡迎會，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們不能在這裡敗下陣來。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也會",
        "unit_id": 106411,
        "voice": "vo_adv_9047155_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "試著讓自己幫上大家的忙！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就以齊聚一堂的【美食殿堂】",
        "unit_id": 105811,
        "voice": "vo_adv_9047155_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來迎擊吧！",
        "unit_id": 105811
    }
]