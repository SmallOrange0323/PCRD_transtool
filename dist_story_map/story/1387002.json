        "name": "美冬",
        "words": "下一個特訓是──",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「屁鼓五十連打」、",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n「屁股木屐上下樓梯一百趟」、",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「千下雪球臀擊」，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n透過輪盤來決定",
