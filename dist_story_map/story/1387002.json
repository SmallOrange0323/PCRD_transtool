    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "美冬教練……",
        "unit_id": 138712,
        "voice": "vo_adv_1387002_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n妳對屁股相撲的熱情和想像力，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n為什麼不用在世界和平之類的方面呢……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "拜託別轉到屁股木屐，",
