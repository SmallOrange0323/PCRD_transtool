        "voice": "vo_adv_1387002_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "只要不是屁股木屐就好，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "絕對不要屁股木屐……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼轉到的是──",
        "unit_id": 108013,
        "voice": "vo_adv_1387002_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「屁股木屐」！",
