    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡呢！",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是我們【美食殿堂】的公會小屋喔～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等、",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別什麼都不說明就在那裡擅自行動啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳每次都是這個樣子，",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是受不了耶！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～。",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們之間已經熟到讓妳用",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「老是這樣子」來形容了呢……感覺好親密喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很開心喔！",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n親愛的小凱留～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快住手，喂！別抱住我啦！",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要莫名其妙地拉我的尾巴啦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底搞什麼啦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小心我宰了妳喔……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳們感情真的很好呢。",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。在下聽說，",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在設立公會的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以獲得公會之家以作為據點……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡離蘭德索爾商店街只有徒步數分鐘的距離，",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是個位置絕佳的好地方。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "建築的外觀看起來也十分氣派。",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n居然能讓我們這種，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以說是來歷不明的公會使用……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "作為公會據點來說，",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像有點太豪華了些呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蘭德索爾這個地方，",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明地價應該是高的嚇死人才對的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟就算荒廢了，也還是這個國家的首都嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我總覺得，事情好像沒那麼單純耶。",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，反正那也不關我的事！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會不關妳的事呢！",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留也是【美食殿堂】的一員呀！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就說了，",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我不記得我有進過那種奇怪的公會！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明是妳趁人不注意的時候組了公會，",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還擅自把我當會員給加了進去吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哪有呀～……",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過呢在蘭德索爾，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有加入公會的話，做很多事情都會比較方便喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且還有公會專屬的高級餐廳，",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟「孤家寡人」能做的事還是有限的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我們互相幫助、互相扶持、互相友愛吧！",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n公會就是為此而存在的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們今後就好好相處吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就說，不要拉我的尾巴！",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣我會使不上力啦……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真逗趣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們跟蘭德索爾也是非親非故的。",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能得到公會這樣的去處，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真的是一件求之不得的事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再說，",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【美食殿堂】的公會目標，就是吃遍天下呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "平常⋯⋯",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n每天晚上就是我們這幾個圍著餐桌，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣就算是進行公會活動了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不需要做任何困難的事！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家只要跟以前一樣，",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "隨心所欲地做自己的事就OK了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這一次因為要辦理一些繁瑣的資料，",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n需要和公會之家的「管理員」打個照面……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才會請大家親自來這裡一趟。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "基本上公會之家的環境清潔等工作，",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都會由那位「管理員」來負責進行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說實話我們這群人，",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果沒有事的話根本不用到這裡來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼隨隨便便的感覺，真的好嗎……",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然說沒有造成我們的負擔，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也就沒什麼好抱怨的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也不介意吧？",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下服從主人的決定⋯⋯♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，你在啊……",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你還是一樣，毫無存在感呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有{player}……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總之我們四個人～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就先註冊成為【美食殿堂】的成員囉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果有隸屬於其他公會的朋友，",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也可以自由地帶他們過來玩，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就隨意地進出，把這裡當成一個可以玩耍閒聊",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n的聚會場所，好好利用一下吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然啦～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果大家想要活用這個公會之家，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來做些其他事情的話都可以喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我自己本身呢～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是想把這棟小屋改裝成餐廳來經營……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要註冊成為餐廳，",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能夠以這個名目引進各國美食！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼一來每天都是奢華享樂的宴會囉～！",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳還真的是只想得到吃呢。",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我是無所謂啦",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "午安～。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_043"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那個，各位是公會【美食殿堂】的人嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥？",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別隨隨便便地插話啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳是誰呀？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我覺得一見面就好像要找人吵架的語氣不太好喲？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳該不會是～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n公會小屋的「管理員」吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_047"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我是【公會管理協會】的員工，叫作花凜。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次由我來擔任公會【美食殿堂】的負責人，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_048"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n今後請多多指教♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真是太客氣了。",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，【公會管理協會】是？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，我來向各位說明。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_050"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在蘭德索爾，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n幾乎全體居民都有隸屬於公會的義務。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "當然從其他國家，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_051"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "前來觀光的旅客等等是例外。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "隸屬於公會，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_052"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就等同於登記戶籍……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "可以擁有多種好處，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_053"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n像是享受各種公共服務等等。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在蘭德索爾，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_054"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n公會是非常重要的組織。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們【公會管理協會】，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_055"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n就是為了管理公會而設立的………",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "算是，政府機關吧。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜小姐是公務員呀！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼穩定的職業真讓人羨慕……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_057"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n雖然是穩定的職業，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但是由於人手不足很辛苦呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一方面是，公會數量不斷在增加……",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_058"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "而且並不是所有的公會，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n都會乖乖聽從我們的指示。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位也是，請盡量遵守規矩喔。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_059"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "若太常惹事的話，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n會由我來負責指導。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "最嚴重的情況，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_060"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n可能會遭致解散公會之類的處分。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦好啦……",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_061"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不會杵逆上意的啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我會乖乖的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "能這麼做的話就是幫了我大忙了～。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_062"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "相反的，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n如果有任何困難或糾紛的話請找我商量喔！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我就駐守在這個公會之家。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_063"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n有任何需要時，請不要客氣。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105913,
        "voice": "vo_adv_4001001_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這麼說花凜小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是住在這裡的嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，我的住家是在別處。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_065"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不過白天都是在這個公會之家裡，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n做些文書處理之類的工作。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是這樣的規定，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_066"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n你們能理解的話就太好了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "公會之家在設立時，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_067"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n短期間內必須有負責的職員駐守。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "或許會令你們覺得礙眼，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_068"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果能多少寬待一些的話，我會很感激的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不不不，當然不會覺得礙眼啦～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過妳剛剛說……短期間內，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說之後就會離開嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_070"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n規定上，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "需由我判斷，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n看看各位是否為值得信賴的公會……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "只要得到【公會管理協會】的認可，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_071"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我的駐守義務就會解除了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "當然偶而，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_072"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我也會為了建築物的管理而進出這裡。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "畢竟，那是我的工作。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_073"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這裡離其他由我負責的公會之家也很近，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "且位在商圈旁邊非常便利……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "老實說，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_074"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我還真想一直在這裡工作呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我會負責打掃，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_075"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n若有需要的家具與生活用品也請告訴我，我會準備。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "現在屋子裡還什麼都沒有，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_076"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n請依照你們的喜好任意佈置吧。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對了，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_077"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然不收房租，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但是家具依情況是需要收費的，請見諒。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "當然，我會盡可能地準備較便宜的家具。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_078"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "房租免費還真是大方呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且這屋子看起來還很氣派……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會～",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_079"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這棟屋子是那種有問題的房子吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_080"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這就任憑您想像了♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_081"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對了………",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這棟公會之家，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n如各位所見是三層樓的建築。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但是二樓與三樓是無法使用的，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_082"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所以基本上請各位只在一樓活動。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "二樓與三樓，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_083"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "還在調查……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊不對，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是因為還沒清掃完畢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n目前，依我的判斷封鎖了前往二樓的樓梯。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_084"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼感覺",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像有哪裡怪怪的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好可疑……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "管它的。",
        "unit_id": 106012,
        "voice": "vo_adv_4001001_085"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n反正多一事不如少一事對吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵，總之。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_086"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n一直在外面，\n站著說話也不是辦法……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我帶各位到屋內看看吧，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_087"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n話是這麼說，不過裡面真的什麼東西也沒有喔。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的！",
        "unit_id": 105812,
        "voice": "vo_adv_4001001_088"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家我們走吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "打擾囉～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_089"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n不是「打擾了」，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n應該說「我回來了」才對……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "希望這個公會之家能帶給各位一種家的感覺，",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_090"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n請各位多多幫忙了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "再次。",
        "unit_id": 190811,
        "voice": "vo_adv_4001001_091"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "歡迎各位，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n來到您們的公會之家……♪",
        "unit_id": 190811
    }
]