[
    {
        "type": "background",
        "background": "502260"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們在芙菈瓦村要幫忙的事，",
        "unit_id": 130711,
        "voice": "vo_adv_6144207_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n很快就要全部做完了呢……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然有點寂寞，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但那些都變成了美好的回憶。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也得好好準備",
        "unit_id": 130711,
        "voice": "vo_adv_6144207_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要給美美和禊的伴手禮，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n讓她們知道這個村莊的好才行！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "除了花以外，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這裡也有蔬菜和水果，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你覺得哪樣比較好呢？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼要特地選青椒啊！？",
        "unit_id": 130711,
        "voice": "vo_adv_6144207_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我確實已經變得敢吃青椒了，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但我還是不喜歡！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請改挑其他蔬菜吧！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "水果……",
        "unit_id": 130711,
        "voice": "vo_adv_6144207_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我覺得很不錯！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我也沒聽說過",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "她們兩個有什麼水果是不敢吃的。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n只要不是太獨特的水果應該都沒問題！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是，",
        "unit_id": 130711,
        "voice": "vo_adv_6144207_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我對於水果不是很了解，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果你方便的話，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可以和我一起挑選嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "畢竟關於食物方面，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我想你應該比較清楚吧。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "花束的話，",
        "unit_id": 130711,
        "voice": "vo_adv_6144207_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我想美美會很喜歡的。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "至於禊……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯～",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "選更加有趣的東西給她可能比較好？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在花束上下點功夫或許也不錯。",
        "unit_id": 130711
    }
]