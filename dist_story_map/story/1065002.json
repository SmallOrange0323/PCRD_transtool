[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}帶著嘉夜，\n走到想麻煩她代為爭鬥的人所在地。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這裡嗎……",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "然後",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你說的委託對象在哪呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "哥哥拿走了人家的獅子玩偶～！",
        "unit_id": 211,
        "voice": "vo_adv_1065002_001"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "\n人家，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "還要玩呢！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "玩具，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "快還來啦～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "才不要，",
        "unit_id": 111,
        "voice": "vo_adv_1065002_002"
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "這次換我跟獅子先生一起玩了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "\n而且，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "這本來就是我的東西吧～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "哇～！",
        "unit_id": 211,
        "voice": "vo_adv_1065002_003"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "哥哥是笨蛋笨蛋笨蛋！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快點幫我介紹啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "欸喂。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該不會，你說的打架，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n是指兄妹之間的吵架吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喔？",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是妹妹呀。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "請多多指教！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不對啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "難道",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這就是你說的打架嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但這只是兄妹吵架吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說啊……",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我可是以互毆為工作的打手喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n再怎麼說，小孩子之間的吵架我是不會介入的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不好意思，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種架就交給你了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n再見。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "大姐姐，",
        "unit_id": 211,
        "voice": "vo_adv_1065002_009"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "妳要走了嗎……？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "求求妳！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "\n幫我拿回獅子先生───！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "我會把我的點心給妳的───！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂！",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就說別拉了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "報酬是點心、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是嗎。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真拿妳沒辦法，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我接下了唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "咦～！",
        "unit_id": 111,
        "voice": "vo_adv_1065002_012"
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "妳太狡猾了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "而且是因為妳常常哭鬧，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "\n所以我才一直都讓著妳！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "只借我一天沒關係吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……對呀。",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "從哥哥的角度來看，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n看起來妹妹",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總是占上風吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "吶，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你們還有",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其他兄弟姊妹嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n像這樣吵架，可是一點好處都沒有的唷？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然這個是哥哥的玩具，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但能不能考慮",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "兩個人一起玩呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "嗯、",
        "unit_id": 111,
        "voice": "vo_adv_1065002_016"
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "嗯……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "大姐姐",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "這樣說的話",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "\n那就一起玩吧。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "真的嗎！？",
        "unit_id": 211,
        "voice": "vo_adv_1065002_017"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "太好了！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "跟哥哥一起玩～！！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "那，",
        "unit_id": 111,
        "voice": "vo_adv_1065002_018"
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "我們去那邊的公園一起跟獅子玩吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "嗯！",
        "unit_id": 211,
        "voice": "vo_adv_1065002_019"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "大姐姐謝謝妳───！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "他們走掉了呢。",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個孩子，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該是想跟哥哥一起玩吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……之類的，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你以為當成美談一件就能打發過去嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拜託你之後認真點啦？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n下次你可要介紹給我",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "正經一點的打架工作喔。",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喲。",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的假的？",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這次一定沒問題吧……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總之帶我去現場吧。",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "為什麼你每次、",
        "unit_id": 411,
        "voice": "vo_adv_1065002_024"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "每次約會都遲到啊！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n反正我對你來說，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "一點都不重要吧！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我不是說過很多次了嗎！？",
        "unit_id": 311,
        "voice": "vo_adv_1065002_025"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n那是因為下班前又被交代工作，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不用好的話根本回不了家呀！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……喂。",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n該不會，這次是要我",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "阻止情侶吵架吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊，",
        "unit_id": 411,
        "voice": "vo_adv_1065002_027"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳就是那個打手吧！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我會付錢的，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳能嚴厲地訓一訓這個人嗎！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "總是不斷地找藉口……",
        "unit_id": 411,
        "voice": "vo_adv_1065002_028"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我無論如何都不能原諒他！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算妳要我嚴厲……",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這位小姐。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n妳覺得我看起來是個專精口頭吵架的人嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我的專業可是跟人互毆唷。",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "小姐的男朋友，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "能讓我揍嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果可以，我是也能接下這個工作啦……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "如、",
        "unit_id": 411,
        "voice": "vo_adv_1065002_031"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "如果要揍他的話不行！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不要傷害他！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "他、",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "他受傷的話我可沒辦法忍受！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "對不起……",
        "unit_id": 411,
        "voice": "vo_adv_1065002_032"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "太寂寞了……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "而且我怕你太過努力工作，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可能會累倒，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我一直很擔心……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這樣啊……",
        "unit_id": 311,
        "voice": "vo_adv_1065002_033"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "抱歉，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "讓妳不安了……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我努力工作，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "也是為了有天能和妳在一起。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我愛妳……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我也是……",
        "unit_id": 411,
        "voice": "vo_adv_1065002_034"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "果然",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "還是",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "很愛你……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我的達令……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂～",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_035"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "兩人卿卿我我的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別忘記",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們還在這裡好嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "對不起，",
        "unit_id": 411,
        "voice": "vo_adv_1065002_036"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不知不覺進入了兩人世界……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "多虧你們，我們才能和好。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n好的，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "給妳，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這是報酬。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "呵呵，",
        "unit_id": 311,
        "voice": "vo_adv_1065002_037"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我的小親親……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n那麼，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "去個能夠獨處的地方吧……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好啦好啦，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_038"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你們快去吧……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然拿到了報酬，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但感覺比平常更累呀……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好啦這給你，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你的那份。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "既然閒下來了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就去吃個甜食吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你也陪我來吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟是你把剛剛那個女生介紹給我。",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這裡的可麗餅，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_040"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很好吃喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這頓我請客。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "作為介紹工作的謝禮。",
        "unit_id": 106511
    },
    {
        "type": "still",
        "still": "106500201"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯～！",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好甜！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "超甜的！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然思考完後，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一定要吃甜食啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是嗎？",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就是我吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我不覺得哪有變化呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那是當然，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為美食很美味呀！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你不也是這樣嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一臉覺得很美味的表情啊？",
        "unit_id": 106511
    },
    {
        "type": "still",
        "still": "106500202"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那還真是謝謝誇獎了。",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不對不對，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別開玩笑了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還想說你突然要說什麼咧，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_045"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是有趣的傢伙呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該說是動作，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是舉止呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說話的方式總覺得也有種特別的感覺。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "平時過著怎樣的生活呢？",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_046"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n明明身上有劍，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該不只做送貨的工作吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該不會你",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "和我一樣也是打手……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該不是吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "欸，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你是什麼來頭啊？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啥？",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_048"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼回事……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的假的啊。",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_049"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你這樣不只是不記得的程度了耶。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n真虧你",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "能活到現在啊？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_050"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不記得別人都記得的事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n感覺滿累的呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們龍人族跟你相反，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_051"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們記得的事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其他人都不記得唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟沒有記憶的你說這些，你應該也不懂，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_052"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但是現在這個世界，是有人把各種東西",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "大幅度地扭曲以後所形成的世界呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們龍人族，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_053"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還記得那個被改變前的世界，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n而其他人則都忘記了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種感覺真的很奇怪呢。",
        "unit_id": 106511
    },
    {
        "type": "still",
        "still": "106500203"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_054"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "關於我的事就這樣吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總之，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們同為",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有記憶問題的夥伴，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今後就好好相處吧──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好～了，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_055"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "肚子也飽了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "接下來要做什麼呢──",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "好痛啊，你這傢伙！",
        "unit_id": 911,
        "voice": "vo_adv_1065002_056"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "看哪裡走路啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n可麗餅都沾到老子的衣服上了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "別邊走邊發呆！",
        "unit_id": 911,
        "voice": "vo_adv_1065002_057"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n小心我把你揍的滿地找牙！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "喂！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊──",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_058"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果我誤會的話不好意思。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你現在是在找我死黨",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的麻煩吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "啊啊是啊！",
        "unit_id": 911,
        "voice": "vo_adv_1065002_059"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "如果是那又怎樣，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "妳這個小鬼！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼這場架，",
        "unit_id": 106511,
        "voice": "vo_adv_1065002_060"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就接手了吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "喔喔喔！",
