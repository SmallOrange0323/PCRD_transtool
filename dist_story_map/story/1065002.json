    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我可是不會輸給小鬼的！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n讓我來狠揍妳一頓吧！",
