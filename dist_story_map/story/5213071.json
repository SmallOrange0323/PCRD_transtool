        "words": "呼……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不小心就發出聲音了……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "又好吃，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "又可愛……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這種甜點，我還是第一次吃到……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊，",
        "unit_id": 103712,
        "voice": "vo_adv_5213071_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "竟然讓你看見",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我跟平常不一樣的一面……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我根本沒想到",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你也會在這裡，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好尷尬啊。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511,
        "voice": "vo_adv_5213071_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "妳喜歡嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這可是吉歐‧提格尼亞裡，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "精挑細選出的可愛甜點呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不由自主地發出聲音，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也是情有可原的事。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那是當然，",
        "unit_id": 103712,
        "voice": "vo_adv_5213071_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "完全無可挑剔呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不只外表可愛，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就連味道和口感，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都可愛得不像話，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n太犯規了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "竟然連我都會一時忘我……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以，",
        "unit_id": 103712,
        "voice": "vo_adv_5213071_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我剛才",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為太沉迷於可愛甜點，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n發出奇怪聲音的這件事……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要是妳們能幫我保密，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會很感激",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "的……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯，",
        "unit_id": 126511,
        "voice": "vo_adv_5213071_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是啊。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我也有同感……♪",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所、",
        "unit_id": 103712,
        "voice": "vo_adv_5213071_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以我才說啊！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我平常，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可是一直維持著很正經的形象！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以也拜託你了，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一定要替我保密喔──！",
        "unit_id": 103712
    }
]