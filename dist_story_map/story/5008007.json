    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不看氣氛直接硬闖，真不愧是流夏姐！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我可不允許用毛巾和熱氣來蒙混喔～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那我也去吧～？　",
        "unit_id": 101311,
        "voice": "vo_adv_5008007_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真期待呢，混浴溫泉！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我嗅到後宮路線的味道囉～！！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "混、混浴！？",
        "unit_id": 100911,
        "voice": "vo_adv_5008007_037"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "混浴也就是說，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要和吉格魯特",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一起泡溫泉！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然，",
        "unit_id": 101311,
        "voice": "vo_adv_5008007_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "杏奈美眉也會一起去對吧～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不，",
        "unit_id": 100911,
        "voice": "vo_adv_5008007_039"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那個……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但如果",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼做可以療癒吉格魯特的傷……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔喔喔喔喔！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008007_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "杏奈美眉立旗了！？　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "立旗了嗎！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看啊",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "大家～！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "杏奈立旗囉～！！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳到底在說什麼啊，七七香！",
        "unit_id": 100911,
        "voice": "vo_adv_5008007_041"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我只是",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "想幫助吉格魯特療癒他的傷啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "明明是難得的混浴露天溫泉……",
        "unit_id": 102711,
        "voice": "vo_adv_5008007_042"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是沒辦法了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就在溫泉裡加入含有催眠效果的藥……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呵呵。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呵呵。",
        "unit_id": 105611,
        "voice": "vo_adv_5008007_043"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是群靜不下來的傢伙。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
