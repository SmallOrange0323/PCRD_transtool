[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧從有些距離的地方"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遠望著露娜和玩偶遊玩的樣子。"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……呵呵。",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露娜和玩偶說話的時候，",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n看起來非常開心呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我在幫好朋友號維修保養的時候",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n也會專注到忘了時間，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可以說我很了解這種心情吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "或許形式不同，",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但對露娜來說，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩偶果然是很特別的存在呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………啊。",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……嗯？　",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_005"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……這裡。",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_006"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_007"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……雖然以前媽媽會修補，",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_008"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n但對露娜來說太難了……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_009"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "會修補嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不介意的話，",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n可以讓我來縫補露娜的玩偶嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為好朋友號",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "從以前就很常",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "彈飛到各種地方，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n每次斗篷都會變得破破爛爛的呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我身上也隨時帶著維修用的裁縫組……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要露娜不介意的話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……可以嗎？",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "當、",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "當然可以……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我稍微跟妳借一下玩偶喔……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "哇……",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_017"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "你看！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n好像魔法一樣耶！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸嘿嘿……！",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這麼說可能有些太自吹自擂，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不過我算是個手巧的人啦……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以，",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼一點小事我就算閉著眼也能──",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊嗚！？",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_020"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "！？",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_021"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……感覺",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_022"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "手指很痛。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我太得意忘形了……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……要不要",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_024"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "用露娜的手帕？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不用不用……！",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這點小傷不要緊……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我這次會確實睜開眼縫補的……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "完成了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n以我而言，縫得還挺不錯的！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露娜，",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "來，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請收下！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……啊。",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_029"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嗯……",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_030"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大姐姐，",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_031"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……謝謝妳。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "她、",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "她看著我的眼睛對我笑了……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我有學會裁縫技術",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真是太好了……！　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我才是……！",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n要謝謝妳……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……那個，",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_034"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜想說的",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "並不只有謝謝……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "什麼？",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_035"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……該、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "該不會我沒確實縫補好！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不是的……",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_036"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大姐姐，",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_037"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "雖然妳很怪。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……雖然妳很怪。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不過，",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_038"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜不討厭妳喔。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……可以稍微",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "和妳玩一下喔。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚、",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_039"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚哇啊啊啊～！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n真的嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011,
        "voice": "vo_adv_7026004_040"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我好高興！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不嫌棄的話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請務必讓我陪妳玩！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……呵呵，",
        "unit_id": 111411,
        "voice": "vo_adv_7026004_041"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n妳果然很怪，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "好有趣。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧和露娜透過玩偶稍微拉近了距離，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}帶著微笑看著她們兩人。"
    }
]