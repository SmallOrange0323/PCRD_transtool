[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在眾人為即將到來的聖誕節雀躍不已時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一名少女愁眉苦臉地走在路上。"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "人又多，天氣又冷，還有種格格不入的感覺……",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "果然不該在聖誕節期間出門的。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好想窩在家裡玩遊戲啊……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "叮叮噹，叮叮噹～♪",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "聖誕節好讓人雀躍呀！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里的朋友在那邊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n要不要去打個招呼呀！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我的確",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是沒有以前那麼怕生了……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n但也不是完全不怕生呀。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而且我有點累了，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我就坐長椅上顧東西吧……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊很沒有體力呢……",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里知道了～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那我自己去聊個天吧！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啦啦啦～♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "居然在雪地上小跳步……",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里的體力好得跟鬼一樣……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "明明不用特地找我這種弱不禁風的人來逛街的……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……咦。",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那間店陳列的遊戲是……！　",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呵呵♪",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n聖誕節期間也是有好事的嘛。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我預購的遊戲",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎麼還不快點寄到呢。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "{player}一定也預購了吧……",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "或許可以約他一起玩合作模式──",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……唔，",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是{player}",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "跟茜里一樣人緣好、朋友多……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我約他玩遊戲會不會造成他的困擾呢……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唔～",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里覺得不會吧～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇！？",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n妳回來了！？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里不能丟下姊姊一個人嘛。",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "比起這個，",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊居然會主動想要約人，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n嚇了茜里好大一跳呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "明天可能要下雪人了呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有那麼誇張嗎……？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不管怎樣，",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "絕對不能放棄喔！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥一定會很高興的！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不然，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也可以幫忙傳話……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇！",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不行不行！",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我自己會去約他的！！",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯，",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也覺得那麼做比較好♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這可是難得的聖誕節呀。",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊也留下一個幸福的回憶吧！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "幸福的回憶……",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這麼說起來，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "以往的聖誕節，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n好像都沒留下什麼美好的回憶呢。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里會收到很多邀請函，",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而我當然是沒有。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "大家都笑容滿面地期待聖誕節的到來，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只有我一臉陰沉啊～",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以，",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "和大家在一起",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "比自己一個人度過還要難堪……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "聖誕節就是讓我那麼憂鬱的存在。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "自從遇見他以後，認識的人越來越多……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n現在甚至能收到邀請函了。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這毫無疑問，",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n是因為{player}教會了我",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "連結人際關係的樂趣……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然我還沒有自信能夠變得坦率一些……",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但就像{player}經常來見我一樣，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我也想",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一步一步地",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "向他靠近。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳說得對。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是「那孩子」",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "給了我「邁出第一步的勇氣」，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不能白白浪費掉這份好意。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "會努力約{player}的！",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就是這股氣勢，",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "「邁出第一步的勇氣」",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要是知道成為天使的經歷",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "現在也對姊姊很有幫助的話，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n拉菲一定會非常高興的♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……不知道拉菲",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "現在過得好嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她現在",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "或許又在某個地方帶給別人幸福吧。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "搞不好已經成為一名優秀的天使了呢。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "希望還有機會和她見面呢……",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯……",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_031"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！",
        "unit_id": 100611,
        "voice": "vo_adv_5106000_032"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是哥哥耶♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……姊姊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "機會來了……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我還沒做好心理準備……！",
        "unit_id": 102212,
        "voice": "vo_adv_5106000_033"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
