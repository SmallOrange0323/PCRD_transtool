    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了體驗「夏日海邊」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雷姆接著來到──"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "十分熱鬧呢。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_000"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這就是",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "海邊的「夏日祭典」",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "嗎？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "無論在海上",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "或是沙灘……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n光是從這裡就能看到",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "許多活動。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "大家都很開心的樣子呢！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是！",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這場夏日祭典",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "會舉行一段時間對吧？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "如果有昴或姊姊會喜歡的活動，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雷姆想全都先標記起來！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_004"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但是……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那裡到底是？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "只有那個區塊",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_005"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "空蕩蕩的……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n什麼活動都沒有。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "好奇怪。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_006"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "到底怎麼了……？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔唔唔唔……",
        "unit_id": 1,
        "voice": "vo_adv_1321003_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n果然很奇怪對吧……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "太不自然了對吧……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "咦？",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_008"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "怎～麼～辦～～～！！",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_009"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "欸～欸～",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我該怎麼做、",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "怎麼做才好！？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請、",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_010"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請冷靜下來。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "到底怎麼了呢？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "其實呢，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_011"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "本來是打算在這個空間舉辦",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "海邊的時尚競賽啦……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "啊，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我是",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "夏日祭典的主辦人哦。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "結果我卻完全忘了要預訂舞台機材啊。",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_012"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "害得今天連活動都只能臨時宣告泡湯了呢～",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "光聽也被嚇到了對吧？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "啊～我真是笨蛋笨蛋！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "而且這裡",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_013"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "不正是沙灘的正中央嗎？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n要是這裡空蕩蕩的，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "會非常不妙呀～",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "啊～",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "傷腦筋傷腦筋。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_014"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那個，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_015"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "如果可以的話。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "真的嗎？",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_016"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "你們只是路過的人而已耶？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n你們要幫我想",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "替代方案嗎？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "現階段我還沒想到好的方案……",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_017"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但是",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這個城鎮的各位",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "平時總是對我照顧有加。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而且，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_018"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆想邀請重要的人們",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "來參加這個夏日祭典。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n因此，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請讓我一起想想",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "有沒有什麼能做的。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "太～",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_019"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "感～",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "謝～",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "了～！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "突然得要構思活動替代方案的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雷姆和{player}──"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "能讓許多人樂在其中的",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_020"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n海邊活動……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……在海邊賽跑",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_021"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這活動如何呢？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n邊賽跑邊感受到海水的清涼，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "應該會讓人覺得舒暢。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "豈止舒暢，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_022"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "那根本是特訓了！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這位小姐，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳不知道沙灘衝刺的艱辛吧？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "前幾天",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_023"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我巡邏時抱著漂流木跑，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n感覺沒那麼艱辛呀……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳是運動員嗎……",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_024"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那在沙灘挖洞，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_025"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "誰挖的洞深誰就是贏家，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n用這樣的方式一決輸贏呢？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "啊，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "考慮到危險，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "挖好後要再把沙子填回去……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "那是哪裡的拷問刑罰……",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_026"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "比賽划船",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_027"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "到海的邊角──",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "海有",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_028"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "邊角嗎？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……沒有嗎！",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_029"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "……妳喔。",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_030"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "咦，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "該不會",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳不知道海是什麼？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那個，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_031"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不至於到不知道，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n只是不敢說非常瞭解。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "也就是說關於海邊……",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_032"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我是個",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "初學者……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "海邊初學者，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_033"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這我還是第一次聽到。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n妳看那邊那位大哥也插著手在沉思了哦。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "嗯～",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_034"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "束手無策了啊……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "實在想不到什麼好注意。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_035"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "果然",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "只靠雷姆對海的淺薄知識……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……？",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_036"
    },
    {
        "type": "still",
        "still": "132100301"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "啊～沒事沒事，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_037"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳不用這樣低頭哦。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n我原本就沒打算把事情推給你們，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "追根究柢都是我自己的錯嘛？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_038"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我不是那個意思……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n你看，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "腳邊的沙子……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "沙子怎麼啦？",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_039"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "仔細看就會發現，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_040"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這些沙粒",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "非常細膩，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "相當滑順。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這是當然的嘛。",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_041"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n畢竟是沙灘的沙子啊。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "如果是這種性質的沙子……",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_042"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n只要含有水分，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "或許就能像雪一樣固定。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_043"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n不是雪雕，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而是用沙子做成的雕像，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "沙雕！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "以前，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_044"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "羅茲瓦爾大人的宅邸被雪覆蓋時，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n大家一起做過雪雕。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "如果像那時一樣，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_045"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "用沙子製作各種東西，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n再舉辦昴辦過的",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "「競賽」，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n那就算沒舞台，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "應該也能讓來賓開心？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "原來如此……",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_046"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n嗯………………",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "就是這個！",
        "unit_id": 1413
    },
    {
        "type": "background",
        "background": "500680"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雷姆的想法馬上被採用。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n馬上就招募到了參賽者，開始製作沙雕。"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "好厲害！",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_047"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雖然宣布得臨時，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還是有好多人來參加呢。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可是……",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_048"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這樣好嗎？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "連雷姆我們",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "都參加。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "沒事沒事！",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_049"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n這一切都多虧了你們啊。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n你們是招待嘉賓啦。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "盡情去做吧～！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那麼，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_050"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我就順著您的好意……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "嗯？",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_051"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "話說根本已經接近完成了呀。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雷姆妳做的是什麼？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "別害羞讓我看嘛～",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我第一次做沙雕，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_052"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還有很多需要改進的地方……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "好了啦好了啦……",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_053"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "──哇！？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這是怎麼回事……！？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這不是超～高水準的作品嗎！！！！",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_054"
    },
    {
        "type": "dialogue",
        "name": "參加者們",
        "words": "人聲嘈雜……",
        "unit_id": 1,
        "voice": "vo_adv_1321003_055"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這是……",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_056"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "在打西瓜的、",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "青年的雕像……？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "對。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_057"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這是「盡情享受暑假的身影也帥氣無比的昴之雕像」！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這什麼動感十足的樣子……",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_058"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n還有西瓜被砸開的逼真程度……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n這真的是用沙子做成的嗎！？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雷姆，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_059"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "第一名就是妳啦……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "參加者們",
        "words": "這我可贏不了。",
        "unit_id": 1,
        "voice": "vo_adv_1321003_060"
    },
    {
        "type": "dialogue",
        "name": "參加者們",
        "words": "…………！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "大、",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_061"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "大家……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "是啊。",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_062"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "不管是這個令人嘆為觀止的主意，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n或是妳運用沙子的技術，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳哪是初學者，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "已經是海邊專家了！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "大家因為昴的雕像而這麼高興，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_063"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆好感動……！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "好啦～",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_064"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "大家注意！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n請以雷姆的作品為範本，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "創作厲害的沙雕吧～！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "──是說，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_065"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "咦……？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "怎麼了嗎？",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_066"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雷姆做昴的雕像的這個地點，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_067"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n該不會是……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "地點有什麼問題嗎？",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_068"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "啪唰─────"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "呀……！",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_069"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n海浪……！？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "為、",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_070"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "為什麼！？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n明明剛剛水位還離得那麼遠。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n難道",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "海變近了……？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雷姆妳啊，該不會，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_071"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n不知道",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "漲潮嗎！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "漲潮……？",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_072"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "啪唰─────！！"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴、",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_073"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴的雕像……！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雷姆，",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_074"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "海浪這東西，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n會有所漲落，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "水位也會跟著移動喔！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "啊～",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_075"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "沒救了……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這下無計可施了……！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳別看……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "不要看啊～！",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "漲潮……",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_076"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "原來還有這種東西……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "竟然連這麼基本的事都不懂，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n果然雷姆還是海邊初學者……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我要繃緊神經，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_077"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n多加學習關於海的知識才行……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "那麼厲害的作品消失在浪花中了耶……",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_078"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n妳還真是樂觀又謙虛呢……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_079"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我會重做這座昴的雕像。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不過，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "幸好為了以防萬一，我做了許多座。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為我還想讓大家多多欣賞昴的雕像。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "……嗯？",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_080"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳剛剛說什麼？",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_081"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n很多座……？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_082"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n因為要呈現昴夏日的魅力，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n只用一座沙雕完全不夠。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "其他的都在那裡。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_083"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "唔喔！？",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_084"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n昴的雕像，",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "一、二、",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "三、四……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n妳什麼時候做了這麼多！？",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這樣還完全不夠！",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_085"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "從右邊開始，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_086"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "「拼命抓住香蕉船之頑強的昴之雕像」、",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "「享受熱帶果汁之時尚的昴之雕像」、",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n「為姊姊續杯果汁之紳士的昴之雕像」。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還有，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_087"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "「打翻果汁，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n被姊姊埋在沙中之勇猛的昴之雕像」、",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n「在被埋著的狀態下不小心睡著之可愛的昴之雕像」。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還沒完喔。",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_088"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還有──",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雷姆……",
        "unit_id": 1413,
        "voice": "vo_adv_1321003_089"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n妳或許是海邊初學者，但……",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "是認真的呢。",
        "unit_id": 1413
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為雷姆是為了正確傳遞夏日樂趣而來的！",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_090"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n好期待昴看到這些沙雕",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n會說什麼喔……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這也是我的目的之一。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而且，",
        "unit_id": 132112,
        "voice": "vo_adv_1321003_091"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "有昴的沙雕自是不在話下，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n在另一邊",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "也準備了「敬愛的姊姊之雕像」。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請容我一座座為各位介紹吧。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "首先是──",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看到雷姆這麼認真，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n昴他們一定也能盡情享受這個活動。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}如此確信。"
    }
]