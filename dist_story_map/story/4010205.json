    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好巧喔學長，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你在做什麼？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "今天去上英文會話課程了。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "現在剛結束，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果你堅持的話，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我也可以跟你一起回去──",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "──啊！",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "難道說！？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n其實是",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "知道今天是風間琪愛兒的超重要的紀念日，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n所以學長才沒有預約就在這邊埋伏要給我驚喜！？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊……",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是開玩笑的，原來真的是驚喜啊，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好噁。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊沒事！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然有被嚇到一下，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但就忘記這個先謝謝你了！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還有，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可以叫琪愛兒",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「琪愛兒」就好喔？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真虧學長能記得住",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學妹的生日。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒關係啦、沒關係啦。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "反正這之後，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我也打算傳訊息",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n委婉地恐嚇你說出「恭喜」。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過呢學長？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為是琪愛兒才會這樣毫無防備地接受，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對其他人還是不要用這種危險的慶祝方式比較好喔？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一般來說被男生這樣埋伏的話，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "除非是特別喜歡的人──",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "──啊，",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不對，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我不是說這次是那個「特別」的意思。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是這樣，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是因為琪愛兒知道學長不是那種人。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "畢竟學長",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是喜歡替人慶祝的人嘛。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "才不會帶有男女之情那種心思……",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的嗎？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還真是感謝你的用心……",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我知道這間店！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你特地去排隊了嗎！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還有可以叫風間",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「琪愛兒」就好喔！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唔哇～",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好可愛！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我很喜歡",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這間的巧克力！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "為什麼你會知道？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是去問花子學姐嗎？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊？",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等一下等一下，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "為什麼學長會看我直播啊好噁。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n聊衣服美妝的客群是女生的閒聊台，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你絕對沒興趣吧。",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯？",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "難道說這個人……",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其實是認真的愛上我了……",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好的～",
        "unit_id": 110931,
        "voice": "vo_adv_4010205_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "掰切嚕～♪",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "──不對，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦咦！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的只是慶祝完就跑喔那傢伙是怎樣！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等、",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等一下～！",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "至少一起去喝杯茶嘛，",
        "unit_id": 110931
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長～！",
        "unit_id": 110931
    }
]