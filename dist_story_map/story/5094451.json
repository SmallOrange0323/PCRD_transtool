    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "なんなら、",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "うちらが霊界に",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "遊びに行ってもいいし！",
        "unit_id": 117911
