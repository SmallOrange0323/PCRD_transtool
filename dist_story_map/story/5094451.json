        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "大勝利さ～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "でも正直……",
        "unit_id": 117711,
        "voice": "vo_adv_5076451_001"
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "\nわたあめちゃんとお別れしちゃうのは、",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "ちょっぴり寂しいさ～……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "だよねー……",
        "unit_id": 117911,
        "voice": "vo_adv_5076451_002"
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "けど、",
