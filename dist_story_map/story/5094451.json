    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "行き方はわかんないけど、",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "ヒデサイがいれば",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "なんとかなるっしょ！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "ハイ！　",
        "unit_id": 117811,
        "voice": "vo_adv_5076451_003"
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "わたあめちゃんに会いに行くのは",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "大賛成デス！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "それに、",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "霊界も",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "ショーグンが治めるべき土地かもしれまセン。",
