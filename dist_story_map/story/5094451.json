    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "ま、",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "スズナ",
        "words": "いつかまた会えるんじゃん？",
        "unit_id": 117911
