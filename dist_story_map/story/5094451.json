        "name": "カオリ",
        "words": "二人とも、",
        "unit_id": 117711,
        "voice": "vo_adv_5076451_004"
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "ずいぶん大胆だね～！　",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "けど、",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "いい考えかもしれないさ～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "もし遊びに行く時は、",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "カオリ",
        "words": "わたあめちゃんや霊界の王様のために、",
        "unit_id": 117711
