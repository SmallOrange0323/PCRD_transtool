    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "ショーグンの家来として、",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "機会があれば",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "一度",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "行ってみたいデス！",
        "unit_id": 117811
    },
    {
