[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正在散步的{player}，\n看到了被眾多男性窮追不捨的女孩子。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼、",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n他們還在後面……！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是的！不要再跟過來了啦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "男子們",
        "words": "小望！",
        "unit_id": 1,
        "voice": "vo_adv_1029001_001"
    },
    {
        "type": "dialogue",
        "name": "男子們",
        "words": "\n等等我們啊！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……呼……",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n沒、沒地方可逃了……怎麼辦？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀？",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你、你要做什麼？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你說躲在你後面嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "即使你突然那麼說我也……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等、等等！",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你為什麼要拿出武器啊！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……你說要和那些人戰鬥？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行不行！他們都是好人，你不要對他們那麼粗魯！",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我確實是被他們追著跑，但那些人都不是壞人……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然他們都是好人，但所謂的愛情有時也會成為利刃……",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，好難解釋啊～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才、才不是呢！怎麼結論會變成那樣啊？",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你聽好了？這世上不是只有正義與邪惡……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "這麼吵鬧是怎麼回事！？",
        "unit_id": 711,
        "voice": "vo_adv_1029001_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "嗯，那邊的傢伙！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n在這種地方亮出武器，你究竟想做什麼？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "看來你們兩個就是這場騷動的主謀了吧。",
        "unit_id": 711,
        "voice": "vo_adv_1029001_009"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "跟我走！讓我聽聽你們的說詞！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸！ ",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼會變成那樣！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果被王宮騎士抓到的話，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不知道會被拘留多久！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊，真是的！沒辦法了！",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你跟我來！要逃跑了喔！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……呼……呼～～",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n總、總算逃跑成功了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣就可以悠哉地……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "天都黑了啦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只能回家睡覺了……難得的休假都泡湯了……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的……",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天真倒楣！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這全部都是你的錯啦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n都怪你在街上拿出武器！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "早知如此，\n我答應幫粉絲們簽名的話就好了呢。",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？瞧你一臉不可思議的樣子，怎麼了？",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你應該也是想要我的簽名對吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……你好像還是一臉困惑……？",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個，咦……？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n難、難道你不知道我是誰嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，嗯……",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n像這樣面對面應該是第一次。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不是這個意思啦……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看你這麼煩惱，你不知道我是誰對吧？",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊，還有人不認識我啊。",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，抱歉喔！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我也還差得遠呢～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但你明明不知道我是誰，卻還來救我……",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你真是個好人呢！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是望。\n你叫什麼名字呢？",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喔～我記住了！",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛剛我竟然還說今天很倒楣，抱歉喔。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n謝謝你救了我，{player}。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為我的關係，造成了你的困擾……",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想要向你賠罪……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，對了！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你知道音響盤嗎？\n那是一種用魔法將音樂存放在魔石裡的東西。",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是我的音響盤。",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不介意的話，你願意收下嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我呢，姑且算是個偶像喔！",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "白天的那些人是我的粉絲。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，你卻不知道我是誰啊。",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n看來我成為頂尖偶像之路",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還遠著呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可以的話，你也來幫我加油吧！",
        "unit_id": 102911,
        "voice": "vo_adv_1029001_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那麼以後再一起玩吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n今天",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的很謝謝你！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為意想不到的事情，\n{player}認識了偶像。"
    }
]