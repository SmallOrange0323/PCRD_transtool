    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……可惡……",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_000"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_001"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡……！",
        "unit_id": 191611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來我真的太高估你了。",
        "unit_id": 107011,
        "voice": "vo_adv_2107008_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這簡直就像是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在跟小丑說話……",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "501040"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡啊啊啊───！！",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_003"
    },
    {
        "type": "dialogue",
        "name": "紅的",
        "words": "啾！？",
        "unit_id": 191613
    },
    {
        "type": "dialogue",
        "name": "藍",
        "words": "嗶！！",
        "unit_id": 191614
    },
    {
        "type": "dialogue",
        "name": "黃的",
        "words": "咻。",
        "unit_id": 191615
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就說了！",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_004"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n不准躲啦你這黃色的！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……卡里莎，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_005"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n把氣出在寵物身上是不好的，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我之前說過的吧。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "吵死了！",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_006"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我不是也說過",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這些傢伙就算被打被壓扁，也會立刻恢復原狀嗎！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "但是──",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_007"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "贊恩！",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_008"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n別想指使我！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你這樣最讓我不爽了！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "居然把我當小孩子對待！！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "卡里莎，贊恩先生？",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不可以吵架啦～！",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "出現啦，妳這腦子都是用糖漿做的女人！",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_010"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳也打算指使我是嗎，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊啊！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "什麼？",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_011"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n你在說什麼啊？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……他似乎正因為沒能解決變貌大妃",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_012"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "而感到憤怒。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "變貌大妃……",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_013"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嗚……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那個全身粉色的蘿莉老太婆啊啊啊啊！！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那傢伙，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_014"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那傢伙！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n竟然敢一直把人當白痴耍！！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "超讓人不爽，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "超讓人不爽，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "超讓人不爽的……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_015"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不只那傢伙！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "贊恩也是！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "美空也是！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你們心裡一定都在笑我輸得很難看對吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你們說話啊！！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我怎麼會有理由",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_016"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "產生這種想法呢。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯嗯★",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_017"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n卡里莎，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你不是很努力嗎♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "美空說得對，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_018"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n不如說──",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "卡里莎，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_019"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n我對你",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "抱持著敬意。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "咦……！？",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_020"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……少、",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_021"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "少在那裡胡說八道了！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你、",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你說說看你是對",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我的哪些部分抱持著敬意",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊……？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "首先，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_022"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "你非常聰明，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "特別是在戰術方面。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "雖然你說不要把你當作小孩子……",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n但要是真的只把你當小孩子來應對，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "對手應該會嘗到苦頭吧。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……嗚……",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_023"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……其",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_024"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……其他還有什麼？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "還有",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_025"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "你的行動力非常強，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n不管什麼樣的作戰都會果決",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "且毫不猶豫地實行。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n你那為了自身目的、",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "為了願望而前進的身姿，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "甚至讓我感到很耀眼。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "反過來看我，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_026"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我卻──",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "正在迷惘著。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……啊啊？",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_027"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你說迷惘？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "沒錯。",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_028"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n你們應該也知道，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我的「願望」──",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "就是",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_029"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "把自己的缺陷，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n把自己失去的記憶",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "找回來。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我究竟",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_030"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "是什麼人，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n是為了什麼",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "而來到這個世界的？",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "為了釐清這些，我選擇的手段……",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "便是投靠這個公會。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_031"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "但是……",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_032"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n這項行動是否是正確的呢？",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我有時會感到猶豫。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "為了實現自己的願望，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_033"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n把其他人當作是墊腳石，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n這麼做究竟能說是正確的行為嗎……",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我會這麼想。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_034"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n這樣當然沒問題啊～",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "要是一直想些無趣的顧慮，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_035"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n只會很快就",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "輪到自己成為別人的墊腳石而已，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n不管在「這邊」還是「那邊」，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "道理都是一樣的吧。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……說得也是。",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_036"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n這就是所謂的不變之真理吧，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "你果然",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "很聰明。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……嘖！",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_037"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嘖，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嘖！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你就算拍馬屁，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "也不會有任何好處啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "而且，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_038"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n你剛才說",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "被變貌大妃打倒的自己",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "很難看，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n但我並不這麼想。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "七冠中",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_039"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "每一個人都是不可輕忽的對手，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n目前唯一成功捉捕的",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "跳躍王",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "也是一樣──",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "別謙虛了啦，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_040"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n那傢伙不是你抓到的嗎。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "確實",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_041"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "使出了決定性一擊的人是我，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "但是──",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "要是阿澤爾德沒有掌握他的所在地，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_042"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n要是蘭法",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "沒有去對付名叫大吾的公主騎士，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n我甚至無法",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "和跳躍王對峙。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "而且……",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_043"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "要是美空",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "沒有封住那傢伙的權能，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n他應該就已經使用他擅長的空間跳躍，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "逃到場外去了吧。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不會啦，",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_044"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我才辦不到那種事呢～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我那時也說過了，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n那時是因為",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "有贊助者出力才能做到的★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_045"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n「贊助者」是吧……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我記得──",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_046"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "是叫做「厄莉絲」沒錯吧？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "她可以從空無一物的地方變出這個據點，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n還有阻止跳躍王的權能。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就是因為看見了這些荒唐的景象，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_047"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我們才會聽信「要是抓住七冠就實現你們的願望」",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n這種說法的，不過啊……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "該是時候",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_048"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "讓人至少見識一下她的長相了吧。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳到底要什麼時候才肯讓我們見她啊？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "唔～",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_049"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n雖然我是很想正式把她介紹給你們啦……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但現在沒有辦法喔～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊，",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_050"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這可不是因為我很壞心眼喔？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "畢竟厄莉絲大人，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是一個非常貪睡的人嘛★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嘖，",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_051"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n那種貪睡鬼",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "真的值得依靠嗎？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真的沒問題啦～♪",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_052"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說到頭來，正因為她是無法自由行動的人，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我們才會受到委託呀～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "說得對。",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_053"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n為了能得到「厄莉絲」的信賴，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n首先我們也必須盡量",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "多捉捕幾位七冠",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "才行。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼……",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_054"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "算了，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "現在就當作是這麼一回事好了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯★",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_055"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n反正阿澤爾德先生似乎也",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "暫時還需要休養嘛，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我們不慌不忙地採取行動就好♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我也打算",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_056"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "一邊悠～哉地渡個假，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n一邊等待獵物上鉤♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊啊？",
        "unit_id": 191611,
        "voice": "vo_adv_2107008_057"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳這傢伙，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "之前不是才剛去過溫泉，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "現在又要去渡假喔。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳真的有心要做事嗎？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那當然★",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_058"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這樣才符合我的風格呀♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "美空，",
        "unit_id": 191711,
        "voice": "vo_adv_2107008_059"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "妳又設下了",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "什麼陷阱嗎？",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……呵呵♪",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_060"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n關於這點呢～？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "──現在還是",
        "unit_id": 192011,
        "voice": "vo_adv_2107008_061"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "秘",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "密",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "喲★",
        "unit_id": 192011
    }
]