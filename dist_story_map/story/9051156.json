    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很棘手的對手呢～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但多虧如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拿到了很多點心的材料喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趁著還新鮮，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開始料理吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也有雪菲準備好的帳篷，",
        "unit_id": 105812,
        "voice": "vo_adv_9051156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n點心時間的準備已經齊全了呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "糟糕了，",
        "unit_id": 105913,
        "voice": "vo_adv_9051156_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沙丘的底下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有魔物群聚集……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有可能是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才的魔物呼喚了同伴。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎、",
        "unit_id": 105812,
        "voice": "vo_adv_9051156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這樣～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好不容易美妙的時間才剛要開始耶……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……話是這麼說……",
        "unit_id": 105812,
        "voice": "vo_adv_9051156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這數量應該打不過呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是三十六計",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "走為上策了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也贊成逃跑。",
        "unit_id": 106412,
        "voice": "vo_adv_9051156_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個沙丘",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很不好走，馬上就會被追上的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯，",
        "unit_id": 105913,
        "voice": "vo_adv_9051156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且因為正在休息，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "行李也都還沒收好。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐仍熟睡著，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從剛才開始怎麼叫都叫不起來……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不管是搔她癢、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是拉她耳朵",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都完全沒反應。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼嚕呼嚕……",
        "unit_id": 106012,
        "voice": "vo_adv_9051156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "揹著凱留的話",
        "unit_id": 106412,
        "voice": "vo_adv_9051156_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就更逃不掉了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對了！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就讓她繼續這樣裹著花瓣，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n把她從沙丘上滑下去如何？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把凱留小姐",
        "unit_id": 105913,
        "voice": "vo_adv_9051156_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "滑下去，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總之先讓她暫時遠離敵人比較安全對吧？",
        "unit_id": 106412,
        "voice": "vo_adv_9051156_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n幸好是下坡，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以可以像雪橇一樣……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咻──地滑下去！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_9051156_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像雪橇一樣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能向您借這個帳篷的材料嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "當然沒問題……",
        "unit_id": 106412,
        "voice": "vo_adv_9051156_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但可可蘿小姐，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在才開始做東西來不及的……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會花什麼時間的……",
        "unit_id": 105913,
        "voice": "vo_adv_9051156_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把花瓣和莖",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像這樣",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n重新組合的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該就能像雪橇一樣在斜面上滑行。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請坐到在下身後吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔喔～！",
        "unit_id": 105812,
        "voice": "vo_adv_9051156_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這真是好主意！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "行李也能一口氣搬運呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好厲害啊，",
        "unit_id": 106412,
        "voice": "vo_adv_9051156_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這麼一來，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留就能和雪橇綁在一起滑行了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "魔物就快來了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們走吧！",
        "unit_id": 106412
    },
    {
