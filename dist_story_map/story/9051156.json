    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼一來就逃得掉了吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嘴開太大會吃到沙子喔，",
        "unit_id": 106412,
        "voice": "vo_adv_9051156_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n要注意！",
