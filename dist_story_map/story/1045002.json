[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "空花在路上走著走著就遇到了{player}。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花到底應該怎麼做……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n在這種地方相遇",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "真是巧耶。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花看起來心情不好的樣子？",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸！",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "看得出來！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "該不會虐、虐待狂先生，",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還有隱藏的特殊能力吧……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……他、他要是使用這股力量，",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n整個世界不管是誰，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "瞬間都會變成剛誕生的赤裸模樣！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……欸？空花好像很有精神所以你就要回去了？",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請等一下。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "到剛剛為止空花確實都很沒有精神。",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n多虧了虐待狂先生才打起一點精神的。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "該、該不會，",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n你想說要用空花的身體做交換吧……流口水。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生，你、你要去哪裡？",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花說。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花說就是了。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……其實，空、空花",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是以過度操勞自己的身體，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在賺取酬金的。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "簡單來說……",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n就是在那邊的酒吧，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n擔任舞孃……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是空花是新人……",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n而且沒想到",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "舞技比別人落後很多……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸，比別人落後的原因嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對、對自己的舞蹈還沒有自信……",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n再加上……被這麼多人的眼睛盯著看，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花覺得很難為情……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "所、所以，空花想多少做一些努力也好，",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "剛剛正在這裡練習。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸欸！陪、陪空花做嗎！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就在光天化日之下……嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "真、真不愧是虐待狂先生……流口水。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花……這、這種事情，",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n雖然是第一次做，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n但既然虐待狂先生這麼說了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸？",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n你說大概跟空花想的不一樣……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是陪空花做……練習？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀、呀啊！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空空空、空花又，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n異想天開地誤會了……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、這是第二次，",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n被虐待狂先生看到",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這麼丟臉的樣子呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……真不是涉世未深的少女該有的失態。",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花已經嫁不出去了。",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_022"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n因為已經被虐待狂先生玷汙了。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……乾、",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "乾脆，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一鼓作氣，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "把空花弄得更亂七八糟吧！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻、",
        "unit_id": 104511,
        "voice": "vo_adv_1045002_024"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……流口水。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}無意間理解了空花的舞技無法進步的原因。"
    }
]