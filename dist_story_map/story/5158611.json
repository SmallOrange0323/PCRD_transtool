        "voice": "vo_adv_5158611_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該怎麼辦呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要是沒辦法哄他入睡，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "身為聖誕節的惡魔，",
