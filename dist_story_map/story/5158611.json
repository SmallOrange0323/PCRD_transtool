        "voice": "vo_adv_5158611_032"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "既然如此",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n……這種時候試試搖籃曲",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "怎麼樣呢？",
        "unit_id": 132811
    },
