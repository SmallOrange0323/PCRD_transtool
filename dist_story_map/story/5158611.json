    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "請你緊緊握住，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但是要溫柔地握，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 132912,
        "voice": "vo_adv_5158611_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很舒服嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你果然",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也是男孩子呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "既厚實",
        "unit_id": 132912,
        "voice": "vo_adv_5158611_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "又剛強……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n跟我的手指完全不同……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "怎麼樣呢？",
