    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "再把眼睛閉起來一次……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，聖誕節惡魔們有如奇妙夢境般的嘗試，"
