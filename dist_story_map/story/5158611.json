        "voice": "vo_adv_5158611_027"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你不覺得",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們好像在交換體溫一樣嗎？",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n來，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "把眼睛閉起來。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n做深呼吸，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "感受我們吧。",
        "unit_id": 132811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這就是",
        "unit_id": 132811,
        "voice": "vo_adv_5158611_028"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "彼此連結的感覺喔。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n很舒服對吧……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如何呀，",
        "unit_id": 132912,
        "voice": "vo_adv_5158611_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "牽著手",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是不是逐漸放鬆下來了呢？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣子",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有比較能熟睡了嗎？",
        "unit_id": 132912
    },
    {
        "type": "still",
        "still": "515861101"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾、伊緒",
        "words": "咦咦……！？",
