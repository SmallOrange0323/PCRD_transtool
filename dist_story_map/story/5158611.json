        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們身為聖誕節的惡魔，",
