[
    {
        "type": "background",
        "background": "510340"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯？",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "認不出來嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我的聲音，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽起來有沒有印象？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一直以來諭示時，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算只有聲音，應該還是有聽過吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦……",
        "unit_id": 105931,
        "voice": "vo_adv_2012010_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難、",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您就是，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位愛梅斯大人嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯♪　",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一直好想見妳一面呀",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可可蘿～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊真是的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小小一隻超可愛的～☆",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇哇……",
        "unit_id": 105931,
        "voice": "vo_adv_2012010_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那、",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "　愛梅斯大人？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n該說是比想像中的",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還要更為年輕嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "且意外地",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺是位自由奔放之人呢！？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呀哈哈，",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幻想破滅了？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先回到正題。",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n託妳們每個人盡了全力且不放棄的福，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳們才能像這樣暫時潛到凱留的內心……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "潛到她的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "夢境之中。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但撐不了多久唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不僅是現在的我幫不上妳們什麼忙，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且凱留的肉體也到極限了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若再磨磨蹭蹭下去，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她真的會死掉喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為我也想要出份力，所以一直靜待著好時機，",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因此能幫上忙我也感到很高興……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，我也只能讓妳們進到夢中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓某個誰和誰的心靈連接起來而已。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而能將凱留拉回到現實，",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還有帶所有人回到和平的日常中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就只有妳們自己了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們必須得找到凱留，",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並且和她談談。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聊什麼都沒關係。",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管是要聊天氣還是什麼都行。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又或是說哪一家店的東西真的很好吃呀",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之類的也可以。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只要是妳們的聲音，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想一定就有辦法讓她聽見的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算是被那令人髮指的惡意，",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鬱悶或是不愉快……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被種種因素籠罩的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "凱留的內心，只要是妳們一定能夠傳達給她。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們得找到她，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後緊緊抱住她，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並且用愛去包容她。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後告訴她妳們的願望，",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說想要和她一起活下去……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說還想",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再和大家開心地一塊聚在餐桌前。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n若這些話凱留她聽見了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並且願意點頭，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就一定沒問題了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們就一定能夠到達那Happy End的唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在現實中，",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然只靠著祈禱終究什麼都不會改變。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是這裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是只要祈願便能實現的夢之世界。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們的願望",
        "unit_id": 190011,
        "voice": "vo_adv_2012010_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "與羈絆……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一定能夠拯救凱留那不曾受過愛憐又傷痕累累的內心，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "至少我是如此",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "堅信著的。",
        "unit_id": 190011
    }
]