[
    {
        "type": "background",
        "background": "502223"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "臨近蜜桃碰撞淘汰賽。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n若菜在{player}的守候下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n努力接受美冬的嚴格指導，然而──"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那、",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_000"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那個、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "美冬教練？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n被人用那種赤裸的眼神直盯著屁股，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n感、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "感覺好害羞……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對臀部進行各種角度的高效率分析，",
        "unit_id": 108013,
        "voice": "vo_adv_1387001_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n是我身為教練的工作。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我又不是因為若菜的屁股上",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "黏著納豆才一直盯著看的。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就算真的黏到納豆，",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我自己也會發現的！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "話說回來，",
        "unit_id": 108013,
        "voice": "vo_adv_1387001_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還真是讓人神魂顛倒的「蜜桃臀」呢。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n身為臀士",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "的理想動作，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "都已經自然而然地掌握了……",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n難不成平時",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有在進行相當高效率的訓練嗎？　",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那、",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_004"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那個，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "話說教練。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "下午能不能讓我請個假呢？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "其實最近",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "家裡亂成一團……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊她們",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "總是用完東西就隨手亂丟，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我必須要收拾才行。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "善後處理啊。",
        "unit_id": 108013,
        "voice": "vo_adv_1387001_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "原來如此，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "幫人擦屁股也是一種優秀的屁股特訓。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "畢竟我也不知道幫秋乃擦過幾次屁股了……",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好吧。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就去好好擦乾淨吧！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然我覺得應該不會訓練到臀部，不過……",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_006"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "謝、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "謝謝教練。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是我有一個條件。",
        "unit_id": 108013,
        "voice": "vo_adv_1387001_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在妳做家事的期間，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "必須全程穿著泳裝！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "咦咦！？",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_008"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "要穿著泳裝煮飯、洗衣服，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "還要出門買東西嗎……！？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "感覺會感冒……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n是說",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那樣真的沒問題嗎，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "像是法律層面上……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "既然如此，",
        "unit_id": 108013,
        "voice": "vo_adv_1387001_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就讓{player}也跟去吧。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你要好好觀察若菜的屁股，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "揭開其中的祕密！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "騎士先生能一起來的話感覺很安心。",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_010"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但是",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "觀察屁股這件事，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "還、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "還請稍微節制一點……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n因、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "因為我會害羞。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "謝、",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_011"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "謝謝你！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n這樣一來害羞的感覺，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也扯平了！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……算扯平",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗎？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呃、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呃～？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵……",
        "unit_id": 108013,
        "voice": "vo_adv_1387001_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳內心在糾結呢。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "為了克服自身的羞恥心，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n直到妳能將泳裝視為自身皮膚的一部分前，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n都要好好努力喔，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "若菜！　",
        "unit_id": 108013
    },
    {
        "type": "background",
        "background": "501760"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗚嗚……",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_013"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "穿成這樣待在家裡，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "感覺像個變態，好難為情……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n幸好姊姊和布武機不在家……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀哈哈哈♪",
        "unit_id": 1,
        "voice": "vo_adv_1387001_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "笨菜姊～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "午飯時間到了喔～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n熱騰騰的飯菜呢～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要是配菜又只有梅干的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我可是會懲罰妳的喔～♡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_015"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "抱歉嚇到你了！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這是布武機為我製作，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "附帶「家務通知」功能的時鐘。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n時鐘會以她平常的語氣提醒我，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "所以還滿方便的……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……等等，",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_016"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "現在不是說這些的時候……！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我必須趕快去晾衣服，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "否則會乾不了～！",
        "unit_id": 138712
    },
    {
        "type": "background",
        "background": "500540"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "今天要晾的衣服",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_017"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "有這些。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嘿咻。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "畢竟是我們三姊妹的分，",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_018"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "如果三天不洗，很快就會累積這麼多。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然用布武機製作的洗衣機一下就能洗好，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但是晾衣服相當耗費體力……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "有騎士先生幫忙真是太感謝了。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不過，",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_019"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "連我的衣服也交給騎士先生晾真的沒問題嗎？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然我已經先把內衣褲之類的拿走了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "如果是騎士先生的話……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "等等！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我在想什麼啦～！？　",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "怎、",
        "unit_id": 138712,
        "voice": "vo_adv_1387001_020"
    },
    {
        "type": "dialogue",
