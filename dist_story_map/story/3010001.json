[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在公會成員募集的布告欄前，\n站著一名少女。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯─，",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "海報明明都貼這麼久了，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n完全沒人來應徵……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼呢？　",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為限定女孩子嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶像活動雖然很順利……",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但除了單獨活動外，也想嘗試看看團體……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "希望可以快點有人來應徵！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……那個，不好意思。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是為了大家而載歌載舞，並且（與悲傷的情緒）戰鬥的公會！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有沒有女孩子有興趣呢─？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……我開玩笑的……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個─",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇！我嚇了一跳……",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "午安！你找我有事嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "招募能載歌載舞進行戰鬥的成員……",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這張海報是妳貼的嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嗯、嗯嗯。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是我沒錯呀？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我雖然沒有跳舞的經驗，但是我很有興趣。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還能讓我加入妳的公會嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳要加入公會嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "超級歡迎的！我叫望！請多指教！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是千歌。還請妳多多指教。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳平常都是擔任前衛嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的位置不是前衛是Center！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果能再加入一個人的話，應該就很華麗熱鬧了……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "Center？華麗熱鬧？",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是甚麼意思呢……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "這樣的話，也讓我們加入吧！",
        "unit_id": 811,
        "voice": "vo_adv_3010001_013"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "\n我們啊，可是真的很強的咧。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "\n絕對能派上用場的說？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "欸妳們兩個，長得挺可愛的嘛！",
        "unit_id": 911,
        "voice": "vo_adv_3010001_014"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "和我們做好朋友吧嘿嘿。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不好意思。我們目前只招募女孩子呢。",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果你們肯穿上可愛的服裝跳舞的話，那倒是非常歡迎呦？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "我們嗎？比起那個，我們還更想看妳們",
        "unit_id": 811,
        "voice": "vo_adv_3010001_016"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "\n穿上可愛的服裝耶。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "反正妳們找不到公會成員很閒吧？",
        "unit_id": 911,
        "voice": "vo_adv_3010001_017"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "乾脆和我們一起去玩吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "走啦！",
        "unit_id": 911
    },
    {
        "type": "still",
        "still": "104200101"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們想幹什麼！",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n請放手！既然這樣的話我只好……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～～～♪",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "───！"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛剛的歌聲是……！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這孩子，是被剛剛的歌聲呼喚來的嗎……？",
        "unit_id": 102911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "這傢伙是什麼啊！怎麼會突然冒出來！",
        "unit_id": 811,
        "voice": "vo_adv_3010001_020"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "\n不管了妳們給我過來啦──",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "哇啊！！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "你幹嘛腿軟啊──",
        "unit_id": 911,
        "voice": "vo_adv_3010001_021"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "哇啊啊！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……真是的。你們居然敢對一臉厭惡的女孩子硬來，簡直爛透了！",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_022"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "可惡！身體被絲線纏住而無法自由行動……！",
        "unit_id": 911,
        "voice": "vo_adv_3010001_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你們如果不想全員都被包成肉粽的話，",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就立刻在我眼前消失！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "嗚、",
        "unit_id": 811,
        "voice": "vo_adv_3010001_025"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "嗚呀呀呀！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "\n對不起！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝妳。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們已經沒事了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "───♪"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "得救了～……",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是謝謝妳們兩位！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不客氣。我並沒有做什麼了不起的事情。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果沒有阻止那兩人的行動，應該還是會很危險吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我只是做了理所當然的事情而已。",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "像那種人，只用口頭告誡是沒什麼用處的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要用實力讓他們閉嘴！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳呀，看起來相當可靠呢。",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了！有緣千里來相會，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳想不想加入我們的公會呢？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯……公會嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我現在並不隸屬於任何公會，要我加入是可以啦……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓我們找個比較能靜下心閒聊的地方吧！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "詳細狀況到那邊再說！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "──到目前為止，單人偶像能夠進行的活動我大都做過了。",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過以偶像的角度來說，我認為應該還有更多事情是我能夠去挑戰的……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了找到這個答案，",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想要脫離單人狀態，改以團體模式來進行偶像活動。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以拜託兩位了！和我一起成為偶像吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我記得偶像，是透過音樂帶給大家活力的存在對吧……",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這和我聽說的不一樣呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "招募成員的海報上寫著「唱歌、跳舞、戰鬥」呀……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是載歌載舞，並忍受日常的悲傷與苦惱，",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後用我們的笑容，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "把大家的悲傷情緒吹至九霄雲外的戰鬥呦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這種事情，總覺得好像不該稱為戰鬥吧……",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我還以為，這是透過唱歌跳舞，從魔物手中守護人們的公會……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算是偶像，也能透過唱歌跳舞來守護大家的笑容呦？",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當然如果辦得到的話……我也想用歌舞打倒魔物的說。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我想應該沒有人辦得到這種事情吧……",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然以一個公會來說和魔物戰鬥才是正途，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過讓女孩子去進行戰鬥，果然還是很危險吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然都要戰鬥的話，我覺得穿著可愛的服裝去工作",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n應該會比較開心吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對吧，望！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希說的沒錯！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌也是女孩子呀，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如果不停的戰鬥可是會很疲憊的呦？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明就不用自己主動投身危險之中的說。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳不用替我擔心。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我就是為了這個目標才會被授予力量。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "透過歌聲召喚精靈的唱喚術……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳們有聽過嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唱喚術！？　",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我有聽過呢！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那剛剛的事情……！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳真的是唱喚士呢！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好厲害……！",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n辦得到這種事情的人……原來真的存在呀！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的。一直以來我都為了守護人們的和平而歌唱。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_045"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也因為如此，我對於為了其他事情唱歌並不是很感興趣……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原來是這樣呀！？",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看妳穿的服裝，我還以為妳是吟遊詩人呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是吟遊詩人！？",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_047"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我從來沒有想過這種事呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是太可惜了。",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果千歌姐和小望姐在一起的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n光靠外表就能立刻攻陷大部分的男性吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且還得加上剛剛那首歌。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該怎麼說呢，根本是最強了吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算妳說最強，我也沒有什麼實際的感觸。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_049"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n至今為止我都沒怎麼感受過異性投向我的視線。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這怎麼可能！",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千歌姐妳的身材呢，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "從上到下可是80、56、82吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再加上妳的美貌，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n至今應該有很多人靠過來向妳搭訕過才對吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為、為什麼知道我的三圍……！？",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我只要看對方一眼就能知道她的三圍！",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "身體是不會說謊的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要妳們兩個人一起進行偶像活動的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n一定可以吸引到很多人的注意！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒錯！只為了戰鬥而唱歌真是太浪費了！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "歌聲擁有讓人變得更有精神、讓人露出笑容的力量吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要能讓大家露出笑容，不就跟守護和平一樣了？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼說……似乎也沒有錯。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_055"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且要進行守護人們的任務，也需要一些資金吧？",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果光靠戰鬥來賺錢的話，我們的身體可撐不住。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果唱歌跳舞能夠賺到錢的話，我認為就應該要試試。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然妳唱歌好聽到能夠呼喚精靈，",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_057"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n能夠讓許多人欣賞的話應該更好吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希妳也想要多聽一些千歌唱的歌吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是當然的囉。",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且如果能再穿上我製作的衣服，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我就更加歡迎了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "其他人一定也會喜歡千歌的歌。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼這樣……",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_059"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……不過呢，我……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不然這樣好了！我來幫助妳討伐魔物。",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_060"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n相對的妳也來協助我進行偶像活動！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣的話就沒問題了吧？可以吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "拜託妳了……！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要妳肯穿上我做的服裝，",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那我也願意幫忙千歌想做的事情！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_062"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我明白了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果只是在討伐魔物任務的空檔幫點忙，那我同意。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望小姐，請你多多指教。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_063"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n讓我們一起加油吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好、好的。",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_064"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過我的歌聲是為了守護大家的和平而存在的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n請妳絕對不可忘了這一點。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是當然的！放心吧。討伐魔物這方面我也會認真的！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "戰鬥也是偶像的工作呢！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的嗎？總覺得，有點擔心呢……",
        "unit_id": 104211,
        "voice": "vo_adv_3010001_066"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希也要加入我們的公會吧？",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_067"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然都說到這種程度了，妳應該願意加入吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我當然不會反悔囉。如果專注幕後工作也OK的話就讓我也來幫忙吧。",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過呢！我是個裁縫師，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對於服裝可是非常囉嗦的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然要做的話，我就會替妳們準備精心製作的舞台服裝。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太棒了！居然還一起招募到服裝設計師，真是太幸運了！",
        "unit_id": 102911,
        "voice": "vo_adv_3010001_069"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳們兩個人穿上這種衣服那種衣服的樣子，",
        "unit_id": 105411,
        "voice": "vo_adv_3010001_070"
    },
