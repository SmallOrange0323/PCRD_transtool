        "voice": "vo_adv_1144003_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我有一事想詢問您。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n您應該能明白，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "像您這般身分的人，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "現在正在做的事",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n有多麼脫離常識。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "於是，",
