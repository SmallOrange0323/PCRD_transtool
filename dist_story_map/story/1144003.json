    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒事，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "看著這幅光景，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我就不由自主的想到很多事……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……決定舉辦這個派對的時候，",
        "unit_id": 114411,
        "voice": "vo_adv_1144003_042"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我想的是",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n要辦一個我認為最完美、從來沒有體驗過的那種派對。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "認為至今為止參加過的派對既老套又無趣，",
        "unit_id": 114411,
        "voice": "vo_adv_1144003_043"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "將它們全盤否定，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只想讓我心目中的完美派對……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只想讓我自己，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "獲得眾人的認同而已。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，",
        "unit_id": 114411,
        "voice": "vo_adv_1144003_044"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "派對這種東西，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既不是為了自己，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也不是為了誰，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n而是為了讓大家同樂而存在。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我竟然沒有意識到這件事……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總覺得",
