[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔～嗯嗯嗯……？",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦、",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真巧呢～你也外出購物嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也出來買晚飯……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過你看看，豆芽菜竟然要100盧幣耶。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺整體的物價都上漲了呢～雖然這也沒有辦法。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "蘭德索爾是被四面高牆圍起來的城牆都市，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n很難擴張腹地面積。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而城牆裡面幾乎沒有農地或是牧場等",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n生產糧食的基礎建設。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以只能靠城鎮周圍的農地運送糧食進來，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "並且活用位於大陸中央的地理優勢致力於貿易，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才總算能維持居民的生活。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總之，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n城鎮的糧食，絕大多數都得依賴城鎮外部的支援呢。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正因為如此，前幾天蘭德索爾連接外部的主要道路……",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n埃斯特雷拉街道出現大量魔物，就引發了大麻煩。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "貿易商人都害怕得不敢靠近。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "以人體為例，就相當於切斷頸動脈……",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然沒那麼嚴重，不過就像長了血管瘤造成血流阻塞的狀態。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是放著不管，也是會死的。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "由於物資進不來，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就只能販賣現有的庫存，而使物價上漲。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "需求與供給的平衡就潰散了呢，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在回復原先的狀態前，好好撐下去才是上策。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【咲戀育幼院】的孩子們正值成長期，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以我希望盡可能地替他們準備營養的飯菜。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "育幼院的宅院裡，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就連最低限度的生活用品都還沒備齊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不得已，只好出來買東西了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無論如何我都得動腦想辦法解決呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過啊，即使想撿便宜也是得注意一分錢一分貨。",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉唉，受不了，時機實在是太差了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……哦唷。",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，不小心發了牢騷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "繼續抱怨下去也沒有用，得想辦法解決才行。",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你要是發現便宜的店家，就要把情報告訴我哦♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哇呀！？",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你那是怎麼回事？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你好像在發光……？",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔呵呵呵……♪",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉呀，進行了一次愉快的購物！",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像這種商店街，和以大量生產為前提的量販店相比，",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n商品的價格反倒有偏高的傾向……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我原本是這麼想的，不過是我太膚淺了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "蔬果店店長因為興趣而採來的野菜、",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n麵包店通常會扔掉的吐司邊、",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還有工廠破產的清倉物品……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "甚至是平常沒辦法弄到的便宜貨，到處都是♪",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "僅需一枚硬幣！",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只要花500日圓，就能買到兩手都快抱不動的東西♪",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣的購物真是令人開心呢，",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幾乎比考試拿到高分還開心！",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喂～！",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在這種地方相遇真巧呢，你在做什麼～？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼「小」咲戀，你……",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼了嗎？幹嘛突然喊得這麼客氣。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不喜歡這樣，",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你平常不都更直接一點嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "面對青梅竹馬，不要有什麼奇怪的顧慮好嗎？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔嘿？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n哇，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不小心發出怪聲……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼這麼突然，對我這麼溫柔？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你是吃了什麼怪東西嗎，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼時候變得這麼紳士啊？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n總覺得，你的狀態好像和平常不太一樣呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是我的錯覺嗎？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們以前曾經一起玩到渾身是泥巴的吧，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼現在才把我當女孩子來對待？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，正如你所見到的，我正在買東西哦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我平常很忙，通常都交給鈴莓去處理，",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過今天學生會也沒什麼工作。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我得定期來親眼確認行情才行，",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不然請鈴莓去買東西的時候，也會覺得困擾。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是給她的錢不夠就糟糕了對吧？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然在網路上能查出概略的資訊，",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過這種事情，還是得親眼見識才能了解。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "特別是像這種商店街。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n年輕的女高中生，放學後一個人確認市場行情，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你說這樣很奇怪？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還說是不是沒有朋友陪我玩～？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你真沒禮貌欸～！",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我在學校也算是個受歡迎的人耶？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，平常總是被周遭的人包圍，吵吵鬧鬧的，",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我偶爾也會想一個人出來喘口氣的！",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "四處看看商品的價格～",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n和店家殺殺價之類的～？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總覺得做這些事會讓我放鬆哦～♪",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只有我會這樣嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還敢說我，你放學了卻一個人到處閒晃，",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你才是孤單的傢伙呢～",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就陪你玩吧♪",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯嗯。",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n附近的遊樂中心，進了很有趣的遊戲機台嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以你想要去玩是吧～嗯哼？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會是什麼樣的遊戲呢？我有點興趣♪",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在回家時間也還有點早，要不要一起去玩？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸嘿嘿，就像以前一樣……♪",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，但是手上這些東西有點礙事呢……",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "實在是不巧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼辦，該拿去寄物櫃寄放嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哇哇，做什麼？",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你要替我拿東西嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝、謝謝……？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈，今天的你果然有點怪呢。",
        "unit_id": 102832,
        "voice": "vo_adv_1028004_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不要對我這麼溫柔啦～會令人害臊的♪",
        "unit_id": 102832
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……啊啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓我出了一身冷汗。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所謂的青梅竹馬～果然就像是家人一樣的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只不過稍微說一下話，似乎就感受到不協調。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "過去的你和現在的你，是同一個人沒錯。",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過現在的你失去了記憶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也在這個狀態下累積了各種經驗。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和過去的你相比，多少會有一些變化呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正因為如此，為了調和過去以及現在的你，",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我才會像這樣讓你做夢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是要進行各種調整。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n抱歉，不小心自顧自地一直聊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你覺得很莫名其妙對吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然對我個人而言，還有很多想要探索的事情，",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像是為什麼「這邊」的咲戀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n會忘記你是她的青梅竹馬之類……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但現在似乎沒有多餘的時間。",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n狀況仍然像走在一條不穩定的鋼索上呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以呀，這次就先告一段落吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉。",
        "unit_id": 190011,
        "voice": "vo_adv_1028004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次在夢裡再會吧♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}？\n喂～怎麼了嗎？\n",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你好像在發呆……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉。",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還請你替我搬東西……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是因為我讓你做了太多事，所以把你累慘了嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把東西搬到【咲戀育幼院】後，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就在那裡好好休息吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我會請你喝杯茶的，那是理所當然的報酬呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……{player}。\n",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_060"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們最近",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是不是有像這樣一起走在街上？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯嗯～？",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不不，這是第一次對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，單純只是似曾相識的既視感嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，總覺得有點不可思議呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "似乎曾經和你一直、一直……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無數次、無數次地像這樣併肩而行。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "日落時分兩人一起走在回家的路上，",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還一邊閒聊無關緊要的小事……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那明明是不可能的，還真奇怪呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明我才和你相識不久呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028004_064"
    }
]