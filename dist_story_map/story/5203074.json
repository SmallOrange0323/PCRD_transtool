[
    {
        "type": "still",
        "still": "520307201"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "波波爺爺的",
        "unit_id": 9212,
        "voice": "vo_adv_5203074_000"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「克蘿茜的詳細介紹」",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "要開始啦～！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n把老夫解析的新型軀體的詳細資訊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n用大家都能懂的方式",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "仔細地",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "慢～慢地",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "講解給大家聽。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這次要講解的是，",
        "unit_id": 9212,
        "voice": "vo_adv_5203074_001"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "航空軀體裝備，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "它的手臂元件。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n是優先考量速度與敏捷，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "以及射擊時協調性的設計，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n也有考慮到高速巡航時的空氣動力特性。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也因此，",
        "unit_id": 9212,
        "voice": "vo_adv_5203074_002"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "跟之前的手部裝備比起來，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n能夠明顯感受到破壞力降低了呢。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這部分",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "無論如何",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "都會需要衡量取捨，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "很令人煩惱啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我",
        "unit_id": 134511,
        "voice": "vo_adv_5203074_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "很喜歡這個手臂元件。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "因為可以",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "盡情地抱抱大家♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "抱緊～♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這、",
        "unit_id": 134612,
        "voice": "vo_adv_5203074_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是非常剛好的力道……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不會像之前一樣要被攔腰折斷，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不用擔心脊椎肋骨而是被安心感包圍的",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "抱抱……！",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "碧♪",
        "unit_id": 134511,
        "voice": "vo_adv_5203074_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克蘿茜小姐♪",
        "unit_id": 134612,
        "voice": "vo_adv_5203074_006"
    },
    {
        "type": "dialogue",
        "name": "碧、克蘿茜",
        "words": "欸嘿嘿嘿嘿嘿嘿嘿……♪",
        "unit_id": 1,
        "voice": "vo_adv_5203074_007"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯，",
        "unit_id": 9212,
        "voice": "vo_adv_5203074_008"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "手臂元件力量降低後，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n變得能夠細微的控制力道了嗎，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n也會有削弱後更好用的情況啊……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "真是從妳們身上學到了一課。",
        "unit_id": 9212,
        "voice": "vo_adv_5203074_009"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n即使到了這年紀，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也還是有很多需要學習的呢。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n不過，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "感情這麼好的模樣",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "甚是美麗……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "呵呵。",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "end"
    }
]