        "type": "dialogue",
        "name": "真步",
        "words": "而且，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_062"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家竟然還夢到了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生對人家立下了誓言的夢呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_063"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生也做了一樣的夢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還真是有這種不可思議的事情呢～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那、",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_064"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n如果說，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也有像夢裡頭的人家一樣的煩惱的話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊……！",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_065"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您不用跪下來，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n把夢裡發生的事情重現一次也沒關係啦～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_066"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不管那是不是夢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果然王子先生就是王子先生呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那麼，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_067"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "既然收下了王子先生的包裹了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那人家也要重新開始打包行李了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……人家，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_068"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也不能輸給夢裡的那個自己，得再加把勁才行呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "首先，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要先把人家心裡真正想的事，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還有現在想要做的事情，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好好地傳達給父親才行呢……！　",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然對於到底能不能辦到還有點不安……",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_069"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但一定沒問題的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n畢竟人家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可是有願意立下誓言的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生陪伴在人家身邊呢♪　",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "神奇真步魔法靈，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_070"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咕嚕咕嚕靈～……☆",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_071"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這可是少女的祕密唷～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——真步那似乎很開心的聲音。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n直到其他的公會成員都回來了以後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n依舊在公會小屋中迴盪始終不絕於耳。"
    }
]