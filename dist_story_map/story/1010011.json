[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "大約是正午時分，在【哞哞自衛隊】公會小屋裡頭。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在那裡，真步正在打包著行李。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呼，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總之，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n衣服這樣就打包好了～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "剩下的，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是日常用品，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還有把父親寄來的信",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也一塊帶去好了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "父親寫的信嗎……",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到底該怎麼辦呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是王子先生啊～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您來了呀，人家好開心。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是您那打扮，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是在快遞的打工中嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您說快遞上寫的住所在這裡，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但是都沒有回應，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以才進來了嗎……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真對不起呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為正好在打包行李，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以沒聽見呀～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家收到了父親寄來的信，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n上頭寫著「差不多該回來一趟了吧」呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以才想著要回老家一趟唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只是去報告一下近況，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還是會回來蘭德索爾的唷？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家和王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼會分開的嘛～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……不過，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "先前也有說過，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家的老家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有開著一家店呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是為了增廣見聞所以才待在這個城中，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n總有一天，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是得繼承老家的店才行的呢～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總有一天",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗎……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會是什麼時候呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不好意思愣了一下呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生送來的包裹，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就讓人家來收吧～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呀啊……",
        "unit_id": 101011,
        "voice": "vo_adv_1010011_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家想要收下包裹，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以如果能把那個光給弄掉的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就幫大忙了呢……",
        "unit_id": 101011
    },
    {
        "type": "background",
        "background": "510161"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n圖書館中有這本書實在太好了呢♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生要看嗎？",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家很推薦這本書唷～♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算您這麼講，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但因為被說得要回老家報告一下近況，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以總覺得",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是沒辦法專心念書呢……",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而能夠好好療癒人家的，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就只有這本",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家最喜歡的書了……",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然念書也很重要，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是讀了這本書",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是會很療癒的呢～……",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "偷瞄。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "回家以後，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家會乖乖念書的嘛，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以就算只有一下下也行，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "若能放鬆一下就好了呢……",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "偷瞄偷瞄。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我就知道，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n如果是王子先生的話一定會這麼說的唷♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家是",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很喜歡這本書呢～",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n故事是在講公主和王子的戀愛故事唷？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "公主和王子明明深深地相愛著，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但沒想到他們兩人的國家",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "卻是對立的關係呢～",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "儘管如此兩人還是",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "貫徹了他們的愛，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n接著跨越了無數的困難……",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……最後兩人踏上了前往天國的旅途，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n然後在那他們終於能夠共結連理了，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是個這樣的故事唷。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然人家",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實比較喜歡所有人都能夠幸福快樂的故事，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但這故事中，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子殿下和公主殿下立下誓言的場景，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家真的好喜歡啊。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這裡。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n「不論怎麼做，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "兩位的愛戀終將沒有結果」",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "——",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就在神父這麼說之後，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就算如此，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "深深相愛的兩人還是決意",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "互相立下了誓言。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "「就算是",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "死亡要拆散我們倆……」",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "「……我也會和王子您一同。」",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "然後，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子做為他的誓言，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "親吻了",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "公主的手呢～♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對吧～？",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家真的好喜歡這一幕，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以看過了一次又一次了呢。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……他們兩人，",
        "unit_id": 101032,
        "voice": "vo_adv_1010011_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在天國一定能過著幸福快樂的日子吧。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然能永遠和最喜歡的人在一塊，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這種事讓人好嚮往呢♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "永遠不會改變，",
