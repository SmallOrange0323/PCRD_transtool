[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優衣和{player}兩人為了購買新年首賣的福袋"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而前往城鎮，平安買到目標的福袋後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n享受著只有兩人的購物時光。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你會不會餓？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我在想差不多該吃點東西了……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為正逢新年，",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "店家",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "似乎都沒開呢……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "回去之後",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我再做點什麼吃的吧。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "公會小屋有食材嗎……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該只剩下",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "白米了吧。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼辦……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對了。",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我家店裡賣的",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "年菜可能還有剩。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們可以去確認看看嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵。",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就知道。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生一路上幫我提東西，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n真想快點填飽騎士先生的肚子呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……爸爸媽媽，",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "已經",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從神殿回來了嗎……？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "稍微",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等我一下喔。",
        "unit_id": 108811
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我回來了～！",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_006"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1088008_007"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "歡迎回來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "昨天妳真的幫了大忙。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n攤販已經交給新請來的工讀生們顧著了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n妳已經去過新年首賣了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "去過了喔。",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "媽媽，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "年菜",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有剩嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "我有另外做好家裡要吃的份了喔。",
        "unit_id": 1,
        "voice": "vo_adv_1088008_009"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n怎麼了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我打算在外面吃飯，",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但店家都沒有開，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "正感到困擾呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我可以",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "帶一些走嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "啊啊，",
        "unit_id": 1,
        "voice": "vo_adv_1088008_011"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "原來是這樣。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "本來就是家裡要吃的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n別說是一些了，想吃多少都可以帶走。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n盛裝的盒子也是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "那些多出來的都可以用喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝～！",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_012"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "妳看起來很著急呢。",
        "unit_id": 1,
        "voice": "vo_adv_1088008_013"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n是外面有誰在等妳嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊啊～",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是啊！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "哎呀是這樣啊。",
        "unit_id": 1,
        "voice": "vo_adv_1088008_015"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n那要快點裝一裝才行了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n好了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "快一點快一點！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是的～",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不要催我啦～！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我已經很著急了～！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_1088008_017"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "話說回來那孩子，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n是讓誰在外面等啊……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "外面這麼冷",
        "unit_id": 1,
        "voice": "vo_adv_1088008_018"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "明明讓他也進來就好了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n哎呀？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "哎呀哎呀哎呀～！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "久等了～！",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "抱歉，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "挑選騎士先生可能會喜歡的菜",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "花了點時間……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "你呀，",
        "unit_id": 1,
        "voice": "vo_adv_1088008_020"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "叫做騎士先生是嗎……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n重新來跟你打聲招呼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "我們女兒",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "就拜託你了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "爸爸也打個招呼！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "媽！？",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "媽、",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "媽媽！？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n連爸爸也……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是的～！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不要亂說啦～！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "不過～",
        "unit_id": 1,
        "voice": "vo_adv_1088008_022"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "昨天受到了幫助，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n當然得鄭重的答謝對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n而且",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "妳也不用這麼害羞吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對我說什麼都沒關係，",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對騎士先生可不行！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "答謝的事交給我就好，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你們不用在意！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們走吧騎士先生。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你肚子餓了吧？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "話說",
        "unit_id": 1,
        "voice": "vo_adv_1088008_024"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "你和優衣",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "是在哪裡認識的？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！",
        "unit_id": 108811,
        "voice": "vo_adv_1088008_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不要認真回答啦～！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "媽媽他們",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一定只是在捉弄我們而已！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好了，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們走吧？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "來這裡！",
        "unit_id": 108811
    },
