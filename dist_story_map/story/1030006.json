    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍、將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "糟糕了！不對，我說錯了，到底在說什麼呢！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我是要說城鎮裡發生了很厲害的事是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我在那裡拿了傳單回來。",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍請看一下這上面所寫的。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那名字也很！登登登登登！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "竟然叫「H（祕技）-1 大賽」是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "獎金高達1000萬盧幣！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也是讓大家",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n展現平日所鍛鍊密技的大大大活動是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這次一定也有很多真正的忍者會來是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "搞不好會成為我們統一天下的夥伴喔！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們一起去看吧～",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "吶、吶、拜託啦～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的草鞋……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n是妮諾放入懷裡，幫你暖好鞋的喔？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太棒了！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n真不愧是將軍是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n將軍",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太偉大了是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是令人期待是也～",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵呵呵……",
        "unit_id": 103011
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼，各位先生女士！",
        "unit_id": 311,
        "voice": "vo_adv_1030006_008"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\nH－１大賽開始囉～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "到底能看到哪些厲害的祕技呢～？",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我現在可是非常興奮、心跳加速，心裡狂打鼓是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "有請1號參賽者！",
        "unit_id": 311,
        "voice": "vo_adv_1030006_010"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "參賽號碼1號。",
        "unit_id": 1411,
        "voice": "vo_adv_1030006_011"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n我的祕技是……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "用肚臍煮開水。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "什、什麼────！？",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_012"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "啊、好燙！好燙！好燙燙燙！",
        "unit_id": 1411,
        "voice": "vo_adv_1030006_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是怎麼一回事！！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在肚子上放茶壺，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n然後在一旁用噴槍煮茶壺是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那一定很熱……一定很痛苦……",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是他竟然忍得住……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "只不過是為了要用肚臍燒開水而已……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正可謂專業是也……",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_016"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "接下來，有請2號參賽者！",
        "unit_id": 311,
        "voice": "vo_adv_1030006_017"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "我的祕技！",
        "unit_id": 911,
        "voice": "vo_adv_1030006_018"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "\n是能自由自在地操控空氣！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "什、什、什麼────！？",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n真是令人不敢相信是也────！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，這位能以秘技操控空氣的人，",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n如果變成同伴的話，應該可以提升我們不少戰力喔！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "那麼，我要開始了……為了能聽到空氣的聲音",
        "unit_id": 911,
        "voice": "vo_adv_1030006_021"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "\n請大家豎起耳朵好好聽清楚囉……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "…………咕嚕。",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_022"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "………………噗嘶。",
        "unit_id": 911,
        "voice": "vo_adv_1030006_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "…………嗯！！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n確實有聽到風的聲音是也！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "啊，沒錯！我說的能夠操控空氣……",
        "unit_id": 911,
        "voice": "vo_adv_1030006_025"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "\n指的就是放屁！我呢，能自由自在地於任何時間點，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "\n放出指定音色的屁喔！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "驚嘆不已、情非得已、死而後已是也！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_026"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "那麼，我就在此演奏一曲……這首歌曲的主題是，",
        "unit_id": 911,
        "voice": "vo_adv_1030006_027"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "\n思念留在家鄉裡的戀人。敬請聆聽……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "\n「以放屁演奏的小夜曲」……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "噗、噗嘶、噗噗噗嗚。（A旋律）噗噗、噗噗嗚。（B旋律）",
        "unit_id": 911,
        "voice": "vo_adv_1030006_028"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "噗逼噗噗噗噗噗噗逼！（副歌）",
        "unit_id": 911,
        "voice": "vo_adv_1030006_029"
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "\n噗噗逼噗噗嗚噗噗噗咕噗（非常帶動氣氛的副歌）",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "２號",
        "words": "\n……窣嗚嗚嗚嗚嗚嗚……（連環屁獨唱）",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "才不是呢，將軍……這個很厲害……",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_030"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是很美妙的旋律……音色……我很感動呢……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我想要給他個紅包呢……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_031"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我們有來這裡真是太好了♪",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "老天保佑、老天保佑 ♪",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼，接下來我們於現場募集參加祕技挑戰的人喔！",
        "unit_id": 311,
        "voice": "vo_adv_1030006_032"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n對自己的祕技有自信的人請上舞台來！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_033"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有！有！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n有〜〜〜〜！我也想參加展現祕技是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼，那位小姐請上舞台來！",
        "unit_id": 311,
        "voice": "vo_adv_1030006_034"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍、將軍！為了要使出祕技，",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我有一件事想拜託你幫忙是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個是沒有幫手就沒辦法使出的秘術，",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_036"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以請將軍跟我一起來！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾拉著{player}的手，登上了舞台。"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼，台上這位小姐",
        "unit_id": 311,
        "voice": "vo_adv_1030006_037"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n到底會讓我們看到怎樣的祕技呢！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我乃臨時報名參加的妮諾是也。",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_038"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我所要展現的是忍法・千手觀音之術是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈～……咻啪啪！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_039"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "喔喔，妮諾的手竟然……",
        "unit_id": 311,
        "voice": "vo_adv_1030006_040"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n變成四隻了────！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "本以為是這樣，但其實只是在後面的人",
        "unit_id": 311,
        "voice": "vo_adv_1030006_041"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n把手伸到不同方向去而已啊────！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵……要嚇一跳還太早囉。",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_042"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "再來……我扭扭扭扭！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "嚇、嚇一跳什麼的……這次只是將兩隻手",
        "unit_id": 1011,
        "voice": "vo_adv_1030006_043"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "\n像章魚一樣扭動而已啊……？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "不不，才不是！",
        "unit_id": 511,
        "voice": "vo_adv_1030006_044"
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "這真是太棒了……竟然讓我們看到如此厲害的東西……",
        "unit_id": 511,
        "voice": "vo_adv_1030006_045"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "到、到底是怎麼一回事啊！感覺很懂的大叔！",
        "unit_id": 1111,
        "voice": "vo_adv_1030006_046"
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "施主們看不到嗎……無數的手相互交纏……",
        "unit_id": 511,
        "voice": "vo_adv_1030006_047"
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "\n那正是千手觀音！東國的神秘！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "\n兼具母性、官能性與耽美……可謂是美的象徵……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "老朽我看到了啊……老朽故鄉的光景……",
        "unit_id": 511,
        "voice": "vo_adv_1030006_048"
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "\n煲飯的香味還有……母親的膝枕……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "自大的客人",
        "words": "媽、媽媽────！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "嗚喔喔喔喔喔──！",
        "unit_id": 1111,
        "voice": "vo_adv_1030006_049"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "\n聽感覺很懂的大叔這麼說，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "\n就覺得好像真的看到很厲害的東西了───！！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "謝謝大家！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_050"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "謝謝你們───────！！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n妮諾的心情也非常暢快是也～！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "接下來呢……希望在那裡的觀眾也能一起參加！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_051"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍法・熱熱吃關東煮之術是也────！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n請跟我一起把剛剛買的這個關東煮一口氣吃下去是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "喔喔，就交給我吧！……嗯、",
        "unit_id": 1011,
        "voice": "vo_adv_1030006_052"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "好燙！好燙！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "\n蒟蒻好燙啊！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好燙、好燙、好燙！油炸豆腐噴出一堆熱湯，",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_053"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n很危險！湯很危險是也───！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "關東煮湯……噗滋─────！！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "觀眾全體",
        "words": "啊哈哈哈哈！（咚）",
        "unit_id": 1,
        "voice": "vo_adv_1030006_054"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030006_055"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們獲得了許多要一起統一天下的夥伴是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……欸，咦？將軍去哪裡了呢？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "要是讓這裡的人們變成夥伴，那就別想要統一天下了……\n{player}一邊這麼想，一邊先逃離了會場。"
    }
