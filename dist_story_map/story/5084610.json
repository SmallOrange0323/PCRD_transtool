[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔，",
        "unit_id": 100911,
        "voice": "vo_adv_5084610_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特那麼優秀的男人竟被困在沉睡的深淵……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這是「機關」幹的好事？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還是有別的原因？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如果吉格魯特依然沒有醒來的話，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……不，",
        "unit_id": 100911,
        "voice": "vo_adv_5084610_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我怎麼會不相信呢！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n那閃光的吉格魯特",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不會在這種地方迎來終結的吧？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "而且，",
        "unit_id": 100911,
        "voice": "vo_adv_5084610_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就算與你的緣分在此處斷絕了，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n靈魂之間已有羈絆相繫的我們",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有著必定會再次相逢的命運。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我很期待將至的再會之日哦！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……話、",
        "unit_id": 100911,
        "voice": "vo_adv_5084610_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "話雖如此，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就算你現在就醒來，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也沒有問題哦？",
        "unit_id": 100911
    }
]