    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "先來",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "整理一下吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "哦？",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_001"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n這東西沒有見過。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n是追加製作的嗎？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "綜合莓果蛋糕……",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_002"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "對世界觀而言",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "還真是細緻的商品名稱啊。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "道具的效果是……",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_003"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "提升好感度？",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_004"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "好感度是……？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "直接問似乎會比較快。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "似似花，",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_005"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我想問妳這個道具，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "好感度",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "到底是什麼？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是好感度。",
        "unit_id": 107031,
        "voice": "vo_adv_5201078_006"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "如果這是考試",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_007"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我可要算妳答錯喔。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "好感度是什麼？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n目前",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "應該沒有準備這種數值才對……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要蛋糕好吃，",
        "unit_id": 107031,
        "voice": "vo_adv_5201078_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好感度就會提升。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "原來如此。",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_009"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "妳沒打算讓我理解是吧？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大量裝飾的數種莓果酸味，",
        "unit_id": 107031,
        "voice": "vo_adv_5201078_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與香甜滑順的鮮奶油，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n入口即化的滋味",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "均勻地在口中混合，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "滲透糖分不足的",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n大腦和身體，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好感度",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "勢必會就此上升。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……這是要我怎麼處理……",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_011"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "總之……",
        "unit_id": 107331,
        "voice": "vo_adv_5201078_012"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就先製作出來吧……",
        "unit_id": 107331
    }
