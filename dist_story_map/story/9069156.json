    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "光是要趕走",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就很費勁了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……哼。",
        "unit_id": 104412,
        "voice": "vo_adv_9069156_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但妾身已",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看透牠的弱點。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "下次相會時，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就會讓牠領教何謂真正的力量。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對了，",
        "unit_id": 105311,
        "voice": "vo_adv_9069156_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n妳",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是叫亞里莎……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n剛才的戰鬥，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感謝",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳出手助陣。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也向妳道謝吧。",
        "unit_id": 104412,
        "voice": "vo_adv_9069156_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳似乎保護了",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "迷路的班比啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這傢伙，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是讓妾身操心……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就～說～了──",
        "unit_id": 122311,
        "voice": "vo_adv_9069156_004"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比沒有迷路～！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n不知道擅自跑哪去的",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是伊莉亞才對吧──？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n亞里莎還陪班比一起找妳喔？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊、",
        "unit_id": 106311,
        "voice": "vo_adv_9069156_005"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊哈哈……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "班比跟伊莉亞小姐",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "能順利會合真是太好了。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "其實",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我也是為了找某個人，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "才來到吉歐‧格黑納的……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦，",
        "unit_id": 104412,
        "voice": "vo_adv_9069156_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳也是嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還真是奇妙的巧合呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n竟然所有人",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都在找人。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "莫妮卡，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳也是吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊，",
        "unit_id": 105311,
        "voice": "vo_adv_9069156_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也是跟夥伴走散了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雪跟空花那些傢伙，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "究竟跑哪去啦。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為是那兩人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是很想認為她們沒事……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟咱們連現在所在的地方",
        "unit_id": 104412,
        "voice": "vo_adv_9069156_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是吉歐‧格黑納的哪一帶都不知道啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是在找迷路的人，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還是成了迷路的人呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在魔物橫行的這個狀況下單獨行動是很危險的。",
        "unit_id": 105311,
        "voice": "vo_adv_9069156_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我們",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "現在應該互相協助吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "各位，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "意下如何？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "畢竟這一帶",
        "unit_id": 106311,
        "voice": "vo_adv_9069156_010"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "好像很危險……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "要是大家願意一起行動，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "會很讓人安心！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比也贊成！",
        "unit_id": 122311,
        "voice": "vo_adv_9069156_011"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "畢竟大家在一起也很開心！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412,
        "voice": "vo_adv_9069156_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身同意。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓妾身",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "順道親自確認，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這個世界值不值得征服吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼首先，",
        "unit_id": 105311,
        "voice": "vo_adv_9069156_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來找返回居住區的路吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要是妳們對周圍的風景跟地形",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有什麼印象，還請告訴我。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，",
        "unit_id": 105311,
        "voice": "vo_adv_9069156_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個世界的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "大自然似乎也具有危險性。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n為了能沿著正確的道路前進，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們必須謹慎……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嗯……",
        "unit_id": 122311,
        "voice": "vo_adv_9069156_015"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "有印象的風景……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "啊！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "那棵很～高的樹！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比感覺剛剛有見過！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "走吧！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這邊這邊！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂，",
        "unit_id": 104412,
        "voice": "vo_adv_9069156_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "班比！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳要去哪！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n等等！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳又想迷路了嗎！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "伊莉亞小姐！？",
        "unit_id": 106311,
        "voice": "vo_adv_9069156_017"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "班比妳也等等──！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "話才剛講完，竟然所有人都跑掉了……",
        "unit_id": 105311,
        "voice": "vo_adv_9069156_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我就說要謹慎行動了吧──！！",
        "unit_id": 105311
    }
]