    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難道，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個對島上的貓咪來說是錢嗎喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n得到好東西了喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有這個機器的話，",
        "unit_id": 107911,
        "voice": "vo_adv_5005002_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n除了可以受到貓咪歡迎……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也能夠變成有錢人……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一石二鳥……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這座島也太棒了喵──────！！！",
        "unit_id": 107911,
        "voice": "vo_adv_5005002_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我才沒有變得怪怪的！",
        "unit_id": 107911,
        "voice": "vo_adv_5005002_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為世界如此寬闊，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在某個地方有著\n「貓咪喜愛的全自動．鯛魚燒機器」也是應該的喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這裡對我來說是很棒的島喵～♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要冷靜下來思考看看的是你啦！",
        "unit_id": 108011,
        "voice": "vo_adv_5005002_040"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n一折商品可以再打一折哦！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n你應該能明白這是多棒的事吧！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這裡正是，",
        "unit_id": 108011,
        "voice": "vo_adv_5005002_041"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "夢之島啊！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯嗯！",
        "unit_id": 107911,
        "voice": "vo_adv_5005002_042"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n馬上來建立貓的王國喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "很不錯呢！",
        "unit_id": 108011,
        "voice": "vo_adv_5005002_043"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "來建立我們理想的王國吧！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n對所有人來說都很和平、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "很富足、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且能有效率地生活的理想王國……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "夢想愈來愈大了喵～！",
        "unit_id": 107911,
        "voice": "vo_adv_5005002_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "之後再說啦喵！",
        "unit_id": 107911,
        "voice": "vo_adv_5005002_045"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在可沒這種時間喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不，",
        "unit_id": 108011,
        "voice": "vo_adv_5005002_046"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "現在比起做這種沒效率的事情，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還不如一起來思考在這裡生活的方法吧！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒問題！",
        "unit_id": 107911,
        "voice": "vo_adv_5005002_047"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果在這裡優雅悠哉地生活，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n總有一天會有人來救我們的喵～♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}只能默默守護著\n內心完全被理想情境給佔據的珠希和美冬。"
    }
]