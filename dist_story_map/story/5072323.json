[
    {
        "type": "dialogue",
        "name": "望",
        "words": "就差最後一哩路了！",
        "unit_id": 117211,
        "voice": "vo_adv_5072323_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n演唱會也快接近尾聲，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們就在這裡緊緊抓住粉絲們的心吧！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希，",
        "unit_id": 117311,
        "voice": "vo_adv_5072323_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳還動得了嗎？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳是在問誰呀，千歌！",
        "unit_id": 117411,
        "voice": "vo_adv_5072323_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "與平時的練習量相比，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種程度只是小菜一碟！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "無論是千歌還是紡希，",
        "unit_id": 117211,
        "voice": "vo_adv_5072323_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都很耀眼動人呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說不定比我還……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是可靠的夥伴……♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以我一定也會",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "變得更加耀眼。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多虧有妳們，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定可以……！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌、",
        "unit_id": 117211,
        "voice": "vo_adv_5072323_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n再多用腹部來發聲！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "舞步要輕盈，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "臉上要帶著一百分的笑容！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "用我們三人的耀眼光芒，",
        "unit_id": 117211,
        "voice": "vo_adv_5072323_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來炒熱這舞台的氣氛吧♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "卯足全力歌唱！",
        "unit_id": 117311,
        "voice": "vo_adv_5072323_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "卯足全力跳舞！",
        "unit_id": 117411,
        "voice": "vo_adv_5072323_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "完成一場最棒的夏日演唱會！",
        "unit_id": 117211,
        "voice": "vo_adv_5072323_008"
    },
    {
