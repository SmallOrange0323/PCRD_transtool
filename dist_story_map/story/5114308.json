        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "莫妮卡，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓對方見識一下生意人的骨氣喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是軍人！",
        "unit_id": 125211,
        "voice": "vo_adv_5114308_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也是個生意人！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了能",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "提供客人美味的咖啡與幸福……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就要以全力以赴的態度面對對手喵！",
        "unit_id": 125111,
        "voice": "vo_adv_5114308_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好，",
        "unit_id": 125211,
        "voice": "vo_adv_5114308_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "放馬過來！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這是咖啡廳",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「Naschkatze」的",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "總體戰！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
