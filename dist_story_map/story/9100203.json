    {
        "type": "background",
        "background": "501790"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "唔……！",
        "unit_id": 136013,
        "voice": "vo_adv_9100203_001"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──為了奪回雪菲被搶走的靈魂，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}等人與六凶‧魔蜘蛛阿剌克涅展開對決。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "他們躲過如雨水般從空中灑落的傀儡絲線，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n擊退【蠻賊三姊妹】和芙蕾雅，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n終於給予阿剌克涅女士會心一擊──"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼、",
        "unit_id": 105811,
        "voice": "vo_adv_9100203_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這次真的",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把她逼入絕境了……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請把雪菲小姐",
        "unit_id": 105911,
        "voice": "vo_adv_9100203_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還給我們！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "……別得意忘形了，",
        "unit_id": 136013,
        "voice": "vo_adv_9100203_004"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "暴食公主和你們。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n吾已經說了，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾從一開始就沒把你們當作對手。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼！",
        "unit_id": 106011,
        "voice": "vo_adv_9100203_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別再嘴硬了……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "從衰老的鳳凰那裡奪來的權能。",
        "unit_id": 136013,
        "voice": "vo_adv_9100203_006"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n要將其消化比想像中還耗費功夫──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "……不過，",
        "unit_id": 136013,
        "voice": "vo_adv_9100203_007"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n因為跟你們玩耍的關係，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "讓吾消化了不少。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "果然還是",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "得偶爾動動身體才行呢……！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……！",
        "unit_id": 125811,
        "voice": "vo_adv_9100203_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "阿剌克涅的身體",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "正溢出驚人的魔力和熱度……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好、",
        "unit_id": 106011,
        "voice": "vo_adv_9100203_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好熱！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟剛剛完全無法比──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "很熱的。",
        "unit_id": 126111,
        "voice": "vo_adv_9100203_010"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n要來了。",
        "unit_id": 126111
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥、",
        "unit_id": 126011,
        "voice": "vo_adv_9100203_011"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "各位！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n請到我的身後！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n可可蘿小姐，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "麻煩妳支援！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是！",
        "unit_id": 105911,
        "voice": "vo_adv_9100203_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n風之精靈，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請給我等守護的加持……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "侵毀吾之居所的罪，",
        "unit_id": 136013,
        "voice": "vo_adv_9100203_013"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "恣意踏在吾渴求不止之世界的罪！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n還有無數的無禮發言，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "為此化作焦炭懺悔贖罪吧！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n就在你們無比希望拯救的",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "這個丫頭面前！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "──唔！！！",
        "unit_id": 1,
        "voice": "vo_adv_9100203_014"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "──呵哈哈哈哈……！",
        "unit_id": 136013,
        "voice": "vo_adv_9100203_015"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n這種程度正好暖身……！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "傳令！",
        "unit_id": 136013,
        "voice": "vo_adv_9100203_016"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n還活著的話就把門打開！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的芙蕾雅",
        "words": "「……了解了，",
        "unit_id": 193711,
        "voice": "vo_adv_9100203_017"
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的芙蕾雅",
        "words": "女士。」",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那、",
        "unit_id": 125811,
        "voice": "vo_adv_9100203_018"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個魔法陣是……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "空間跳躍。",
