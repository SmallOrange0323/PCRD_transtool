        "voice": "vo_adv_9100203_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳、",
        "unit_id": 105811,
        "voice": "vo_adv_9100203_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳是想逃跑嗎……！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "說什麼蠢話！",
        "unit_id": 136013,
        "voice": "vo_adv_9100203_021"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n對吾來說，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "真正的戰鬥現在才開始呢……！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊！",
        "unit_id": 105911,
        "voice": "vo_adv_9100203_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雪菲小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被帶走了……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只能追上去了！",
        "unit_id": 105811,
        "voice": "vo_adv_9100203_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留、普蕾西亞，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能阻止那個魔法陣",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "消失嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留、普蕾西亞",
        "words": "「好！」\n「嗯。」",
        "unit_id": 1,
        "voice": "vo_adv_9100203_024"
    },
    {
        "type": "still",
        "still": "900660801"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "「小雪菲！」\n「雪菲小姐！」\n「雪菲！」",
        "unit_id": 1,
        "voice": "vo_adv_9100203_025"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──皇女……！！",
        "unit_id": 129613,
        "voice": "vo_adv_9100203_026"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "哦……",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_027"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n烏合之眾一個個聚集起來，",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "追在吾身後啊？",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n明明應該深刻明白力量上的差距，",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "真是愚蠢啊。",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……！？",
        "unit_id": 126011,
        "voice": "vo_adv_9100203_028"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "阿剌克涅的頭",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "變成女人了……！？",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這個妖魔人的姿態",
