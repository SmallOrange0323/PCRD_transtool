        "voice": "vo_adv_9100203_034"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "比剛剛",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還要快上很多──",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是很靈活！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n沒有辦法躲掉……！",
        "unit_id": 126011
    },
