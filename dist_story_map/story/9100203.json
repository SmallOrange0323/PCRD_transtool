        "name": "可可蘿",
        "words": "但、",
        "unit_id": 105911,
        "voice": "vo_adv_9100203_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們可不能輸……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "──這是吾無法理解的感情。",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_032"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n但你們就對這個龍丫頭",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "這麼念念不忘嗎？",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "不過──",
        "unit_id": 136014
    },
