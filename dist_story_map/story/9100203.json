    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "身、",
        "unit_id": 125811,
        "voice": "vo_adv_9100203_037"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "身體……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "又……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "哈哈──",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_038"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "呵哈哈哈哈！",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n啊啊，",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "愉悅。",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n感覺實在太愉悅了──",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾已經多久",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "沒有覺得如此神清氣爽了！",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "鳳凰的權能已為吾所有！",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_039"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n過去一直",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "妨礙吾的唯一阻礙──",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "鐵皇女也消失了！",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "接下來就將剩餘的六凶盡數吞噬。",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_040"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n奪去所有",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "不為吾所有的諸種光輝。",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n打破這座名為吉歐‧格黑納的狹窄牢獄！",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "沒錯──",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_041"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n吾要破壞掉",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "阻隔在世界與世界之間的「牆壁」！",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……這、",
        "unit_id": 105811,
        "voice": "vo_adv_9100203_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個人……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然有這樣的企圖……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "──哼。",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_043"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n即便知曉了，",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "於你們也毫無意義。",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n畢竟被吾的絲線所束縛的你們，",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "就如小蟲子一般。",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "好了──",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_044"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "這次。",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n你們就在吾的掌心裡，",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "互相奪取性命吧！",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n暴食公主",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "與其夥伴啊……！",
        "unit_id": 136014
    }
]