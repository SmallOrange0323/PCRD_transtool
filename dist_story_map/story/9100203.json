        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "如今失去了鐵皇女的保護。",
        "unit_id": 136014,
        "voice": "vo_adv_9100203_035"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n你們沒有方法",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "可以抵禦更加強化過的傀儡絲線。",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n",
        "unit_id": 136014
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "如此一來──",
