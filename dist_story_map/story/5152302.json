[
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "莉雅，",
        "unit_id": 2612,
        "voice": "vo_adv_5152302_000"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "別離開我的身邊喔。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n要是掉下去可就不好了。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯。",
        "unit_id": 131911,
        "voice": "vo_adv_5152302_001"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "謝謝你，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "帕克。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "下面是海吧？",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "掉下去應該也還好才對。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "把巴魯斯推下去確認看看好了。",
        "unit_id": 109812,
        "voice": "vo_adv_5152302_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這麼說來，",
        "unit_id": 132111,
        "voice": "vo_adv_5152302_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴曾經說過。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n有種從高處掉落水面的遊戲。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "據說",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "要在掉落的同時一邊旋轉，",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "競爭藝術得分之類的。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……那個是遊戲嗎？",
        "unit_id": 109812,
        "voice": "vo_adv_5152302_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "果然還是把巴魯斯推下去讓他表演看看好了。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "如果是昴，",
        "unit_id": 132111,
        "voice": "vo_adv_5152302_005"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n一定能展現出吸引住海灘所有目光的掉落給我們看的。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……也是為了看他的表演，",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我們就來把白島鯨打倒吧。",
        "unit_id": 132111
    }
]