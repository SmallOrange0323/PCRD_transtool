[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "除了逃避社會服務活動，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【蠻賊三姊妹】還被問罪假釋期間的盜賊活動。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}前來面訪倭，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她一人扛起罪名並因此入獄。"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──噗哈。",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊啊？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這是什麼呀？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "咖哩果汁？",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_001"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "誰叫你帶這種東西來探監的。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我不是跟你說過好幾次，要你帶葡萄酒來的嘛！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……嘖。",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_002"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "每天晚上都來，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我不知道你是剛打完工還是怎樣，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "一下帶來果菜汁，一下換燉菜，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "還有藥材冰沙……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你以為你是若菜嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…………哼。",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_003"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "誰叫她們老是被我牽著走，",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_004"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我說這次一定沒問題，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這是賭上性命的關鍵一戰，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "結果變成這～種下場。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那兩個傢伙",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_005"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "也不是小鬼了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n事已至此，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n她們也有她們的打算吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哼～",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "誰知道呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我們一直以來都",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_007"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n隨心所欲地過日子。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "會有什麼下場，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "也都是理所當然。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "為什麼你要一臉窩囊的樣子啊？",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_008"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子你也只是",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "被捲進來的人質吧？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你應該恨我才對，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n沒道理這樣老實地",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來見我啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你要誤解也給我差不多點。",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_010"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n大蜘蛛和鱷魚男的時候都一樣，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n因為我看他們不爽，才會賞他們一刀的。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "好了，",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_011"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "快回去快回去！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n已經不需要人質這角色了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你快滾吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啥～？",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_012"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你真的一直都是個蠢蛋耶。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……怎麼可能寂寞。",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_013"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你以為我是誰啊？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…………好啦，",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_014"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "時間差不多了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "離牆壁遠一點！",
        "unit_id": 130012
    },
    {
        "type": "background",
        "background": "500342"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "────！！"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "呀哈哈～ｗ",
        "unit_id": 130212,
        "voice": "vo_adv_5156007_015"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n明明是監獄的牆壁，",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "居然這麼好搞定～♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "破、",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_016"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "破壞得這麼明目張膽……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "布武機，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我不是說稍微挖個洞就好嗎～！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真是的，",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_017"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "誰叫妳們搭「這個」來的呀。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不是要妳們別引人注意了嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "因為～",
        "unit_id": 130212,
        "voice": "vo_adv_5156007_018"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n我想讓大家看",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "新～的小鯊鯊號嘛～♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "……嗯，",
        "unit_id": 130212,
        "voice": "vo_adv_5156007_019"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "咦？",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "這不是雜碎哥哥嗎。",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "呀～",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "好久不見～♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n你越來越雜碎了耶～ｗｗ",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "哇啊，{player}先生，",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_020"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好久不見！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n之前承蒙你照顧。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你們幾個，",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_021"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "可沒時間打招呼喔。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "在警衛來之前快上車。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我們要離開這裡了！",
        "unit_id": 130012
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──"
    },
    {
        "type": "background",
        "background": "501760"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "到這裡就比較安心了",
        "unit_id": 130012,
        "voice": "vo_adv_5156007_022"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "呼……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "還是自己家裡好。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──是說小子，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你還跟著啊！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_023"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "說、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "說得也是！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "抱歉太晚跟你通知了。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那正式來一次，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "鏘～",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我們的家翻新了～！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……說是這樣說，",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_024"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n其實只是把已經破舊不堪的家，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n修整回原來的樣子罷了。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嘿嘿。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對、",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_025"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對呀～",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n雖然財寶都已經被沒收了……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那個，",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_026"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呃……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然是不能大聲嚷嚷的事……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那時──",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_027"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n就是被【王宮騎士團（NIGHTMARE）】包圍的時候，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n那時……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "在財寶要被沒收的前一刻，",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_028"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "有把一點點財寶、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n放在帽子裡……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就是……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "把財寶、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n偷藏起來收下了。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "然後，",
        "unit_id": 130112,
        "voice": "vo_adv_5156007_029"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "把這筆錢當作頭期款去貸款，",
        "unit_id": 130112
