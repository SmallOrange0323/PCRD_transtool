        "name": "鈴奈",
        "words": "真的嗎？　",
        "unit_id": 110011,
        "voice": "vo_adv_6019110_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我好開心！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是說，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才你那麼閒嗎？",
