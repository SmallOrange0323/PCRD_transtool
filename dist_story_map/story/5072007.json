[
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夏日演唱會結束後，過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾的街頭巷尾都在談論著與慈樂之音相關的話題。"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "好險好險，",
        "unit_id": 1111,
        "voice": "vo_adv_5072007_000"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "差點就買不到了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "什麼啊，",
        "unit_id": 311,
        "voice": "vo_adv_5072007_001"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "慈樂之音的書，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n你到現在才去買啊？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是啊。",
        "unit_id": 1111,
        "voice": "vo_adv_5072007_002"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我沒有想到會有那麼多人排隊購買。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n看來前陣子的演唱會",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "讓她們的知名度一口氣高漲呢！",
        "unit_id": 1111
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "說到慈樂之音，我最欣賞的還是紡希！",
        "unit_id": 411,
        "voice": "vo_adv_5072007_003"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "她所設計的服裝，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "每件都好可愛喔～♪",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我啊，",
        "unit_id": 6511,
        "voice": "vo_adv_5072007_004"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "比較喜歡千歌吧。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n喜歡她那能夠撫慰人心的歌聲。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "對了，",
        "unit_id": 411,
        "voice": "vo_adv_5072007_005"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "妳有讀了訪談的文章嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n可以看到慈樂之音與平時不同的一面，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n讓人很有親近感呢！",
        "unit_id": 411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "我",
        "unit_id": 5411,
        "voice": "vo_adv_5072007_006"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "將來想成為像望那樣的偶像♪",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "我也是～♪",
        "unit_id": 415,
        "voice": "vo_adv_5072007_007"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "對了，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "待會要不要一起練習跳舞？",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "好啊！",
        "unit_id": 5411,
        "voice": "vo_adv_5072007_008"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n我家有慈樂之音全套的音響盤，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n一起以",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "慈樂之音為目標吧♪",
        "unit_id": 5411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──喂，小子。",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在這裡四處閒晃，是在做什麼啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……真是的。",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我說小子你也太悠哉了吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那本書的預購幾乎都搶光了，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "店面販售也都大排長龍。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你現在才出來買，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "根本不可能找到還有存貨的店家吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看你一臉「怎麼會這樣」",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "的表情。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你用不著這麼失落。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我早就想到可能會這樣，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以留了一本書",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要送你。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這本書還有附簽名！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n當然",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是我本人的簽名！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你就開開心心地收下吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你那是什麼奇怪的表情。",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n哼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你想要的是望她們的簽名？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然如此，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "等一下去跟她們要就行了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她們在另一邊等著你呢。",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然遲了點，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她們還是想辦一場慶祝演唱會圓滿落幕的慶功宴。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只是她們現在若在大街上走，肯定會造成騷動，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以就請我來叫你過去。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟敢使喚我充當傳話人，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她們越來越大牌了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "反正",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也有話要當面跟你說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以就特地走一趟來找你啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你這次做得很好。",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "收錄在書裡的訪談文章也大受好評。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這是因為能夠看見她們三人真實的一面，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也問到了不少我沒有指定的話題，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n無論哪個話題都很棒，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "的確值得好好讚賞。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如何？小子。",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要不要來當慈樂之音的專屬工作人員？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就知道你會這麼說。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很好，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那我們就說定囉？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n今後",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你將成為我的左右手，被我當牛馬般使喚……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這跟你所想像的不一樣？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這任性的傢伙。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "慈樂之音的最後一次訪談，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n刪掉未免太可惜了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我就收錄到書裡了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "演唱會結束後的訪談，",
        "unit_id": 107111,
        "voice": "vo_adv_5072007_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這並不常見呢──",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500161"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "訪談",
        "unit_id": 117411,
        "voice": "vo_adv_5072007_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還要繼續嗎？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n話說啊，演唱會才剛結束，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們現在可都累癱了耶。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒有關係啦，",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n正因為演唱會才剛結束，所以更應該來採訪，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是吧？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n……妳說呢，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 117311,
        "voice": "vo_adv_5072007_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在情緒高亢的當下，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "才有辦法問出真心話來。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，",
        "unit_id": 117411,
        "voice": "vo_adv_5072007_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳們兩個也太有體力了吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼，騎士先生，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "快點完成訪談吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "演唱會的感想啊。",
        "unit_id": 117411,
        "voice": "vo_adv_5072007_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我啊，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "大概是「累慘了──」",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "的感覺吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了辦場好的演唱會，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可是使出了渾身解數。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……當然，",
        "unit_id": 117411,
        "voice": "vo_adv_5072007_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這確實是場最棒的演唱會了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 117311,
        "voice": "vo_adv_5072007_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "以紡希而言",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這句話真坦率呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等，千歌。",
        "unit_id": 117411,
        "voice": "vo_adv_5072007_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請不要捉弄我啦！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 117311,
        "voice": "vo_adv_5072007_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "接著就是我囉。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "每回舉辦演唱會，",
        "unit_id": 117311,
        "voice": "vo_adv_5072007_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在眾人面前歌唱，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都讓我察覺到了自己全新表現的可能性……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但這次，",
        "unit_id": 117311,
        "voice": "vo_adv_5072007_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我更加深刻感受到，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不是單獨一個人，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n而是因為有望與紡希，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這兩位與我一同歌唱的夥伴，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們的歌聲重合才更具有力量。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌妳啊，",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算累壞了還是一樣冷靜。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真不公平，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接在這樣的感言之後我該說些什麼啊。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就請妳在此",
        "unit_id": 117311,
        "voice": "vo_adv_5072007_038"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好好展現出",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "隊長的風範來吧，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n望。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好～的。",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最後就輪到我囉。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次的演唱會，",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就我個人而言，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不僅有我個人的堅持，也碰上了不少的問題……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "或者該說，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是我給大家添了不少的麻煩。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "身為唱唱跳跳一面戰鬥的偶像，",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "慈樂之音的一員，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我認為我們已經呈現出了",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們所有的一切。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們還不是一個",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "完美的偶像團體。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會遭遇失敗，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也有努力不足的時候。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正因為如此，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們才能繼續向前邁進。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在我身旁有千歌和",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還有手腕高強的製作人，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "全力支持我們的工作人員們，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以及",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "致力聲援我們的粉絲們。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "慈樂之音",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "將會持續向前邁進，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n──邁向光輝燦爛的未來。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這就是我對這次演唱會的感想。",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……這～樣，",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是不是有點耍帥過頭了？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不錯嘛。",
        "unit_id": 117411,
        "voice": "vo_adv_5072007_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n直接了當，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "很像小望的作風。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。",
        "unit_id": 117311,
        "voice": "vo_adv_5072007_049"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只顧著看著前方直衝而去，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這就是我們慈樂之音的隊長。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿、",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿……♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝……",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_051"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們兩位。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這個嘛……",
        "unit_id": 117411,
        "voice": "vo_adv_5072007_052"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "想也知道吧。",
        "unit_id": 117311,
        "voice": "vo_adv_5072007_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……呵呵，",
        "unit_id": 117211,
        "voice": "vo_adv_5072007_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家一起說！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "當然是成為",
        "unit_id": 1,
        "voice": "vo_adv_5072007_055"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "頂尖",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "偶像！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}透過訪談，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看到了慈樂之音的過去和現在。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他凝視著這群偶像們耀眼奪目的身影，不禁露出了微笑。"
    }
]