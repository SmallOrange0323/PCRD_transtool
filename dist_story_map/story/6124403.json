[
    {
        "type": "background",
        "background": "501032"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124403_000"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]想說終於解決靈魂出竅的事了，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]結果忍超級生氣的，好可怕啊……",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]真是的，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]我該怎麼做才好啊……",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]吵死了小伙子！",
        "unit_id": 2415,
        "voice": "vo_adv_6124403_001"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]不用你說我也會這樣做！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]就算一副老成，忍也還是小孩……",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]相對的，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]我可是充滿大人的餘裕，能夠包容情緒化的女兒呢！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]閉嘴小伙子！",
        "unit_id": 2415,
        "voice": "vo_adv_6124403_002"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]為什麼我非得被你說教不可啊！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]不過，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]讓忍擔心這點，我確實有在反省啦……",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]……我就去道歉吧。",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124403_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]啊啊！？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]不行不行！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]你想把我當成藉口，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]跑去跟忍說話的意圖我可是一清二楚！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]你是好意？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]吵死了──！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]要做好事去其他地方做！",
        "unit_id": 2415
    }
]