[
    {
        "type": "background",
        "background": "500037"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "綾音幫助了和自己一模一樣的『闇影』後，過了幾天。\n等注意到時，『闇影』已經消失了蹤影，\n結果，依然不清楚她到底是什麼東西――"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "即使覺得心裡還有在意的地方，\n但因忙於進行平安夜派對的準備，\n綾音漸漸忘了那個不可思議的『闇影』。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼哼哼哼哼～♪",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這邊這邊！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n找到玩具店了，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就在這裡買胡桃和可可蘿的禮物吧！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們要在平安夜派對交換禮物對吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我不小心忘了挑選禮物，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以想說去買點東西好了～♪",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽拜託我們買的東西也都買好了，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "稍微繞點路再回去也沒關係吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "反正我猜哥哥也還沒有買禮物，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們一起選吧♪",
        "unit_id": 108611
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呵呵。",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快看快看，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這裡擺了好多的玩具！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我已經是姊姊了，所以才不會因為玩具感到高興，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但我覺得胡桃她們會喜歡這種的呢～♪",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "吶吶，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥覺得要選哪個好？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "先不說胡桃了，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥和可可蘿相處的時間比較久吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而且你們感情也很好，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以應該知道買什麼玩具可可蘿會開心吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "把那個",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "跟我說！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我會以自己的品味來挑選禮物，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但是參考別人的意見應該沒關係吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥覺得",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "挑哪個玩具可可蘿會喜歡？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "她好像會喜歡！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不愧是哥哥，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真了解她！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可可蘿她",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好像很喜歡抱著什麼東西呢。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "她前陣子吃完晚飯後開始想睡覺，還邊打瞌睡",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n邊抱住噗吉呢。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『是啊。",
        "unit_id": 2112,
        "voice": "vo_adv_1086003_012"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "那個小姑娘，",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n沒有給人會那樣子撒嬌的印象，",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我滿吃驚的呢。』",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿。",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可可蘿雖然很精明能幹，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但年紀還小啊……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以偶爾會想和人撒嬌吧。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "其實，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我並不想讓任何人碰噗吉的。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但可可蘿的話沒關係，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我們已經是家人了。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦？",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但可可蘿還是小孩子啊，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是會喜歡玩具之類的嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯……",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥覺得送",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "書本、",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n動物",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "或是植物之類的，可可蘿會比較開心？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊啊，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "的確，可可蘿很常讀書，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n或是給盆栽澆水呢。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不愧是哥哥，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很了解家人的事情呢～♪",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那麼，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們就去能買到那些東西的店鋪吧？",
        "unit_id": 108611
    },
    {
        "type": "background",
        "background": "500037"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "動作快！",
        "unit_id": 711,
        "voice": "vo_adv_1086003_019"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n朝那裡去了，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "別働隊迂迴到前方堵住她的去路！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "總算是讓她無路可逃了，",
        "unit_id": 712,
        "voice": "vo_adv_1086003_020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "可惡的『闇影』……！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦咦！？",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n怎、怎麼了？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　怎麼回事？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『嗯～？",
        "unit_id": 2112,
        "voice": "vo_adv_1086003_022"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n雖然不是很清楚，",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "但感覺氣氛很凝重呢……？』",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "……呣？",
        "unit_id": 711,
        "voice": "vo_adv_1086003_023"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n喂，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "那邊的人！　",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "不准動！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "什、什麼？　",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好可怕，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒有做什麼壞事啊……？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "……",
        "unit_id": 711,
        "voice": "vo_adv_1086003_025"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "失禮，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "認錯人了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n很抱歉用武器對著妳，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "讓妳害怕了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "喂，你在做什麼？",
        "unit_id": 712,
        "voice": "vo_adv_1086003_026"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n別働隊與『闇影』進入交戰狀態了，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "快去進行援護！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "啊，是！　",
        "unit_id": 711,
        "voice": "vo_adv_1086003_027"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "了解！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n我立刻趕往現場！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……呃？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "到、到底是怎麼回事？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n他們是負責這城鎮警備的",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n【王宮騎士團】吧，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嚇死我了～！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『唔～嗯？",
        "unit_id": 2112,
        "voice": "vo_adv_1086003_029"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n他們是不是說『闇影』怎麼了？』",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……啊、",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不會吧！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『唔哇？　",
        "unit_id": 2112,
        "voice": "vo_adv_1086003_031"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "喂，怎麼了，綾音？",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n別突然跑起來，",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "會跌倒的！』",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不好了！",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n他把我和『闇影』認錯就表示",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "他們說不定……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "正在追",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我們前陣子遇到的那個和我一模一樣的『闇影』！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "『闇影』就像魔物般的存在，不是嗎？",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "如果被【王宮騎士團（NIGHTMARE）】發現了，\n說不定會被他們驅除掉。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒辦法置之不理！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為那孩子，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個『闇影』和我一模一樣啊！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那孩子",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就是另一個我……！",
        "unit_id": 108611
    },
    {
        "type": "background",
        "background": "500024"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，綾音等人全速全力\n追趕著【王宮騎士團（NIGHTMARE）】――"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是當她們抵達目擊到『闇影』的現場時，\n戰鬥已經結束了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而詢問在場的\n【王宮騎士團（NIGHTMARE）】成員後，\n得知『闇影』似乎已經遭到討伐了……"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_036"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喂、喂。",
        "unit_id": 2112,
        "voice": "vo_adv_1086003_037"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "打起精神來啊，綾音。",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n被驅除的『闇影』，",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "又還沒確定\n就是和綾音一模一樣的『闇影』啊。』",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是……",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我覺得大概就是她。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n因為【王宮騎士團（NIGHTMARE）】的人也說了啊，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那是外表和我很像的『闇影』。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那孩子，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_039"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "被驅除了啊……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這也無可奈何，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為『闇影』就是類似魔物的存在啊。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_040"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那孩子，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們在一開始見到她的時候，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n她和我的爸爸媽媽牽著手走路。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "她代替我這個離家出走的壞孩子，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_041"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好好地當了爸爸媽媽的『女兒』啊。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "她代替『家人』、",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_042"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "代替『我』……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "挑選禮物，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n打算在聖誕節送給爸爸媽媽讓他們開心。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "她比我",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_043"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "做得更像『我』啊。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……比起在某天，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_044"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "突然",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "說什麼爸爸媽媽看起來像是冒牌貨開始。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n結果因為害怕，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而用莫名其妙的理由離開了家裡的我――",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那孩子，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_045"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "更像是『我』啊。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "她愛著爸爸媽媽，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "療癒他們、",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "讓他們幸福。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "然而，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是我這個壞孩子，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "反而卻是那孩子被驅除消失。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那樣子",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_046"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "太不公平了。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "太過份了，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "該消失的人應該是我才對。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『綾音……",
        "unit_id": 2112,
        "voice": "vo_adv_1086003_047"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不是那樣的，",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "絕對不是。",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳如果消失了，",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我會很寂寞的。』",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『{player}和其他的大家，",
        "unit_id": 2112,
        "voice": "vo_adv_1086003_048"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n【咲戀育幼院】的家人們都會悲傷的。",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n所以再也不要",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "說什麼自己應該消失了。』",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯……",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_049"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n謝謝，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是我，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_050"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "完全無法接受。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我不明白，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那孩子到底是什麼？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "『闇影』到底是什麼？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個世界正在發生什麼可怕的事情，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_051"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可是我還是小孩子，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我很笨，所以什麼都無法理解。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那讓我覺得有點",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不甘心呢。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『…………』",
        "unit_id": 102321,
        "voice": "vo_adv_1086003_052"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……咦？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_053"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "奇、奇怪？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n妳是",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個『闇影』？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳沒事嗎？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_054"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "太好了！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還以為妳被驅除了呢……？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『……的』",
        "unit_id": 102321,
        "voice": "vo_adv_1086003_055"
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『爸爸、媽媽……』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『……呢……？』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦，什麼？",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_056"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n比起這個，『闇影』，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是不是在閃爍？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好像在漸漸消失……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "怎、怎麼了嗎？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_057"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "果然\n【王宮騎士團（NIGHTMARE）】的人對妳做了很過分的事？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以妳才快要死了，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快要消失……了？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『……喔』",
        "unit_id": 102321,
        "voice": "vo_adv_1086003_058"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦？",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_059"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哇哇！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "『闇影』把什麼東西丟過來了！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個是……？",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_060"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是前陣子，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我替她付錢買的禮物？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是『闇影』打算買下來",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "送給爸爸媽媽的禮物……？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『……拜託妳』",
        "unit_id": 102321,
        "voice": "vo_adv_1086003_061"
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『我……』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『最喜歡",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "爸爸媽媽了……』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊、",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_062"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊啊！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "消失了，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "『闇影』！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "她到哪裡去了？",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_063"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n妳別躲起來，快出來！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "回答我！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這種東西",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_064"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳就算把禮物……交給我也很困擾啊！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n把這個",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "交給爸爸媽媽就好了嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要我代替妳去？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_065"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是這個意思嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我是不行的啊……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "爸爸媽媽不會開心的，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我是離家出走的壞孩子。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這應該要由好孩子的妳去送才對，",
        "unit_id": 108611,
        "voice": "vo_adv_1086003_066"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就算妳是『闇影』也一樣！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對爸爸媽媽來說，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n大概妳才是",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "『真正的孩子』啊……！",
        "unit_id": 108611
    }
]