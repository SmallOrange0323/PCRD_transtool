[
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「流星☆隕星！」\n「羅剎涅槃‧《霸極》萬象無盡冥壞破──！」\n「幻影地獄！」",
        "unit_id": 1,
        "voice": "vo_adv_0000326_000"
    },
    {
        "type": "dialogue",
        "name": "蜘蛛型魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 50011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "剩下的魔物",
        "unit_id": 101211,
        "voice": "vo_adv_0000326_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "似乎被大家打倒了呢──！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小初音",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "差不多……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼啊……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哎呀～",
        "unit_id": 2411,
        "voice": "vo_adv_0000326_002"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "居然露出像小孩一樣的睡臉。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n……但是……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗚，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這小姑娘身材不錯呢～",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n如果她再多一點大人的色香的話──",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "居然一直盯著睡著的女孩子看……",
        "unit_id": 103113,
        "voice": "vo_adv_0000326_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你想像剛剛被打倒的阿剌克涅的部下的魔物一樣，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n進入永眠嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "噫！？",
        "unit_id": 2411,
        "voice": "vo_adv_0000326_004"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n等等，忍！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "爸爸已經死了啊～！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說到永眠──",
        "unit_id": 100911,
        "voice": "vo_adv_0000326_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "下個的舞台是",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "冥界吉歐‧尼布爾黑爾！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我推測那是我靈魂的故鄉！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "等待著我們的會是",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "黑暗之神或是地獄之神──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "奇怪？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "永恆黑暗的公主",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "跟吉格魯特他們到哪去了？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──妳是說",
        "unit_id": 129612,
        "voice": "vo_adv_0000326_006"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "薇歐莉特公主他們嗎。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n他們回去",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "原本的世界了──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "騎士一行人",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "也一起去了。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚哇啊！？",
        "unit_id": 100911,
        "voice": "vo_adv_0000326_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼這樣……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我本來想讓他們帶我去的說～！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是說吉格魯特也先跑去，太狡猾了啦～！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在追上去的話，",
        "unit_id": 103113,
        "voice": "vo_adv_0000326_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或許能馬上就跟他們會合喔。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……我也",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對幽靈們居住的國度",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有興趣。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好──",
        "unit_id": 100911,
        "voice": "vo_adv_0000326_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "既然如此我們就立刻出發吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "潛伏於冥界的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "永恆黑暗的居民們啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你們就顫抖著地等待著",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "疾風之冥姬的凱旋吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "初音，",
        "unit_id": 103113,
        "voice": "vo_adv_0000326_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要走了喔。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "初音……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她完全沒反應呢。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不好意思，杏奈。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會把初音一起拖去的，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n妳可以來幫忙我嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "咦……",
        "unit_id": 100911,
        "voice": "vo_adv_0000326_011"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喂，初音！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "下個世界在等著我們啊──！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "醒～來～啦～！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真拿她沒辦法。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "忍！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "數到三要一起拖她喔！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n一二三──！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚唔唔～！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_0000326_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯嗯……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我還吃得下喔……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……",
        "unit_id": 129612,
        "voice": "vo_adv_0000326_013"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──路上",
        "unit_id": 129612,
        "voice": "vo_adv_0000326_014"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "小心。",
        "unit_id": 129612
    }
]