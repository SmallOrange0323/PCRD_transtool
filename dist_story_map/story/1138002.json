[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──依里為了改善自己的怕生而展開特訓。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當她在會合地點等待時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n姍姍來遲的{player}終於出現了。"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "太慢了──！",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你剛剛都在做什麼啊！！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "拜託你準時來嘛！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "難得我們",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有機會獨處……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊～",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "討厭，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "沒什麼啦！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以說，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你為什麼會遲到？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你今天本來不是有空嗎？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "該不會是",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "發生什麼事情了？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "他是在",
        "unit_id": 311,
        "voice": "vo_adv_1138002_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "為我帶路。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你是……？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "初次見面。",
        "unit_id": 311,
        "voice": "vo_adv_1138002_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那個，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "請問妳就是能幫人實現心願的",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "天使大人嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你說實現心願……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n雖然我打扮成這副樣子，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但我並不是真正的天使……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以說，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這種事情有點……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不、",
        "unit_id": 311,
        "voice": "vo_adv_1138002_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不是這樣嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這件事是在我去咲戀育幼院擺攤時，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n從他和孩子們那裡聽說的……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "他們說有個會幫忙解決煩惱的人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "而那個人一定就是，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能幫人實現心願的",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "天使……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以說，那個……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我問你！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這是怎麼一回事啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你說這是因為",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你想幫助在傷腦筋的人……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然我是能夠同理你這種想法……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我這種人能解決成年人遇到的困擾嗎……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總而言之，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就先聽他說說看吧……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然不知道像我這樣的人能不能幫上你的忙，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可以請你先說說看是什麼事情嗎？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "謝、",
        "unit_id": 311,
        "voice": "vo_adv_1138002_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "謝謝妳！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我其實是個",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "用小攤子在賣餐點的人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n不過我在不久前結婚了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是這樣嗎！？",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n恭喜你！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "…………",
        "unit_id": 311,
        "voice": "vo_adv_1138002_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你們的婚姻",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不順利嗎……？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_016"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們夫妻的感情很好。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妻子為了我，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "總是在不辭辛勞地努力，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n為了回應妻子的心意，我也想努力打拼。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……但我完全沒能",
        "unit_id": 311,
        "voice": "vo_adv_1138002_017"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "為妻子做點什麼。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我才剛開始擺攤，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "既沒辦法",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "送她衣服，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "甚至也無法舉行婚禮。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "…………",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_018"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要是我賺得更多，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_019"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n就能為妻子舉辦婚禮了，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "事情卻無法如我所願……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……但就算是這樣，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_020"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我還是想做點什麼，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n回報總是在支持我的妻子！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "天使大人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "如果妳願意的話，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n能不能請妳和我一起想想向妻子表達謝意的方法呢？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就算沒辦法舉辦婚禮，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_021"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "至少讓我為她做點什麼……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就算你這麼說……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就算找我商量這種事，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我也沒辦法幫忙解決啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然很抱歉，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但這時候只能說我也不知道……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "…………",
        "unit_id": 311,
        "voice": "vo_adv_1138002_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "他的表情好悲傷……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "他應該是由衷地",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "想為他太太做點什麼吧……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……我想幫助他。",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n是為了這個人，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也是為了他太太！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但是，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我該怎麼做……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "用言語表達感謝……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這我想",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你應該已經在做了……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "果然還是想",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "做一件最能讓你太太開心的事情對吧。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這樣想下來，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "果然還是要辦婚禮……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "錢的問題……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我嗎……？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果我結婚，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "遇到了相同的情況……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果是我……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就算沒有華麗的禮服，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n只要能表達出想慶祝的心意",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就很幸福了……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我是這麼想的。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "能表達心意……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n然後",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "又能讓兩人獲得幸福的婚禮……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_032"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對了！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n來舉辦一場",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "親手打造的驚喜婚禮如何？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "親手打造的婚禮……！？",
        "unit_id": 311,
        "voice": "vo_adv_1138002_033"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是的！",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_034"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我會找孩子們，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還有我的妹妹來！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這樣一定會很熱鬧的！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n啊，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "捧花之類的東西也由我們來做！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我對這個提議非常感激，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_035"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但真的可以讓天使大人為我做這麼多嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_036"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可以！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我想要",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "改變自己……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我很希望這能成為改變自己的契機，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以請讓我這麼做！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "既然妳都這麼說了，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_037"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不如說是",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我要拜託妳才對。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n天使大人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "請妳助我一臂之力。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好的！！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n既然如此，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就馬上來準備吧。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n因為有很多需要用到的東西！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "當然了，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我也要請你來幫忙喔♪",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呵呵，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "很高興你這麼聽話♪",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_041"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不，那個，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你可以不必這麼賣力喔？",
        "unit_id": 113811
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "──好，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_042"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那就馬上來動手做吧！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "捧花之類的東西",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我之後會請妹妹幫我做，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們就先來做",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "卡片吧。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "卡片嗎？",
        "unit_id": 311,
        "voice": "vo_adv_1138002_043"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是的！",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_044"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n請在上面",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "寫下你身為新郎想說的話。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n可以當作是致謝，也能成為邀請卡。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "原來如此……",
        "unit_id": 311,
        "voice": "vo_adv_1138002_045"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我知道了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那我來",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_046"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "努力做卡片。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……畢竟不知道會需要多少張，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我就做多一點喔。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_047"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "既然如此，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以給我一張嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我會做很多，所以沒關係喔。",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_048"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但你要",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "拿來做什麼呢？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我有些想做的事情……",
        "unit_id": 311,
        "voice": "vo_adv_1138002_049"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不提這個，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n剛才帶我來這裡的那個人",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "還沒回來嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_050"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那傢伙說",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "他知道有可以拿來舉辦婚禮的地方，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n他想去看看能不能使用，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就去勘查了。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那傢伙",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_051"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "莫名其妙地有很多人脈。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n之所以能使用這個地方，也是託了那傢伙的福。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……不過，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那些人脈好像大部分",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都和女孩子有關。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "女孩子嗎……",
        "unit_id": 311,
        "voice": "vo_adv_1138002_052"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊！",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_053"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "講是這樣講，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那傢伙並不是愛搭訕的爛男人！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "他會為了改善我的怕生而努力，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也會對我很溫柔……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "呵呵，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_054"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "只要看見你們倆剛才相處的情形，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n就能知道他並不是那樣的人喔。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n真不愧是天使大人的戀人呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "………………！？",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_055"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n戀、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "戀戀、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "戀人……！？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們兩位要舉辦婚禮時，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_056"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "請一定要讓我好好報答你們。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "在那之前，我會好好努力，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "讓自己不是經營攤販，\n而是擁有自己的商店。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_057"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不是這樣的！！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我和那傢伙",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "並不是那種關係……！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "歡迎回來。",
        "unit_id": 311,
        "voice": "vo_adv_1138002_058"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n沒什麼，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們只是在聊你和天使大人的關係。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不，所以說，我們是……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_059"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對了！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你也來跟他說！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n跟他說我們的關係並不是那樣……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_060"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什什……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什…………",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔喔，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_061"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們果然是那樣的關係啊。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為什麼你總愛講這種會讓人誤解的話啊！",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_062"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n受不了，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你別再開口了～～！！",
        "unit_id": 113811
    },
    {
        "type": "background",
        "background": "500041"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "──好，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_063"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "大致完成了呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "剩下的我們會想辦法處理，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以今天就先解散吧。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我會準備當天的餐點。",
        "unit_id": 311,
        "voice": "vo_adv_1138002_064"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n不只是為了妻子而已，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我會試著做出能讓天使大人",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n和來參加的各位開心享用的菜餚。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "麻煩你了。",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_065"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那這麼一來，大部分的準備工作就……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還沒有決定好要找誰來主持祝福儀式……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "的、",
        "unit_id": 311,
        "voice": "vo_adv_1138002_066"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "的確是這樣。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但我沒有錢",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能找人來擔任這個職務……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "既然如此，",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_067"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就只能由我們自己來了嗎？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n遇到這種狀況，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "應該是那傢伙比較適合吧……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我……！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_068"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可以讓我來負責這個職務嗎？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咦……",
        "unit_id": 311,
        "voice": "vo_adv_1138002_069"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然我可能會做得不太好……",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_070"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但提議要來舉辦",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這場婚禮的人是我，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n所以我想好好努力到最後，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "祝福你們兩位！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_071"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而且，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你看！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我難得做出了這樣的打扮！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以說……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我和妻子……",
        "unit_id": 311,
        "voice": "vo_adv_1138002_072"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "果真是受到上天眷顧著呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……咦？",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_073"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我沒有拒絕妳的理由。",
        "unit_id": 311,
        "voice": "vo_adv_1138002_074"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n反而是我要拜託妳才對。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "天使大人，",
        "unit_id": 311,
        "voice": "vo_adv_1138002_075"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以請妳在婚禮上",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "祝福我和妻子嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……好、",
        "unit_id": 113811,
        "voice": "vo_adv_1138002_076"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好的！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "會全力以赴的！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──最後決定親自為新郎和新娘獻上祝福的依里，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n更堅定了決心，等待著婚禮之日到來。"
    }
]