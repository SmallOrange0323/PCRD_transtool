[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原本是為了調查馬車上貨物離奇消失的事件才過來的，",
        "unit_id": 106011,
        "voice": "vo_adv_9032155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但可沒聽說會有這麼多蟲子啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊煩死了！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全部燒爛好了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好啦好啦，",
        "unit_id": 105811,
        "voice": "vo_adv_9032155_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冷靜一下。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就在這附近吃飯，休息一下吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n填飽肚子的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "煩躁也會通通消……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家的飯糰……",
        "unit_id": 105811,
        "voice": "vo_adv_9032155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼不見了？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪了？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞什麼啊真是的。",
        "unit_id": 106011,
        "voice": "vo_adv_9032155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該是妳，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在無意識的情況下吃掉了吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～，",
        "unit_id": 105811,
        "voice": "vo_adv_9032155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該不會這樣的啊……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒辦法了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在只好把備用的私房飯糰……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇！　",
        "unit_id": 105811,
        "voice": "vo_adv_9032155_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "飯、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "飯糰突然從手上消失了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這就是傳聞中的貨物消失事件嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_9032155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但也沒有使用過魔法的跡象啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底發生什麼事了！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9032155_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那裡的地上有飯粒呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "飯粒",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎一直延伸到森林的深處。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n趕快追上去吧……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚哇！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔！　",
        "unit_id": 106011,
        "voice": "vo_adv_9032155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那邊的樹上好像有什麼……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有個巨大的眼球漂在空中啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……那雙顯眼的大眼睛，",
        "unit_id": 105911,
        "voice": "vo_adv_9032155_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是以前書裡看到",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n名為「變色龍」的生物也說不定。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "鱉色龍！？　",
        "unit_id": 105811,
        "voice": "vo_adv_9032155_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽起來能熬出很棒的湯頭呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n快點打倒牠……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛剛有什麼飛過來了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是鱉，",
        "unit_id": 105911,
        "voice": "vo_adv_9032155_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是變色龍。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然無法用肉眼確認，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下判斷應該是用伸長的舌頭來進行攻擊的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！　",
        "unit_id": 105811,
        "voice": "vo_adv_9032155_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能隱藏身影",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又能伸長舌頭，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n的確能在不被察覺的情況下偷走貨物呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_9032155_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來那隻魔物",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無庸置疑就是這一連串事件的犯人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了能安全地開拓，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就在此將牠擊退吧！",
        "unit_id": 105911
    }
]