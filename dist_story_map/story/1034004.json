[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從餐館內傳來聲音。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喂～你～！",
        "unit_id": 103411,
        "voice": "vo_adv_1034004_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這裡這裡～！ 啊哈哈哈哈哈！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦～，你問我是不是又在喝酒～？",
        "unit_id": 103411,
        "voice": "vo_adv_1034004_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為在這種地方，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n喝到醉倒才是有禮貌喔～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你不用那麼擔心也迷～有關係啦～。",
        "unit_id": 103411,
        "voice": "vo_adv_1034004_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你看，玻璃杯也發著光展現自己，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n說著『再多喝我一點』～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈哈哈！ 港覺越來越耀眼～！",
        "unit_id": 103411,
        "voice": "vo_adv_1034004_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n閃耀～，再閃耀一點～！",
        "unit_id": 103411
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被叫到車站前，\n優花梨和不認識的男人正站在那裡。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對、對不起，突然叫你出來。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其、其實……",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_005"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "優花梨，妳說的男朋友就是這傢伙？ 妳在開玩笑吧？",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒、沒那回事。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n他是我出色的男朋友。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你、你聽我說一下！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "拜、拜託你，配合我說話！",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我被這個人搭訕，他很難纏……",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "只要現在就好，我希望你假裝是我男朋友，蒙混過去！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "在說什麼悄悄話啊。\n真可疑呢。",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才、才不可疑。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我們",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是很恩愛的！ 很恩愛！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你說對吧！？",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸、欸嘿嘿……即使是說謊，好像還是有點高興……",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也、也許是這樣沒錯……但是拜託你配合我！",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_012"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "……很像在騙人呢。就情侶來說，你們的距離也太遠了。",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "距、距離？ 我就說沒那回事嘛！",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n喂、喂，你！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哇哇哇！ 那、那樣實在是太大膽了啊！",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，嗯，手呢，如果只是手的話……",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、你看，我們牽著手喔！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "還是很可疑……\n你們是情侶這件事是騙人的吧？",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才、才沒有騙人！ 你也該相信了吧！",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_018"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "若是這樣的話，就讓我看證據。\n你們是情侶的證據。",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "證、證據……就算你這麼說……嗚……",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……我、我知道了。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n在這裡等我一下！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我馬上回來！",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "優花梨好慢呢。",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_022"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "\n不會逃走了吧……",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "你、你說不可能會那樣？",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_023"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "搞、搞什麼嘛，突然變得激動起來……",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "嗯？",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸嘿嘿～♪　讓你們久等了～♪",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_024"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "……優花梨？",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是，我是優花梨！ 我回來惹優～！",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一點事也沒～有喔！ 比起這個，你……",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們接吻吧，啾――♪",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "什……喂、喂！ 妳突然地在做什麼！",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你問我在做什麼，這就素證據喔～。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你鼻是說要讓你看恩愛的證據嗎～。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喂，啾――♪",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那種事鼻重要啦～。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喂，我們接吻吧，啾――♪",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "啊啊，夠了！ 我已經知道了！",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哎呀？ 夠了？",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_032"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "可惡，竟然放閃……這傢伙哪裡好了啊！",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_033"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "我比他有錢，又是個帥哥，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "\n還擁有社會地位喔！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯嗯，雖然也許是這樣沒錯……但素呢。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_034"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他會看著真實的偶。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_035"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n只有在他面前，偶才能顯現出自己真實的模樣。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "偶素第一次遇見這樣的人……",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_036"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且，他的長相意外地是偶的菜……",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n欸嘿嘿，偶很喜翻他喔～。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "……嘖，沒想到搭訕到了笨蛋情侶。",
        "unit_id": 1031,
        "voice": "vo_adv_1034004_037"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "\n再見。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好～，再見喔～！",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_038"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……喝了水之後好多了。",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_039"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝你的幫忙。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你說你什麼都沒做？ ",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_040"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒那回事喔。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為有你在，",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我才能隨心所欲地說……而且呢。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "剛剛我說的……意外地，也許不全是胡說八道喔？",
        "unit_id": 103431,
        "voice": "vo_adv_1034004_041"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n如果是和你的話，我……",
        "unit_id": 103431
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1034004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1034004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後幾乎都會忘記，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖是這麼說……你和優花梨兩人的氣氛不是很好嗎？　",
        "unit_id": 190011,
        "voice": "vo_adv_1034004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然在我看來她是個麻煩的孩子，",
        "unit_id": 190011,
        "voice": "vo_adv_1034004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但是你似乎覺得她這一點也很可愛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管我無法理解，但要我支持你也無妨喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為無論是『那邊』的她或『這邊』的她……",
        "unit_id": 190011,
        "voice": "vo_adv_1034004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她們的心靈支柱似乎只有喝酒和你而已。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今後也請溫柔對待她們吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣一來，即使你現在只是個能與她交心的年輕人……",
        "unit_id": 190011,
        "voice": "vo_adv_1034004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但總有一天，你說不定能成為王子呢？",
        "unit_id": 190011
    },
