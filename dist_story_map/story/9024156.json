[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總算度過了突如其來的恐怖危機。",
        "unit_id": 106011,
        "voice": "vo_adv_9024156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被強迫跳舞，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "害得我全身都是汗。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒想到敵人還能使用那種奇怪的技能……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們得小心一點。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在附近尋找了一下，",
        "unit_id": 105811,
        "voice": "vo_adv_9024156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎沒發現人類小孩的蹤影……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喂～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有人在嗎～？　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們來救你了～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨、",
        "unit_id": 106011,
        "voice": "vo_adv_9024156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨蛋！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那群獸人是靠巨大聲響溝通的喲？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這樣大聲嚷嚷，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會把牠們全引過來的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊是，",
        "unit_id": 105811,
        "voice": "vo_adv_9024156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳那裡的情況如何呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105911,
        "voice": "vo_adv_9024156_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡也沒有什麼斬獲。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "部落的後方",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是綿延不絕的小徑。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能只是其中一個據點……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許能如此推測吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦～",
        "unit_id": 106011,
        "voice": "vo_adv_9024156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼說來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物的數量可能會比預期的還要多。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然對孩子們很不好意思，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我們還是先回去回報狀況，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n順便在村裡做好組織搜索隊的準備比較好吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "了解☆　",
        "unit_id": 105811,
        "voice": "vo_adv_9024156_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然如此，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "事不宜遲！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我在半路做了一些肉乾，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n填飽肚子後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趕緊出發吧！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位，請用☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在半路做的……",
        "unit_id": 106011,
        "voice": "vo_adv_9024156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難不成又是魔物肉……！！",
        "unit_id": 106011
    }
]