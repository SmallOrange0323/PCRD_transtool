[
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "──喝啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_5085203_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……！",
        "unit_id": 15811,
        "voice": "vo_adv_5085203_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "另一個你",
        "unit_id": 121011,
        "voice": "vo_adv_5085203_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正在消失……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成功了吧！？",
        "unit_id": 121111,
        "voice": "vo_adv_5085203_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是啊，",
        "unit_id": 121211,
        "voice": "vo_adv_5085203_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n少年，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你已經用「你的力量」超越了。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來吧，",
        "unit_id": 121211,
        "voice": "vo_adv_5085203_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接下來就開個盛大的派對之類的",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "狂歡到隔天吧！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我會給大家吃特製的可麗餅喲！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……雖然",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我正想這麼說。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "整個空間開始產生扭曲了。",
        "unit_id": 121211,
        "voice": "vo_adv_5085203_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n比剛才還巨大的力量正在改變它的形狀。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還沒有結束。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚哇～",
        "unit_id": 121111,
        "voice": "vo_adv_5085203_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "早知道就別說什麼",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「成功了吧！？」",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真是空歡喜一場。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……無所謂。",
        "unit_id": 121011,
        "voice": "vo_adv_5085203_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不論有什麼樣的戰鬥等著我，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我都會迎面而戰！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很好。",
        "unit_id": 121211,
        "voice": "vo_adv_5085203_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，大家",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以稍微湊過來一點嗎？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我來讓空間的扭曲穩定下來。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……這可是大姐姐的職責",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喲！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "前進吧。",
        "unit_id": 121011,
        "voice": "vo_adv_5085203_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓你，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有我們一起！",
        "unit_id": 121011
    }
]