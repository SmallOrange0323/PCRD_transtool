        "voice": "vo_adv_5044321_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不好意思～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我沒什麼興趣耶──♪",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "恕我鄭重拒絕。",
        "unit_id": 113211,
        "voice": "vo_adv_5044321_006"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "唔唔唔！",
        "unit_id": 13511,
        "voice": "vo_adv_5044321_007"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "怎麼這麼難攻陷……！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n但本大爺並不討厭、",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "不討厭這種型的喔……！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n那邊那位帶刀的小妞意下如何！？",
        "unit_id": 13511
