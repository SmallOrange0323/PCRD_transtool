    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本、",
        "unit_id": 13511,
        "voice": "vo_adv_5044321_003"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本大爺追尋的後宮就在眼前……",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n好、",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "好羨慕……！！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "喂喂，",
        "unit_id": 13511,
        "voice": "vo_adv_5044321_004"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "那邊的小妞們！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n要不要來這裡",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "和本大爺銀河約會一場啊～？",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
