    {
        "type": "dialogue",
        "name": "流夏",
        "words": "受不了，",
        "unit_id": 113111,
        "voice": "vo_adv_5044321_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是學不會教訓的傢伙。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "回答的話就不用說了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……像你這種輕浮的傢伙，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我可敬謝不敏。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "哦哦～",
        "unit_id": 13511,
        "voice": "vo_adv_5044321_009"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "真是銳利的眼神！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n身體一震酥麻",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "……本、",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本、",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本大爺興奮起來啦──！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎、",
        "unit_id": 113211,
        "voice": "vo_adv_5044321_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼了！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這傢伙的力量增強了……！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難道說，",
        "unit_id": 113311,
        "voice": "vo_adv_5044321_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "他被流夏姐拒絕後，情緒反而更高漲了！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為什麼會變成這樣！？",
        "unit_id": 113111,
        "voice": "vo_adv_5044321_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拜託饒了我吧……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也只能迎擊了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要來了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "杏奈、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
