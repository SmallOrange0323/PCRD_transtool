        "unit_id": 121911,
        "voice": "vo_adv_5092422_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好啦，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然大家都累了",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不過還是要",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "抬頭挺胸。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n贏家要是這副德性",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對輸家就太失禮了。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n然後",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要痛快地喊出勝利的歡呼！",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈～哈哈哈！",
