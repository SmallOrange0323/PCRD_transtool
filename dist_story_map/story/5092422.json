        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就算有第二或第三的守護者也不奇怪……",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "杏奈，",
        "unit_id": 122011,
        "voice": "vo_adv_5092422_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那可不是開玩笑的……",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
