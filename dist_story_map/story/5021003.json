    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人為了尋找奄美魔物的線索，\n於是便在漁村裡四處打聽消息。\n就在那時候，從村民那裡得知了玩偶浮在空中的目擊情報。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "吶、我說。",
        "unit_id": 110411,
        "voice": "vo_adv_5021003_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n果然……",
