        "words": "那個，公主。",
        "unit_id": 110411,
        "voice": "vo_adv_5021003_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在還不能確定就是它們對吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然奪取他人的靈魂，",
        "unit_id": 110611,
        "voice": "vo_adv_5021003_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我絕無法原諒。",
