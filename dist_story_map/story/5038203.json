[
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆",
        "unit_id": 110911,
        "voice": "vo_adv_5038203_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對於這個裝作琪愛兒的假粉絲，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我已經華麗地封鎖囉！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊。",
        "unit_id": 110811,
        "voice": "vo_adv_5038203_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我從之前就一直很好奇。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n琪愛兒那簡直像在開玩笑似的亂七八糟的格鬥風格到底是怎麼回事？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊？",
        "unit_id": 110911,
        "voice": "vo_adv_5038203_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "　怎麼回事是怎麼回事？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來克蘿依很難把這個講得更白話，",
        "unit_id": 111011,
        "voice": "vo_adv_5038203_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這裡就由軍師我來問妳吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "為什麼妳這麼強？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳有在哪個流派修行過嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～不，",
        "unit_id": 110911,
        "voice": "vo_adv_5038203_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我沒有。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我只是隨便",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "看著很厲害的人的動作，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有樣學樣而已？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，那些動作基本上都不是很可愛，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以就自己調整為琪愛兒流了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "自成一派啊。",
        "unit_id": 110811,
        "voice": "vo_adv_5038203_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "明明感覺像在做新型運動，竟然還能亂強一把的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那是什麼玩笑嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳可以向全世界的武鬥家道歉嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依。",
        "unit_id": 111011,
        "voice": "vo_adv_5038203_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我們很容易忘記呢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "其實她在很多方面都是個天才。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊哈！",
        "unit_id": 110911,
        "voice": "vo_adv_5038203_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n沒有啦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這種事只要願意做，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不管是誰都做得到啦～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我想那應該不是驕傲或挖苦，",
        "unit_id": 110811,
        "voice": "vo_adv_5038203_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而是發自內心的想法。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "等等，克蘿依，",
        "unit_id": 111011,
        "voice": "vo_adv_5038203_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "把刀收起來吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然後請妳回想一下她的個性。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她是個就算在背地裡歷盡千辛萬苦的努力與不斷鑽研，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也不會表現出來讓人知道的女孩。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這就像是天鵝划水一樣。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "超級美談！　",
        "unit_id": 110911,
        "voice": "vo_adv_5038203_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "採用這個說法！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真是感人喵～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "煩躁煩躁煩躁煩躁……",
        "unit_id": 110811,
        "voice": "vo_adv_5038203_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～",
        "unit_id": 110911,
        "voice": "vo_adv_5038203_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說我們還沒有跟先遣部隊的小墨丘利們會合呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "到底發生了什麼事呢……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們要不要再稍微往前走一點看看？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過琪愛兒有點累了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以投回家泡澡一票～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那傢伙，",
        "unit_id": 110811,
        "voice": "vo_adv_5038203_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真會享受人生。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我有同感。",
        "unit_id": 111011,
        "voice": "vo_adv_5038203_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n先不管天才投的那一票，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們趕快追上應該在前面的財團吧。",
        "unit_id": 111011
    }
]