[
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "工會之家的大門被用力打開，\n同時珠希也衝了進來。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我帶來新事業的消息了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希，",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一直以來謝謝妳。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n能告訴我詳情嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "之前我曾在某間牧場打工幫忙，",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那裡的老闆似乎想將牧場賣掉喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "經營牧場……？",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這與我們至今所接觸的行業相當不同呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "假設我們收購牧場，",
        "unit_id": 103411,
        "voice": "vo_adv_3008002_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n靠我們是否能夠創造收益呢……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們先和經營者見面，聽聽對方怎麼說吧。",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "細節的部分之後再考慮就好了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就知道妳會這麼說，我已經把他們帶來了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂――，進來吧喵――。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "初次見面。",
        "unit_id": 311,
        "voice": "vo_adv_3008002_007"
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "\n請多多指教。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這兩位是牧場的主人喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牧場原本相當興盛繁榮，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但聽說最近經營得很辛苦。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "我們不得不解雇所有之前聘請的大量員工…",
        "unit_id": 411,
        "voice": "vo_adv_3008002_009"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "所以這次決定狠下心來拋售牧場。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牧場所有權就讓這個公會買下，",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n條件是希望能雇用他們倆作為管理牧場的員工喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果經營狀況原本就已經上軌道的話，",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n要重新整頓似乎不是件難事呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "與從頭開始建立牧場不同，幾乎不需花錢在備齊設備和招募員工上，這點相當吸引人喔。",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "若由原本一直管理的人為我們工作，",
        "unit_id": 103411,
        "voice": "vo_adv_3008002_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n即使是沒經驗的我們似乎也沒問題，我認為是筆不錯的交易喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "決定了。",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們會買下你們的牧場。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "明天開始立刻著手重建牧場吧！",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天――"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好累啊～！",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n沒聽說有這麼多勞力活要做啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "秋乃，想休息還早呢！",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "工作還多得是，動作俐落點！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n說要重建牧場的是秋乃妳吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那是因為我沒想到會這麼辛苦……",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "事到如今才開始感到後悔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n好恨昨天的自己……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳看，來打工的他",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n都認真努力的工作，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以秋乃也不要抱怨了！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗯，我就覺得需要男性幫手，",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n叫你來果真是正確的呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以說{player}大人，",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我的份也……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "謝謝你為我打氣！",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣一來，我似乎就能努力了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不是！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n求你幫幫我！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不愧是你……！",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼請馬上到這裡來……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不要把工作推給別人做！",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n好了，到這裡來！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請、請等等啊，美冬！",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你～！ 拜託幫幫我～！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "喂喂，你們很吵喔？",
        "unit_id": 811,
        "voice": "vo_adv_3008002_025"
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "這裡的員工不是全都被炒魷魚了嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？ 請問是哪位呢？",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_026"
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "我們是隔壁牧場的人。",
        "unit_id": 911,
        "voice": "vo_adv_3008002_027"
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "\n你們在這裡工作可是會倒大楣的喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "最好給我做好心理準備。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "會倒大楣……？",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n是怎麼回事？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "同行的競爭心態……",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這樣看來還真是充滿敵意呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃！ 美冬！",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n沒事吧喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒被怎麼樣吧喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希怎麼那麼慌張……",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那些人做了什麼嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "那些傢伙，還真敢若無其事地出現在我們面前……！",
        "unit_id": 311,
        "voice": "vo_adv_3008002_032"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "他們不只騙走隔壁的牧場，",
        "unit_id": 411,
        "voice": "vo_adv_3008002_033"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "\n似乎還覬覦我們這座牧場，不斷地來找麻煩。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這座牧場的馬很有名，",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n養大的馬會賣給騎士團和商人喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "可是直到最近，不是馬匹的飼料裡被下毒，",
        "unit_id": 411,
        "voice": "vo_adv_3008002_035"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "\n就是理應很堅固的柵欄遭到破壞，導致魔物入侵牧場，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "\n害馬匹受傷等等，發生了很多問題。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "隔壁牧場發生過那種事，所以我不覺得這只是不幸的意外……",
        "unit_id": 311,
        "voice": "vo_adv_3008002_036"
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "而且我們還因此損失了大部分的老客戶與生意，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "才會決定拋售牧場……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那些傢伙絕對是犯人喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就算沒有證據，也一定是他們沒錯喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然如此，我就把他們手頭上的錢全部偷走喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什麼要妨礙我喵！？",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難道你一點也不在意嗎喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你也這麼認為！？",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好――，我們兩個去突擊他們吧喵――！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希，冷靜一下。",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_040"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算搶走他們的錢，也只能打擊他們於一時。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是……！",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_041"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果不懲罰那群傢伙的話，我嚥不下這口氣喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……我也一樣。像那種沒有道德的人，",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_042"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "應該徹底的教訓他們，讓他們無法再做壞事。",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500152"
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "可惡，這是怎麼回事？",
        "unit_id": 811,
        "voice": "vo_adv_3008002_043"
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "\n動物飼料居然都被人買斷了……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "動物們沒有飼料可吃，豈不是就會暴躁抓狂嗎！",
        "unit_id": 911,
        "voice": "vo_adv_3008002_044"
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "那對牧場兄妹也很快就會讓步，",
        "unit_id": 911,
        "voice": "vo_adv_3008002_045"
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "事情本該進展得很順利的……怎麼會變成這樣！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "安啦。",
        "unit_id": 811,
        "voice": "vo_adv_3008002_046"
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "\n下次只要讓我們馴養的魔物過去大鬧一番，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "那個牧場絕對會完蛋的。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "之後只要趁機奪取牧場，",
        "unit_id": 911,
        "voice": "vo_adv_3008002_047"
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "\n這一帶的土地與家畜就全都是我們的囊中物了……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……原來如此。",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_048"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n看樣子犯人果然就是你們呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "什麼！？",
        "unit_id": 811,
        "voice": "vo_adv_3008002_049"
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "\n妳們是什麼時候……！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "祕密行動是義賊的基本功夫喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_050"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你們說的話我已經全部聽到了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "受罰吧喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "可、可惡！……既然如此！",
        "unit_id": 911,
        "voice": "vo_adv_3008002_051"
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "\n魔物們，給我幹掉這些人！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是魔物喵！？",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_052"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n危險喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這種人類能馴養程度的魔物，",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_053"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n沒什麼大不了的。看招！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500152"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "什麼……魔物竟然一瞬間就被！?",
        "unit_id": 811,
        "voice": "vo_adv_3008002_054"
    },
    {
        "type": "dialogue",
        "name": "無禮男子１",
        "words": "\n妳們到底是什麼來頭！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你不知道本小姐是誰嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_055"
    },
    {
        "type": "dialogue",
        "name": "無禮男子２",
        "words": "我怎麼可能會知道！",
        "unit_id": 911,
        "voice": "vo_adv_3008002_056"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你、你說什麼！？",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_057"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "很好，各位！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n讓我們徹底擊潰這些人吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那種說法聽起來",
        "unit_id": 103411,
        "voice": "vo_adv_3008002_058"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n好像我們才是壞人……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下我的正義之槌吧！",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_059"
    },
    {
        "type": "dialogue",
        "name": "男子們",
        "words": "咕哇───！！",
        "unit_id": 1,
        "voice": "vo_adv_3008002_060"
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……變成不得了的事了呢……",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_061"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為那些男人們被逮，",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_062"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n那間牧場竟也變成由我們管理了……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "怎麼辦才好～？ 工作量可不只有加倍啊……？",
        "unit_id": 103411,
        "voice": "vo_adv_3008002_063"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這已經不是我們所能負荷的了呢……",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_064"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "牧場的經營，就交給你們兩兄妹了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "這怎麼行……！",
        "unit_id": 411,
        "voice": "vo_adv_3008002_065"
    },
    {
        "type": "dialogue",
        "name": "妹",
        "words": "\n真的可以嗎……！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "已經沒有人會再來騷擾了，",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_066"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要牧場確實能夠獲利，我沒關係喔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而且即使我們這些外行人來幫忙，也只是礙手礙腳。",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_067"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "重新雇用之前工作的員工吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣的話也能維持經營吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "當然沒問題……",
        "unit_id": 311,
        "voice": "vo_adv_3008002_068"
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "多謝各位！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "兄",
        "words": "\n真的非常感謝您們！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不用在意喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008002_069"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說到底這只是生意上的事喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但沒想到我們連懲戒惡人都要做呢。",
        "unit_id": 104811,
        "voice": "vo_adv_3008002_070"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的……",
        "unit_id": 103411,
        "voice": "vo_adv_3008002_071"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "回到城裡之後想去喝一杯呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "各位，要尋找下一個商機囉！",
        "unit_id": 103211,
        "voice": "vo_adv_3008002_072"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n回城鎮去吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隨著秋乃一行人的商業經營活動而帶來的公會擴張，\n看來還會再持續下去呢。"
    }
