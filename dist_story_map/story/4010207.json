    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "比平時還要",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "閃閃發亮……！？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呀啊！？",
        "unit_id": 101031,
        "voice": "vo_adv_4010207_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "牽起人家手的動作",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也好帥氣……！",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不可以，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓人家這麼",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "心跳加速……！",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當然，",
        "unit_id": 101031,
        "voice": "vo_adv_4010207_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為是慶生的邀請，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以有點期待……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但沒想到會這麼用心……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不愧是人家的王子先生……♪",
        "unit_id": 101031,
        "voice": "vo_adv_4010207_004"
    },
    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
