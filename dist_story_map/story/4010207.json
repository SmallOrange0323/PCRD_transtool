        "voice": "vo_adv_4010207_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "發、",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "發生什麼事了，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
