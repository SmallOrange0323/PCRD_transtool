    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "提出「願望」嗎？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 101031,
        "voice": "vo_adv_4010207_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家想要",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "感受王子先生",
