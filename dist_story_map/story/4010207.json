    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是公主的特權呢……♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……難道說，",
        "unit_id": 101031,
        "voice": "vo_adv_4010207_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也可以由我",
