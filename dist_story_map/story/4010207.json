    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "手腕的觸感。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是用",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家的一部分……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
