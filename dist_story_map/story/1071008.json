        "voice": "vo_adv_1071008_083"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "確實……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_084"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n和他人一起攜手生活，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實在是件很煩人的事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n相較之下，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一個人獨自解決問題要快得多了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──只不過，",
