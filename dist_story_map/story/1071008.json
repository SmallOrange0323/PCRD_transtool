    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──好。",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_088"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我們回去吧，",
