[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順利躲過中止危機的結婚生活模擬演習，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在那之後也很順利地繼續著。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "表面上看似如此──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不對勁。",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼到了這時間還不回來？",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n他的工作應該早就已經做完了才對。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "最近幾天",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都這樣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算問他原因，他也會很明顯地轉移話題……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該不會……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子他不可能……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不，正因為是小子，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以有可能嗎──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_006"
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "抱歉突然問個怪問題，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你有看到一個穿披風的暖男嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n他應該是走這條路回家的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "穿披風的暖男？",
        "unit_id": 4911,
        "voice": "vo_adv_1071008_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "穿披風的暖男……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……呵。",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然是自己的行為，但還是忍不住讓我露出苦笑。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒想到被稱為狂犬的女豪傑克莉絲提娜，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n竟然會因為嫉妒這種動機，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跑來四處打聽老公的下落……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊啊，",
        "unit_id": 4911,
        "voice": "vo_adv_1071008_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這麼說來我是有看到！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n他往那邊的方向走了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他是一個人嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不。",
        "unit_id": 4911,
        "voice": "vo_adv_1071008_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不是一個人。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n感謝",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的情報。",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500400"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這邊嗎……？",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n竟然跑到這種沒有人煙的地方，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "究竟是打算和誰做什……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你這混帳，",
        "unit_id": 911,
        "voice": "vo_adv_1071008_016"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "再不老實招來，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "小心吃上苦頭！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n克莉絲提娜到底在哪！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_017"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "別給我裝傻！",
        "unit_id": 811,
        "voice": "vo_adv_1071008_018"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n我們早就掌握到情報，她現在跟你這混帳住在一起！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "都怪那傢伙突然間不見蹤影，",
        "unit_id": 6311,
        "voice": "vo_adv_1071008_019"
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "\n你瞧，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "想和她打招呼的客人都像這樣大排長龍啦。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你肯定也感到很困擾吧？",
        "unit_id": 911,
        "voice": "vo_adv_1071008_020"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n連續好幾天都有像我們這樣",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "長得凶神惡煞的傢伙跑到職場來。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你要天天",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "成功把我們全甩掉才回家，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "也是很費心思吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………！　",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_021"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "我也覺得不太好意思啊？",
        "unit_id": 911,
        "voice": "vo_adv_1071008_022"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "可",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "是哪，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "追根究柢，就要怪那傢伙先前把我們痛扁一頓。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n這可是克莉絲提娜播下的禍種。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你就告訴我們",
        "unit_id": 911,
        "voice": "vo_adv_1071008_023"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "那傢伙在哪吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "好不好？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來是這麼一回事嗎……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_024"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "你這混帳家伙──",
        "unit_id": 811,
        "voice": "vo_adv_1071008_025"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n我們不過是好聲好氣了點，你就囂張起來啦！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n如果硬是不肯說，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "就只好讓你嚐嚐苦頭！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "給我慢著……！",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們這些傢伙是什麼意思？",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟然想瞞著我偷偷和小子加深感情哪。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真令我感到嫉妒啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "暴徒們",
        "words": "──是克莉絲提娜！",
        "unit_id": 1,
        "voice": "vo_adv_1071008_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們很想見我啊？",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那還真是抱歉哪，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一直放著你們不管。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就坦白告訴你們吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我現在已經是人妻了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以你們對我這些日積月累的感情，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要全數斬斷，扔到一旁去。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n──好啦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "放馬過來！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "……妳總算現身啦？",
        "unit_id": 911,
        "voice": "vo_adv_1071008_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子──！",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們幾個打算做什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們的目標是我才對吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "沒錯，妳確實是我們的目標。",
        "unit_id": 911,
        "voice": "vo_adv_1071008_033"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "不過如果我們直接和妳打，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "可說是幾乎不可能打贏。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "照目前的狀況看來，",
        "unit_id": 911,
        "voice": "vo_adv_1071008_034"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你們應該是結婚了吧……？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "竟然願意為了保護妻子，而親自涉險，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n妳還真是找到了一個好老公啊，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "克莉絲提娜。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "只不過，",
        "unit_id": 911,
        "voice": "vo_adv_1071008_035"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "抱歉啦，就讓我好好利用他一下。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "這傢伙",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "現在起就是負責擋下妳攻擊的盾牌了♪",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………唔！",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_036"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "哇～哈哈哈！",
        "unit_id": 911,
        "voice": "vo_adv_1071008_037"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n看到沒？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "欸，你們看到沒？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n這還是我第一次見到",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "克莉絲提娜露出動搖的表情啊～！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……現在要讓小子有機會逃走，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再把這些傢伙教訓一頓，對我來說可謂簡單至極。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n用不到幾秒就能解決。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "問題並不在那裡。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而是在於小子",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他想要保護我這點上。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──確實，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我已經決定無論發生什麼事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都要與小子同進退。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然而我當初，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是否有料想到小子竟會為了我劍下產生的恩怨，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而選擇自己將性命，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "暴露在危險之下的情況……？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "自己積下的恩怨要自己清算，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你別出手……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算我這麼說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那傢伙恐怕也不會乖乖聽話吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果有危險要逼近我，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n他就會打算先用自己那纖細的手將其擋掉。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他就是那樣的男人……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_047"
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "嘿嘿嘿！",
        "unit_id": 6311,
        "voice": "vo_adv_1071008_048"
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "\n瞧妳這傷腦筋的模樣。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "\n誰叫蘭德索爾最凶猛的狂犬，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "竟然選擇結婚了呢～",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "果然，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我和小子的人生無法有所交會。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是不該有",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "交會的──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子他正在……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "向我傳達什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "交給我吧……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我會閃過攻擊的……？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子……！",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你該不會……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打算在最後一刻閃過我的攻勢，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n然後讓攻擊打中在背後的流氓們吧……！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這狀況我一個人就足以解決。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而且說到底，這是我得自己收拾的問題。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你沒有必要再繼續擋在我──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "希望我能交給你？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n頭……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "髮……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就像弄乾",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "頭髮時那樣……？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，小子。",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然你說得好像很簡單，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但你明白要躲過我的攻擊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是件多困難的事嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這道理可和弄乾頭髮不同──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為想和我……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一起跨越這道難關……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……重要的並非",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事務的大小……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而是願意彼此託付這點……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣才是",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所謂的攜手共進退……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n道理是……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相同的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………！",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_063"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "喂，",
        "unit_id": 911,
        "voice": "vo_adv_1071008_064"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你們在那邊磨磨蹭蹭地說些什麼！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n如果不打算抵抗，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "我可就要出手──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "─",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "─好。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n小子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就託付給你了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈☆",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_066"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n手下留情？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這話是在對誰說呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要上了，小子！",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可別死囉──☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「極值聖域」！",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_068"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "嗚哇啊啊啊，",
        "unit_id": 811,
        "voice": "vo_adv_1071008_069"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "那傢伙",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "正面攻過來了！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n她打算連自己的老公一起殺掉嗎！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "別退縮！",
        "unit_id": 911,
        "voice": "vo_adv_1071008_070"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n那傢伙的攻擊是絕對不會打偏的。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "就把她老公當成盾牌──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "──啊啊！！？？",
        "unit_id": 911,
        "voice": "vo_adv_1071008_071"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n這傢伙……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "竟然閃過了克莉絲提娜的攻擊！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "怎麼可能──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒們",
        "words": "唔啊啊啊啊啊啊啊────！",
        "unit_id": 1,
        "voice": "vo_adv_1071008_072"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們太小看夫婦間的羈絆了♪",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_073"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好啦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "剩下的傢伙也放馬過來吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就讓你們用身體好好記住，",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_074"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對克莉絲提娜的老公出手是什麼下場☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "唔啊啊！？",
        "unit_id": 6311,
        "voice": "vo_adv_1071008_075"
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "\n這次……",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒3",
        "words": "她連劍都沒揮，卻出現了劍的攻擊軌跡！？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「演算劍桌」！",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_076"
    },
    {
        "type": "dialogue",
        "name": "暴徒們",
        "words": "呃啊啊啊啊啊──！！",
        "unit_id": 1,
        "voice": "vo_adv_1071008_077"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "不行，",
        "unit_id": 911,
        "voice": "vo_adv_1071008_078"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "這下要收到找她碴的一萬倍回禮了……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "跟平時是相同的發展！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n快逃啊──！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒們",
        "words": "唔哇啊啊啊啊──！",
        "unit_id": 1,
        "voice": "vo_adv_1071008_079"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哼。",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_080"
    },
    {
        "type": "background",
        "background": "500400"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071008_081"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你不要搶走我要說的台詞啊。",
        "unit_id": 107111,
