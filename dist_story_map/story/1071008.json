        "voice": "vo_adv_1071008_085"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來有些景色……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎只有一起跨越難關後才能看到呢。",
