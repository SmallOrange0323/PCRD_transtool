[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒看到魔物的身影……",
        "unit_id": 105911,
        "voice": "vo_adv_9036156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被牠逃走了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為身體軟趴趴的關係沒能抓住呢～",
        "unit_id": 105811,
        "voice": "vo_adv_9036156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被魔物的黏液弄得黏糊糊了啦……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～真是的！　",
        "unit_id": 106011,
        "voice": "vo_adv_9036156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好噁心啊～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好不容易沖完澡很舒服的說！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯。",
        "unit_id": 105911,
        "voice": "vo_adv_9036156_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種黏糊糊的感覺，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很讓人不舒服……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或許是這樣沒錯……",
        "unit_id": 105811,
        "voice": "vo_adv_9036156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像反而也",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別有一番樂趣？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看招──！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸！　",
        "unit_id": 106011,
        "voice": "vo_adv_9036156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可――！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳幹嘛抱住我啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要把黏糊糊的往我身上擦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_9036156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐真是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是蠻有趣的感覺。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下失敬了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘿！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇！？　",
        "unit_id": 106011,
        "voice": "vo_adv_9036156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就連可蘿仔也是這樣在幹嘛啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "討厭！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我走開！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊嗚……",
        "unit_id": 105911,
        "voice": "vo_adv_9036156_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被掙脫了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 105811,
        "voice": "vo_adv_9036156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的那麼討厭我們嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸……",
        "unit_id": 106011,
        "voice": "vo_adv_9036156_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們幹嘛一副那麼落寞的表情啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n並、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "並不是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "討厭妳們，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是因為黏呼呼的讓人不舒服很討厭而已！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼那麼，",
        "unit_id": 105811,
        "voice": "vo_adv_9036156_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個意思是喜歡我們嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對吧對吧，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蛤、",
        "unit_id": 106011,
        "voice": "vo_adv_9036156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蛤啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎怎怎、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼突然說些奇怪的話呀妳！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9036156_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的臉好紅呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "～～～～～！！　",
        "unit_id": 106011,
        "voice": "vo_adv_9036156_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在可不是閒聊的時候吧！？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "追上剛剛那傢伙吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不好好收拾掉牠的話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就不能好好沖澡了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿～",
        "unit_id": 105811,
        "voice": "vo_adv_9036156_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "害羞的小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真可愛呢！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好吧——",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼我們就追上牠吧——！",
        "unit_id": 105811
    }
