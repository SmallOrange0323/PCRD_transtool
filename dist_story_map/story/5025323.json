[
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呼，",
        "unit_id": 111211,
        "voice": "vo_adv_5025323_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呼……！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n還沒辦法解決它嗎！？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n真頑強呢～",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "它好像還留有強大的力量！",
        "unit_id": 111111,
        "voice": "vo_adv_5025323_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "到最後都不能掉以輕心！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "幻影男爵",
        "words": "嗚吼吼吼吼吼吼吼！！",
        "unit_id": 12111,
        "voice": "vo_adv_5025323_002"
    },
    {
        "type": "dialogue",
        "name": "幻影男爵",
        "words": "\n把花、",
        "unit_id": 12111
    },
    {
        "type": "dialogue",
        "name": "幻影男爵",
        "words": "把花還給我啊啊啊啊！！",
        "unit_id": 12111
    },
    {
        "type": "dialogue",
        "name": "幻影男爵",
        "words": "我想在她身邊！！",
        "unit_id": 12111,
        "voice": "vo_adv_5025323_003"
    },
    {
        "type": "dialogue",
        "name": "幻影男爵",
        "words": "　不想被她忘記！！",
        "unit_id": 12111
    },
    {
        "type": "dialogue",
        "name": "幻影男爵",
        "words": "\n僅此而已啊啊啊啊啊啊！！",
        "unit_id": 12111
    },
    {
        "type": "dialogue",
        "name": "幻影男爵",
        "words": "\n為什麼要來礙事！！",
        "unit_id": 12111
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "唔！！",
        "unit_id": 111311,
        "voice": "vo_adv_5025323_004"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n不行啦！！",
        "unit_id": 111311
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "　因為花是活人啊！",
        "unit_id": 111311
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n要好好的跟她告別才行！",
        "unit_id": 111311
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "美美說得沒錯！",
        "unit_id": 111111,
        "voice": "vo_adv_5025323_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你差不多",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該死心了！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不懂事的傢伙，就要全力讓他懂才行呢！",
        "unit_id": 111211,
        "voice": "vo_adv_5025323_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們走吧！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "　美美、",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n就這麼了結它吧！",
        "unit_id": 111211
    }
]