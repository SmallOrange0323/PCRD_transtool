[
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]{player}一行人取回碧卡拉被奪走的老鼠耳朵，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n[FFFFFFFF]平安地回到蘭德索爾的隔天早晨──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n[FFFFFFFF]吉塔一個人在城鎮裡走著。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嗯──",
        "unit_id": 105712,
        "voice": "vo_adv_5118600_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]天氣真好！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]接下來，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]今天有什麼委託呢？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哎呀？",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_001"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]在那邊的不是吉塔嗎！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "冬麥斯",
        "words": "[FFFFFFFF]──！",
        "unit_id": 9711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]碧卡拉、",
        "unit_id": 105712,
        "voice": "vo_adv_5118600_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]小冬！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]你們好啊！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]昨天睡得好嗎？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_003"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]睡得很好！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]託妳的福我現在精力充沛、",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]精神飽滿！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]還早起做了追加的老鼠耳朵喔♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]話說回來吉塔在做什麼呢？",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我正好要去確認",
        "unit_id": 105712,
        "voice": "vo_adv_5118600_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]有沒有給騎空團的委託！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]為了獲得騎空艇，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]也為了鍛鍊自己，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我想要完成很多委託。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]而且，",
        "unit_id": 105712,
        "voice": "vo_adv_5118600_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]如果見到各種人",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]就能聊各種話題對吧？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]在這當中",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]說不定會獲得能在騎空團派上用場的情報！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]原來如此，",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_007"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]吉塔真了不起呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]朝著自己的夢想筆直前進著！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]現在這個時間花凜似乎也在公會管理協會工作……",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_008"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]得向妳們兩人的勤勞看齊呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我也要投入修行囉！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]啊哈哈，",
        "unit_id": 105712,
        "voice": "vo_adv_5118600_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]過獎了啦～",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]而且我也不是一直在工作喔？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]我還想要去跳蚤市場。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]現在也還在舉辦……",
        "unit_id": 105712,
        "voice": "vo_adv_5118600_010"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]說不定",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]又能找到珍品呢。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]說到跳蚤市場，",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_011"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我之後也會繼續擺攤喔。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不過要先備齊老鼠耳朵",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]才行呢♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]為此我現在正在全力製作中！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]還有……",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_012"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]啊啊，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]對了！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]其實我還拜託了{player}帶我參觀城鎮。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]因為我才剛來蘭德索爾啊。",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_013"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]所以有好多想知道的事喔！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]這個城鎮的事情",
        "unit_id": 105712,
        "voice": "vo_adv_5118600_014"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]問他就對了。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]他知道很多店，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]也認識很多人呢。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]一定會有美好的邂逅喔！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_015"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]那很棒呢！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]我會滿心期待",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]新的邂逅！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嗯，",
        "unit_id": 105712,
        "voice": "vo_adv_5118600_016"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]要玩得開心喔！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]碧卡拉，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]擺攤加油！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]祝妳有個美好的邂逅！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗯嗯！",
        "unit_id": 125611,
        "voice": "vo_adv_5118600_017"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]妳也是喔♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]吉塔是為了在騎空團活動上更加活躍──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n[FFFFFFFF]而碧卡拉是為了鼠神宮和自身的修行──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n[FFFFFFFF]她們各自開始了在蘭德索爾的日常生活。"
    }
]