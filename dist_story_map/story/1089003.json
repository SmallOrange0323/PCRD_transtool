[
    {
        "type": "background",
        "background": "500023"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "繼續著逃亡之旅的怜與{player}，\n被追兵發現後，逐漸失去退路。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這邊也是死路嗎……！",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_000"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "怜小姐，",
        "unit_id": 1211,
        "voice": "vo_adv_1089003_001"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "您已經無路可逃了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "請死心吧。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "\n現在回頭的話，老爺還是肯原諒您的。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真纏人！",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我追求自由有什麼不對！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "……如果您還要繼續抵抗的話，",
        "unit_id": 1111,
        "voice": "vo_adv_1089003_003"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "有可能連您的同伴也受到傷害。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼！",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟他沒有關係吧！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "他跟您一路逃到這裡來，",
        "unit_id": 1111,
        "voice": "vo_adv_1089003_005"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "要說沒有關係，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "是一點說服力都沒有的喔。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "怜小姐跟那位先生很親近的這件事，",
        "unit_id": 1211,
        "voice": "vo_adv_1089003_006"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "\n我們已經有調查過了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "基於任務，",
        "unit_id": 1111,
        "voice": "vo_adv_1089003_007"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "為了帶回怜小姐，我們會不擇手段。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "畢竟，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "老爺就是這麼交待下來的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "來吧。",
        "unit_id": 1211,
        "voice": "vo_adv_1089003_008"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "請您不要抵抗，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "跟我們走。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……到此為止了嗎。",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經無路可逃了……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n更何況，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果因為我的關係讓你受到危害，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也不能接受。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……謝謝你一路上的陪伴。",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是到此為止吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不能再",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "繼續把你捲進來了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……要是會失去重要的夥伴，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那還是老實的照父親的意思走就好了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我知道了，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我投降！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不准碰他一根寒毛！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "很明智的判斷，",
        "unit_id": 1111,
        "voice": "vo_adv_1089003_014"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "請移駕到這邊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n我們為您安排馬車。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說到底都是不可能實現的願望嗎……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和、",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有連你也都得失去的話，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我寧願放棄「自我」。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣就好了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣子……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──！！",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還真是狡猾呢，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你這個人啊。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聽到這種話，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不就又讓我的決心動搖了嗎。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "喂，放開手！",
        "unit_id": 1111,
        "voice": "vo_adv_1089003_019"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "就算您是跟怜小姐關係曖昧的男人，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n再有更過分的行為我們可不能容忍！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "怜小姐也請您",
        "unit_id": 1211,
        "voice": "vo_adv_1089003_020"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "說服您的情人！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼、",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不、",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他不是什麼情人……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟剛才的貴族一樣誤會了……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真麻煩啊。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼跟父親說明才好……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……啊啊，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果這樣的話，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就乾脆麻煩到底好了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……那個，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n既然你都這麼阻止我放棄了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不論什麼事情你都會幫忙吧？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎。",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就開始囉，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不要動喔……！",
        "unit_id": 108911
    },
    {
        "type": "still",
        "still": "108900301"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……拜託你。",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "暫時，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "維持這樣子。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "什麼！？",
        "unit_id": 1211,
        "voice": "vo_adv_1089003_027"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "怜、",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "怜小姐！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "\n在這種眾目睽睽的地方，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "做出那種行為……！！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謠言就讓它越描越黑好了……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n為了讓他們相信，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的決心是貨真價實的。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "不准看！",
        "unit_id": 1111,
        "voice": "vo_adv_1089003_029"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "絕對不准看啊！！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "直到我說可以睜眼之前，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "都要閉上眼睛！！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "是，",
        "unit_id": 1211,
        "voice": "vo_adv_1089003_030"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "是的！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來是很順利了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "儘管讓他們看吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "臉靠得好近……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺得到肌膚的溫度。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算想別過視線，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻還是移不開……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還有微熱的吐息……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "居然和你靠得這麼近……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對我來說還真是大膽……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果有天不是和你演戲，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就這樣子真的……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是別想了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "繼續下去的話優衣會生氣的。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "香味？",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這樣嗎？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到處跑來跑去的留了些汗，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想應該沒有那種事……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……總感覺突然想要放開你了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不要問理由。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以拜託了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嚇得都不敢問了，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但我好像沒有汗味。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太好了呢……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不用在意",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那種事情。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n現在也不是講求什麼矜持的時候了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有什麼汗味啊。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我反而覺得這味道還不錯……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛剛的就忘了吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到底在亂說什麼啊我。",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……或許是因為氣氛剛好呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……也差不多了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放開吧……",
        "unit_id": 108911
    },
    {
        "type": "background",
        "background": "500023"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼樣！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣就明白了吧？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "怎麼會……",
        "unit_id": 1111,
        "voice": "vo_adv_1089003_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "去吧，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "回去告訴我父親！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我已經有了要託付終身的對象！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是絕對，",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不會讓那個人稱心如意的！！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "怜小姐，",
        "unit_id": 1111,
        "voice": "vo_adv_1089003_047"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "您這樣……",
