        "type": "dialogue",
        "name": "男追兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "會有怎樣的後果，我們可不能保證啊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n……撤退了！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "女追兵",
