        "voice": "vo_adv_1089003_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這麼一來，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "至少在父親的下一道命令前，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可以暫時平穩的過日子吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才說什麼託付終身的，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那句只是逢場作戲而已，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我到現在都沒考慮過。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對我來說可真是不切實際呢……",
