        "unit_id": 108911,
        "voice": "vo_adv_1089003_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這樣沒錯。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就像你說的。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "把和重要的夥伴的約定、",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "重要的願望實現。",
