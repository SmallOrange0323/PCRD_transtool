    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 108911,
        "voice": "vo_adv_1089003_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "順利挨過了呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你願意幫我。",
