[
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好，",
        "unit_id": 127511,
        "voice": "vo_adv_5128203_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "打倒它了！",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "──咦？那傢伙！",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "居然還能動！？",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來事情還沒有",
        "unit_id": 127611,
        "voice": "vo_adv_5128203_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就這樣告一段落呢。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對手",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "似乎在被徹底破壞前都不會停下來。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那傢伙，",
        "unit_id": 127511,
        "voice": "vo_adv_5128203_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是打算從它逃向的地方再射出那道光線嗎？",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "居然",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要在這大得要命的沙漠中玩鬼抓人，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是讓人受夠了……",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但如果不管它，",
        "unit_id": 127611,
        "voice": "vo_adv_5128203_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是被那道光線射到也不是鬧著玩的呢。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只能靠我們來打倒它了，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "快去追它吧。",
        "unit_id": 127611
    }
]