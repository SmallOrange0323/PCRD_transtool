        "voice": "vo_adv_5202064_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒有問題呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "伴唱和聲的大家",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也都幹勁十足。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "演出的部分，",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_001"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "彩排已經結束了……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "看來，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "不會有問題……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……大、",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "大概……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這些",
        "unit_id": 134411,
        "voice": "vo_adv_5202064_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都是多虧了大家的幫忙呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "託大家的福，我想內容應該會很精彩。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一開始是有那個打算的。",
        "unit_id": 134411,
        "voice": "vo_adv_5202064_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n紡希也說了",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「我會做出最適合妳們的衣服！」",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "，\n整個人充滿幹勁。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我和千歌……",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_004"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "兩人",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "一起決定了……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "如果要站上",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "舞台，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "就穿這套",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "衣服……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "而且……",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_005"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "紡希。",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "不曉得為什麼……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "知道，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我的三圍……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "有時候……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "會用很嚇人的眼神，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "盯著",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我看……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "彷彿像是……",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_006"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "全身，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "都被舔過似的……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "一想到，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "又要被那樣的眼神",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "注視……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "就覺得，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "有點困擾……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這套衣服",
        "unit_id": 134411,
        "voice": "vo_adv_5202064_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也是充滿了心意的重要衣服。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我覺得要答謝村裡的大家，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "穿這套再適合不過了。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 134411,
        "voice": "vo_adv_5202064_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希覺得非常不甘心就是……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但她也說了",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「我『這次』就放棄」，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看起來是把精力放到其他機會上了，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一定不用擔心的。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "咦……？",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_009"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "其他機會……",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_010"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "她應該",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "不會擅自……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "幫我製作衣服，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "對吧……？　",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的！",
        "unit_id": 134411,
        "voice": "vo_adv_5202064_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那麼蘭法小姐，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們上場吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好、",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_012"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好的……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "…………",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "呼……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是呀……",
        "unit_id": 134411,
        "voice": "vo_adv_5202064_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是能說",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "自己不緊張的話就好了。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但是開幕之前",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總是會覺得緊張。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 134411,
        "voice": "vo_adv_5202064_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是作為偶像，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而是以唱喚士的身分舉辦演唱會，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這種事在過去根本無法想像呢……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我覺得，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有點感觸良多。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我也是……",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_015"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "在大家面前",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "唱歌",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "這種事……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "本來，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "覺得已經不會",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "想再這麼做了……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "雖然，",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_016"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "非常地",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "緊張……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……但是，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "也有一點",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "覺得",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "高興……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n真不可思議……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我記得……",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_017"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "是幫忙……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "和聲，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "對吧……？",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "那樣的話，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "如果……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我覺得，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "要負荷不來",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "的時候……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我會",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_018"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "側耳，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "去傾聽",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "你的",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "歌聲……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "這麼一來，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "肯定",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "就不會",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "有問題了……",
