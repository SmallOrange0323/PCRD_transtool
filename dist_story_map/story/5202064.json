    {
        "type": "dialogue",
        "name": "旁白",
        "words": "忙碌又開心的準備期間很快就過去……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n精靈族之村"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "迎來了舉辦演唱會的當天。"
    },
    {
        "type": "background",
