    },
    {
        "type": "background",
        "background": "501202"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不只是村民們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "連路過附近的旅行者和商人都加入的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n超客滿演唱會就此開幕──"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "恐怖的東西……",
        "unit_id": 134311,
        "voice": "vo_adv_5202064_019"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "是不能，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "就那樣",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "直接使用……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "但如果",
        "unit_id": 134311
    },
