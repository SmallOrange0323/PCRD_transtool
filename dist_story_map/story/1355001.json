[
    {
        "type": "background",
        "background": "501651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過去埃拉作為管理者統治的伺服器"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「天貓座」。"
    },
    {
        "type": "background",
        "background": "502610"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束了管理者職責的埃拉，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "如今──"
    },
    {
        "type": "background",
        "background": "502520"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先～生！",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_000"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這邊這邊～！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好久不見了！",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不，也不算久吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "看你的樣子，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "似乎非常有精神，真是太好了！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "前陣子因為事情太多了～",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n連放鬆的時間都沒有啊？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n沒能為你介紹這個世界真是抱歉呢～！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以，",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_003"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然也不算是補償。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n但是今天就由我埃拉，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "帶你遊覽薩拉薩利亞吧！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "──就是這樣♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_004"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你有點拘謹耶！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n態度再放輕鬆一點吧，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "放～輕鬆♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "畢竟是我跟騎士先生的交情嘛，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不需要客氣喔？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好嗎！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈♪",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_005"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很好，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是這樣！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那就馬上出發吧。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n首先，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "從我最喜歡的地方開始──",
        "unit_id": 135511
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "乾杯────！！",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_006"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n啊哈哈哈！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "來，大家一起喝吧～！！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咕嚕咕嚕咕嚕……",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "噗哈──！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊～",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "沁人心脾～～",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n薩拉薩利亞的赤麥酒果然是最棒的！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_008"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n好啦好啦，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "別擺出那種臉嘛。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我會這樣是有理由的。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這間店啊，",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "從很久以前就開在這了。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "它有提供薩拉薩利亞的特色傳統料理喔♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "因為，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生是【美食殿堂】的人對吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你想了解",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_010"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好吃的料理吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要是向公會的大家分享旅行趣聞，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "還有料理的食譜，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我想大家一定會很高興的♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生的世界，",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_011"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "和我的世界。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n不同世界，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也會有不同文化。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "料理的味道當然也是囉？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "其他世界的薩拉薩利亞料理是什麼味道，",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_012"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n實際去確認一下，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我想",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "應該也會是很好的經驗。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就如同字面上的意思，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對於「不同世界的味道」",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你有興趣對吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……不過這只是",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "一半的理由。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "另外一半，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "只是我自己想喝啦～♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嘿嘿嘿！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "來！",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_014"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生也快點餐吧！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這裡的坦都里烤雞可是極品喔。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n這味道啊～",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "真的跟麥酒很搭呢～！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊，",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_015"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生喝的是這個。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n用在沙漠綠洲採到的果實榨的新鮮果汁！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這附近的小孩都很喜歡這個喔。",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n味道酸甜，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "在炎熱時也能讓人打起精神呢。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生一定也會喜歡的♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "畢竟麥酒",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_017"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "在這個世界也是成人的飲料，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我會好好地等到",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生能喝酒的時候，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你就放心吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好了，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那麼再來一次，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "乾杯！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "酒館的客人１",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1355001_018"
    },
    {
        "type": "dialogue",
        "name": "酒館的客人１",
        "words": "今天也喝得很爽快呢，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "酒館的客人１",
        "words": "埃拉大人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我已經不是管理者了！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "叫我埃拉就好啦！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "而且，",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_020"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯咕、",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯咕……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哈。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n果然還是人多一起喝比較開心呢～！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這樣也更好喝！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "怎麼樣啊大家？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "一起來喝吧♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "酒館的客人１",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1355001_021"
    },
    {
        "type": "dialogue",
        "name": "酒館的客人１",
        "words": "那我們也不客氣了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "酒館的客人１",
        "words": "\n你們幾個，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "酒館的客人１",
        "words": "今天要大喝一番喔～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "周圍的客人們",
        "words": "哦哦～～～～！！",
        "unit_id": 1,
        "voice": "vo_adv_1355001_022"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咦？",
        "unit_id": 135511,
        "voice": "vo_adv_1355001_023"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你的杯子空了喔～？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
