[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吃吧，這是慶功宴哦！",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n多虧了你，工作大功告成了呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們互相分享這份喜悅吧♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟也因為種種原因，一起工作了一整天呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一起慶祝才合乎情理是吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔呵呵呵……♪",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉呀，不小心發出有點粗俗的笑聲了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，笑容完全止不住～",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n確實完成工作後，覺得特別滿足呢♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，能夠感受到自己活著！",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n努力工作果然會令人開心……☆",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵……{player}。\n多虧了我，才能順利完成任務是吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這頓飯，就讓你請吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "狩獵了比預想中更多的蟲，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你也能領到更好的報酬對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "開玩笑的～",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "平分付錢就好了，我本來就沒打算欠你人情。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "多虧你拉貨車，我也得到了幫助呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "彼此都互相得到了照應。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不用啦，雖然男方應該請客似乎是一種流行……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我和你都這麼熟了，不用客氣啦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖這麼說～但我們幾乎算是剛認識不久呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過你給我的感覺，卻像是認識十幾年的知心朋友。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是為什麼呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸……",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要跟我裝熟啦，真是厚臉皮呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼？難道說你有金錢方面的困擾嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不介意的話，我也能替你介紹工作哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n各個店家和公會可是很給我面子的♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算了沒關係，比起那個……",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以由我決定點什麼菜嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個嘛，原因說來話長。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我運送的果實，叫做橄欖。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為你也在一旁看著，應該也知道。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這間店把那些橄欖全都買下來了哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我正好得從深山中的老家裡，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n運送各種東西過來。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以就「趁機」，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n用低價從熟識的旅行商人那裡買下許多橄欖運過來了。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "蘭德索爾的人們，雖然不太熟悉橄欖……",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過在稍遠的國家，這是很常被用在菜餚中的食材哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，因應各國狀況，有些國家會藉此大量生產，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n並且可以用便宜的價格買到。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然而，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n橄欖在蘭德索爾卻非常稀有，於是就被當成高價的珍貴食品。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就利用這樣的價差，賺了一筆哦。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟不是常見的食材，一般的店家也不會願意購買。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正因為如此……在這之前，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n先傳授了這間店橄欖的烹飪方法哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當然，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也約定好要店家以更高的價錢買下橄欖。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因此這間店，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就成了在蘭德索爾非常罕見，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能端出橄欖菜餚的店家。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而我也能獲利，之後持續和這間店做生意……",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也就是還會有「下次」。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "做買賣，就是必須要把眼光放遠。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n獲得僅僅一次性的利益，就等同賭博。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "販賣商品前，首先要創造需求。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n接著挖掘買家，並且盡可能地提高商品價值。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是買賣的基本準則呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是把想賣的商品擺在店裡後，才開始想販賣方法就太遲了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n沒有任何人有所損失，才是最理想的交易哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如此一來，我、這間店，甚至是這間店的客人……",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家都能夠皆大歡喜。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "平常也不是都這麼順利的。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n今天也是，要是沒有偶然遇到你……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不知道實際的狀況會如何演變呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過呢……",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不能畏懼失敗，必須勇往直前。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟我還有想要守護的事物呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n明天也得努力工作，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們現在先好好吃一頓補充營養吧♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……所以就盡量點用橄欖做的餐點吧，",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我想先嘗嘗看味道，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以才選了這間店辦慶功宴哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是把賺得的錢，在這間店裡花掉。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這麼做的話，店家對我的好感度也會提高對吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然後店家應該還會想繼續和我交易哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "金錢是流通於世界的東西哦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "流來轉去，應該和我的利益也息息相關。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來吧，盡量點！",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你畢竟是個男孩子，食量很大吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "多吃多工作，這就是人生的醍醐味哦！",
        "unit_id": 102811,
        "voice": "vo_adv_1028003_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n沒有錯吧，{player}♪",
        "unit_id": 102811
    }
]