[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和為了迎接明天的武鬥會，\n正在公會之家養精蓄銳中。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明天就是正式比賽了，",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n得讓身心都是萬全的狀態才行……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天要做的事……",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。一件也沒有。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好～，要好好休息一下呢！！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……（東張西望）。",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……（坐立難安）。",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "…………",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "心癢癢！ 心癢癢呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊～不行了！ 不做點事的話我冷靜不下來呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有沒有些事，是現在的我可以做的呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是為了明天可不能不休息，",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因此也不能做練習……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！ 去散步吧！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "轉換心情也是很重要的呢！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～……雖然是走到外面了……",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但只是走路的話，心裡還是很不安呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有沒有……有沒有一些事可以……",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦！ 在那邊的是！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗨～，騎士先生！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吶吶，騎士先生現在有沒有正在煩惱的事呢！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我呀，現在的話任何事都可以幫騎士先生解決喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在沒有嗎……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣呀，真可惜。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個呢……其實明天就是武鬥會了，",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我原本想把今天當成什麼都不做的休息日……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過不做點什麼的話我冷靜不下來！！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦好呢！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吶騎士先生！ 我該怎麼辦才好呢……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n騎士先生知道能讓我安分休息的方法嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來如此！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "人、人、人……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個就是讓自己不緊張的咒語嘛！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來如此！ ",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那就拜託騎士先生了唷！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n請把我綁起來吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……但這樣根本就無法休息呀！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n只會變得更累而已呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚嗚……怎麼辦呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我完全不懂得休息的方法！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生說不要勉強我自己，是指什麼意思呀？",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我根本沒有勉強自己呀。",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我讓自己不要強迫做練習，真的想好好休息的唷？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……雖然完全沒休息到就是。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來如此呀。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n原來",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我在勉強自己休息呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果因此而讓狀況變差的話，",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n至今的努力就會白廢了呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝，騎士先生。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我決定了。果然我還是，要做回平時的自己。",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我不想讓自己在失去自我主張的狀況下戰鬥呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "很痛痛痛…",
        "unit_id": 411,
        "voice": "vo_adv_1001006_025"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "…",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然如此！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我現在就去幫助那位看上去好像遇到麻煩了的人！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個，妳沒事嗎？ 哪裡覺得痛呢？",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_028"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我剛剛在走斜坡的時候，不小心絆倒了……",
        "unit_id": 411,
        "voice": "vo_adv_1001006_029"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n一想要抬腳舉步疼痛就……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "糟了……！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們帶妳回去城鎮吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可以嗎……？",
        "unit_id": 411,
        "voice": "vo_adv_1001006_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當然可以！ 遇到麻煩時互相幫助幫助！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "走吧騎士先生！ 全速前進～！！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那位大姐姐的傷勢，好像很快可以康復呢。",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果放著她不管的話，會出什麼意外都很難說的呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，今天真是謝謝了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "多虧了騎士先生，我明天可以用最佳狀態出戰武鬥會了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……如果方便的話、請來幫我打氣加油唷。",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣子呀……",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生有工作在身呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那就沒辦法了呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嗯、",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我明白了！ 直到那之前我會努力晉級上去的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果騎士先生太晚的話，我可是會直接拿到優勝囉！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘻嘻……開玩笑的啦！",
        "unit_id": 100111,
        "voice": "vo_adv_1001006_038"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這瞬間，日和心中\n又多了一個不能輸的原因。"
    }
]