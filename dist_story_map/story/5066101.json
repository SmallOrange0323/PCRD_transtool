    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜實在是個笨蛋打架狂耶……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那祈梨又會想做什麼啊？",
        "unit_id": 106511,
        "voice": "vo_adv_5066101_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我嗎？",
