        "voice": "vo_adv_1059011_037"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下感覺自己的心跳",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "莫名地加速。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "幻想著不知長相，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_038"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也不知名字，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下未曾謀面的……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "未來主人的",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "樣貌。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_039"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "簡直就像是",
