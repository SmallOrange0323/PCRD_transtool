        "voice": "vo_adv_1059011_036"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "會學到很多東西，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n總有一天，在下會",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在不知不覺中成長到",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n與父親旗鼓相當的程度。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "聽到她這麼說的時候，",
