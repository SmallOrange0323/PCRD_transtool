[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "離開公務機關回家的路上，{player}和可可蘿\n悠閒地在街上漫步。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天天氣真好呢！",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種日子",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會讓人很想躺在綠色的草坪上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓全身感受",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太陽公公的溫暖。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦呀。",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您剛剛打了一個很大的呵欠耶，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要不要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍微睡個午覺再走？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "汪汪！",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "汪汪主人好像有點",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n精力過剩的樣子呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，稍微",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去那邊草地玩耍一下也可以喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請注意不要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跑太遠喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請人類主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過來這邊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請把在下的膝蓋",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當作枕頭躺下吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩邊都同一個名字，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下只好",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直主人主人地叫，真是忙碌。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過已經是很熟悉的名字了，",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n叫再多遍都沒問題。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說起來，",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從在下把主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稱為主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到現在也已經過了一段時間呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回想起來真的",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有很多……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這道光，",
        "unit_id": 105913,
        "voice": "vo_adv_1059011_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是愛梅斯大人的……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還好是在柔軟的草地上",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "510140"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "抱歉突然把您叫出來，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_011"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下是您忠誠的僕人－",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "棗 可蘿。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊……",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_012"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真的是非常抱歉。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您說過",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "盡量不要",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在人前稱呼您主人吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不過現在周圍沒什麼人",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_013"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "應該沒關係吧？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那真是太好了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "果然，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "面對主人",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "卻不叫主人，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "總覺得很不習慣。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人……",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "話說回來，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "今天還真熱。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n附近人會很少",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "應該也是因為這樣吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這是",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "冰涼的果汁",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n這是給在下的嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……咕嚕，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "咕嚕。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "謝謝您，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人您",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真是溫柔……♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不過",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這個只有一瓶。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這樣的話",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人也會口渴。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "可是",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也不能因為這樣，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就辜負主人的好意。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "所以，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這瓶果汁",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我們就一人一半吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下剛剛已經喝了一口了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "接下來",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "輪到主人了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "哇～",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您喝果汁的樣子真豪爽……♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n那麼，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "接下來換我了――",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好了，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_022"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "現在也解渴了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n就讓我們切入正題吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人……",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_023"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n米奈娃",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這個名字，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您有聽過嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "本該待在WISDOM的她，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_024"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n前一陣子",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "卻失蹤了……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "其實最近，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "她有與在下聯繫。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "內容提到",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_025"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n自己平安無事，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還有――",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "――迷宮女王的",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_026"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "公主騎士",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這件事。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是的。",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_027"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n正如您所猜測的……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "她是掌管阿斯特朗傳奇",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_028"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "營運管理的",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\nAI……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "人工智慧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真的非常抱歉。",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_029"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下說明得不夠充分，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嚇到您了吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "管理阿斯特朗傳奇的AI－",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_030"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n米奈娃，其開發團隊中的一員",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "正是在下的父親。",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "105901101"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而在下",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_031"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "則從旁協助父親的研究，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n經常擔任和米奈娃對話的",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "『說話對象』。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "根據父親的說法，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_032"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "要讓人工智慧成長，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "須讓它與真正的人類大量對話。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n因此在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "被選為她的",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "『說話對象』。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為了協助父親研究，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_033"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "常常和米奈娃聊天。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n聊的內容幾乎都是一些",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "閒聊和日常生活的對話而已……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但也因為這樣，",
        "unit_id": 105931,
        "voice": "vo_adv_1059011_034"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下和米奈娃之間",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有著一股連結。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "米奈娃",
