        "voice": "vo_adv_1059011_035"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "說過好幾次。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n她說在下",
