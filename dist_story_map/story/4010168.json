    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩，",
        "unit_id": 105531,
        "voice": "vo_adv_4010168_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你好！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "今天",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為了慶祝我的生日，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n前輩幫我規劃了這個外出企劃……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呃，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……",
        "unit_id": 105531,
        "voice": "vo_adv_4010168_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "超級緊張的……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "明明只是跟{player}前輩去吃飯而已……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一想到",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是兩人單獨外出，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "果然還是……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯、",
        "unit_id": 105531,
        "voice": "vo_adv_4010168_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝謝你，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呼……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你邀請我一起出來，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我非常的高興！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然至今為止",
        "unit_id": 105531,
        "voice": "vo_adv_4010168_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "家人或是朋友也有幫我慶生過。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但像這樣度過生日，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還是第一次……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那就請多多包涵了。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……咦、",
        "unit_id": 105531,
        "voice": "vo_adv_4010168_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "奇怪？",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "剛剛的說法，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "會不會",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "讓人覺得，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n{player}前輩對我來說",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是比朋友",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還重要的人……？　",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好、",
        "unit_id": 105531,
        "voice": "vo_adv_4010168_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好的！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n請多多指教，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不對，",
        "unit_id": 105531,
        "voice": "vo_adv_4010168_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那才不是「誤會」呢……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我就坦率地享受吧。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n享受和{player}前輩度過的，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "珍貴的時間……",
        "unit_id": 105531
    }
]