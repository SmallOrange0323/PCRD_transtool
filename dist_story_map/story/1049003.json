    },
    {
        "type": "still",
        "still": "104900301"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來。",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我很快就煎好囉！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐特製的",
