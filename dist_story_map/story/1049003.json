        "voice": "vo_adv_1049003_040"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不管",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "發生什麼事……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n無論世界驟變",
