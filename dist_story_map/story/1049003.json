    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就算你不特地點餐……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "打從一開始就是{player}你的啦♪",
