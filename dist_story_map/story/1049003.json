    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_037"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n永遠都會是{player}的姐姐喔。",
