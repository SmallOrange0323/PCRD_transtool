    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唉……",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n有點",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "鬱悶。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "比起祕密結社的成員……",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我怎麼覺得自己現在的生活",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "更像個",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "普通的飛特族呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "打工，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "賺生活費……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "心不在焉的發了個呆，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一天就過了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我才剛搬到這個鎮上，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n檯面上的生活也很忙碌。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "公會長只是顧慮到我，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以才沒有特別安排工作給我～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果是這樣就好了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個人",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的沒問題嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n她還記得",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "【拉比林斯】的目的嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真擔心……",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "或許我應該獨自展開調查活動，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n哪怕只有我一個人。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我還想說",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不曉得公會長最近在埋頭做什麼事……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "結果是在研究",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "新口味的可麗餅。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "她也太沒幹勁了吧。",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "算了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "急著採取行動也做不了什麼事。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我有點迷惘……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n照這個情況，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我還有辦法和「弟弟」重逢嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我該不會只是個呼之則來揮之則去，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能輕易使喚的存在吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天也是這樣。",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n突然被叫出來，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還以為發生了什麼事……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "特地把事情都擱置了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "急急忙忙趕來。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "結果只得到一句，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "幫我顧一下可麗餅店～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n相較之下，根本是無關緊要的事。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，在我和璃乃幫忙顧店的這段期間，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n公會長也正在探索",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「世界謎團」……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大多時候，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "她也確實會帶回一些新情報。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我還是抱持著期待的心情",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等她回來好了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "壓力也不利於美容保養，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n放寬心……♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "歡迎光臨～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "奇怪，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？\n{player}！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "歡迎來到",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可麗餅店【拉比林斯】～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "見到你，我好開心喔！",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n剛剛有點焦慮呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我活過來了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}的存在",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n能帶給姐姐心靈健康和肌膚光澤呢～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿。",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n抱歉呀，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "突然抱住你……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太不端莊了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這樣啊……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "前陣子",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我有發這間可麗餅店的傳單給你嘛。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你想要用折價券，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以才過來的嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太好了，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你是在我顧店的時候過來！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多虧這樣，我才能見到",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "儘管點吧。",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐會招待你的～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "OK～♪",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然店長現在不在，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但我也會煎可麗餅，放心吧！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等一下喔～",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n馬上就讓你嚐嚐美味的可麗餅！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "作為招待，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n現在可以免費加點裝飾用的配料喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "店長有著莫名的堅持，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一開始還說「因為我喜歡紅色呀！」……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "然後配料就只有",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "草莓醬。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我費了一番工夫說服她，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n準備了各式各樣的裝飾配料。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……交給姐姐",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "決定？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "OK～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那就",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "巧克力、香蕉和",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "香草冰淇淋～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最後再加上",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n珍藏的裝飾！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐滿滿的",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "愛～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以呀～",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n都給你，都給你。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n吃掉姐姐吧～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "開玩笑的啦。",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐可不是商品喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要是你點可麗餅的話，",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我會很開心的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天完全沒有客人，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n食材還有好多呢。",
