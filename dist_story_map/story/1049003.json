    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "或許{player}會覺得我是個奇怪的女人……",
        "unit_id": 104911,
        "voice": "vo_adv_1049003_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因此感到害怕，",
