[
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在距離皇家主辦的聖誕節活動不到一個月的某天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蕾琪塔正在勤務室裡抱著頭。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊……",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我覺得好不安！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好不安好不安！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不安到會寫下「不安」！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "距離當天時間都所剩無幾了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但我卻好像不安到快瘋了……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "縝密制定的計畫，",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "器材、商品、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "活動……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "全部都是我親自挑選的頂級水準。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n明明一定能夠讓陛下滿意的，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但這不安是為什麼呢！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "果然該從頭開始調整計畫嗎？",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不不，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n先從頭開始確認計畫書，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "看有沒有哪裡有差錯……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "快，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳也要幫忙！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那一堆就拜託妳了喔！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_003"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我理解您的不安，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n但要是現在推翻",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "進行至今的計畫，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n您應該也知道",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要花費",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "多龐大的經費吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要我為您計算嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "事到如今既然無法改變整體框架，",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n就必須下定決心才行。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不用妳說我也知道。",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但是，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是陛下親自交託給我的工作！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為求萬無一失，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "付出多少勞力和金錢我都不後悔啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "嗯，",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_006"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您開始變得慎重是一件好事。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "畢竟要是您漫不經心得意忘形，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "結果失敗了被解雇，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那我也會很困擾呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我說妳啊！",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不要對已經備受不安折磨的雇主",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "講這種不吉利的話！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "若付出這麼多還是失敗而無法待在陛下身邊，",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那我該怎麼辦才好！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的心痛，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可是無法單憑刪減妳的獎金來填補的啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真困擾呢，",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_009"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您整個人都慌了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要是我有擊打腹部或後頸能奏效的技術，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就能讓克蕾琪塔小姐冷靜下來了……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喂，",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可以不要一邊說著危險的台詞，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n一邊捲起袖子靠近嗎！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那、",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我聽見了很大的聲響，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒事吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛、",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不不不，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什什什什麼事也沒有呵呵呵呵呵……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您來的正是時候，",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_013"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "陛下。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐正由於對活動感到不安",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "而手忙腳亂，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n可以請您對她",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "說句寬慰的話嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔、",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喂！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳不用說多餘的話啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐也會",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有感到不安的事呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我這次是信任克蕾琪塔小姐才會交託給妳的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳就盡情去做吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下……",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您的心胸是多麼寬闊且有深度啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這我當然從以前就知道了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但不論幾次都會被感動到。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是擁有作為商人慧眼的克蕾琪塔小姐，那不會有問題的！",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我跟秘書小姐都相信妳☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是的，",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_018"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我相信您。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳的語氣也太沒感情了吧比平時還過分！？",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過要是",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳在勤務室裡會感到不安，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那要不要",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "試著去街上走走轉換一下心情呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "城裡的大家",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎都很期待聖誕節活動喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "謝謝您，",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就恭敬不如從命了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "畢竟不實際走訪現場，活動不可能會成功。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我向您承諾，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我會冷靜下來並讓活動更完美。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "告辭！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……呼，",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_022"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您幫大忙了，陛下。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "雖然她在賺錢相關的事上",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n出類拔萃，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "但為人著想帶來娛樂的",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "經驗值還不夠。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
