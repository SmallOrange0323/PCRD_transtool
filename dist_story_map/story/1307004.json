[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鏡華放棄與花朵先生踏上旅途，決定留在蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在破除迷惘之後，她更賣力地參與地方的綠化活動。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呵呵呵♪",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那是當然了。",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我拒絕了花朵先生的邀請，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要是不好好成長的話，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "他會對我很失望的。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "來吧，",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吸收大量的水分和陽光，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "成長茁壯吧。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……話說，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這陽光是不是有點強？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再怎麼說這也太刺眼了，",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀～！",
        "unit_id": 130711
    },
    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，{player}收到鏡華的邀約，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一起來到了自然庭園。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……到了喔。",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "首先先冷靜下來深呼吸。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吸氣～",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吐氣……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼就出發吧！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這是一年一度的鮮花節。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可以看到當季的花卉，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "甚至是稀有的植物喔！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我已經完美預習了所有會展出的植物情報，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也想好怎樣的路線才是最有效率的！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再來是……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我可沒有很雀躍喔？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我又不是小孩子。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這只不過",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是純粹的",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "「學術興趣」而已。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你該不會什麼都不知道就跟著我來了吧？",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我只有說希望你跟我一起來自然庭園？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那、",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那真是抱歉了……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就是呢，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "自然庭園現在，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "正在舉辦鮮花節。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "當季的花朵當然不用說，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n在玫瑰庭園中還展示了稀有的品種。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n對喜歡花的人而言，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這是絕對不能錯過的活動！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我先說清楚，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果是跟美美或禊，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "感覺沒辦法安靜地欣賞，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以我才會找你來的。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然要請你陪我",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是可不要誤會了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我早就猜到會是這樣了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過請放心吧，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我在來這裡之前已經完美地預習過了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我會好好地說明給你聽，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "絕對不會讓你感到無聊的。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "例如說呢……",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那邊那棵是櫻花樹對吧？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "其實日本的櫻花樹",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "幾乎都是名為染井吉野櫻的品種。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而那種染井吉野櫻，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "它原本是以同一棵樹，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n透過嫁接和扦插來進行無性繁殖的。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這個你知道嗎？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也是，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "感覺對你來說，食物比起植物還要更重要呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼我再告訴你",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "另一個跟櫻花，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n同時也跟甜點有關的小知識吧。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "櫻餅這種甜點",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "外面會捲著一片櫻花葉吧。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n其實櫻花的葉子……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "含有毒性喔。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你昨天吃了三個嗎？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊啊，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼已經太遲了……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……開玩笑的，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你不用那麼慌張。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖說有毒，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但只是少量攝取的話就沒問題。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "反而",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還會有抗菌的作用呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "嗯嗯，",
        "unit_id": 1,
        "voice": "vo_adv_1307004_020"
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "我想聽，我想聽！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "告訴我們吧，",
        "unit_id": 1,
        "voice": "vo_adv_1307004_021"
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "大姐姐～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這還真是，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒有辦法呢……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這些孩子是誰！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該不會是走失兒童？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_1307004_023"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "竟然在這種地方！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "真的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "非常抱歉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n真是的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "不能隨便亂跑。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "大姐姐也很困擾吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我沒有關係……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請問，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這該不會是幼兒園的遠足吧？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "是的。",
        "unit_id": 1,
        "voice": "vo_adv_1307004_025"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "其實是希望他們好好賞花的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n但孩子們果然還是待不住……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "真的很抱歉。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "來，",
        "unit_id": 1,
        "voice": "vo_adv_1307004_026"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "我們走吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "不能再打擾大姐姐了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "咦～",
        "unit_id": 1,
        "voice": "vo_adv_1307004_027"
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "我還想再聽大姐姐說更多",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "故事～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "告",
        "unit_id": 1,
        "voice": "vo_adv_1307004_028"
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "訴我們告訴我們！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "真是的，",
        "unit_id": 1,
        "voice": "vo_adv_1307004_029"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "不能這麼任性。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "那麼",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "我們就先告辭──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請、",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請等一下。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果不嫌棄的話，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請讓我來跟他們講解吧。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "咦，",
        "unit_id": 1,
        "voice": "vo_adv_1307004_031"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "可是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "難得大家對植物感興趣，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n想請你們",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "務必讓我來介紹！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "太好了～！",
        "unit_id": 1,
        "voice": "vo_adv_1307004_033"
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "謝謝妳，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "大姐姐！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "…",
        "unit_id": 1,
        "voice": "vo_adv_1307004_034"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "…",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "不好意思，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "那麼",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "就拜託妳了。",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "130700401"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼大姐姐的植物講座，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就要開始囉～",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n各位要當個乖寶寶認真聽喔。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好～！",
        "unit_id": 1,
        "voice": "vo_adv_1307004_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很棒的回答。",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼──",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這座自然庭園中，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然開著很多種類的花，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但世界上",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還有很多稀有的花。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "特別罕見的",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_038"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是一種名為巨花魔芋的花，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n它可是要好幾年才會開一次花喔！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "什麼！",
        "unit_id": 1,
        "voice": "vo_adv_1307004_039"
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "真的嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對。",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且它的花",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "長得非常大。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就跟那位大哥哥差不多大，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還非～常地臭喔！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "啊哈哈哈！",
        "unit_id": 1,
        "voice": "vo_adv_1307004_041"
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "明明是花卻臭臭的，好好玩～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那種事我知道啦。",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_042"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n現在是在孩子面前，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請再稍微正經一點。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼接下來",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_043"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就來說說的",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大家熟悉玫瑰花吧。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n大家有沒有看過",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "藍色的玫瑰呢？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "藍色的玫瑰？",
        "unit_id": 1,
        "voice": "vo_adv_1307004_044"
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "我沒看過那種花耶。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "真的有嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "我有看過喔！",
        "unit_id": 1,
        "voice": "vo_adv_1307004_045"
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "超級漂亮的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒錯，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_046"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有藍色的玫瑰花。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n其實一直到最近幾年，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "它都還不存在於自然界中。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以藍玫瑰",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_047"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就象徵著「不可能」。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "不可能～？",
        "unit_id": 1,
        "voice": "vo_adv_1307004_048"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就是做不到，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_049"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "或是沒辦法的意思。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在許多人的努力之下，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "最後終於成功培育出藍色的玫瑰了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "藍玫瑰的花語是",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_050"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "「奇蹟」、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "「美夢成真」。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n很適合這種將不可能變為可能的花呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以大家也一樣，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_051"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "即使未來有很累人、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很痛苦的事情，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也不能輕易放棄喔。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只要努力的話，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_052"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就會像藍玫瑰一樣綻放的！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好～！",
        "unit_id": 1,
        "voice": "vo_adv_1307004_053"
    },
    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "──真的",
        "unit_id": 1,
        "voice": "vo_adv_1307004_054"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "非常謝謝妳。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n沒想到那些孩子竟然會這麼專心地聽……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "其實連我",
        "unit_id": 1,
        "voice": "vo_adv_1307004_055"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "都聽得入神了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n妳真的講得很好呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "大姐姐說的故事",
        "unit_id": 1,
        "voice": "vo_adv_1307004_056"
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "都很有趣耶！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "\n我變得",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子1",
        "words": "喜歡上花了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "我也是！",
        "unit_id": 1,
        "voice": "vo_adv_1307004_057"
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "下次再告訴我其他的喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子2",
        "words": "掰掰～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呼……",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_058"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總算是講完了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有好好地介紹嗎？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然是順勢答應的，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_059"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但我也才剛學了這些東西，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n很擔心有沒有講得清楚……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……如果是這樣，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_060"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那我說不定可以稍微有自信一點呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n呵呵，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我有好好地",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "做出大姐姐的表現呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_061"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "接下來就換我們去賞花了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n趕快走吧，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "花兒們在等我們了！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，鏡華和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n盡情享受了活動。"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "感謝",
        "unit_id": 1,
        "voice": "vo_adv_1307004_062"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "各位今天的蒞臨，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n這個花",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "是給各位的伴手禮。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇啊，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_063"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "太漂亮了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "還有，",
        "unit_id": 1,
        "voice": "vo_adv_1307004_064"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "這是我們要私下給兩位的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "特別贈禮。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這個是，",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_065"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "花的種子……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過特別贈禮是指？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "小姐妳，",
        "unit_id": 1,
        "voice": "vo_adv_1307004_066"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "剛才在孩子們面前，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "向他們解說植物吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n周圍，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "有不少人在聽妳的解說喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "大家聽了都很欽佩，",
        "unit_id": 1,
        "voice": "vo_adv_1307004_067"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "就去看了妳解說過的花。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n這個",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "是感謝你們炒熱活動氣氛的小小謝禮。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "請兩位務必",
        "unit_id": 1,
        "voice": "vo_adv_1307004_068"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "要栽種看看。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我的介紹……",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_069"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "原來，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是這樣啊。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呵呵，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總覺得很開心呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我會好好地種植……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "包裝上的照片",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_070"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是秋海棠。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "花語是",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "「暗戀」、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "「愛的告白」……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要我們兩人一起栽種的話，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那不就……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這只是碰巧而已！　",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再說",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_071"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我對這個人根本就，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "根本就……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什、",
        "unit_id": 103631,
        "voice": "vo_adv_1307004_072"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什麼都沒有！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什麼都沒有啦～！",
        "unit_id": 103631
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1307004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "心靈祥和啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看著鏡華",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是能讓人變得心靈祥和啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼小的孩子拼命努力著，",
        "unit_id": 190011,
        "voice": "vo_adv_1307004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n結果自己一個人在腦中胡思亂想，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那份可愛真的是供給過剩了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 190011,
        "voice": "vo_adv_1307004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不知道為什麼她會在腦中胡思亂想？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的，",
        "unit_id": 190011,
        "voice": "vo_adv_1307004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來你還得再多學習各種東西才行呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n請多向鏡華學習。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不論有多麼地聰明努力，",
        "unit_id": 190011,
        "voice": "vo_adv_1307004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她也還只是個孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你要在她身旁好好支持她，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "作一個值得效仿的大人啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼",
        "unit_id": 190011,
        "voice": "vo_adv_1307004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天就到此為止。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜拜～",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……奇怪？",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_079"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們睡著了嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是因為今天陽光很溫暖嗎……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過還真是不可思議的夢呢。",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_080"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我夢到了",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "自己在跟小孩子們介紹有關植物的事……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦，",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_081"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你也作了同樣的夢？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "解說得很棒？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……是啊，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "的確是不錯。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "關於花的知識和我的口條都還過得去，",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_082"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n最重要的是孩子們看起來都很開心，真是太好了。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是……",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_083"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你不覺得若是現在的我，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "一定可以表現得更好嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這陣子",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "遇到了很多人，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "做了很多事，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "作為一名大人我經歷了許多的磨練呢。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我當然",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_084"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不會就此滿足。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我還要體驗更多事，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "成為更了不起的大人讓你見識見識。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "到時候，",
        "unit_id": 130711,
        "voice": "vo_adv_1307004_085"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我會讓你聽到更精彩的解說的。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還請好好期待！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這麼說著的鏡華露出了充滿自信的笑容。"
    }
]