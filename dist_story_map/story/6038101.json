[
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆　",
        "unit_id": 110911,
        "voice": "vo_adv_6038101_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長最近過得怎麼樣啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有沒有過得很青春呢？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不要浪費剩餘的寶貴青春，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要切嚕地樂在其中喔！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們的近況……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那你想先問誰的呢？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐啊。",
        "unit_id": 110911,
        "voice": "vo_adv_6038101_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "地區交流會之後，她偶爾會到小小甜心那裡露臉\n的樣子。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小鏡華雖然說她討厭小孩子玩的遊戲，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n但8歲小優妮卻好像還是全力嚷著說要玩扮家家酒的樣子。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐啊。",
        "unit_id": 110911,
        "voice": "vo_adv_6038101_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "她之前還在說特別講座的簡報很難寫。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個人真的會在一些很奇怪的地方認真喵～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "簡報和小論文那種東西，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n其實只要抓住老師的重點，像玩遊戲一樣寫一寫，就可以輕鬆交差了對吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒啊。",
        "unit_id": 110911,
        "voice": "vo_adv_6038101_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在好朋友社琪愛兒就是一個人負責對外交涉。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒辦法。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n優妮學姐平常是個繭居族，克蘿依學姐又是那副德性。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "她們兩個\n都相當地自由。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以琪愛兒身為社團最後的良心，會繼續努力下去的。",
        "unit_id": 110911
    }
]