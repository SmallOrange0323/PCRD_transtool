[
    {
        "type": "background",
        "background": "501870"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "逛蘭祭會場的{player}和七七香，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在看似正在爭吵的一行人面前停下腳步。"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "所以說，",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_000"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "妳講得不是很奇怪嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n根本就無視上下文的脈絡了嘛。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "一點都不奇怪。",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_001"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n正常得很。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "不如說這是常識好不好。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "到底是哪個偏僻鄉下的常識啊？",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_002"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n妳讀得還不夠深入吧？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊～",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "爭論得好激烈耶……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼了？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，我想也是。",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你就是這樣的人，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n果然會在意吧……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不會，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那種事情算是家常便飯……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過還是會有點在意呢。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真拿你沒辦法……",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我也不想在難得的蘭祭看到有人起爭執。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈囉哈囉～",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "幾位姐姐，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以打擾一下嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "妳是在叫",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_008"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我們嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "啥……",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_009"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "幹嘛？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n我們和跟風仔可沒什麼好談的喔。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "而且還帶著男人……",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_010"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "是來亂的嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "帶帶帶、",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "帶著男人！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不不不、",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是啦他跟我不是那種關係……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "重點不是這個！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……哎呀～不好意思啊，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我只是",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感覺妳們好像在起爭執……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "這跟妳沒關係吧？",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_013"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "而且妳知道我們在說什麼嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是赤空，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對吧？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "只聽到那麼一小段對話為什麼會知道？",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_015"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n難道妳跟蹤我們！？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那很簡單啊，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你們三個人都帶著週邊……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "啊……",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果是解釋不同而起爭執，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n那就不是在講四騎士而是司天！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是這樣猜測的～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "說、",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_019"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "說對了……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n妳滿厲害的嘛。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "是說旁邊這位，你還好嗎？",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_020"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n跟得上話題嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈～抱歉抱歉。",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "赤空是現在",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在男女之間都很受歡迎的奇幻作品啦！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然它不是普通的奇幻作品，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在每座島上譜寫出有哭有笑的各種劇情，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n還有裡面的角色都超棒的！！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "妳很懂嘛。",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_023"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "沒錯……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n我們是司天推。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "只不過，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "這個人一直在說莫名其妙的話……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "啥？",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_024"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "哪裡莫名其妙？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n光輝可是如字面上所示的，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n「受」到高塔的忌妒欸！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我說啊，",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_025"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "光輝跟做為備份的兄弟湊在一起才比較自然！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n他們的感情可是重到他差點惡墮喔？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n妳到底都看了什麼啊？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "我說了，",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_026"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "現在的光輝不是當時的光輝。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n這妳們總該懂吧？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n所以高塔沒有理由執著於他。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "塔是孤傲的總受。",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_027"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "只有這個可能。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哦哦哦……",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這可真是業障重啊……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "兄×光！",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_029"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "塔×光！",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_030"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "塔是全方位受！",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那惡呢……？",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_032"
    },
    {
        "type": "dialogue",
        "name": "女性們",
        "words": "那個另當別論。",
        "unit_id": 1,
        "voice": "vo_adv_1237002_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈哈，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想也是……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n要怎麼說，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們不會直接說角色的名字，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n而是用暗號那樣的感覺稱呼。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不知道為什麼。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "對啊，為什麼呢？",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_036"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "以前呀……",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_037"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "發生過很多事喔。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "很多，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "真的……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那、",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那是歷經百戰的戰士的風範……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呃，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在不是被人的氣場壓倒的時候！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說起來塔的概念",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是從別的系統引進的，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n兄弟中被稱為哥哥的存在",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也不是光輝。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "那是哪來的消息？",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_040"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "確實，",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_041"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "關於他們名字來源的神話是這麼寫的……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n但那沒有直接的關係吧？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一般來說可能沒有關係，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但赤空這種作品不可能沒考慮這一點。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對了，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "既然知道神話的話，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "兄弟中的哥哥……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n妳還記得出現在哪裡嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "炎之柱……！",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_043"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "咦！",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_044"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "那不是出現在夢裡的巨人嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_045"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳很了解嘛喵～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n真厲害～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "等等，",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_046"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我來整理一下。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n光輝和塔是從高次元降臨的，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n光輝做了自己的仿造品還有兄弟跟惡",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "來管理這個世界……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "那不是仿造品！",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_047"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "那個光輝是光輝本人！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n還有，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "塔雖然自己被貶到下界但仍然想回到天界……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "是啊……",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_048"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "那就是塔的優點啊……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n沒有回報的孤傲之人！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "想利用別人卻反遭人利用的可憐體質！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "妳懂嗎！？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "塔這個角色",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_049"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼說呢，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是之前大戰中敵方的大頭目，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n表現得非常唯我獨尊，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是被比他高次元的敵人陷害，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n被幽禁起來，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是個",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不走運但很受歡迎的角色呢。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "咦～",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_050"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "還有其他作品中有出現",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "這麼有特色的角色嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "……下次請你告訴我，",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_051"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n我想聽一聽當作參考……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "妳真的很喜歡",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_052"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "這種類型耶……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔喔，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_053"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "人的喜好都有偏好呢……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呃，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "回到正題……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我一直在想啊～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n炎之柱",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "到底是什麼呢？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "他是配合世界毀滅而出現的呢，",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_054"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n簡直就像是針對世界的功能一樣……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "說起來他的存在是事先設定好的嗎？",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_055"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n與他成對的存在被當成了分身……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "惡獲得與分身相近的能力只是突發狀況，",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_056"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n很難認為是事先設定好的。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "至於分身，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "怎麼說呢，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "要說是虛無嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "炎之柱",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_057"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "頂多只能算是天界系統方的備份是嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "這樣的話，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "跟兄弟不就撞設定了嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來如此，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_058"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "作為天界系統方備份的炎之柱，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n和現世備份的兄弟，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說不定是互相補足的。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "創造的人，",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_059"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "就是原本的光輝對吧？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "那就是說他瞞著塔暗中安排的囉？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "嗚",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_060"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "怎麼會……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n光輝其實也對哥哥有箭頭嗎……？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "這樣的話，",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_061"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "光輝也顧不得塔了呀……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼想的話，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_062"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就完全是……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性們、七七香",
        "words": "愛啊……",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_063"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒錯！",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_064"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在萌的面前我們是同志！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n哎呀，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "集結了眾人的英明睿智，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是不錯的宅宅對談啊……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "真的，",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_065"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "聊得好起勁。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我好像很久沒有這麼熱情地跟別人討論了。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "妳啊，",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_066"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "年紀輕輕卻不簡單耶。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "我也還得繼續多學一點才行……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "老實說我小看妳了……",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_067"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我現在好尊敬妳啊。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不小心談出結論談到都忘記時間了呢。",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_068"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "不過，",
        "unit_id": 1511,
        "voice": "vo_adv_1237002_069"
    },
    {
        "type": "dialogue",
        "name": "女性3",
        "words": "這樣好嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳是指什麼？",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_070"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "感覺妳、",
        "unit_id": 6511,
        "voice": "vo_adv_1237002_071"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "聊得超級興奮……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "在相方面前",
        "unit_id": 1211,
        "voice": "vo_adv_1237002_072"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "聊這種話題沒關係嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼──！？",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_073"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不、",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "他、",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "才不是什麼相方……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對不對？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不對，",
        "unit_id": 123711,
        "voice": "vo_adv_1237002_074"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那是相聲！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是啦，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這算是宅宅用語……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難道你知道然後故意裝傻！？",
        "unit_id": 123711
    },
    {
