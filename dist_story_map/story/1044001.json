[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在布里薩溪谷，\n一名小女孩正獨自與一群魔物對峙著。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈──哈哈哈！",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n竟然敢反抗妾身，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們膽子倒不小嘛。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就讓你們見識一下，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妾身的力量。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "現在才開始哭天喊地，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也已經太遲了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "覺悟吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔！？",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n竟然起不了作用！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咕嗚……",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可惡……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "想不到妾身的力量竟弱化到這種程度……",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你……是何人。",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n算了，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "先不提這個。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "總而言之待在這裡很危險的……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你背著妾身打算做什麼啊！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說要帶著妾身逃跑……？",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣啊，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說想為了妾身而賣命啊……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……那好吧。",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妾身的命運，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就交付在你的手上了。",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……看樣子，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "似乎是逃掉了呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "總而言之，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所幸有你的幫忙妾身才能平安無事。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "叫什麼名字？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "叫{player}啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "做得好。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身乃是統御黑夜之人，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "伊莉亞‧奧恩斯坦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "此次你護妾身有功，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就讓你成為吾之眷屬吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n很不錯的反應。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說什麼！？",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "倘若在從前，被妾身選為眷屬，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n無論是誰都會喜極而泣的……！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總而言之，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這件事已定案！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你沒有拒絕妾身的權利！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這麼一來，你也是妾身的眷屬了！",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從今以後，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可要好好為妾身效力啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……不過，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然得到眷屬是件好事，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但還是無法解決當前的任何問題……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒想到，魔力竟會衰弱到這種程度……",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要是憑妾身從前的魔力，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n區區魔物光靠一根指頭就能讓牠們變成塵埃的……",
        "unit_id": 104412
    },
    {
        "type": "still",
        "still": "104400101"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為什麼要突然摸妾身的頭啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說，要妾身打起精神？",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別把妾身當孩子了！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "摸妾身的頭這種行為，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n可不是隨便誰人都能做的事……",
        "unit_id": 104412
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這、",
        "unit_id": 104411,
        "voice": "vo_adv_1044001_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是……！？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n變回原本的姿態了！？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是怎麼回事……？",
        "unit_id": 104411,
        "voice": "vo_adv_1044001_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "明明妾身試了許多方法都無法恢復這身姿態的？？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不、",
        "unit_id": 104411,
        "voice": "vo_adv_1044001_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然不知理由為何，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但妾身既已恢復為原本的姿態，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就無所畏懼了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如此一來――",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊啊！？",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n又變回孩提之姿了！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……唔……",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是怎麼回事。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一想著正被你摸著頭時，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身就突然恢復成原本的姿態……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "該不會……",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "與你有關吧……？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然如此……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "仔細一看，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你這張臉，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似乎在哪見過的樣子……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不行，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想不起來。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總而言之，",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你非常有可能",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是讓妾身恢復原狀的關鍵。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若真是如此……",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只要吸了你的血，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身或許就能恢復成原本的姿態了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "…………",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_034"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}，快讓妾身",
        "unit_id": 104412,
        "voice": "vo_adv_1044001_035"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吸你的血吧！！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在這之後，\n便不斷地被伊莉亞追著到處跑……"
    }
]