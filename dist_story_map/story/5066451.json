    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個扭曲的時間也終於要結束了呢……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然是妳自作自受，",
        "unit_id": 116611,
        "voice": "vo_adv_5066451_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過以祈梨來說很努力了呢。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！",
        "unit_id": 116511,
        "voice": "vo_adv_5066451_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "歸根究柢，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還不是因為嘉夜夜推了我才變成這樣的！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打從一開始祈梨不要進去那個房間，",
        "unit_id": 116611,
        "voice": "vo_adv_5066451_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不就不會惹上這種麻煩了嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……！",
        "unit_id": 116511,
        "voice": "vo_adv_5066451_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "過、",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "過去的事就不要追究了。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我們現在要盡早",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "結束這個混亂的狀況啦。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也是。",
        "unit_id": 116611,
        "voice": "vo_adv_5066451_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就麻煩你再稍微",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "陪我們一下囉。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "萬事拜託囉！",
        "unit_id": 116511,
        "voice": "vo_adv_5066451_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 116511
    }
]