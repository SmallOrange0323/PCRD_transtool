    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "贏了……？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "贏了吧……？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 111711,
        "voice": "vo_adv_5029402_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是場艱難的戰鬥。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n馴鹿們好像已經動彈不得了。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好～",
        "unit_id": 111511,
        "voice": "vo_adv_5029402_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要怎麼處置這些意圖謀反的無禮傢伙才好呢……？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "克莉絲提娜……",
        "unit_id": 111711,
        "voice": "vo_adv_5029402_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在妳這麼興致高昂的時候說這個真是對不住，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但今天可是特別的日子。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別做得太過……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個不用妳說我也知道。",
        "unit_id": 111511,
        "voice": "vo_adv_5029402_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我跟牠們並沒什麼特別的仇恨，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "反而很感謝牠們呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n因為牠們讓我在這個聖誕節有這麼刺激的體驗。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人……！",
        "unit_id": 111611,
        "voice": "vo_adv_5029402_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然有時候很嚴厲，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是其實很溫柔呢……！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯。",
        "unit_id": 111711,
        "voice": "vo_adv_5029402_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "克莉絲提娜看似豪放，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但其實是個怕寂寞的人呢。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳們兩個，",
        "unit_id": 111511,
        "voice": "vo_adv_5029402_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在那邊排隊站好。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在聖誕老人克莉絲提娜，要送聖誕禮物給妳們囉♪",
        "unit_id": 111511
    }
]