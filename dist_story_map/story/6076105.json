[
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你曾說過，",
        "unit_id": 117711,
        "voice": "vo_adv_6076105_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "每當到了萬聖節期間，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "幽靈就會變多，對吧～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "眼看萬聖節就快到了，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就算有幽靈跑出來",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也不足為奇吧～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果遇到惡靈，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你認為該怎麼做才好呢～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "說得也是～",
        "unit_id": 117711,
        "voice": "vo_adv_6076105_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "既然是惡靈，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要戰鬥",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也得好好想個對策！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……不過，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們的攻擊大該對它無效吧～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就用溝通來解決～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果好好溝通，惡靈應該也會理解的～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就憑我們，",
        "unit_id": 117711,
        "voice": "vo_adv_6076105_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在幽靈面前",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也是束手無策吧……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不如暫時先逃跑，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "去找來能夠和幽靈戰鬥的幫手～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為請別人幫忙，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "並不是件壞事喔～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 117711,
        "voice": "vo_adv_6076105_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果可以成為朋友",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是再好不過的了～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我會努力勸導幽靈，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "與其去做壞事，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不如和朋友一起",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "聊天、跳舞，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "更加",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "快樂有趣喔～♪",
        "unit_id": 117711
    }
]