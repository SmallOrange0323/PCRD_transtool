[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜與{player}\n在逛著萬聖節樂園內的攤販。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不愧是主要大街，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這附近相當熱鬧呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "慶典的人很多，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是走散就麻煩了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要小心",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "別離得太遠。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個是什麼？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n沒錯，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是那個吊著很多繩子的攤販。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……那個是",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抽獎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "繩子跟獎品綁在一起，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是只要拉繩子，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就能把拉中的獎品拉起來的機關啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "攤販賣的食物，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也和在鎮上看到的東西挺不一樣的呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然在鎮上",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也會看到賣食物的攤販，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但這裡賣的感覺似乎有另外下過工夫。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還是第一次看到色彩這麼鮮艷的雪酪。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話又說回來……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n擺設了這麼多家店，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "目光會不禁就被吸引過去了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以現在我也想要問問你有沒有什麼推薦的去逛的地點，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你覺得呢？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喂～",
        "unit_id": 1411,
        "voice": "vo_adv_1140002_008"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "你們兩個！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你是前幾天的……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_009"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "果然是小妹妹你們啊。",
        "unit_id": 1411,
        "voice": "vo_adv_1140002_010"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "前陣子真的幫大忙了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n多虧你們替我收集來的建材，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n我才能",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "像這樣順利出攤，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "多謝啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "就如你們所見，",
        "unit_id": 1411,
        "voice": "vo_adv_1140002_011"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我這裡是開射擊遊戲的攤販……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n小妹妹你們要不要也來玩玩看？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "射擊嗎……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說的也是，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得人家都邀請了，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就玩玩看吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "好喔，",
        "unit_id": 1411,
        "voice": "vo_adv_1140002_013"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "客人兩位～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "規則很簡單，",
        "unit_id": 1411,
        "voice": "vo_adv_1140002_014"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "射中靶子，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "若是掉下來就能得到獎品。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n只要倒下還不算，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "要完全掉到地板上才行。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "開始玩玩看吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "首先是……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看我的！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……沒中啊，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來沒那麼簡單呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼了？",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "瞄準的時候盡量把手伸直？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這樣……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "仔細瞄準獵物……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "命中吧！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "哦，",
        "unit_id": 1411,
        "voice": "vo_adv_1140002_019"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "射中了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳技術不錯喔，小妹妹！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "平時都是我負責指導你，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n感覺就像立場顛倒了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣的話……！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "又射中了！",
        "unit_id": 1411,
        "voice": "vo_adv_1140002_021"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "小妹妹，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳很有天分喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n小哥你也要努力別輸給她了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該是你很會教人吧，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我覺得自己還能繼續射下獎品。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哦，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你看起來也很有幹勁呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那接下來",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就讓我見識你的技術吧？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我替你加油。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "來，",
        "unit_id": 1411,
        "voice": "vo_adv_1140002_024"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這是小姑娘獲得的獎品。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "謝謝你們來玩，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "如果有空",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "就再來玩吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為得到了很多獎品。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n以第一次來說，算是很不錯的成果吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這也是",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "多虧有你的建議。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "給你，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一起吃獲得的點心吧？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我一個人也吃不完。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過你",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還真是吃得津津有味呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該說你很值得讓人餵你吃東西嗎，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一不小心就會想餵你……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼說呢，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可能是你有點像小狗狗吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接下來要做什麼？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你有什麼想做的事嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你很在意那邊嗎？",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是製作萬聖節周邊小物的專區嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們去看看吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嘿～",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "胸針、帽子、人偶……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連籃子都能做啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個是……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "把南瓜挖空做成的燈籠啊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真令人感興趣。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳想做燈籠嗎？",
        "unit_id": 1511,
        "voice": "vo_adv_1140002_031"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n如果有興趣，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "要不要試試看呢？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得的機會，就來體驗看看吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而且你",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像也對這個很感興趣。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那麼",
        "unit_id": 1511,
        "voice": "vo_adv_1140002_033"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我去拿必要的道具過來。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "南瓜就堆放在那裡，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n請挑自己喜歡的。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "擺放了很多漂亮的南瓜呢。",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只要從擺在這裡的南瓜中",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "挑選就行了吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……原來如此，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "裡面早就已經都挖空了啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣的話，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要雕刻外皮好像就能完成了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來你也選好了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n道具好像也都準備好了，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就來開始做吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼了？",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "拿著南瓜待愣在原地。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你想和我比賽做燈籠？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得這應該跟比賽沒什麼關係……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但好啊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你想比的話。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得的機會，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "規則就定",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "輸的那方請客也行喔。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那樣子感覺讓人更有幹勁。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然要比，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就彼此盡全力來比賽吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得我也開始有點熱血沸騰了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就趕快來開始吧！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著過了一段時間後──"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "來了來了，",
        "unit_id": 4911,
        "voice": "vo_adv_1140002_041"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "馬上就做好，請等一下喔。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "七戰六勝",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一平手……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到會都讓你請客，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖說是比賽的結果，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但感覺有點不好意思呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是段非常有意義的時間。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n多虧你，我才能有這麼刺激的體驗。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像這樣度過，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就讓我會想",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "自己是不是也稍微體驗了一般女孩子會做的事情呢？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為我至今都沒機會參加這類的活動，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也有因為學習和家裡的事情而無法去的時候……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且家裡的人都對我說",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "人多吵雜的地方很危險，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n特別是像慶典這種地方就更是如此。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或許我內心中也默默對此感到憧憬吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我沒想到\n你居然會這麼喜歡比賽。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以你平常的樣子來看，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺有點意外呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有什麼理由嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦……？",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那你",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並不是很在意輸贏，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只是想和我一起玩，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那真是中了你的計呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n結果我完全稱了你的意。",
        "unit_id": 114011
    },
    {
        "type": "still",
        "still": "114000201"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難怪我會變成這種打扮。",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從中途開始就很樂於讓我穿上各種裝飾吧？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真受不了你……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我是不會說我沒樂在其中，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但這種引人注目的打扮，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓人有點難為情啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就看在這棉花糖的份上",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放過你吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要是只有我一個人，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我一定不會買吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我說不定",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是第一次吃到棉花糖，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到會是這麼甜的東西呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "…………",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你那樣盯著我看，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會讓人難以入口……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也買自己的份就好了啊……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然那麼在意，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要吃一口看看嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這麼乖地把嘴張開等人餵你吃，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_057"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n讓我有種母鳥在餵小鳥的感覺。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃……",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n來，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 114011
    },
    {
        "type": "still",
        "still": "114000202"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不對，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_059"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等一下。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種事就是，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所謂的、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "間接……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該不算吧？　",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……他可能沒有在意那種事情，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_060"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但還是避開我吃過的地方",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比較好嗎……？　",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……對啊，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_061"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要是沒吃過的這邊就沒問題了吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這樣的話，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我吃過的地方也不會被他吃到……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但在他吃過",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_062"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "之後……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……就會",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "變成我吃到……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他吃過的地方……？　",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，",
        "unit_id": 114011,
        "voice": "vo_adv_1140002_064"
    },
    {
        "type": "dialogue",
        "name": "怜",
