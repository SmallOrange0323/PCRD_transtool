[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在櫻的街頭個人演唱會結束後過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她雖然被哥布林的車子給撞飛，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但勉強躲過了被發現是喪屍的危機，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n作為一個偶像與冒險者繼續活動著。"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "哎呀──",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_000"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "沒想到會在演唱會的最後被車撞到。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "嗯，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_001"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "真的。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "薇歐莉特……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "今天果然不在啊。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "她被一個叫做格蕾斯小姐",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_002"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "的大姐姐給抓住，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "回家去了呢。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "今天，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_003"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "會請騎士先生過來，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "是想要跟你道謝。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n在當冒險者時從你身上學到了很多，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n而之前的演唱會，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "也幫我招攬了",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "很多客人。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "因為我是一個人從佐賀的城市跑到蘭德索爾來的，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_004"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n所以騎士先生與大家的溫柔真的讓我好感動、",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "好高興……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "特別是騎士先生，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_005"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "從你身上受到了",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "最多照顧。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "要是不好好回報給你，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "會有損佐賀的名聲！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "對於感到不安的我來說，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_006"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n騎士先生的存在",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "就像現在照射下來的這道光芒一樣……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "呃，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "怎麼",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "好像真的有道光照了下來？",
        "unit_id": 136111
    },
    {
        "type": "background",
        "background": "510510"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你好呀～？",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n在這種地方睡覺，沒事吧──？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是啊。",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "睡得很熟呢。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你不記得了？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n該不會，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "連這裡是哪都忘了吧？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦咦！？",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "難道是失憶了！？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n莫非是明明死了卻還在動……",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "又好像不是這麼一回事，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "難道是像牛一樣，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "被幽浮綁架了嗎！？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說好像……",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈♪",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡是",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "位在佐賀北邊最外圍的放牧場哦。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n難道說，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你還沒睡醒嗎？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我是",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_011"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "源……",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "不對，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我在一個名為法蘭秀秀",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "的偶像團體裡活動，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n我叫做１號。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "今天是因為有一個拍攝佐賀PR影片的工作，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_012"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "才來到這個牧場的。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "哇啊，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_013"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "真的嗎？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "就算只知道名字，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "能被東京的人記得真是太高興了♪",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我們法蘭秀秀，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_014"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n是為了讓佐賀變得更加興盛，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "為了拯救佐賀而活動的！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "謝謝你！",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_015"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "……咦，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "難道說，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "你肚子餓了嗎？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "那樣的話，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_016"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我帶你去一間不錯的店吧。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n剛好現在是拍攝的空檔",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我有一點時間。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "好的！",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_017"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n是間很好吃的店哦，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "敬請期待！",
        "unit_id": 136131
    },
    {
        "type": "still",
        "still": "136100401"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "鏘鏘──♪",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_018"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\nDrivein雞的",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "頭號定食！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "雖然說到燒肉可能會先想到牛肉，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_019"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "但是在佐賀只要提到燒肉那就會是雞肉哦♪",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "怎麼樣？",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_020"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n很好吃對吧？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "對吧♪",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_021"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n這裡",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "是我之前在偶像工作上受到很多照顧的店家。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "從那之後，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_022"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我現在偶爾也會跟法蘭秀秀的成員們",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "一起來這裡呢。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "因為",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "就跟你剛才說的一樣，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "超級好吃的♪",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "作為一個在佐賀活動的偶像，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_023"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n能夠跟在地受到喜愛的店家一起工作，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n真的是既榮幸又開心。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "而且我認為，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_024"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "只要在當地一點一滴地努力工作，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n總有一天就能成為全國",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "都認識的偶像。",
        "unit_id": 136131
    },
    {
        "type": "still",
        "still": "136100402"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "那當然！",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_025"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n偶像可是讓",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "曾經放棄掉許多東西的我，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n能重新振作再加油一次的存在。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "而佐賀，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_026"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "則接納了我們法蘭秀秀。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n曾經一無所有，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "只是想當偶像的我們。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "不管是我們還是佐賀，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_027"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "一路走來都遇到了許多困難。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n有時就好像站在懸崖邊一樣……",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "倒不如說，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n是已經掉到了懸崖底下般的困境。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "雖然現在比較沒那麼艱辛了，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_028"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "但還是有許多很辛苦的事情。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "麻煩這種東西，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "真的是會在突然之間發生的。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "不過即使如此，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_029"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我也相信不管遇到什麼狀況，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "都一定能跨越過去！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "只要具備偶像所擁有的力量，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_030"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "以及無可取代的夥伴們。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "而且，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "還有好多好多深愛著佐賀的人們。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "所以不管幾次我都能重新站起來，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_031"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n不管失敗了幾次，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "都能再次挑戰。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我們的夢想，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_032"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "是讓佐賀變得更加興盛，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "拯救佐賀，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "然後……",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "成為世界第一的，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "永遠的偶像！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "雖然可能會被",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_033"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "覺得這真的只是個「夢想」而已，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n但我相信總有一天一定能達成。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "因為我們法蘭秀秀，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_034"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n可是永遠不滅的偶像啊♪",
        "unit_id": 136131
    },
    {
        "type": "still",
        "still": "136100401"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "對了♪",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_035"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n如果可以的話，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "請來看我們的演唱會吧。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n就快要舉辦了。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "畢竟這太突然了點，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_036"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "是時間上不方便嗎？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "說起來你是來旅行的呢。",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_037"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "那也沒有辦法……",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "啊，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "你有在玩阿斯特朗傳奇嗎？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "我也有在玩",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_038"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "阿斯特朗！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n不只遊戲本身很有趣，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "更棒的是還能",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "跟相隔很處的朋友聯繫。",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "好比說像是",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "佐賀與東京這麼遠也行！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "然後啊……",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_039"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "其實我，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n在阿斯特朗裡",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "也在當偶像哦！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "所以說，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_040"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "在看佐賀的演唱會之前，",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n要不要先來看我在阿斯特朗的演唱會呢？",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "真的嗎？",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_041"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "\n",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "那麼就",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "約好囉！",
        "unit_id": 136131
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "法蘭秀秀的演唱會，",
        "unit_id": 136131,
        "voice": "vo_adv_1361004_042"
    },
    {
        "type": "dialogue",
        "name": "１號",
        "words": "請你一定要來看看喔♪",
        "unit_id": 136131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1361004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個，到底是怎麼",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一回事啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1361004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你會與這名叫做",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "櫻的女孩一起做夢呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "櫻她是屬於「外面」的存在……",
        "unit_id": 190011,
        "voice": "vo_adv_1361004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但為什麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是會做夢……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明明她與你之間",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該不會有交集才對……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以前也曾發生過",
        "unit_id": 190011,
        "voice": "vo_adv_1361004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "類似的事情呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n結果",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到最後謎團依然沒有解開，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "搞不好這次也……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一樣是個謎呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來……",
        "unit_id": 190011,
        "voice": "vo_adv_1361004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "暫且不論櫻她的頭能拿下來這件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n沒想到居然能接在薇歐莉特的身體上，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "連我都嚇了一大跳！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n話說",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼你可以那麼無動於衷啊！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看櫻那個樣子，",
        "unit_id": 190011,
        "voice": "vo_adv_1361004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能沒被發現是喪屍簡直讓人覺得不可思議，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是有什麼萬一",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你可要好好幫她哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然感覺她對斷頭這件事，",
        "unit_id": 190011,
        "voice": "vo_adv_1361004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經習慣成自然了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要幫她隱瞞，你應該會很辛苦吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "嗯……",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_050"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "奇怪～？",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "好像不知不覺間睡著了……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "騎士先生，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_051"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "難道說你也睡著了嗎？",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n到底是什麼，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "剛才那個……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "奇怪的感覺。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "話說回來，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_052"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我睡著時夢到的夢",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "也很奇怪呢。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n在夢裡見到了法蘭秀秀的成員，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "也遇見了騎士先生。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "而且，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_053"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "還在一個我應該不認識，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n卻又好像認識的地方",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "工作著，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n甚至跟騎士先生一起吃了飯。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "哦～",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_054"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "居然會有這種巧合！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "為了佐賀嗎？",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_055"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "啊哈哈，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_056"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "看來我們真的做了同樣的夢！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "不過，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我在夢裡也做著同樣的事情，想想也是當然的呢。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我啊，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_057"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "真的很喜歡偶像嘛。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "一方面是因為我不想再放棄了，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_058"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "而且也有夥伴在我背後支持我，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n所以我才可以在夢裡的佐賀也在努力著。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "這份心情，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_059"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "不只是存在於夢裡，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "就連現在也是。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "以前的我，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_060"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "曾經朝著目標拚命努力，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "還受了傷",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "搞壞了身體，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "讓至今為止的努力",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "全部泡湯，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n讓一切全都變得沒有意義。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "不只有一兩次，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_061"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "而是好幾次努力到最後都毫無意義。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "所以我",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "才會",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "發現到自己",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "「很倒霉」，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "進而放棄繼續努力。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "……但是，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_062"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "偶像改變了",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "這樣的我。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n讓我能夠再一次重新努力！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "雖然，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_063"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我也是有",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "稍～",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "微消沉過一陣子就是了……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "但多虧了法蘭秀秀的成員與製作人，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n還有佐賀與在那裡的大家，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "才有現在這樣的我。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "然後，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_064"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "這個城鎮接納了",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "從佐賀過來的我，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n我已經喜歡上這座城鎮了。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "也很高興能夠",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "交到新朋友，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n不管是偶像的個人活動還是冒險者，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我都能夠努力加油。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我作為一個偶像，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_065"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "有件事情想要與拯救佐賀的心願，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n一起傳達給大家。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "那就是……",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_066"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "希望大家能跟我在佐賀的時候一樣，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n不管跌倒幾次都能站起來，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n努力、",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "再努力、",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "不斷地",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "捲土重來。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我相信就算死了，",
        "unit_id": 136111,
        "voice": "vo_adv_1361004_067"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n只要還能活下去，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "就能實現夢想！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從今以後，櫻也會繼續在自己所相信的道路上邁進。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n即使前方有許多困難在等待著她，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她肯定也能靠著自身與夥伴的力量跨越過去吧。"
    }
]