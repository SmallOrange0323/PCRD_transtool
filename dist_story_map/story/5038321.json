[
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等等……",
        "unit_id": 110911,
        "voice": "vo_adv_5038321_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那是怎麼回事啊！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n好像墨丘利的極限角色扮演的謎之團體",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n墨丘地登場了耶！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個叫做……",
        "unit_id": 104811,
        "voice": "vo_adv_5038321_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「好朋友全像投影」！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這功能可以用外觀、性格、行為模式……等",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "事先儲存的資訊為參考，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n製作出和目標幾乎一模一樣的影子！！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來這並不是鏡像立體投影",
        "unit_id": 111011,
        "voice": "vo_adv_5038321_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼簡單的東西。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喔～竟然",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "連質量都能複製，真有意思。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n簡直就像是複製人啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喔～真的，",
        "unit_id": 110811,
        "voice": "vo_adv_5038321_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "連細節都好像。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n喝著麥酒，吃著鯛魚燒，數著錢，高聲地笑著。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "全體的獨特風格都完全模仿了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等一下？",
        "unit_id": 103411,
        "voice": "vo_adv_5038321_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我喝酒的方式可沒那麼誇張喔！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "魔法的酒杯裡像間歇泉一樣不斷湧出金黃色的液體。",
        "unit_id": 111011,
        "voice": "vo_adv_5038321_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n大口大口地把那奔騰的酒水",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一滴也不漏地喝光，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這已經可以說是街頭藝人等級了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，真的很誇張。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個連琪愛兒都無法接受。",
        "unit_id": 110911,
        "voice": "vo_adv_5038321_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不～是～的～！",
        "unit_id": 103411,
        "voice": "vo_adv_5038321_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "美冬！　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那種滿是虛假的影子，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "趕快把它打倒吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯，是啊。",
        "unit_id": 104811,
        "voice": "vo_adv_5038321_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "本人比這個更誇張說……！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "美冬！？",
        "unit_id": 103411,
        "voice": "vo_adv_5038321_009"
    }
]