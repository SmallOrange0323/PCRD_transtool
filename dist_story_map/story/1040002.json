[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和碧相遇並組成BB團之後的第二天，\n{player}再次來到精靈之森。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啦啦啦～BB團～♪",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n還沒來嗎，還沒來嗎，BB團～♪",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊！{player}！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我等你好久啦！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我等著這天到來好久了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "彷彿度日如年！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，我從昨天就開始期待了！",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "喔耶、喔耶！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、那麼，我們一起想想吧，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為、為了認識新朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我、我們，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "應該做什麼好呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此，就是像蝴蝶般舞動，像蜜蜂那樣攻擊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n對吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真有你的，真是位謀士！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n雖然我不太懂用意！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此！",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n正所謂知己知彼，百戰百勝對吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你果然博學多聞！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "交朋友這回事，好像沒辦法隨心所欲地，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n用普通的方式呢……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也就是說……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那個嘛……接下來，我想問你問題，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n聽聽你實際的建議……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "假設有一天我在路上，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n突然遇到普通人類時，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n應該怎樣開口打招呼呢？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "什、什、什、什、",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "什麼――――！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這、這個，難度太高了！！！",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n超高難度！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難、難度太高……高、高……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n高高……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "高中狀元！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對、對不起，我太不安了，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n又說了一些莫名其妙的話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？你叫我先試著跟人偶練習一下，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n是嗎……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為我常跟「有我在喔好朋友1號」對話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n把它當作練習對象應該會不錯。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你的觀點真獨到……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、那麼，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我練習看看如何好好地說出「請你和我做朋友」！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果有錯的話請你告訴我喔！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你、",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你、你、你好、你好……你好……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好多國家……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n呈、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呈現出生率下降和人口老化的社會現象，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n景氣不見好轉的問題也持續困擾著我們……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃！",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "糟、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "糟糕……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我太像社運人士了。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自、自己的……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我自己的……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我自己的話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "比起肉類，我更喜歡蔬菜。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好的！我們現在來猜謎！",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個該怎麼唸呢――！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "→「朋友」",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯、嗯嗯……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我好像沒辦法在今天之內做到……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "果然，像我這樣的人，想要跟別人做朋友什麼的，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n還早了十萬年……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說不定我一輩子都說不出",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「和我做朋友吧」這句話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能不能不要立刻提到當朋友……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n而是先說一些能夠聊天的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "開場白呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原、原來如此！",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果是這種話題……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}，請看我的表現！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "午安！今天",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天氣不錯呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你說我蠻有天份的嗎！！",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的嗎！！！！！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我做到了……",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n多虧了你的幫忙……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的是、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的是開心到不行！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500191"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "話說{player}，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天天氣不錯呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然開始有點轉陰了，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但天氣不錯呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "改變一下話題，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天氣不錯呢！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500192"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "夜深了，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天氣不錯呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然漆黑一片什麼都看不見了，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_034"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天氣不錯呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "明天和後天，",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_035"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "當然還有大後天，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天氣應該也都不錯呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "後面的農田裡有小狗在叫！",
        "unit_id": 104011,
        "voice": "vo_adv_1040002_036"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天氣不錯呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，碧就開心地和{player}\n說著天氣的話題直至天亮為止……"
    }
]