[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與{player}他們分別後，流夏抵達村子入口，\n她踏入了彷彿不允許發出任何驚愕、\n被寂靜所支配的地方。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看得出來這裡就是那時提到的村子。",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過話又說回來……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "……",
        "unit_id": 511,
        "voice": "vo_adv_5008001_001"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……",
        "unit_id": 611,
        "voice": "vo_adv_5008001_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就算流露出對我這個外人",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感興趣的眼神，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n也沒有人過來找我搭話。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這到底是怎麼回事？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "每家店",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都是關著的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也沒見到年輕男性的身影……",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都外出了嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "喂，",
        "unit_id": 811,
        "voice": "vo_adv_5008001_006"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "我知道有人在家！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "\n把能吃的東西都給我交出來！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "好，",
        "unit_id": 1511,
        "voice": "vo_adv_5008001_007"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "好的！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這裡就是全部了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "請拿去……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "少騙我了！　",
        "unit_id": 811,
        "voice": "vo_adv_5008001_008"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "還有藏起來的份吧？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "\n喂，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "這不是還有麵包留著嗎！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "拜、",
        "unit_id": 1511,
        "voice": "vo_adv_5008001_009"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "拜託你，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "請留下這塊麵包……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n孩子的肚子已經餓著了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "那種事情關我屁事！",
        "unit_id": 811,
        "voice": "vo_adv_5008001_010"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "\n叫妳把能吃的東西都給我交出來，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "是沒聽到嗎！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "到此為止吧。",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_011"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "啊！？　",
        "unit_id": 811,
        "voice": "vo_adv_5008001_012"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "怎麼，妳這傢伙！　",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "少來礙事！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嘿咻。",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_013"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "什麼！？　",
        "unit_id": 811,
        "voice": "vo_adv_5008001_014"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "嘖！　",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "喝啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了？　",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "完全打不中啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "可惡啊！",
        "unit_id": 811,
        "voice": "vo_adv_5008001_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "底子太差了。",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "去重新練過吧！",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "嘿噗啊啊啊！？",
        "unit_id": 811,
        "voice": "vo_adv_5008001_018"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "妳、",
        "unit_id": 811,
        "voice": "vo_adv_5008001_019"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "妳做什麼！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "妳知道對我出手",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "代表什麼意思吧！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "誰想知道啊。",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能給你的東西，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n頂多就那路邊地上的小石子。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "趕快拿了走人。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "妳這傢伙……！　",
        "unit_id": 811,
        "voice": "vo_adv_5008001_021"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "給我記住！！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "已經忘記啦。",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n好了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳還好吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳、",
        "unit_id": 1511,
        "voice": "vo_adv_5008001_023"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳看妳、",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "做了什麼好事！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊啊，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "到底該怎麼辦才好……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……這反應真讓人意外。",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這是說餓肚子比較好的意思嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳是什麼都不知道，才能說出那種話來……！",
        "unit_id": 1511,
        "voice": "vo_adv_5008001_025"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "嗚嗚嗚……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "小姐。",
        "unit_id": 511,
        "voice": "vo_adv_5008001_026"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "關於這位母親的無禮，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "能否請妳原諒她呢？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n她也有她的苦衷啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "生活在這村子所有人的家人，",
        "unit_id": 511,
        "voice": "vo_adv_5008001_027"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n都被那些傢伙當成人質了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "人質？",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_028"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那傢伙就是負責溪谷洞窟採掘的其中一名業者。",
        "unit_id": 1511,
        "voice": "vo_adv_5008001_029"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "村子裡",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "多數的男人為了尋求工作離開村子……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可是離開以後，",
        "unit_id": 1511,
        "voice": "vo_adv_5008001_030"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "卻沒有任何一人再回來……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "溪谷洞窟？　",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那不就是……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "去打探情況的人，也沒有任何人回來。",
        "unit_id": 511,
        "voice": "vo_adv_5008001_032"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n就算送陳情書到王都尋求幫助，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "也毫無消息。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "村裡的年輕男人都被奪走，",
        "unit_id": 511,
        "voice": "vo_adv_5008001_033"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "只剩下我這樣的老人和女人小孩。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n所以就算食物被搶奪，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "除了忍耐也別無他法啊……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "…………",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_034"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來，",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_035"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "似乎遇到比想像中更差勁的惡徒了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那傢伙說小弟也只是個小弟吧……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "杏奈和{player}也很令人在意，",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_036"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n得盡快前往溪谷了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "小姐，",
        "unit_id": 511,
        "voice": "vo_adv_5008001_037"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "妳趕快離開這個村子。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n那些傢伙",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "肯定會回來報仇的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我會離開的，",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_038"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但並不是因為怕危險。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n而是因為我的夥伴已經前往洞窟了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說不定",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_039"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能順便一起救出這個村子的人們。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n總之我先去看看――",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――呀啊啊啊啊！！　",
        "unit_id": 1,
        "voice": "vo_adv_5008001_040"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "救命啊啊啊啊啊啊！！？？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "？　",
        "unit_id": 105611,
        "voice": "vo_adv_5008001_041"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了……？",
        "unit_id": 105611
    }
]