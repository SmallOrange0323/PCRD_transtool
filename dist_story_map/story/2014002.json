        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這究竟是吹起了什麼風啊？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若說到魔力的波長與微粒子等級的模組變更，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n除了妳以外，又還有誰辦得到呢？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "比起這回事……",
        "unit_id": 106914,
        "voice": "vo_adv_2014002_050"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給我從那讓開，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "變貌大妃。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n現在還能放妳一馬唷，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看在同是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "『七冠』的情誼上。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還是說，",
        "unit_id": 106914,
        "voice": "vo_adv_2014002_051"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳想比那些傢伙，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "先一步去死嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳那被我吸收過了魔力的身體……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我認為可沒什麼餘裕了才是。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若你口中還有份情誼……",
        "unit_id": 107011,
        "voice": "vo_adv_2014002_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要不和我好好談談呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並非是用如此毀滅性的辦法……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而是為了探討更有高度的解決辦法來進行談話。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若是我們……",
        "unit_id": 107011,
        "voice": "vo_adv_2014002_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正是因為是我們。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就是要改變這個被封閉的世界，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不也是有可能的嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟我們，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可同樣是『七冠』呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哼！",
        "unit_id": 106914,
        "voice": "vo_adv_2014002_054"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "雖說僅管同是『七冠』，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我和你們可是截然不同！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳說要",
        "unit_id": 106914,
        "voice": "vo_adv_2014002_055"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "改變世界？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那當然，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就改變給妳看看――",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "用我的這雙手！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那……",
        "unit_id": 107011,
        "voice": "vo_adv_2014002_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真可憐。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不論經過了多久，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n果然在你的世界中……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "除了你以外容不下他人呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給我閉嘴！",
        "unit_id": 106914,
        "voice": "vo_adv_2014002_057"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "別向如同神一般的我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "投以妳的憐憫！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而且……",
        "unit_id": 106914,
        "voice": "vo_adv_2014002_058"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "事到如今還講什麼好好談談，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這種一眼就能看穿的拖延時間就免了吧！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n明明就是盡靠張嘴詭辯的牆頭草……！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "夠了！",
        "unit_id": 106914,
        "voice": "vo_adv_2014002_059"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給我消失吧，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "變貌大妃――！！",
        "unit_id": 106914
    }
]