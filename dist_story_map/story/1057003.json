    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我連早飯也沒吃，肚子已經餓扁了……",
