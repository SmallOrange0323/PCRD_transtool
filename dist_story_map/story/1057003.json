    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "他非常可靠哦。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "小吉塔！",
        "unit_id": 311,
        "voice": "vo_adv_1057003_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "防具已經修理好了，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n明天就過來拿吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我知道了～！",
