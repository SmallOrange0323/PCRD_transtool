    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我現在正要和騎空團的夥伴",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "一起去吃飯。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "好好哦～！",
        "unit_id": 211,
        "voice": "vo_adv_1057003_011"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我也想要加入騎空團！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好吧～♪",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_012"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "等妳長大，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就讓妳加入騎空團。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "雖然不久前我才開始在這個城鎮生活，",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_013"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過大家都很溫柔，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "受到很多的幫助。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "所以很快就和所有人打成一片了……",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_014"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "現在與其說他們是鄰居，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不如說像是家人。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……不過呢，",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_015"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你對我來說，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n也已經像是家人了哦？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "畢竟是同個騎空團的夥伴呀！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過和你待在一起時說是家人，",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_016"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "看起來更像是兄弟姊妹呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你會是哪邊呢……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "唔～嗯……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你沒有給人哥哥的感覺……",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_017"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "所以是弟弟吧！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "從現在開始，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你可以叫我姐姐也沒關係哦？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "什麼事～",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_018"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "怎麼了嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "開玩笑的……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嘿嘿。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊！",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_019"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "在我們聊天時就到了呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這裡就是我預約的餐廳。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "來，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "進去吧進去吧！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "妳好～！",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_020"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨──！",
        "unit_id": 411,
        "voice": "vo_adv_1057003_021"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "唉呀，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這不是吉塔嗎。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "幫妳留好的座位在那裡，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "決定好要點什麼後，\n再叫我吧！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好的～！",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_022"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我看看，菜單菜單……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "來，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "拿去。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有什麼想吃的東西嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我看看喔──",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_023"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "姐姐喜歡吃的東西是……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "唔，",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_024"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不對！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n該不會，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你剛才是在鬧我的吧？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真是的……之後要好好叫我的名字喔？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……呵呵，",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_025"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "開玩笑的──",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這是你想鬧我的反擊。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嚇了一跳嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想想，",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_026"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這間店的這個，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還有這個特別好吃！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n總之就先點這兩個吧？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不好意思──！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "好的──！",
        "unit_id": 411,
        "voice": "vo_adv_1057003_027"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "請稍等──！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……怎麼了嗎？",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_028"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "一直盯著我看，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我的臉上有沾到什麼嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我看起來很開心……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_029"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我呢，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "現在非常開心哦。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "能像這樣和夥伴聊天，互相開玩笑，",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_030"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "在不久前還只是想像中的景象呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "可是現在，",
        "unit_id": 105711,
        "voice": "vo_adv_1057003_031"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有如此氣味相投的夥伴……\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有你在我的面前。\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真的非常令人開心，令人快樂……",
        "unit_id": 105711
