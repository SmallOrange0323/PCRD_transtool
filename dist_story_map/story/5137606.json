[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ノウェムは、次の戦いに向けて作戦を立てたいと、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nオクトーに呼び出されていた。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おーい、",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトー！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いないのか～！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n次の作戦を立てようって呼び出したのはそっちだろ～？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "やぁ、",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_001"
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "ノウェム。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "\n待たせてすまなかったね、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "怒ってないかい？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "キミの美しい眉間に、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "しわが寄ってなければいいのだけれど。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いや、",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_002"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そこまで待たされたわけじゃ……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "は？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nちょっと待て、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "何言ってんだオマエ！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "キミが美しいと言ったのさ。",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_003"
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "この世に存在するどんな宝石でも、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "\nキミの瞳の美しさにはかなわないよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "……分かった、",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_004"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "さてはネネカだろ！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトーは絶対にそんなこと言わないからな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "思ったより簡単にバレてしまいましたね。",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_005"
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "彼に化けて歯の浮くようなセリフを吐けば、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "面白い貴方が見られるかもと",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "期待したのですが。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_006"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ちょっと遅刻したボクも悪いんだけどさ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n本人がいないところで",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "悪質過ぎるでしょー、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そのいやがらせ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nボクがセクハラオヤジみたいな扱いになったら、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "どうしてくれるわけ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "今度は本物のオクトーだ、",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_007"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "間違いない！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n面倒なことに巻き込むなっていう雰囲気が、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ちゃんとにじみ出てるぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "それはそれで傷つく評価だけどなー",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_008"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まぁ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "事実だから否定もできないんだけど。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "ふむ……",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_009"
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "貴方たちはお互い、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "深く信頼しあっているのですね。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "では、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "今度は少し難易度をあげてみましょうか。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\nもう一度、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "彼に化けてみます……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "分身のおまけつきで。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "……うわっ！？",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_010"
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "\nなんだよこれ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？",
        "words": "ボクだらけじゃないか！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？？",
        "words": "さすがに勘弁してよねー……",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_011"
    },
    {
        "type": "dialogue",
        "name": "オクトー？？",
        "words": "\n自分と同じ顔が見渡す限り広がってるって、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？？",
        "words": "完全にホラーだしさ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オ、",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_012"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトーが一人、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトーが二人、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトーがたくさん！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n見た目は完全に同じだし、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "すごい変身能力だ……！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー？？？",
        "words": "見た目はさておき、",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_013"
    },
    {
        "type": "dialogue",
        "name": "オクトー？？？",
        "words": "ボクって周りからこんなに気の抜けた",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？？？",
        "words": "\nしゃべり方をしてると思われてるわけ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？？？",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？？？",
        "words": "もう少し、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？？？",
        "words": "ハキハキ……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？？？",
        "words": "してなかったかなー、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー？？？",
        "words": "別に。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "しかも、",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_014"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "今度はちゃんと性格まで真似してるみたいだ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nでも、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシの目は",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そんなことじゃごまかせないぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "本物のオクトーは……",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_015"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "こいつだ～！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "うん、",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_016"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "正解～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "よく分かったねー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "……驚きました。",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_017"
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n今度は騙せる自信があったのですが、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "どうやって本物が彼だと見抜いたのです？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "もちろん、",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_018"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "勘だ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n一番オクトーっぽいと感じたオクトーを選んだだけだぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "相変わらず雑だねー、",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_019"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "キミ……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "本当にボクに化ける敵が出てきたときは、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nもうちょっと慎重に選んでよ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "任せとけ！",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_020"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nオクトーのことが一番よく分かってるのは、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシなんだからな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nどんな偽物が出てきても、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "絶対に見抜いてやるぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "なるほど、",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_021"
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "参考になりました。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n深い絆を結んだ人間が相手だと、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n私の変身能力も見破られるリスクが高いようですね。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクにはさっぱり分からない理屈だけどねー",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_022"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そんな曖昧なもので",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "本物か偽物か区別するなんて、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "できる気がしないよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "そうでしょうか？",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_023"
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "私がノウェムに化けたとしても、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "貴方が相手では",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "変貌大妃",
        "words": "\n簡単に見破られてしまう気がしていますよ。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "……買いかぶりすぎだって、",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_024"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まったく。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "その後、ノウェムたちは改めて作戦会議を始めたのだった。"
    }
]