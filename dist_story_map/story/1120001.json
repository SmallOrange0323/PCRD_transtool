    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在歡慶新年的氣氛中熱鬧歡騰的蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在配送郵件的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看到凱留手上抱著堆積如山的東西。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算新年特賣很便宜，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也不需要買這麼多魔導書的……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "人這麼多真讓人厭煩。",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好想快點回去好好放鬆啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇！？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你別突然跟我搭話啦！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n害我嚇了一大跳。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問我為什麼要買這麼多書？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我只是在新年參拜後的",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "回家途中看到賣得很便宜的書才先買起來的，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是新年剛開始就想去念書呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你才是呢，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "手上抱著非常多的東西啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是在配送賀年卡嗎？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "賀年卡的數量還真是驚人呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不只是自己的份，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你還幫請病假的人配送？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你真的是個爛好人耶。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才剛說你是爛好人，你就在說些什麼啊……",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "行了，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你去做自己的工作吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好了，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快走快走。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這樣搖搖晃晃的感覺很危險耶。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你一個人配送的話，要配送的量實在太大了啦。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等我一下！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了。",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我來幫你，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把東西分一半給我吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問我書怎麼了？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我放到公會小屋裡了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你可要確實地",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "支付我幫忙的酬勞喔？",
        "unit_id": 112011
