        "words": "這樣我就能理解了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "嗯？　",
        "unit_id": 911,
        "voice": "vo_adv_1120001_032"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "怎麼了？　小姐。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒、",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒什麼。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們要去送下一個地方了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "哦，",
        "unit_id": 911,
        "voice": "vo_adv_1120001_034"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "謝啦。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n我想一定很辛苦吧，加油啊。",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼～",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總算快送完了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真虧你能剛開始過年",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就做這麼累的工作呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大家會很開心？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那又怎樣……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然是這麼想的，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但看到別人開心的臉",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺還不壞呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我如果來寫賀年卡的話，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可和可蘿仔也會覺得開心嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又沒有人說要寫。",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我考慮看看吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不是就在我眼前嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是是。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是想說賀年卡不是那種東西對吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我會考慮的。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別在那邊說些有的沒的了，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕快把信件送完吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接下來的賀年卡是……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是怎樣？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有寫收件人啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣就沒辦法送了呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許是這樣沒錯，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但不寫收件人就沒辦法送吧？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你要去哪？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道你心裡有底嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要去街上問人？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣怎麼可能有辦法知道啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你打算問到知道的人出現為止？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的話，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被問到的人也會很困擾啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唔，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟你就是那種人呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也來幫你找。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "賀年卡讓我看看。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n『奶奶　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新年快樂』",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看得出來這是小孩子寫的卡片呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上面還畫有",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一位老奶奶在攤販賣糖果的圖……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然還是什麼都不知……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會是……",
        "unit_id": 112011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "要不要買糖果啊～",
        "unit_id": 611,
        "voice": "vo_adv_1120001_047"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n不管怎麼切都會出現相同的圖案，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是很吉祥的東西喔～",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以打擾一下嗎？",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_048"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "歡迎光臨。",
        "unit_id": 611,
        "voice": "vo_adv_1120001_049"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n你們",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "想要幾條糖果啊？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不是來買糖果的。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這張賀年卡，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我在想是不是要送給老奶奶的東西。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "哦～哦～！　",
        "unit_id": 611,
        "voice": "vo_adv_1120001_051"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這是我的孫子要給我的卡片。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "他是個粗枝大葉的孩子，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "應該是忘記寫收件人了吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "話又說回來，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真虧妳能知道這是要給我的呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看到上面的畫",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我想起自己之前跟一個很貪吃的朋友在路上吃著東西時，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n曾經來老奶奶這裡買過糖。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真的很謝謝妳。",
        "unit_id": 611,
        "voice": "vo_adv_1120001_053"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n要是小姐妳沒注意到，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我就要迎來寂寞的新年了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能順利送達就好了。",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們回去工作了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊啊，",
        "unit_id": 611,
        "voice": "vo_adv_1120001_055"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你們等一下。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "作為勞煩你們的賠禮兼謝禮，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這糖果你們收下吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n來。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇哇！",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_056"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們拿了那麼多也吃不完啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "妳就分給那位和妳一起在路上吃東西的朋友吧。",
        "unit_id": 611,
        "voice": "vo_adv_1120001_057"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "保證味道很好喔。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道很好吃啦。",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_058"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們這次真的要走了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我想我那個",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很貪吃的朋友收到糖果會很開心的。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊。",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_059"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可應該會很開心吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說的不是糖果，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而是因為能看見老奶奶開心的表情嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那好像也是……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 112011,
        "voice": "vo_adv_1120001_061"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "覺得太好了的人是老奶奶，",
