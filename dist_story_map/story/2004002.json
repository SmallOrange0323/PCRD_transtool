[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被奇怪現象『闇影』襲擊的數日後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}接受了某個委託，\n在茂密的山林步道裡走著。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊嗚嗚～……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肚子好餓～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子好餓哦～……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明明已經先吃了很多東西，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也帶了多到快要拿不動的便當來……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但肚子又餓到咕嚕咕嚕叫了。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道我的胃",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是破了個洞嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "餓得好難受呀～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很不妙呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣下去的話，我可能又要餓倒在路邊了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊嗚～頭好暈呀～……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（只要盡量別使用『皇家裝備』的話，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n其實也不會餓肚子……）",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（但是恰巧遇到魔物接二連三地襲擊嘛～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果我不全力戰鬥的話，可是會死掉的。）",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（要是我有僱用別人當護衛就好了……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然我在鎮上有認識幾個人，\n但也沒有交情好到能夠隨意拜託他們這種事。）",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（不過反正他們也會忘記我吧……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我不能跟他們變得太要好對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣只是讓分別的時候更加痛苦而已。）",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（……嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那邊的草叢好像有些動靜？）",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（真幸運♪",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果是動物或魔物的話，就可以把他們捉來吃了！）",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（這就是所謂的上天的恩惠吧？",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我真是受到命運之神的疼愛呢☆）",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊啊！",
        "unit_id": 105811,
        "voice": "vo_adv_2004002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我要開動～囉……☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀！？",
        "unit_id": 105811,
        "voice": "vo_adv_2004002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊咧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真常遇到你呢～你好嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉抱歉，我差點就砍到你了呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你為什麼要走在草叢裡呀？",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是不是東西掉了呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n需要我一起幫你找嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你是因為有些事要進去深山一趟啊～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過要是被魔物看到的話就麻煩了，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才會偷偷摸摸地走在草叢裡啊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你好像忍者喔！忍者！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你沒聽過嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n據說很久以前有這種具有特殊技能的士兵喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過也僅止於傳說啦～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總之呢～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然我不知道你為什麼要一個人旅行，但這樣很危險的唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟最近魔物的數量異常地增加了許多呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經到了只是稍微出來走一走就會被襲擊的程度。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是隨便走到城鎮外頭的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不管有幾條命都不夠用的喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且你看起來又那麼弱……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～不是～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該說你看起來那麼可愛啦～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是會死掉的呦～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你願意的話，我可以和你同行呦？",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就由我來當你的保鑣吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但作為報酬，請你分我一些食物……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……我的肚子已經餓扁了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你要給我這些小餅乾嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是太感謝你了！",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我絕對不會忘記這份恩情的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以愛上你嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真～好吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～我活過來了，感覺熱量傳遍全身了呢～♪",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃了甜的東西後，腦中會湧出大量多巴胺呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺要愛上你了～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你真的幫了我大忙。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你呀～\n總是一直幫助我呢♪",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以親你一下嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我真的要親了哦？　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可以收回前言哦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總感覺你連親吻都不太曉得是什麼呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟記憶喪失了嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對這孩子做這種強迫般的事，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就好像在騙小孩子一樣，心裡會過意不去。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼東西是當然的？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n親吻嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是在說幫助是當然的啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿嘿～，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有夥伴還真是好呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很開心。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一直都是一個人。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能和{player}成為朋友，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真是超級開心的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先不說這個。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能跟我說明一下你的情況嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說你正要前往位於深山的【伊麗莎白牧場】是嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牧場啊～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像有很多好吃的食物呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說，因為你寄宿的",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【咲戀育幼院】被叫做闇影的東西襲擊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "相當危險……\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以希望",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓孩子們暫時先去避難呀。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然話是這麼說，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但突然大家一起過去的話，會造成對方的麻煩，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才派你做為代表，先向對方打個招呼？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為你和～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【伊麗莎白牧場】的人們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n原本就認識嗎……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是因為這樣\n你才會單獨行動對吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你擔任【咲戀育幼院】的使者，\n前往【伊麗莎白牧場】。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為原本就認識對方，所以應該也比較好商量吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來你就是為了這份工作、",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個使命才會單獨行動啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是辛苦你了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～孩子好～孩子……♪",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "誒嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對不起啊～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我隨便就摸了你的頭……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像太愛和別人肢體接觸了呢～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我一直以來都是自己一個人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以很渴望能和別人接觸呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你問我我在做什麼嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我呀～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為家裡的情況有些特殊……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以正在進行全國行腳，或者該說是武者修行的旅行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會前往各個地方、幫助他人。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果看到造成人民困擾的魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就會去打倒它。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在我們家族中，如果不進行這種武者修行的話，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就不會認同自己是個獨當一面的人喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是一個有點麻煩的家族呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們家族有很多傳統跟規矩，真的是整死我了。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過人畢竟無法選擇自己的雙親和家族嘛～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以這也是沒辦法的事。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我旅行全國各地，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以也能到處吃遍各個地區的美食喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這真的相當有趣呢～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然自己獨自旅行是有些寂寞啦～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "第一次遇到你的時候也是這樣……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我為了報告武者修行的成果，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才會前往我老家所在的蘭德索爾。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但似乎，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "武者修行還遠遠不夠的樣子……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以被家裡趕了出來，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因此我打算暫時繼續走遍全國。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然在蘭德索爾，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再多待上一陣子其實也不錯呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "離開你、",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿、小凱留……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有其他好朋友，讓我覺得有些寂寞。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為這是我的宿命，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以也無可奈何。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "反正又不是這輩子都沒有辦法再見面了。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要我被認可能夠獨當一面的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就可以一直住在蘭德索爾了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來。平常的你，",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不是一直都跟小可蘿在一起的嗎……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天怎麼會單獨行動呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為總覺得有些令人在意的事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以小可蘿要暫時待在神殿裡？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼要待在神殿……？",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那孩子原來是個巫女，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以是在和神明對話囉？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總而言之，我在進行一趟沒有目標的旅行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我並沒有什麼具體的目的地。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以要是你願意的話……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我來當你的保鑣吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會讓你平安地抵達目的地的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果你不介意的話……",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這也算是在幫助人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家都說旅行靠夥伴、處世靠人情呀～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且我也很擔心你的事。",
        "unit_id": 105812,
        "voice": "vo_adv_2004002_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
