        "name": "克蕾琪塔",
        "words": "應緊急召集而來。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n【墨丘利財團】。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_2108002_054"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "克蕾琪塔小姐！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n聽說妳解散了【里士滿工商會】，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "讓我很擔心妳……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但看到妳這麼有精神，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這真是太好了♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉。",
        "unit_id": 118011,
        "voice": "vo_adv_2108002_055"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n如果只照著字面來解讀，這番話分明就是一套諷刺。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但就因為妳百分之百是真的在擔心我，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這反而令人佩服啊……",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "秋乃小姐。",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n非常感謝妳。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝妳願意接受",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼胡來的要求……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不客氣，",
        "unit_id": 103211,
        "voice": "vo_adv_2108002_057"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "公主殿下。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "畢竟【憤怒‧軍團】",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也對我們",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "以及蘭德索爾的市場",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n造成了龐大的損害。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我非常樂意",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "幫忙喔♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "常感謝妳。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要妳能把移動的方法借給我們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "後續就可以交給我們了。",
        "unit_id": 105812
