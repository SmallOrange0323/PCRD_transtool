[
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳說要闖進",
        "unit_id": 106412,
        "voice": "vo_adv_2108002_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "【憤怒‧軍團】的據點……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳是認真的嗎？",
        "unit_id": 100213,
        "voice": "vo_adv_2108002_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n貪吃佩可？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再說，",
        "unit_id": 100311,
        "voice": "vo_adv_2108002_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳知道他們的據點在哪裡嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的，",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我應該知道。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在城堡的王座上，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有留下一張這樣的紙片……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這難道是",
        "unit_id": 100111,
        "voice": "vo_adv_2108002_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "似似花小姐留下的……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "地圖上有做記號啊。",
        "unit_id": 106012,
        "voice": "vo_adv_2108002_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在海上嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有另一個",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "根據。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呈報給王宮的陳述書……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這片海域最近",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎在一夜之間",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冒出了一座島嶼。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說到島嶼出現的時期，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像就是在我們打倒霸瞳皇帝之後。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然因為有魔物在四處遊蕩，",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎很難登陸那座島嶼。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，好像有漁夫在那座孤島的上空",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看見綠色的骷髏飛龍。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n以及……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "乘坐在那隻飛龍背上的女孩子。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個人……",
        "unit_id": 105913,
        "voice": "vo_adv_2108002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蘭法小姐？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個人確實是",
        "unit_id": 100213,
        "voice": "vo_adv_2108002_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "操控著骷髏飛龍呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然正確來說，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n似乎是用某些材料做出來，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "像是魔法生物的東西……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也就是說……",
        "unit_id": 106412,
        "voice": "vo_adv_2108002_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n【憤怒‧軍團】的據點",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就在那座孤島上啊。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "坦白說，如果只有這則陳述書，",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會覺得很可疑。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟很有可能是敵人的陷阱，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總不能",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "叫人去調查這件事……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但既然似似花小姐最後留下的筆記",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也在指示同一個地方，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我認為就有試著闖進去的價值。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 106012,
        "voice": "vo_adv_2108002_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然都談到這裡了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但貪吃佩可，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我覺得連妳也一起闖進去",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實在是有點問題。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_2108002_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想把這件事情交給我們，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而妳等待我們回來，這樣應該比較好。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為妳畢竟是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個國家的領導人。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……這……",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然的確是這樣……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的習慣就是會不由自主地想衝出去……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在也非常清楚，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身為公主，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣真的不太好。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在非去不可。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟【憤怒‧軍團】",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像也有在策畫攻擊蘭德索爾。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想為國家帶來和平，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就必須阻止他們。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再說……",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n似似花小姐為我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "扮演了好幾次替身。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她是因為這樣做對她有利益，所以才願意幫我……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是可是，",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算是這樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我受她照顧的事實並沒有改變。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且就我個人來說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我很想拜託似似花小姐",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以後繼續當我的替身。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我只跟你們說喔……",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣講讓人有點不好意思，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但如果沒有偶爾偷偷出去散步，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的心情……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就會很餓很餓，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "遲早會倒下的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_2108002_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106012,
        "voice": "vo_adv_2108002_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就沒辦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才怪，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳別想把這個話題收尾得像是什麼感人的故事啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這個說法",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不足以構成讓妳親自以身犯險的理由。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "凱留，",
        "unit_id": 100213,
        "voice": "vo_adv_2108002_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳是在擔心",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "貪吃佩可吧……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗚……",
        "unit_id": 106012,
        "voice": "vo_adv_2108002_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是想說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要是這變成肉包子打狗，那也太蠢了吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……妳說得沒錯。",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但如果地點是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "位處於遙遠海上的孤島，",
