    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我們接下來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要去的地方很危險。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對船施展的魔法",
        "unit_id": 103211,
        "voice": "vo_adv_2108002_059"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "會輔助操縱，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n如果只是要飛向目的地的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n並沒有那麼困難。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過……",
        "unit_id": 103211,
        "voice": "vo_adv_2108002_060"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n您要做的事情",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真的很亂來呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n居然說要用飛空艇",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "闖進隔著一片海洋的敵營。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……公主殿下。",
        "unit_id": 118011,
        "voice": "vo_adv_2108002_061"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n請容我先提醒您……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請務必要",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "把這艘船",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n毫髮無傷地還給【墨丘利財團】喔？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為了復興蘭德索爾，",
        "unit_id": 118011,
        "voice": "vo_adv_2108002_062"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "國庫的帳簿相當拮据……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n如果事情落得要賠償飛空艇，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就算把整個國庫倒過來，也擠不出這種閒錢喔。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好、",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "格外小心的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是說啊。",
        "unit_id": 103211,
        "voice": "vo_adv_2108002_064"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如今",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "和獸人族之國的交易",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總算是上了軌道。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我想只要再過一陣子，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "市場上應該就會開始販賣",
