        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105812,
        "voice": "vo_adv_2108002_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我好期待☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是啊。",
        "unit_id": 103211,
        "voice": "vo_adv_2108002_066"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以說……",
