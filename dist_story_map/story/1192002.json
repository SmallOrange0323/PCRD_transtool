    {
        "type": "dialogue",
        "name": "審查員",
        "words": "這場乳牛比賽",
        "unit_id": 2512,
        "voice": "vo_adv_1192002_063"
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "比的不只是美貌，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "\n而是牛隻們的健康美啊。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "牛群團結一致對抗魔物……",
        "unit_id": 2512,
        "voice": "vo_adv_1192002_064"
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "\n",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "她們讓我們看到",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "粗暴的生命力裡充滿了美。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "\n確實值得頒獎。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "因此……",
        "unit_id": 2512,
        "voice": "vo_adv_1192002_065"
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "特別追加今年的大賽獲獎資格。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "\n只要是參賽牛隻，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "都可以獲得獎品。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "\n各位參加者，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "恭喜妳們獲獎！",
        "unit_id": 2512
    },
    {
        "type": "background",
        "background": "500865"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "大賽在盛大的歡呼聲下落幕後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真陽回到了牧場。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她帶著有點驕傲的神情，在餵動物們吃飼料。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好乖好乖……♪",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_066"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n多吃一點喔……♪",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "牛群",
        "words": "哞──────♪",
        "unit_id": 1,
        "voice": "vo_adv_1192002_067"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為拿了大賽獎金而豁出去買了高級飼料，",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_068"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n大家都很開心呢。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大口大口吃不停♪",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "家人被稱讚真的很令人開心呢。",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_069"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "親手栽培，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "付出關愛拉拔牠們長大。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n認同我的做法的人還是存在的啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只是",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_070"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "接下來又要開始忙碌啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n因為聖誕季的時候",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牛奶跟奶油的銷量都會飛耀式成長嘛。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_071"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝你幫我到這麼晚。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比賽的時候也是，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是你在我們戰鬥的後方，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n保護評審和其他沒有戰力的人吧？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "多虧有你，",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_072"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "會場的人，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n和牛孩子都很平安。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我總是受你幫助呢。",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_073"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n說再多的感謝",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也不夠啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因此",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_074"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我有準備頒獎給你喔。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就叫做：",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝你總是陪我一直「講」……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "開玩笑的啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要和老哥在一起",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_075"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就會很放鬆，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n感覺就像真的家人一樣。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_076"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果要找老公，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就要選老哥你這種的啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_077"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛剛說了什麼？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不不、",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_078"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是你想的那樣喔！？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛剛的意思是，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n如果有人可以",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "像老哥一樣陪我",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就好了啦！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "像這樣一起工作、",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_079"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一起吃同鍋飯。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n如果有這麼一個人陪我就好了的意思啦……！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖、",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_080"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我說要像老哥一樣的人，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但可以的話，還是老哥比較好啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為如果是你，",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_081"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n好像可以把我做的飯吃得津津有味，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n然後我也會覺得很有成就感……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊啊，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是啦！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對、",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_082"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對了！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "吃飯！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你今天也陪我到這麼晚，",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_083"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我也總是在依賴你對吧？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_084"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為了感謝你，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我想親自下廚請你吃飯啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "順便舉辦",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "聖誕派對之類的……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個，",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_085"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "希望老哥能",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "賞個臉……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真、",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_086"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的嗎？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們約好囉。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我會使出",
        "unit_id": 119211,
        "voice": "vo_adv_1192002_087"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "渾身解數",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "煮出大餐的啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以老哥你就",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "靜待聖誕節的來臨吧♪",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真陽雙頰微微泛紅，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n羞澀地跟{player}勾手指許下約定。"
    }
]