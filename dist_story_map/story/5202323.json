        "voice": "vo_adv_5202323_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一定不會有問題的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n因為，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有千歌小姐她們跟我們一起嘛。",
        "unit_id": 106411
    },
