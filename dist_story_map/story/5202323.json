    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "必須趁狀況惡化之前阻止它！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都到這裡了，",
