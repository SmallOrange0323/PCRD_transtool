[
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束了長年的海外生活，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n久違回國的真璃"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了問候而前往祖母的家。"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "呃……",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_000"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "在這個轉角轉彎……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n在這條路直走……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "咦？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n又走回剛才那條路了……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "祖母的家是在哪裡來著……",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_001"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "完全迷路了啊。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "話說",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "地圖是要怎麼看……！？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n……唔唔唔。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然平常總是被敷衍過去，",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但今天絕對",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要讓對方好好聽我抱怨才行。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n寺小姐、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "寺小姐！！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "呵呵，",
        "unit_id": 1,
        "voice": "vo_adv_5204069_003"
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "深月，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "妳好♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "啊，",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_004"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "剛剛那是祖母的聲音！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……而且，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "她說話的對象是……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "「妳好♪」",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼啦……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "寺小姐，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我說啊，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n請妳不要",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "跟鄰居到處散播些",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "隨便亂說的話。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼肚臍上抹鹽能治針眼，",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n頭痛的話",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在太陽穴貼梅子就萬無一失♪",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "之類的，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "全都是胡說八道！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是出什麼意外不就糟糕了嗎。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "呵呵，",
        "unit_id": 1,
        "voice": "vo_adv_5204069_007"
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "這不是胡說八道，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "而是老奶奶的智慧啊♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "\n比起那個，深月，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "妳比以往還更氣鼓鼓的呢，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "\n是聯誼派對",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "進行得不順利嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……少囉嗦……",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我現在沒在講那件事吧！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不對！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我不希望妳胡說八道智慧的",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "犧牲者再增加了！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我可不准妳說忘了",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "10年前暴風雨之夜的事啊！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "嗯，",
        "unit_id": 1,
        "voice": "vo_adv_5204069_009"
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "我當然記得喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "\n10年前",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "被猛烈的暴風雨淋到後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "深月發了高燒。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "\n所以奶奶我才很擔心，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "就幫妳圍上了吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒錯……",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n在我的脖子",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "圍上了蔥。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因發燒而做了惡夢的我，",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "鼻子還被蔥的氣味侵襲……！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為那樣，自那以後",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我都變得沒辦法吃蔥了啊！！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "撇開個人的怨恨不談，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我有義務阻止災害擴大。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "但是，",
        "unit_id": 1,
        "voice": "vo_adv_5204069_012"
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "妳退燒了吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唔，",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "退",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是退了啦……！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但就只是我的免疫力戰勝了感冒而已！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n蔥奏效了這種不科學的事，我可……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊啊，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n研究室叫我過去了……！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳的運氣還真好呢，",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天就先放過妳吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但相對地，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我很快又會再來的，早早認命吧！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "呵呵呵♪",
        "unit_id": 1,
        "voice": "vo_adv_5204069_015"
    },
    {
        "type": "dialogue",
        "name": "寺婆婆",
        "words": "\n好──♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……唔？",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_016"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "啊……",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_017"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "妳、",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "妳好。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……？",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳好。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……我的臉上",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有什麼嗎……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "不好意思，",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_019"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "我",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "是寺祖母的孫女，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "我叫真璃。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "那個……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "妳是",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "祖母的鄰居",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "深月小姐",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "吧。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是真璃嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……真是長大了呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好久不見……",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算這麼說，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳或許也不記得吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳還小的時候，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也有陪妳一起玩過喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳現在",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是住在國外之類的嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "是的，",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_022"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "但",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "因為爸媽工作的關係，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "所以我回來日本了。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊，",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那寺小姐也會很高興的吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……那麼，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我還有事，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就先告辭了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……深、",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_024"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "深月小姐！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "謝謝妳",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "總是關心",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "祖母！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "關心祖母？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "是的，",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_026"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "祖母",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "在電話裡告訴我了。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n「鄰居家的深月",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "擔心一個人生活的我，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n總是會假裝抱怨，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "過來看看我的狀況喔」，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "她這麼說。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "祖母總是",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_027"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "非常開心地",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "說起妳的事情！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n她說",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "深月就是她的第二個",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "孫女，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "非常開心的樣子！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "所以，",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_028"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n我久違地好想見見",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "深月小姐！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "想著見到了之後要向妳",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "道謝！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "真的",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_029"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "很謝謝妳！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那個……",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想只是她誤會了喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n那麼，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我還有工作。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……再見囉。",
        "unit_id": 105131,
        "voice": "vo_adv_5204069_031"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "好的！",
        "unit_id": 132331,
        "voice": "vo_adv_5204069_032"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "再見！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "深月與寺婆婆之間的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因緣就這樣被娓娓道來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n還有，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與真璃之間的相遇。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n……可能也曾有過這樣的前世也說不定。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一定有過沒錯。"
    }
