[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉～～～……",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽，怎、怎麼了嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_1077001_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘆了這麼一大口氣……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是、",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是肚子痛嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　好擔心……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我來幫你揉揉肚子唷……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "（揉揉，",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "揉揉……♪）",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 102311,
        "voice": "vo_adv_1077001_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也要揉！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "恢復元氣吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　（揉揉……♪）",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哇哇？\n",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等，好癢啦～……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵。",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我很高興你們擔心我。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "綾音抱歉啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以的話還是讓我用自己的手揉吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n別硬是強迫噗吉來幫忙啦……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喂喂，對我有什麼不滿嗎？』",
        "unit_id": 2111,
        "voice": "vo_adv_1077001_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒問題的哦，",
        "unit_id": 102311,
        "voice": "vo_adv_1077001_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為噗吉很紳士",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會很溫柔地揉揉！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n肩膀很僵硬的時候，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也常常讓噗吉幫我按摩，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n完全不會痛很舒服呢！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音，",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果把噗吉拿來當像抓、抓癢棒一樣使用的話，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n噗吉很可憐吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『還好啦。",
        "unit_id": 2111,
        "voice": "vo_adv_1077001_010"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n無論用什麼方式，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "能幫上對方的忙我就很滿足了』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的很紳士呢……",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總而言之，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請別擔心呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有點煩惱【咲戀育幼院】手頭拮据，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這種和你們無關的大人的煩惱哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔，",
        "unit_id": 102311,
        "voice": "vo_adv_1077001_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽總是馬上把我們當作小朋友！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真、",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真的有這麼缺錢嗎、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然說經營上沒有吃緊到，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n馬上得讓大家流落街頭的程度。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過整體而言很缺錢呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "非常讓人頭痛啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果不趁早",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "解決根本的問題，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可能就得繼續過著寒酸的生活。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然也希望",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "盡可能讓你們過著好一點的生活。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～……",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能想到的方法，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也只有在各方面再更節省一點呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過問題的源頭是收入不足啊～，",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無論再怎麼盡量減少支出，這樣下去可能無法維持生活了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐～！",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哇哇！？",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "　鈴莓，怎、怎麼了嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別這麼吵吵鬧鬧的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣一點也不優雅哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "抱，抱歉！",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我實在沒辦法冷靜下來……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比起這種事。",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我可以去短期打工一下嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼？",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "　打工？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是沒關係啦，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過還滿突然的呢……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不是，那個。",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "之前就一直想著",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有點想打工之類的～。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "【咲戀育幼院】",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "的經營狀況也不是太好吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……\n現在正在因為這件事而煩惱呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對吧。",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "然後那個……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n自己去工作也能稍微貢獻一點家計。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "慢慢習慣了這裡的生活，",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n孩子們也都愈來愈自動自發不用人照顧……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "家事也有",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}或是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可可蘿之類的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還有大家一起幫忙分擔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "白天的時候，",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "意外地我常常閒得發慌呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n然後",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "想說既然這麼空閒，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就好想出去外面工作呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以就開始",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "閱讀就業情報雜誌之類的書，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n然後找到了看起來還不錯的工作。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你看你看……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然是簡單的短期打工，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "薪水還很不錯哦。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓我看看。",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……嗯，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "的確是相當不錯的工作呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n工作也是服務或打掃之類的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n和鈴莓平常在做的工作差不多，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像也不會很難呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "什麼什麼？",
        "unit_id": 102311,
        "voice": "vo_adv_1077001_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哇，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "在海之家打工？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　什麼是海之家？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好像是會在海邊擺的攤子……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "之類的？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會賣炒麵之類的東西哦，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n以前",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好像曾經和誰一起去過的樣子……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "記得好像是和家人，",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也就是和父母……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我的父母",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為『消失』中，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以不是很確定，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不過隱隱約約",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "記得好像有",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "又好像沒有",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "的樣子……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚，",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一想到父母",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "頭就變得好痛。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒、沒事吧？",
        "unit_id": 102311,
        "voice": "vo_adv_1077001_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "幫你摸摸頭哦。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "（摸摸……♪）",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻嘻……",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n綾音，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝謝……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，",
        "unit_id": 102111,
        "voice": "vo_adv_1077001_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "先別說我了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐姐既然想工作，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想幫你加油呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "白天確實",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為沒什麼事要做所以很閒呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯，",
        "unit_id": 102311,
        "voice": "vo_adv_1077001_039"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我也因為太無聊，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "已經到了開始看不想看的書的程度了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣啊……",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過【咲戀育幼院】，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也沒在進行什麼活動呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我被各種經營上零零總總的細節，",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n以及各式各樣的事情給追著跑總是很忙碌。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但你們就很空閒呢……",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是不好意思",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒幫你們想到這些。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐不需要道歉……",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總而言之",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "打工是可以的對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那麼就先寫履歷，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "立刻寄給對方好了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "當然薪水就會，",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n全部拿去作為【咲戀育幼院】的營運資金所用♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不不，",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你們賺到的錢",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就用在自己身上吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拿來買漂亮的衣服、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吃美味的食物，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有出去玩的話如何？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "幫助大小姐……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想做的事情",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就是幫助【咲戀育幼院】♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～……\n",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也是呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很像是鈴莓會說的話呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "從以前開始就是個乖孩子。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不過我放心了～，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還以為你會徹底地反對呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐總是把我們保護過頭，",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以我們也很想盡可能地減輕你的辛勞。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是這樣嗎……",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "基本上是主張讓心愛的孩子出去外面磨練的唷？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓的個性很冒失呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好擔心你會不會給對方添麻煩啊……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n拜託",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要發生",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不小心破壞了海之家，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反倒還得支付賠償金之類的疏失哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒、",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_052"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒問題的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大概！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會盡量小心的！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是相信你啦……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但鈴莓是第一次去一般的打工吧，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在還沒習慣的時候也不要太勉強哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "另外如果被奇怪的男生給搭訕，",
        "unit_id": 102811,
        "voice": "vo_adv_1077001_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也絕對不要跟著他走。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n然後，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也要好好防曬之類的……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、我知道啦！",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我又不是小孩子！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我",
        "unit_id": 102511,
        "voice": "vo_adv_1077001_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會拚了命地努力工作的！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為了最喜歡的大家……☆",
        "unit_id": 102511
    }
]