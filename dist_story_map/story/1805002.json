        "voice": "vo_adv_1805002_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "左手出布……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變成凱留小姐的耳朵♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐的耳朵～♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "學得很棒呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來挑戰下一個吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "右手出拳頭，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "左手出剪刀……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有人在嗎～",
        "unit_id": 1,
        "voice": "vo_adv_1805002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦？",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不曉得會是誰來拜訪？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請在這稍等一會。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "不好意思突然來打擾。\n{player}呢……？",
        "unit_id": 1211,
        "voice": "vo_adv_1805002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要找主人的話，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他就在這裡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "噢，太好了。",
        "unit_id": 1211,
        "voice": "vo_adv_1805002_007"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n我是",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "他打工的地方，也就是郵差公會的成員……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "雖然我之前就已得知他打算長期休假，",
        "unit_id": 1211,
        "voice": "vo_adv_1805002_008"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n但這次無論如何都希望{player}能幫忙……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n因此，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "我今天才會前來拜訪。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "事情是這樣的，",
        "unit_id": 1211,
        "voice": "vo_adv_1805002_009"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "由於送貨人員不足和委託數量增加，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "我們的送貨進度已開始落後……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "還請你們好心幫幫忙，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "今天一天就好，可以來幫忙送貨嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟是主人平時受到很多關照的打工雇主，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "考量到往後，也不好就此拒絕。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人他……",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目前身體有些不適，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就由在下來替他送貨吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也多少",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對蘭德索爾這地區有些熟悉了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應能派上用場的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "真的可以嗎？",
        "unit_id": 1211,
        "voice": "vo_adv_1805002_013"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "非常感謝！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n那麼，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "我待會就把貨物跟",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "記載著收件地點的地圖拿過來！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……雖然就這樣",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接下了工作……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下也無法扔下主人孤身一人，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己跑出去送貨。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，只是去送貨的話，應該沒什麼危險，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若出了什麼事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鎮上的大家應該也會伸出援手的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "待會就和在下一起",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出門散步吧♪",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──請在此處",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蓋上印章簽收。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒問題～",
        "unit_id": 311,
        "voice": "vo_adv_1805002_018"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "辛苦啦！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "送完剛才那一戶，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個地區的貨物就全解決了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看樣子似乎可以平安結束送貨工作，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下感到安心多了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出來散步感覺如何呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那真是太好了。",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今日天氣也不錯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相當適合散步呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "往下個地區前進吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下看看，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接下來是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根據地圖所標示，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應當在這附近才是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真古怪，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遍尋不著感覺像是目標的宅邸呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您知道",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這戶人家在哪嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您莫非",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是睏了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟說是散步，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還比較像是做了充分的運動，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會想睡也是情有可原。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回去後",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就來睡午覺吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在那之前得完成送貨工作才行……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "地圖上的標示是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "啊！",
        "unit_id": 211,
        "voice": "vo_adv_1805002_027"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "是大哥哥～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "喂～！",
        "unit_id": 111,
        "voice": "vo_adv_1805002_028"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "來一起玩嘛～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔？",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這幾位是？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "因為感覺很好玩，",
        "unit_id": 111,
        "voice": "vo_adv_1805002_030"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "所以我們平常都會跟著大哥哥去送貨喔～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不過，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "他今天怎麼看起來很想睡啊？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "你沒事吧～？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "振作點呀～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "喔～",
        "unit_id": 111,
        "voice": "vo_adv_1805002_031"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "今天是大姊姊負責送貨嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這附近的路很複雜，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "很容易迷路呢～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "你說會跟著主人去送貨，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n意思是你認得",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他送貨時所行的路徑嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "對呀～！",
        "unit_id": 111,
        "voice": "vo_adv_1805002_033"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我家也在附近，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "對這裡很熟的～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果可以，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能麻煩你們協助在下送貨嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這邊是標有",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "送貨路徑的地圖……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好啊～！",
        "unit_id": 211,
        "voice": "vo_adv_1805002_035"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n大哥哥，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "像平常那樣一起去送貨吧～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "勞煩你們幫忙了。",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_036"
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這戶便是最後一家了。",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "十分感謝你們的協助。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "再不快點回家，",
        "unit_id": 111,
        "voice": "vo_adv_1805002_038"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "會被媽媽罵的。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "所以我差不多要回去啦！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我也是！",
        "unit_id": 211,
        "voice": "vo_adv_1805002_039"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "大哥哥，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "下次再見～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回去路上還請小心呀。",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來主人",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您在這種地方",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有可靠的夥伴在呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也因為如此，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下又再次受到鎮上居民的幫助了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "快點將貨送完，回去吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟目前所花費的時間比預想中還多，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也得盡早回去，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "處理餐點以及",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "洗衣服等事了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "哦，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_043"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "以前沒見過妳呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "新來的送貨員？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是的，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只有今日",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前來代班，協助處理送貨工作的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請您在此處蓋章。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "這樣呀……",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_045"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "哎呀？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "結果平常那個小哥也在嘛。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n是來陪妳送貨的囉。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "對了，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_046"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "既然如此，這個給你們帶回去吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n是我常做的燉菜，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "我又不小心煮太多了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人每次出去送貨時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都會收到的燉菜呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來不是打工的報酬之一呀。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "哎呀，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_048"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "妳該不會",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "就是可可蘿吧？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "他常常會提起妳呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "今天怎麼會來送貨呀？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個……",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實是主人他……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "原來是這樣啊……",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_050"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "一定很辛苦吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "這樣一來，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "今天只給這點燉菜恐怕不夠啊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "讓我過去幫點什麼忙吧！",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_051"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "既然你們出來送貨了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "那應該代表還沒有準備晚餐吧？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼好意思",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您再多做什麼……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "沒關係，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_053"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "沒關係啦。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n你們都幫忙處理囤積著送不完的貨物了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "這只是一點小回禮而已。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "我想這個時間",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_054"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "大家的家事都做得差不多了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "你們",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "去回報完送貨的結果後，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "就先回去吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "我們晚點就會過去公會小屋那邊的！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家……？",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們是指……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "好了好了，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_056"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "別在意這麼多了！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "那麼，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "待會見啦！",
        "unit_id": 1511
    },
    {
        "type": "background",
        "background": "500367"
    },
    {
        "type": "dialogue",
        "name": "主婦2",
        "words": "可可蘿～！",
        "unit_id": 411,
        "voice": "vo_adv_1805002_057"
    },
    {
        "type": "dialogue",
        "name": "主婦2",
        "words": "垃圾桶滿了，我幫你們把垃圾拿出去倒囉～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "主婦3",
        "words": "可可蘿，",
        "unit_id": 611,
        "voice": "vo_adv_1805002_058"
    },
    {
        "type": "dialogue",
        "name": "主婦3",
        "words": "洗好的碗盤放在那邊的棚架上可以吧？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "碗盤請放在那邊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔唔……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然還是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下也幫忙吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "不用啦，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_060"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "沒關係。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "家事就交給我們吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n大家可都是經驗相當老道的家庭主婦了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "呵呵。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但、",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不能就這樣全都讓各位幫忙呀……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "我們平時",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_062"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "都很受他的關照，這彼此互相照顧一下而已啦。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "而且呀，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_063"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "他在送貨時，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n老是會吃可可蘿讓他帶在身上的飯糰，吃得津津有味呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "「多虧了這個，我才能如此努力」。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "他之前是這麼對我說的。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "所以呢，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_064"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "我們平時能夠得到他的關照，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n說到頭來，也是多虧了可可蘿妳唷。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "我們一直以來都很想找機會回報一下，",
        "unit_id": 1511,
        "voice": "vo_adv_1805002_065"
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦1",
        "words": "因此，可可蘿妳就和他一起好好地休息吧。",
        "unit_id": 1511
    },
    {
        "type": "still",
        "still": "180500201"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下為主人捏飯糰時，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也並未考慮到如此長遠的層面。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下只是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一心一意想為主人送貨的工作出份力，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n然後將這份心意捏進每一個飯糰中而已。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "未料在下為主人的奉獻，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟在因緣際會之下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回報到自身上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n此事在下著實始料未及。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "180500202"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但也多虧如此，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_068"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今日在下才能",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與主人如此共度時光。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了主人……",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了大家，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下得再更誠心奉獻才行呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在那之前……",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就順著大家的好意，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一同悠閒度過今日吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝您今日陪伴在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n去進行在下不太熟悉的送貨工作。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您一定相當累了吧。",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n老實說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也走到有些累了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們一起",
        "unit_id": 105913,
        "voice": "vo_adv_1805002_073"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "睡午覺吧……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿讓{player}的頭靠在自己肩上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n露出安詳的表情，進入了夢鄉。"
    },
    {
        "type": "still",
        "still": "end"
    }
]