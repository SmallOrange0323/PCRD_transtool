    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "至今為止",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家都辛苦了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這一路上積累的所有努力是不會背叛你們的。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要相信",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "自己的力量唷。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒錯沒錯！",
        "unit_id": 113411,
        "voice": "vo_adv_5046451_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n大家連教練們的魔鬼特訓",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "都熬過了嘛！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不會這麼輕易就輸掉的！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "接下來",
        "unit_id": 113511,
        "voice": "vo_adv_5046451_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "只需要發揮出實力就行了哦。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "昂首挺胸，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "盡全力",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在球場上奮鬥吧～！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為了讓你們有200％的活力奮鬥，",
        "unit_id": 113411,
        "voice": "vo_adv_5046451_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我會在觀眾席上大聲加油的～！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "聲援交給我，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大家就盡情享受比賽吧！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來，",
        "unit_id": 113511,
        "voice": "vo_adv_5046451_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們去實現夢想吧！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n如果是你們，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一定能拿到",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
