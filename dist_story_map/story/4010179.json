    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯……？",
        "unit_id": 123331,
        "voice": "vo_adv_4010179_002"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那隻小猴子，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "跟某人長得很像耶～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "一直嘰嘰叫不覺得就像小卡里莎一樣嗎？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哼哼，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "拍個照吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "很好，",
        "unit_id": 123331,
        "voice": "vo_adv_4010179_003"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "再來是三人合照～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "小",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "騎士，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "再靠過來一點～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "你不好好貼著姐姐的話，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "就沒辦法拍出可愛的照片囉～？",
