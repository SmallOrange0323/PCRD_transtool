    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "OK～",
        "unit_id": 123331,
        "voice": "vo_adv_4010179_004"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n嗯哼，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "很不錯嘛♡",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "手機解鎖畫面換成這張好了～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯～",
        "unit_id": 123331,
        "voice": "vo_adv_4010179_005"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "雖然",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "也喜歡動物，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "但也蠻喜歡巡邏的？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "你想想～",
        "unit_id": 123331,
        "voice": "vo_adv_4010179_006"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "來動物園",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "是遠足的經典行程嘛。",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n所以可以一邊看動物，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "一邊幫助落單迷路的小孩～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "這樣還能看到小孩的笑容，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "雙重養眼呢♡",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "沒有啦～",
        "unit_id": 123331,
        "voice": "vo_adv_4010179_007"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "話說",
