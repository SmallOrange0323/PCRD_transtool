[
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "噫、",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是強烈的殺氣……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看起來是一位非常強悍的人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正面交戰的話",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺絲毫沒有勝算。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "光憑氣勢就足以壓制場面……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是主人認識的人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下想還是老實的現出真面目，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "用誠摯的態度去說服對方比較好。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別再躲躲藏藏了，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "希望你們能趕緊出來呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟我也不怎麼擅長耍小手段，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n盡可能地想要正大光明的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "和你們面對面。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果不想遵照禮節，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "打算奇襲的話也無妨就是了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但如果那樣的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也不會有多高尚的應對唷。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀、",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "壓迫感又更強了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個人的體型，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "忽然間給人有更巨大的感覺！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍、",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍等一下！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非是您的敵人！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？　",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小孩子嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n迷路……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大概也不太可能",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就算是迷路，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或是抱著惡作劇或半開玩笑的心態偷溜進來的孩子也一樣。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只要是入侵『王宮』的人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不論是誰一律都得處罰。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "依照陛下所制定的法律，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這種行為可是被嚴禁的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對觸犯此法的傢伙可不能輕易放過，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖說輕微",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "卻也算是國家叛亂罪了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "念個幾句讓妳們好好反省一下，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然後就把妳們給送回家……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可不是這種程度就能解決的問題。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個嘛，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該從哪裡開始說明才好呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n該、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好呀，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊啊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "果然是你嗎……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "{player}少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n聽到聲音就察覺到了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還想說如果是我聽錯該有多好呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是遺憾。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像你這樣的好孩子，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "竟然非得要收拾掉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "噫、",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明就看見了主人……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n殺氣卻絲毫沒有任何減弱？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大多數的情況下，",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果跟主人的朋友說明，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都願意把話聽進去的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "計畫失敗了嗎……？",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n該、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好呀？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n意思是你為了救出重要的友人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "才會像這樣入侵『王宮』。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n突破嚴峻的警備、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "賭上性命……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "簡直就像童話中的王子。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是令人感動的故事呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n都想替你鼓掌，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "眼淚都要掉下來了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你已經觸犯了法律，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可不能只因為同情就放過你。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只能說感到很抱歉囉。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我也不是第一次說了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是我的職責。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n將犯罪者就地解決，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就算是你也一樣。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？　",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "突然做什麼？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位溫柔和善的主人，",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然這麼直接的發動了攻勢……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……真過份呢，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n突然之間，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就拿劍砍了過來呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過這點程度的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "連防禦的必要都沒有就是了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有如果你真打算要偷襲，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n時機要再看準一些比較好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n「我要攻擊囉」，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你的舉止就像在告訴別人這件事唷。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也不是只會呆站著的木頭人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是會反擊的喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果你真的想要我從這裡讓開，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你就應該在最初的一刀就將我斃命才對。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為剛才那一擊，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我已經完全做好迎戰的準備囉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n別看我這樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "直到剛才都還挺悠哉的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我可沒有愜意到，就連被攻擊了",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還會繼續毫無防備。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真的很遺憾呢，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你已經失去了最大、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最後的機會了。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "順便就和妳解說一下，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n地下監獄入口前的那件鎧甲裡頭是空的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只是",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "放進了能夠接收音波的秘石，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我們剛好新進了個",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "相當擅長魔法的人呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳們對那空蕩蕩的鎧甲越是警戒，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "越是沒辦法注意到真正的我從後頭悄悄接近。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這種詐騙一樣的手法很讓人不齒呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "尾狗刀的性格可真差。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但卻非常有效。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣就死棋了唷，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "希望妳別再抵抗，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "乖乖束手就擒。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不！",
        "unit_id": 105911,
        "voice": "vo_adv_2011003_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還能夠戰鬥！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳是贏不了我的唷，",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "惹人憐的孩子……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是因為知道了我和{player}少年有所認識的關係嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n儘管看起來像是拚了命想打倒我，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但卻絲毫感覺不到殺氣。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你真是個溫柔的孩子呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也因此你",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "殺不了我。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也戰勝不了我。",
        "unit_id": 104711,
        "voice": "vo_adv_2011003_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這一切都到此為止了唷。",
        "unit_id": 104711
    }
]