    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "上啊！",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉全力揮～擊☆",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼哼♪",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n很好……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和練習的一樣",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n有好好使出來！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這就是我的必殺技",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n噗吉全力揮擊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "無論是什麼魔物，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我都能一擊打飛！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我和噗吉是最強組合！",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然被人叮嚀過城鎮外面很危險，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但根本沒什麼嘛！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也完全沒有魔物出現，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "簡直就是和平♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「別大意了，",
        "unit_id": 2111,
        "voice": "vo_adv_1023001_006"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n雖然不管出現什麼魔物，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我都會把牠給打飛……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「但妳可別離開城鎮太遠，",
        "unit_id": 2111,
        "voice": "vo_adv_1023001_007"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n否則有可能會迷路。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我知道啦～",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過沒問題啦，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我有帶好地圖！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "應該能遠遠地看見索爾之塔對吧？",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n只要把那個當成地標……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "索爾之塔",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "跑哪裡去了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n咦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "奇怪？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真傷腦筋，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在森林裡就看不太到上面的樣子呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這個嘛……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你可以去幫我看看嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿咻……♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「嗯～",
        "unit_id": 2111,
        "voice": "vo_adv_1023001_013"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "沒辦法吧。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我的長度……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不對，是身高連樹的上方都搆不著。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n總之，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "照原路折返應該會比較快吧？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯～",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "說的也是。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可是，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我是從哪裡走來的？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「沒有腳印",
        "unit_id": 2111,
        "voice": "vo_adv_1023001_015"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n之類的痕跡嗎？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯……",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我不知道。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n怎麼辦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我原本是想把索爾之塔",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "當地標就好了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以都沒怎麼注意周圍！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我……",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n該不會是迷路了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「別慌張，",
        "unit_id": 2111,
        "voice": "vo_adv_1023001_019"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我們沒走那麼遠，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n只要別搞錯方向，應該很快就能走出森林。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「冷靜下來，",
        "unit_id": 2111,
        "voice": "vo_adv_1023001_020"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n回想起自己是從哪個方向走來的。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔、",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n唔……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "蹲下來，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n把臉貼近地面，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "或許就能看得見腳印了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "感覺會衣服沾到泥巴弄髒，我不太想這麼做就是了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我看看、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我看看喔？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n有、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有人倒在地上了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在那邊的",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "樹叢那裡！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "難道是、",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "屍體……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "討厭討厭，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我不想看那種東西！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n晚上會睡不著覺啦～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉可以去幫我看看嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「喂，給我住手。",
        "unit_id": 2111,
        "voice": "vo_adv_1023001_025"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n別用我去戳",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "屍體（暫定）啊。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔～？",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "他的腳動了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好像還活著，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "應該只是昏過去了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "難道說",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n他是被噗吉全力揮擊給波及到了……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那、",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你還好嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n對不起，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這該不會是我的錯吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呃……",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是誰？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒有見過你耶～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼嗯，{player}？",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那麼，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我叫你{player}哥哥喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我叫做",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "綾音！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這個是噗吉！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "請多指教♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "第一次見面",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就會跟噗吉打招呼的人真少見♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你好像",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是個滿好的人呢♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這才不是腹語術啦……",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉是",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我的摯友",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也是家人♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "總之，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你為什麼會倒在這裡？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "果然是因為",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我的關係？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對不起。",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我下次",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會確定周圍都沒人，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n才使出噗吉全力揮擊。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我有反省了，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_037"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n原諒我好嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n作為賠禮，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我給你療傷藥。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽說「以備不時之需」要我帶著，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_039"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n她擔心我出事，都會讓我帶很多東西。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我來幫你擦藥，",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_040"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這樣我們就和好囉？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你願意",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "原諒我了嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對……",
        "unit_id": 102311,
        "voice": "vo_adv_1023001_041"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這也算是某種緣分，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "請你和我當朋友吧♪",
        "unit_id": 102311
    }
]