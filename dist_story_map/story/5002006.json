    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了治療美美的病，造訪地下迷宮的三人組，\n再度對上了魔物。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好──吧，首先把小魔物解決掉！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_000"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿嘿！發出那種聲音也不怕你啦！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "剛剛被你修理了一頓呢！吃我這招，刺眼檸檬汁！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊哈哈哈哈哈！怎麼樣，認輸了嗎！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華！現在就是機會！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝妳，禊！呀啊！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_003"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "太好了！就用這個氣勢打倒那隻大傢伙吧～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "果然比剛才好打多了！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n吵架果然不是什麼好事！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒錯沒錯！禊也不再心浮氣躁，精神百倍了！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "趕快打倒它去採藥草吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯！現在禊和鏡華是最強的！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n只要是和鏡華一起，什麼困難都能克服！！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你……那個……也要謝謝你。",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "多虧了你，感覺和禊的感情比以前更好了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "阿爾瑪",
        "words": "──咕喔喔喔喔",
        "unit_id": 10211
    },
    {
        "type": "dialogue",
        "name": "阿爾瑪",
        "words": "！",
        "unit_id": 10211
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀！力，力量湧出來了……這樣的話！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n禊！我隨時都沒問題的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "OK！先在鏡華和哥哥之前出手……",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "喂喂──！這邊啦！慢吞吞的魔物！慢吞魔物！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "阿爾瑪",
        "words": "──咕喔喔喔喔！",
        "unit_id": 10211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就是現在！嘿呀！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "（吸氣）要相信禊……冰啊，出來吧！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_012"
    },
    {
        "type": "still",
        "still": "500200601"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈啊啊啊啊！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "太好了！光被冰反射回去了！這樣的話！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "被自己的攻擊……給幹掉吧",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "阿爾瑪",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 10211
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "正中目標！我就這樣保持冰持續出現，",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n禊，拜託妳解決它了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯！交給我吧！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要上囉～！禊特製的超特大炸彈！飛吧！",
        "unit_id": 100411
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "阿爾瑪",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 10211
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "打敗它了……好厲害啊禊！真的打敗它了！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿嘿嘿嘿，畢竟禊是天才嘛！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_019"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……雖然很想這麼說，其實是多虧了鏡華啦！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒有這種事啦，妳看，戰略也是禊想到的啊！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是鏡華教我反射的知識啊！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……啊──",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿嘿，吵架之後，又把鏡華教過的事",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n再複習了一次！只不過心浮氣躁地馬上就放棄了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n雖然教的是鏡子，冰也能成功實在是太好了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯嗯，就算是那樣，還是很厲害唷！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我就算懂得反射的知識，也沒有想出這種作戰啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那種靈活的反應，就是禊的長處呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是，是這樣嗎？嘿嘿嘿，被鏡華稱讚了耶～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……啊！對，對了，藥草！得趕快送去美美家啊！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "房間的深處有出口哦！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n禊、{player}，我們趕快吧！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗚哇！好美！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒想到穿越山峰，眼前竟然展開了這樣的景色……",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "教科書上記載的事，並不是一切哦，鏡華同學……",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這話是什麼意思？",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯，不過真的是那樣呢。說不定就像禊所說的……",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有些事遠比教科書裡記載的事更重要呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊也教了我一課。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "終於明白了嗎？那麼以後唸書也適當──",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那就另當別論！走吧，我們去找藥草啦！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_033"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "果然鏡華還是鏡華啊～",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_034"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那個，藥草是……",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……啊，就是這個！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_036"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個？怎麼看都是花啊……",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這種花的葉子和莖的部分可以做成藥草！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_038"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那只要把這個帶回去，就能讓美美退燒了對吧！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_039"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯……我們辦到了呢！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_040"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯，真好玩～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_041"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然是很花時間的探險，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n但是能走到這地步也是因為有鏡華和哥哥在啊！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也是，有禊和這個人在才能努力到現在！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_042"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是禊給了我勇氣所以才能戰鬥的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿嘿……從來沒有被人那麼說過，真是不好意思吶",
        "unit_id": 100411,
        "voice": "vo_adv_5002006_043"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼下次……小小甜心大家一起去探險吧！",
        "unit_id": 103611,
        "voice": "vo_adv_5002006_044"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，鏡華和禊就這麼團結一心，一起達成了目的。\n如此稍微成熟了一丁點，回到城鎮去了。"
    }
]