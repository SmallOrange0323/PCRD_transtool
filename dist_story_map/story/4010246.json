    {
        "type": "dialogue",
        "name": "志名都",
        "words": "這裡是……",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_000"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "現實世界？",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "為何",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我會",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "在這裡？",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "等等，",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_001"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "不太對……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "這是夢嗎。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n我在這夢裡變成了理想中的模樣……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "雖然不知是出於誰的意思，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "但感覺並沒有惡意。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "你也在這裡？",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_002"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "這樣啊，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "原來如此……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n是因為我想要有",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "跟你獨處的時間……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "才產生了這個夢啊。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "……",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_003"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "沒事，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "當我什麼都沒說。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "話說",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "你接下來要幹嘛？",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "有什麼想去的地方",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "或想做的事，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我都可以陪你去。",
        "unit_id": 135631
    },
    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "呼……",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_004"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "找個寧靜的地方放空一下",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "真的很棒呢。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n青翠的草木、",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "晴朗無雲的天空……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "光是看著",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "就覺得心曠神怡……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "老實說，",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_005"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我有點受不了",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "大街上那種吵雜的環境……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n我天生就很難投入一般人",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "所從事的娛樂活動中。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "所以……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "感謝你",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "帶我來這個地方。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "可是……",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_006"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "像這樣呆坐著，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "你都不會覺得無聊嗎？",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "一直勉強你配合我的喜好的話，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我會覺得",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "有點過意不去……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "唔……",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_007"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "感謝你的好意……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n但這究竟是",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "基於什麼理由？",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "生日",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_008"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "是指……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我的？",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "啊啊，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "這樣啊……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n我根本想都沒想過",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "自己會有那種東西呢……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "呵呵……",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_009"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "這麼",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "說起來，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "今天",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "確實是個",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "無比特別的日子。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "那我也就沒有必要客氣了吧……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "你的生日祝福",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我確確實實收到了。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "這是……",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_010"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "釣魚用具？",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "呵呵……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我會心懷感激地使用的。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "對了，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "下次有機會見面的話，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "一起去釣魚如何？",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "嗯，",
        "unit_id": 135631,
        "voice": "vo_adv_4010246_011"
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我會永遠記得",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "今天的事。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n不論是你送我的禮物，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "還是一起去釣魚的約定……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "我都絕對不會忘記。",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "\n……",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "謝謝你，",
        "unit_id": 135631
    },
    {
        "type": "dialogue",
        "name": "志名都",
        "words": "{player}。",
        "unit_id": 135631
    }
