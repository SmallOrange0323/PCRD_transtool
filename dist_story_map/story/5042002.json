        "voice": "vo_adv_5042002_079"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "身上沒有特別痛的地方，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "頭腦也很清醒。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n像是做了一場惡夢的感覺。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是妳救了我吧。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "謝謝。",
        "unit_id": 1111
    },
