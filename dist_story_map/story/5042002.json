        "voice": "vo_adv_5042002_080"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "別這麼客氣。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不必道謝……",
