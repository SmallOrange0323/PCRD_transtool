    },
    {
        "type": "dialogue",
        "name": "璃乃等人",
        "words": "紅心皇后？",
        "unit_id": 1,
        "voice": "vo_adv_5042002_083"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "最近",
        "unit_id": 1111,
        "voice": "vo_adv_5042002_084"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "她自稱是這個國家的統治者，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "甚至佔據了一座城堡。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n轉眼間勢力不斷地擴大，是個可怕的傢伙。",
