    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "但傳聞中與黑之王聯手的那位紅心皇后，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n我倒是知道她的所在之處。",
