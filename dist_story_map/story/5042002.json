    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我的功勞就是你的功勞。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "實際上",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "射出箭的人也是妳呀。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥……",
        "unit_id": 112912,
        "voice": "vo_adv_5042002_076"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝你。",
