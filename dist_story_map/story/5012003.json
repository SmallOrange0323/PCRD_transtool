        "voice": "vo_adv_5012003_031"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我叫步未！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我會把關於前輩的事，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "全部告訴你們！",
        "unit_id": 105511
