    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "目擊了馬車暴走事件的步未，\n逃離開了霞她們，一個人邊走邊想事情。"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊……",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "天都黑了呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩今天也很平安，太好了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真多虧那個獸人族的人……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真琴的幫忙。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "…………",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "針對前輩而來的攻擊，",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "越來越激烈了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "霞和真琴，",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像還覺得可能只是偶發事件……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但不是的……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為一直看著前輩，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以我知道……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一定是被某人給盯上了！　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣下去可不行……",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "若不快出手，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩會……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不知道對方是誰的話，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說什麼都不會有人相信的……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……咦？",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n怎麼了，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這感覺。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "感覺氣氛突然變了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦。",
        "unit_id": 1,
        "voice": "vo_adv_5012003_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "注意到了啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呀！？",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_009"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "　誰、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "誰！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還問是誰……",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n會是誰呢？　",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "猜猜看啊？",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊、",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_011"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊嗚……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀呀，",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怕到發不出聲音來嗎？",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真不錯呢，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這股生澀感。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有如剛摘的果實。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我名為……",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哀嘆之女神。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n渴求痛哭與絕望者。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "我一直在看著喔……",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_014"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "他可真是極品呢。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n有眾多女子",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "愛慕著他……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n看來",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "你也是其中一人吧。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "若他遭逢悲劇，",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_015"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n那在這蘭德索爾之中，會產生出多少的絕望呢？",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n呵呵呵，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "光是用想的都令人興奮呢……！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那種",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "事……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "才、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不會……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "放心吧。",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_017"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n你啊，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "什麼事都做不了。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "我是知道的。",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_018"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n因為你",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "跟以前的我有著相同的氣味。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦……？",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_019"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "篤定自己什麼都不會而自我決斷……",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_020"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n當一切都染上絕望後，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "開始詛咒自己……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n那種",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "愚者的氣味。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "還請你，",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_021"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "放棄鼓起那一絲絲的勇氣，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n就看著他到最後吧？",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "如爛泥般糾纏，",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_022"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "真是期待那黑暗的絕望。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚、",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_023"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不可以……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "啊，",
        "unit_id": 11111,
        "voice": "vo_adv_5012003_024"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "真不錯。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "你那副表情。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n一副要抵抗恐懼感的樣子，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "束手無策被吞噬的樣子，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "真棒的表情……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n我已經開始期待了呢……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊……",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_025"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "等、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "等等……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "現、",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_026"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "現在這是……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不會",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "錯的。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n是盯上前輩的",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "魔物……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n果然前輩的",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "性命被盯上了！！　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "再、",
        "unit_id": 105511,
        "voice": "vo_adv_5012003_027"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "再這樣下去前輩會……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我得想想辦法……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n想想……！　",
        "unit_id": 105511
    },
    {
        "type": "background",
