        "type": "dialogue",
        "name": "步未",
        "words": "不、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不好意思！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我要跟真琴和霞",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說件很重要的事！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
