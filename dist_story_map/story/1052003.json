[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘿～咿",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "☆",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好痛痛痛…",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "…\n用太大力，手都麻掉了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，這麼一來需要的木材就砍得差不多了吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "接下來只要搬運到牧場，\n稍微加工，整理成合適的大小……",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "最後把客人訂購的份量，運送到城鎮就OK了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻。\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "搬運木材的路上，常常會遇到那個人……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很期待遇到那個人，所以人家才這麼投入工作。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且那個人，\n能跟這樣的我毫無偏見地聊天。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "最喜歡那個人了",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "。\n當然",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，是朋友那方面的喜歡！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n嘻嘻",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "～♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真想見見那個人……\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就當作是為了這個目的，好好努力工作吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘿～咻",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯～……果然比起劍，",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n用斧頭之類的比較適合採伐木材呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過，我的手就只用得好這把劍呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，木工的工作也變得很好玩。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n嗯嗯",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，任何事情都得開心地去做，這才對呢～♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為我比較粗笨，\n就只做得來採伐木材之類的事情。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n之後",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "再來查看看木雕人像的做法好了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是能做出不錯的成品，\n說不定也能擺在牧場的販賣部之類的地方當伴手禮賣。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我得報答受人照顧的恩情，\n為【伊麗莎白牧場】做出貢獻才行。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "關於木工的書，\n只要拜託小栞就能拿到手了呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n要是",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能自己去買就好了，不過我不能進出城鎮。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，沒關係。\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "隨時都得正向思考才行呢～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "每天過得都算充實、也很幸福。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "再要求更多的話，就太貪心了呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "{player}！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你在這種山裡做什麼？",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "看起來慌慌張張的……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哇呀！",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "？\n怎怎怎、怎麼了？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不要亂來！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為什麼要拉著人家走呢？\n好好說明一下，不可以用強迫的！",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是沒有愛就不行……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗚嗚……",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？這附近傳出很多目擊魔物的情報？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以城鎮派了討伐隊過來？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你也有參加那個討伐隊是嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是被發現了，\n說不定會被誤認為魔物而被攻擊……",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以你才來幫我？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔、",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n躲在那裡的草叢裡就好了吧，我知道了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝、謝謝……",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n得救",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "了，我完全大意了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n要是被討伐隊發現，說不定會什麼都做不到直接被解決。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔、",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我會屏住氣息，一動也不動。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呀……為什麼要撒上樹葉？",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊，是偽裝，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n想讓大家不會發現我在這裡吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，不行！",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n葉子搔到鼻子，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好像快打噴嚏了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我、我會忍耐的！",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n嗯～……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯嗯，腦袋好像要變奇怪了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n人家不擅長靜靜待著不說話～人家是女孩子嘛！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呀……\n討厭",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，好帥……♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，\n為什麼你會願意保護我呢？",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_029"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然我很開心……\n不過一般來說，大家面對我的時候都會感到害怕，離遠遠的。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_030"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你真是個奇怪的男孩子呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_031"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但是，謝謝你……♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "…………",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……已、已經沒事了嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n討伐隊走遠了嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太好了～暫時放心了。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_034"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n謝謝你掩護我。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家很開心，你就像童話故事裡的王子一樣……♪",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_035"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，討伐隊似乎還在這裡逗留……",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_036"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我就暫時躲回安全的牧場吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家可不想被誤認為是魔物而被制伏。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊討厭，人家受夠了。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n如果我是普通的人類，就不用這麼小心翼翼的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n為什麼我的外表長這樣呢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒有啦～",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_038"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "有時會忍不住發牢騷。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n得好好接受現況，並正向思考才行。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我總是這麼做的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "既然得減少外出工作，\n就暫時見不到你了，有點寂寞呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_039"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟性命是就只有一條呢。\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在風頭過去之前，我會乖乖躲好的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n要是我感到寂寞，",
        "unit_id": 105211,
        "voice": "vo_adv_1052003_041"
    },
    {
