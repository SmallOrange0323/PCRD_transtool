[
    {
        "type": "background",
        "background": "500123"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃～",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n吶、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n對不起，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還醒著嗎……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚耶……",
        "unit_id": 102111,
        "voice": "vo_adv_2003004_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎麼了嗎，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯……",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n妳有沒有，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "聽到什麼奇怪的聲音……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "聲音……？",
        "unit_id": 102111,
        "voice": "vo_adv_2003004_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還是，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n可能是咲戀媽媽她們還醒著吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "現在，幾點……？",
        "unit_id": 102111,
        "voice": "vo_adv_2003004_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唔唔，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "今天晚睡了，好睏唷‥‥？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n對不起，把妳吵醒了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒關係……",
        "unit_id": 102111,
        "voice": "vo_adv_2003004_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有時候我做惡夢之類的時候，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n綾音妳也會擔心我，陪我一起睡……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以這次換我來幫妳，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "應該說，我想報恩……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音，不如一起睡覺吧……？",
        "unit_id": 102111,
        "voice": "vo_adv_2003004_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "和我一起的話會安心吧，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一定會睡得很甜的……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯～一個人睡不著真像個小寶寶呢。",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我，比起胡桃應該是姐姐吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過，算了。",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這次就看在胡桃的份上，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n陪妳一起睡吧……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "…………",
        "unit_id": 102111,
        "voice": "vo_adv_2003004_010"
    },
    {
        "type": "still",
        "still": "200300401"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘎，嘎啊啊啊啊啊！？",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_011"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500122"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請醒來，主人。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早安。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "夜深時分，在下自知失禮。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉打擾主人休息了。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以稍微聽聽在下說話嗎？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，那個。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，並不是因為覺得一個人睡果然還是很寂寞才過來的……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在鈴莓小姐殷切地告誡之下，",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然不大情願，但在下還是接受了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至少，她還是讓在下睡在離主人寢室最近的房間，",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也做好了準備，如果有異狀可以馬上過來支援。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此夜裡如果有任何動靜⋯⋯",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請任意大聲呼喚讓在下知道。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下在幾秒內就能趕來。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳咳。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "言歸正傳，您剛剛有聽到慘叫聲嗎？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像是女孩子的聲音，聽起來很尖銳……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望只是在下幻聽了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。白天時，已經多次處於生死關頭呢……",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最好還是保持警戒。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n最壞的情況，有可能再遇到襲擊。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遇到緊急狀況時，就可以馬上行動。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，一直在守夜。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然有點半夢半醒的。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後就聽到了慘叫聲。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為保險起見，在下就前來查看主人有沒有事。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看到主人四平八穩地睡著，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就放心了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人沒事，真是太好了……",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓主人一個人睡，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n使在下擔心得不得了啊。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，主人。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下最重要、最重要的主人……♪",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘎啊啊啊！？",
        "voice": "vo_adv_2003004_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，又聽到慘叫了！",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這果然不是在下的錯覺吧？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n慘叫聲好像是從育幼院的……大廳傳來的。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下先去看看情況。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人請先在這裡等候。",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對……這裡也不一定安全，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請與在下一起去。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是襲擊的話……",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也一定會想辦法讓主人逃走的。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "穿著睡衣好像不太好，",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請披上披風。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再來只要拿劍就可以了吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "走吧，",
        "unit_id": 105912,
        "voice": "vo_adv_2003004_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請務必多加留意。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也請不要太遠離在下。",
        "unit_id": 105912
    },
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗚啊啊啊！",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n討厭啦啊啊！",
        "unit_id": 102311
    },
    {
        "type": "still",
        "still": "200300402"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好恐怖好恐怖，好恐怖！",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我，我在那裡！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我，站在窗外面呀！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒有說謊哦，要相信我！",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我都不會說謊的喔，我是好孩子！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "果然，是這樣呀！",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_037"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n和爸爸媽媽一樣，我不是『真』的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "站在窗外面的人，才是『真正的我』呀！",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以，所以……嗚啊啊啊！",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，冷靜一點，小綾音！",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒關係的，不要哭了～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打擾了。",
        "unit_id": 105911,
        "voice": "vo_adv_2003004_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不好意思，請問為何騷動呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，可可蘿，還有{player}也……",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不好意思，吵醒你們了呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯。我也是聽到尖叫才剛驚醒，",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還不太清楚狀況……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像是小綾音做惡夢了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那、",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_043"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那不是夢！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我真的看到了，我就在那裡！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡、胡桃妳願意相信我吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_2003004_044"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不知道呀……",
        "unit_id": 102111
    },
    {
        "type": "still",
        "still": "200300403"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音，明明和我一起睡覺的……",
        "unit_id": 102111,
        "voice": "vo_adv_2003004_045"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但窗外面，竟然有另一個綾音……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯，怎麼一回事？",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小胡桃也看到了那個什麼……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n『另一個小綾音』了嗎？\"",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "兩個人都不像是會說謊的孩子……",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嗯，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會不會只是窗戶玻璃倒映出小綾音的臉呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你們看到倒影，",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n覺得不應該出現在窗外的小綾音竟然在那裡……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因此才受到驚嚇之類的吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是哦，雖然站在窗外面的人是我但不是真的我呀！",
        "unit_id": 102311,
        "voice": "vo_adv_2003004_049"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那雙眼睛發亮，和我的眼睛的顏色都不一樣！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還一邊看著我一邊笑著說了些什麼呢！",
        "unit_id": 102311
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯、嗯。",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然不太明白，該怎麼辦……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我到外頭去看看情況吧。",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_051"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n若是可疑人物或是魔物的話就不好了，以防萬一。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_2003004_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果是魔物的話，一個人去會很危險吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且鈴莓小姐看起來似乎也不擅長戰鬥。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不……",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_053"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒關係的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我只是去看看情況而已。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可可蘿你們，",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就待在小綾音她們身邊吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "若是覺得不對勁的話，我會大聲呼叫的，",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n到時候請帶著大家去避難。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會試著爭取讓大家逃走的時間。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐去參加會議，所以不在……",
        "unit_id": 102511,
        "voice": "vo_adv_2003004_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因此，守護【咲戀育幼院】的大家就是我現在的責任。",
        "unit_id": 102511
    }
]