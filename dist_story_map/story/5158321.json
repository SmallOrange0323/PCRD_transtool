        "voice": "vo_adv_5158321_002"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "魔物有異狀！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n它對小伊緒有所反應……？",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……！",
