        "voice": "vo_adv_5158321_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "伊緒，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就是那樣。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n請妳像剛才那樣，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "魅惑魔物吧！",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "只要持續魅惑後方的魔物，",
        "unit_id": 132811,
        "voice": "vo_adv_5158321_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
