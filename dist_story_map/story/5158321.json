        "voice": "vo_adv_5158321_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且",
        "unit_id": 132911
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那隻魔物，",
        "unit_id": 132911
    },
    {
        "type": "dialogue",
