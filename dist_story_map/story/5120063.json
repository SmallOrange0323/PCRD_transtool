[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "日和小姐美麗的地方，",
        "unit_id": 126311,
        "voice": "vo_adv_5120063_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是為了助人而四處奔走時的笑容，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n與她充滿活力的聲音吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的聲援會帶給許多人活力，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n並且為她的周圍",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "添上美麗的色彩。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過有一點很遺憾，",
        "unit_id": 126311,
        "voice": "vo_adv_5120063_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是我以前",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "曾經找日和小姐商量",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n「我太美了，好困擾」這件事，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "結果她卻用困惑的眼神看著我。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……我認為",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她應該要去提升對美的理解。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果要形容優衣小姐的美貌，",
        "unit_id": 126311,
        "voice": "vo_adv_5120063_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "簡直就如同",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一朵「惹人憐愛的花」呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她那柔和的氛圍很美呢，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會令人不禁想一直看著她。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果要變得更美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120063_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這個嘛……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n即使沒有我的建議，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她也很努力",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在磨練自己喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她心中所懷抱的情感，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該會讓她變得更加美麗吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怜小姐給人的印象",
        "unit_id": 126311,
        "voice": "vo_adv_5120063_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "正像是把美的刀刃呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "經過精心琢磨的冰山美人，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "即使稱她是我的競爭對手",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n也不為過，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她就是擁有這樣的美貌喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的美沒有什麼不足的地方，",
        "unit_id": 126311,
        "voice": "vo_adv_5120063_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想不到需要給她的建議呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真想要",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "找她來",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "針對美進行深度討論呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "下次",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "招待她來我們的公會小屋好了。",
        "unit_id": 126311
    }
]