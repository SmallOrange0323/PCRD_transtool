    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}為了送郵件而造訪咲戀育幼院時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看見了與平時有所不同的場面。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不可以挖那邊的土地喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要維護庭院",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也是很辛苦的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "咦～！",
        "unit_id": 111,
        "voice": "vo_adv_1028010_001"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "但這裡",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "可以抓到很多蚯蚓，很好玩欸！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不可以去嚇到蚯蚓啊。",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就不要再去管蚯蚓了吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "可是～！",
        "unit_id": 111,
        "voice": "vo_adv_1028010_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒什麼可是不可是的。",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "改去玩其他遊戲吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "好～～",
        "unit_id": 111,
        "voice": "vo_adv_1028010_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的。",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那個年紀的小孩，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "老是會對莫名其妙的東西有興趣……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你總是幫忙送郵件。",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不曉得今天寄來了什麼？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我看看～？",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是買東西的明細，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而這是……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喔喔，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是那群孩子要接種疫苗的通知啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來已經到了這時期嗎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我必須要處理的手續",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "多得跟山一樣呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看起來似乎是沒有需要緊急處理的文件呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟我現在手邊忙不過來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的是太好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓、胡桃",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和綾音她們現在都出去了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我得一個人",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "照顧那群孩子。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家都太有精神了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "搞得我手忙腳亂的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "喂～！",
        "unit_id": 111,
        "voice": "vo_adv_1028010_011"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "我在石頭下面",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "找到了好多",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "奇怪的蟲喔～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我說啊！",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有些蟲可能有毒，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不可以用手碰喔～！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "知道了～！",
        "unit_id": 111,
        "voice": "vo_adv_1028010_013"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "我會小心～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉……",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我現在真的很想找人幫忙。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我問你。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你可以幫我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "去跟孩子們",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一起玩嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然想這麼說，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但你還在工作中呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "害你翹班這樣……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡是最後一處送件地點是嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我就不用顧慮了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拜託你囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "大哥哥！",
        "unit_id": 111,
        "voice": "vo_adv_1028010_016"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "一起玩球吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "大哥哥已經",
        "unit_id": 211,
        "voice": "vo_adv_1028010_017"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "跟我約好要玩扮家家酒了啦～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "玩什麼扮家家酒，",
        "unit_id": 111,
        "voice": "vo_adv_1028010_018"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "還是玩球比較開心吧？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "對吧，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "大哥哥！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "呿～！",
        "unit_id": 111,
        "voice": "vo_adv_1028010_019"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "那玩完扮家家酒以後，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "下一個要跟我玩喔！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "我們約好了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他真受歡迎呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "大哥哥",
        "unit_id": 211,
        "voice": "vo_adv_1028010_021"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "你負責當狗！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該是",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "受歡迎的對吧……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "這是最後一球了！",
        "unit_id": 111,
        "voice": "vo_adv_1028010_023"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n吃我的",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "超級無敵高速球吧～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "啊～～！",
        "unit_id": 111,
        "voice": "vo_adv_1028010_024"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "真的被擋下了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "太不手下留情了吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "很好，",
        "unit_id": 111,
        "voice": "vo_adv_1028010_025"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "那接下來去抓蟲子吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n那邊有很多奇怪的蟲喔！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n我帶大哥哥你去看！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "走吧！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要阻止他啊！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你剛才也有聽到",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我在阻止他吧！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒什麼可是不可是！",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這對話",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "根本和剛才一樣啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我還以為你要幫忙照顧他們，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你這樣不就真的只是在跟他們一起玩而已嗎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺本來想找人幫忙，",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "結果反而多了一個",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "需要照顧的小孩。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然孩子們看起來很開心，是無所謂啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你真的跟小時候幫助了我的男孩子是同一個人嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028010_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我都開始失去信心了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "哈哈，",
        "unit_id": 416,
        "voice": "vo_adv_1028010_030"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "這是什麼啊！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n這種小紙片，怎麼可能是公主啊！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "欸、",
        "unit_id": 211,
        "voice": "vo_adv_1028010_031"
    },
