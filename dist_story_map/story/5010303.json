        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "\nこの先はすっごく危険かもしれないの……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "それでも",
        "unit_id": 108211,
        "voice": "vo_adv_5007303_002"
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "ミヤコはシノブを助けたいの！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "\n早く行かなくちゃなの～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "わあっ！　",
        "unit_id": 108211,
        "voice": "vo_adv_5007303_003"
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "急になにか光りだしたの！？",
