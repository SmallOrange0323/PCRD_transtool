[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}收到帆稀請他過來一趟的信件，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n動身前往她身為老大的幫派據點。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你今天過來一趟～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我還有事想拜託你……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "希望你能來幫我進行龍人族的研究～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n可以嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你說龍人族嗎～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……咦～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "難道",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你不知道龍人族～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "仔細想想，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我好像不曾跟你說過關於龍人族的事。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這正是個好機會，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就簡單說明一下。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我本身就是龍人族，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "至於龍人族呢，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n現在是人數相當稀少的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "罕見種族～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而有個公會，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就是以找到龍人族的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "同胞或跡象",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為活動目的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那就是",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "由我擔任公會長的公會，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n【龍族巢穴】喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……好奇怪啊？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也沒跟你提過這件事嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊啊，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣啊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "說起來你還沒見過她們兩人，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我之前也把這裡說成是幫派的據點呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實這裡原本就是",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "公會所用的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "公會小屋，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n只是我也把這裡",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當作幫派據點來使用～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "事實上是不可以這樣做的，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還請你幫忙保密喔♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因此，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在沒有畫圖工作和幫派工作的時候，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我就會到各地方去",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "找尋同胞們。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天請你過來，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是想請你陪我一起去找～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你覺得怎麼樣？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "願意跟我一起去嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n準備工作都已經做好了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們馬上出發吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n如果今天可以找到就好了～♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "馬車只能",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "到這裡，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你先乖乖地待著～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我要佈下讓魔物進不來的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "結界……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣就行了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "經調查可知，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這座火山以前似乎曾有人居住過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n說不定就是龍人族呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "洞穴的入口……",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在那裡呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n因為這種地方",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很常成為魔物的巢穴，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不要突然就衝進去，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "得小心翼翼地接近。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "從入口處看，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也完全看不到洞穴的深處……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過似乎沒有魔物的樣子，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之我們先進去瞧瞧吧♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不要使用火把，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可能會引起火災喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這時候，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要利用魔力來配置光源",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就沒問題了……♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣就可以了☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我走在前頭，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你與拉格一起跟著我走。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "洞窟探險這就出發囉～♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……嗯～",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看來這裡似乎也落空了……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖說也只能有耐心地找下去，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還是很令人喪氣～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "難道說龍人族",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真的已不存在這世上了……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開～玩笑的☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然有我這名龍人族在，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該不可能沒有其他族人嘛～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們都難得到這裡來了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不如試著走到不能再走為止吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n拉格，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果發生什麼事，就拜託你囉？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎喔！",
        "unit_id": 1,
        "voice": "vo_adv_1067003_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "他說，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "包在我身上吧♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "拉格或許是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "把你當作弟弟呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎喔～♪",
        "unit_id": 1,
        "voice": "vo_adv_1067003_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……沒路可走了。",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們已經走到相當深的地方，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這裡是用來做什麼的地方啊？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我完全一頭霧水……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "無論是對這裡，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還是對這個世界。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了！",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你對這個世界的了解",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有多少呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你知道這個世界",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "曾經有過一群名為七冠，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "宛如神一般的存在，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n而他們的身邊，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有著被稱為公主騎士，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n具有特殊力量的騎士",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "隨侍在側的事嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "被視為古老傳說代代流傳的，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "歷史性存在，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "七冠……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "假如他們",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "現在仍活在這世上的話，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你有何想法？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不知為何，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "他們好像喪失了身為七冠的記憶……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有人連名字都不被記得，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只有其存在，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n被確實地流傳下來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但也有還好好地活著的人呢……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "該不會是",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "神不高興他們太過接近自己，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就不著痕跡地把他們全都消滅了吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "才只會留下曾經存在過的事實……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你不覺得這很有可能嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……就像你的記憶一樣♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是有趣的反應～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想不到你會這麼驚訝呢～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我只是在第一次見面時，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_035"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "稍～微看了一下……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "用我這雙眼睛♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的眼睛",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "跟一般人比起來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好像能不小心看到更多東西，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你現在處於什麼樣的狀態，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我其實比你看得更清楚喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我知道你喪失了記憶，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也知道你就是公主騎士……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，請放心。",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我既不會加害於你，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也不打算利用你的力量☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我啊，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_039"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只是覺得",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你會不會是，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n被捲入這世界奇怪現象的人。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這世界",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有許多奇怪的現象。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就像人數少到一隻手就數得完的我們龍人族，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n並沒有父母親喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們到底是怎麼誕生的啊～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_041"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "身為公主騎士的你以喪失記憶的狀態，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n突然出現在這個世界……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊啊，這是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我蒐集種種情報後所做的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "推測啦？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_042"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個世界有許多奇怪的現象發生。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "除了我自己的種族外，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這種現象到處可見，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n很令人感興趣呢～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然毫無所獲，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不如我們回去吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n……老實說，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "若能在這裡好好調查一下活著的你的腦袋，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n似乎也會很有趣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，這次就先饒了你吧～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……？",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊哈哈☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你當真啦？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "剛剛的是玩笑話啦～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我現在認為",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "目前這個世界",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有得玩呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以才會像這樣到處去做調查……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "究竟是誰，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_046"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "又是如何改寫世界的呢♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了！",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_047"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果可以，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今後你想不想像今天一樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n陪我到處去走走看看呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣一來，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_048"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "說不定哪一天也會知道",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你的記憶到底怎麼了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n如何呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是的～",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_049"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這麼愛擔心～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別看我這樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也是很厲害的喔～☆",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好～了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_050"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們到了～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n謝謝你陪我去洞穴探險，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "辛苦了～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我說，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_051"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你待會有空嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你可以來",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "幫忙我提東西嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這算是工作委託，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再加上剛剛的探險，我會給你加倍的酬勞的♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為洞穴調查落空了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_052"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為了轉換心情，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想要去逛街買東西～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你沒有拒絕，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_053"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那就表示願意陪我囉☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，我們今天",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就去大買特買吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不好意思～！",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_054"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請幫我把這件衣服包起來～！",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500610"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067003_055"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "實驗的材料剛好也用完了……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "從這裡到這裡，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我全部都要買下～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
