        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "著急了著急了♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這裡就再加把勁……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "欸。",
        "unit_id": 1,
        "voice": "vo_adv_1248004_049"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n剛才",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "有沒有聽到望望的聲音啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n而且還是特別清楚的音質。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "有聽到有聽到！",
        "unit_id": 1,
        "voice": "vo_adv_1248004_050"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "\n果然有聽到對吧！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "\n清楚到不像是影片，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "簡直就是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "本人在說話！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊。",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_051"
    },
    {
        "type": "background",
        "background": "510302"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "快來這邊！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n趕快躲起來吧！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n現在粉絲們",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還沒有注意到我在這！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這麼做對支持我的粉絲們很抱歉……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但畢竟我們能在一起的時間也有限嘛。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之後就用表演",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來補償他們吧！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好了，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你也動作快一點！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要盡全力",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓你玩得盡興，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓你覺得慶幸，能跟我共度時光～！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大受歡迎的偶像望望──",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n現在",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這瞬間能發揮出的全力！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你就好好接下來吧♪",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1248004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n順帶一提……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在那之後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你們好像立刻",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就被望的粉絲發現了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1248004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那也是當然的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那可是大受歡迎的偶像的全力耶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一定會很引人注目的啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n光是沒有演變成大緋聞，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就已經算走運了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來……",
        "unit_id": 190011,
        "voice": "vo_adv_1248004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n望有確實體會到呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "體會到時間是有限的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這件事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……沒錯。",
        "unit_id": 190011,
        "voice": "vo_adv_1248004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "時間是有限的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正因為有限，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "邂逅與羈絆才顯得耀眼。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且那道耀眼的光，",
        "unit_id": 190011,
        "voice": "vo_adv_1248004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該要照亮前方。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一路走來的道路，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論有多麼美麗……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n光芒都不該照向過去。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從今以後，",
        "unit_id": 190011,
        "voice": "vo_adv_1248004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也別忘了對於未來的「希望」喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……要加油喔。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_062"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇哇？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在這種地方睡著了嗎！？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你也是？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒想到我們兩個居然會一起睡著……",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_063"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算事件完全解決了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也太過鬆懈了呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看來我得要打起精神了……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "其實我本來想說今天就悠閒地玩，",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_064"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n別讓明天感到疲累……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我要改變計畫了！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n要盡全力玩一整天囉！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "放心吧！",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想過可能也會有這種事，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以有先想好計畫！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "邊移動邊跟你說要去哪裡吧♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來，",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_066"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "走吧！{player}！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n時間可是不等人的喔～",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望握住{player}的手跑了起來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人在城鎮中前進的步伐，比以往都還來得輕盈。"
