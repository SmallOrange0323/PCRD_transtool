    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唉",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你明明這麼顧慮著我，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我卻一下遲到，",
