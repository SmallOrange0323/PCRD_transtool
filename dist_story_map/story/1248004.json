    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在演唱會的時候之類的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "演唱會的時間受到了限制，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n能來會場的粉絲人數也會受到限制。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一旦在這種狀況下表演，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就會自然地……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "湧起",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一股感激的心情。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n在不知不覺中。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就會想要更加努力。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想著下次想要做出更好的表演。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "下次也想",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "傳達給不在現場的人們",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不管變得再怎麼忙，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我都很樂在其中。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……說說而已。",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n好像有點",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "講得太激動了？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……謝謝。",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你沒有嘲笑我呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n心裡覺得有點癢癢的……",
