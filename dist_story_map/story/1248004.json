[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望照著矛依未的提案，將解放樂園的居民的力量給交了出去。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n──其結果就是，樂園的氣息從蘭德索爾完全消滅了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後過了幾天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n望趁著工作的空檔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n跟{player}共度著短暫的休假時光。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉喔，",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "把你叫了出來！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "其實啊，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我接下來好像又要變忙了～",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「女神祭典」也已經完全結束了。",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n也不能一直都像在過節一樣嘛。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以就想說，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也只剩現在",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能和你出來玩了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且你想嘛，",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "樂園的事件也全部解決了不是嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這也得慶祝一下才行嘛♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……失去解放的力量，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "令人有點落寞就是了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那套衣服的設計，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我還挺喜歡的說～",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n怎麼好像突然變得好刺眼……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難道是偷拍？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n受不了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到底是哪家出版社──",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，",
        "unit_id": 102913,
        "voice": "vo_adv_1248004_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是你在發光嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀啊啊啊～～～！",
        "unit_id": 102913
    },
    {
        "type": "background",
        "background": "510352"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼、",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n趕上了～！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了～",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "準時在約好的時間到了！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "本來以為會趕不上，害我好著急呢～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不可以說",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那種話！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我是很高興你體諒我，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但太寵我是不行的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n把人叫出來自己卻遲到，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這一般來說是很失禮的嘛！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "由我這個遲到大王來說，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可能沒什麼說服力就是了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但這就",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "先放一邊。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行的事情就是不行，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n的確，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是說不忙",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是騙人的了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天也是早上去學校，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "下午開始拍攝雜誌跟接受訪談……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "稍微開了一下會呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在來跟你碰面。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒事啦，你不用擺出那麼擔心的表情。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n該休息的時候，我都有好好休息的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且我也會像這樣跟你見面，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來轉換心情啊♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且啊。",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n時間有限",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這一點，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也不全然是壞事喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你想嘛，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在考試的時候，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是就能超級專心嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那一定就是因為",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有限制時間的關係喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶像的工作也是一樣。",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不管是拍攝還是演唱會，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能做的時間都有限。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正因為這樣才會覺得要全力以赴，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "卯足幹勁喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "順帶一提……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我現在也充滿幹勁喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "已經這麼晚了嘛！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是我太晚回家會被罵的！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以說，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們趕快走吧！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想喝",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "某一款飲料♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是期間限定的！",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "510302"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "十幾分鐘後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n望和{player}兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n順利外帶了要買的飲料。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯嗯！",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n真好喝～♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我有點意外耶……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n本來看照片還在想這會不會太甜，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "結果完全不會！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才再點大杯一點說不定也喝得下……！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這必須再找時間來喝……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是期間限定的呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n明明這麼好喝卻不是一般品項……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚～！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊、",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對耶。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所謂的期間限定，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也就代表它的時間",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "受到了限制對吧。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才會覺得特別好喝嗎……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "仔細想想",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "每件事都是這樣呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不管對誰來說，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "時間都很重要嘛。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就因為很重要，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能一起度過一段時光才會令人感到高興對吧。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不對，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不只會覺得高興……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n也會有股感激的心情。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感激對方",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跟自己度過同一段",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "時光。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對不起，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "突然說了奇怪的話。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我好像不小心打開了開關，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是因為晚上的關係嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要說是",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "深夜的情緒，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "時間又還很早的說。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然都講一點了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n希望你能再多聽",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我說一下。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "回到剛才的話題……",
        "unit_id": 102931,
        "voice": "vo_adv_1248004_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我心中",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "常覺得充滿感激的心情。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n特別是",
