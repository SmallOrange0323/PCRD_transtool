        "voice": "vo_adv_9045155_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐方才跌倒的衝擊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n引發了地震……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留居然隱藏著這種力量！？",
        "unit_id": 105811,
        "voice": "vo_adv_9045155_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最好是啦！",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種搖晃的感覺，可能是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……！",
        "unit_id": 105911,
        "voice": "vo_adv_9045155_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是寶石魔物……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "學不乖",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又鑽回地面上了呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是多死心眼啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇，",
        "unit_id": 105811,
        "voice": "vo_adv_9045155_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為小凱留說牠壞話，魔物好像生氣了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快閃開！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……！",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明是個大塊頭，攻擊速度卻這麼快！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "小凱留……！\n凱留小姐……！",
        "unit_id": 1,
        "voice": "vo_adv_9045155_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你休想！",
        "unit_id": 1,
        "voice": "vo_adv_9045155_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼，",
        "unit_id": 1,
        "voice": "vo_adv_9045155_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "千鈞一髮呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過",
        "unit_id": 106411,
        "voice": "vo_adv_9045155_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "太好了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n似乎有趕上。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "小雪菲！\n雪菲小姐！",
        "unit_id": 1,
        "voice": "vo_adv_9045155_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來得正是時候！",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n幫大忙了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "突然用通訊魔法聯繫我，嚇了一跳……",
        "unit_id": 106411,
        "voice": "vo_adv_9045155_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看來盡快趕來是對的，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留也因此得救的樣子。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來",
        "unit_id": 105911,
        "voice": "vo_adv_9045155_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是凱留小姐所說的秘計……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有雪菲小姐在的話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可說是以一擋百。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯！",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這就是我的秘計！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管是多強的魔物，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只要我們【美食殿堂】齊聚一堂，就絕對不會輸！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是這樣。",
        "unit_id": 106411,
        "voice": "vo_adv_9045155_030"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你認命吧！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也會全力以赴！",
        "unit_id": 106411
    }
