        "voice": "vo_adv_9045155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n差不多可以",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "告訴我妳的秘計是什麼了吧～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵，",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是祕密的計策才叫做秘計。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n馬上就會知道了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好好拭目以待吧♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不是不能給妳一點提示啦──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個寶石的碎片是……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在洞穴的深處也是",
        "unit_id": 105911,
        "voice": "vo_adv_9045155_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各處散落著這樣的東西呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是從那個寶石魔物身上",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "掉落的嗎。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要循著地上的寶石，",
        "unit_id": 105811,
        "voice": "vo_adv_9045155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能知道它逃去哪裡了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們去看看吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……",
        "unit_id": 105811,
        "voice": "vo_adv_9045155_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好奇怪喔～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "寶石碎片的軌跡到這裡就消失了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n照理說牠應該躲在附近才對……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們都找這麼久了，",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻連影子都沒見著……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡是不是特別暖和啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為，",
        "unit_id": 105911,
        "voice": "vo_adv_9045155_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是受到了地熱的影響。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟我們往地底深處前進了不少。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來如此……",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "待起來挺舒服的，也好。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我說可蘿仔，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要不要休息一下？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有點累了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說得也是呢。",
        "unit_id": 105911,
        "voice": "vo_adv_9045155_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n稍作休息後",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再進行搜索吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們就坐在那塊岩石上吃點東西──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚呀……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！？",
        "unit_id": 105811,
        "voice": "vo_adv_9045155_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳還好嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "痛痛痛……",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這岩石",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也太光滑了吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "害我摔了個四腳朝天，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這、",
        "unit_id": 106011,
        "voice": "vo_adv_9045155_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個聲音跟晃動是怎麼回事……？",
