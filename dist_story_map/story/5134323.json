[
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……盯──",
        "unit_id": 128411,
        "voice": "vo_adv_5134323_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為、",
        "unit_id": 128311,
        "voice": "vo_adv_5134323_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼要盯著我看啊？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才想說妳到剛剛還一副看起來很想睡的樣子，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n結果突然就變得一臉嚴肅的。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，",
        "unit_id": 128411,
        "voice": "vo_adv_5134323_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒問題！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這個祈梨應該是正牌的沒錯！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看起來不會突然說一些詩情畫意的話！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個，",
        "unit_id": 128511,
        "voice": "vo_adv_5134323_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然我聽不懂這是在說什麼，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不過初音覺得沒問題就好。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還有，",
        "unit_id": 128311,
        "voice": "vo_adv_5134323_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "接下來可是禁止打瞌睡的喔。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "太陽已經完全下山了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n隕石會在什麼時候飛過來都不奇怪呢。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒問題！",
        "unit_id": 128411,
        "voice": "vo_adv_5134323_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n都好好地睡了這麼久，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n感覺能夠撐到新年的第一天日出呢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是這股氣勢。",
        "unit_id": 128511,
        "voice": "vo_adv_5134323_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也準備好了吧？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們要一次定勝負……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "確實地把它解決掉吧！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這就是",
        "unit_id": 128411,
        "voice": "vo_adv_5134323_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真正的最後一次……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕──────！！",
        "unit_id": 128411
    }
]