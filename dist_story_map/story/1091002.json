[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靜流為了讓{player}\n吃到絕品美味的巧克力而幹勁十足\n去參加了市區中舉辦的料理教室。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然是看宣傳手冊而來的，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不過點心教室的地點",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是這裡沒錯吧？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "說是很有名的老師來教，相當大受好評，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會教我們做出怎樣的巧克力真讓人期待呢♪",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚哇，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "除了我還有其他學生也來了呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為情人節快到了呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n大家為了做出美味的巧克力都很努力。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好～",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也要為了{player}弟弟，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n努力做出美味的甜點！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？　",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "隔壁廚房的周圍也有學生耶。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這邊也有舉辦一般的料理教室呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯？　",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "學生裡面只有一位男性……？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那該不會是{player}弟弟吧？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊～",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果真是{player}弟弟啊♪",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太巧了呢！",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你在這裡做什麼呢？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯……",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "平常受到可可蘿她們照顧，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為了道謝想煮飯給她們吃？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真了不起呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有個溫柔的弟弟，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐很開心喔♪",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那位是老師嗎？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱歉，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好像要開始上課了。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "回去自己的班上囉。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "各位，",
        "unit_id": 611,
        "voice": "vo_adv_1091002_010"
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "您們好。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "今天由我",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "來擔任各位的料理講師。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "\n能讓你們學會製作美味的巧克力，是我的光榮。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "請多多指教！",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_011"
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "那麼，",
        "unit_id": 611,
        "voice": "vo_adv_1091002_012"
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "首先我來發放製作的流程說明。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天的課要教的是聖誕樹幹蛋糕啊。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "雖然巧克力基本上都是做成一顆一顆的，",
        "unit_id": 611,
        "voice": "vo_adv_1091002_014"
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "不過今天要來教各位的是適合送禮的\n聖誕樹幹蛋糕課程。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "說到聖誕樹幹蛋糕，",
        "unit_id": 611,
        "voice": "vo_adv_1091002_015"
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "\n一般來說常會聯想到它的材料是瑞士卷，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老師1",
        "words": "不過這次我們只使用甘納許和慕斯來製作出層次吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯～",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺是蠻困難的食譜呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過這都是為了{player}弟弟嘛。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐會加油的！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哼，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "總之材料準備到這個地步，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n只要再稍微等一下就可以了吧？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺不錯！　",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "順利順利♪",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "話說回來，我本來以為調溫",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n只是用隔水加熱再攪拌而已，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過意外的很有難度呢……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我稍微\n去看看{player}弟弟的情況吧。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我看一下～",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個食譜是……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼！？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}弟弟，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n他上的課程，難度會不會未免太高了！？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「酪梨鮮蝦拼盤」",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n「蘆筍佐荷蘭醬」",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「鯛魚印度烤餅」",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n「燻鮭魚熱壓吐司磚」",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「蒸長臂大蝦燉飯」",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「甲殼類奶油醬」",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「鵝肝醬」",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n「無花果焦糖塔」",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……呃，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不管哪一道\n都不像是新手能做出來的。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他為了讓可可蘿她們開心，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n似乎報名了最困難的料理教室呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "做得出來嗎？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊～",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟果然一臉茫然的樣子……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好像很不知所措……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯！　",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這算是{player}弟弟的一件大事，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n讓姐姐來幫他一把！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不能傷到{player}的心才行呢！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然有點辛苦，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了不被{player}弟弟發現，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我就偷偷地支援他吧。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "老師2",
        "words": "那麼，",
        "unit_id": 1511,
        "voice": "vo_adv_1091002_030"
    },
    {
        "type": "dialogue",
        "name": "老師2",
        "words": "接下來要製作荷蘭醬。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "老師2",
        "words": "\n在融化的奶油中",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "老師2",
        "words": "加入酒、",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "老師2",
        "words": "檸檬汁、",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "老師2",
        "words": "和砂糖……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "搞錯醬料的作法了！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要快點做出正確的……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "拿去掉包……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊啊，",
        "unit_id": 109111,
        "voice": "vo_adv_1091002_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不能讓它沸騰到那個程度啊！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
