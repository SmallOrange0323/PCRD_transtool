    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒眼光的人",
        "unit_id": 121611,
        "voice": "vo_adv_6090204_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "似乎會認為步未未",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只是個不起眼的人……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是絕對，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才沒那回事！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥也是",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這麼覺得的吧！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對！",
        "unit_id": 121611,
        "voice": "vo_adv_6090204_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥也很懂步未未呢！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n步未未才不是隨處可見的普通女孩子！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n是個超級不妙的人啊！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不愧是小哥，",
        "unit_id": 121611,
        "voice": "vo_adv_6090204_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你真有眼光！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n步未未是個體貼",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又很亮眼的老百姓！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真希望老大也能效法步未未個性溫柔的部分！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯！",
        "unit_id": 121611,
        "voice": "vo_adv_6090204_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有那麼厲害的能力，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我覺得她可以對自己更有信心一點……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "步未未謙虛的個性",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也是她的優點啊。",
        "unit_id": 121611
    }
]