        "voice": "vo_adv_5111308_000"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "樂園……",
        "unit_id": 17212
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "將幸福……",
        "unit_id": 17212
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這傢伙……！",
        "unit_id": 124911,
        "voice": "vo_adv_5111308_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "到了這個節骨眼，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還能提升力量嗎……！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣子，",
        "unit_id": 124811,
        "voice": "vo_adv_5111308_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像有點太吃力了……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒問題！",
        "unit_id": 125011,
        "voice": "vo_adv_5111308_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們能贏！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 124911,
        "voice": "vo_adv_5111308_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳有什麼根據？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在支持著他的，",
        "unit_id": 125011,
        "voice": "vo_adv_5111308_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只有他自己的理想。",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但是，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們有夥伴，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以及",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有著無限可能的未來！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們看，",
        "unit_id": 125011,
        "voice": "vo_adv_5111308_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "完全沒有打不贏的理由吧。",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈，",
        "unit_id": 124911,
        "voice": "vo_adv_5111308_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "數量多就比較強的意思嗎？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然簡單，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但挺有道理的。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我身為偶像，卻差點忘記要保持正向思考了。",
        "unit_id": 124811,
        "voice": "vo_adv_5111308_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "矛依未，謝謝妳！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "亞斯來，",
        "unit_id": 125011,
        "voice": "vo_adv_5111308_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "準備好！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "差不多該一決勝負了！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你的理想，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們的未來……",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最後還站在場上的人就是贏家！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "一陣子沒見，",
        "unit_id": 106211,
        "voice": "vo_adv_5111308_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳變得可靠了呢，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這樣成為世界第一的大壞蛋，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好像也不是夢了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那麼我身為妳的搭檔，",
        "unit_id": 106211,
        "voice": "vo_adv_5111308_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可得拿出相符的表現才行！　",
        "unit_id": 106211
    }
