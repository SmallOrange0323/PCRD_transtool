    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "「大夢想樂園」也是",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "客滿狀態♪",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算人家不在，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這座遊樂園",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也沒問題呢……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "開玩笑的，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實人家",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "根本就沒～有做什麼大貢獻♪",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "別這麼說別這麼說！",
        "unit_id": 130911,
        "voice": "vo_adv_5146411_001"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "現在之所以會有這麼多客人來玩，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n真步小小姐和英雄先生的貢獻，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n占了99.99999999999999……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "％呀！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我的貢獻程度，",
        "unit_id": 130911,
        "voice": "vo_adv_5146411_002"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n根本只有0.00000000000000……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "1％左右而已！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是的，",
        "unit_id": 131011,
        "voice": "vo_adv_5146411_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "庫露露小姐謙虛過頭了呀。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳今後",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以再更有自信一點",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也沒關係唷？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "至少人家",
        "unit_id": 131011,
        "voice": "vo_adv_5146411_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很尊敬庫露露小姐♪",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要不是因為如此，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也不會跟妳",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一起工作到現在呀。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這全都是",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "托庫露露小姐的福哪♪",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "真步小小姐……！",
        "unit_id": 130911,
        "voice": "vo_adv_5146411_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……好了，",
        "unit_id": 131011,
        "voice": "vo_adv_5146411_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那人家",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "差不多要",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "回去蘭德索爾了。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下次",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家會以客人的身分",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n來「大夢想樂園」",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "玩的喔♪",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對了，",
        "unit_id": 131011,
        "voice": "vo_adv_5146411_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家能作為職員，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n最後再跟妳一起",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說一次那個嗎？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "嗯，",
        "unit_id": 130911,
        "voice": "vo_adv_5146411_008"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "當然可以！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "來喊和真步小小姐",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "一起說過好幾次的",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "那句話吧！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "要來囉！",
