        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "預備～！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露、真步",
        "words": "歡迎來到",
