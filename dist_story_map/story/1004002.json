[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呀哈哈哈！完成了─！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊想了很久的超厲害陷阱終於完成了─！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊要把它取名為禊究極陷阱特製1號機！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸嘿嘿～既然都完成了，那禊乾脆躲起來",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n看看有沒有誰會踩到陷阱吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好興奮好興奮！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……………………",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "…………",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "…………………",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "…\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "………………………………嗯～。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "都沒有人中招呢～",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個陷阱果然太明顯了嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "路上掉了個香蕉皮實在是太顯眼了嗎",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，是哥哥耶！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "如果是哥哥的話，說不定會中招呢！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥跌倒了！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "因為跌倒而觸發了陷阱，臉盆砸到哥哥頭上了！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "裝在臉盆裡的水，全部都完美地淋在哥哥身上了！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "放在臉盆水中的檸檬、洋蔥跟辣椒刺激到哥哥的眼睛，",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n讓哥哥走起路來搖搖晃晃的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥眼睛張不開、走路又搖搖晃晃的，結果掉到地洞裡啦！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "太棒了！太棒了啦！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊特製的陷阱，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥居然完美地全部都中招了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊真的太感動了！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "如果禊是惡作劇的專家，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n那哥哥就是被惡整的專家了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n抓住這條繩索──！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿咻、嘿咻、嘿咻……",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_015"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呼呼。哥哥沒事吧？",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒有受傷吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "話說回來，哥哥真的是太厲害了！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥中招的方式太棒了～真是超有趣的～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊，最喜歡哥哥了♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……不過呀～哥哥。",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n雖然禊沒資格說這些話，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過哥哥還是",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n多留意一下周遭比較好喔～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊的陷阱只是在惡作劇，所以設計上不會讓人受傷，",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_019"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過如果遇到壞人做的陷阱，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥可是會受重傷死掉的喔！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "當然是在擔心哥哥呀──！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要是哥哥不在了，",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_021"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n那禊可以惡作劇的對象就少一個人了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？要是哥哥開始注意的話，",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n是不是就再也不會掉到禊的陷阱裡了呢……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～……不過",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣也好。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊也",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不希望哥哥死掉嘛！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥以後走路的時候要更小心呦。",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要想到周圍可能有陷阱，仔細地觀察周遭情況喔。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒錯沒錯！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就是要這樣小心翼翼地觀察四周……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯，確實地觀察前後左右……",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "上下左右仔細注意……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "…………",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……………………",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "…………哥哥也看太久了！差不多該前進了吧！",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊……",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥又因為踩到剛剛的香蕉皮滑倒，",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "再一次掉到地洞裡了……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "看來在要求哥哥注意四周之前，",
        "unit_id": 100411,
        "voice": "vo_adv_1004002_031"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊得先教教哥哥",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "「踩到香蕉皮會滑倒！」才行呢……",
        "unit_id": 100411
    }
]