[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從剛才開始，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們就在講什麼悄悄話……？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不知道妳們有什麼企圖，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但沒用唷",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒用！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不管再怎麼祈禱",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再怎麼努力，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個世界還不是一點都沒有改變！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們就放棄，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "屈服，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後回去啦～！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管是誰都救不了我的！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為這根本就沒價值，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒意義，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一點道理都沒有！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且我只要看到妳們",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就會很不爽啊，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們全都死一死從這個世界上消失就好啦！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我知道。",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留是傲嬌嘛，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以每次講的話",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都剛好和心裡想的相反對吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一天又一天，",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家開開心心的聚在飯桌前……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是因為聊過了好多好多的天，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以就算遲鈍",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又是笨蛋的我也知道的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個總是不坦率的小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她真正的願望。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而那願望，",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是知道的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n簡單說，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是想要我們救妳對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "希望我們靠近妳，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱緊妳，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後說",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最喜歡妳了對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的話！　",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是以達成人民所願為己任的公主殿下！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而小凱留可是我最重要的伙伴、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好朋友！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我絕對，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會實現妳的願望給妳看的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓大家的願望都能成真！",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就是，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的願望！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳就是像那樣裝好人！",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明什麼東西都給人搶走了，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你卻總還是笑嘻嘻的，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就是看不慣妳這一點啊……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！",
        "unit_id": 106013
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……！",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈哈！　",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇、",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇哈哈哈！　",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎樣呀？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正中紅心！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳那張總是講著一大堆蠢話的嘴，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n永遠都張不開了吧！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太棒了，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太棒了，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太棒了！　",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我終於殺掉她了！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n啊哈哈哈哈，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "打從第一次見面我就該這麼做了！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣子，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就……！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就……？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊啊……？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把貪吃佩可……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n啊，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "殺掉……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對不起！",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對不起對不起，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我一不注意就殺掉了！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n抱歉呢，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像我這樣的人被生下來真是對不起！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊啊啊……！？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳明明一點錯都沒有的啊，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明妳就只是為了要救我而已……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我到底……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我想要的",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "究竟是什麼呢……？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是乖乖聽『陛下』的話，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n討好他，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要被他給稱讚嗎？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這件事，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有比和妳們聚一起的，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個幸福的餐桌上，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還更有價值嗎……？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真正想要的",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "究竟是什麼啊……？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真遺憾！　",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒事的唷，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛剛，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳打飛的那個",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我的假人唷☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n騙……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "騙人，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼妳這傢伙還活著啊！？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為有人把我生下來了！",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並且用愛把我養大，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還每天",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都吃著美味的飯所以才能像這樣活跳跳的唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "讓我來說明！　",
        "unit_id": 191011,
        "voice": "vo_adv_2012009_025"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "正當璃乃小姐她們進行著擾亂的期間，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n我便悄悄地用貪吃佩可小姐的假人，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "跟她本人交換了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我們悄悄的將過去在研究中所製造出來的人工魔物解放，",
        "unit_id": 191011,
        "voice": "vo_adv_2012009_026"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n並以似似花大人的秘藥",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "使牠變化成與貪吃佩可小姐如出一轍的樣貌！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "順帶一提！　",
        "unit_id": 101112,
        "voice": "vo_adv_2012009_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個作戰",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是姐姐她所立案，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n而我用箭銜信悄悄的傳遞給大家的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "完美的團隊合作，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "超讚的對吧☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我專用的台詞被抄襲了……！？",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總而言之！　",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當小凱留妳被假人給吸引住的同時，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們就像這樣悄悄的接近過來了喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抓～到～妳～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "囉☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喵嘎啊啊！？",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放、",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放開我！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我絕對不會放手的！",
        "unit_id": 105811,
        "voice": "vo_adv_2012009_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳偶爾也要，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "乖乖聽比妳年紀還要大的姐姐說的話～呀！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇啊啊？　",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這傢伙啊，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像妳這種傢伙……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過就是碰巧比較早出生而已，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有什麼好跩的啊！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明就是個笨蛋，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳和我之間到底差在哪裡呀！？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在正是好時機！",
        "unit_id": 105911,
        "voice": "vo_adv_2012009_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得將主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "送到凱留小姐的身邊……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咕",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚嗚！　",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算被架了起來，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我還是用得出魔法！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這次一定要把妳們全部人",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都給搗成肉醬……！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想得美！",
        "unit_id": 104911,
        "voice": "vo_adv_2012009_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不可以胡鬧，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個危險的東西",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐要給妳沒收唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的法杖……！？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是怎樣啦，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可惡可惡可惡！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們這些人，",
        "unit_id": 106013,
        "voice": "vo_adv_2012009_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到底是為什麼要為了我這麼的拚命啊？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們都是笨蛋嗎？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本搞不懂妳們啦！",
        "unit_id": 106013
    }
]