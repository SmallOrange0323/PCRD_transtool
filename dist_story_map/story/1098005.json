    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆什麼時候變成那個男人的朋友了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "大哥哥大哥哥。",
        "unit_id": 111,
        "voice": "vo_adv_1098005_046"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "啊，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_047"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "等一下！",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……看來把小孩子帶來是拉姆的失策。",
