        "voice": "vo_adv_1098005_069"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n這傢伙，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "現在是要跟我們──",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這不是{player}嗎。",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_070"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "遇見你正好。",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_071"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我雖然久違地來到街上買東西，",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_072"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但卻因為人太多而跟真軌走散了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你能幫我找一下真軌，",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_073"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然後把他帶過來嗎。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是在鬧區那裡。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是平時我會不管他直接回去，",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_074"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但是因為今天行李都在真軌那裡。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這個男人的身邊",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_075"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "為何總是會不斷地有人聚集過來。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "為什麼，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_076"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "無論是誰都能解決的問題，卻要刻意拜託這個男人呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是無法理解。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "咦咦咦～",
        "unit_id": 111,
        "voice": "vo_adv_1098005_077"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n先修玩具啦～",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "所以說",
        "unit_id": 6311,
        "voice": "vo_adv_1098005_078"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "要先跟我們一起吃午餐！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……原來如此。",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_079"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是這樣的情況嗎。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "吶～大哥哥，",
        "unit_id": 111,
        "voice": "vo_adv_1098005_080"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "你要選誰？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "你最喜歡的是誰～？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "說清楚啊。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不、",
        "unit_id": 101512,
        "voice": "vo_adv_1098005_081"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不行不行。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不可以這麼讓人困擾喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵呵，",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_082"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這問題很直接很好啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他會給出什麼回答，",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_083"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我其實還滿感興趣的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_1098005_084"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "似似花妳真是的……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "畢竟都對我們那麼溫柔了。",
        "unit_id": 811,
        "voice": "vo_adv_1098005_085"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n當然是最喜歡",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "我們的對吧？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "是我對吧？",
        "unit_id": 111,
        "voice": "vo_adv_1098005_086"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "大哥哥。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "到底是如何呢。",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_087"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "到、",
        "unit_id": 101512,
        "voice": "vo_adv_1098005_088"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "到底怎麼樣呢……！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看樣子身陷險境呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_089"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "誰叫他不管對誰都那麼好。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "就這樣被逼上絕路吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_090"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "反正這不關拉姆的事。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "濫好人的末路還真是悲哀。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_091"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n把這件事當作教訓從今以後──",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "────！",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_092"
    },
    {
        "type": "dialogue",
        "name": "美里、小孩",
        "words": "大家……",
        "unit_id": 1,
        "voice": "vo_adv_1098005_093"
    },
    {
        "type": "dialogue",
        "name": "暴徒們",
        "words": "…………都喜歡？",
        "unit_id": 1,
        "voice": "vo_adv_1098005_094"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵。",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_095"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "討厭啦，",
        "unit_id": 101512,
        "voice": "vo_adv_1098005_096"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "讓老師好害羞……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "小孩、流氓們",
        "words": "「嘿嘿嘿～」\n「嘿嘿嘿～」",
        "unit_id": 1,
        "voice": "vo_adv_1098005_097"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "既然你都這樣說了，",
        "unit_id": 101512,
        "voice": "vo_adv_1098005_098"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，大家就",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "先來",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一起吃便當吧！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n在那之後再修理玩具。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好嗎，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有似似花小姐也是。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是沒辦法。",
        "unit_id": 107011,
        "voice": "vo_adv_1098005_099"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "等你吃完後",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真軌就拜託你了哦。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "小孩、流氓們",
        "words": "耶──！",
        "unit_id": 1,
        "voice": "vo_adv_1098005_100"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……居然全都喜歡，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_101"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是下流。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "本來還以為他表裡如一，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_102"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n但看來有必要修正一下對他的評價了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是個花心大蘿蔔。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_103"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "而且，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_104"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還是跟巴魯斯不同類型的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然兩邊都差不多就是了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這個男人，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_105"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看樣子還是先不要完全信任他比較好。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "為了以防萬一，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_106"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "暫時先不解除警戒。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "──拉姆的眼睛，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_107"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "可不會這樣被蒙混過去。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}不但沒發現拉姆的視線，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n還被大家一邊擠來擠去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊享用著便當。"
    }
]