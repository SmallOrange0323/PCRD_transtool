        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "太好了──！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "那就來交換小菜吧。",
