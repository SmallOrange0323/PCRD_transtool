    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "難怪會有人願意作愛情便當給你。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n很抱歉，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "這個還給你。",
