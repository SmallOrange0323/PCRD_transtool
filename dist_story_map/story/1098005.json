        "type": "dialogue",
        "name": "小孩",
        "words": "玩具修理，",
        "unit_id": 111,
        "voice": "vo_adv_1098005_049"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n還要很久嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……玩具的，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_050"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "修理？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "……嗯，",
        "unit_id": 111,
        "voice": "vo_adv_1098005_051"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我知道了。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我等你。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "大哥哥，",
