[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在拉姆對【美食殿堂】表達感謝之意後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n過了一段時間的某一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拉姆正一個人走在蘭德索爾的街道上──"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雷姆跟咲戀一起出門買東西，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_000"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆為了打發時間才會來到街上走走……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這裡依舊還是一樣，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是個很悠哉的城鎮呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚嗚……",
        "unit_id": 111,
        "voice": "vo_adv_1098005_002"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚嗚……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n嗚嗚",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚嗚。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "────？",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_003"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚",
        "unit_id": 111,
        "voice": "vo_adv_1098005_004"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我的、",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我的……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "本想說怎麼會有小孩子的哭聲，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_005"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n結果跟小孩在一起的不就是{player}嗎。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這邊也還是老樣子呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "啊……",
        "unit_id": 111,
        "voice": "vo_adv_1098005_006"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "大哥哥……？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我的玩具……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那是──",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_007"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "他把小孩子的玩具拿走了？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還以為他是個把善良當作衣服穿在身上的男人，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_008"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看來是拉姆搞錯了呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "似乎還不能，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_009"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "徹底信任他。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那個男人對來到了這個世界的拉姆我們展現出了自然的善良。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_010"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "而針對這點，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_011"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆已經親自招待他傳說中的蒸番薯來回報了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但剛才的行為……",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_012"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看來有必要修正一下對那個男人的評價。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "以剛才那個樣子，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_013"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "誰知道他背地裡會是什麼樣的人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "在雷姆跟愛蜜莉雅大人看到他背地裡的樣子前──",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_014"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "似乎有必要讓拉姆來處理一下呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_015"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "請放心交給拉姆吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_016"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n先放長線讓那個男人逍遙一陣子。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n在那之後，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆會好好地讓他受到懲罰的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "放長線……？",
        "unit_id": 111,
        "voice": "vo_adv_1098005_017"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "沒錯。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_018"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "首先要收集證據，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "然後再交給適當的機關來處理。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "為此得先跟蹤他。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這次拉姆不會再失敗了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "雖然不是很清楚……",
        "unit_id": 111,
        "voice": "vo_adv_1098005_019"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "但好像很有趣！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我也要一起！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……拉姆了解了。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_020"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你想親自取回自己的東西對吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但作為交換，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "別再哭了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n跟蹤時如果因為哭聲而被發現就功虧一簣了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉姆決定開始跟蹤{player}……"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那就是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_021"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "所謂的打工嗎。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n在四處奔波送完貨後，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "終於坐下來休息了的樣子。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n在他膝蓋上的是……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "便當嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這是在用餐休息嗎。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_022"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這麼說起來，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_023"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "可可蘿好像有給他一個包袱。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只是，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還真大呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "到底在裡面塞了多少小菜。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_024"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "可可蘿的過度保護真是讓人傷腦筋。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "喂喂，",
        "unit_id": 811,
        "voice": "vo_adv_1098005_025"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "小哥。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n這裡是我們的位子。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你擋到我們了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "嗯嗯？",
        "unit_id": 6311,
        "voice": "vo_adv_1098005_026"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "你這東西不錯哦。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n雙層的愛情便當是嗎？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "不僅搶了別人的位子還拿便當出來炫耀，你膽子可真不小啊！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "我才不管你什麼意思呢。",
        "unit_id": 811,
        "voice": "vo_adv_1098005_027"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "交出來！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "我幫你吃掉。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看起來就是群沒品的傢伙。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_028"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不過，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這或許剛好能治治那個男人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "而且，",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_029"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "在這種情況下應該會露出本性才對。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "來吧──",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_030"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "讓拉姆看看你背地裡骯髒的一面。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "想要的話就來搶回去啊！",
        "unit_id": 811,
        "voice": "vo_adv_1098005_031"
    },
    {
        "type": "dialogue",
        "name": "暴徒們",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_1098005_032"
    },
    {
        "type": "dialogue",
        "name": "暴徒們",
        "words": "你為什麼一動也不動！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "他為什麼呆站在那裡。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_033"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "難道說是在等對方徹底鬆懈嗎……？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "嗚哇！",
        "unit_id": 811,
        "voice": "vo_adv_1098005_034"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n這傢伙，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "居然搶回去了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "以那男人來說搶得還算強硬呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_035"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……為什麼他附上了吃便當用的餐具跟茶飲，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n然後又把便當交還給對方了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "你說雖然是很重要的便當，",
        "unit_id": 6311,
        "voice": "vo_adv_1098005_036"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "但如果有人需要幫助，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "\n就應該分給對方？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "請我們好好享用……？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你是認真的嗎？",
        "unit_id": 811,
        "voice": "vo_adv_1098005_037"
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你、",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "你這傢伙真的是……！！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_038"
    },
    {
        "type": "dialogue",
