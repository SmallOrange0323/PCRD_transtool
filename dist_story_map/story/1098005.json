        "voice": "vo_adv_1098005_052"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "原來是這樣。",
        "unit_id": 109811,
        "voice": "vo_adv_1098005_053"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n並不是把玩具從小孩子手中搶走，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n而是為了修理而暫時拿過來而已。",
