        "voice": "vo_adv_1098005_042"
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
        "words": "你說還有其他好人？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒２",
