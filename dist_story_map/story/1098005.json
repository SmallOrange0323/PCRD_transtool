        "name": "暴徒１",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "是嗎，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "暴徒１",
        "words": "拉姆也是個好人。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "到底都在胡說些什麼。",
