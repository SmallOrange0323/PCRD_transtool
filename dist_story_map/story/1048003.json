[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}走在平原上，看到美冬在河邊\n以驚人氣勢修復損壞的橋。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "得啦啊啊啊啊啊啊！",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣就修理好了呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "土木工程人員",
        "words": "哦，大姐，謝謝妳的幫忙呢！",
        "unit_id": 1411,
        "voice": "vo_adv_1048003_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不客氣。那麼打工費是10,000盧幣。",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "確實收到了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝惠顧！再見！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後過了一段時間，{player}在城鎮邊\n看見美冬正從田的一端收割農作物。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喝啊啊啊啊啊啊！",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼，收割完成了呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好，打工費是2000盧幣。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝惠顧！ 再見！",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_007"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "又過了ㄧ段時間，{player}遇見了\n臉色很差、背著大量報紙，雙手邊在劍上\n加裝蒲公英飾品邊走路的美冬。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，是你。",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是巧遇呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我這副模樣？ 我正接受新藥開發臨床試驗的打工，",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "並一邊送報紙，一邊做在時髦的劍上",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n加裝蒲公英飾品的打工喔。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，果然還是有點累……",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊……！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝…謝…我是怎麼了，身體突然失去平衡……",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦……？ 你說我正發著高燒嗎……？",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不知道是否因為太過疲勞……該怎麼辦？",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n必須完成的工作量還有這麼多……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦……！　",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}他！？",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "哎――呀，你是送報紙的嗎？",
        "unit_id": 611,
        "voice": "vo_adv_1048003_015"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "非常感謝你呢。",
        "unit_id": 611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "武器屋的大叔",
        "words": "喔……！ 蒲公英飾品都裝上了嘛！",
        "unit_id": 911,
        "voice": "vo_adv_1048003_016"
    },
    {
        "type": "dialogue",
        "name": "武器屋的大叔",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "武器屋的大叔",
        "words": "新劍上面有沒有蒲公英的時髦度",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "武器屋的大叔",
        "words": "\n完全不一樣呢！ 謝啦！",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "女醫師",
        "words": "發生什麼事了？這樣拉著我的手……",
        "unit_id": 1211,
        "voice": "vo_adv_1048003_017"
    },
    {
        "type": "dialogue",
        "name": "女醫師",
        "words": "咦？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女醫師",
        "words": "\n因為臨床實驗的病人倒下，所以希望我直接過去？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女醫師",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女醫師",
        "words": "我知道了，我現在就過去……",
        "unit_id": 1211
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "完成美冬所有打工的{player}，\n向在公會小屋休養的美冬報告。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝……謝。",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你幫了大忙呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "竟然讓你幫忙……我真是個不及格的師父。",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "欸嘿嘿……謝謝。",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喂，雖然我可能是因為發燒才會說這種話……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等我退燒之後，會再次以你師父的身分",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n嚴格訓練你，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "所以只有現在，我能把你前陣子",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n說的那個當真嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只有現在……我能把自己當成一個女孩子，",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n向你撒嬌嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "今天我想……喝粥呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048003_023"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}熱心地照顧美冬直到退燒為止，\n兩人之間的羈絆又再次加深了。"
    }
]