        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "時間很趕讓人家真的超著急的～",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "後輩",
        "words": "非常謝謝妳，",
        "unit_id": 1214,
        "voice": "vo_adv_1179001_061"
    },
    {
        "type": "dialogue",
        "name": "後輩",
        "words": "鈴奈前輩。",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "後輩",
        "words": "\n我",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "後輩",
        "words": "這就上場登台！",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯！",
        "unit_id": 117911,
        "voice": "vo_adv_1179001_062"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "讓大家清楚地看看",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n妳最最可愛的模樣吧～！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小後輩，",
        "unit_id": 117911,
        "voice": "vo_adv_1179001_063"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看她那樣子，應該是沒問題了？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "幫了忙",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的很謝謝你！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "剛剛雖然對小後輩說了很帥氣的話，",
        "unit_id": 117911,
        "voice": "vo_adv_1179001_064"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n但人家也是總是失敗連連呢。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也經常",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "受秀才你的幫助。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 117911,
        "voice": "vo_adv_1179001_065"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "即使不能說是報答，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n但要是有人遇到困難，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也想要幫助他。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有，",
        "unit_id": 117911,
        "voice": "vo_adv_1179001_066"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然同事務所也是原因之一……",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看著她感覺就好像看到家裡的弟弟一樣，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "實在無法放下她不管。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家啊，",
        "unit_id": 117911,
        "voice": "vo_adv_1179001_067"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不是對後輩說了",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "轉換心情也很重要嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，",
        "unit_id": 117911,
        "voice": "vo_adv_1179001_068"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對人家來說，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n轉換心情最好的方法，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你覺得是什麼呢？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那就是……",
        "unit_id": 117911,
        "voice": "vo_adv_1179001_069"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和秀才一起玩！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n今天從現在起",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你一整天都要陪著人家喔，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "請多指教囉♪",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴奈握住{player}的手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以輕快的步伐走向萬聖節的熱鬧大街。"
    }
