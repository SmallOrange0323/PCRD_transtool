    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聯合行軍訓練平安（？）地結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n惠理子與新兵們回到了訓練所。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在那之後的某一天，真琴再次前來關心狀況。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗨，",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n訓練還順利嗎──？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯，",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那當然。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n畢竟我在行軍訓練時也已經掌握到和新兵們相處的方式了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "接下來的工作是基礎訓練……",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我正在用最好的訓練計畫",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "鍛鍊新兵們呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦～",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "挺用心的嘛！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼最重要的訓練計畫內容是什麼？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我看看……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "第一天。",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "練腹肌。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "練背肌。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "伏地挺身。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "長跑。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n第二天。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "練腹肌。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "練背肌。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "深蹲。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "長跑。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n第三天。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "練腹肌。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "練背肌。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "再練一次腹肌……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "長跑……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…………",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子……",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這些訓練，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只有練到肌力欸……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是的。",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這有什麼問題嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就說了！",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們要培育的",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不是肌肉男，而是騎士啊，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "騎士！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "像是劍術訓練，",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "或馬術訓練之類……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果不把這些也加進來，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是不會成長為強大的騎士的！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有這回事唷。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "畢竟我",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "根本不懂什麼劍術，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還是很強。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而且，",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "肌力這種東西是不容小看的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為在戰鬥中，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唯有肌力才是力量。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這是什麼聽起來很笨的理論啊！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然妳的確有著跟外表不符的怪力啦……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怪力……",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我有嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "確實",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這點程",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "度的斧頭，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我是可以隨心所欲地揮舞沒錯……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別、",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別那麼輕巧地亂揮大斧啦……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話說",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳那把武器",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "究竟有多重啊？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要拿拿看嗎？",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、啊啊……",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那我就",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "來試試看。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咿",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咻",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──嗯嗯！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "？",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳怎麼了嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還、",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還問我怎麼了……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說妳，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "平常都在揮舞這麼重的東西嗎！？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "重……？",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "確實是有點偏重，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但應該沒有到那麼重吧……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "果然很異常啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳這傢伙！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是有妳這種蠻力，才不需要什麼劍術啊！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀……",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是這個樣子的嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉……",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣不行。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂惠理子，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "跟我過來一下。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴？",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是要去哪……？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別問了快過來！",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯。",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到這附近應該可以了吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴？",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我們離訓練所有一段距離了……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n妳是打算要做什麼？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我要訓練妳的劍術。",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "訓練我的劍術？",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我剛才也說了，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有這個必要……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算對妳來說沒有必要，",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但妳指導的那些新兵需要啊！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唉……",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "訓練盡是些麻煩的事呢……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別一直碎碎念了。",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "趕快開始吧！",
        "unit_id": 129811
    },
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "劍……",
        "unit_id": 129811,
        "voice": "vo_adv_5142003_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "斷掉了……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "斷掉……",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "了呢……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然很可惜，",
        "unit_id": 129911,
        "voice": "vo_adv_5142003_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
