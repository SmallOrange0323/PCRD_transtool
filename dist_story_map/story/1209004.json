        "unit_id": 120911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n溫暖的感覺在胸口深處慢慢地湧現。",
        "unit_id": 120911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這傢伙也頂著一張幸福的臉睡著了。",
