[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾充分享受過新年，\n伊莉亞和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一臉滿足地回到了古城。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼，",
        "unit_id": 120912,
        "voice": "vo_adv_1209004_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總算回到妾身的城堡了。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這身子的步伐",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然比較小，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "回家的路走起來感覺特別遠呢。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 120912,
        "voice": "vo_adv_1209004_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一想到妾身因此而能和這傢伙相處得更久，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這副姿態",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也不是一無是處哪……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但",
        "unit_id": 120912,
        "voice": "vo_adv_1209004_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖說妾身是為了未來的人民，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才放棄真正姿態的……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在又得找出變回去的方法了哪。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……喂，",
        "unit_id": 120912,
        "voice": "vo_adv_1209004_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "幹嘛一臉滿足地呆站著？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身會變回這副姿態，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還不就是你出的主意害的？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "接下來也要當護花使者、",
        "unit_id": 120912,
        "voice": "vo_adv_1209004_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "護花使者。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "暫時",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不許你離開妾身的身邊哦。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯？",
        "unit_id": 120912,
        "voice": "vo_adv_1209004_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為什麼房間好像散發著奇異的光芒……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n難道是哪個房間的窗簾沒有拉好嗎？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚，",
        "unit_id": 120912,
        "voice": "vo_adv_1209004_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好、",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好刺眼……！",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──等等，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在發光的",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不就是你嗎！？",
        "unit_id": 120912
    },
    {
        "type": "background",
        "background": "510202"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在將要迎來新年的某夜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "人們正趕著回家，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而伊莉亞隻身一人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在瞭望台眺望燈火通明的城鎮。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n怪不得妾身覺得城鎮變得冷清了。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……已經要過年了啊。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唉，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真憂鬱。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這時節的寒冷",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不知為何要比往常更加刺骨。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……心中這份因長命而生的寂寞，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身早在許久以前就決定要遺忘的。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但年復一年，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身總在要忘記時又再度想起。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "孤獨這傢伙啊……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "簡直能自詡為妾身的家人了呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還是說，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這也是因為與那傢伙相遇，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以打從心底信任他的緣故呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "反常地",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "變得感傷了呀……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呀啊啊啊！？",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n怎、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎怎怎、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼了！？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n──是你啊！！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別在妾身無精打采的時候……",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n忽、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "忽然向妾身搭話！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而、",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n偏偏還是在",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身想著這傢伙的時候……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哎唷，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "該擺出什麼表情才好……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……耳、",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "耳朵真尖啊。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n明明平常就呆呆的，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "卻只在這種時候……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "算了，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是因為妾身",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "活得比你更久的緣故吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以才會不斷回顧過往呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "比起這個……",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你應該也有等著你回去的家人吧？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "太陽馬上就要下山了，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且天氣也很冷。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別在這種地方徘徊了，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快點回家比較好哦。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾、",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身很中意這片從瞭望台看出去的夜景。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "尤其是，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在這個時節所望見的城鎮燈火，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n因為空氣澄澈，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以別有韻味。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在征服世界之前，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身想先獨占這片絕景。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "再享受一下子，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也要回去了。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你也不要有所顧慮，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快點回到家人身邊吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……快，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你還不走嗎？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說什麼？",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在這裡等一下",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是什麼意思……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n──喂、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唉，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還是跟往常一樣，老是這麼不穩重啊。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n至少也說一下到底要做什麼吧……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你回來了！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n剛剛去了哪裡？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還有，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那堆東西到底是……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你背上背的東西是……",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "新年裝飾",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗎？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n還有像是玩具之類的東西……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還有，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你手上拿著的鍋子？這又是？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你、",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說年糕湯？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是人民在這種時候",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "會聚在一起吃的那個年糕湯？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……還有點熱呢",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──不，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這根本是燙的呀。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "難道",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n回家一趟後",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "又回來這裡？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "………………",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵──",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈哈哈！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你、",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你這傢伙，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是個打破常規的人哪！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不論什麼時候，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都不曉得你會做出什麼事來！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想看夜景，所以抱著裝有年糕湯的鍋子，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n在年前的街上走來走去……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈哈哈，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你這種人，妾身也是第一次看見呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是為了",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "和你這般有趣又奇怪的人相遇……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n呵呵，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身才會活這麼久的吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……好吧。",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是你讓妾身發出新年第一笑的回禮。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n能和妾身",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "共賞這片絕景的榮耀，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就特別賞賜給你一人吧……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這可是有條件的。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "趁還沒涼之前，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_034"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把那年糕湯給妾身吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n在這裡看見的景色",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都將會納入妾身的統治，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以年糕湯就當作是參觀費了。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這次特別算你一碗就好。",
        "unit_id": 104431
    },
    {
        "type": "still",
        "still": "120900401"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──呼哈……",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_035"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好溫暖。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n簡直像",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吸吮美味之血時的感覺……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n全身暖呼呼的，好舒服哦。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯、",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "年糕湯吃得到濃郁香味，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真好吃。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身不知道是你的父親還母親做的，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過真是好手藝。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "當妾身完成征服世界之時，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身很樂意",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "納他為專屬的廚師。這手藝就是這麼好。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "連那種東西都……",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是特地裝在保溫瓶裡帶過來的嗎？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你又費了一番心思呀。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還真體貼。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就讚賞你吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……呼。",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然是好景色呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身已看過這片夜景無數次，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但像這樣和你一起眺望，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n又更加別有風味。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "街上的每一簇燈光",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_040"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看起來都好溫暖……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "以前，妾身總覺得它們在遠方閃耀，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但此刻",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "卻感覺它們忽然靠得好近。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是不可思議呀。",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_041"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n即便現在妾身非常喜愛這景色，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從前卻認為終有一天會對此感到厭煩。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只要待在你身邊……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就不會無趣。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是令人愉快的傢伙哪。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n今年也",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "盡心取悅妾身吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n可以的話，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "明年也要如此，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "後年也是。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妾身會期待",
        "unit_id": 104431,
        "voice": "vo_adv_1209004_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "並等著的。",
        "unit_id": 104431
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗚……",
        "unit_id": 190011,
        "voice": "vo_adv_1209004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總覺得",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好想哭哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一直以來崇高又精神滿滿的伊莉亞，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n居然也有這一面……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所有人都希望長命百歲，",
        "unit_id": 190011,
        "voice": "vo_adv_1209004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然我不認為那是多奢侈的願望……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但有些痛苦啊，唯有活得夠久，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才得以體會。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是……",
        "unit_id": 190011,
        "voice": "vo_adv_1209004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "此刻的伊莉亞",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有你在。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她已經不是孤身一人了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一定是這樣吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "至少，在這個瞬間，",
        "unit_id": 190011,
        "voice": "vo_adv_1209004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "伊莉亞應該會這麼想吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……「幸好有你」。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n呵呵，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來你也要好好珍惜她哦？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1209004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "差點忘記說了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "祝你新年快樂～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
