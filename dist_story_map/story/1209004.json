        "voice": "vo_adv_1209004_052"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n現在妾身的身體是縮小的……",
        "unit_id": 120911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對吧……？",
        "unit_id": 120911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n嗯？",
        "unit_id": 120911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯～？",
