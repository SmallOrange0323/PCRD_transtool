[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……我跟鈴莓還有流夏商量過了，",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不太可能一起住在育幼院裡。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們好好準備一個新家，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然後再每天通勤吧。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是這樣，",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那你想要什麼樣的房子呢？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟是接下來要一直居住的地方，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n如果有什麼需求就告訴我吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不是想問你這個……",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我沒有不開心喔。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只是，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總不能無視你的喜好來決定啊。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……我跟流夏自行決定就好嗎？",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你真的是",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對這種事情",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒什麼堅持耶。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那樣的話，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就不客氣了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然也有預算的考量……",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但果然",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "廚房跟客廳要大一點比較好吧。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我偶爾",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也想帶育幼院的孩子們",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來新家玩。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n大家一起吃飯的話，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就需要大一點的空間吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且也有可能",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為工作的關係需要招待客人。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有，",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果有一間書房能讓我集中精神工作",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就沒問題了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n防音要做得徹底，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為了保管重要的文件，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也想裝好一點的鎖呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……先準備好一間這樣的房間，",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n想要兩人獨處的時候也比較方便對吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我可不是想排擠流夏喔？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不是這個意思～",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以說，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是想在兩人獨處時撒嬌用的房間啦！！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟你卿卿我我的時候，",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我不希望還要擔心流夏或其他人",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會跑進來啦！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……這樣你懂了嗎！？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好，",
        "unit_id": 127512,
        "voice": "vo_adv_5128072_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你的理解。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n總之，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我的要求就是這樣。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那就之後",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再跟流夏一起討論細項吧。",
        "unit_id": 127512
    }
]