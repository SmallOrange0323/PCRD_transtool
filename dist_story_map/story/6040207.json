    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家",
        "unit_id": 102611,
        "voice": "vo_adv_6040207_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都很喜歡溫泉真是太好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不枉費我們那麼努力宣傳呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家都被那個雕像？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "給嚇到了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很有趣呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是啊。",
        "unit_id": 102611,
        "voice": "vo_adv_6040207_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "比真陽更有搞笑的品味……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不是那樣嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "　那是怎麼樣啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "突然",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "開始覺得那位製作人有點恐怖呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "溫泉與大自然比肩而鄰，",
        "unit_id": 102611,
        "voice": "vo_adv_6040207_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就這樣成為了不錯的觀光地呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不過規模變得越大，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "似乎也代表會變得越來越忙，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣我的心情也有點複雜就是了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是說啊！",
        "unit_id": 102611,
        "voice": "vo_adv_6040207_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "　難得有溫泉竟然還得一直工作！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……不過，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽好像很高興，所以也不錯啦。",
        "unit_id": 102611
    }
]