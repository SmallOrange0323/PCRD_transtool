[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，當{player}在平原與魔物戰鬥時，\n一旁傳來巨大聲響。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喝啊啊啊啊啊！",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_000"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很好！ 一招致命呢！",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n討伐委託完成！ ",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "下一個！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼、呼、",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼、呼……",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後又過了一段時間，\n當{player}正在其他地方與魔物展開死鬥時――"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喝啊啊啊啊啊啊！",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_003"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很好！ 一招致命！",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯……但是剛才的動作有點多餘呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "該反省反省……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯？ 奇怪……",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂，你。我從剛剛開始就一直遇見你……",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你是賞金獵人？ 還是保鏢？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來似乎不是同行呢……",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是喔。算了，沒關係。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "話說回來，你叫什麼名字？",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣啊，原來如此。我的名字是美冬喔。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "今後請多多指教。我隸屬於墨丘利財團……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n是只要有酬勞什麼都能搞定的傭兵喔！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也可以說我是在各地領時薪工作的能幹打工族喔。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "話說回來，你剛剛使的劍法，",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n慢到我都看不下去了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你認為戰鬥最需要的是什麼？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯──，",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只有勝利是不行的。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然答案很接近……",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可惜答錯了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "正確答案是……",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "『效率』喔！！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "以最精簡的動作獲得最佳效率，那就是我引以為目標的",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n最強傭兵。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "時間就是金錢！ 時間是不等人的！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "換句話說，如果有時間悠閒沉浸在擊倒一個敵人的餘韻中，",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不如更有效率地行動，再擊倒一個敵人。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "能看一下這裡嗎？ 我示範給你看。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要一招擊倒兩個敵人……",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "首先是給予重擊，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再用力抓過來，像這樣",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯，大概是這種感覺喔！",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，等等……？ ",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我想到更有效率地擊倒敵人的方法了！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n或許，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "像這樣高舉之後，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再這麼做的話，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n第三招就能擊中……！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "………………",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……沒有傷到喔。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_024"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒、沒有傷到啦！！ ",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是真的喔！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是，你的攻擊看起來頗具威力呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然劍法不太行，但是若好好地鍛鍊，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我認為能有相當的戰力喔。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對了，",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你要不要當我的徒弟？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我會手把手教你如何有效率地打敗敵人喔！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不客氣。呵呵呵，用不著道謝。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_028"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n今後，我會定期在這個平原",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n嚴格訓練你喔！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "像這樣，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再這樣……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "痛、",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "痛痛痛……我的腰……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "話說回來，教師費幫你打了個大折扣，",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_030"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n時薪只要750盧幣就好了喔！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……？ 怎麼了？一臉搞不清楚狀況的樣子。",
        "unit_id": 104811,
        "voice": "vo_adv_1048001_031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美冬自己說要收徒弟，又主動要求報酬，\n{player}對於她強烈的經商頭腦感到相當吃驚……"
    }
]