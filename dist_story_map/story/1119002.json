[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在神殿結束參拜的{player}與可可蘿，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了因為新年廟會而熱鬧非凡的繁華街。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "參拜的內容",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是祕密。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算是主人，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也不能說。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下聽說，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若是說給別人聽，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "願望就不會實現了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也不可以說出來喔。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話又說回來，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明新年都快要結束了，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n卻還非常熱鬧呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼主人，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您肚子餓了嗎？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡有很多攤販，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若有任何想吃的東西，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請儘管告訴在下。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請別擔心錢的問題。",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下從家鄉那裡領到了不少壓歲錢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來那邊",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎非常熱鬧呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人有興趣的話，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們就一起去看看吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "情侶（男）",
        "words": "是這裡嗎？",
        "unit_id": 311,
        "voice": "vo_adv_1119002_007"
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "就是這種感覺。",
        "unit_id": 411,
        "voice": "vo_adv_1119002_008"
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "\n要慢慢地，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "慢慢地喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雙人羽織啊。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有很多男女參加呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "哦，",
        "unit_id": 1411,
        "voice": "vo_adv_1119002_010"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "那邊的小姐，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "你們有興趣嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n以雙人羽織的方式吃蕎麥麵，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "來考驗兩個人的羈絆。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "要是能夠吃完，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "就送你們可以在附近攤販",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "使用的折價券喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "啊啊！",
        "unit_id": 411,
        "voice": "vo_adv_1119002_011"
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "　就說不是那裡了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "\n你認真點啦～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊……",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "麵被放到",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位女性的鼻子裡了！",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是讓人同情……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "哈哈，",
        "unit_id": 1411,
        "voice": "vo_adv_1119002_013"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "那對情侶不會長久呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "那種人每年都很多，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "簡直要讓人看不下去了啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雙人羽織",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "連這種事情都看得出來嗎？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_1119002_015"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "只要像我一樣長年",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "做這份工作，就看得出來喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "但是，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "如果兩個人之間的羈絆是真實的，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "雙人羽織根本是小事一樁啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "糟糕，",
        "unit_id": 1411,
        "voice": "vo_adv_1119002_016"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "嚇到你們了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "不過……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "就我來看的話，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n我猜小姐你們兩位",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "一定能夠吃完蕎麥麵吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "那麼，",
        "unit_id": 1411,
        "voice": "vo_adv_1119002_017"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "怎麼樣呢？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "要來展示一下",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "妳和這位小哥的羈絆嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們的羈絆嗎？",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺似乎比想像中還困難……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真有自信呢。",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下被您那可靠的樣子",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "給打動了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對您來說，雙人羽織的難度",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根本算不上什麼嗎？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟壓歲錢也有限，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個獎品確實是很吸引人……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是說呢，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是在下和主人的話，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肯定不會有問題的。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓我們也參加吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們會漂亮地",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吃完這碗蕎麥麵的。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "好喔～！",
        "unit_id": 1411,
        "voice": "vo_adv_1119002_023"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "　就是該這樣才對嘛！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "來，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "這是你們的羽織。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "在下一輪開始前，",
        "unit_id": 1411,
        "voice": "vo_adv_1119002_024"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "先決定好",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "誰坐前面、誰坐後面吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "要換你們上場時，我再叫你們！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身為『嚮導』，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就由在下來\n確實地",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將蕎麥麵引導至",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的嘴裡吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎還要再等一下",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才會輪到我們的樣子，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先來練習吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下從背後失禮了……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱住。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是錯覺嗎？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總覺得主人的背",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎比以前",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還要寬廣的樣子……？　",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然剛才參拜時，",
        "unit_id": 111911,
        "voice": "vo_adv_1119002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "許了願希望今年也能",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直待在主人身旁，",
        "unit_id": 111911
    },
    {
