        "voice": "vo_adv_5098003_100"
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "\n我總覺得很久以前聽說過",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "會發出這種叫聲的生物。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "\n",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "是在哪裡來著……",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下2",
        "words": "真的嗎，",
