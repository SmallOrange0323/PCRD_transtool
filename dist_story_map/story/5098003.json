        "type": "dialogue",
        "name": "仲介商",
        "words": "……那麼，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "你為什麼從剛剛開始就不講話了？",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下1",
        "words": "咦？",
        "unit_id": 4911,
        "voice": "vo_adv_5098003_103"
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下1",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下1",
        "words": "啊，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下1",
        "words": "不……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下1",
        "words": "沒什麼。",
