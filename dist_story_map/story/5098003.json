        "voice": "vo_adv_5098003_107"
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "由我決定。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "\n你老實地把知道的消息通通說出來。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "\n",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "──就算想法天真愚蠢，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "你起碼也懂得衡量得失吧？",
