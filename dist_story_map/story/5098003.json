        "type": "dialogue",
        "name": "仲介商的手下1",
        "words": "有點古怪的動物，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下1",
        "words": "\n我想也沒什麼賺頭……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "有沒有賺頭",
