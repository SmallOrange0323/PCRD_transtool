    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果有我也做得到的事情，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想要幫忙。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "幸好，",
        "unit_id": 103813,
        "voice": "vo_adv_5098003_093"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我有許多藏書……",
