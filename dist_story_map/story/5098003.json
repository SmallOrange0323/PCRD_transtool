        "name": "？？？",
        "words": "\n牧場的範圍。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n大概是牛叫聲，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "或是觀光客的喧鬧聲吧。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "話是這麼說沒錯……",
        "unit_id": 4911,
        "voice": "vo_adv_5098003_081"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我總覺得那種叫聲很奇怪。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "聽起來不像動物……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喔？",
        "unit_id": 811,
        "voice": "vo_adv_5098003_082"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……哪個，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那就過去看看吧。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "反正也閒著沒事。",
