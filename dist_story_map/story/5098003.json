        "voice": "vo_adv_5098003_098"
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下2",
        "words": "\n外表長得難以形容，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下2",
        "words": "\n會發出繆～繆～",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "仲介商的手下2",
        "words": "這樣的奇特叫聲。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "仲介商",
        "words": "叫聲奇特的",
