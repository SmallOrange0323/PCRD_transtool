        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 103813,
        "voice": "vo_adv_5098003_090"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我知道了。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請讓我也來幫忙吧。",
        "unit_id": 103813
    },
