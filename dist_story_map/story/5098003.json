        "type": "dialogue",
        "name": "鏡華",
        "words": "可以嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_5098003_091"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我",
        "unit_id": 103813,
        "voice": "vo_adv_5098003_092"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "身體虛弱……",
