        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "別說資料，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "連情報也沒有……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們把能想到的一切都試著調查過了。",
        "unit_id": 103611,
        "voice": "vo_adv_5098003_088"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可是……",
