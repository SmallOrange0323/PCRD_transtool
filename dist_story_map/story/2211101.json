        "voice": "vo_adv_2211101_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "泡起來會這麼舒服呢……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "逐漸乾枯的身心",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都要變得滋潤了……",
        "unit_id": 103412
    },
