        "voice": "vo_adv_2211101_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這麼說來……",
        "unit_id": 103412,
        "voice": "vo_adv_2211101_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我還沒問過",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "小苑的年紀呢。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n在飲食",
