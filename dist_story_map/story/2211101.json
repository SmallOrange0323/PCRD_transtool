    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "竟然說出這種彷彿像是大人一樣的話。",
