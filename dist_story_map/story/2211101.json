    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n不如說",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這個水溫對於因為運動不足而容易冰冷的身體來說，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是再好不過了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗚嗯……",
        "unit_id": 132512,
        "voice": "vo_adv_2211101_006"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "舒暢……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n真是通體舒暢……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……唉唷，小苑妳真是的，",
