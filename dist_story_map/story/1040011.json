        "voice": "vo_adv_1040011_062"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一起睡著了呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n叫醒他也不太好，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就等他自己起來吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵，",
        "unit_id": 104011,
        "voice": "vo_adv_1040011_063"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "他睡著的表情好像很幸福。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "看著這個表情……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040011_064"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我怎麼好像害羞起來了……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這是為什麼呢……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040011_065"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是因為剛才做了",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好像很開心，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "又好像很害羞的夢嗎……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚嗚……",
        "unit_id": 104011,
        "voice": "vo_adv_1040011_066"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我好想現在就逃得遠遠的……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是我又不能把團長丟在這裡……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長～！",
        "unit_id": 104011,
        "voice": "vo_adv_1040011_067"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n請、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請你快點起來啦～！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}清醒後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他和不知為何比平時更怪的碧，"
    },
    {
        "type": "dialogue",
