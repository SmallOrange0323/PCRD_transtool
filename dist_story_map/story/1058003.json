        "voice": "vo_adv_1058003_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "♪\n{player}真是好人！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以喜歡上你嗎？",
