        "voice": "vo_adv_1058003_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n釣竿好像都要折斷了呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很不妙呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "堅持下去吧，{player}！\n為了美味的魚料理！",
