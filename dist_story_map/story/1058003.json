[
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這不是{player}嗎！\n",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們最近蠻常碰面呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你在這種地方",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n做什麼呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "夜晚的海邊很危險喔～",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為會出現很兇猛的魔物喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且海裡什麼也看不見，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是不小心掉下去就麻煩了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果不是很擅長游泳的人，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一旦驚慌失措，就會溺水喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你怎麼了嗎～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呆坐在海灘上……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你遇到什麼難過的事情嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好可憐啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以的話，說給我聽聽吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開導煩惱中的人民，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n原本就是我們的職責所在♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哼哼，{player}……",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了做我教你的魚料理，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才來這裡收集食材的吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起去店裡採買，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n自己取得食材省錢多了呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說完全捉不到魚，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以很煩惱？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……這一帶不但會出現魔物，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n魚類的戒心也很強喔～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是太過大意，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "反而會被一口吃掉喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且用手捉是不行的喔，\n{player}。",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "至少要準備好釣竿和魚網。",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要不要我教你怎麼釣啊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我最近也是為了幫打工的料理店收集食材，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才像這樣到海邊來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我這裡有釣魚用具，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以借你喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不用道謝啦，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有困難的時候就是要互相幫忙嘛♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且。",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想吃美味的東西、想做料理……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n想取得食材～諸如此類的願望，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我全部都給予肯定喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "進食就是為了生存呢。",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看到為了生存而全力以赴的人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我就不禁想為他加油呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷？",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你不用這麼客氣啦～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們不是朋友嗎♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你說要是把釣竿借走，反而我會困擾？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題啦～",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我可是老手呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "情況再怎麼糟，我徒手也能捉到魚喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我經常徒步遊走全國……",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大部分的食材，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我都是在當地附近的山野、河川取得的喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以收集食材",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我相當熟練喔？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是我的釣竿。",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n拿去吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我破例告訴你釣魚的好地方吧～",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "強烈推薦這附近的海灣喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那片水域豐富的營養條件，孕育了各式各樣的魚，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一釣就會上鉤喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀。",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n等一下喔，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我準備一下魚餌。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿咻……",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n把那附近的岩石\n翻開來～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把跑出來的蟲子收集起來、弄死，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再將它們弄碎、做成丸子。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把這個繫在釣鉤的尖端上。",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然活餌比較容易讓魚上鉤～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但要在晚上把活生生的蟲子繫在釣鉤上太困難了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好了，弄好了喔～",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了讓它看起來像魚餌",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我可是下了不少功夫呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "接著把釣竿握好，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小心不要讓它從手中滑出去～……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "使盡全力拋竿，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "將釣鉤拋向遠處落下♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很棒很棒！",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，在浮標有反應前，我們就耐心等待吧～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果完全沒反應，表示魚餌可能已經被吃掉了，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n暫且把釣鉤收回，確認看看吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果感覺魚都不上鉤，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以定期地改變垂釣的地點喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我先去設置漁網，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n稍微失陪一下喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻……",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣到了明天早上，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就有多到滿出來魚可以帶回去了～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼了，{player}？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是你發出奇怪的聲音嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔哇，上鉤了上鉤了！",
