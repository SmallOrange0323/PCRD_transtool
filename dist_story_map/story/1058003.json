    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇哇？",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都兩人合力收竿了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n卻感覺要一起被拖到海裡去！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別說釣線會斷掉，",
