        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該是我展現廚藝的時候了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好期待吧，\n{player}♪",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
