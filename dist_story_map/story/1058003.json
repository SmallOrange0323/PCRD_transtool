    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺挺好的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從這個強烈的反應看來，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n上鉤的可能不是普通的魚，而是魔物？",
