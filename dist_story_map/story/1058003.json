        "voice": "vo_adv_1058003_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n自己釣到的魚自己來料理並享用，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可謂是最奢侈的享受啊♪",
