        "voice": "vo_adv_1058003_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n魚好像立刻就咬住魚餌不放！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "收線收線，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n快點！",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "105800301"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我來幫你啦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要稍微從後面抱緊你！",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n討厭的話，\n要跟我說喔～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔，好強的拉力……！　",
        "unit_id": 105812,
        "voice": "vo_adv_1058003_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像是條大魚，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}說不定有釣魚的才能喔？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，你不要強拉啦！",
