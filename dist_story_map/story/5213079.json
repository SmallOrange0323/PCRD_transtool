[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……啊！",
        "unit_id": 105611,
        "voice": "vo_adv_5213079_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "剛、",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "剛才那是",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼回事？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n簡直像是",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "全身上下都被",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一刀刀斬裂一樣……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難道我",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是看見了",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "幻覺嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵──",
        "unit_id": 129711,
        "voice": "vo_adv_5213079_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n此次請恁品嚐的，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "乃棲息於吉歐‧格黑納之太刀魚料理。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "其刃即便死後仍然鋒利，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還會襲向食用之人。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "身處生死之際，",
        "unit_id": 129711,
        "voice": "vo_adv_5213079_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "諸般感官皆為之磨礪銳利。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "味覺亦不例外……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "故而此料理方被奉為絕品，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n為那不懼生死的猛者們",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "所鍾愛。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "確實是",
        "unit_id": 105611,
        "voice": "vo_adv_5213079_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好吃得不得了……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n可是難不成，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那是因為我剛才",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "專注到彷彿生死一線",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的關係嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖說世界之大無奇不有，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但還真有這種驚人的料理啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "經預先去刃之處理後，",
        "unit_id": 129711,
        "voice": "vo_adv_5213079_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便不至於落命，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還請寬心。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而據聞，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若天資過人者食之，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "將無意識地感知那撲面而來的劍氣，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n或現沙場征戰之幻象──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "即如方才",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "流夏閣下那般。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那就好……",
        "unit_id": 105611,
        "voice": "vo_adv_5213079_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可不能這麼妥協呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就算只是幻影，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是被單方面斬殺，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我這女武士的名號就要蒙羞了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這下得再來一份，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好好雪恥才行。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這股氣魄甚好──",
        "unit_id": 129711,
        "voice": "vo_adv_5213079_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "最緊要的太刀魚",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "已告罄了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若流夏閣下不介意，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "親自前往垂釣太刀魚",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦無不可。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n釣具一應俱全，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這此處皆已備妥。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒問題，",
        "unit_id": 105611,
        "voice": "vo_adv_5213079_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我對釣魚也是很有自信的──",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呃，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那是什麼？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好像純會喜歡的",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "全身鎧甲？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n說是釣魚用的裝備，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "未免也",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "太誇張了……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "太刀魚棲息之處，",
        "unit_id": 129711,
        "voice": "vo_adv_5213079_008"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "乃是從煉獄大地噴出的灼熱熔岩流。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若無準備萬全便貿然靠近，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "轉眼間即會化為焦炭……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還請多加當心，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "吉歐‧格黑納",
        "unit_id": 105611,
        "voice": "vo_adv_5213079_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "到底是多狂野的世界啊！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓人忍不住想挑戰，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這也是釣魚人的天性……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也一起來吧，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "走囉！",
        "unit_id": 105611
    }
]