[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希為了慈樂之音的出道演唱會，\n正在製作舞台服裝。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "想不到居然還需要製作第三件……",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n被擺了一道了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "慈樂之音的首次演唱會，明明只有小望和千歌登場才對啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "結果海報一出來，才發現怎麼我也變成表演者了……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的──！被小望給騙了啊～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……算了，還能再做一件服裝我也挺開心的……",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……一直猶豫不決的也不是辦法，就開始動手吧",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "素材不夠用了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n得雇個打工的來幫忙才行。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──幾天後。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哇，謝謝你……",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼你總是在這種時候出現啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好啊，非常樂意！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你以為我會這麼說嗎！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼又是騎士先生啊！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總感覺，遇到困難時都會碰見你……",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n該說是時機正好，還是很不湊巧……算了無所謂了啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，是知道一切的騎士先生來，",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n坦白說我還真是鬆了一口氣呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "下次的演唱會還必須要再準備一套服裝，",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以今天為了這個我們要來捕捉一種會吐出絲線的魔物。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生你幫我拿一下這個。這是我們捕捉魔物用的籠子。",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼我們就出發吧！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "聽好了哦，騎士先生。",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次可不行一個不小心，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就把魔物打倒了哦。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們得使它們吐出製作服裝所需的絲線，然後再將它們放生。",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果靠蠻力討伐，以後就無法再採集到絲線了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "馬上就出現了呢……我們先把那一隻顏色不一樣的給捉起來吧。",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那一隻是母的，只要捉到母的，公的就會前來保護它。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生你用以往使用的力量來輔助我，",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n再幫我看好捉到的魔物，別讓它們逃出籠子外面了。那我上囉！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來囉──！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生！快把籠子打開！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "首先把母的那一隻給捕獲到手！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "身體變得好輕！比以前活動自如也更能使出力來！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天是騎士先生陪我來真是太好了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看我的──！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "公魔物們察覺後都紛紛靠過來了呢！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "趁著這股氣勢多抓一點吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "第二隻！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "第三隻！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n還不夠還不夠～！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還差得遠呢。",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n絲線永遠不嫌多，我們再抓多一點！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咻嚕嚕嚕嚕嚕！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種攻擊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n只要不被擊中就好啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咻嚕嚕嚕嚕嚕！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛才的是陷阱！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔……掙脫不了……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n怎麼會這樣……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚呃！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n絲線、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好緊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再這樣下去的話……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你！我就這個狀態沒關係，",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你就直接拖著我離開這裡吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊痛痛痛痛！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請不要拉我的腳啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的頭！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的頭在地上磨擦啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對不起……不快點的話騎士先生也要被絲線纏住了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就這樣扛著我逃跑吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀啊！你在摸哪裡呀！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你、你是變態嗎！？我說的沒錯吧！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n還是快放我下來吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊──等下等下，騙你的，我開玩笑的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n拜託你別當真了快點逃吧～！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……雖然發生了點事故，",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n能安然無事的捕捉到幾隻也算差強人意吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "被絲線纏住的那一刻，",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我多少能夠感受到騎士先生被束縛住的心情了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒想到居然那麼難受。",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，那個……初次見面時就把你捆綁了起來，真是對不起。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是……我很在意啊。",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為、",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼你要說那種話啊！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我遇上危險的話你會比較難受嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼這個人，要對我這麼好……",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不對。他對怜大人也是一樣的。",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生肯定，對誰都好……一定是這樣的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！我不會再像剛才那樣亂來了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n下次再發生什麼事，騎士先生會再來幫我的對吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些，",
        "unit_id": 105411,
        "voice": "vo_adv_1054005_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是打工的錢！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天謝謝你了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那再見囉！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希不知為何不敢看{player}的臉，\n便在他面前快步離去了。"
    }
]