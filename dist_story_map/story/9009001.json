[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾的鬧區。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可主辦的夏季慶典迎來了大量的人潮。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯♪",
        "unit_id": 105812,
        "voice": "vo_adv_9009001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘭德索爾夏日大祭典！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常成功呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聖誕節有擺攤的攤販這次也有來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我推出的魔物料理專區也很熱鬧呢～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說什麼看起來很開心……",
        "unit_id": 106012,
        "voice": "vo_adv_9009001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也是啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "稀奇的東西總是會吸引人們的目光呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "攤販用的是妳的名字，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n狸貓眼鏡女她沒有阻止嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「只要是陛下的期望，",
        "unit_id": 105913,
        "voice": "vo_adv_9009001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哪怕是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要做些不太合理的投資，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我也會準備超一流的食材和廚師的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦──呵呵呵。」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她是這麼說的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她的眼神有點游移不定。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐",
        "unit_id": 105812,
        "voice": "vo_adv_9009001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常地賣力呢～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "託她的福，活動才能這麼成功，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明年我們還要",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "增加攤販的數量",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和魔物的種類……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開什麼玩笑呀！",
        "unit_id": 106012,
        "voice": "vo_adv_9009001_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是這裡的夏日祭典",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n變成吉歐‧格黑納的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物料理地獄該怎麼辦啊！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那當然",
        "unit_id": 105812,
        "voice": "vo_adv_9009001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是非常歡迎呀！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有多餘脂肪的瘦肉、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "精心製作的刺激香料、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和我們這裡的魔物截然不同的美味……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真想再吃一次呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使在吉歐‧格黑納取得了魔物的肉，",
        "unit_id": 105913,
        "voice": "vo_adv_9009001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對於將肉帶到蘭德索爾時",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的保存狀態不太放心呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出於衛生考量，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而沒有辦法招攬店家前來，實在可惜。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812,
        "voice": "vo_adv_9009001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真希望背面世界的人們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也能夠感受",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種祭典氛圍呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n更加更加地",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "美味、好玩……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想到了一個好主意！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也在吉歐‧格黑納",
        "unit_id": 105812,
        "voice": "vo_adv_9009001_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "舉辦夏日祭典吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有吉歐‧提格尼亞。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可以享受各種世界的料理和遊戲的一大盛事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽起來不是很有趣嗎！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，",
        "unit_id": 106012,
        "voice": "vo_adv_9009001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳打算要怎麼安排",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那樣的大型活動呀。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在那個狸貓眼鏡女已經動不了了吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n光靠我們可是辦不到的喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是主人。",
        "unit_id": 105913,
        "voice": "vo_adv_9009001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很高明的想法。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n既然決定了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們就馬上去詢問大家吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好！",
        "unit_id": 105812,
        "voice": "vo_adv_9009001_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留也要幫忙哦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼那麼！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "三大世界聯合夏日大祭典計畫，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正式展開♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，在貪吃佩可的引領下，聯合了不同世界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n長達兩週的「6.5周年紀念夏日祭典」開始了。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂──！",
        "unit_id": 106012,
        "voice": "vo_adv_9009001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要給我擅自決定啊──！！",
        "unit_id": 106012
    }
]