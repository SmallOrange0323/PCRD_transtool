    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "おや、",
        "unit_id": 105611,
        "voice": "vo_adv_5044431_000"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "今日でバカンスも終わりなのかい。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "まだ来たばかりだと思っていたんだけどねぇ。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ぐぬぬ、",
        "unit_id": 100911,
        "voice": "vo_adv_5044431_001"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "やり足りないことだらけではないか！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "この地に眠る伝説を",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "まだ探し終わっていないのだぞ！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "何言ってんのアンナたそ、",
        "unit_id": 101311,
        "voice": "vo_adv_5044431_002"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "来年また来ればいいでしょ。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "織姫ちゃんたちと会うって約束したんだし。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ね？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "……",
        "unit_id": 100911,
        "voice": "vo_adv_5044431_003"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "確かに、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ナナカの言う通りだな。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ならば仕方あるまい、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "伝説探しは",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "来年の楽しみとしておこう。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "帰る前に買い物しなきゃね！",
        "unit_id": 101311,
        "voice": "vo_adv_5044431_004"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ミツキさんとエリコ様にお土産買わなきゃ",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "絶対怒られるし～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "さぁて、",
        "unit_id": 105611,
        "voice": "vo_adv_5044431_005"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "最後に思いっきり遊んでいこうかね。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "お前さんは",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "何かやり残したことはないかい？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "アタシたちと一緒に、",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "夜まで楽しもうじゃないか！",
        "unit_id": 105611
    }
]