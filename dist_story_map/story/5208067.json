[
    {
        "type": "background",
        "background": "502522"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "時光轉瞬即逝，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在日和於複製品世界度過的最後一夜──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n日和與埃拉就像是要把握住分別前的每一刻，正與對方聊著天。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……埃拉，",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經發現囉。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯？",
        "unit_id": 135511,
        "voice": "vo_adv_5208067_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "自從我",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到這裡來以後，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳一次都沒喝過最喜歡的麥酒對吧？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135511,
        "voice": "vo_adv_5208067_003"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那當然了。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我可不想因為喝了麥酒，",
        "unit_id": 135511,
        "voice": "vo_adv_5208067_004"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n結果",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "把難得跟妳在一起的回憶忘掉啊。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……唔。",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "討、",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "討厭啦，突然說這種話，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n還擺出那麼正經的表情……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會害羞耶……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對、",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了，埃拉……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼說來，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這邊世界的我，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "給人的感覺怎麼樣呀？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳想見見她嗎？",
        "unit_id": 135511,
        "voice": "vo_adv_5208067_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n見見這邊世界的日和。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……！",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嗯，",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想見她。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為我很在意她是不是跟珠姐",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和香織一樣，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "開始向未來邁進了，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有她現在的生活",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幸不幸福。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我──",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是算了。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺不能只因為我想見她",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就跟她見面。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跟我見面……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "搞不好",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會讓她很難受……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以說。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……這樣啊，",
        "unit_id": 135511,
        "voice": "vo_adv_5208067_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我明白了。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我尊重妳日和的想法喔。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "此時有兩個人影，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正待在離那裡有些距離的牆壁另一側。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……那妳是怎麼想的？",
        "unit_id": 1,
        "voice": "vo_adv_5208067_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳之前不是很想跟她說說話嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘿嘿，",
        "unit_id": 1,
        "voice": "vo_adv_5208067_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不用了啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n而且那樣我會很緊張！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……不過，",
        "unit_id": 1,
        "voice": "vo_adv_5208067_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果能和她說上話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我可能會想要謝謝她救了這個世界。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……不過，",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果能和她說上話。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我應該會想跟她道謝吧。",
        "unit_id": 135712,
        "voice": "vo_adv_5208067_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "多虧了這邊世界的我",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "被騎士先生選上，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我才能像這樣遇見埃拉你們。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和與？？？",
        "words": "……我呀，",
        "unit_id": 1,
        "voice": "vo_adv_5208067_019"
    },
    {
        "type": "dialogue",
        "name": "日和與？？？",
        "words": "謝謝妳。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是在隔天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和回去了原本的世界。"
    }
]