        "voice": "vo_adv_1053009_077"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "上一次這麼高興",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是我加入軍隊的時候呢！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要對閣下",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如何表達謝意才好……",
