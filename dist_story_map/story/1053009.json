    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "跟我說她可以相信啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你、",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_056"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你給我說清楚！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n被你蒙混過去就感覺更加可疑了！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "倒不如說很恐怖耶！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……原來如此，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_057"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "歸納了下閣下說的內容，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n雖然她會使用各種各樣過度激烈的手段，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不過作為醫生的實力貨真價實，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是能夠信任的……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果是為了長高，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_058"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "多多少少的風險也在預想之中。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那個魔法藥，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我想要試試看！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……什麼？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_059"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下要幫我去跟她商量？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這真是令人感激的提案！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "拜託你了！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "事情已經搞定了嗎？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_060"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "結果怎麼樣了！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔！",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_061"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你幫我把魔法藥給拿來了嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……她有寄託給你一張",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "紙條？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "讓我瞧瞧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「由於此魔法藥是強制性將骨骼拉長，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_062"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以在幾個月內",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會有渾身痛到打滾以及發高燒的症狀。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "另外",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "副作用是",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有長出第三、四隻手或腳的可能，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以後果請自行負責」。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "………………果、",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_063"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "果然，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_064"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "依賴藥物是不好的呢！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們就老老實實地",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "透過健康的途徑去執行吧！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣莫妮卡和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n嘗試「長高的方法」連續長達數天……"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「喝伊麗莎白牧場的牛奶100瓶」！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_065"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "膽小退縮是不行的。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我要嘗試！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「吃現在引起話題的營養素滿分肉」……",
