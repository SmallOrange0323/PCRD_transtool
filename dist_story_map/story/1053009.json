    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "記得帶上毛毯喔。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從那之後經過了幾天，莫妮卡終於要試著測量身高了。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_068"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "身高沒有長高的話……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "話是這樣說沒錯……",
