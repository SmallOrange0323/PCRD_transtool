    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "努力不懈地嘗試長高。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n然後……",
