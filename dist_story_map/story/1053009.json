    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真的能吃嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_067"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「向流星祈禱的作戰」",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "決定要在今晚要執行。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們在那間山中小屋集合。",
