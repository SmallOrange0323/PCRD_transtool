        "voice": "vo_adv_1053009_074"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還能再成長的意思囉！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "{player}……！！",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_075"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……喂、",
