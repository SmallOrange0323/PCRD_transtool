        "voice": "vo_adv_1053009_078"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要高興還太早了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我還沒有",
