[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}發現了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "邊哼歌邊小跳步的嬌小軍人背影。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼──♪",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗚哇！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下你在啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該不會剛才的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "樣子被你看到了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你說看到什麼……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好意思讓我說出口啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是什麼人！",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……原來",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是閣下啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "幸好沒有把你丟飛出去。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你不想受傷的話，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就不應該隨意觸碰軍人的後背。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊哈哈哈！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……你，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個大笨蛋！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在碰哪裡啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n搔軍人癢這種事，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是閣下的話我差點就砍下去了！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你問我為什麼看起來那麼開心……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……別笑我喔？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今天早上，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我自主量了身高……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "結果長高了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我的長高了！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……喂！",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "幹嘛那樣盯著我！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是覺得很難以置信嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先聲明，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我沒有騙人喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我確實",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "長了那麼一點點……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "長了跟豆子大小差不多的高度！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不對，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "說豆子太過頭了嗎。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n大概是米粒大小……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咦！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要我再測量一次看看！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我拒絕！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果只是我多心，那不是很讓人洩氣嗎！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "喂──！",
        "unit_id": 111,
        "voice": "vo_adv_1053009_010"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "莫妮卡隊長──！",
        "unit_id": 211,
        "voice": "vo_adv_1053009_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……唔？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是你們啊！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "向閣下介紹一下兩位。",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我和他們",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是在森林裡認識的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那之後，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我便以朋友的身分",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "和他們交往甚密。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "我跟你說、",
        "unit_id": 211,
        "voice": "vo_adv_1053009_014"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "我跟你說，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n我們在逃離魔物的時候，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "是莫妮卡隊長救了我們的！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "她用好大一把劍",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "一瞬間把魔物給打倒了哦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "莫妮卡隊長",
        "unit_id": 111,
        "voice": "vo_adv_1053009_015"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "她很帥氣吧～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "雖然看起來這～麼小！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "嗯，",
        "unit_id": 211,
        "voice": "vo_adv_1053009_016"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "她超級強的！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "雖然看起來這～麼小！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別說我小啦！！",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該說小孩子是天真呢，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還是老實呢……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你們今天",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有什麼事情嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n想要我再指導練劍嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "嘿嘿！",
        "unit_id": 111,
        "voice": "vo_adv_1053009_019"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "今天要向莫妮卡隊長",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "「報告」",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "一件事。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n其實我們，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "長高了喔！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n前陣子不是才報告過一樣的事嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "嗯，",
        "unit_id": 111,
        "voice": "vo_adv_1053009_021"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "前陣子也有長高，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "但這次好像又長了。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "伊緒老師說過",
        "unit_id": 211,
        "voice": "vo_adv_1053009_022"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "「小孩子都",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "成長得好快呢──♪」。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "更重要的是，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "我們長大了的話，妳會答應讓我們當妳的部下對吧！？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我說的「長大」的意思",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是指身體，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是指年齡方面才對……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是羨慕到不行啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不管什麼豆子還米粒的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果個子再長高一點",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我就能雪恥了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……也對，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這話題並非和{player}你沒有關係。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你還記得嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "以前曾經舉辦過的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那場決鬥大賽。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也為了參賽",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_026"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "和閣下進行了反覆的訓練，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但他們卻說140公分以下的人不能參加，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "連出賽都沒能如願……",
