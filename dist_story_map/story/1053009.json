        "voice": "vo_adv_1053009_069"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我知道了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n幫我量吧……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以……",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_070"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼樣？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……這樣啊，",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_071"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我的身高令人吃驚地完全沒長半點啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n雖然早就知道這種事，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但還是……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053009_072"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
