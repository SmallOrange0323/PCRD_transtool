    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]如果是在他戰力增加後的狀態下跟他對峙，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n[FFFFFFFF]我們也不曉得會變得怎樣。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]確實，",
        "unit_id": 125511,
        "voice": "vo_adv_5118402_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]雖然我覺得會陷入苦戰……",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]但一定會有辦法的喔。",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]因為……",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我們並不是孤身一人嘛。",
