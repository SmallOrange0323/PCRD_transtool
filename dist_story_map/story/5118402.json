        "voice": "vo_adv_5118402_002"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]對他而言一定就是烏～托邦呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]無論如何，",
