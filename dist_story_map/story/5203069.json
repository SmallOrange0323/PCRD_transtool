[
    {
        "type": "still",
        "still": "520306201"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "波波爺爺的",
        "unit_id": 9212,
        "voice": "vo_adv_5203069_000"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「克蘿茜大解密」",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "要開始啦～！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n把老夫解析的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "古代兵器",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "巨型軀體的詳細資訊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n用大家都能懂的方式",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "慢～慢仔細地講解給大家聽喔。",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "520306901"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這次要講解的是，",
        "unit_id": 9212,
        "voice": "vo_adv_5203069_001"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「巨型尾巴鑽頭」。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n正如其名，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "是以尾巴模樣長出來的鑽頭。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n很可愛吧？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的♪",
        "unit_id": 134511,
        "voice": "vo_adv_5203069_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "像動物一樣非常可愛。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "講解結束。",
        "unit_id": 9212,
        "voice": "vo_adv_5203069_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……咦？",
        "unit_id": 134612,
        "voice": "vo_adv_5203069_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就這樣？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "本來是好像是尾巴末端──",
        "unit_id": 9212,
        "voice": "vo_adv_5203069_005"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "鑽頭部分能夠張開，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n裡面有能夠連接及駭入機器的機械手臂",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n的樣子……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "──但這個世界",
        "unit_id": 9212,
        "voice": "vo_adv_5203069_006"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "幾乎沒有機器對吧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n沒有比講解沒用處的功能",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "還要空虛的事了……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "碧、克蘿茜",
        "words": "啊……",
        "unit_id": 1,
        "voice": "vo_adv_5203069_007"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "因為",
        "unit_id": 9212,
        "voice": "vo_adv_5203069_008"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "有像手指般精密的功能，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n作為鑽頭的耐久度也不怎麼樣……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "基本上",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就只是裝飾。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "雖然也稱不上是完全沒用。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "裝飾…………",
        "unit_id": 134612,
        "voice": "vo_adv_5203069_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "試著想做到所有事，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n結果卻變成",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "泛而不精這點簡直就是我呢……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "毫無",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "實用性……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "壁花……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哈、哈哈……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚、嗚嗚……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我",
        "unit_id": 134511,
        "voice": "vo_adv_5203069_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "很喜歡，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n是很可愛的裝飾呢♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克蘿茜小姐……！",
        "unit_id": 134612,
        "voice": "vo_adv_5203069_011"
    },
    {
        "type": "still",
        "still": "end"
    }
]