[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在店鋪前，紡希受到路過的粉絲的招呼。"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "紡希！",
        "unit_id": 211,
        "voice": "vo_adv_1054007_000"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我很期待你的個人演唱會哦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "非常謝謝妳！我會加油的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n個人演唱會嗎……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小望那傢伙～！又在擅自為我計劃安排個人演唱會了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "甚至還額外準備了一首新曲……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說到底我原本應該只是作為小望和千歌的贈品附帶上去的說……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只有我一個人的演唱會，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的會有觀眾來嗎……？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就只有我一個人",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "站在舞台上，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好沒有真實感……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而且完全無法想像。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊～到底該怎麼辦才好……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哎……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哎……這不是騎士先生嗎！？幹嘛突然出現啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、我偶爾也是會嘆氣的好嗎！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我又不是騎士先生你那樣輕鬆爽快的人！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒有生氣！我是在煩惱！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "抱歉突然吼出聲來……你好啊，騎士先生。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "露出一臉不開心的表情是不行的呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次我真的不知道該怎麼辦才好了啦～……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊──真是的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n都是騎士先生啦讓我又更加焦慮起來了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊不過，這也不是和騎士先生商量就能解決的煩惱，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你不用管我也沒關係。這是我個人的問題。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "其實，下一次我必需要舉辦個人演唱會了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不用來也沒關係！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n已經要走囉！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說是這麼說，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對那個人……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那種歌詞的歌，我根本無法在騎士先生面前唱出來，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n並不想在演唱會上看到他來……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n現在要是騎士先生對我這麼好，我……絕對會太依賴他的……",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──當天晚上。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總算結束第二次的總彩了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好累啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "稍微休息一下吧……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哎……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "歌唱和舞步都沒有問題……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "新曲歌詞……是小望寫的呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "無法坦白的女孩，想傳達出自己感情的歌……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這和我一模一樣嘛……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n小望對我，已經看透到什麼程度了啊……？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣不就是在說我和騎士先生之間的事了嗎……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不不，那種事情……可是……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還不是因為，騎士先生有怜大人了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不對啊！現在應該集中精力在演唱會上！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且這首曲子，是給怜大人和粉絲們的情歌啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒錯！這首歌是要把對大家的心聲唱出來的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以，這並不是給特定對象的歌……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦……？",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有人往這裡來了……？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼你總是突然出現啊！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我說突然就是突然！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對我來說就是很突然啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難道騎士先生，你在跟蹤我嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你可別這樣做哦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難不成你對我以外的女孩子也是這樣嗎……！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊真討厭！真是的你就是這樣……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這個人……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的是……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生。可以，稍微請你聽我說幾句話嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說起來，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "之前的時候，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也請你聽我說了幾句話呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那時，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我從來沒想過將來會辦什麼個人演唱會……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也並不打算中途就把偶像事業給放棄掉。",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我想盡我所能的努力。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……比起讓自己閃耀，我更喜歡的是讓其他人閃耀的樣子。",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而我自己，就只打算做好自己的本份。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就在想，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這樣的我真的有需要辦什麼個人活動的必要嗎……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "粉絲嗎……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……話說回來，之前一起逮捕的那個人，就是我的粉絲呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我很訝異，我居然真的擁有自己的粉絲呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你知道嗎？有人替我加油打氣，意外的感覺挺不錯的喔？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有這麼一群人，就算只有一些人……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n只要有一點點會為我加油打氣的人在……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我，或許就能更加努力了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯既然都拼命收集素材把服裝給做出來了？",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不穿上去就太可惜了嘛。而且──",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算舞沒有小望跳得好，歌也沒有千歌來得會唱……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我希望能夠盡量離那兩個人更近一點，不管是舞蹈動作或是歌曲，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也希望能跟她們站在同樣的高度說話。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "即使再怎麼辛苦，也是現在的我必須去做的事情，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n如果人們穿上我親手做的衣服後能散發出最燿眼的光芒，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那我就必須達成！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我，也有想要讓他閃耀光芒的人在……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也有人喜歡閃耀光芒的我……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──若能讓穿上我作的衣服的人能散發出最燿眼的光芒，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就只有拼命去做好了對吧……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就算那個人正是我自己……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "若是為了這些事情，我……無論如何也要加油！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總感覺自己振作起來了呢！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好～！個人演唱會，絕對要成功！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哼，看見我恢復原來的狀態很高興了嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣你就滿意了吧？所以你不用來看演唱會也沒關係的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……如果當天覺得很閒，無聊到感覺快死掉了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n完全沒有事情做的話，再來看吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "演唱會當天……"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今日的演唱會……雖然只有我一個人，但我一定會成功給你們看的！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我上了喔──！",
        "unit_id": 105412
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "各位──！今天非常感謝你們來到我的個人演唱會！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_055"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我會非常努力加油的，請各位好好期待吧！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "紡希──！",
        "voice": "vo_adv_1054007_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好熱烈的歡呼聲……還有，粉絲們的笑容……！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就如騎士先生所說的，有這些人在，我──定要加油！",
        "unit_id": 105412
    },
    {
        "type": "still",
        "still": "105400701"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼首先是第一首歌，請各位欣賞……這是我的新歌！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_058"
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "Foooo～！！",
        "voice": "vo_adv_1054007_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總而言之就是全力地歌唱，舞蹈，全力以赴！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然不知道能做到什麼程度，反正就是竭盡全力！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "將我內心的感情……傳達給「你」！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以……請好好聆聽我的聲音！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_063"
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "唔喔喔喔喔喔喔！",
        "voice": "vo_adv_1054007_064"
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "紡希――！！！",
        "voice": "vo_adv_1054007_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些人，大家都是我的粉絲，都為了我這麼開心……",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生，就和你說的一樣呢……我，有努力真是太好了！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們還要讓氣氛更加熱烈哦～！",
        "unit_id": 105412,
        "voice": "vo_adv_1054007_067"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "大家也要",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "盡全力跟上來哦──！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "耶～！！！",
        "unit_id": 1,
        "voice": "vo_adv_1054007_068"
    },
    {
        "type": "still",
