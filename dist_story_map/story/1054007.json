    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "辛苦你們了──！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_069"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "妳也辛苦了──！",
        "unit_id": 311,
        "voice": "vo_adv_1054007_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊──累死我了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_071"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生！？埋伏偶像可是NG行為喔！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "開玩笑的。你有來看我的演唱會呢。謝謝你。",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_073"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天的演唱會，你覺得……怎麼樣？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "新歌，大家都很喜歡我就放心了。",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_074"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生你也覺得是一首不錯的曲子吧？這首曲子的歌詞──",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──不，算了沒事！請你還是什麼都別說吧！",
        "unit_id": 105411,
        "voice": "vo_adv_1054007_075"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，騎士先生的感想一定很無聊，感覺一點也不有趣啦！",
