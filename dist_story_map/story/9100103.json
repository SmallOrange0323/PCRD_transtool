[
    {
        "type": "background",
        "background": "501630"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦……！",
        "unit_id": 101112,
        "voice": "vo_adv_9100103_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "黑之王！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "牠竟然復活了……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個彌勒還是勒彌什麼的，",
        "unit_id": 106611,
        "voice": "vo_adv_9100103_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n未免太多管閒事了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然如此，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我就再次把牠打得落花流水！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼？",
        "unit_id": 106511,
        "voice": "vo_adv_9100103_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你們",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "曾和那傢伙對戰過嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "希望之力……？",
        "unit_id": 104911,
        "voice": "vo_adv_9100103_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是什麼意思？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "黑之王的弱點",
        "unit_id": 101112,
        "voice": "vo_adv_9100103_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "正是我們心中所懷抱的希望。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那時，大家將希望全都灌注到我的弓箭上，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n用這種方式打倒牠。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 101112,
        "voice": "vo_adv_9100103_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們是在繪本故事中",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "使用這股力量的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在這邊的世界能不能比照運用，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "老實說，我不知道……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唔……",
        "unit_id": 105511,
        "voice": "vo_adv_9100103_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說得也是……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n繪本與現實是不一樣的……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的！",
        "unit_id": 106611,
        "voice": "vo_adv_9100103_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳們兩個",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在那邊碎念些什麼啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然之前曾用這種方式打倒過牠，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總之我們就先試試看啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n好啦，各位。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如果大家都明白的話，那就快心懷希望吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳說希望嗎～",
        "unit_id": 104911,
        "voice": "vo_adv_9100103_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這包在我身上♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今後還有很多事想和弟弟一起做呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n像是一起約會啦～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一起泡澡",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一起耍懶啦～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有很多很多喔～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊！",
        "unit_id": 101112,
        "voice": "vo_adv_9100103_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐太狡猾了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我可沒有說",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要捨棄這些希望喔！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等生活恢復平靜，我要叫哥哥多陪我一點！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "向姐姐撒嬌的前輩，",
        "unit_id": 105511,
        "voice": "vo_adv_9100103_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還有照顧妹妹的前輩……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為了當作",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "日後的參考，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我想我也再多觀察一下好了……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔哇……",
        "unit_id": 106511,
        "voice": "vo_adv_9100103_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看來你",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還真辛苦……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n下次我請你吃頓飯吧……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵。",
        "unit_id": 106611,
        "voice": "vo_adv_9100103_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "大家都很順利地懷抱起希望！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼，就將這些希望化為力量，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n用來打倒黑之王吧──！",
        "unit_id": 106611
    }
]