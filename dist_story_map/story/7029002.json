    {
        "type": "dialogue",
        "name": "旁白",
        "words": "帆稀走在前頭，在塔中一面調查，一面前進。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說，",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們在趕時間吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那麼",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "悠哉地慢慢走",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不要緊嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦？",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哦哦，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也不是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "現在就要立刻想辦法解決，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以放心吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n只是，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一旦開始等待某天可能會到來的機會，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n或許那個時刻就一輩子",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都不會到來了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為在我看見的未來裡，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就連這座塔曾經存在的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "痕跡也都消失了呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有痕跡就表示",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這座塔會消失吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐看見的未來是……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "答對了☆",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖說是未來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但終究只是模擬場景……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也就是「如果",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就這樣什麼都不做，或許就會變成那樣」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "的一種",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "預測。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但也有可能",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只是關於這座塔的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "情報太少，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就算用時間儀",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也沒辦法模擬出來……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或者也有可能",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是我輸入的情報有誤。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過你們想想，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然是期間限定，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是就該趕快行動嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n畢竟說不定",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也有可能會發生無法挽回的事情。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不需要那麼害怕哦～♪",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n抱歉呢，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一不小心就說了像威脅般的話。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這也算是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "職業病啊。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣啊，",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐的工作",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是幫派老大吧……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳果然",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "平時",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就會",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "威脅別人嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊哈♪",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "放心吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我是會挑對象的～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "究竟是因為從事那種職業才會變成這樣，",
        "unit_id": 106711
