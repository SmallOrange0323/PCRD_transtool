        "type": "dialogue",
        "name": "雪菲",
        "words": "這個嘛……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也不是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不覺得",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那回事……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲？",
