    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會變成這樣一定是理所當然的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊哈哈，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這我倒是不否認呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n畢竟",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "維持現在這樣我一直都很開心。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n【龍族巢穴】的活動也是如此。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然會抱怨，但都會跟著我來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嘉夜",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也有充滿幹勁的一面，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我知道她都會特地配合我的主意。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她們兩人",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都是非常溫柔的孩子哦。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "正因為如此，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我才能像這樣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "扮演有點使壞的角色。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳為什麼沒找她們一起來呢？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳帶我來的理由",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難不成",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是為了像這樣挖角？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是因為啊。",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "已經有人",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "帶那兩個孩子來過",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這裡了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就像我剛才說過的，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要來到這裡",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就必須有他同行才可以。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n而且每次",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要帶不同的成員一起來。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不同的成員……",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n也就是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "同一個人沒辦法來好幾次",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的意思？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哦，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真敏銳呢～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可能",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "除了他以外的人都是這樣吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這其中應該有某種意義……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "比如說，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n明明塔裡還有路，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但是不更換成員就會無法前進",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "之類的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以我才覺得",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一次都沒來過這裡的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我和雪菲，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n一起來應該會",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "比較好。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "以不同的成員來這裡好幾次。",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_030"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這一點",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許和這座塔的祕密",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有關聯呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳知道他開始往返這座塔……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是因為什麼理由嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_032"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我記得",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是為了找回失去的記憶，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對吧？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "聽他說",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在那時會看見某種像夢一樣",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的情景。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯。",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你有真正",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在這座塔找回記憶嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n看見那邊……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看見夢中世界後，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你有想起什麼嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "說起來，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "關於那些記憶的事，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你知道是聽誰說的嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想也是～",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_035"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然如此……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣想想看如何？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以找回記憶是個謊言，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實還另有其他",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真正的目的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等一下，",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_036"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那我們",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不就變成",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "眼睜睜被騙來",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這裡了？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不會很危險嗎！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒事沒事，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲，妳先冷靜下來。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然的確會出現魔物，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但我認為",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來到這裡本身",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "並不危險。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不如說，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是非來不可。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "尤其是妳哦，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我嗎？",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_039"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為──",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳和其他孩子不同，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_041"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒有「回去過一次」。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！",
        "unit_id": 106411,
        "voice": "vo_adv_7029002_042"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──這座塔真正的目的，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是讓我們也看見那些夢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我認為這麼想",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或許會比較貼切",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以現在這個狀況可能沒辦法完全理解……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但在這個世界和那邊……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也就是夢中世界相比，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n有許多孩子的境遇",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "並不相同。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果是類似的境遇，",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要替換一定程度的記憶就能解決，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但如果是完全不同的情況，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就必須用更大的謊言",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓事情變得合理。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
