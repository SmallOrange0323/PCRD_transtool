        "type": "dialogue",
        "name": "帆稀",
        "words": "對了對了。",
        "unit_id": 106711,
        "voice": "vo_adv_7029002_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你覺得是哪一種？",
