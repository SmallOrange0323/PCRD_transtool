    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──咲戀育幼院的中午。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n大家全都外出時，綾音則是躺在床上休息。"
