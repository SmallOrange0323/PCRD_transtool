[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在拉姆們暫時居住的咲戀育幼院裡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "身為育幼院女僕的鈴莓，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n似乎正在拜託拉姆一些事情。"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "女僕指導……",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_000"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "為什麼拉姆得去做這種事呢？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的……",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳或許隱約有察覺到……",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n其實我，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很冒失。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這件事大家都知道。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這跟要拉姆做女僕指導有什麼關聯嗎。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為雷姆小姐她總是在說。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n姊姊是自己的理想，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有比姊姊更棒的女僕了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "既然那麼厲害的女僕雷姆小姐都那麼說了，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那我想拉姆小姐肯定是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "女僕的頂點。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "女僕界的傳奇！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以說，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "拉姆小姐……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不對，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "拉姆師傅！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請對我，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "進行不再冒失的女僕指導吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "拜託了～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……事情我了解了。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_009"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "確實就如雷姆所說的。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_010"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆是個超級優秀的女僕。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但是很遺憾。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_011"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆現在非常地忙碌。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "實在是沒空照顧鈴莓妳。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是、",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是這樣嗎……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "本來還以為大小姐帶著小孩子們出去的這個時候！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是個好機會的說……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣啊……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是啊。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……雖然妳這麼說，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但卻是穩穩地坐在椅子上，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n悠閒地喝著……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "紅茶，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對吧……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "鈴莓，",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_015"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "休息也是重要的工作之一。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果不好好休息，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "在關鍵時刻會派不上用場。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "隨時準備應對緊急狀況是女僕的職責。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "啊啊，真是忙碌。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚嗚……",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "拉姆小姐～～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "求求妳了～～！",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "再這樣下去會失去當一個女僕的資格！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n今天早上煎荷包蛋時",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還把油給打翻了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "剛才我的頭，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "去撞到了餐具櫃的角落，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "幸好只是腫一個包而已，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還打破了小孩子們的馬克杯，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "然後明明幫大小姐泡的是紅茶",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但卻有咖啡的味道～～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "到底怎麼做才會發生那種事。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_020"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆實在難以理解。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也不知道啊……",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n明明我都有按部就班地，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "照著步驟來做。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一回過神來",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就會發生爆炸",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "或是損壞。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我到底該怎麼辦才好……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "──因為你站著完全不說話，拉姆還以為你睡著了，",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_022"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n原來只是在發呆啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你希望拉姆幫一下鈴莓？",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_023"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你以為你是誰啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "停止那種哀求的眼神吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_024"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你以為拉姆會屈服在這種威脅之下嗎……",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_025"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……真是的。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_026"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "茶都變難喝了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果不管如何都希望拉姆指導的話也不是不可以。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_027"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但是，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆可是很嚴格的哦。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n無論妳身陷什麼狀況拉姆都絕對不會幫忙。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真、",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的可以嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果這樣妳能接受的話就做好心理準備吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098006_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "非、",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "非常感謝妳～～～～！！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我從現在開始來打掃房間！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果有什麼在意的事，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請盡量跟我說吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "拉姆師傅，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "拜託妳了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿咻……",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿咻……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然是很平常的打掃，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但只要一想到師傅正在看著，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就會特別有幹勁呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總覺得，",
        "unit_id": 102511,
        "voice": "vo_adv_1098006_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能做得比往常還要更好。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很好，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要加油囉～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "──呀啊啊啊啊啊啊！",
        "unit_id": 102511,
