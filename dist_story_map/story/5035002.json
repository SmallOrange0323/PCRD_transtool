        "voice": "vo_adv_5035002_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否沒問題呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不僅在馬車中要練習唱歌，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "入夜後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還得練習舞蹈的動作，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n練習直到深夜……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個嘛，",
        "unit_id": 106012,
        "voice": "vo_adv_5035002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "體力方面的話應該沒問題吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她們至今都是以冒險者的身分活動，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正因為這樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺也多少能夠應戰呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然問題，",
        "unit_id": 105913,
        "voice": "vo_adv_5035002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是在於準備的時間不夠充裕呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n抵達繆思小鎮之際，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "約莫是甄選大會的前一兩天……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幾乎可說是毫無事前準備直接正式上陣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是呢。",
        "unit_id": 106012,
        "voice": "vo_adv_5035002_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這點小事她們自己也最清楚了吧。",
