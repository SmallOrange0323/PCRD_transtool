        "voice": "vo_adv_5035002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "願意借給在下等人馬車，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此至今的旅程",
        "unit_id": 105913
