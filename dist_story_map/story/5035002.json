        "voice": "vo_adv_5035002_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天的晚餐是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "香脆炸格里芬！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "焗烤奶香岩窟蝸牛唷～☆",
