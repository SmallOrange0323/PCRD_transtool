        "words": "啊啊，",
        "unit_id": 104311,
        "voice": "vo_adv_5012606_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來如此。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然是這麼回事，那我就試試看吧！！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是這個幹勁。",
