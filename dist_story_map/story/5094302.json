[
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還、",
        "unit_id": 122111,
        "voice": "vo_adv_5094302_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還想說終於找到了……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但那個魔物，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "已經完全恢復精神了呢……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "倒不如說，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "牠好像比剛才還要活蹦亂跳呀……？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "牠的恢復能力比預想中還要強呢。",
        "unit_id": 104715,
        "voice": "vo_adv_5094302_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n又或者是……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為這邊是牠的地盤，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓牠能徹底發揮出原本的力量。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "無論如何，",
        "unit_id": 122211,
        "voice": "vo_adv_5094302_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都還是得打倒牠。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "認命吧，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你這冒牌阿斯特賴亞菇！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n讓我來徹底教教你，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "下酒菜的怨念有多麼可怕！",
        "unit_id": 122211
    }
]