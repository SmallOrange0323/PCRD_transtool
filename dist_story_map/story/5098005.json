        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n昨日、",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "向栞姐姐借的那些……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是專業書籍",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "來著？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n妳已經看過了嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "都看過了。",
        "unit_id": 103611,
        "voice": "vo_adv_5098005_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "有什麼發現嗎？",
        "unit_id": 102012,
        "voice": "vo_adv_5098005_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……「喚來幸福的生物」是",
        "unit_id": 103611,
        "voice": "vo_adv_5098005_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "來自另一個世界的存在。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "當牠耗盡力量之後…………",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "…………",
        "unit_id": 103611,
        "voice": "vo_adv_5098005_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……據說會",
        "unit_id": 103611,
        "voice": "vo_adv_5098005_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "從這個世界上消失。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊＆美美",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_5098005_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……意思是說牠會死掉？",
        "unit_id": 100411,
        "voice": "vo_adv_5098005_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "或許是，",
        "unit_id": 103611,
        "voice": "vo_adv_5098005_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "或許不是。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過變虛弱後",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "結果會消失，似乎是確定的。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總之只要不使用力量，",
        "unit_id": 103611,
        "voice": "vo_adv_5098005_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "暫時就不要緊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但那樣只是應付一時，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "並非解決的方法。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要解決問題……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……只能將小繆送回",
        "unit_id": 102012,
        "voice": "vo_adv_5098005_014"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "牠原本所在的世界？",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……嗯。",
        "unit_id": 103611,
        "voice": "vo_adv_5098005_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那麼一來牠應該不會消失，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "能夠一直健健康康的。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是栞姐姐說過的方法呢。",
        "unit_id": 100411,
        "voice": "vo_adv_5098005_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不管怎樣，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們都要和小繆…………",
