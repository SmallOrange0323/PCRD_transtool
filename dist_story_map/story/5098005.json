    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當【小小甜心】的三人在調查小繆回去的時刻之際……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}回想起拉比林斯達前幾天意味深長的態度，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n獨自前往可麗餅店……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}看著「臨時歇業」的招牌……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n發現招牌背面貼著一張紙。"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "「致少年。",
        "unit_id": 1,
        "voice": "vo_adv_5098005_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "\n我突然有點私事要辦，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "會離開蘭德索爾幾天。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "\n如果你想念我的可麗餅",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "而跑來見我，那抱歉喔。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "「如果",
        "unit_id": 1,
        "voice": "vo_adv_5098005_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "你是來找我商量那個玩偶的事情，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "\n那什麼也不必擔心。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "「只要那些孩子們",
        "unit_id": 1,
        "voice": "vo_adv_5098005_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "能度過一個開心的夏天就沒問題了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達的留言",
        "words": "\n只要這樣就可以了。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}看完拉比林斯達的留言後，"
    },
