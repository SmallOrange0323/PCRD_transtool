        "words": "好像",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "姑且成功打倒一隻了！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是……",
        "unit_id": 105911,
        "voice": "vo_adv_0000425_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "它們仍然在繼續送魔力給",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n霸瞳皇帝的樣子……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵呵……！",
        "unit_id": 106915,
        "voice": "vo_adv_0000425_002"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我不是說了嗎？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那些魔物不過就只是用魔力做出來的傀儡！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n要它們捲土重來多少次都行！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是，",
        "unit_id": 102811,
        "voice": "vo_adv_0000425_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺它們好像有稍微被削弱一些了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看來是場拉鋸戰！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家，",
        "unit_id": 105811,
        "voice": "vo_adv_0000425_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拜託了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511,
        "voice": "vo_adv_0000425_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會努力打掃的～……！",
        "unit_id": 102511
    }
