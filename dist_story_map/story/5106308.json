[
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼啊……",
        "unit_id": 124111,
        "voice": "vo_adv_5106308_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼啊……！",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那傢伙……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好難搞……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我們這種新手天使",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是不是打不贏啊……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "確實……",
        "unit_id": 124011,
        "voice": "vo_adv_5106308_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n仔細想想，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們是超超級新手的天使呢……",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚嗚，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好像失去信心了。",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呼……",
        "unit_id": 124213,
        "voice": "vo_adv_5106308_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呼……",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳們說什麼啊？",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓艾米和拉菲成為更成熟的天使的人，",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不是別人，",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是妳們吧？　",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對自己有點信心，",
        "unit_id": 124213,
        "voice": "vo_adv_5106308_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳們已經是名副其實的",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "厲害天使了。",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "純小姐……",
        "unit_id": 124111,
        "voice": "vo_adv_5106308_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "天使的任務是什麼呢？",
        "unit_id": 124213,
        "voice": "vo_adv_5106308_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "天使的",
        "unit_id": 124011,
        "voice": "vo_adv_5106308_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "任務……？",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那就是……",
        "unit_id": 124111,
        "voice": "vo_adv_5106308_007"
    },
    {
        "type": "dialogue",
        "name": "依里、茜里",
        "words": "讓人們幸福……！",
        "unit_id": 1,
        "voice": "vo_adv_5106308_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對。",
        "unit_id": 124213,
        "voice": "vo_adv_5106308_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n任務只差一步就完成了啊。",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n──來吧，",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為了蘭德索爾的人們，",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "找回幸福的聖誕節吧！",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "依里、茜里",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_5106308_010"
    },
    {
        "type": "dialogue",
        "name": "依里、茜里",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "依里、茜里",
        "words": "──好！",
        "unit_id": 1
    }
]