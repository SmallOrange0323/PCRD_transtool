        "voice": "vo_adv_3001001_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，是白天昏倒的那個人！",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳沒事嗎？都還好嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不管是貧血還是怎樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃白飯的話就可以解決了喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請用請用～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為、為什麼這麼強勢呢？",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……雖然不太想和這個人接觸，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看來是沒辦法吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，不要把菜推過來啦！？",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "超好吃的唷～？",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快吃快吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來，",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我中午的時候也讓妳請了飯吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是剛好，現在就讓我回禮吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯哼。",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是這家店辦的大胃王比賽的優勝者喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "I am a CHAMPION……☆ ",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後我就拿到了獎金，就由我請你們吃飯吧！ ",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請不要客氣，大家都點自己喜歡的東西吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也要加點～！",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這菜單上的菜，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從上到下我全部都要☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還、還吃得下啊……",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原本擺在那邊滿滿一盤的料理山，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才剛剛被吃完而已。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "佩可小姐的胃是破了洞嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論如何。",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛好在下等人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也正為了今晚的晚餐煩惱……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是遇到了救星，",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請容許在下等人來沾點光。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐也一起來吧……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……啊～嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_053"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是沒辦法了，一不作二不休啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯☆",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不管是毒還是盤子統統都吃掉，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃到飽為止吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快過來，",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看是要坐我的腿上還是坐哪裡都可以♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快點～不然飯菜都要涼了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來吧來吧，盡情享用吧！",
