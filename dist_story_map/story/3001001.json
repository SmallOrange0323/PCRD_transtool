[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼。",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算是確保住宿地點了，",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下想接下來是要填飽肚子……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，您認為怎麼辦才好？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下畢竟不習慣都會的生態，",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒辦法決定接下來何去何從。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n作為『嚮導』，在下真是失責呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然白天的時候有優衣小姐準備餐食，",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還算過得去。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每天、每餐……都讓人家安排實在過意不去。",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人必須能夠取得當日糧食才行。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～。",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看是要自己取得食材自己料理，還是要在哪裡外食……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n目前在下想到了這些選項。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天發生了好多事，已經身心俱疲了。",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想趕快隨便找家店外食。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該選哪家店呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來這附近",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是一個有許多餐飲店的區域。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，您有沒有想吃的東西呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人正看著其他地方呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，您有看中的店家嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹嘛，看什麼看？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，在下還以為是誰呢。",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您好。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問身體還好嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n突然這樣，幹嘛呀。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們是誰啊！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……說來，您之前一直都處於昏倒的狀態，",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下都還沒能跟您打招呼呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這位是，{player}大人。\n在下，叫做可可蘿。",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這名字……",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，我想起來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽說是你們把昏倒的我送到醫院。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該要跟你們道謝的。謝謝了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哪裡哪裡……愛梅斯小姐教導在下，",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有困難就要互相幫助。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看到您沒事就好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……怎麼了嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事。",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對不起，一直盯著妳看。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（嗯，就是這些人嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": " 真的就是『陛下』口中所說的厲害的傢伙嗎？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（怎麼辦呢……  ",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然我被指示暫時先別動手。）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（我也被命令要監視他們。  ",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然已經有接觸了，也沒辦法就此不管了吧？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我好像還是有點不舒服，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不小心就恍神啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不曉得為什麼你好像知道名字了……",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過我還是再報上名一次吧，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我叫做凱留。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然是段不可思議的緣分，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但以後也請多指教。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請多多指教。",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思，這樣問可能有點冒昧……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問凱留小姐熟悉這附近嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人今天的晚餐，",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想在感覺不錯的店家享用。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若有推薦的店家，希望您能介紹給在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都受了你們的照顧，這點小事沒什麼。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但是對不起，我也很少離開住處。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n對什麼店家完全不熟呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "隨便找一家人多的店的話，應該就不會踩到雷吧？",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以的話，晚餐就由我來請你們吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣就誰也不欠誰了♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人多的店，像那家店嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_3001001_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是，我看到的是……？",
        "unit_id": 106012
    },
    {
        "type": "still",
        "still": "300100101"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼嚼嚼♪",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，好～吃♪",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n活過來了！白飯是生命的能量啊……☆",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "300100102"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀？",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這個聲音是，佩可小姐？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n叫我貪吃佩可的是……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃，等我一下！",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我先把眼前的食物山塞進胃裡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n清理出視野！",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "300100103"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼嚼♪",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，果然是白天的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "阿囉哈……？",
        "unit_id": 105913,
        "voice": "vo_adv_3001001_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下每次看到您，您都在吃東西呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈哈，因為我肚子很快就餓了！",
        "unit_id": 105812,
        "voice": "vo_adv_3001001_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？",
        "unit_id": 105812
    },
