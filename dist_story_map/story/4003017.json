        "voice": "vo_adv_4003017_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "第八次……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【美食殿堂】……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃遍",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之旅……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這片沙漠",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底有多廣闊啊……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳看",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那裡！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……那是",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "通往長著傳說中的仙人掌的",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "縱穴的入口嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n據說那條通道一直延伸到地底……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像是。",
        "unit_id": 105911,
        "voice": "vo_adv_4003017_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n跟凱留小姐從花凜小姐那裡打聽到的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n特徵一致。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "究竟是什麼樣的仙人掌呢～？",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n既然是「傳說」等級的……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會不會是超～級巨大的呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳有問到什麼嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 106011,
        "voice": "vo_adv_4003017_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽說裡頭好像充滿了甘甜蜜汁、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果肉也鮮美多汁、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還能加工製作成秘藥、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "具有驚人的美肌效果之類的……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那外觀是什麼樣的呢？",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n有沒有什麼特徵是我們也能辨識的？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像是一種圓圓的、",
        "unit_id": 106011,
        "voice": "vo_adv_4003017_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有長刺的仙人掌。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n用那個來辨識應該就行了吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此～",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留問得還真詳細呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太可靠了～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之前妳明明那麼討厭吃遍之旅的，",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在竟然主動幫我們帶回這麼有用的情報……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像快要感動落淚了～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才、",
        "unit_id": 106011,
        "voice": "vo_adv_4003017_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才沒有什麼主動不主動的啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是不想要",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有做好充分準備就傻乎乎地出門，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果搞得自己慘兮兮而已……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──呵呵，",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留在顧左右而言他的時候，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "尾巴都會搖呀搖的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這是我最近的發現。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳注意到那點了啊，",
        "unit_id": 105911,
        "voice": "vo_adv_4003017_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那可是凱留小姐的魅惑點之一喔。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看著她的尾巴",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就會覺得心情很平和。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對啊，",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就像貓一樣，好療癒喔。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰是貓啊！？",
        "unit_id": 106011,
        "voice": "vo_adv_4003017_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說雪菲，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳自己在開心的時候也會搖尾巴不是嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還好意思說我啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真、",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的嗎！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我都沒注意到……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好丟臉喔……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們兩個都超可愛的唷♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我在肚子餓的時候，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也習慣盯著妳們的尾巴看\n來轉移注意力！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽妳這樣說，",
        "unit_id": 106011,
        "voice": "vo_adv_4003017_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我覺得自己好像有被妳吃掉的危險耶……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了別廢話了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕緊找到仙人掌然後回去吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不想一直待在這種",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "悶熱得要死的地方！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好，",
        "unit_id": 105911,
        "voice": "vo_adv_4003017_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那我們就進去吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n裡頭可能棲息著凶暴魔物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們提高警戒謹慎前進吧。",
        "unit_id": 105911
    },
    {
        "type": "background",
        "background": "501520"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……呼，",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個縱穴",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的好深喔。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都已經往下走這麼久，我還以為差不多也該到達地底了……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_4003017_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "周遭的景色漸漸在改變。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "途中",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有看到幾處類似遺跡的建築物……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但感覺這一帶新的建築物似乎不少。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～？",
        "unit_id": 106011,
        "voice": "vo_adv_4003017_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽妳這麼一說，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實是呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是不是被盜賊之類的當成據點了啊……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──啊！",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請看那邊！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那邊長了好多類似仙人掌的東西耶～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的耶！",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我看看……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n圓圓的、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有刺的……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看來那就是傳說中的仙人掌錯不了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總算找到了～！",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n光看就覺得很好吃♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趕緊把那些帶回去吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！？",
        "unit_id": 105911,
        "voice": "vo_adv_4003017_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "且慢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎有某種類似地鳴的聲音正在靠近。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這究竟是……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "！",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_026"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳看那個！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……是、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是一大群哥布林！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "數量好驚人啊！？",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難不成那些散落在縱穴各處的建築物，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是哥布林建造的嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像是呢。",
        "unit_id": 105911,
        "voice": "vo_adv_4003017_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想不到我們",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然在不知不覺中",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "走進了",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n哥布林城寨的深處……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等、",
        "unit_id": 106011,
        "voice": "vo_adv_4003017_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "重點是，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那些傢伙開始大吃仙人掌了呀！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "傳說中的仙人掌～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……有些哥布林舉起了武器。",
        "unit_id": 105911,
        "voice": "vo_adv_4003017_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來牠們已經察覺到我們的存在了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "準備作戰──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦、",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_031"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "奇怪……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那些哥布林抱著仙人掌",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "跑走了！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105911,
        "voice": "vo_adv_4003017_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出乎在下的預料。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n比起戰鬥，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠們寧可優先保全仙人掌……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來那種仙人掌應該相當美味呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種事有什麼好笑的啦！？",
        "unit_id": 106011,
        "voice": "vo_adv_4003017_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那些傢伙把仙人掌一株不留地通通拔走了耶！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們好不容易才找到的～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請、",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請先等一下，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哥布林……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先生！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請將那些仙人掌分給我們好嗎，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一點點就好～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "同為饕客，",
        "unit_id": 105811,
        "voice": "vo_adv_4003017_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "至少也溝通……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔唔，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "叫你們先等一下～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總、",
        "unit_id": 106411,
        "voice": "vo_adv_4003017_036"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總之先追上去吧！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然不知道牠們能不能溝通……",
        "unit_id": 106411
    }
]