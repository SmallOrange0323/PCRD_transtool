    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "明明總是你",
        "unit_id": 101211,
        "voice": "vo_adv_5084613_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "等著睡著的我……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但現在相反過來了呢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你也會",
        "unit_id": 101211,
        "voice": "vo_adv_5084613_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "像我現在這樣，牽掛著深深睡去的我嗎……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我居然是這樣察覺到的呀……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個……",
        "unit_id": 101211,
        "voice": "vo_adv_5084613_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "當我醒來時，你會待在我身邊，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那使我非常安心哦……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你知道嗎……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以，",
        "unit_id": 101211,
        "voice": "vo_adv_5084613_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這次輪到我等你醒來了哦……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想將那份心安",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "傳遞給你知道……！",
        "unit_id": 101211
    }
]