    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了貼身採訪望的假日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}今天也和她一起在海邊散步。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天也要麻煩你囉！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我的採訪員。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哼哼哼～♪",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "問得好！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天呢……",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說到夏天，就少不了這個！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "海邊遊玩必備的行程，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也就是海灘運動～！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "主流的衝浪運動也不錯，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以享受放假的時光來說，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n悠哉地搭乘遊艇也很好玩喔。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "另外",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像還有用潛水魔法遊覽海底的活動……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "選項太多了，真讓人苦惱呢～",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這道聲音",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是什麼啊……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在那邊！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看你看！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那是什麼啊？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那個東西在海上咻～地奔跑著耶！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且速度還很快！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "它往碼頭的方向過去了呢。",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n岸上好像也有擺出招牌。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個人好像要上岸了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們去問一下詳情吧！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不好意思～！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_009"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "啊，",
        "unit_id": 312,
        "voice": "vo_adv_1172002_010"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "歡迎光臨。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n兩位客人",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "是來搭乘「高速小艇」的嗎？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "高速小艇……？",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_011"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "是新型態的海上娛樂喔。",
        "unit_id": 312,
        "voice": "vo_adv_1172002_012"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n就是駕駛這艘小型船，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "在海面上奔馳。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哦～",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像很有趣！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這會不會很難操縱？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "簡單啦",
        "unit_id": 312,
        "voice": "vo_adv_1172002_014"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "簡單！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "因為這東西的賣點就是簡單到連初學者都能開著到處跑啊。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "我們也有提供",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "能體驗一天的出租服務。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "對了，",
        "unit_id": 312,
        "voice": "vo_adv_1172002_015"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "如果你們有興趣的話，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n願不願意來當免費體驗員啊？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "可能因為這是很新穎的海灘運動，",
        "unit_id": 312,
        "voice": "vo_adv_1172002_016"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n知道的人不多，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "所以完全沒有客人上門……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "反正再這樣下去，",
        "unit_id": 312,
        "voice": "vo_adv_1172002_017"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "店也是有開跟沒開一樣。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "為了招攬更多的顧客，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "希望你們能多告訴我一些感想。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們一起試試看吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當第一個體驗的人，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣好像很有趣不是嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就這麼決定！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我們",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要兩個人一起搭！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "太好啦。",
        "unit_id": 312,
        "voice": "vo_adv_1172002_020"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "那我就先從駕駛方法開始教起囉。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n如果兩個人一起搭乘──",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃～",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "扭轉這個就會加速……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這邊的握桿是減速……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我知道操縱的方法了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那要出發囉。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們走～！！",
        "unit_id": 117211
    },
    {
        "type": "still",
        "still": "117200201"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈♪",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺會很舒暢耶！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是說啊♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會讓人有種",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像真的能前往任何地方的感覺。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個明明這麼好玩，竟然都沒有客人上門。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n大家都去玩其他的海灘運動了嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好可惜喔。",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是能讓大家知道有這種活動，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定會很受歡迎的。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為撞到人會很危險，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以不能太靠近人多的沙灘，也是客人少的一大要因呢……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是能讓其他人從遠處看過來，也能感受到這份魅力就好了。",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要用跟跳舞一樣，在客人面前表演之類的方法嗎……？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "譬如",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "像這樣……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n提升速度後再迴轉！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再向左右兩側蛇行！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿呀～♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接下來～",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就一鼓作氣地加速……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後跳躍！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才那樣可能挺不錯的！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次就嘗試用迴旋力來轉彎吧！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應該就是……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種感覺吧",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你也要抓緊喔！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接下來的速度會更快的～♪",
        "unit_id": 117211
    },
    {
        "type": "still",
        "still": "117200202"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇哇！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等等，{player}！？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇～～～！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他的手",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "緊緊抱住了我的肚子！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n抱得好緊喔～～！！　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能、",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能這麼貼近地感受他的存在是很好，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但對我來說，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種刺激可能有點太強烈了……！　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跟我緊貼到一點空隙都沒有的話……",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n一定會被你發現",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的心在怦怦跳啦～！　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "幸好有穿上",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這件救生衣……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣真的沒問題嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒有被你感覺到吧！？　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……呃，哇哇！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "加速過頭了！",
        "unit_id": 117211
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀啊啊啊啊～～～！",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈……",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "全身都溼透了呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為剛剛的盡情玩耍，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我有點累了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在沙灘上休息一下吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但這樣就又實現一件了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就是我想在夏天做的事情。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我啊，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有很～多想在放假時去做的事情。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為這是難得的夏天啊！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "像是一邊在巡演的目的地逛街，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一邊走到哪吃到哪。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "或是跟今天一樣，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在海邊挑戰海灘運動。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我把這一類",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想在夏天做的事情整理成了清單。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為平常很忙碌，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有很多辦不到的事情……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是想要好好地實現，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "自己曾經想過要去做的那些事情。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以說啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我覺得今天很棒。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我體驗了海灘運動……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也和你一起來海邊玩了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不可以把剛才說的話寫進採訪裡面喔？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "話又說回來，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_049"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才的轉彎失敗了啊。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是不是該一口氣轉過去才對呢？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就考慮表現魅力的方法這一點來說，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這可能和舞蹈動作很像。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不只是橫向，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也要加入縱向的動作……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "辛苦你們了。",
        "unit_id": 312,
        "voice": "vo_adv_1172002_051"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "你們剛才讓我看到了很棒的東西啊。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "那是很優秀的表演喔。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "原來如此，",
        "unit_id": 312,
        "voice": "vo_adv_1172002_052"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "那麼做就能吸引到目光啊……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n這位客人，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "妳不是普通人啊。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "妳有在做什麼嗎？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這、",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "算是有在",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跳一點舞嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "除此之外",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也算有在進行各種活動……？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "我可以參考",
        "unit_id": 312,
        "voice": "vo_adv_1172002_054"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "妳剛剛展現的技巧嗎？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n只要在練習後表演給客人看，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "我想一定",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "能讓他們對這些高速小艇更有興趣！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好的！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒問題，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "但是？",
        "unit_id": 312,
        "voice": "vo_adv_1172002_056"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_057"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這只是我的感想，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但如果想要一口氣引來顧客的興趣，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我覺得剛才的技巧",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還不太夠力。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也就是說，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_058"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要拿出能成為表演的重頭戲，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "又有強大魄力的華麗技巧，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是這麼想的。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "比剛才更厲害的華麗技巧……",
        "unit_id": 312,
        "voice": "vo_adv_1172002_059"
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "呃，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "老闆",
        "words": "妳辦得到嗎？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然不試試看就不會知道……",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_060"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但依我試著駕駛的感覺，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應該是可以吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我可以試試看嗎？",
        "unit_id": 117211
    },
    {
        "type": "still",
        "still": "117200201"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_061"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想這速度已經夠快了，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但要空翻的話，這個力道還不太夠呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是因為不夠乾脆俐落嗎……？",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_062"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就像這樣，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺就像把整個身體更加用力地向後拉……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……呵呵，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_063"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但今天明明是難得跟你一起度過的假日呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這明明也不是工作，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們卻這麼努力地在練習。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不過啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_064"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "像是大家驚訝到合不攏嘴的表情，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還有",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "眼神閃閃發亮的笑容。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一想像到那些畫面，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就會湧現出幹勁。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然我自己也覺得很不可思議。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這麼看來，",
        "unit_id": 117211,
        "voice": "vo_adv_1172002_066"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我果然很喜歡用自己的表演讓人露出笑容呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管身在哪裡，",
