[
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呼、",
        "unit_id": 105211,
        "voice": "vo_adv_5040323_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呼……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n都打到這個地步了",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還打不倒他們嗎……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的很強啊……",
        "unit_id": 112811,
        "voice": "vo_adv_5040323_001"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "沒想到竟然跟我能打到這種程度。",
        "unit_id": 13311,
        "voice": "vo_adv_5040323_002"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "真讓人吃驚。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n雖然正面對決並不是我的作風，",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "但就讓我用全力迎戰你們吧。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "所——以——說——！",
        "unit_id": 2511,
        "voice": "vo_adv_5040323_003"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n一開始就該傾盡全力才對啊，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "沒用的東西！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "…………",
        "unit_id": 13311,
        "voice": "vo_adv_5040323_004"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "喂！　",
        "unit_id": 2511,
        "voice": "vo_adv_5040323_005"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "回話啊！！　",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "不准無視我！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n除掉他們！　",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "趕快把那幾個傢伙給我除掉！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的不顧形象了呢……",
        "unit_id": 112711,
        "voice": "vo_adv_5040323_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "他已經放棄裝模作樣了嗎？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這表示他可能也要不擇手段了。",
        "unit_id": 103811,
        "voice": "vo_adv_5040323_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n大家要繃緊神經、小心為上喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說什麼除掉除掉的，",
        "unit_id": 112811,
        "voice": "vo_adv_5040323_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你把我們當成什麼啊！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不知道要珍惜他人的傢伙，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就該打倒他啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒錯！　",
        "unit_id": 105211,
        "voice": "vo_adv_5040323_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼危險的人，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可不能放任他不管！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在就是最重要的關頭了。",
        "unit_id": 112811,
        "voice": "vo_adv_5040323_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "打倒他們，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "取回牧場的和平吧！",
        "unit_id": 112811
    }
]