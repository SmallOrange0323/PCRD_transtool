[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "公會管理協會的",
        "unit_id": 126311,
        "voice": "vo_adv_5120079_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可靠大姐姐，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "花凜小姐。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管是誰",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n都沒辦法忤逆她……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我有聽過這樣的傳聞，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是真的嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在夥伴增加時打開門的她，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "臉上笑容真的很耀眼呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明明工作那麼繁忙，",
        "unit_id": 126311,
        "voice": "vo_adv_5120079_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "卻總是維持著溫和的表情，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這一點",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n真的很厲害，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是我希望她能好好休息呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果因為不停地勉強自己，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n而讓美麗的人事物從這世上消失的話，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是件很令人難過的事情啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "克蕾琪塔小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120079_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有著可以說是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "由奔放的行動",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "以及財力",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n所支撐的美吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管跌倒幾次都不認輸的強悍心靈，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "非常地棒呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我希望她能",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "將那個財力分我一點點啊……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然沒辦法用錢買到真正的美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120079_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是投資美是很棒的事情喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不想得到",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "成為將我的美傳達給全世界的贊助者",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這份榮譽嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "貪吃佩可小姐",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一定也會覺得很高興喔♪",
        "unit_id": 126311
    }
]