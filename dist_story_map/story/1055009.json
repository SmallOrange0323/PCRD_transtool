        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……切嚕。",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_045"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎麼辦……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_046"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然順勢講了一大堆話……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩他，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n卻露出了從來沒有看過的困擾表情……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎麼辦……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_047"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然順勢講了一大堆話……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n但是{player}前輩他",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "完全嚇到了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n不但眼神不停地亂飄，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像還快哭出來了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "仔細想想……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_048"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不對，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就算不用想也知道，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我做了",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "完全無法挽回的事……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說不定還被{player}前輩討厭了……！？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_049"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對不起～！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請當作",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一切都沒花生過吧～！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……對不起，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_050"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "剛剛亂了手腳。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我以為{player}前輩一定已經討厭我，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n也許今後都不願意再跟我說話了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你問我",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_051"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為什麼……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "會做出那種事？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說得也是，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你一定會感到在意嘛……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唉……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呃……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_052"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我這個人很不起眼，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也沒什麼存在感不是嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不但髮型很普通，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "穿的衣服也沒有特色，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也做不到什麼特別厲害的事……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以才想靠",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_053"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "鮮明的個性或說話方式，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n讓{player}前輩對我的印象",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可以好一點。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因、",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_054"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因此……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我觀察了跟{player}前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "愉快地交談的女孩子，\n並把她們的特徵全都學起來……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "結果就變成那副丟人的模樣了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦……！？",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_055"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n可是，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "平常的我很沒存在感，大家幾乎都注意不到，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n{player}前輩也覺得跟個性鮮明的人相處",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "比較開心吧？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你是說如果大家都跟平常一樣，就會覺得很開心，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_056"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n但要是在逞強，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "或是沒有精神",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就會感到難過……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n會擔心",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對方是不是很困擾……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以說，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_057"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩跟女孩子說話時會露出笑容……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "並不是因為喜歡對方，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "而是知道對方過得很好，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n感到很安心才會笑出來嗎……？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……我",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_058"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "明明一直注視著{player}前輩，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n卻完全沒注意到",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你的心意呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以才會做出那種",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "讓前輩感到困擾的舉動……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我決定",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_059"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不再勉強自己去模仿其他人的個性了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n雖然我很不起眼，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也沒有存在感……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n前輩你願意",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "跟我變得更要好嗎……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嘿嘿……♪",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_060"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n謝謝你，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩♪",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，雖然多少有點白忙一場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n步未還是以原本的自己，跟{player}加深了羈絆。"
    }
