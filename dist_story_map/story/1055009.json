[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，在蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n步未今天也仔細地「觀察」著{player}。"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "今天也好帥……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然這麼說，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但最近我們變得比較不常一起打工呢～",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我們除了去約會，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還一起打倒了魔物。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "明明發生了許多可以跟{player}前輩增進感情的事件，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "結果到頭來",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還是只能遠遠看著他……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "最後一次",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "跟前輩好好說話是什麼時候啊？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我本來就很不起眼，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒什麼存在感了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n再這樣下去，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "他說不定會把我忘掉……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要是我跟其他人一樣",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有個性，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "或是開朗一點，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n是不是就能跟{player}前輩更要好了？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "如果想把自己變成那樣，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "又該怎麼做才好呢……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "……然後啊，",
        "unit_id": 6511,
        "voice": "vo_adv_1055009_004"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n因為他",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "喜歡開朗又引人注目的女生，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我就參考了鈴奈的說話方式，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "嘗試營造出這種感覺～",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "那位模特兒鈴奈，",
        "unit_id": 1211,
        "voice": "vo_adv_1055009_005"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "明明跟妳一點也不像耶。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "不過，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "能靠這種方式成功跟喜歡的人交往，或許很厲害呢……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "畢竟她是大家憧憬的對象呀～♪",
        "unit_id": 6511,
        "voice": "vo_adv_1055009_006"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n只要模仿有名的人，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "自己也會受到大家喜愛！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n這真是個好主意，對吧～？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……感覺聽到了一個好主意。",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只要調查{player}前輩喜歡的類型，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n再模仿那個人就好了……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "總之，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "先繼續觀察{player}前輩，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n看他跟哪種女孩子講話時，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "會感到很開心好了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然調查過程可能會很辛苦，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_009"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也不曉得會不會有效果……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但必須從自己做得到的事情",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "開始才行……！",
        "unit_id": 105511
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "已經跟著{player}前輩走了一段時間……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我想，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "他應該是出來購買公會需要的食材吧？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……啊，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_011"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是【美食殿堂】的貪吃佩可小姐！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n她好像跟{player}前輩聊得很開心。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n看來",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "得仔細聽聽他們都在聊些什麼話題！　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "讓我聽聽看……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_012"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n怎麼好像",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一直在聊今天的晚餐，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n還有貪吃佩可小姐餓到肚子咕嚕咕嚕叫而已……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過{player}前輩看起來很開心……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_013"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n說不定",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "他喜歡",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "總是餓著肚子，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n並說著食物話題的女孩子！　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我算不上是",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_014"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "很能吃的類型啊……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不對，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "正因如此才要參考前輩跟貪吃佩可小姐的對話，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n並好好模仿才行……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "得把肚子為什麼咕嚕咕嚕叫的原因",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_015"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也都記錄下來。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我寫我寫……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "貪吃佩可小姐走掉後，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n只剩下{player}前輩一個人了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "看他還留在市場，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是有其他想買的東西嗎？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_017"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有人接近{player}前輩了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦！？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個人難不成是",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_018"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "空花！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n兩人似乎聊起來了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n不曉得",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是怎麼看待空花的呢？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "乍看之下……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "兩人好像",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "都很開心……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n得移動到",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可以聽見對話的位置才行……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "到這邊就沒問題了吧？",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_020"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩露出非常安穩，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "彷彿看破世間的表情附和著，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n究竟在聊",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "什麼話題呢……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯嗯……",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_021"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦……！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n空花她在妄想",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "自己被做過分的事，或是很害羞的事，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n而且內容比往常",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還要誇張……！　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "光是聽著",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_022"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "臉頰就發燙了……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是{player}前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "仍然一臉笑容……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n他不討厭……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這種事嗎？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "難、",
        "unit_id": 105511,
        "voice": "vo_adv_1055009_023"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "難、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
