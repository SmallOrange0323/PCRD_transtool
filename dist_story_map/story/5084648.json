        "voice": "vo_adv_5084648_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n大家都很擔心啊。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的有很多、",
        "unit_id": 105213,
        "voice": "vo_adv_5084648_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很多女孩子在擔心你。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "都讓人家有點嫉妒了……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "亂說的，當然沒這回事啦。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為大家都跟你一樣是很溫柔的好人。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就像跟你在一起時一樣，心情會變得很溫暖。",
        "unit_id": 105213,
        "voice": "vo_adv_5084648_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但相對地……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你不在的話，就又不禁讓人感到寂寞了。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我想大家一定都是跟我一樣的心情。",
        "unit_id": 105213,
        "voice": "vo_adv_5084648_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要快點醒來喔。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n讓人感到寂寞可不像你啊。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我相信我們還能再一起歡笑著。",
        "unit_id": 105213,
        "voice": "vo_adv_5084648_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我會滿心期待地等著那一刻的喔。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為我相信如果是你，一定會沒事的。",
        "unit_id": 105213
    }
]