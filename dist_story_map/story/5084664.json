[
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗……",
        "unit_id": 110812,
        "voice": "vo_adv_5084664_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那傢伙是怎樣？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n還真的一覺不醒耶，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "超好笑。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哪裡好笑，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一點也不好笑啦。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是我說，",
        "unit_id": 110812,
        "voice": "vo_adv_5084664_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一覺不醒也就算了，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以是該怎麼辦？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n老實說，這事態很嚴重吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嚴重到這地步我有點受不了啊。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "都是你害我打工得請假，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該補貼我打工費了吧？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以咧，",
        "unit_id": 110812,
        "voice": "vo_adv_5084664_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只要存錢請個名醫來，就能治好你了嗎？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那我就存錢嘛。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n只要去找個厲害的治癒魔法大師來，就能叫醒你了嗎？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那我就去找嘛。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "欸，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你說我該怎麼辦？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我什麼都願意做。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的什麼都願意做啦。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……話雖如此，",
        "unit_id": 110812,
        "voice": "vo_adv_5084664_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在也已經各種方法都嘗試過了啊～",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "靠墨財團的財力也無計可施的話，就沒救了。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "死胡同啦。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唔，",
        "unit_id": 110812,
        "voice": "vo_adv_5084664_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "反正是那傢伙，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總會沒事的吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "之後他想上廁所可能就會醒了吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "──我就當作是這樣，",
        "unit_id": 110812,
        "voice": "vo_adv_5084664_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "暫時先等待吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你應該也有各種苦衷，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以偶爾讓身體休息也好啦。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但要是你改變想法，就立刻給我起來啊？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "聽到沒？",
        "unit_id": 110812
    }
]