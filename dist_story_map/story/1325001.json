    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "露易去遠方出差了，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "彩羽也跟著當保鑣，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n今天就只有我一個人～",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "所以說，",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_005"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "今天一天",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "就麻煩你幫忙了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "絕對會準時下班，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不讓你加班的，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "放心吧。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哦，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "有客人來了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "雖然你應該也習慣接待客人了，",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_006"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "總之",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我來示範一次吧。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "要上囉，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "大人的待客術……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "來了～",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "歡迎光臨。",
        "unit_id": 132512
    },
    {
