        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "結果才扛起以前用的槍，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "就變成那樣了……",
