        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "也就是說，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "提供解決問題的方法，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "才是能幹的店員。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n如何？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "學到了嗎？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊～",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_018"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你想嘛，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "要全部說明",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不是很麻煩嗎？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這是所謂的",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "臨機應變。",
