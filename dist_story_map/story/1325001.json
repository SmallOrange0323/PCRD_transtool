    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "大概",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "就是這種感覺。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不是，",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_016"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我可不是小孩子啊。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n剛才那種大人銷售術，",
