        "voice": "vo_adv_1325001_011"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "魔物嗎。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那真的很可怕呢。",
