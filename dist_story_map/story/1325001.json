    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "先把這裡的庫存……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "怪了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n啊啊，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "在上面啊。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "等我一下喔。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "腳踏台、腳踏台……",
