    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那麼",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這邊有個驅除魔物的護身符，",
