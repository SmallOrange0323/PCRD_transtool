    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "早市的人潮散去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "往來的腳步聲也變少的時候。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在小巷內的阿爾克絲鍊金堂店門口，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "有個嬌小的身影站著。"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嘿咻……",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_000"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "好。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呼。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "好",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_001"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n就快到開店時間了……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哦，",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_002"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "來了來了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n時間剛剛好呢。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n真準時啊～",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那麼……",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_003"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "阿爾克絲鍊金堂，",
