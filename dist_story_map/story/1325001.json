    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "呼～",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "話說回來，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "還真是乖巧的孩子呢。",
