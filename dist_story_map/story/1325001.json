    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哦，",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_020"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "謝謝。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這種時候還是以前的身體方便啊。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不過因為沒什麼力氣，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "所以太重的還是沒辦法就是了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "有男生在真是幫了大忙啊。",
        "unit_id": 132512,
        "voice": "vo_adv_1325001_021"
    },
