[
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "喲，",
        "unit_id": 18711,
        "voice": "vo_adv_5210008_000"
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "你們幾個，",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "\n似乎在競技場",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "大顯身手了吧。",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "\n",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "這下事情總算解決了",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "……",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "怎麼了？",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "幹嘛露出這麼嚴肅的表情？",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "什麼！？",
        "unit_id": 18711,
        "voice": "vo_adv_5210008_001"
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "什麼意思？",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "\n蜘蛛假審判長不是凶手嗎？",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "……",
        "unit_id": 18711,
        "voice": "vo_adv_5210008_002"
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "原來如此。",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "你們懷疑",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "我是實行犯對吧？",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "我的確是",
        "unit_id": 18711,
        "voice": "vo_adv_5210008_003"
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "一時喪失自我，",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "當時的記憶",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "很模糊，",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "\n",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "可能沒辦法",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "斷言",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "自己絕對沒做。",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "\n",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "……好，",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "那我就束手就擒吧。",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚的太太",
        "words": "等等，",
        "unit_id": 1,
        "voice": "vo_adv_5210008_004"
    },
    {
        "type": "dialogue",
        "name": "主廚的太太",
        "words": "你在說什麼啊！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "如果有人必須要贖罪，",
        "unit_id": 18711,
        "voice": "vo_adv_5210008_005"
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "\n理所當然該由作為主廚的我",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "負起責任。",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "只是，",
        "unit_id": 18711,
        "voice": "vo_adv_5210008_006"
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "我是",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "真的準備款待蘭德索爾的人們。",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "\n",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "只有這點，",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主廚",
        "words": "請你們相信我。",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "廚師被作為毒殺事件的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真正凶手遭到拘留──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這個新聞馬上就傳遍整個吉歐‧格黑納。"
    },
    {
        "type": "background",
        "background": "502710"
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員１",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_5210008_007"
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員１",
        "words": "聽說了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員１",
        "words": "\n那起殺人事件，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員１",
        "words": "凶手就是主廚。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員２",
        "words": "可是，",
        "unit_id": 1,
        "voice": "vo_adv_5210008_008"
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員２",
        "words": "是不是有點奇怪？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員２",
        "words": "\n就算下毒的是他，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員２",
        "words": "結果到底是哪種毒，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員２",
        "words": "\n這關鍵的一點還是沒弄清楚……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員１",
        "words": "真的是啊。",
        "unit_id": 1,
        "voice": "vo_adv_5210008_009"
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員１",
        "words": "\n只要不弄清這一點，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員１",
        "words": "這裡就危險得讓人待不下去。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員２",
        "words": "根本不是談什麼開發森林的時候，",
        "unit_id": 1,
        "voice": "vo_adv_5210008_010"
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的技術人員２",
        "words": "趕緊回蘭德索爾吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾的人們"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這麼離開吉歐‧格黑納，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n合作的生意也化為烏有──"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來",
        "unit_id": 137412,
        "voice": "vo_adv_5210008_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是我們弄錯了呢……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這次的事件裡，",
        "unit_id": 137412,
        "voice": "vo_adv_5210008_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有件最重要的關鍵。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n凶手到底",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是如何讓被害者服下毒物的呢？",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我們重新思考一次這個問題吧。",
        "unit_id": 137412,
        "voice": "vo_adv_5210008_013"
    }
]