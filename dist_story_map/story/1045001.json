[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "騎士在那裡殘暴地對妖精……",
        "voice": "vo_adv_1045001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n嘻嘻、嘻嘻嘻……而後，"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那雙魔手也伸向空花……流口水。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你、你好，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n找、找空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "有什麼事情呢？！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你、",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你該不會想把空花綁住，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "盡情地蹂躪吧……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……這、這樣下去，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花會被當成聽話的奴隸的。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊，但是這樣也……",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n沒什麼不好……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "應該說很好！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n流口水……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……欸，不是嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……為、為什麼？！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "如果沒有要把空花當成奴隸的意思……",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那、那、那是有什麼事！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……只是在尋找一起討伐魔物的夥伴而已？",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "討伐魔物……",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！這、這該不會……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是空花第一次被搭訕吧……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "討伐魔物這藉口，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是在委婉地掩飾害羞呢……",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是、",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是的！怎麼了嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n看、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "看得出來",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花很緊張……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "其實今天是空花第一次，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為了討伐魔物出來……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "少女破繭而出變成大人，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n總是這麼地突然……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過被人這樣激情地對待，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花也會覺得困擾的，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "拜託一開始的時候要溫柔些。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呱歐…… "
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "突、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "突然對空花的脖子吹熱氣，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n真是厲害的招數……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但、但是，在這種地方──",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦、咦咦，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、這是，到底是──？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咿欸欸欸欸欸！",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n魔物─────！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "果、果然，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n你一開始就是",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這個目的啊……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "從安全的地方，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n直盯著失去意識的空花衣衫不整的樣子……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在沒辦法奮力抵抗之後……",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花被帶到黑暗中，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "只聽到「我來治癒妳的身心吧……」",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這樣！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這個虐待狂！！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n人格異常者……！",
        "unit_id": 104511
    },
    {
        "type": "still",
        "still": "104500101"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……但是，空花感到全身發燙……",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_022"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這該不會就是戀愛！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但、但是對第一次見面的人，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n就把身體交出去，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花，\n真是個可怕的花痴！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊哇哇哇哇哇！",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_024"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_025"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這之後……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一定會約好也要在街上見面，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n在下次見面時……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花就會被說「我要在妳的身體上刻下我的印記」，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一定會變成這樣……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "──欸？要、要回去了嗎！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "奇、奇怪，跟空花想的",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "有點不一樣……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……那……那個，你這就要回去的話，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n為、為什麼還要",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "約空花呢……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可、可是……，",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_029"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "所謂的討伐魔物，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n難道不是在掩飾害羞嗎，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "真、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "真的只是這樣……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸、",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_030"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸欸欸欸欸──！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n那不是搭訕嗎！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊啊，這、這個誤會真是丟臉……",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_031"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這麼說來……空、空花被玩弄了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你果然是……人格異常的虐待狂……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、空花要回家了……！",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_032"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚嗚嗚……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "再也不相信冒險者了……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是，不知道為什麼\n空花覺得很興奮……"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻……",
        "unit_id": 104511,
        "voice": "vo_adv_1045001_033"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "流口水。",
        "unit_id": 104511
    }
]