[
    {
        "type": "background",
        "background": "500081"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留與{player}今天依然在準備考試。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n眼看考試的日子就快到了，兩人也準備得很有幹勁。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……已經這麼晚了？",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們持續讀了很長一段時間呢。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "稍微休息一下吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天的狀況感覺滿不錯的，你念書很專注呢。",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看來考試",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說不定真的有機會拿高分喔……♪",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼了？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹嘛直盯著我的臉看？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是有什麼話想說嗎？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我怎麼可能會喜歡讀書！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說讀書時的我",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很樂在其中……？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是……",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許是這樣吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "老實說我自己也覺得很不可思議呢……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是真的沒有很喜歡讀書喔。",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為我覺得拚命去記住",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一堆對將來沒有用處的知識，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是完全沒有意義的事。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼我會這麼熱中呢……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是為什麼？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "了解未知的事物很有趣……",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是嗎？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…嗯，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許是吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "多增加一些新的知識和經驗，",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也是很有趣呢。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……在【美食殿堂】的日子",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大概就是這個樣子吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為遇見了貪吃佩可她們，",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果每天都被捲入",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "意想不到的新事件呢！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我話先說在前頭，",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有你也是喔？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和你相遇之後……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓我學到了",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "許多未知的事物。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像這樣來學校上課，",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放學後讀書複習，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感受著從窗戶吹進來的輕柔微風……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有……",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所謂的青春，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這一切，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是因為有你……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為有與你相遇，我才能體會到……！",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說什麼",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也是啊……！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可沒說",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我很慶幸與你相遇什麼的喔！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……但我也沒說我覺得討厭。",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或者該說，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不是討厭，而是……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n感、",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺好熱呢！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們把窗戶打開吧！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 127214,
        "voice": "vo_adv_5126702_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別再聊廢話了！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "考試馬上就要到了！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們要來做最後衝刺，好好努力！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是兩個人就在"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n流入新鮮空氣的教室裡，繼續準備考試──"
    }
]