    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵♪",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n真開心呢～",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跟幼稚園的大家一起辦慶生會。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也要謝謝你",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "協助孩子們進行準備。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家為了我，",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "畫了肖像畫與摺了摺紙……",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "成了一場非～",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "常棒的生日。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我發自內心覺得……",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "能成為保母真是太好了。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n可是，",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "孩子們都已經",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "回家……",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀～！",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n包裝精美的盒子……",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這是",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "生日禮物嗎？",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是跟",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "孩子們一起送的……",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是你個人送的？",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "莫非，",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你是想獨占",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師開心的笑容嗎？",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是貪心呢……♪",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可以讓我打開嗎？",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀～！",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n是一條可愛的緞帶♪",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是你為我選的嗎？",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵♪",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我會非常",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "珍惜地",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "穿戴於身上的。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對了……",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "第一次，",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我就拜託你吧。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這條緞帶。",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n第一次穿戴……",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我想要拜託你。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你願意幫我繫上嗎？",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "穿戴上這個後……",
        "unit_id": 101533,
        "voice": "vo_adv_4010201_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n感覺就像你",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一直陪伴在我身邊。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝你。",
        "unit_id": 101533
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵♪",
        "unit_id": 101533
    }
]