        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那就當新年試手氣，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一起來抽抽看吧～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨！",
