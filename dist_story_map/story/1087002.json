        "type": "dialogue",
        "name": "日和",
        "words": "\n就只有中獎的人才能買呢！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "每個人都在說這籤根本就都抽不中嘛，",
        "unit_id": 108711,
        "voice": "vo_adv_1087002_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以我早就想要挑戰一次看看了呢～♪",
        "unit_id": 108711
    },
