    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與日和在邊走邊把食物都吃光了之後，\n為了散步兼消化，便一同逛起新年首賣的街道了。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 108711,
        "voice": "vo_adv_1087002_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們可以去那家商店嗎？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我啊，",
        "unit_id": 108711,
        "voice": "vo_adv_1087002_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有一個不管怎樣都想入手的東西！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這家店裡有在賣……",
        "unit_id": 108711,
        "voice": "vo_adv_1087002_002"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "賞臉光顧的客官們！",
        "unit_id": 1411,
        "voice": "vo_adv_1087002_003"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "身為蘭德索爾中最大商店的我們，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n今年也抱著賠本的覺悟，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "為各位客官們準備了最棒的福袋！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "究竟今年是誰最有福氣，能將大獎給帶回家呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "請一定要挑戰看看！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "來吧轉吧試試你的手氣！",
        "unit_id": 1411,
        "voice": "vo_adv_1087002_004"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "中獎了就是你的福氣！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "展現你那萬中選一的天分！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "路過經過走過也不要錯過！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "來吧來吧，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "不來轉轉看試試手氣嗎〜？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你聽見剛剛的話了嗎？",
        "unit_id": 108711,
        "voice": "vo_adv_1087002_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這家店準備了塞滿很多高價商品的特別福袋，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n每年不但就一個，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還用非常便宜的價格來賣唷！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且呀，",
        "unit_id": 108711,
        "voice": "vo_adv_1087002_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還得要先抽那家店前面準備的籤，",
        "unit_id": 108711
    },
