    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "由我去見你吧！",
        "unit_id": 105032
    },
    {
        "type": "still",
        "still": "121400402"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒錯！",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_055"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這根本不算什麼嘛♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n如果我們相隔得很遠，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那我只要去見你就行了。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就算相隔得有點遠，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_056"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只要搭飛機就馬上到了。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "即使很難每天見面，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但如果想見面，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還是能見得到面不是嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_057"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "假如你要去到很遠的地方，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我也會特別去見你，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "然後回你今天的謝禮♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_058"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然比我還年長……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但是我",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "會成長得更多，然後馬上就追上你的。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "明年的這個時候，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_059"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我肯定會變成",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "比現在更優雅",
