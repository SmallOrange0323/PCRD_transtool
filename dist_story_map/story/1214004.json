[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "物產展公休的某個假日。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了和育幼院的孩子們一起去牧場賞花，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n美咲正在做出門的準備。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃，",
        "unit_id": 121411,
        "voice": "vo_adv_1214004_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "便當有帶了。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要給真陽小姐她們的伴手禮也帶了。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "其他",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒帶到的東西……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "真是的，",
        "unit_id": 111,
        "voice": "vo_adv_1214004_001"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "美咲姐姐還沒好嗎～？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們快點走嘛～！",
        "unit_id": 211,
        "voice": "vo_adv_1214004_002"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n真陽姐姐",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "在等我們喔～",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我、",
        "unit_id": 121411,
        "voice": "vo_adv_1214004_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我知道啦！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我正在",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "檢查東西有沒有帶齊，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你們等我一下！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "好──♪",
        "unit_id": 1,
        "voice": "vo_adv_1214004_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要照顧小朋友，這是當然的吧。",
        "unit_id": 121411,
        "voice": "vo_adv_1214004_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n因為我可是成熟的淑女。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這不重要，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來，這給你。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是負責拿行李的，",
        "unit_id": 121411,
        "voice": "vo_adv_1214004_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n要確實",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "把便當和點心搬過去喔。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果不認真工作，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就不給你吃點心。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那麼，",
        "unit_id": 121411,
        "voice": "vo_adv_1214004_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "快點走吧！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n今天可是最佳的賞花日啊♪",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……咦？",
        "unit_id": 121411,
        "voice": "vo_adv_1214004_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這再怎麼說，也太耀眼了吧？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就算是好天氣，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也該有個限度吧～！？",
        "unit_id": 121411
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你總算回來了。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "居然敢買東西讓淑女等這麼久，你很大牌嘛。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "聽好了，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想你應該知道，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n今天我可是",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "勉為其難來陪你的。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我原本",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是預定要和家人一起去賞花。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為沒辦法大家一起去了……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n所以媽媽",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才說什麼",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果是和你一起就能去……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也是多虧如此，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n才能夠和我這麼出色的淑女",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一起賞花，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要心存感激喔。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說回來，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "剛才去買了什麼？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n……為什麼要藏起來啊，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這不是反而讓人更在意嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "算了，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "成熟的大人是不會隨便亂追問的呢。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就交給你帶路了。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你說過有推薦的賞花地點吧。",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我很期待你到底會",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "帶我去哪裡～♪",
        "unit_id": 105032
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……欸，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這裡是",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "附近的林蔭大道吧？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我沒看到",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哪裡有什麼櫻花木啊。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你應該不會",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說什麼……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要我賞那邊的蒲公英",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這種蠢話吧？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只要繼續沿著河川走，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就會走到櫻花道？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這麼說的話，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們還得再走一段路才行嗎！？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "討厭，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "早知道要走路，我就不會穿什麼高跟鞋來了～",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我還以為是要去時尚的櫻花景點耶。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊！",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等、",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等等！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你再走慢一點啦！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "男性要配合女性的走路速度，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這不是應該的嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果是紳士，就應該懂得體貼淑女。",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_021"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n麻煩你振作點！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唔哇～",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你看那邊那些男生。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "明明還是這種冷冷的季節，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "他們居然穿得那麼少到處跑。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真虧他們那樣不會感冒呢。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "放長假",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "能盡情出去玩，是讓人很高興，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但媽媽老是嘮叨著要我念書……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "比想像中更不輕鬆呢。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎樣啦？",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_024"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你那什麼擔心的眼神？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我先說清楚了，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我可是有認真在念書喔。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "像是今天該念的份，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也早就都念完了呀。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哇！",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_025"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你別摸我的頭！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "別亂搓我的頭髮！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你會害我難得弄好的髮型",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "都要亂掉了啦！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說回來，",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_026"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你有認真",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在念書嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真的？",
        "unit_id": 105032,
        "voice": "vo_adv_1214004_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
