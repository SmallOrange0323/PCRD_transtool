[
    {
        "type": "background",
        "background": "500054"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為各種事件接連發生，讓似似花累倒了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而{player}全心全意地"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n照顧躺在醫院病床上的似似花。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……嗯。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這裡是……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……看來我是昏倒了嗎。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "似乎讓你操心了呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我已經沒事了──",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣啊。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就依你說的了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……你為什麼",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要露出那麼沮喪的臉？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為什麼要道歉？",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你並沒有做錯事吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這次",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是我自己決定要陪你去幫助別人的。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n選擇這麼做的後果",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要由我自己承擔。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也就是說，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你沒有必要放在心上。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果你還是覺得良心上過意不去……",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想想看，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那你就多照顧我一陣子吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好啊，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "拜託你了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可以的話，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能弄成兔子的形狀嗎？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然花了點時間，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但形狀看起來還不錯。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "手指的靈巧測驗就算你及格吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "跟以前相比",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真的進步了不少呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n甚至讓我心中有些感慨。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就開動了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這顆蘋果的味道還真特別呢。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "味道是好的，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過這究竟是……？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……原來如此，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也有聽過這個傳聞。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n據說是只生長在伊麗絲樹海",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "的稀有蘋果。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "它的價格相當地貴吧，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n應該快把你的零用錢都花光了？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……受不了，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你還是一樣是個濫好人呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "甚至到了無可救藥的程度。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是跟我完全相反的性格。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正因為如此，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你才──",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒什麼事。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起這個，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "吃了蘋果後，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我已經恢復不少了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "假期可還沒有結束。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我們",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再去一趟大間吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──因為，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想跟你一起享受這個夏天。",
        "unit_id": 126611
    },
    {
        "type": "background",
        "background": "500692"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……雖然天色已經整個暗下來，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但總算是回到這裡了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊啊！？",
        "unit_id": 3311,
        "voice": "vo_adv_1266003_021"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是大姐你們！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我等好久了！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n謝謝你們",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "幫我教訓了哥哥一頓！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……看樣子你已經見過那位黑手黨了。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_022"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是的，",
        "unit_id": 3311,
        "voice": "vo_adv_1266003_023"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "他似乎受夠了教訓，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "打算去自首。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n還說了「只要有那種女人在就不可能幹壞事」",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這種話。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "他跟我約好，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "等他回來就會幫忙店裡的工作……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我真的很想報答大姐的恩情。",
        "unit_id": 3311,
        "voice": "vo_adv_1266003_024"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n如果有我能做的事，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "還請儘管吩咐！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣啊。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n可以讓我包下這家店嗎？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這點小事當然沒問題！",
        "unit_id": 3311,
        "voice": "vo_adv_1266003_026"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n剛好現在也沒有其他客人。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我馬上去準備餐點跟飲料，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "兩位還請悠閒地──",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不用麻煩了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "倒是",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能不能請你",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "暫時離開店裡呢？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好的，",
        "unit_id": 3311,
        "voice": "vo_adv_1266003_028"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "還請慢慢享受！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……好了，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣就只有我們兩人了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……話說夜晚的大海",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也有種相當獨特的風情呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今天雖然發生了不少事情……",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過這也許",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算是個不錯的假期。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且也讓我有機會，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n能夠再次地了解到你是個怎麼樣的人呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "早在世界變成現在這樣之前，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我就一直對你很有興趣了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──因為，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你是很特別的存在。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……趁這個機會，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就告訴你一個我隱藏的小祕密吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然說，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這原本是你早就知道的事情。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……如你所知，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我可以模仿世界上存在的",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "任何東西。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是身為七冠的我──",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "變貌大妃所擁有的權能。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算是這樣的我，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也存在著無法模仿的特例。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……那就是你，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶的公主騎士。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "準確來說，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "單就外觀",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是可以模仿出來。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就像這樣……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "{0}的複製品",
        "words": "……",
        "unit_id": 100011,
        "voice": "vo_adv_1266003_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "乍看之下",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可能非常完美，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個複製品只能模仿外表，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "內在卻是個空殼……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "消失吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我無法理解",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你在想什麼，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或是相信著什麼。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因此，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我沒辦法作為你來開口說話，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或是採取行動。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正因為如此……",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_042"
    },
    {
        "type": "still",
        "still": "126600301"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想要",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "親眼看看你眼中的世界。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n想知道你究竟",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都在想些什麼……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──我想要變成你。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_044"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……晶曾經",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣對我說過，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n她說身為七冠的我",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不可能複製得了你。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我並不這樣認為。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為跟你建立起羈絆，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我自己",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也多少產生了一些變化。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要繼續加深兩人之間的羈絆，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我應該遲早能夠理解你的一切……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……在你眼中的世界，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "究竟會是什麼樣子呢？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那真是太好了呢。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n……你今後",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也只要照自己的想法活下去就好。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "總有一天，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我一定會",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "收下你的一切。",
        "unit_id": 126611
    },
    {
        "type": "background",
        "background": "500692"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……先不談這個話題了。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n關於你今天的分數，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該可以給個80分吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比我預想的還要高。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是能再觀察得仔細一點，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或許就可以拿到更高分呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你很在意嗎？",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……不過答案可是祕密。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我想",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "獨自去附近散步一下。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你就趁這段時間，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "試著思考我說的話有什麼含意吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然我剛才那樣說，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但他是不可能知道真相的。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──他應該",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "連作夢都想不到，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我會倒下竟然只是在演戲吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "身為七冠的我，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼可能因為工作繁忙，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "加上稍微過度使用權能",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就倒下呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那只是一場模擬測試。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_059"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了藉此確認",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n萬一我真的倒下了，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他會採取什麼樣的行動。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "結果相當不錯。",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "尤其",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是一了解狀況後，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就立刻把我帶去醫院",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是很正確的判斷。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然搬運方式",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有點出乎我的預料。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他會露出那種表情──",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也讓我很意外。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然說對於這次的觀察結果沒有任何不滿，",
        "unit_id": 126611,
        "voice": "vo_adv_1266003_062"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但今後還是盡量",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "避免採用那種測試方法或許會比較好吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夜裡，似似花獨自漫步在月光照耀的沙灘上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊回想著今天所發生的事情。"
    }
]