[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在將各種麻煩化險為夷後，\n順利完成配送郵件的工作返家了。\n而這是發生在隔天的事。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打擾了！",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我是【王宮騎士團】副團長，\n克莉絲提娜‧摩根！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我接獲一則密報，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n指出{player}就生活在這個【咲戀育幼院】的據點！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想見他，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有人可以替我安排嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒有人在啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是不小心，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是有惡徒偷跑進來我可不管啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂～",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有沒有人啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要我放火把你們燻出來嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？　",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦哦，{player}！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n又見面了呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很高興能見到你。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你一臉剛睡醒的表情呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "已經過中午了啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "生活要規律，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "否則上了年紀後你會後悔喔♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不說這些了。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我有點話想和你說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "方便嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別這麼警戒啊……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我沒打算要亂來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個育幼院是咲戀大小姐經營的吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果壞了她的心情會很麻煩。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不會給你添麻煩，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就歡迎我的來訪吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我依照和你的約定，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無罪釋放你了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且昨天的事情，我不但沒有向「王宮」報告，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n甚至也囑咐部下不准外傳你的消息了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也不會留下前科。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我沒打算刁難你、纏著你不放，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "放心吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就是說，我是普通的客人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "希望你可以好歹端杯茶出來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，謝謝。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這用的是便宜的茶葉啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來咲戀大小姐還是老樣子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n明明可以再生活地更奢華點的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "非要過得這麼貧困。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我以前和她在工作上有點關係……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在咲戀大小姐的事情怎樣都無所謂。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是來",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和你談話的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "坐下吧。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "放輕鬆，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是在茶喝完前就能說完的簡短話題。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很好很好，很老實呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼我要說了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這還真的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓人有點難開口啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "{player}。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和我結婚吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……一臉呆愣呢。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這也無可奈何，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟才剛相遇就提結婚也太快了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼說來，你喪失記憶了呢。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你明白什麼是結婚嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "夫婦……",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就是成為相愛的家人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n許下願意永遠陪伴彼此的誓約。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "順帶一提。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要是瞞著喪失記憶的你談下去，就太不公平了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n做那種像欺騙人的事會讓我心生愧疚，所以我先說明。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "依照我國的法律，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結婚對象只能選擇一個人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結婚，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可以說是人生中最為重要的一項誓約。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而我是來拜託你，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "希望你選擇我做為那個對象。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……一臉無法理解的表情呢。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不是自願的啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可沒輕浮到輕易就將自己的人生託付給一個剛認識的男人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是有理由的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我們一族",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有個每年都必須在神前立下一個誓約的習俗。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "違反這個誓約被視為最大的禁忌，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而違反者會遭到整族人的追捕並處刑。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你覺得很荒唐吧？",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也有同感。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但是古老的家世就是會伴隨著這種傳統，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我們團長也是為此才穿著那種粗獷的鎧甲生活。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總而言之，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在我還是可愛少女時，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不小心立下了一個誓約。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是「和碰到我胸部的男人結婚」",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣的誓約。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是出身於地位相當顯赫的家世。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n自第二性徵發育結束那時起，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n向我求婚的親事就如雪片般不停地飛來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這也是古老的家世經常有的",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "政治聯姻。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我那時候還年輕，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還想繼續享受優雅的單身生活。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然而一堆蠢蛋不斷地爭相跑來追求，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我感到很厭煩。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因此我就立下了剛才所說的誓約，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n並且告訴那些求婚者。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想和我結婚的話",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就來碰我的胸部試試。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而我那時候就已經是個最強無敵的女人了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "理所當然，把那些拚命追來的男人全都踢飛了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那些白白淨淨的少爺們拼命地想碰我胸部的樣子，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還真是滑稽呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把我都給逗笑了。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但不久後，因為我實在難以攻陷，所以挑戰者也漸漸消失了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n於是我就徹底把那個誓約給忘了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就在昨天，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我回家後就想起了那件事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然那只是偶然的意外，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但你還是碰到了我的胸部。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而我也不過是為了接住",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "朝我這倒過來的你而已呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但接觸就是接觸。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n遵從誓約，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我必須和你結婚。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明白了吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你有什麼意見嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不好。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我說過了吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不是自願的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是誓約不論是對我們一族，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n或是對我而言，就是代表著「絕對」。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這任何事物都充滿不確定的世界，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n連這都失去絕對性的話，我也會失去能夠倚賴的存在。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "發生那種事的話……",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然我無法說明得很清楚，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且也不像我，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但會讓我很害怕。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們一族必定會遵守誓約，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也是眾所周知的事了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我如果毀約將會造成信用問題，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想避免那個結果……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟我至今給家人添了不少麻煩呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真讓人不爽，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你說沒辦法？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以那種心情結婚，我會很困擾的。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然要結，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也希望你能夠對我有所追求。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那才是對等的契約，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才是所謂的夫婦吧……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了，也罷。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總之，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我「絕對」會遵守誓約。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算你沒有那個意思，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也無論如何都要讓你和我結婚。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我雖然也喜歡強迫他人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但還是想盡可能同時顧及你的意願。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果認為我做為結婚對象有什麼不足的話，別客氣儘管說。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會盡可能地改善。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，要是你說什麼",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在意年齡差距的話，我可是會很傷腦筋的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我今年27歲，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而你大概還是才10來歲的小孩子吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一般而言，應該不會把我當成結婚對象考慮吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只是呢……",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算是我，也無法改變年齡啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種事就算用魔法也束手無策，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "此身經歷過的歲月是不會消失的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這雖然算不上什麼安慰，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算是年齡差距足以當親子的夫妻，在貴族間也並不少見。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了延續一族的繁榮，",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只要到了適婚年齡，就會被迫早早出嫁。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就是討厭那樣……",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才會基於青春期特有的叛逆，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n許下了那種",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以為「絕對」不會被打破的誓約。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了，也罷。",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n想必事出突然也嚇到你了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就給你整理思緒的時間吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過我沒辦法等太久就是了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天我就先打道回府吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明天起……",
        "unit_id": 107111,
        "voice": "vo_adv_1071003_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n為了和你結婚，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會開始想方設法用盡任何手段，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你先做好心理準備吧。",
        "unit_id": 107111
    },
    {
