        "voice": "vo_adv_1264003_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你動不了的話可能很危險喔？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生……♪",
