        "name": "波波爺爺",
        "words": "你們兩位！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n剛才戰鬥的樣子真棒啊！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n小夥子對周圍也觀察得很仔細！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "真了不起！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不過！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_057"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這全都是",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "因為有老夫開發的特製新裝備！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n可別忘了這點喔？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嘎哈哈哈！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然是這麼說沒有錯？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不過充電的部分跟以往都一樣的感覺！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "一、",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_059"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "一樣？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n怎怎怎麼說！？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "只要騎士先生幫我充電，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_060"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "都能暫時變得元氣滿滿！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不管是近是遠都一樣的感覺！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n當然，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "能待在一起我也很開心！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯啊！？",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_061"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這、",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這麼說來是老夫判斷錯誤了嗎？",
