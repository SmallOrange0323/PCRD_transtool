        "voice": "vo_adv_1264003_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "牠們往這裡飛過來了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n仔細一看，都是有翅膀的魔物！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可以嗎？",
