    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蘿茜首次拜訪阿斯特賴亞大陸後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n過了數天──"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "然後呢，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "波波爺爺！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n蘭德索爾",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "有一座非常大的城堡！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n而且",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不是用點心做成的喔！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "聽過很多遍了所以老夫知道。",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_001"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n是用石頭做的對吧？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n真是的，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "妳這陣子都只顧著說蘭德索爾的事情。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "抱歉♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "──啊，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "喂──",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這裡～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "你來了啊，",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_003"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "小伙子！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n等你很久囉！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嘎哈哈，",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_004"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "問得真好！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n事不宜遲，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就讓你看看這傢伙吧！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n老夫開發的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "新裝備──────！！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "鏘鏘鏘鏘～♪",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_005"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "才不是！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_006"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "看起來雖然是這樣，這點老夫不否定喔？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "老夫理解你為什麼誤會！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "但是，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這完全是",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "別的東西！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "畢竟這傢伙是──",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "能連接你和克蘿茜的",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_007"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "特製系統啊！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我和騎士先生？",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_008"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "你看，",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_009"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這個座位前面有個皮帶對吧？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "有了這個啊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "克蘿茜就可以揹上這傢伙。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就像是後揹包一樣的感覺呢！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n然後呢然後呢？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "首先是小伙子坐上座椅！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_011"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n然後接著",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "克蘿茜把小伙子和座椅整個揹起來！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯哼嗯哼！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就像",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "揹小孩一樣對吧？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不要說這麼煞風景的話！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_013"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "跟揹小孩不一樣，妳的雙手可以自由使用喔？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n很方便吧！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這還用得著說嗎！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_014"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n為了要確認你們的可能性啊！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "雖然不曉得原因，",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_015"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "但你確實能幫克蘿茜充電。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "老夫一直在調查機械人族，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "卻都沒有其他像這樣方便的存在。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n……隨便使用太多能量也會被萊拉耶爾殿下罵。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這次的裝備",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_016"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "是為了防止克蘿茜耗盡能量。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n只要經常和小伙子待在一起，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "隨時隨地都能充電！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n所以一定還能附帶",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "力量全開的功能！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "更何況！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_017"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n現在的你們",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "還要一起擊退魔物，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也會一起出門旅行。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n你們稍微貼在一起應該也不會造成問題。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不是嗎？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來如此──！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "確實是這樣呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我們",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "比之前也更有默契了♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好──！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n那麼騎士先生！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們來試試",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "連接系統吧！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿咻！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "坐起來舒適嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n真的嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "總覺得好開心～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊哈哈，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "沒關係！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這也只是實驗！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n完──全不會丟臉喔♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "各就各位了！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_023"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "小伙子，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "幫克蘿茜充電！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "來了來了──！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生的能量",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "直接傳過來了！！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我隨時都能飛喔～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "好了去吧，",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_025"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "你們兩個！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n「騎士組合‧連接系統　",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "揹-揹」！！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "實驗開始──────！！！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "抓緊了喔！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "準……",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "備！",
        "unit_id": 126411
    },
    {
        "type": "still",
        "still": "126400301"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "克蘿茜，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "起飛──！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這是比我以前都還要更厲害的",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "速度呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n說不定比之前在蘭德索爾飛行的時候還要快？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n該不會，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就是因為那時候並沒有在充電的緣故？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的話我們說不定實驗成功了呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "喂喂～！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_030"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n感覺",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "如何！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "狀態極佳──！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_031"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嘎哈哈！",
        "unit_id": 9212,
        "voice": "vo_adv_1264003_032"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這樣啊這樣啊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "果然老夫的判斷沒有錯！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n如何，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "你們暫時先在這附近來回飛看看！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這也是實驗！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好──！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n波波爺爺，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我出發了──♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生騎士先生！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_034"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n雖然已經飛得很好了，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你覺得這個速度可以嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n要再快一點嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那就好！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_035"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n速度如果太快，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "導致裝備壞掉的話就不好了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n啊哈哈♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "而且，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_036"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我好驚訝。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n事實上，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我幾乎沒有這麼長時間飛行過喔～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n噴射器太耗能了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_037"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "緊急時刻！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "的時候才會使用飛行能力！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n萊拉耶爾殿下也是這麼交代的。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "因為我很喜歡在空中飛行，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以還覺得有點遺憾呢……",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n能量耗盡的話就不好了。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n因此原本覺得那也是沒有辦法的事。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就是因為這樣！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n如果沒有遇上騎士先生，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我也就不能像這樣在空中飛行了呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_040"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真心覺得遇到騎士先生真的太好了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_041"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n當然不只是因為",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你會幫我充電喔！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖說這一點",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "當然也很重要……",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯──",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "怎麼說呢……",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我感到非常",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_042"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "非常",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "非～",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "常！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n開心～",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n變得想要",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一直待在一起的程度～♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "畢竟",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_043"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "和騎士先生在一起的話，什麼事情都辦得到！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n而且而且！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "還教會了我許多事情！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "像是擊退魔物的方式，",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "還有其他世界的事情！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我還有好──多不知道的事情！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以，騎士先生！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_045"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n以後也多多教我一些",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我不知道的事情吧！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "謝謝你！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "該不會其實好奇心很旺盛吧？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n啊哈哈，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我連這件事都不知道呢♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n相對的，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「吉歐‧提格尼亞」的事情也都可以問我喔！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們互教對方吧♪",
        "unit_id": 126411
