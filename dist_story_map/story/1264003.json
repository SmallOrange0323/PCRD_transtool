        "voice": "vo_adv_1264003_062"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不過和騎士先生一起在空中飛行，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "超級開心的！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n打起精神來吧！",
        "unit_id": 126411
    },
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就是這麼一回事！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_063"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1264003_064"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我明白了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n妳和騎士的關係",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "似乎很好呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那我就安心了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜，",
        "unit_id": 126511,
        "voice": "vo_adv_1264003_065"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "報告辛苦了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n今天可以退下了喔。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的！",
        "unit_id": 126411,
        "voice": "vo_adv_1264003_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n萊拉耶爾殿下，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我先離開了！",
