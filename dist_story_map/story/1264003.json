    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "阿斯特賴亞大陸。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n從克蘿茜捎來的情報聽起來，",
