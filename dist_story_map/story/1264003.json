        "voice": "vo_adv_1264003_049"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n波波爺爺就在那下面，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "得快點──",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
