[
    {
        "type": "background",
        "background": "501590"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "露營啊……",
        "unit_id": 104715,
        "voice": "vo_adv_6094301_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "來了之後才發現，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這還挺困難的呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n和軍隊野營似乎不同，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像我這種武人也能玩得盡興嗎？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果少年也在這裡，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他會如何",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對現在的我搭話呢……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯。",
        "unit_id": 104715,
        "voice": "vo_adv_6094301_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果是少年，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他一定會這樣對我說吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不要想這些假設性的問題，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "專心地認真休假吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再次開始訓練囉！",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我好像聽到少年的聲音……",
        "unit_id": 104715,
        "voice": "vo_adv_6094301_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不對，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他又不在這裡，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是我多心了吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果是少年，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他應該會積極地去活用過去的經驗。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……我也試著這麼做吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "完全被他影響了呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果是少年，",
        "unit_id": 104715,
        "voice": "vo_adv_6094301_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該會那樣回答吧……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我把事情想得太壞了。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有所自覺就越感到困惑了嗎……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "深呼吸讓自己冷靜一下吧。",
        "unit_id": 104715
    }
]