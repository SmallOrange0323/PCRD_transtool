[
    {
        "type": "background",
        "background": "500743"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}參加滾大球比賽，\n完美展現出了平均水準的活躍。\n之後，他為了和好朋友社的成員會合而獨自徘徊在校園內。"
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "各位好孩子們～！",
        "unit_id": 2913,
        "voice": "vo_adv_1162002_000"
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "\n這裡是開心的射擊遊戲攤位喲～！",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "哎呀，",
        "unit_id": 2913,
        "voice": "vo_adv_1162002_001"
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "那邊的大朋友們，",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "要不要也來試試啊？",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "\n只要用弓箭",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "射中目標，",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "就會送您該獎品喔。",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "是呀，",
        "unit_id": 2913,
        "voice": "vo_adv_1162002_002"
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "當然很好玩。",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "\n來吧來吧，",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "請進請進，",
        "unit_id": 2913
    },
    {
        "type": "dialogue",
        "name": "招攬客人的學生",
        "words": "\n這裡有一位客人喔～！",
        "unit_id": 2913
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很好～",
        "unit_id": 1,
        "voice": "vo_adv_1162002_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我要瞄準那個人偶……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘿！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊啊～",
        "unit_id": 1,
        "voice": "vo_adv_1162002_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "歪掉了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "下一個",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "換姊姊來試試嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哈……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好是好啦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但要是姊姊來挑戰，\n就會因為太過簡單而稱不上是遊戲呀……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嘿！",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "射歪了～！",
        "unit_id": 1,
        "voice": "vo_adv_1162002_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n哈哈……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "好廢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "好廢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不行，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不算不算。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "剛才的不算數。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這根弦",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "狀況太差了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n去叫一下店員來，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我要問這裡的商品是怎麼管理的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "姊姊",
        "unit_id": 1,
        "voice": "vo_adv_1162002_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "妳太幼稚了啦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n惡劣的奧客，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "會被人看出成長環境不好喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "誰怕誰啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我的出生成長環境可沒甚麼好藏的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那只不過是一條居民的混混指數偏高又大而化之的街道而已。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呀！",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嚇我一跳……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼嘛，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來是你……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1162002_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "是姊姊常常帶回家的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "騎士大哥哥！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "弟弟啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你剛才說了什麼？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你給我好好上國語課喔。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "姊姊可還沒嫁人，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好好注意你那種會引人誤會的說法。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "真是的！",
        "unit_id": 1,
        "voice": "vo_adv_1162002_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "大哥哥，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "你這樣不行喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n我們家姊姊",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "只要有人突然從後面搭話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n就會嚇到發出像是萌角色一樣的聲音。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "這樣可是名譽損毀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不用說這些了啦。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好孩子首先應該要好好打招呼。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "你好！",
        "unit_id": 1,
        "voice": "vo_adv_1162002_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n欸欸，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "大哥哥要不要也一起玩～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不用啦，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不用啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這個大哥哥長得一臉很閒，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但其實意外地挺忙的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該說……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真是抱歉呀，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這種時候我卻待在這種地方悠哉地玩。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你問有什麼好抱歉的，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒啦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n明明大家都在關心社團存亡，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很認真地在努力。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n卻只有我在做",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "顧小孩這種",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "悠哉的事。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……真好笑。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那兩個人剛才也對我說了一樣的話。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也是啦，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n畢竟我平常也很少有空陪這些孩子玩，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n至少在這種時候，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我想表現得像個姊姊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喔，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "比較小的弟弟們都在觀眾席，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n他們和我母親一起在休息。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "然後這孩子則是說",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "他想看看遊樂設施類的展覽。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "欸欸，",
        "unit_id": 1,
        "voice": "vo_adv_1162002_023"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "大哥哥～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n好嘛好嘛，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "來跟我們一起玩～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "別扯他別扯他。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你看，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "大哥哥的奇怪斗篷",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "都整個往右歪了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你也是，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_025"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不用在意我們，快走吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我直到下次出場前還有一點時間，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以還不──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "真的嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_1162002_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n太棒了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "可以跟大哥哥玩～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉──真是的……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你可以不用",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼顧慮我們啦……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總覺得……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我家的孩子們",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "已經完全黏上你了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你明明只有",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "來我家一兩次而已。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_1162002_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "姊姊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "妳把他帶回家很多次了吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "弟弟。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_030"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以就說了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不要輕易地說什麼「帶回家」好嗎。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你是從哪裡學來這種話的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "這個嗎，",
        "unit_id": 1,
        "voice": "vo_adv_1162002_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "是切嚕大姐姐說的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……那傢伙該禁止入境了。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n她對小孩子的教育有不良影響。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "我跟你說，",
        "unit_id": 1,
        "voice": "vo_adv_1162002_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "大哥哥！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n聽說外面有遊樂園喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n我們趕快過去吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "快點快點！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以說了，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_034"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "別拉他的奇怪斗篷啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n大哥哥整個人看起來都變得不對稱了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_035"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "看起來有點像是暗黑騎士，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好像也不錯……？",
        "unit_id": 116211
    },
    {
        "type": "background",
        "background": "501280"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "哇，",
        "unit_id": 1,
        "voice": "vo_adv_1162002_036"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "好厲害喔～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "是遊樂園～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哦哦……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_037"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n真可愛，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的就像是迷你遊樂園一樣。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你不知道遊樂園嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "在那裡可以搭乘魔法控制的高速貨車，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "從很高的地方一口氣掉下來，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n還可以搭著長翅膀的馬型魔像，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "漂浮在天上──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒錯。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "遊樂園就是聚集了很多那種有趣設施的地方，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n而這裡算是它的簡易版，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還是該說是人力版？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "大概就是這種感覺吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話雖如此，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_040"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這裡的規模也只有原型的十分之一而已。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣也不錯吧，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這對小孩子來說尺寸剛剛好。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n嗯，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "以學生手工重現的結果來說，已經算是很努力了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_041"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我就說了這是給小孩子玩的了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你別搭啦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "年紀都這麼大了──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "──啊啊不對，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_042"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是這樣的吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你不是想玩，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而是願意陪我家的孩子玩，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是這樣對吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_043"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "謝啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你以後",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該會成為一個好父親吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然我也不太清楚啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真是太好了呢，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "大哥哥說願意和你一起搭喔。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那麼，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你想搭哪個設施？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "唔唔……",
        "unit_id": 1,
        "voice": "vo_adv_1162002_045"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼了，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你在猶豫嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "嗯……",
        "unit_id": 1,
        "voice": "vo_adv_1162002_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n雖然很想搭……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "但感覺有一點可怕。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你聽到了嗎？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n他說會怕這種像是公園的遊樂器材一樣的手工遊樂設施欸。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然說話口氣很大，畢竟還是小孩子嘛。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我家弟弟，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很可愛對吧？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你看看，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_049"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "大哥哥難得看起來很可靠喔。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這傢伙會看起來可靠，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可是超稀有的事喔？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好啦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你就跟他一起去搭吧～？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "嗯……",
        "unit_id": 1,
        "voice": "vo_adv_1162002_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n那不然這樣好了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "我在旁邊看著！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n姊姊妳和他去搭！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，太詭異了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "為什麼啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那樣不就沒有意義了嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你說的話，就跟「我肚子餓了所以姊姊妳去吃吧」",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是一樣意思欸。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "這是試毒啊。",
        "unit_id": 1,
        "voice": "vo_adv_1162002_052"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n姊姊你們去試搭",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "看會不會死掉。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_053"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你這傢伙說什麼鬼話啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你要是以為什麼話都用小孩子天真的語氣說出口就會被原諒，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那可大錯特錯了喔？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "啊～",
        "unit_id": 1,
        "voice": "vo_adv_1162002_054"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "姊姊妳會怕對吧～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "與其說是害怕，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_055"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我是覺得很丟臉啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我不是說了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是給小孩子搭的嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不對，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_056"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我不是這個意思啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你不用現在重複之前的可靠台詞。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……奇怪？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_057"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n話說這個男的難道……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不是為了顧小孩，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只是單純自己想玩？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "然後啊，",
        "unit_id": 1,
        "voice": "vo_adv_1162002_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "就是啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "我想想……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "我想搭那個！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "你們去搭那個！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哪個？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_059"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "那個！",
        "unit_id": 1,
        "voice": "vo_adv_1162002_060"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "那個唰──地用水滑下來的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "這邊的設施是",
        "unit_id": 3112,
        "voice": "vo_adv_1162002_061"
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "迷你滑水道喲～！",
        "unit_id": 3112
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "\n可以搭著迷你小船",
        "unit_id": 3112
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "享受從迷你水道滑下去的感覺喔～！",
        "unit_id": 3112
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哦～",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_062"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "滑水道和人工水池呀。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n原來如此，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "居然還建造了這麼費工的東西……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，船好小！",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_063"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不行這擠不進去吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n兩個大人搭那艘船，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很明顯會超載呀。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "姊姊你們不是大人吧！",
        "unit_id": 1,
        "voice": "vo_adv_1162002_064"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n你們正處於既不是小孩也不是大人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "這種不穩定的年紀不是嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你真的都是從哪裡",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_065"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學來那些話的啊？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是粉紅女嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "又是那個粉紅女嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "不是，",
        "unit_id": 1,
        "voice": "vo_adv_1162002_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "這是看起來很優妮的姐姐說的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "別說了快去搭吧！",
        "unit_id": 1,
        "voice": "vo_adv_1162002_067"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n姊姊和大哥哥，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "你們兩個人去搭～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就算你這麼說……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_068"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n{player}你應該也",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不想要兩個人搭那個吧？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_069"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不對等等，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_070"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你在說什麼啊？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n等一下，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你冷靜思考看看，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n兩個大人",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼一起搭那艘兒童尺寸的船──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "太棒了～！",
        "unit_id": 1,
        "voice": "vo_adv_1162002_071"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n大哥哥說OK欸！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "很好，姊姊也確定要搭了～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哈～～～！？",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_072"
    },
    {
        "type": "still",
        "still": "116200201"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "…………",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_073"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……真的假的。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_074"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣會不會很不妙啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就各方面而言。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "來吧，",
        "unit_id": 3112,
        "voice": "vo_adv_1162002_075"
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "兩位大朋友，",
        "unit_id": 3112
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "\n請你們抓好囉～！",
        "unit_id": 3112
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等……！",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_076"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喂店員，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不要推我。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我不是都說了",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_077"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我還沒嫁人嗎。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣子",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "畫面看起來好像會很不妙欸……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n喂，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的沒問題嗎……？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "姊姊，",
        "unit_id": 1,
        "voice": "vo_adv_1162002_078"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "妳怎麼突然變安靜了啊～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "少囉嗦。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_079"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n要是在這個狀態下還吵吵鬧鬧的，那不就只是單純的情侶放閃嗎。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "笨……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_080"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "白癡喔，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不要搖啦！",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_081"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你為什麼可以",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼保持平時的態度啊？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我覺得你這樣也是有點問題喔。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_082"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你覺得沒問題的話，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那倒是",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "無所謂啦……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "唔，",
        "unit_id": 3112,
        "voice": "vo_adv_1162002_083"
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "是愛情喜劇的氣氛……！",
        "unit_id": 3112
    },
    {
        "type": "dialogue",
        "name": "擔任工作人員的學生",
        "words": "好了快結束吧咚──！",
        "unit_id": 3112,
        "voice": "vo_adv_1162002_084"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哇啊啊啊啊！",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_085"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "────"
    },
    {
        "type": "background",
        "background": "500970"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "哇～",
        "unit_id": 1,
        "voice": "vo_adv_1162002_086"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "好有趣喔～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是喔……",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_087"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那太好了……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n要是這樣還沒能讓你覺得開心，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n就算你是親弟弟我可能也要擔心會留下禍根了……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喔喔，",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_088"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不要緊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這點程度",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對發熱的身體來說剛剛好。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_089"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不對，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說身體發熱，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可沒有",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼奇怪的含意──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "什麼是奇怪的含意～？",
        "unit_id": 1,
        "voice": "vo_adv_1162002_090"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "別吵。",
        "unit_id": 116211,
        "voice": "vo_adv_1162002_091"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "夠了啦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你去那邊和大哥哥一起玩吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "快走快走。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蘿依雖然故作鎮定，仍然滿臉通紅。"
    }
]