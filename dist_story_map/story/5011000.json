        "voice": "vo_adv_5011000_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓牠結出美味的可可亞果實。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後，",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
