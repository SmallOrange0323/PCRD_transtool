    {
        "type": "dialogue",
        "name": "可可亞烏拉",
        "words": "巧克♪",
        "unit_id": 10911,
        "voice": "vo_adv_5011000_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你說牠不就是魔物嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對啊，",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "牠是一種叫做可可亞烏拉的魔物寶寶。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我現在",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "正在幫牠澆水照顧牠。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你問我養牠的理由？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "牠的尾巴是可可亞的幼苗對吧？",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聽說只要用幸福的話語來養育牠，",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這裡就會結出美味的可可亞果實喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後，",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "使用那個可可亞的話，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n似乎就能做出讓吃的人變幸福的",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "頂級巧克力『LoveDestiny』！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來，",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你看這裡！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n看起來",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是不是再過一陣子就要結出可可亞的果實了？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以這步調來看，似乎有足夠的時間能趕在情人節之前結果。",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？　",
        "unit_id": 101112,
        "voice": "vo_adv_5011000_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難道說哥哥，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你不知道情人節嗎！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不是不是，",
