[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生，",
        "unit_id": 104511,
        "voice": "vo_adv_5084641_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你要何時才會醒來呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖然空花一開始以為這是像平常那樣的放置玩法……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但看來似乎不是這樣。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……唉。",
        "unit_id": 104511,
        "voice": "vo_adv_5084641_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n因為擔心而感到苦悶，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n就算是空花也興奮不起來……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "難、",
        "unit_id": 104511,
        "voice": "vo_adv_5084641_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "難不成……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這也是虐待狂先生的作戰嗎……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為了使空花自己體會到，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花有多希望受到虐待狂先生的凌辱……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "之類的。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這是自己束縛自己的玩法吧！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花會乖乖照做的……",
        "unit_id": 104511,
        "voice": "vo_adv_5084641_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n所以，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請快點、快點來玩弄空花喔……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生……",
        "unit_id": 104511
    }
]