[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "久違地",
        "unit_id": 105811,
        "voice": "vo_adv_9020155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "深入森林獲取食材，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓人覺得好雀躍呀☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過說起來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如此珍貴的森林果實，竟然會有魔物要獨佔……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這種吃個沒停的習慣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺就像是我們呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105911,
        "voice": "vo_adv_9020155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那邊有隻很大的狸貓。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n肉量相當地好，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這種荒野環境下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "毛髮卻相當艷麗蓬鬆……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該就是之前提到的魔物不會錯了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來沒什麼精神啊……",
        "unit_id": 106011,
        "voice": "vo_adv_9020155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得對我們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "興趣缺缺的樣子。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該是除了吃之外什麼都沒想吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟那個誰一模一樣嘛。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811,
        "voice": "vo_adv_9020155_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳是在指誰啊……！？",
        "unit_id": 105811
    }
]