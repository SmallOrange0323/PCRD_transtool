    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了建造新的「鳳凰的庭園」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與鳳凰在吉歐‧格黑納逗留中──"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咿咿────────！",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_000"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n為什麼",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "每次每次都這樣",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "真是的────────！！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "吵死了！",
        "unit_id": 52111,
        "voice": "vo_adv_1347003_001"
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "別逃了快讓我吃吧────！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "不對！",
        "unit_id": 50611,
        "voice": "vo_adv_1347003_002"
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "要吃的是我！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "快給我讓出來！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為何、",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_003"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為什麼總是以吃我為前提啊！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你們那嘴巴是專門用來吃的嗎！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n用來稱讚我不是比較好嗎啊～～！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "聽好囉！？",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_004"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n雖然我現在是這副模樣，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n但我其實",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "是身為青空霸主的──",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "我當然知道。",
        "unit_id": 52111,
        "voice": "vo_adv_1347003_005"
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "妳是六凶其中之一的",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "萬花菲尼克斯吧？",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "就是那樣！",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_006"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咦？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n那、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你們是知道了",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "還想吃我？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "有傳聞說",
        "unit_id": 50611,
        "voice": "vo_adv_1347003_007"
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "只要吃了妳，就能獲得強大的力量呢。",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "\n滋養強壯不在話下，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "要是毛髮跟排便都能變得滑順，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "\n那我可不能放過啊！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "來，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "成為我的養分吧！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "竟然想把這偉大而優雅的我",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_008"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "當成營養餐……！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我可不打算變成妳的膳食纖維喔！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "啊，",
        "unit_id": 52111,
        "voice": "vo_adv_1347003_009"
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "等等！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "給我等一下！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "\n──",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "啊啊可惡，",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "別拍拍翅膀飛走啊～！",
        "unit_id": 52111
    },
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……唔唔，",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_010"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我好震驚……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "他們明明應該知道我真實的模樣，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "還對我實施那種暴行！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n現在的我",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "別說是不死鳥了，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "甚至連信天翁都不如嗎！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "別說是被當成神明了，",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_011"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我甚至不被當成妖魔人看待嘛──！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我還是真實模樣的時候，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "他們明明那麼惶恐的～～～",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "開心的",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_012"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "事……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "跟貪吃佩可她們",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "泡溫泉之類的？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "跟拿娜",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "分享好喝的飲料，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "跟克蘿茜一起在天上飛，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "還有……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……也、",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_013"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "也算是",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不全然只有壞事呢。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n也有因為是這個模樣",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "才能辦到的事……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你是想這樣說吧？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那、",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_014"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那兩件事能算開心嗎……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咳咳。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n總之，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你是想鼓勵我吧？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "好吧。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "看在你那份心意上，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我會打起精神的♪",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "…………",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_015"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "謝謝你，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "騎士先生。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我先",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_016"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "試著跟剛剛那些人談談吧。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n既然要在這片土地上活下去，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我也不能光是四處逃竄。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "騎、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "騎士先生，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你想要跟我一起去談",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "的權利吧？",
        "unit_id": 134712
    },
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那個……",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_017"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咳咳。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "各位────",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你們聽著！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "偉大而優雅的本人我，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "有重要的事要──",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "吵死了！",
        "unit_id": 52111,
        "voice": "vo_adv_1347003_018"
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "閃遠一點啦鳥仔！！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "鳥、",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_019"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "鳥仔！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "唔，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咦？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "總覺得村子好像",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "比平常還更混亂耶。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "狩獵不死鳥，",
        "unit_id": 50611,
        "voice": "vo_adv_1347003_020"
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "等跟這傢伙做完了斷後再說！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咦咦！？",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_021"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "同、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "同伴之間起內鬨了！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "我們原本就不是什麼夥伴啦！",
        "unit_id": 52111,
        "voice": "vo_adv_1347003_022"
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "\n她每次都搶我們的獵物，",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男流氓",
        "words": "我已經受夠了！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "那是我的台詞才對！",
        "unit_id": 50611,
        "voice": "vo_adv_1347003_023"
    },
    {
        "type": "dialogue",
        "name": "女流氓",
        "words": "\n我今天非讓你好看不可！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "男流氓‧女流氓",
        "words": "要打就來打啊啊啊啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_1347003_024"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "啊哇哇……",
        "unit_id": 134712,
        "voice": "vo_adv_1347003_025"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不只那兩人，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "到處都有爭鬥！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n這已經是戰爭狀態了吧！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
