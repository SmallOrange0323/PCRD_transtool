        "words": "喵呵呵，",
        "unit_id": 125111,
        "voice": "vo_adv_6114207_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "店裡來客絡繹不絕，盛況空前喵♪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n貓咪職員牠們也都工作得很開心喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想好好謝謝很努力的莫妮卡……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "該怎麼謝她喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "跟貓拳一樣說得有夠直接喵！",
        "unit_id": 125111,
        "voice": "vo_adv_6114207_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……咖啡廳的工作很開心，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就跟莫妮卡合作，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n往後也要努力拼喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "當然",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你也要一起陪我們",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵♪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好主意喵！",
        "unit_id": 125111,
        "voice": "vo_adv_6114207_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只要吸貓咪的肚肚，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不只是光覺得有益健康，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就算沒實質解決各種煩惱，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n卻覺得一切都無所謂了喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就讓她盡情吸貓喵～",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵！？",
        "unit_id": 125111,
        "voice": "vo_adv_6114207_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要我一個人顧整間店喵！？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚嗚，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是讓莫妮卡累癱而店休的話，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就本末倒置了喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我就配合",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你的提議喵！",
        "unit_id": 125111
    }
]