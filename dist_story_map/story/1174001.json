[
    {
        "type": "background",
        "background": "500840"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在慈樂之音巡演中的某個夏日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n紡希趁著休假時間，悄悄參加了一場海釣活動──"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "噁嗚……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好不蘇胡……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可沒聽說過",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "船會這麼晃啊……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "仔細想想，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "昨天的演唱會表演到很晚……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "又趁著日出前搭上船，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "以睡眠不足的狀態出海，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "會這樣也難怪啦……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難得怜大人向我推薦了這裡，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明天就要離開了，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只有今天才有機會去……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "小姑娘。",
        "unit_id": 1411,
        "voice": "vo_adv_1174001_003"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n妳蹲在這種角落……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "是暈船了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "船長先生，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不好意思讓你擔心了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "別在意啦。",
        "unit_id": 1411,
        "voice": "vo_adv_1174001_005"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "暈船這種事人人都要經歷過的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "話說回來，小姑娘妳……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "好像有點眼熟啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "……對了對了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "妳長得像那個慈樂之音偶像團體裡的──",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔呃！？　",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_006"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "哇啊！？",
        "unit_id": 1,
        "voice": "vo_adv_1174001_007"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "釣竿突然變重了！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n船長先生──！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "這該怎麼辦啊──！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "哦！",
        "unit_id": 1411,
        "voice": "vo_adv_1174001_008"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "上鉤啦！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n就保持那樣，別鬆開手啊──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "船長先生。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我只要稍微休息一下就好了，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你去幫那個人吧……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "這樣啊。",
        "unit_id": 1411,
        "voice": "vo_adv_1174001_010"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "那",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "如果真的覺得撐不住了， ",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "要跟我說喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "慈樂之音的偶像要是露出這種醜態",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是會讓人幻滅的。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我絕對不能暴露身分……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "或許就是因為想著不舒服才覺得不舒服。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "試著把大腦放空，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "眺望海景或許會好一點──",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個女生穿的是現在正流行的連身泳裝！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們店裡要不要也來做做看呢？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "至於設計嘛──",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "噁……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不行不行，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "想事情只會讓自己更不舒服……！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看來只剩下",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "閉眼休息這個辦法了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "意識越來越模糊了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這下真的不妙了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣下去……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是的……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我沒事。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不好意思",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓你擔心了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛才的聲音是……",
        "unit_id": 117411
    },
    {
        "type": "background",
        "background": "500840"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你怎麼在這裡……？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……那杯水",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是要給我的嗎……？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就不客氣了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n多虧了騎士先生，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我稍微好點了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚呀！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……我、",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我沒事。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然剛才晃得很厲害，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但多虧了騎士先生扶住我，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我才沒有跌倒……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……………………我要吐了。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給你添麻煩了！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "糟透了……！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "竟然讓騎士先生看見了我這麼難堪的一面……！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是真的在為我擔心呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他也不是什麼壞人，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我現在應該要坦率地……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是的，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "託你的福，我已經好多了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這下應該也能重新去釣魚了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──什麼？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你問我想釣什麼魚？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那當然是",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人之前釣過的那種魚啦♪",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人給我看了魚的拓本，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那似乎是只存在於這片海域中，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "擁有七彩鱗片的魚喔！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也想釣一隻大魚，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "做成魚拓，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓怜大人誇獎我♪",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生也是！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……你們兩個是釣友，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "常常一起去釣魚？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………收、",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "收回前言！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生是對怜大人不懷好意的",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "卑鄙",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "無恥之徒！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n竟然偏偏是",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和怜大人釣魚約會！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我才不會",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "輸給騎士先生！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們就來比比看誰能釣到",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "配得上怜大人的魚吧！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "首先是綁魚鉤！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哼，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我已經事先研究過綁法了！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我記得……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "釣魚線要這樣……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔唔──",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不像釣魚線跟縫衣線不太一樣呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣繞對不對啊……？　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幹嘛呀",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我現在很忙，能不能別和我說話──",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "「這次只需要打簡單的繩結就行了？」",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……真的耶。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生的綁法簡單易懂。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼嘛，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那種程度的結我也能輕鬆完成！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "竟然被幫助了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過僅此一次！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "僅此一次而已！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "綁好魚鉤了！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼就馬上來釣魚吧！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n嘿！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來吧來吧！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "比騎士先生的還大的魚！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………釣不起來呢。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "引誘……？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊啊！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要像騎士先生那樣",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "晃動釣竿就行了吧！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我試試看！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不對啦！！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你一直關注我的話，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "自己就沒時間釣魚了喔！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你又說這種話……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這發言真有騎士先生的風格。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n自顧自地懷抱著競爭心理的我，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "簡直就像個笨蛋……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我知道了啦。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_055"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，擺出一副「不用你教」的態度，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n卻又厚臉皮的接受你的好意，這種行為太無禮了，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以我重新說一遍。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………請你，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "教我怎麼釣魚。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我又錯過揚竿時機了！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我下次一定會釣到……！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "多虧了騎士先生，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我有抓到一些訣竅囉！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好像變得有趣起來了♪",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是是。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我不會再因為這種話動搖了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚哇哇！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n釣竿突然……！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這感覺是條大魚呢！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "太重了拉不起來……！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_063"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這、",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_064"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這有點貼太近了吧！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n嗚嗚，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "別去在意！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "專心專心！！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚唔唔……",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還差一點點……！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "太棒了──！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "釣上來了──！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "彩色的魚！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_067"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且非常大條喔！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是啊！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_068"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "喔，",
        "unit_id": 1411,
        "voice": "vo_adv_1174001_069"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "終於釣到啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "而且相當大條啊！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "這說不定破了新紀錄呢！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的嗎！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_070"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "機會難得，",
        "unit_id": 1411,
        "voice": "vo_adv_1174001_071"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "要不要做個魚拓？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當然要！",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……呵呵，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果怜大人看到了，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定會誇獎我吧♪",
        "unit_id": 117411
    },
    {
        "type": "background",
        "background": "500841"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "這樣就行了。",
        "unit_id": 1411,
        "voice": "vo_adv_1174001_073"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "接下來只剩",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "寫下小姑娘的名字啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_074"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也寫上騎士先生的名字吧。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_075"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有什麼好驚訝的。",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_076"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我話先說在前頭，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你沒有否決權喔。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我可不想獨攬功勞。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過下次，",
        "unit_id": 117411,
        "voice": "vo_adv_1174001_077"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我一定會憑自己的力量釣到魚！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希露出惡作劇般的笑容，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n珍惜地捧著"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "盛滿兩人回憶的魚拓。"
    }
]