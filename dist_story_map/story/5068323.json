[
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳的動作很靈活喔，",
        "unit_id": 116911,
        "voice": "vo_adv_5068323_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "小碧！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n雖然長得一樣，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但終究是仿造品。",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們不可能會輸在效率上！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "唔唔唔……",
        "unit_id": 14912,
        "voice": "vo_adv_5068323_001"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "真的跟妳們說的一樣",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "嗎……？",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n是我",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "錯了……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "嗎……？",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n可是……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "妳們為什麼",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "要為我做到這種地步……？",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是的……",
        "unit_id": 116911,
        "voice": "vo_adv_5068323_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你還不懂嗎？",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "當然是因為",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們是真的為你……",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還有為孩子們著想啊！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒、",
        "unit_id": 116713,
        "voice": "vo_adv_5068323_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "會為對方著想，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "才叫做友情不是嗎……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以……",
        "unit_id": 116713,
        "voice": "vo_adv_5068323_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你要不要先跟我們交朋友，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n從頭開始拓展朋友圈呢……？",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就、",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就大家一起攜手前進吧……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "可是……",
        "unit_id": 14912,
        "voice": "vo_adv_5068323_005"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "可是……！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n我已經親手弄哭了孩子們！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n我已經破壞了友情！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "終於到關鍵時刻了……！",
        "unit_id": 116911,
        "voice": "vo_adv_5068323_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n再一次重視效率行動吧！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "妳沒問題吧，",
        "unit_id": 7311,
        "voice": "vo_adv_5068323_007"
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "碧？",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "\n我相信妳",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "不可能會在這裡輸給它！",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯！",
        "unit_id": 116713,
        "voice": "vo_adv_5068323_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要讓它變回溫柔的玩具王……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我會以朋友的身分，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和它握手言和的……！",
        "unit_id": 116713
    }
]