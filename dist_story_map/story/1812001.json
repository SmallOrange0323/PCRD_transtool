[
    {
        "type": "still",
        "still": "181200101"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「──喜歡你。」",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……說出口了。",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_001"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──在那之後，",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "究竟過了多久呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那天，",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "當我把大家送回原本的世界後，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n原本以為意識會連同身體一起消失，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但卻不知為何",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有完全消散。",
        "unit_id": 106412
    },
    {
        "type": "background",
        "background": "501820"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "彷彿像是安穩地睡在一個",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "什麼都沒有的地方。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n死亡",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會不會就是這種感覺呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是說……",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為我是「末端裝置」，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n消失前",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "才花了比較多時間……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……至今為止發生了好多事呢。",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不管是快樂的事，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是痛苦的事，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n感覺全都在轉眼間就過去了。",
        "unit_id": 106412
    },
    {
        "type": "still",
        "still": "181200102"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一開始",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "變得跟小嬰兒似的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n真的什麼都辦不到。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n給【美食殿堂】的大家添了好多麻煩。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n當時大家都沒有怨言，接受了那樣的我。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那份溫柔就像家人一樣，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓人感到很舒服。",
        "unit_id": 106412
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "181200103"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以當我恢復明確的自我意識，",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n正式成為【美食殿堂】的夥伴時，真的好高興──",
        "unit_id": 106412
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "501600"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "然而當發現自己是厄莉絲的「末端裝置」時，",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我真的大受打擊，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "覺得很對不起大家……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n甚至想要直接從世界上消失。",
        "unit_id": 106412
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "既便如此……",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "正因為我是「末端裝置」，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "才能遇見大家──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n也才能在最後",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "幫助到大家。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這點是不變的事實。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然不能說沒有感到後悔……",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但那時我已經盡全力，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "去做到自己能做的事情了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n直到現在，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個想法都沒有改變。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n正因為現在一切都結束了，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "才會忍不住去想像。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我有更強大的力量呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n如果",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還有下一次機會呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我一定可以──",
        "unit_id": 106412
    },
    {
        "type": "still",
        "still": "181200104"
    },
    {
        "type": "background",
        "background": "501820"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}……？",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你會在這裡？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這裡",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又是什麼地方……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難不成",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是我在作夢嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是說……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "失敗了？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我還以為",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有趕上時間讓你登出……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "回到現實世界去。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難道說",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是被捲入再再構築了嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n而且不只是你，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就連其他人也……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又為什麼……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "原來是這麼回事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為了找到我，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "【美食殿堂】的各位來到了背面世界。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而如今，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "正在跟名為阿剌克涅女士的敵人戰鬥……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個叫阿剌克涅的人，",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真不可原諒。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n竟然操縱大家，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓夥伴們互相傷害。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不僅如此……",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "竟然以看著被操縱的人痛苦為樂，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這絕對是錯的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "被那種狡猾的人當作人質……",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "彷彿就是在凸顯我有多麼的無力，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好不甘心……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只要跟著你離開這裡，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我就能一起戰鬥，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n並幫上大家的忙，對吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那麼，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我就要戰鬥！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我可沒有辦法默默看著",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_025"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "重要的人們受到傷害。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "必須讓對方明白，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "別人可不是她的玩具！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那是我該說的話。",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_026"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我……",
        "unit_id": 106412,
        "voice": "vo_adv_1812001_027"
