        "words": "走在鬧區裡的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聽見有人從暗處叫自己便環顧四周。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂……",
        "unit_id": 1,
        "voice": "vo_adv_9006012_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這邊這邊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n嘿嘿……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你好呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n太好了～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "幸好有找到你♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "努力調整工作",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓今天休假是值得的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "畢竟今天是個特別的日子呀。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的！",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你的mimi也有收到通知的吧？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天是我和你在阿斯特朗傳奇第一次相遇的日子。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對，",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是個非常重要的日子……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "遇見你之後，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "阿斯特朗傳奇對我來說，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n變成了很特別的地方。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個時候",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的很抱歉。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n給你添了很多麻煩……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_9006012_005"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "你看那邊那個是不是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n望望？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_9006012_006"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "真的耶……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "是望望！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "\n哇～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "好棒哦～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈……",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被認出來了呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不好意思！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在是私人行程……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "那個！",
        "unit_id": 1,
        "voice": "vo_adv_9006012_008"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "能跟妳一起拍照嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n可以的話，幫我簽名好嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n我會視為寶物的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒辦法了。",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這種時候……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只能逃囉！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "走吧，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "快點！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_9006012_010"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "等一下呀，望望！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "\n別逃跑呀～！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈！",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你記得嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們第一次相遇的時候，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也是這樣一起逃跑了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總覺得有些懷念……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現實的世界",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就沒有辦法像阿斯特朗傳奇那樣",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跑個不停了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們在那邊的公園躲一下吧。",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也想休息一下……",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我有點累了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "樣？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n順利甩掉了嗎……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！？",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯？",
        "unit_id": 1,
        "voice": "vo_adv_9006012_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n什麼呀……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然讓晶給逃掉了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但這不是遇到有趣的傢伙了嗎。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了，小子。",
        "unit_id": 107131,
        "voice": "vo_adv_9006012_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看上去像逃犯一樣疲憊不堪，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是被殺手盯上了嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個人……",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難道是",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "克莉絲提娜‧摩根！？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你們",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "認識嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯，",
        "unit_id": 107131,
        "voice": "vo_adv_9006012_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就是克莉絲提娜‧摩根。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這位小姑娘……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我好像見過。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "她剛才是跑進這個公園吧？",
        "unit_id": 1,
        "voice": "vo_adv_9006012_021"
    },
    {
        "type": "dialogue",
        "name": "粉絲3",
        "words": "望望真的在這裡嗎？",
        "unit_id": 1,
        "voice": "vo_adv_9006012_022"
    },
    {
        "type": "dialogue",
        "name": "粉絲3",
        "words": "\n唔喔──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲3",
        "words": "我都興奮起來了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇哇，",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "居然追上來了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且人數比剛才還多耶！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔……",
        "unit_id": 107131,
        "voice": "vo_adv_9006012_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我大概掌握情況了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但用跑的逃走",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不是一個聰明的方法啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好吧！",
        "unit_id": 107131,
        "voice": "vo_adv_9006012_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那就讓克莉絲提娜我來助妳一臂之力吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實際上應該要怎麼應對……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳可要看清楚了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗨，",
        "unit_id": 107131,
        "voice": "vo_adv_9006012_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "日本的朋友們。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你們拿著相機在這個地方做什麼呀？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難道是",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想和克莉絲提娜‧摩根我",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拍合照嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "咦，",
        "unit_id": 1,
        "voice": "vo_adv_9006012_028"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "咦咦？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "沒頭沒腦的說什麼啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n呃，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "她剛剛說她是克莉絲提娜‧摩根嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n那個超級名流！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是來拜訪朋友的，但他好像不在。",
        "unit_id": 107131,
        "voice": "vo_adv_9006012_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n實在是太無聊了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想找個人拍雙人合照。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼樣？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那邊的小姑娘？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "嗯……",
        "unit_id": 1,
        "voice": "vo_adv_9006012_030"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "那可以請妳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "和我拍雙人合照嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "\n我不會傳到網路上的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵……",
        "unit_id": 107131,
        "voice": "vo_adv_9006012_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不用",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "顧慮那麼多。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這可是和我拍的雙人合照呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "儘管傳到網路上向大家炫耀吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "粉絲3",
        "words": "可以嗎？",
        "unit_id": 1,
        "voice": "vo_adv_9006012_032"
    },
    {
        "type": "dialogue",
        "name": "粉絲3",
        "words": "\n那我也想麻煩妳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲3",
        "words": "和我拍合照！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好、",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好厲害啊……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這已經不只是在提供粉絲服務了，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n而是不斷製造出新粉絲……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊、",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是呀！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n趁克莉絲提娜在幫我們轉移注意力的時候……",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跑到這裡來應該就沒問題了吧……",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "話說回來，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她真的好厲害呀。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n真不愧是聞名世界的超級名流……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那樣的應對能力",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是我所缺少的嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不……",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也還差得遠呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n得更加努力才行！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102931,
        "voice": "vo_adv_9006012_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到時候希望你能在我身邊。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果和你在一起，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我一定可以更加耀眼……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以，今後",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你也要在離我最近的地方為我加油打氣哦♪",
        "unit_id": 102931
    }
]