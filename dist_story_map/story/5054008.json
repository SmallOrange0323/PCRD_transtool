[
    {
        "type": "background",
        "background": "500876"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望眼環視變得一團糟的派對會場後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n秋乃與咲戀大大地嘆了口氣。"
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "……唉。",
        "unit_id": 1,
        "voice": "vo_adv_5054008_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒想到雪人會爆炸，",
        "unit_id": 114511,
        "voice": "vo_adv_5054008_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n把聖誕樹都給燒掉了……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也就是說，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "魔法玫瑰全～部都被燒光了吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是啊，",
        "unit_id": 114411,
        "voice": "vo_adv_5054008_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "當然那也是顆很寶貴的聖誕樹，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但對大家而言，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "更是共同培育愛的重要回憶……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n也有人因此感到很沮喪呢。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算是我這個超超有錢人，",
        "unit_id": 114411,
        "voice": "vo_adv_5054008_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也沒辦法把燒成",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "焦黑的玫瑰復原，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只有這件事……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是任誰",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "都無可奈何呢。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 114511,
        "voice": "vo_adv_5054008_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "並不是只有壞消息！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳想想，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "已經抓到那個賈斯頓了對吧？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但不曉得為什麼",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他會變成全身焦黑……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗯。",
        "unit_id": 114411,
        "voice": "vo_adv_5054008_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是美冬和珠希她們告訴我的，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n聽說是有個巨大雪人的頭從天而降，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "正巧直接命中那個大盜。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n……那恐怕",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是我們打倒的",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個雪人的頭吧。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嘿～",
        "unit_id": 114511,
        "voice": "vo_adv_5054008_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有這麼巧的事情呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不如說，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這算是近似奇蹟了？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "誰叫他想偷走別人的愛，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大概是得到天罰了吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉，",
        "unit_id": 114511,
        "voice": "vo_adv_5054008_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺好累人。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n差不多該準備回去了吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……這麼說來，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那傢伙跑哪裡去了？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "噢，",
        "unit_id": 114411,
        "voice": "vo_adv_5054008_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "他被薔薇假面叫走了。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "唉…………",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_009"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "啊啊，",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_010"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "灰姑娘男孩。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "不好意思，突然找你過來。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n我想清理被燒掉的聖誕樹，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n可以請你幫忙嗎？",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "真抱歉。",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_011"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n一看到這散落一地的魔法玫瑰，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n我就怎麼也提不起勁來……",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "……其實啊，",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_012"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n我認為，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "是這些魔法玫瑰，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n保護了各位不受",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "那個雪人爆炸的波及。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "那個時候，",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_013"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "我確實看見了。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n有道不可思議的光芒",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "籠罩了所有人……",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "我想那道光芒，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n一定就是各位彼此思慕的心意吧。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "灰姑娘男孩……",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_014"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "我再次感謝你",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "能夠參加今天的派對。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n背負蘭德索爾未來的年輕人們，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "讓我看見了",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n以愛互相連結，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "以愛勇敢面對，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "共同演出了這樣的奇蹟。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "但是，",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_015"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "對大家來說，今天的回憶",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n就像這朵因為惡意而被燃燒殆盡的玫瑰一樣。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "我想一定會",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "變成悲傷的記憶吧。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "希望至少",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_016"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "能將發生奇蹟的瞬間，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n化為這些玫瑰",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "曾經美麗綻放的模樣，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "留在大家的記憶裡……",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n但是，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "這也已經是無法實現的夢想了呢。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "你說可以，",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_017"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "是什麼意思呢……？",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "……嗯嗯。",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_018"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "原來如此，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "你所說的梗概",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "真是令人感興趣。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n凡事有萬一，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "那奇蹟或許值得",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "讓人賭一把。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "請把你的計畫全部告訴我。",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_019"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n有任何需要，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "我會準備好的。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "各位！",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_020"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "在回去之前，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n能請你們聽我說幾句話嗎？",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_5054008_021"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "咦？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "薔薇假面。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "他是想要做什麼？",
        "unit_id": 1,
        "voice": "vo_adv_5054008_022"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "各位，",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_023"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "這裡已經",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n沒有任何特別的設施，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "也沒有任何特別的料理。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "但是，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "還有特別的各位在這裡。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "……各位意下如何呢？",
        "unit_id": 6211,
        "voice": "vo_adv_5054008_024"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n讓我們再一次",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "在這裡舉辦派對吧！",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "贊成！！",
        "unit_id": 103411,
        "voice": "vo_adv_5054008_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……優花梨！？",
        "unit_id": 104811,
        "voice": "vo_adv_5054008_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喂！？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳是局外人，",
        "unit_id": 104611,
        "voice": "vo_adv_5054008_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "別亂插嘴喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有什麼關係。",
