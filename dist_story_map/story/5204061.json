        "voice": "vo_adv_5204061_008"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "因為我可沒白當姑姑。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n好了，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "追加的肉烤好了喔。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "來，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "杏奈有在吃嗎？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……嗯。",
        "unit_id": 100911,
        "voice": "vo_adv_5204061_009"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯？",
        "unit_id": 132512,
        "voice": "vo_adv_5204061_010"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "杏奈怎麼了？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n肚子已經飽了嗎？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不……",
        "unit_id": 100911,
        "voice": "vo_adv_5204061_011"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真要說是哪邊的話，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是心中充滿了感慨。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因為能與大家這樣歡笑，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哪怕只是短暫的一刻，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我也遇見了能",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n一同",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "出生入死的夥伴啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不知為何，我不覺得",
        "unit_id": 100911,
        "voice": "vo_adv_5204061_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "跟在這裡的大家是不久前才相遇的。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒錯，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "簡直就像",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "從很久以前──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "從前世",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就彼此相繫著一樣。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "什麼是前世──？",
        "unit_id": 132412,
        "voice": "vo_adv_5204061_013"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯嗯，",
        "unit_id": 132512,
        "voice": "vo_adv_5204061_014"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "很難說明呢。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "算是",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "跟現在的我們不一樣的",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "其他人生的感覺……？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "定義那種事沒意義喔，",
        "unit_id": 105111,
        "voice": "vo_adv_5204061_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為什麼前世的，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都是不存在、不科學的東西。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105111,
        "voice": "vo_adv_5204061_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不過，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我總覺得奇怪。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "跟瑪莉絲黛菈相遇的10年前的",
        "unit_id": 105111,
        "voice": "vo_adv_5204061_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "暴風雨之夜的記憶，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我到現在也記得很清楚……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但是，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n除了那之外的記憶卻……？　",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不對勁，",
        "unit_id": 105111,
        "voice": "vo_adv_5204061_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "想不起來……？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "比起忘記了……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "更像是籠罩在一層霧靄之中的感覺。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……簡直就像……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就像前世的記憶一樣……",
        "unit_id": 105111,
        "voice": "vo_adv_5204061_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊，",
        "unit_id": 105111,
        "voice": "vo_adv_5204061_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒什麼……！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "……呵呵，",
        "unit_id": 53111,
        "voice": "vo_adv_5204061_021"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "那要來窺視看看嗎？",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "大家的前世。",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "「基創鍊成」！",
        "unit_id": 53111,
        "voice": "vo_adv_5204061_022"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "好，完成。",
        "unit_id": 53111,
        "voice": "vo_adv_5204061_023"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n這是「能夠再體驗前世的祕藥」喔。",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「能夠再體驗前世的祕藥」……？",
        "unit_id": 132312,
        "voice": "vo_adv_5204061_024"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "是連我也不曉得的鍊金術啊。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等一下啊，",
        "unit_id": 105611,
        "voice": "vo_adv_5204061_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "瑪莉絲黛菈小姐，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳是說前世",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種東西真的存在嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "呵呵，",
        "unit_id": 53111,
        "voice": "vo_adv_5204061_026"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "並不是那麼了不起的東西喔。",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "這就只是「可能也有這樣的",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "世界存在」，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n如同輕鬆的玩樂一樣而已。",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過",
        "unit_id": 102711,
        "voice": "vo_adv_5204061_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就算是那樣也沒關係。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不管是夢境也好，玩樂也罷，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會找出我和",
