        "voice": "vo_adv_5204061_006"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "妳在說什麼！？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "呃，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "喂，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "可以別亂翻別人的床底嗎！？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好了好了，大家冷靜下來。",
        "unit_id": 101311,
        "voice": "vo_adv_5204061_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來吃飯吧～？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n唔哈～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好好吃♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n苑氏做的飯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "每一道都是３星啊～♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是吧，",
