    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那位大人",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n即便是在前世也在一起的證據的，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
