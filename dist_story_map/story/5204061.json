    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n很好、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "很好♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
