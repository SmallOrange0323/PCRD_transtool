    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是唱喚士，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n比你想像中還習慣危險的事。",
