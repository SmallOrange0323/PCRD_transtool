    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "還有千萬別勉強自己。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n若是妳有什麼萬一，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "小孩子們也都會難過的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我和各位約定會小心的。",
