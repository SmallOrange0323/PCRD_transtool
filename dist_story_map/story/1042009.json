    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不、",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不，沒什麼。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n請妳繼續排練吧，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "呵呵呵……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "你、",
        "unit_id": 511,
        "voice": "vo_adv_1042009_041"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "你在說什麼啊……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "沒有這回事……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "村長，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能請你告訴我們嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果出了什麼問題，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那可就不是辦演唱會的時候了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "其、",
        "unit_id": 511,
        "voice": "vo_adv_1042009_043"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "其實是……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "小孩子們為了找送給千歌小姐的禮物，\n而進了森林裡，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但他們都還沒回來。",
