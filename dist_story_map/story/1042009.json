    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "村子的男性們正出發去找他們了。",
        "unit_id": 511,
        "voice": "vo_adv_1042009_045"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n我知道讓妳擔心了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但請妳冷靜下來等他們回來吧。",
