[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那一天，千歌與{player}接到來自某個村子"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n邀請舉辦演唱會的委託，而前往了當地。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "長途旅行辛苦你了，{player}。",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "馬上",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就快到目的地的村子了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "等到了以後，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "先向村子的代表打招呼，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n然後開始排練。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你說我在緊張嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是什麼事",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都瞞不過你呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但只有一點點而已。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n畢竟我是第一次在蘭德索爾之外的地方單獨公演。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒事的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然當然還是會覺得緊張，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但現在我反而是更期待演出。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "至今和你一起做過的練習，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "以及之前個人演唱會的成功，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這些或許都帶給了我自信。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "若是今天的公演能夠順利辦成，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我覺得自己",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "作為偶像以及唱喚士也能更進一步成長。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我絕對會演出一場很好的表演，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以請你",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要看到最後喔。",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們到了呢。",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是個風和日麗又有氣氛的村子。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們立刻去向村長打招呼──",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "村民們",
        "words": "唔喔喔喔喔喔喔喔！",
        "unit_id": 1,
        "voice": "vo_adv_1042009_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是怎麼了！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "真的……",
        "unit_id": 1111,
        "voice": "vo_adv_1042009_012"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "真的有偶像大人",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "來到我們的村子了！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "唔喔～！",
        "unit_id": 1411,
        "voice": "vo_adv_1042009_013"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "現在可不是吃飯的時候！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "喔喔，",
        "unit_id": 611,
        "voice": "vo_adv_1042009_014"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真是何等地可愛……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "簡直就像是個妖精。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n活得久就是能有不一樣的體驗啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "奶奶，",
        "unit_id": 411,
        "voice": "vo_adv_1042009_015"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "妳看得到千歌！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "奶奶妳最近視力已經徹底衰退了，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "竟然還能夠看得到嗎！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這、",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是很令人感到高興，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n可是該怎麼說呢，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺壓力非常大……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵，",
        "unit_id": 511,
        "voice": "vo_adv_1042009_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不好意思嚇到你們了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呃，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你是……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我是村長。",
        "unit_id": 511,
        "voice": "vo_adv_1042009_019"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我們等妳很久了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "千歌小姐。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "謝謝妳今天",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "特地遠道而來。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "別、",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "別這麼說，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我才要謝謝你們，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很榮幸受到你們的邀請。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們這麼盛大歡迎究竟是……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "正如妳所見，",
        "unit_id": 511,
        "voice": "vo_adv_1042009_021"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這裡是個鳥不生蛋的邊境村子。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "和蘭德索爾那樣的都市不一樣，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這裡不僅沒什麼娛樂，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n也幾乎沒有什麼機會",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "能夠見到名人。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "因此，聽聞有偶像要來這裡公演，",
        "unit_id": 511,
        "voice": "vo_adv_1042009_022"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n大家的情緒自然也是興奮到了極點。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "哎呀，",
        "unit_id": 511,
        "voice": "vo_adv_1042009_023"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不好意思一直站在這裡談話。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我們替你們準備了房間，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這就帶你們過去。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我們很期待",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "今天的公演喔。",
        "unit_id": 511
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～♪",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯嗯，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "再一次",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～♪",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣子不行。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～♪",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也不是說不太好……",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是我覺得有點困惑。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這村子的人們",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是打從心底",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "歡迎我來到這裡。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不曉得",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他們到底",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有多麼期待今天的到來。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼一想後，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就更覺得自己不能夠失敗，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n結果反而",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒多餘的心思能去期待演出之類的事情了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我真的",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很沒出息呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說得也是。",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果感到不安，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只要讓自己有自信到能擺脫不安就行了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我緊張到連這種理所當然的事情都忘了呢。",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是太丟臉了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "已經沒什麼時間了，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在沒空能休息……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不對，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算照這個狀態繼續練習下去，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也不會有什麼好結果。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不如去吃個點心吧……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，謝謝你。",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_033"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和你說過話後，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我心情稍微平靜點了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不論是在什麼地方，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和在什麼樣的客人面前，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n都要時時盡全力",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "去回應對方，這才是偶像啊。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "做好充分的準備，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "以萬全的狀態來表演吧！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說什麼……！",
        "unit_id": 1,
        "voice": "vo_adv_1042009_036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "他們到底跑去哪裡……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個，",
        "unit_id": 1,
        "voice": "vo_adv_1042009_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "似乎是跑去森林裡了……",
