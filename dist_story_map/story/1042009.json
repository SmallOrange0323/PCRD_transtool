    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是怎麼了？",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_038"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺莫名地吵呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n咦？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你要去看情況？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也和你一起去。",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104211,
        "voice": "vo_adv_1042009_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請問發生什麼事了嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "千、",
        "unit_id": 511,
        "voice": "vo_adv_1042009_040"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "千歌小姐！",
