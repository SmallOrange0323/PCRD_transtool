        "voice": "vo_adv_1042009_053"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好了，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "走吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n小孩子們還在等人去救他們！",
