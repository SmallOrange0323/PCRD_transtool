    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但是，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "請妳務必和村子的人一起行動，",
