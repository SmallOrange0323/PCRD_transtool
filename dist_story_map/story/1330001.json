[
    {
        "type": "background",
        "background": "502111"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與阿剌克涅的戰鬥結束後，在吉歐‧格黑納的鬼岩城塞──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n格蕾斯與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在仔細地調查溫泉附近的牆壁。"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……嗯。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_000"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n被魔物們與【蠻賊三姊妹】破壞的牆壁，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n好像都已經修復完畢了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "吉歐‧格黑納",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_001"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "似乎有著非常高效率的建築技術呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "肯定是在平時，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就以會被魔物破壞為前提……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……嗯？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你怎麼了嗎",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是的。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_002"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我打算偷窺溫泉。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_003"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我開玩笑的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "而且說起來牆壁根本就沒有意義。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我可是亡靈，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "能輕易穿透牆壁。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就像這樣，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_004"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你看。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n咻──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "哇。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_005"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……嗯。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_006"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那麼也就是說騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n難道",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你什麼都不知道，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n就來幫忙調查外牆了嗎？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……這麼說起來，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_007"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我好像沒有說明呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "雖然現在才說有點晚了，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但簡單來說就是……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "其實前些日子",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_008"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "涅妃‧涅羅皇女她，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n提議要邀請我們的公主",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n一起去泡溫泉，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "作為吉歐‧格黑納與吉歐‧尼布爾黑爾兩國間的交流。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "想偷窺嗎？",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_009"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那麼是那個嗎。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_010"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n你是不是在想原來不死生物也會洗澡之類的？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "真過分。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是嗎。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_011"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那真是失禮了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……不過就是因為這樣，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我才來調查溫泉周圍的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "絕對不能讓我們家公主的柔嫩肌膚",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_012"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n被任何不肖之徒看到。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "所以說騎士氏。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_013"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "雖然順序有點顛倒了，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但是很感謝你",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "陪同我進行調查。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……啊。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_014"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就這樣解散似乎有點不近人情呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "對了。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_015"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你應該也有流汗吧，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "泡個溫泉",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "如何？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n作為你今天幫忙的謝禮，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "費用就由我們來出吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_016"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我就不用了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n因為幽靈",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不會流汗。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "討厭，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_017"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你好積極──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不對。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嗯，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這麼說好像也有道理。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那麼，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_018"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我們就來泡看看吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這只是為了調查而已。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "既然決定了，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_019"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那就突擊前進吧",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n把手舉高，「萬歲～」。",
        "unit_id": 133012
    },
    {
        "type": "still",
        "still": "133000101"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "咔咚～",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_020"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "咔咚～",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_021"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "到底是什麼呢？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n是卡隆氏的親戚嗎。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "先不論這個……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呼……",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_022"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "真舒服。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n要活過來了呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_023"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒有真的活過來就是了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_024"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏～",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_025"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n你那邊的水溫如何～",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那真是太好了。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_026"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過話說回來這裡的溫泉，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_027"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "有好多種類呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不同的溫泉",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "似乎有不同的功效。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這裡的乳白溫泉，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_028"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "能提升血液循環及新陳代謝。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n那裡的濁色溫泉，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "能滋潤肌膚。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "喔喔。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這邊是對",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "肩膀僵硬、",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "風濕、",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "以及神經痛有效果。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_029"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "跟幽靈沒有關係就是了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_030"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……你可以吐槽我也沒有關係喔？",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_031"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "什麼事都沒有。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "對了。",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_032"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n男生那邊有什麼少見的溫泉嗎？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "哦，",
        "unit_id": 133012,
        "voice": "vo_adv_1330001_033"
    },
