[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼。",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n實在讓我很不爽，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "每件事都是。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然說被那超強的大量破壞魔法給直接擊中，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還能保有這條命就算是賺到了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但竟然被關到這個空無一物的監牢裡呢，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真是無聊到快死了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只不過……",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n為什麼我獲救了啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那可是陛下真的想殺了大家所施展的魔法。",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n想以半吊子的方法",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n來進行防禦或迴避是絕對不可能的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "絕對…",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來即使是陛下，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也沒辦法做到所謂的絕對啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是無聊啊。",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n果然在這世界上，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n根本就不存在能夠被稱為絕對的事情。",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "200601201"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就我記得的事情來看……",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n陛下所施放的是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有著龐大熱量的戰略級大量破壞魔法。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算是我，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在被命中的瞬間應該就會被蒸發掉才對。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當時那個地方還有一些",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n發出異樣氣息的人在……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是他們用了某種手段，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n阻擋了那個攻擊嗎？",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "200601202"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "特別是那個紅髮的女生，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n應該不是泛泛之輩……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不知為何，我就是特別在意她。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個紅通通的女人，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好像從叫什麼諾維姆的髒兮兮少女手上拿了什麼。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看起來是王冠模樣",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "的胸針……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個不知道是什麼呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我記得尾狗刀那小子，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好像也有拿那個來跟我炫耀過。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但之前好像也說過，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n被盜賊偷走了，所以正在找。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這跟先前那件事情有關連嗎？",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "200601203"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呿，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "失算了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n早知道那胸針是那麼重要的東西的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就帶在身邊了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，再怎麼說，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也沒辦法事先預料到事情會變這樣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "尾狗刀那小子有著獨有的能力，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也算是個異樣的天才。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個胸針是他發明的東西，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還是從某個人那邊獲得的秘寶呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "等我離開這監牢，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一定要從尾狗刀那小子口中好好地問出來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過前陣子……",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我才因為自己的陰謀而利用他，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n或許他還很怨恨我呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拿到那個胸針的紅通通女人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在戰略級大量魔法打中我們的瞬間究竟是做了什麼。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不知道為什麼，她好像還碰了那個",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n叫做拉基拉基，皮膚黝黑的男人。",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "200601204"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個瞬間，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "時空好像扭曲了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是一種，難以形容的感覺……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然後我們周圍就被一陣光芒給包圍，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n與某個很遠的地方連接在一起。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接著，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎聽見了某個人的聲音，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是跟拉基拉基一模一樣的聲音，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還有一個比較老成的男人聲音……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那會是誰啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n難不成會是神明什麼的嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但感覺，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好像有種懷念的感覺就是了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n實在搞不懂啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "每件事情都像是在作夢一樣。",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500095"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不過下個瞬間，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就回到了王宮裡自己的房間。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好像瞬間移動一般。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是不是用了被陛下給禁用、",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n類似傳送門之類的魔法呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是為了什麼理由要用瞬間移動？",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n又為什麼把我送到王宮裡自己的房間來？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n其他人又去哪了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這些全都是一團謎。",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然後我只是很單純的……",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n想對那個打算殺了我的陛下進行報仇，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以才攻進王座之間。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接著就跟負責警備的【王宮騎士團】",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n起了衝突。",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "最後，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長及她率領的精銳部隊前來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我因力所不及無法抵抗而被逮捕起來……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然後就像這樣，被關進牢房裡。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個王宮裡的祕密監牢，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是用來收押危險政治犯之類的人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不只戒備森嚴，還做了多重防止逃獄的措施，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算是我也無法逃脫。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即使用我的『絕對攻擊』也無法破壞呢，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這下子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n熟知我能力的陛下應該有做了什麼特殊的對策，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n想必是專門關我的監牢吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "老實說，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我無能為力了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒什麼深交的好友，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以無法期待會有誰來幫我呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這種時候就會覺得，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當壞人真難受呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n發生了這麼多事情也都累了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n稍微休息一下吧……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這世界上沒有『絕對』這回事。",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只要我有那個打算，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這種監牢我應該隨時都有辦法離開才對。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……陛下。",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳會想要殺了我呢……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂。",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……！？",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我記得是叫做……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "諾維姆？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳是從哪裡進來的？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呵呵。",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這算是祕密絕招就是了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們這邊的拉基拉基會使用一種叫做「空間跳躍」的招式。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "無論是什麼地方，",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n都可以將自己跟另一個人送過去。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為他現在，",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "力量已經用盡了……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以光是把我送進這裡，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n應該就是極限了吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔嗯……",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也許就是那個什麼『空間跳躍』的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓我們連陛下的大量破壞魔法都迴避掉了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，陛下應該不可能",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沒想到可以用這種方法逃跑才對吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～，",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不太懂這種很複雜的事情。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個紅通通的人……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像叫做拉比林斯達嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n好像有對拉基拉基進行強化的樣子。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "反正，",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_053"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總而言之呢，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就是我們這邊技高一籌囉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之。",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_054"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我現在因為一些原因，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以跟【拉比林斯】的人一起行動。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以的話，",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_055"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳要不要也加入呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊？",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳該不會是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n來這裡說服我加入妳們的吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就為了這件事，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還特地使用那種像奇蹟似的方法，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n潛入這個監牢裡？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對於妳們希望我克莉絲提娜加入成為夥伴這件事，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就先誇獎妳們慧眼識英雄吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，我無法理解呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然這由我自己說有些奇怪，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但我可是隻無法駕馭的狂犬唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我知道。",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就我們而言，老實說也不太想讓",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n像妳這樣的危險人物加入……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但我真的",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_061"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n受過妳許多照顧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……？　",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從我們第一次見面的時候開始，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳的口氣就一直是這樣……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我和妳",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以前在哪裡見過嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "老實說，",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我不記得有照顧過",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n像妳這樣的小丫頭啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也忘記了呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "無論是以前的事情，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還是【圓桌武士】的事情……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然跟現在的妳說這些也沒用，",
        "unit_id": 106112,
        "voice": "vo_adv_2006012_065"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但以前我和妳曾是夥伴。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_2006012_066"
    }
]