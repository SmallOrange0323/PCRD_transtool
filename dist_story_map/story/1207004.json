    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我還第一次大哭了一場。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那個時候……",
