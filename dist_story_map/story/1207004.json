        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "但那時候",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "他卻不斷地問我",
