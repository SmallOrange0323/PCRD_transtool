    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "肚子才不小心有反應了……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "討厭，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_013"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "你別笑啦……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "很難為情耶……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那個……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
