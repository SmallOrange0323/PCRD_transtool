        "type": "dialogue",
        "name": "紫布菜",
        "words": "有多少年沒吃過烤地瓜了呢……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "這麼說來，第一次吃的時候也是……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_021"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……我小時候",
