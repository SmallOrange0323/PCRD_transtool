    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "傷害了他……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我啊……",
