        "voice": "vo_adv_1207004_026"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "因為膝蓋有受傷，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "所以變得沒辦法跳躍了……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n但我說什麼",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "都無法放棄……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "所以一直持續復健。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "老實說，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_027"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我曾經好幾次都快挫敗了。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "聽到那些我原本的對手在比賽中表現活躍，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "而我卻是在忍痛",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "進行艱苦的復健，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "真的很難受。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "哥哥因為擔心我，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_028"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n所以",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不斷來陪我復健。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……哥哥他自己",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "明明應該也很忙的。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "多虧如此，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_029"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我才恢復到能正常度日的程度。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "可是",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "醫生",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "還是對我說……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n我沒辦法回去溜花式滑冰。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我真的覺得很沮喪……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_030"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "變得什麼事都不想做……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "一直把自己",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "關在家裡面不出去……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "或許是因為很擔心我，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_031"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n所以",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "哥哥他找我",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "一起去參拜。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "於是我們今天",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "去了附近的神社，但是……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "…………",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_032"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……哥哥他",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_033"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "在神壇前，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "一直向神許願。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "很認真地",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "在祈求某件事。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "當我想通他是在為我許願時，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_034"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n整個腦袋",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "都變得一團混亂了。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我明明很高興，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_035"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "卻覺得好難受。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我明明想感謝哥哥，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "卻又對他感到很煩躁。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "結果我就這樣對他說……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "「許願又有什麼用？",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_036"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "明明就不可能會實現！",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n我明明",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "再也跳不起來了！」",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "然後……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_037"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我就逃到這裡來了。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……我真的",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "用了最糟糕的方式跟哥哥撒嬌。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "可是",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_038"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我真的不懂，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n在這種絕望的狀態下，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "許願又有什麼意義……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……你許願的時候？",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_039"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……決心？",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_040"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "…………",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_041"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……這樣啊，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_042"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "就是說呢。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "所謂的「願望」，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "並不是為了讓其他人幫自己實現而許願的……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "而是為了表明",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_043"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "想實現願望的決心呢……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n如果是這樣解釋，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那我或許就能理解許願的意義了。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……就算許願，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_044"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "也不知道是否能實現。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "即使如此，我……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "也還是不想放棄……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "如果要說值得期待的事……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_045"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "就只有那個遊戲……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "雖然這也有可能只是個傳聞，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "但是……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "有值得一試的",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_046"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "價值……！　",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……嗯。",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_047"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "謝謝你聽我說話。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n總覺得你……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "有一點",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "像我哥哥，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n所以我好像",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "就依賴了你不少事情。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "呃……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_048"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "雖然有點晚才問，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n但你的名字……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……！",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_049"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n是哥哥打來的電話。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "對不起，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我去接一下……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "「…………紫布菜，",
        "unit_id": 1,
        "voice": "vo_adv_1207004_050"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "妳在哪？」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……我在公園。",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_051"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "善哥哥，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那個……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……我讓你擔心了，",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_052"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "真的",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "很對不起。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "善",
        "words": "「妳不需要道歉，",
        "unit_id": 1,
        "voice": "vo_adv_1207004_053"
    },
    {
        "type": "dialogue",
        "name": "善",
        "words": "\n妳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "善",
        "words": "沒有錯。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "你又要像這樣寵我……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_054"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那麼，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我不說對不起……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "謝謝你……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_055"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "哥哥。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n我",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "已經沒事了。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我現在就回去你那裡。",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_056"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "然後……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我也想",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "去參拜可以嗎？",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不對……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_057"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
