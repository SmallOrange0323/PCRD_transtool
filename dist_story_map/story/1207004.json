        "voice": "vo_adv_1207004_023"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "哥哥買來了烤地瓜，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
