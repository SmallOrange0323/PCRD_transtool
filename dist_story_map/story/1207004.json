        "voice": "vo_adv_1207004_018"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "怎麼辦……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n讓人停不下來了……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "呵呵……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_019"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "好好吃。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n真的，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "好好吃……",
        "unit_id": 106432
    },
