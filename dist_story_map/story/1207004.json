        "voice": "vo_adv_1207004_008"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我、",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我沒事啦……！",
        "unit_id": 106432
    },
