        "voice": "vo_adv_1207004_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我就恭敬不如從命……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就靠一下子……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
