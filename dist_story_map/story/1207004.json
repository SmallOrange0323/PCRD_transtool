        "type": "dialogue",
        "name": "紫布菜",
        "words": "呃……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_009"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "好久不見……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不好意思，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "讓你見笑了……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n我只是",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "發生了點事情……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我才要問你",
