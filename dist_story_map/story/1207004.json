    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "「好吃嗎？」……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "呵呵，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "哥哥真是的，從那時候就很保護過度呢……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "是啊……",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_025"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "他是我珍視的家人。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……然而我，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "卻對這樣的哥哥遷怒，",
        "unit_id": 106432
