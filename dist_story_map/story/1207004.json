        "voice": "vo_adv_1207004_014"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "既然你本人都說可以了……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我就不客氣了。",
        "unit_id": 106432
    },
    {
        "type": "still",
        "still": "120700401"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……啊唔。",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_015"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n嚼嚼……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "豪燙……",
        "unit_id": 106432
