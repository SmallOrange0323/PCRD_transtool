        "type": "dialogue",
        "name": "紫布菜",
        "words": "不用了。",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_011"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n花式滑冰大會快到了，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "必須管理體重才行……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n況且",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我肚子也不會餓……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……！？",
        "unit_id": 106432,
        "voice": "vo_adv_1207004_012"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n這、",
        "unit_id": 106432
