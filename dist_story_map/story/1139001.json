[
    {
        "type": "background",
        "background": "501130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天，{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "發現了\n面有難色的紡希。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯～",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我該怎麼辦才好呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然這個提議是很不錯……",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但如果是接下來就要開始，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然會很困難啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀啊！？",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你別突然跟我說話！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你對正在煩惱的人不夠體貼呢！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你問我怎麼了，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這件事情和騎士先生並沒有關係喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為這是我的問題，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你不需要在意。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了好了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你快走吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你為什麼還不走呢？",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……………………",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我說過了吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你不需要在意這件事。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………\n……………………\n………………………………",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "～～～",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊～",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "受不了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這樣不就變成在比誰比較有毅力了嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我明明都說你可以不用在意了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你為什麼要這麼濫好人啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……算了。",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n反正這也不是跟人商量",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就能解決的事情，我就說出來吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "其實……",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是有人拜託我",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "參加戲劇的舞台劇特效工作。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你知道我也有在慈樂之音負責演唱會的特效吧？",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n對方在看了演唱會後，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說希望我一定要來負責戲劇的特效。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我……",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還沒有給對方回覆。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n說實話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我覺得拒絕比較好。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為事情很突然，也沒有什麼時間準備，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "演唱會和舞台劇的特效應該也是不一樣的吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我這麼說",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "並不是因為沒自信之類的原因喔？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而是輕易說出",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "「我辦得到」",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "會很不負責任。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也很想",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "試著挑戰新事物。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但如果要負責舞台劇的特效，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好像必須一直陪著他們才行，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n更何況我還有",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "裁縫店的工作……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "希望至少",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能有個協助我的人就好了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你說",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就在這裡……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是指騎士先生嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這樣隨隨便便就決定沒有關係嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生自己明明也有很多打工要……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不……",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算這樣問你也是白問呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n畢竟騎士先生就是這樣的人啊。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n對任何人都會伸出援手……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就是對你這一點……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不、",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒什麼！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不提這個，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你真的沒問題嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說起來，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你為什麼要……？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為、",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了我！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你就是用這種話",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來誆騙怜大人的吧！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是這樣沒錯吧！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這個人真的是讓人大意不得耶！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你說好像很有趣，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是一點緊張感都沒有……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種面對事情的態度",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n很有騎士先生的風格，這樣或許比較好呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……我了解騎士先生的想法了。",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "相對地，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然你都說會幫忙了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我會請你奉陪到底喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "事不宜遲。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們馬上去找主辦人吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為早點開始準備會比較好！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不好意思～！",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_026"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "啊……",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_027"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "紡希……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "真不好意思，還勞煩妳特地過來。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓你等待我的答覆，非常抱歉。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "關於舞台劇特效的事情，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我想接受你的邀請！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然決定要做，我一定會呈現出很棒的舞台劇，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以要請你多多指教了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳願意接受嗎！？",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_030"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這真是太好了……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "嗯，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "太好了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "但是……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對了，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我能和演員見個面嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n如果要負責特效，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就必須先對會成為舞台劇核心的人有所了解才行。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "……關於這件事，",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_032"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n其實……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "發生了點小小的麻煩……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……怎麼了嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_033"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "那個，",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_034"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雖然這不是什麼能大聲說出來的事情……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──你說女主角沒辦法演了！？",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣不就構不成舞台劇了嗎！？",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這問題才不是什麼小小的麻煩吧！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳、",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_037"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳說得對……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雖然",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我們趕緊去找其他的女演員了，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n但實在是找不到願意接演的人……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這也是正常的啊。",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n怎麼可能那麼簡單就找得到……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "該怎麼辦才好呢……",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說到我身邊會演戲的人……",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是小望了吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在才要跟她排檔期這種事，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "絕對辦不到的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "啊啊，",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_041"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "再這樣下去，舞台劇就要取消了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算你哀聲嘆氣也沒有用吧！",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不如想點辦法──",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊？",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_043"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "……！",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你、",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你突然講這什麼話啊，騎士先生！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這樣肯定行不通的啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你別只是一時想到就講出這種不得了的事情，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小心我把你綁起來喔！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "不……",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_046"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "就是這個！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "就是這個啊！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "紡希可是",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "在蘭德索爾聞名遐邇的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "慈樂之音一員！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "由這樣的紡希來飾演角色，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "並身兼特效的舞台劇……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你等等！",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你在那邊擅自異想天開個什麼啊！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我完全沒有演戲那一類的經驗……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "拜託妳了，紡希！",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_048"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n我想",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "讓這齣舞台劇成功……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚……！",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，那個，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只是幕後的工作也就算了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果變成要參演舞台劇，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "慈樂之音的製作人不知道會說什麼……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這我當然明白！",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_050"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "所以說，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我已經用通訊魔法聯絡上",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n妳們的製作人克莉絲提娜大人了！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你做起事來俐落得莫名其妙耶！？",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "製作人，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳聽得到我的聲音嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對方突然問我要不要飾演舞台劇的主角，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但果然",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "很難答應他對吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "叫我演？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "慢著慢著，製作人，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳有好好考慮過嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳說這樣似乎很有趣……",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這話是不是講得太隨便了！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "製作人！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等一下啊！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……通訊斷了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "……請問她意下如何呢？",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……好像",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_055"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可以演的樣子……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "喔喔，",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_056"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這是多麼令人感激……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚～",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這麼突然的工作",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原本絕對該回絕掉才對啊……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "歸根究柢，這都是騎士先生造成的啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n他該不會是覺得",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我什麼事都辦得到吧！？　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可惡的騎士先生～！",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當事人還一臉悠然自得的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n他是真心認為……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我辦得到……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這個人大概",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是真心這麼想的吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我知道了！",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我就接受這個挑戰！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "喔喔！",
        "unit_id": 2511,
        "voice": "vo_adv_1139001_061"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "紡希……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "真的很感謝妳……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我也會",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "全力以赴的……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯，",
        "unit_id": 105411,
        "voice": "vo_adv_1139001_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "仔細想想，這也不全然是壞事啊。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n如果是自己上台演出的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
