    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_055"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "成功了，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們嬴了……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n有緣再見。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "非常感謝你的誇獎。",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_056"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是因為你願意相信我，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我才能盡全力歌唱。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好了，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_057"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們快回沙灘上吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n既然都打倒魔物了，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "觀光船應該也能出海──",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……咦？",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_058"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊！？",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_059"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們不知不覺被沖到遠方了！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且船身也佈滿傷痕……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們該怎麼辦才好！？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一波未平一波又起，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n載著兩人的船就那樣在海上漂啊漂的。"
    }
]