[
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌跟{player}一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n享受了夏日的海邊。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯～",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真好吃！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在海邊吃的東西，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n感覺比平時更加好吃呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是穿著泳裝邊走邊吃這種",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "小小的非日常感，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "成了絕妙的調味料嗎。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還是說，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是因為這種很開闊的場景影響？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "無論如何，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我覺得很不可思議，很開心呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "原來海邊是這麼開心的地方啊……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n自己心裡確實存在著",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能享受這種平凡小事的心靈，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我或許也對這件事覺得有些感動。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "無論是努力舉辦演唱會，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還是剛才的牽手……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n總覺得現在的我",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "或許跟平時不一樣……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這就是",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "自由的感覺嗎？　",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果我能拿出勇氣，再往前踏出一步的話……？　",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那個，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛才散步的時候，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我發現有在近海巡迴的",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "觀光船之旅。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然後啊，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我說……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不嫌棄的話，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要不要一起參加？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了。",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然那是以情侶為客群的行程，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以要以男女為一組，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過這樣也沒關係吧？　",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀～！",
        "unit_id": 1212,
        "voice": "vo_adv_1173002_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有、",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有人被……！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛才的是尖叫聲？",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好像是從沙灘那邊傳來的，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們去看看狀況吧。",
        "unit_id": 117311
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你看，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有一群人聚集在那裡。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n到底是發生了什麼事……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "呼……",
        "unit_id": 1411,
        "voice": "vo_adv_1173002_012"
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "噫……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "我、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "我還以為我要死了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你、",
        "unit_id": 312,
        "voice": "vo_adv_1173002_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你還好嗎！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n到底是發生了什麼事！？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "有魔物……",
        "unit_id": 1411,
        "voice": "vo_adv_1173002_014"
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "出現了",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "會唱歌的魔物……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦……",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_015"
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "我才聽見歌聲沒多久，",
        "unit_id": 1411,
        "voice": "vo_adv_1173002_016"
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "周圍就遭到大霧包圍，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "\n導致我不曉得自己人在哪裡……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "牠一看到我慌了手腳的模樣，",
        "unit_id": 1411,
        "voice": "vo_adv_1173002_017"
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "\n就主動發起攻擊，想把船給弄沉。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "在那之後我拚命逃跑，",
        "unit_id": 1411,
        "voice": "vo_adv_1173002_018"
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "最後好不容易才逃到這個海灘上……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這、",
        "unit_id": 2511,
        "voice": "vo_adv_1173002_019"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這下可麻煩了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n觀光船行程跟",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "其他活動可是排得很緊的……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "我勸你是打消念頭吧。",
        "unit_id": 1411,
        "voice": "vo_adv_1173002_020"
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "現在",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "出海就跟去送死沒兩樣。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "這下我也沒辦法出海捕魚了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "可惡，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "沒得賺了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "你說得對，",
        "unit_id": 2511,
        "voice": "vo_adv_1173002_021"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "考慮到客人的安全，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n觀光行程不得不中止呢……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "怎麼這樣，",
        "unit_id": 1212,
        "voice": "vo_adv_1173002_022"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "人家非常期待的說……",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這是沒辦法的啊。",
        "unit_id": 312,
        "voice": "vo_adv_1173002_023"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這次就先放棄吧。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請問有誰願意借一艘船給我呢？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "喂、",
        "unit_id": 1411,
        "voice": "vo_adv_1173002_025"
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "喂，小姐妳是在說什麼啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "現在",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "海上有很不妙的魔物在。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫",
        "words": "\n妳沒有聽到我剛才說的話嗎！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請放心，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是唱喚士，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我很習慣跟魔物戰鬥。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "什麼，",
        "unit_id": 2511,
        "voice": "vo_adv_1173002_027"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "原來您是唱喚士大人嗎……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "可是，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "即使是唱喚士大人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "在海上也很危險……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "再這樣下去，大家的生活和",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "幸福的時光都會遭到破壞。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我無法坐視不管。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "多麼了不起的人……",
        "unit_id": 2511,
        "voice": "vo_adv_1173002_029"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我明白了，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我會借您一艘船。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "不過，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "還請您不要逞強。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起，{player}。",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n事情經過就是這樣，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天就到此為止。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n明明是我自己邀你的，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的是很過意不去……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你願意幫忙是嗎？",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不能讓你遭遇危險……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "話雖如此，",
        "unit_id": 117311,
        "voice": "vo_adv_1173002_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但你絕對會跟過來對吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟你就是那樣的人……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "非常感謝你，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就請你多費心了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
