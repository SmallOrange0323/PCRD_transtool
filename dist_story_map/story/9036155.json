[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快走不動了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "熱到全身黏答答……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且蟲子超多……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們到底還要在這個悶熱的叢林探險到什麼時候啦～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……！！",
        "unit_id": 105811,
        "voice": "vo_adv_9036155_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快看那個！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是水邊呢！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦……",
        "unit_id": 105911,
        "voice": "vo_adv_9036155_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "走了這麼久，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來終於",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要走出叢林了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太……",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了——！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "水！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是水耶——！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嗯——！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好涼好舒服啊～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_9036155_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您很興奮呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀，",
        "unit_id": 105811,
        "voice": "vo_adv_9036155_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖說小凱留是貓咪，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但其實是喜歡水的吧～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥！？　",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳很囉嗦耶！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算貓很怕水，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但現在滿身大汗，沒沖澡的話我可不行。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n話說妳們，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是也跟著走進水裡了嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……",
        "unit_id": 105911,
        "voice": "vo_adv_9036155_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看著凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不知不覺",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就一起跟著走進來了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像有點黏糊糊的呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哪邊哪邊？",
        "unit_id": 105811,
        "voice": "vo_adv_9036155_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的呢，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼會這樣呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在說什……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎呀！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的是黏糊糊的耶！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等！　",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次變成刺刺麻麻的！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡的水到底怎麼一回事啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇！？　",
        "unit_id": 105811,
        "voice": "vo_adv_9036155_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在輪到我也刺刺麻麻的呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得很好玩呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9036155_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請看那邊。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有隻長得像大型海蝸牛一樣的魔物……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "腳邊感到黏膩",
        "unit_id": 105911,
        "voice": "vo_adv_9036155_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又刺麻，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n恐怕就是那隻魔物所造成的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "海蝸牛……",
        "unit_id": 105811,
        "voice": "vo_adv_9036155_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是牛嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "海蝸牛可以吃吧！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能會有那麼奇形怪狀的牛啦！",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "老是這樣，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的眼睛到底有什麼問題！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海蝸牛呀，",
        "unit_id": 105911,
        "voice": "vo_adv_9036155_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也沒嘗試過將牠做成料理。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這讓在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "十分躍躍欲試呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "騙人的吧……！？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不要絕對不要！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那種又黏又刺刺麻麻的東西，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不想吃啦！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說到底",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種東西根本就不可能會好吃的吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看到那副模樣了吧？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說絕對不會好吃的！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_9036155_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在可不是挑嘴的時候！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在我們可已經陷入危機了喲？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣繼續討論",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要不要吃掉牠的事，真的好嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然不好呀！　",
        "unit_id": 106011,
        "voice": "vo_adv_9036155_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且話說回來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n才輪不到妳說我呢！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9036155_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就先聊到這吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n魔物",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "朝我們這邊來了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "戰鬥吧……！！",
        "unit_id": 105911
    }
]