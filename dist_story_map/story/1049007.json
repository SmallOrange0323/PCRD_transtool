    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}～！\n",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哈囉。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是姐姐我呀～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好巧喔！",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}，\n你也來買東西嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也是耶～",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n果然",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐弟是會越來越像的！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "連採取的行動都一樣。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵呵♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯……",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n偶遇、偶遇。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一切都是巧合，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以沒關係。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "又不是我想見到{player}，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n才刻意碰面的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這應該",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以是理由吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然我被叮嚀",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n盡量不要接觸{player}。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐可是很清楚的。",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "無論是什麼樣的規則，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n都會有對策的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "先調查好\n{player}",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一整天的行為模式……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在{player}經常出沒的地方，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我剛好有事情要來處理……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是這樣設計的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就算事後被公會長罵了，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也可以聲稱只是巧遇。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太完美了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能不能見到面，機會是一半一半，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但我是賭對了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我當然",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不會過度接觸。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我會忍住，就稍微看一下他的臉，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n頂多再閒聊幾句而已。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不小心刺激到{player}的話……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n會發生什麼事，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "誰也說不準。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就連璃乃……",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也很努力地忍耐著",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不要和{player}見面吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐自己先偷跑的話，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n對她也有些過意不去。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱歉。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我剛剛在想事情。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我也有",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n很多煩惱的啦～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}你還小，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以不是很懂吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是大人特有的",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不為人知。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你是在擔心我嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我好高興喔～",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}真是溫柔的好孩子！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是姐姐最引以為傲的弟弟呢～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我沒事啦！",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要能見到{player}，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐就宇宙無敵開心了♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我終於找到一間合適的房子了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最近開始一個人生活……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有很多東西需要買齊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n像是生活用品或家具。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為我想挑一些物美價廉的東西，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不但耗費時間，也很花錢，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要費好一番工夫呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "覺得還不錯的東西",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "價格往往貴得嚇人。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "自己非常喜愛",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而想好好珍惜的東西",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n在房間裡越來越多的畫面……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "該怎麼說呢，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n感覺很幸福吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}，\n你是來買什麼東西的呢？",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你一個人沒問題嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要不要姐姐陪著你，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還可以給你一些建議喔？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哼哼。",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我最近都在這一帶採買，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n很熟悉這邊的店家喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要不要我替你帶路呀？",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就像以前那樣。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "小時候，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我總是牽著{player}的手……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "帶著你四處走、四處逛。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你可能也不記得了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}畢竟是男孩子，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺對逛街這種事",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n沒什麼興趣。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但你總是沒有半句怨言的",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n跟在我身邊。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我非常",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "高興喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那時候和{player}一起買的",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n便宜玩具戒指呀……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "到現在",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也還好好珍惜著。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就算開始一個人生活以後，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也從不離身。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……抱、",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_037"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱歉。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不知道為什麼",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "眼淚突然冒出來了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿。",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_038"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好像有風",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "把髒東西吹進眼睛裡了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我沒事，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不用擔心我……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很堅強的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為我隨時要保護",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_040"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n愛哭鬼{player}嘛。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇？",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_041"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你怎麼突然抱住我了，{player}？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真愛撒嬌～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你也",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_042"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不知道是為什麼？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐是姐姐，所以沒關係，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但你可不能便",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "隨隨便便抱住其他女孩子……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "知道嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唉唷。",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_043"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真危險，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n差點就要頭槌了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是我的壞習慣呢～",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_044"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n動不動就出手。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "然後，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_045"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我就被父母罵了……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n說我不可以動不動就打人或踢人。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我就說，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_046"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那我就改用頭槌，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣就不算是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "打人或踢人了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我真是個",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_047"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n愛賣弄小聰明的小孩呢……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "假裝自己是個",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼都懂的聰明姐姐。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多希望自己能夠不去在意他人眼光，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_048"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n哪怕狼狽地哭哭啼啼，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也要拚命地取得自己想要的東西……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我這個人，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_049"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n真是傻瓜。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哈哈哈。",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_050"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱歡，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我在自言自語……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就這樣。\n{player}，\n",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_051"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天姐姐的狀態",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不是很好，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我就先回去了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "專心走路，不要跌倒囉～",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_052"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還有，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "小心",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不要迷路囉。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哈哈哈，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_053"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我操心過頭了？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n叫我別把你",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "當小孩子對待？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看看你得意的樣子～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真可愛♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過呀～",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_054"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n擔心弟弟，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "照顧弟弟，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n才是姐姐的",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "生存意義呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵。",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_055"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果遇到什麼麻煩，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n隨時都可以找我。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要是為了{player}，",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_056"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐我就算是赴湯蹈火……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對。",
        "unit_id": 104911,
        "voice": "vo_adv_1049007_057"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我永遠會是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}你的後盾。",
        "unit_id": 104911
    }
]