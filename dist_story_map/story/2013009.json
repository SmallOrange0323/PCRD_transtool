    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……嗚咿！？",
        "unit_id": 100711,
        "voice": "vo_adv_2013009_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呀啊啊！？　",
        "unit_id": 102211,
        "voice": "vo_adv_2013009_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎麼了呀宮子？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不要突然發出奇怪的聲音啊，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳這樣不是會嚇到人嗎！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "大……",
        "unit_id": 100711,
        "voice": "vo_adv_2013009_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "大家，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "看那邊！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n好像有",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "什麼讓人感覺不舒服的東西飄在空中喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "誒誒？",
        "unit_id": 102211,
        "voice": "vo_adv_2013009_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什麼呀這麼突然？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不要講那麼可怕的事情啦～？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊她",
        "unit_id": 100611,
        "voice": "vo_adv_2013009_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "害怕的東西很多的嘛。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n還真是多愁善感呢……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘻嘻嘻，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真～可愛♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呣？　",
        "unit_id": 104412,
        "voice": "vo_adv_2013009_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "到底是怎麼回事呀，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "竟會讓那個天真無邪的宮子",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如此的懼怕……？　",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……。",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個是……？　",
        "unit_id": 104412,
        "voice": "vo_adv_2013009_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "究竟是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "何物呀？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n儘管還保有著人類的樣貌，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "卻散發著不祥的氣息！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你這傢伙，",
        "unit_id": 104412,
        "voice": "vo_adv_2013009_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是何人呀！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n別給妾身從那樣的高處",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "俯視這兒，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是令人不悅！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你難道不知曉妾身為何人！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是統御黑夜，",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_009"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "傳說的吸血鬼",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "伊莉亞‧奧恩斯坦呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵呵。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "原本還以為不過就是個報上這種名號的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n腦袋有點遺憾的孩子呢……♪",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "意外中的意外，",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_010"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看來是相當的美味呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論妳到底是真貨還是假貨都無妨唷，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n但潛藏於妳體內那龐大的魔力……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可要收下了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵呵。",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_011"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "雖然待在城中的那群人都逃光了的樣子，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不過",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "小嘍囉什麼的怎樣都好……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n為了愛與正義，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "為了守護眾人，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而留於城內起身對抗的人仍還在這呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如此的人們相較之下吃起來更有份量，",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_012"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "對我來講可是難能可貴的飼料呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而且……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把那些將天真愚昧的漂亮事到處宣揚貫徹的人們踐踏於地，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n再撕得四分五裂後吞下肚，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "鐵定是非常有快感的呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "吸血鬼伊莉亞，",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "以及她的夥伴們……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "名叫【惡魔偽王國軍】",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "來著？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這可還真是個響亮的名字呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "首先，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就先從妳們這幾個開始吞食吸收囉。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳們就成為我那夢想、",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "願望的",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "活祭品吧！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……！　",
        "unit_id": 104412,
        "voice": "vo_adv_2013009_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不好，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是很強的殺氣！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n而且",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那些",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如此龐大的魔力",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "與密度是怎麼回事？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "各位趕緊逃吧！",
        "unit_id": 104412,
        "voice": "vo_adv_2013009_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那傢伙",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "指名道姓的唯有妾身一人，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "目標應只有妾身呀！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n趁妾身吸引住他的注意時，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們趕緊逃――",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦，",
        "unit_id": 102211,
        "voice": "vo_adv_2013009_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n到底是怎麼一回事啊，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個人到底是什麼東西？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真遺憾。",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可是哪兒也逃不掉的唷，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論是妳們……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "亦或是我呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在這個被封閉，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且毀壞了的世界中，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我們除了不斷的上演以血洗血的遊戲以外別無他法。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "儘管也就只能算是打發時間，",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但是也讓我們好好享受享受吧……♪",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……咕嗚！　",
        "unit_id": 104412,
        "voice": "vo_adv_2013009_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不妙，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "他的力量超乎了想像呀！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若那傢伙真釋放出了攻擊魔法，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我等可是毫無招架之力！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "恐怕",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "連一點殘骸也不會留下啊！　",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真不甘心！　",
        "unit_id": 104412,
        "voice": "vo_adv_2013009_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若妾身，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "無論何時何地都能取回那原本的樣貌的話！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這些毫無過錯……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "且願意獻上同情，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n愛慕甚至寄身於妾身的這些小夥伴們，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身或許就能守護好了！　",
        "unit_id": 104412
    },
    {
        "type": "still",
        "still": "201300901"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "………！",
        "unit_id": 104411,
        "voice": "vo_adv_2013009_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這怎麼回事兒……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身竟變回來了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇，",
        "unit_id": 100611,
        "voice": "vo_adv_2013009_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好厲害！　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "伊莉亞，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就算{player}哥哥不在這",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也能變身了……！？",
        "unit_id": 100611
    },
    {
        "type": "still",
        "still": "201300902"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼哈哈，",
        "unit_id": 104411,
        "voice": "vo_adv_2013009_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這便可謂那十萬火急之際的蠻勇之力吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n怎麼樣呀，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身果不其然就是時來運轉的那種吸血鬼吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "做為一位領袖可不真是名副其實的嘛！？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵。",
        "unit_id": 103111,
        "voice": "vo_adv_2013009_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "做為使伊莉亞變身的契機到底為何？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n一直以來都相當令人不解……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是在被{player}觸碰到之時，",
        "unit_id": 103111,
        "voice": "vo_adv_2013009_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n又或是在打從心底想要守護我們之際，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n便能夠取回原本應有的樣貌――",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "換句話說，",
        "unit_id": 100611,
        "voice": "vo_adv_2013009_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這就是愛的力量對吧☆",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "眾卿們！",
        "unit_id": 104411,
        "voice": "vo_adv_2013009_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可別在那兒油嘴滑舌了，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還不趕緊退到妾身的身後！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身會以魔法來展開結界！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哇哈哈哈！　",
        "unit_id": 104411,
        "voice": "vo_adv_2013009_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "臣服於妾身之下吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n連個名號都不報上就向少女們搭話的無恥之徒！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你就死在這兒趕緊往生，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "然後來世再好好學學禮儀吧！",
        "unit_id": 104411
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哎呀，",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳還真是有自信呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過就是個一介玩家，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還以為能與遊戲的營運者平起平坐嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "話說妳也太囂張了吧，",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳啊……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是把自己當成了何等人物了呀。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "竟然如此得意忘形，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我就讓妳對此後悔萬分吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "反倒是妳。",
        "unit_id": 106914,
        "voice": "vo_adv_2013009_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳就準備死在這兒，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然後直到來世也一事無成地",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "自怨自艾吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚……！　",
        "unit_id": 104411,
        "voice": "vo_adv_2013009_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "比預期還要更強的破壞力，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n倘若被直擊，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "結界可是輕易地就會被破壞殆盡呀！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然如此",
        "unit_id": 104411,
        "voice": "vo_adv_2013009_034"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就以攻擊魔法與之對擊，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓軌道偏移！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "伊莉亞！　",
        "unit_id": 103111,
        "voice": "vo_adv_2013009_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳那判斷雖然正確……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但是還請務必注意",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "別讓攻擊魔法，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n往難民們逃離的方向飛去了！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "豈用妳說，",
        "unit_id": 104411,
        "voice": "vo_adv_2013009_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身心知肚明！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "接下來……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就只能祈禱被那傢伙破壞的房屋之內，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n沒有任何尚未",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "及時逃出的傢伙了！",
        "unit_id": 104411
    }
