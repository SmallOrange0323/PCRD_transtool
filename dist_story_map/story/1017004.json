        "voice": "vo_adv_1017004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n感覺應該取決於與你建立羈絆的對象。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你會看到這樣的「夢」，",
        "unit_id": 190011,
        "voice": "vo_adv_1017004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該就代表著你心中的某處也在懷念「故鄉」吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓這樣的你在「夢」裡看到故鄉的一隅，",
