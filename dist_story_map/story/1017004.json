        "voice": "vo_adv_1017004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
