        "voice": "vo_adv_1017004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不斷地到處流浪呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，總而言之呢……",
