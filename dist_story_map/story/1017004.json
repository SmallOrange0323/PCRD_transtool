        "voice": "vo_adv_1017004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也算是一種讓人懷念的「故鄉的味道」吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n難怪你能夠了解香織的心情呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的情況也像是遠離故鄉，",
