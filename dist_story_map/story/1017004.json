[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚼嚼。",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n嚼……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯～果然還是有哪裡不太一樣呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我用和你一起採收的「像苦瓜的東西」，",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n試著重現故鄉的料理啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過還是只做得出「類似的料理」呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "似是而非啊～",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n的確已經非常像了，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但總覺得微妙地缺少什麼東西呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "調味？口感？外觀？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～讓人真懊惱呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原本為了感謝你幫忙我採收……",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n想要給你嚐嚐我故鄉最美味的料理的……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過做成這樣，根本算不上是答謝呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "連我「感謝」之意的百分之一都還表達不出來啊～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n已經很好吃了嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "聽你這麼說是讓我鬆了一口氣……",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過你也不用勉強自己吃下去呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "剩下來的話我會拿去給【哞哞自衛隊】的大家吃啦。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "其實我今天是負責煮飯的人～要幫【哞哞自衛隊】煮飯啦。",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你要是全部都吃光的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我就必須再料理一次了，反而更麻煩呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗚啊！？",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這怎麼回事，周遭好像在發光耶～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "奇怪了奇怪了，我有碰到什麼不該碰的魔法陣嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_1017004_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我常常因為這種失誤而惹大家生氣啊～！",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "510050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喂～{player}！",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n嗨──呵☆",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真巧呢～你在這裡幹什麼？你好嗎～？",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "奇怪了……反應真是冷淡，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "難道你忘記我了嗎？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～這也沒什麼關係啦，",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我們再從頭開始變成好朋友就可以了～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直呢～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，為什麼要用「喜屋武香織」的全名叫我呢？",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且還加上了「小姐」，感覺很陌生讓我好寂寞呢～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀？你呀……該不會是，",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n吃漢堡太大口吃得滿嘴都是，所以講不出話啦～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說看起來塞住喉嚨了，這樣可是會窒息的呦？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "抱歉呀～！",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我幫你拍拍背喔，拍、拍！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你沒事吧～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，看來你有好好記得我，讓我放心了呢～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我雖然把每個人都當作朋友，",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但並不代表我只想跟大家當泛泛之交呢～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想要和你",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "變成更好的朋友呢～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要是你不討厭的話啦！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我是為了空手道全國大會才會來到東京～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過大會已經結束了，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "直接回去的話感覺很浪費，所以才會四處閒晃呢～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n感覺都市的東西都好稀奇呢～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就像是早一點到來的暑假～",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "爺爺和奶奶也都叫我要去「增廣見聞」呢～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過我身上沒什麼錢，",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在住宿和食物這部分實在很頭痛呢。",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "反正，船到橋頭自然直啦～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然都市和沖繩很不一樣，不過在這裡生活的同樣都是人～",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要保持誠意與大家接觸，大家也都會溫柔對待我呢～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？你說要是肚子餓的話可以吃你的漢堡？",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "搶別人的飯吃讓我有點過意不去呢～沒關係嗎？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你說點太多了，吃不完？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸嘿嘿。",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我可不是為了討飯吃，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才向你搭話的呦。",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過我很高興～謝謝你！",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你真的很溫柔呢～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "最喜歡你啦♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我要開動了～",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚼嚼♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈……☆",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n漢堡這種美國食物也是故鄉的味道呢～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真是讓人懷念呢～",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過總覺得，好像還少了什麼呢？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，搞不好是缺了調味料呢？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "加上這個奶奶直傳的醬汁呀～",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n只要有這個醬汁，隨時都能感受到故鄉的味道呢～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以我才會隨身帶著這醬汁呦～啊哈哈♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真的非常謝謝你！",
        "unit_id": 101731,
        "voice": "vo_adv_1017004_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n多虧了你和我一起吃飯，感覺心靈和肚子都超滿足的呢～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是不麻煩的話下次再陪我吧，現實世界和阿斯特朗都要呦♪",
        "unit_id": 101731
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "奶奶直傳的醬汁……",
        "unit_id": 190011,
        "voice": "vo_adv_1017004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真好奇是什麼味道呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對我來說，味覺算是一種未知的領域呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對你來說，速食店的漢堡呢，",
