[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了蒐集神秘男的相關資訊，\n七七香和{player}去了常去的魔法道具店。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗨嗨店長！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然很突然，但我最近在找個人！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n是關於一個拿著奇妙的魔導書到處分發的神秘男，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你知道些什麼嘛？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_1013005_001"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "真抱歉，但我不知道呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "比起這件事，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "店裡進了很多",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "七七香可能會喜歡的東西呦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這不是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "和已經決定要做成動畫作品",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "聯名的魔術道具嘛！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊啊，你不知道動畫？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n是最近發明的",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "超神技術！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是一種快速播放多張畫，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就能使畫中的人物好像動起來一般的技術喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後再用魔法播出！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這樣懂嘛？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "二次元會",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "動起來呦！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對我們御宅族來說簡直是到了天堂一般！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為角色在眼前活生生地動了起來！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼喔！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是只販售短短三天的，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n夢幻超稀有魔術卡！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且還附上畫家的簽名！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "受不了啦──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "唉呀，",
        "unit_id": 1411,
        "voice": "vo_adv_1013005_009"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "但我還真沒想到七七香會帶男朋友來呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我不太懂你在說什麼。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嗯？",
        "unit_id": 1411,
        "voice": "vo_adv_1013005_011"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "旁邊這位小兄弟，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不是妳的男朋友嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不不不，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是不是不是不是不是！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "把我這種土氣的御宅族當成他的女朋友，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對{player}太失禮了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可、可可可可可愛！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "欸！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "美美美美美女──！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔啊啊……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太不習慣了身體產生排斥反應～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你你你",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你知道你在說些什麼嗎！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n那些話對七七香來說簡直像毀滅的咒語！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再、",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再留在這裡勢必會很危險！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n七七香，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "緊急撤離！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再會了──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "啊！",
        "unit_id": 1411,
        "voice": "vo_adv_1013005_018"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喂──七七香！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼……",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼{player}是男朋友，\n是哪來的想法呀！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可能是、",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最近我們太常一起行動，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但那是因為他是夥伴呀！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……客、",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "客觀的角度來看，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就像是在約會一般嗎。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "定、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "定期巡迴也是……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該不會我現在",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是個十足的現充……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不不不快清醒！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "弄清自己的身分！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是魔法少女兼重度御宅族！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n最喜歡漫畫了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最喜歡美少女了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒錯，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現充什麼的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我才不是現充……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不如說……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現充都給我爆炸啦──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我正在重新審視自己，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後在想是不是要毀滅現充……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦、",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚啊啊啊啊！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "{player}！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不、",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我才不是因為覺得難為情而逃跑喔？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n真的喔？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天的七七香也是在絕佳狀態喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "比、",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "比起那個！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "關於那個神秘男呀！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一般的商人如果不知道的話……",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "問問檯面下的人怎麼樣呢……",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為所屬的公會的關係，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我認識黑市裡的人。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果是黑市的魔法道具商人的話，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說不定會知道些什麼！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果在這邊等的話，就會……",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來了來了那個男人！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "唉呀唉呀，「收藏家」。",
        "unit_id": 311,
        "voice": "vo_adv_1013005_033"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "今天要找些什麼呢？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呀齁呀齁！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天呀，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是有個問題想問一下你。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "嗯……",
        "unit_id": 311,
        "voice": "vo_adv_1013005_035"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "但我這裡可不是蒐集情報的店呢……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "不過，",
        "unit_id": 311,
        "voice": "vo_adv_1013005_036"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "如果被妳的公會視為敵人，那可是件麻煩事。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n只有這次喔？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯嗯！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只有這次只有這次！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可真是幫了大忙！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個啊──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "原來如此。",
        "unit_id": 311,
        "voice": "vo_adv_1013005_038"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "直接從結論來說，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我知道那個男人。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哇出現了！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n詳情！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "詳情希望！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那個人一邊在大陸中旅遊，",
        "unit_id": 311,
        "voice": "vo_adv_1013005_040"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "一邊蒐集所有見到的魔導書和魔法道具，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n然後再免費將那些東西交給自己相中的人。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦……",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_041"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼這麼做呢？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "這個嘛，",
        "unit_id": 311,
        "voice": "vo_adv_1013005_042"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "理由就……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "不過，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "他也跟我交易了不少次喔。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我們商人之間，",
        "unit_id": 311,
        "voice": "vo_adv_1013005_043"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "都稱那個男人為「黑暗收藏家」。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯。",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_044"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果是我，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n絕不可能免費將稀有的魔導書送給別人喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……我說，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_045"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要怎麼做才能和那個男人見到面呢？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "這個嘛……",
        "unit_id": 311,
        "voice": "vo_adv_1013005_046"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "實際和我交易的人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "是那男人的徒弟們呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n因為沒和本人碰上面，所以連他的所在地都不知道。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉呀，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_047"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是這樣啊？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那可真可惜",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還以為終於可以見面了呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "……在傳聞中，",
        "unit_id": 311,
        "voice": "vo_adv_1013005_048"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那個男人在找一樣東西。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n為此在招募夥伴中呢……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我知道的就這麼多了。",
        "unit_id": 311,
        "voice": "vo_adv_1013005_049"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n其他麻煩的事就請放過我吧，我先告辭了呦。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好呦──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_050"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "謝謝啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "……我們也有點交情，",
        "unit_id": 311,
        "voice": "vo_adv_1013005_051"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "所以想給妳個忠告。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "聽說那個男人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "似乎是個相當厲害的魔法師。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "恐怕……",
        "unit_id": 311,
        "voice": "vo_adv_1013005_052"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "比妳強悍很多呢……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n好奇心往往會帶來悲劇……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "請萬萬小心。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……嗯呼呼──",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_053"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "又是一個熱血的展開呢──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那樣的忠告反而點燃我魔法少女的鬥志！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "君子不履險的話，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_054"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是無法成為主角的吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然只是預測，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_055"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "個人覺得那男人在找的東西，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該正是傳說中的魔導書吧──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "首先，",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_056"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為了找到男人，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "先找到他的徒弟吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013005_057"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "事情要變得有趣囉──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等著吧神秘男！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我絕對不會將傳說中的魔導書交給你的！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七七香因為這符合魔法少女劇情的情節，\n熱血沸騰了起來。"
    }
]