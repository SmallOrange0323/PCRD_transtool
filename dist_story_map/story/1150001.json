[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在大間逗留的日子進入尾聲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}獨自走在街上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遇見了同樣在街上散步的似似花。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你好。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n有好好享受在大間鎮上的生活嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看你像這樣在街上散步，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n應該相當樂在其中吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那真是再好不過了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你看起來",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是單獨行動呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你的夥伴們都去哪了？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……原來如此，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在收拾回程的行囊啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陛下和你們的人脈都很廣，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要帶回去的伴手禮想必",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "相當可觀吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正合我意呢……",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "跟我來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n接下來的這段時間，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你必須和我待在一起。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你沒有拒絕的權力。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這件事已經拍板定案了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或許可以這麼說呢。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "閒話就到此為止，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要走囉。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n詳細情況等到了現場再說。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們到了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "等您很久了，",
        "unit_id": 5311,
        "voice": "vo_adv_1150001_008"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "大人！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "辛苦了。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都準備好了嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "是的，",
        "unit_id": 411,
        "voice": "vo_adv_1150001_010"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "船隻已經備妥了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很好，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就走吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "好的。",
        "unit_id": 1011,
        "voice": "vo_adv_1150001_012"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "要出發囉！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "快上船吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你比較期待豪華的郵輪之旅嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很遺憾，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請等下次吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他們是我創造出來的複製品。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還有，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你若是以為這是某種悠閒的海上娛樂，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就稍顯缺乏憂患意識了喔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我現在要去",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "釣金槍鮪。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而你",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "將擔任我的助手。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "難得長途跋涉來到大間，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也想",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "釣些金槍鮪當作伴手禮帶回去。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不必擔心，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我有取得海釣許可。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "外行人私自開船出海，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "照理來說是不被允許的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我很順利地拿到許可了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n因為這裡的漁夫們",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "欠了我一筆很大的人情。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "從市場買現成的魚",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "毫無樂趣可言。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然都來了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我更想品嘗自己釣的魚。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也是這麼想的吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而漁夫們卻說了：",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「小姑娘啊，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "釣魚和消滅魚",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是兩碼子事喔？」",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "等等，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "盡是瞧不起我的無稽之談。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說實話，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我感到很火大。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而且是相當地火大。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了讓他們刮目相看，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請你助我一臂之力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我需要你的力量。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不是公主騎士的力量，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而是作為一個男人的力量。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來你能理解我的心情呢。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們出發吧。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "501190"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……應該快到垂釣地點了。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "去準備吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "假漁夫1",
        "words": "大人──！",
        "unit_id": 1411,
        "voice": "vo_adv_1150001_026"
    },
    {
        "type": "dialogue",
        "name": "假漁夫1",
        "words": "已經抵達目標海域了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "謝謝。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "開始釣金槍鮪吧──",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "假漁夫1",
        "words": "好！",
        "unit_id": 1411,
        "voice": "vo_adv_1150001_028"
    },
    {
        "type": "dialogue",
        "name": "假漁夫1",
        "words": "大夥們，要幹活啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "假漁夫2",
        "words": "喔喔！",
        "unit_id": 1,
        "voice": "vo_adv_1150001_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就交給你們了。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_030"
    },
    {
        "type": "dialogue",
        "name": "假漁夫們",
        "words": "遵",
        "unit_id": 1,
        "voice": "vo_adv_1150001_031"
    },
    {
        "type": "dialogue",
        "name": "假漁夫們",
        "words": "命，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "假漁夫們",
        "words": "女士！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是兩個人啊？",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你說了很奇怪的話呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如你所見，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我正在自己釣魚。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那些複製品",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "全部都是「我」喔？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "前幾天漁夫們捕魚時，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我觀察了他們的行動與手法，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了確認能否將其再現，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "才策畫了今天這場海釣。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是我經過思考後得出，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n既合乎法規又屬於我的釣魚方式。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "假漁夫1",
        "words": "大人，您快看──！",
        "unit_id": 1411,
        "voice": "vo_adv_1150001_035"
    },
    {
        "type": "dialogue",
        "name": "假漁夫1",
        "words": "\n是條大魚喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "假漁夫1",
        "words": "真是個好兆頭啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你看。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在那裡歡欣鼓舞的人",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也同樣是我。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n雖然身體和思想不同，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但都共享了我雀躍的心情。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不建議你這麼做。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你知道捉捕金槍鮪有多麼困難吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那不是隨便一個外行人就能插手的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "機會難得。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是和你一起，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我開始有點想用自己的身體釣魚了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "支持努力向上的學生，",
        "unit_id": 1,
        "voice": "vo_adv_1150001_040"
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "\n也是身為教師的職責嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你不會連我用自己的分身都要追究吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你和我都是手無縛雞之力的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請你至少意識到這一點。",
        "unit_id": 107011
    },
    {
        "type": "still",
        "still": "115000101"
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "那麼，",
        "unit_id": 1,
        "voice": "vo_adv_1150001_042"
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "要釣囉。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "\n讓魚類好好見識人類的力量吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "千萬別放開釣魚線，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "知道了嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "我會在旁邊支撐著你。",
        "unit_id": 1,
        "voice": "vo_adv_1150001_044"
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "把重心往下移──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "！！",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "上鉤了喔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n靜下心來，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "冷靜應對吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "……但是，",
        "unit_id": 1,
        "voice": "vo_adv_1150001_046"
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "這股拉力",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "實在是太強了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "\n原來如此，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "這就是用自己身體釣魚的感覺啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "擁有知識",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和自己實際操作",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還是有非常大的不同呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是沒想到。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再這樣下去會有危險……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……知道了。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我也拿出全力回應你吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "唔……！",
        "unit_id": 1,
        "voice": "vo_adv_1150001_049"
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "就、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "差一點了……",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501190"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……釣上來了。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是條大魚喔！",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n做得很好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "分身也",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "辛苦了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼樣？",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有享受到嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說到你這個人，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該連年底都在四處奔波吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n難得的新年，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我為你準備了一個無人打擾的場所，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓你能慢慢享受釣魚的樂趣。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這也是我當初決定開船出海的目的之一。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然和最一開始的計畫相比，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "耗費了更多的體力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你不必感謝我。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這頂多",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只能算順便而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好不容易有點幹勁了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們瞄準更大的目標吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們也",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "別鬆懈了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "知道了嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "假漁夫們",
        "words": "是！！",
        "unit_id": 1,
        "voice": "vo_adv_1150001_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯……",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "釣這麼多就夠了吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "成功釣起一次後，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "之後就都手到擒來了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然就這樣把大間近海附近的金槍鮪",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n都釣起來",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好像也不錯……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真拿你沒辦法。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_059"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n以伴手禮來說，這些量已經夠了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n差不多回港口去吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剩下",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "最後一件事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你今天玩得開心嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……是嘛。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那真是太好了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們去讓那些漁夫們大吃一驚吧。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "喲，",
        "unit_id": 1411,
        "voice": "vo_adv_1150001_062"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "小姑娘。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "妳釣到金槍鮪了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是啊，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_063"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "託你的福，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算是大豐收喔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要不要來船上看看呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "我看看〜？",
        "unit_id": 1,
        "voice": "vo_adv_1150001_064"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "……竟、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "竟然是真的！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "光憑你們兩個人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n就釣了這麼多金槍鮪嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "太不可思議了吧……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是啊，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_065"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只憑我們兩個人。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n若是懷疑我找了幫手，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就去問問你的同行吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "這、",
        "unit_id": 1411,
        "voice": "vo_adv_1150001_066"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "這真是太驚人了……！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒什麼好訝異的。",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_067"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我只是稍微",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "模仿了一下\n你們出色的技術而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "什麼……？",
        "unit_id": 1,
        "voice": "vo_adv_1150001_068"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們說釣魚和消滅魚是兩碼子事，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_069"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就參考了",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你們這些專家的做法，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "才有了這麼多收穫。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n大間漁夫的技術",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真的相當出色呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "是、",
        "unit_id": 1,
        "voice": "vo_adv_1150001_070"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "是啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "妳說的沒錯！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n嘿嘿，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "妳很清楚嘛，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "小姑娘！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_071"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "實在是太過出色了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我在模仿的過程中，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不小心釣得有些超過。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "扣除我們需要的量，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剩下的部分你可以隨意處置。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "交給我吧！",
        "unit_id": 1411,
        "voice": "vo_adv_1150001_072"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "機會難得，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "就來個金槍鮪解剖秀，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n招待鎮上的大家吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "你們也要來捧場喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵……",
        "unit_id": 107011,
        "voice": "vo_adv_1150001_073"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你也會去吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這次就讓我們在餐桌上，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "見識漁夫們那份出色的技術吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "注視著因似似花的讚美而心花怒放的漁夫們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與因此露出壞心眼微笑的似似花，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}無奈的聳了聳肩。"
    }
]