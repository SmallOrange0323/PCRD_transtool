    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿，",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這都要歸功於妳啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老實說，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我有試著模仿妳的動作！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈哈！",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_005"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "難怪我覺得動作很俐落啊～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n真不愧是日和呢！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "看來我才一下子",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就被妳給追上──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔喔喔喔喔喔！！",
        "unit_id": 1,
        "voice": "vo_adv_5136067_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "奇怪？",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這個聲音是……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在這裡嗎────！！",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "諾維姆！",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n果然是妳！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊～",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_010"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "諾維姆！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嘿～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "還真巧呢！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "沒想到連在這裡都能見到妳啊～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳知道我的名字嗎？",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n沒想到居然連沒見過的人都知道我……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來我也變有名了呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真不愧是天下第一大壞蛋！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈──哈哈！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哦，",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_012"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大壞蛋！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……不過",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "事實上，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我們不是沒見過面啦～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n因為我認識另一邊的諾維姆嘛？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "另一邊的……？",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這是什麼意思？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說回來，妳……",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n有股奇怪的氣息呢。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺好像……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以前有在哪裡見過……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "諾維姆，",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我跟妳介紹一下！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "她是埃拉！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n來自與這邊不同的另一個世界！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳說……",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n另一個世界！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來如此……",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳說的另一個世界，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是這麼回事啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是沒有聽說過……",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但如果是阿斯特朗，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺就有可能？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不過……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n也是，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很驚人吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這種時候證據比理論還要更好懂！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n──出來吧，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "天樓霸斷劍！！",
        "unit_id": 135512
    },
    {
        "type": "still",
        "still": "513600202"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊！？",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n果然是這樣啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就覺得有股很像是天樓霸斷劍的氣息！",
        "unit_id": 106113
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來如此！",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以妳才跑到我們這裡來了啊。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這是",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_022"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "另一個世界的諾維姆借我的喔！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "來，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳摸摸看確認一下吧♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔唔唔……",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然有點不一樣，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但的確是天樓霸斷劍呢……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣擺在一起看，",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的是很像呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "居然會如此地相像，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺好不可思議啊。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊，",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_025"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "諾維姆，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳要不要稍微揮揮看？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳不是對天樓霸斷劍的二刀流",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很感興趣嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "二刀流！？",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這也太有夢想了吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就借用一下……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿呀啊啊啊啊啊！！！",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n天樓霸斷劍，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "二刀流！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喔喔～！",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好帥！！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈哈哈！",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_029"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n嗯嗯，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "感覺不錯！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "既然如此……",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_030"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n諾維姆，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳要不要用用看？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n之後也一直拿著它吧。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳、",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳在說什麼啊？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這把天樓霸斷劍，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不是屬於埃拉世界的諾維姆嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不需要！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "外觀確實很像，",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但感覺不太對！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為這把天樓霸斷劍",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是我的。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "事情就是這樣！",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳就把它",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還給另一個世界的我吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊……",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_035"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n果然是這樣呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "因為每次「重置」的時候都會回到我手上，",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_036"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n所以想說乾脆就這樣給妳……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過看來就算是「真品」，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對「本人」來說還是不一樣啊。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉，妳這樣不行啦！",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳自己借的東西，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就要自己拿去還啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說的沒錯！",
        "unit_id": 106113,
        "voice": "vo_adv_5136067_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不物歸原主，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是會變成很壞的大壞蛋呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "唉呀──",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_039"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我要是變成壞蛋可就困擾了呢～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n因為會很困擾，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以我不會再說第二次了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n啊哈哈哈哈！",
        "unit_id": 135512
    }
]