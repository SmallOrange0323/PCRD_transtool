    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "擊掌！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "擊掌！",
        "unit_id": 100111,
        "voice": "vo_adv_5136067_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聽說魔物很強，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以我原本還有點擔心，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n能順利打倒真是太好了～♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "魔物的確是很強哦？",
        "unit_id": 135512,
        "voice": "vo_adv_5136067_003"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "日和的動作比它更俐落呢！",
