    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "甚至感覺其實不需要我的幫助耶？",
        "unit_id": 135512
