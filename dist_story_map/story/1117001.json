    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在幫忙跟打工之中度過了忙碌的日子。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正準備要在房裡睡覺的時候，從某處傳來了模糊的聲音……"
