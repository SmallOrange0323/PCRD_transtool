        "unit_id": 1,
        "voice": "vo_adv_1117001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n居然這麼輕易地就能夠侵入房間……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n警戒心還真是不足啊。",
        "unit_id": 1
    },
