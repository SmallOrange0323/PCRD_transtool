    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼……",
        "unit_id": 102811,
        "voice": "vo_adv_5213063_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種味道……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我可能是第一次嚐到……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明是蔬菜，",
        "unit_id": 102811,
        "voice": "vo_adv_5213063_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "卻像精緻糖果一樣……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可是同時，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "從深處緩緩湧上的是濃郁又溫和的泥土香氣……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不只有單純的甜味，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還多了層次與風味！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正好，",
        "unit_id": 102811,
        "voice": "vo_adv_5213063_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我在找能讓育幼院的孩子們",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不再挑食的",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "蔬菜料理呢！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以把食譜和材料",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "分給我嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好的，",
        "unit_id": 126511,
        "voice": "vo_adv_5213063_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒問題。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如果是要給孩子們吃，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "有幾點需要注意。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這些蔬菜越甜，",
        "unit_id": 126511,
        "voice": "vo_adv_5213063_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "熱量也越高。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "簡單來說……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吃太多會變胖。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔～～～～！？",
        "unit_id": 102811,
        "voice": "vo_adv_5213063_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我果然",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是不要",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "外帶了～！！",
        "unit_id": 102811
    }
]