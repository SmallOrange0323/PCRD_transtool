[
    {
        "type": "background",
        "background": "501640"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──好的，",
        "unit_id": 1,
        "voice": "vo_adv_2201099_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "辛苦了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真是的──",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_001"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n是怎樣？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你那寫滿失望的表情……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……挺不錯的。",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_002"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "再繼續讓我看看吧？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你現在的眼神，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就像是卡在洞裡的小狗一樣教人欲罷不能呢……♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你說「一樣」",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_003"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "呢──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "看來你還記得我，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真開心♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過嘛，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_004"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我希望你把我開的小玩笑",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n當成我是在撒嬌。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n誰叫……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你的周圍，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_005"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n有那～～麼多女孩子呢？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "話說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "怎麼好像又增加了？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "為了讓你留下印象，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_006"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我也不得不表現得尖酸刻薄一點，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你說是吧？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n……對我而言，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我也不太想這樣……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_007"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……啊哈♪",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_008"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊哈哈哈♪",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_009"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n拜託別這樣好嗎──？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "想也知道不可能嘛，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你那樣子",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就叫做自我意識過剩唷。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……呵♪",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_010"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好了，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_011"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "閒話就說到這邊。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你的新冒險",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "開始了呢～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "離開熟悉的阿斯特朗……",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_012"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是叫「吉歐‧提格尼亞」？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "感覺真是個輕鬆",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "又無憂無慮的世界。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "總之，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_013"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你可別掉以輕心囉。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n之後的路似乎還很長。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n而且馬上",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就會有新的敵人闖進來呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "而且，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_014"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "雖然你們才剛認識就好像很意氣相投。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "但像是那位天使公主或",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "機械女孩，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n對現在的你來說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "還有很多你不知道的事情呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "還是說。",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_015"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "因為你是拯救過阿斯特朗好幾次的英雄大人，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n所以不管遇到什麼危機",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "都能從容面對？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n啊哈，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真可靠呢──♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哎呀這樣嗎？",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_016"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那就好。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "畢竟？",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_017"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對我來說？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n比起無敵的你，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我更喜歡看到因為危機而跌跌撞撞的你……♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊哈♪",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_018"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n有什麼關係嘛。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我會把參觀費",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好好付給你的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "沒錯。",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_019"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你可要好好感謝我呢──？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n真要說起來，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我也是可以只拿不給的喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對於你那嫌棄的表情，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_020"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "以及拼命掙扎的樣子，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我所能支付的代價就是……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這個嘛，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "情報？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "之類的？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "姑且先和你說清楚，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_021"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "情報不是指我的三圍之類的喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你想知道的話，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就來試著對我說些甜言蜜語吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n雖然現在的你應該做不到就是了♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對吧──？",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_022"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我還真是親切呢～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊──",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_023"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n是呢──？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……呵呵♪",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_024"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n這件事",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "呢──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "──現在，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_025"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你們",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "正在接受三個「懲罰」。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對。",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_026"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n也可以說是",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "誓約或代價呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "實現了一般來說",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_027"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "絕對不可能實現的願望，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "所產生的代價。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n因為站上了本應無法站上的舞台，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "而形成的制約。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n扭曲了常理的，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "「懲罰」。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不惜做到如此地步，",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_028"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "都還想著要幫助別人。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……啊哈♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n人類還真厲害呢～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……啊──",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_029"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真可惜。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n今天就到這裡。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "雖然還想繼續開心地看著",
        "unit_id": 193211,
        "voice": "vo_adv_2201099_030"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你那副蠢樣……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哎呀算了，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "等下次吧。",
        "unit_id": 193211
    },
    {
