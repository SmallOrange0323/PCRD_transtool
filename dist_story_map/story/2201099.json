    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "大名鼎鼎的七冠之長。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n就算是那兩人，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "也沒辦法輕易捕獲他。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "首先，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "我們必須從外圍開始進攻。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "……遵命。",
        "unit_id": 193732,
        "voice": "vo_adv_2201099_063"
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "\n",
        "unit_id": 193732
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "那麼，",
        "unit_id": 193732
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "我……？",
        "unit_id": 193732
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "妳的任務，",
        "unit_id": 193631,
        "voice": "vo_adv_2201099_064"
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "繼續執行。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n「模組」固然重要，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "但不會被藏得一點破綻都沒有。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "就像鯨魚換氣一樣，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "終究會露出破綻。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "……",
        "unit_id": 193732,
        "voice": "vo_adv_2201099_065"
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "比起這個，",
        "unit_id": 193631,
        "voice": "vo_adv_2201099_066"
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "重要的是這場難得的革命。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "為了穩住我們的橋頭堡，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n妳要",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "完美控制住舊阿斯特賴亞王國。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "控制到就算「公主」歸來……",
        "unit_id": 193631,
        "voice": "vo_adv_2201099_067"
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "也會被",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "人們當成過街老鼠",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "的地步。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "是，",
        "unit_id": 193732,
        "voice": "vo_adv_2201099_068"
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "局長。",
        "unit_id": 193732
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "……阿斯特朗傳奇。",
        "unit_id": 193631,
        "voice": "vo_adv_2201099_069"
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "可以實現願望的遊戲",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "嗎……",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "簡直",
        "unit_id": 193631,
        "voice": "vo_adv_2201099_070"
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "無聊透頂。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n願望這種東西，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "就是要靠自己的力量實現才有意義。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "但是……",
        "unit_id": 193631,
        "voice": "vo_adv_2201099_071"
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "這場混亂，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "就讓我好好利用一番吧。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神局長",
        "words": "\n這也是為了我們所謂的「正義」啊。",
        "unit_id": 193631
    }
]