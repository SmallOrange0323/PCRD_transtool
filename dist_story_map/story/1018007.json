[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天{player}也請\n伊緒指導功課。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，你已經學會很多了呢。",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像這樣繼續和我一起",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n努力學習很多東西喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，今天希望我教你什麼呢？",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_001"
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "伊緒老師！",
        "unit_id": 111,
        "voice": "vo_adv_1018007_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀……你是我班上的……",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼了？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n之前上課的內容有不懂的地方嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "不、不是那樣的……那個……",
        "unit_id": 111,
        "voice": "vo_adv_1018007_004"
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "\n最近老師總是和那個人在一起對吧？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "被看見了呀……真叫人有點害羞。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "那個！",
        "unit_id": 111,
        "voice": "vo_adv_1018007_006"
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "\n你們兩個人是戀人嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸！？",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我和他！？戀人！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不、不是！不是！",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我們不是那種關係！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我在教他念書。",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也就是老師和學生！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n對，關係僅止於此唷！知道了嗎！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "是、",
        "unit_id": 111,
        "voice": "vo_adv_1018007_010"
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "是……我知道了。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "\n真抱歉……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼～",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是嚇了一跳～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n竟然會被誤會為戀人……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然之前也有裝成戀人……",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但明明只是在教你念書，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n竟然會被看成像那種關係。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……啊！",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n抱、抱歉。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我竟然完全地否定……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要這麼說～",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為我們不是那種關係呀……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對、對呀……",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們只是朋友而已……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對我來說，被誤認為和你是戀人――",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒事，沒事。",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要在意。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過……我的戀人啊。",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n至今從沒有過戀人呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和戀人約會，",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n兩個人獨處……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好憧憬喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我的第一個戀人，會是怎樣的人呢？",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果是像你一樣溫柔，",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n在一起又很開心的人，那就太好了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……！",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "討厭……我、我在說什麼？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我只是不由自主的那樣覺得，",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n沒有特別的意思喔！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，哎唷～！",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我為什麼會說出這種話呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好害羞～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我和你是老師與學生的關係！",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n快點快點，今天的課還沒上完呢！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一直到你學會為止，",
        "unit_id": 101811,
        "voice": "vo_adv_1018007_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n作為老師的我會好好指導到最後的！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n一起加油吧！",
        "unit_id": 101811
    }
]