[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 103311,
        "voice": "vo_adv_2012005_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n話說這次的祭典，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今年怎麼辦得格外熱鬧呢？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然沒有確切數據，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但總覺得來客數比往年多出一倍呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "傳聞是說，",
        "unit_id": 104611,
        "voice": "vo_adv_2012005_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好像有什麼",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "偶像在整個大陸中巡迴，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n難道不是她們替祭典做了宣傳喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是那個嘛，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "最近成話題的……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好像叫【慈樂之音】喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好像也有在這次的祭典中，",
        "unit_id": 104611,
        "voice": "vo_adv_2012005_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "辦個叫什麼凱旋演唱會的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不過嘛，大概也是辦在城中央那邊吧，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n歌聲要傳到這個獸人的居住區應該是有點難就是了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "蘭德索爾",
        "unit_id": 101711,
        "voice": "vo_adv_2012005_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很大的嘛～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然【哞哞自衛隊】\n只要負責獸人居住區的警備就好，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但負責守衛整座城的\n【王宮騎士團】可沒那麼好命了呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說得沒錯唷，",
        "unit_id": 100511,
        "voice": "vo_adv_2012005_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真的是要人命了唷！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以我也",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n想要去幫【王宮騎士團】大家的忙啊～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在才不是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "待在這裡做章魚燒的時候呀！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不行唷～",
        "unit_id": 102011,
        "voice": "vo_adv_2012005_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "茉莉。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "今天是大家一起幫忙顧攤的日子～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "放開我，美美！",
        "unit_id": 100511,
        "voice": "vo_adv_2012005_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那可是英雄",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不得不踏上的戰場啊！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而我雖然",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還只是基層中的基層，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但也算是英雄的其中一員呀～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "茉莉還真是",
        "unit_id": 102011,
        "voice": "vo_adv_2012005_007"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "喜歡那種事情呢～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "但是偶爾也和美美一起，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n玩扮家家酒，或是一起玩人偶之類的嘛",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚～",
        "unit_id": 100511,
        "voice": "vo_adv_2012005_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那種女孩子們玩的遊戲",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我不太喜歡呢！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_2012005_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真可愛呢♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "小孩子們湊在一塊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家一起幫忙顧攤～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊、",
        "unit_id": 102011,
        "voice": "vo_adv_2012005_010"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "妳好，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "【哞哞自衛隊】的姐姐♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚，",
        "unit_id": 100511,
        "voice": "vo_adv_2012005_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "【哞哞自衛隊】可是敵人呀……！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "？　",
        "unit_id": 101711,
        "voice": "vo_adv_2012005_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為啥要瞪著人呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "笑起來可愛多了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "Love&Peace～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈。",
        "unit_id": 104611,
        "voice": "vo_adv_2012005_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大部分的獸人都會被派去顧店、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n負責撿垃圾或當志工之類的事喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好像是，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "【動物苑】營運的城內自治會所決定的事情呀喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊！",
        "unit_id": 101711,
        "voice": "vo_adv_2012005_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我也有聽說～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n前陣子因為衝突和一般人類鬧得不太愉快，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為了改善關係，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以才藉由雙方派出志工之類的互動，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "表達互相協助的善意來和好嘛～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但就連這麼小的小孩子們都得讓她們來幫忙，",
        "unit_id": 104611,
        "voice": "vo_adv_2012005_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n讓人有一點愧疚就是了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "明明就想要開開心心的去逛祭典的喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對吧美美？",
        "unit_id": 104611
    },
    {
        "type": "still",
        "still": "201200501"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯！　",
        "unit_id": 102011,
        "voice": "vo_adv_2012005_016"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "但是也只有今天需要來幫忙嘛～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "從明天開始，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "有和鏡華與禊說好",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n要一起去逛祭典",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "的事唷！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "茉莉，",
        "unit_id": 102011,
        "voice": "vo_adv_2012005_017"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "要不要跟我們一起來呀？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "會介紹美美的好朋友給妳認識的唷～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚　",
        "unit_id": 100511,
        "voice": "vo_adv_2012005_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "謝謝妳邀請我，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是我還有警備的工作！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "得要從壞蛋的手中保護這座城才行呀！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "才沒有什麼壞蛋的唷～",
        "unit_id": 102011,
        "voice": "vo_adv_2012005_019"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "大家都很溫柔，都是好人的唷～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_2012005_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過嘛，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "祭典的確很容易引起小摩擦沒錯，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "別忘了小心一點唷～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們【哞哞自衛隊】在各處都會有人在負責警備的，",
        "unit_id": 101711,
        "voice": "vo_adv_2012005_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以有發現什麼事情的話就跟我們說吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯！　",
        "unit_id": 102011,
        "voice": "vo_adv_2012005_022"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "工作辛苦了，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "姐姐！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "快點，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "茉莉也一起來鞠躬吧。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚～",
        "unit_id": 100511,
        "voice": "vo_adv_2012005_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "正義的夥伴",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "才不會這麼輕易就向敵人低下頭的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才不是敵人唷～",
        "unit_id": 101711,
        "voice": "vo_adv_2012005_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "全人類都是一家人呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是好朋友唷～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈。",
        "unit_id": 104611,
        "voice": "vo_adv_2012005_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "美美，最近好像變得更懂事了喵～",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n明明不久前還會一不注意追著蝴蝶",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
