        "voice": "vo_adv_1066010_050"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比起那個，剛剛的話才說到一半啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們地盤上的傢伙都吵吵鬧鬧的，很令人困擾呢……",
