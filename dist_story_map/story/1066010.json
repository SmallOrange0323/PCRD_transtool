        "voice": "vo_adv_1066010_053"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n但又跟老大那時所進行的覺醒",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "完全不同……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如果能像老大做過的那樣，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_054"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "完成所謂真正的覺醒，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n應該就可以迅速地變強了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然如此，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就來覺醒吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以說，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_055"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要請你幫忙囉！",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "501330"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果",
        "unit_id": 106711,
        "voice": "vo_adv_1066010_056"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨她想要進行覺醒，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "希望你阻止她♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}的腦海中，回想起了來自帆稀的「請託」。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊？",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_057"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼啦？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你是害怕了嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "難道說……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你是擔心我變得太強，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_058"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n把你丟下不管是吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不用擔心啦，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_059"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管我變得多強，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n都不會丟下小哥，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "會好好指導身為手下的你。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n所以你就放心地來幫助我覺醒吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "關於這個啊……",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_060"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n好像",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有所謂的",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "覺醒條件之類的東西？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "似乎是",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_061"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "夥伴，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "或家人",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那些……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說起來，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大她的覺醒條件是什麼呢？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "錢？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯～",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_062"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為老大她唯利是圖，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我還想說這個方向是對的呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對吧對吧！",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_063"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n畢竟是那個老大啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這點小事也不值得驚訝嘛。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算啦，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_064"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這時候就交給天才祈梨大人我吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n總之，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為親近的人遇到危機",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而瞬間覺醒！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這可是最典型的呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_065"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要把這個榮譽的職責交給小哥你。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你要不要稍微瀕死看看？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼啊，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_066"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是小氣耶。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這時候就要充滿氣勢地",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "勇往直前啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種發展之前也有過",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_067"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你這麼一說，我好像有一點印象呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如果我的條件是小哥遇到危機的話，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_068"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那麼到現在為止覺醒個十次左右都不奇怪呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說回來，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_069"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你會不會瀕死太多次了？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n再稍微小心一點生活啊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算啦，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_070"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如果是像我這樣的天才，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n怎麼可能會是那種老套的條件嘛。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我從很久以前就這麼認為了，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_071"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我應該是那種被誇獎、疼愛，\n就會成長的類型啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也就是說……",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_072"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要能再見慈樂之音一面，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "應該就會覺醒了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一定會覺醒的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊？",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_073"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我可不是在開玩笑喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "應該說，見到慈樂之音、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "見到望望卻沒有覺醒，\n反而才奇怪也很失禮不是嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "之前嘉夜夜",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_074"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "和望望待在一起時，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不也是一下子就變得全身白了嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那就是慈樂之音的力量啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是這樣，所以……",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_075"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n來吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓我見慈樂之音！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n又或是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "買些什麼好吃的點心過來！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著逐漸脫離認真方向的祈梨，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}鬆了一口氣。"
    },
    {
        "type": "background",
        "background": "501330"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然我想有你在的話應該沒問題，",
        "unit_id": 106711,
        "voice": "vo_adv_1066010_076"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但還是以防萬一……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對吧。",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_077"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你說了什麼嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不提這個了，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_078"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我想起了很好的特訓方法，你聽我說！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥成為我的手下也很長一段時間了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也差不多可以解除限制了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就來進行那個吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_079"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說到幫派就是那個！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n兩個人在草原上全力奔跑！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n接下來就進行這項特訓吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}追著跑出去的祈梨。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾今天也很和平。"
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔嗯……",
