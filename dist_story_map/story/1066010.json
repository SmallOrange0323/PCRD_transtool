        "voice": "vo_adv_1066010_080"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "原來如此。",
        "unit_id": 8111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n總之勘查就到這邊吧。",
        "unit_id": 8111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n在小蟲子們開始大鬧前就先撤退。",
        "unit_id": 8111
    },
    {
        "type": "dialogue",
