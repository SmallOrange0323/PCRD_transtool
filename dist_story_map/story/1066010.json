[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一大早就被祈梨叫出來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前來造訪了公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以說，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是讓家族壯大的活動！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n鼓足幹勁上吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "廢話不多說，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就去看看手下們的情況，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n以大幹部的身分為大家打氣！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你要好好跟上喔！",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "哎唷，",
        "unit_id": 911,
        "voice": "vo_adv_1066010_002"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "所以就說有好好在工作了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "說是這麼說，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "但我們就跟之前說的一樣，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n只是照著老大留下的指示去做而已。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "就是這個，",
        "unit_id": 811,
        "voice": "vo_adv_1066010_003"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n重點復興地區，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "還有給他們的貸款利息的指示資料。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣的指示",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是大多很籠統嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要稍微在這裡",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "提高一點我們的利潤就好啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "話雖如此，但復興地區到處都很辛苦……",
        "unit_id": 911,
        "voice": "vo_adv_1066010_005"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n沒辦法做這種斂財的事啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1066010_006"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "龍骨家族的成員們，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這是這個月的還款。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "喔，",
        "unit_id": 811,
        "voice": "vo_adv_1066010_007"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "我確實收到了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "怎麼樣了啊，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "家裡那邊？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "託你們的福，",
        "unit_id": 1411,
        "voice": "vo_adv_1066010_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "總算不用讓孩子們露宿野外了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這份恩情",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我一定會報答的！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "大嬸，",
        "unit_id": 911,
        "voice": "vo_adv_1066010_009"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "妳那邊怎麼樣？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊，",
        "unit_id": 1511,
        "voice": "vo_adv_1066010_010"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "對不起啊……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n這個月的還款有點……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "啊，",
        "unit_id": 811,
        "voice": "vo_adv_1066010_011"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "沒關係沒關係。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n畢竟老大也指示說，等生意重新開始後再還錢嘛。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "真抱歉啊……",
        "unit_id": 1511,
        "voice": "vo_adv_1066010_012"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "相對地，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "等店面重新開張後，請讓我好好地招待你們一頓啊。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "哈哈，",
        "unit_id": 911,
        "voice": "vo_adv_1066010_013"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "真令人期待啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "啊，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "總之，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "到處都是這種感覺吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在這種時候搾取錢財",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "的確不是我們的作風呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "而且不知道老大是怎麼做到的，連損害金額都正確記錄下來……",
        "unit_id": 811,
        "voice": "vo_adv_1066010_015"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n每一家都有個別指示啊。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "多虧如此，我們也有不錯的獲利。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊？",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那是怎麼回事？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "簡直就像是預先知道事情會變成這樣啊，",
        "unit_id": 911,
        "voice": "vo_adv_1066010_017"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "真不愧是老大呢。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "甚至還附上了還款計畫的範本，",
        "unit_id": 811,
        "voice": "vo_adv_1066010_018"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n那個人",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "真是恐怖啊……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她該不會",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "事先用時間儀調查過了吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如果是老大，確實有可能這麼做呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我知道這邊的工作情況了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後呢，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "其他的生意怎麼樣了？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "雖然妳這麼問，",
        "unit_id": 911,
        "voice": "vo_adv_1066010_021"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "但敵對組織已經潰敗解散了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "而且可以索取場地費的那些店，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "也像這樣正在復興中啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "目前真的就只有這些事了啊。",
        "unit_id": 811,
        "voice": "vo_adv_1066010_022"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "所以",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "祈梨妳也放輕鬆一點嘛。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是太丟臉了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我知道了啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n家族的事情就交給你們了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "總之，",
        "unit_id": 911,
        "voice": "vo_adv_1066010_024"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "和平是再好不過了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "來，",
        "unit_id": 811,
        "voice": "vo_adv_1066010_025"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "給妳零用錢，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "妳就用這些去鎮上晃晃吧。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼～？",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不要把我當成小孩子啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "錢我就收下了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "那麼小哥，",
        "unit_id": 911,
        "voice": "vo_adv_1066010_027"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "祈梨就拜託你了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "可不要讓她亂花錢喔～",
        "unit_id": 811,
        "voice": "vo_adv_1066010_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "吵死了！",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你們不要偷懶，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "趕快去工作啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的……",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和祈梨"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n望著在鬧區來來去去的人們。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "接下來，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說到要做的事",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是公會活動了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但畢竟龍人族不會那麼容易就出現嘛。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然在「吉歐‧提格尼亞」找到了雙胞胎，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_031"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n但她們似乎沒有想加入【龍族巢穴】的意思……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過說到底，",
        "unit_id": 106611,
        "voice": "vo_adv_1066010_032"
    },
    {
        "type": "dialogue",
