[
    {
        "type": "background",
        "background": "500352"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哈呼，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "終於活過來了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n啊，真是的，好累啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝你",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n幫我提東西……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "多虧有你，我才沒有冒失地把購物袋掉在地上，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n終於回到【咲戀育幼院】。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯？如果要道謝的話，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也要向地藏……魔像們說？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說的也是呢～大家都辛苦了♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。我被報恩了呢，好像繪本一樣。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為大小姐意外地喜歡這種事情，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n她知道的話也許會很羨慕。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，雖然不能好好招待大家……",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你們應該累了吧，請好好休息喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "作為幫我提東西的謝禮，我請你吃晚餐吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "反正為了【咲戀育幼院】的孩子們，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我要做的料理份量相當多，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以增加一人份也完全沒問題。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "至於魔像們，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就注入我的魔力代替晚餐吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請在那邊排好～隊，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "恢復健康～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n魔像們很開心，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好可愛……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "儘管如此，我想它們基本上算是公共財產……",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以不能放在我們這裡呢，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明天我會去公所調查那方面的資料。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "首先必須調查這些魔像們到底是什麼。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果拜託大小姐，就有權限能利用圖書館的資料室，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我想總會有辦法的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果它們是沒有主人的魔像，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我就可以收留它們了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們這裡的男生人手不足，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以有人可以幫忙搬東西的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n真是幫了大忙。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果魔像們",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可以幫忙做這些雜事，\n我會很開心……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我總是很冒失，做家事常忙不過來。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n先不聊了，我去做飯囉。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請稍等一下 ……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好、好險。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我差點跌倒了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好不容易順利帶回來的雞蛋等東西，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n差點就要白費了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n謝謝你扶住我♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，奇怪？？",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你好像在發光喔……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這這這、這是什麼？",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我又冒失地",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "按了不該按的按鈕了嗎～！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚……",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊啊啊！？",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "510040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "喔嗚，我做了蠢事～！",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為跌倒的時候撞到……把排列整齊的蔬菜",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n全部都翻倒在地上了啊～！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對對對、對不起，造成騷動！",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我、我馬上撿起來！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會買下凹陷碰傷的蔬菜的！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚，為什麼我總是這樣呢？",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明大小姐為了買到便宜1日圓也好的商品",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而到處精打細算著！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "冒失一回就全部付諸流水了！",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚，買蔬菜的錢就從我的薪水裡扣吧！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然這個月摔破太多盤子，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以已經沒剩多少錢了！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊……？",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n咦，是{player}？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你好～♪",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很少在這裡見到你呢。",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你住在這附近嗎？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我家，應該說是照顧我的大小姐的宅邸，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就在隔壁城鎮呢。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我為了買到便宜的蔬菜等，而遠征到這裡。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果想買到便宜的東西，就用上你的腳，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這是大小姐教我的！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀……",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你要幫我撿蔬菜嗎？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝～！",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n欸嘿嘿，你總是很親切呢♪",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，對不起……",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為想要撿同一個蔬菜，而互相碰到手指了呢。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇～好像以前的少女漫畫。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為大小姐意外地喜歡這種故事，所以我也很常看喔。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "漫畫中冒失的主角相當多，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以我也很有共鳴。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果是漫畫的話，會讓人會心一笑呢～",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但在現實中，冒失只會給人添麻煩吧……？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是這樣嗎～欸嘿嘿。",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，好像讓你費心了。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還沒有那麼悲觀，所以沒關係喔。",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我會積極思考～因為冒失也是一種特色。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也有努力在克服，雖然還沒有成果。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，我嗎？",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯～我不管看什麼都覺得有趣喔，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我喜歡一般的校園故事之類的。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你想想看，我是個女僕，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有大小姐要服侍，不是過著頗特別的生活嗎？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我看一般人談戀愛、玩社團，感到很有意思呢。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我對現在的生活當然也感到滿足、幸福，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是如果出生在一般家庭，我會邁向怎麼樣的人生呢？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會像這樣",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "思考許多事情呢。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好，非常完美……",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "把菜都撿起來了。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n謝謝你的幫忙♪",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你也是出來買晚餐的食材嗎？",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哦，原來是因為父母出差，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以得自己煮飯才行……這樣啊？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼，你不介意的話，要不要在我們那裡吃晚餐？",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我覺得大小姐也會很開心，",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且如果把凹陷的蔬菜等全部買下……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大概會剩下很多，只是放著腐壞而已。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不要客氣。",
        "unit_id": 102531,
        "voice": "vo_adv_1025004_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就當作報答你幫我撿菜的回禮。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果你不覺得困擾的話……♪",
        "unit_id": 102531
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鈴莓她……",
        "unit_id": 190011,
        "voice": "vo_adv_1025004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就算不用特地來「這邊」，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也一樣過著相當夢幻的生活呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為她是女僕呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1025004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，我只看過她那身裝扮。",
        "unit_id": 190011,
        "voice": "vo_adv_1025004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她整天都穿著女僕裝嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也想看她穿其他衣服的模樣呢～像是睡衣之類的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1025004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉抱歉，如果沒有好好說明，你會感到困惑吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1025004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n它會補足你失去的記憶，並使其一致……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，該說是這樣的調整嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在你真正恢復記憶之前，",
        "unit_id": 190011,
        "voice": "vo_adv_1025004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n嗯，像是奠定基礎的感覺。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在你應該搞不清楚狀況，所以沒關係，不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正，我想你醒來以後記憶馬上會變得模糊。",
        "unit_id": 190011,
        "voice": "vo_adv_1025004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以你不用太在意，正常地過生活就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如漫畫般破天荒，",
        "unit_id": 190011,
        "voice": "vo_adv_1025004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對你來說卻稀鬆平常的每一天……\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正常地過好現實生活就好。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}～？\n怎麼了，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你怎麼在發呆……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "果然是因為提東西累了嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請好好休息吧～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n飯菜也煮好了，請享用吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_057"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我不是很擅長做菜……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以可能不怎麼好吃。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很好吃嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好開心～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你總是一直誇獎我呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "非常感謝你……",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n誇獎這樣的我。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐也是這樣喔，很溫柔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果我太過自卑的話，",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_060"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就太對不起那些稱讚我的人……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以我會努力積極向前看的。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_061"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n盡可能不冒失，並以自己的方式加油。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025004_062"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "今後鈴莓也會努力服侍主人的♪",
        "unit_id": 102511
    }
]