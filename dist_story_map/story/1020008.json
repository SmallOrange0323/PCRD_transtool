    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "雖然哥哥都這麼說了，",
        "unit_id": 102032
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美是很想相信自己啦……",
