        "type": "dialogue",
        "name": "美美",
        "words": "因為美美不太擅長運動，",
        "unit_id": 102032,
        "voice": "vo_adv_1020008_007"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n想說如果失敗的話該怎麼辦……",
        "unit_id": 102032
