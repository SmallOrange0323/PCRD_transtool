    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――討厭大蒜的伊莉亞因為不小心誤食加了大蒜的雞腿，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而虛弱地無法變回原本的姿態。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人向著較為安靜的郊外前進，並在長椅上稍作休息。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚嗚……",
        "unit_id": 111712,
        "voice": "vo_adv_1117004_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "大蒜……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n大蒜討厭……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚、",
        "unit_id": 111712,
        "voice": "vo_adv_1117004_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n稍微穩定下來了……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "再等一下下，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "應該就能恢復本來的身體了……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚嗚……",
        "unit_id": 111712,
        "voice": "vo_adv_1117004_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "居然會如此失態……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可惡的大蒜……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n為什麼那種東西",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "會存在於這個世界上呢……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……要是平常的話，",
        "unit_id": 111712,
        "voice": "vo_adv_1117004_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "應該會說別把妾身當成小孩，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然不甘心，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是現在",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "溫暖的手，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "卻讓人很安心……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚嗚……",
        "unit_id": 111712,
        "voice": "vo_adv_1117004_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "居然會變成這麼難為情的樣子……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不論陷入什麼狀況，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身的『偉大計劃』都一定要成功！　",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}！！",
        "unit_id": 111712,
        "voice": "vo_adv_1117004_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那個，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "繼續剛剛的……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咦？",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n怎、",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼了，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你的身體在發光…………！？",
        "unit_id": 111712
    },
    {
        "type": "still",
        "still": "111700401"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "諸位喔！！",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身可是在販售蛋糕，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "心懷感激來購買吧！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "即便妾身有滿溢的魅力，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也已經賣不出去了嗎。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟都已經這個時間了，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n聖誕派對應該也早就開始了吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "輪、輪不到你來道謝！",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身只是很在意",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n到底是什麼事",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓你拒絕妾身",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也要去做！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才、",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才不是，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n想要跟你一起",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "度過",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "聖誕節喔！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才不是那樣喔！！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過{player}。",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也沒必要連這種時候都在工作吧？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咦……",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為人手不足店家很困擾，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以被拜託幫忙了？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唉……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "明明是聖誕節，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你還真是……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然瞭解理由了，",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但就算是那樣，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也工作過頭了。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你也應該",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n有、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有可以一起過節的",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對象吧？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼了～？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n眼神在飄移喔～？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嘛，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今天可是有妾身在你身邊，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "心懷感謝吧♪",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……什麼！？",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那個……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "的、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "的確是呢……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "跟妾身在一起……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對能跟妾身一起過節這件事情，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "儘管心懷感謝吧！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1117004_015"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "兩位～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n今天應該已經賣不出去了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n整理好販賣窗口之後就可以下班囉～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼……",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n看來，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "蛋糕販售也結束了呢。",
        "unit_id": 104431
    },
    {
        "type": "still",
        "still": "111700402"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "………………",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……不、",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不要看這邊！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就這樣聽好。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……其實",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今天，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n過來幫你的忙，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是有理由的。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個……",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為一直以來都受到你的照顧，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以想要用什麼東西來回禮，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身才自己想了這個計劃。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "『偉大計劃』……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n作為平日的感謝，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "準備了禮物，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n想要在聖誕節的時候送給你。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "本、",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "本來沒打算",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這麼突然地交給你，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n原本想說要在吃飯時交給你的，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想了很多方法喔！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但、但是你卻",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "突然說什麼要打工……！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什！　",
        "unit_id": 104431,
        "voice": "vo_adv_1117004_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所、",
        "unit_id": 104431
