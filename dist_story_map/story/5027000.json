[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某日午後，在蘭德索爾的王宮城門前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n黑鐵鎧甲彷彿在守護身後王宮般佇立於此。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n此時，有兩個人影向她跑了過來。"
    },
    {
        "type": "still",
        "still": "502700001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓妳久等了，",
        "unit_id": 100511,
        "voice": "vo_adv_5027000_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "團員茉莉，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "跟小智姐一起來報到了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼了？",
        "unit_id": 103711,
        "voice": "vo_adv_5027000_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n特地把我們叫到這裡來。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有話要說的話，在裡面講不是比較好嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗨，",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳們來啦。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茉莉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我覺得在這裡講會比較好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原來如此……",
        "unit_id": 103711,
        "voice": "vo_adv_5027000_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "刻意選在這種開放場所，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果有人偷聽的話很容易就能發現，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這就是妳的目的對吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以是相當重要的事才對？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊！？　",
        "unit_id": 100511,
        "voice": "vo_adv_5027000_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也就是說，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這是祕密指令嗎！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哈哈，",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小心一點總是好的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……小智妳們",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有聽過那塊新開拓的地嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "新開拓",
        "unit_id": 100511,
        "voice": "vo_adv_5027000_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的地……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊……",
        "unit_id": 103711,
        "voice": "vo_adv_5027000_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳該不會是說",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "之前提過的那座『島』吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然開拓這件事",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "的確會有遭遇魔物的危險，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但是因為是由公會管理協會掌管，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "應該沒有問題才對啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就是接到了公會管理協會的請託。",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n似乎有某艘船脫離了管理協會所指定的安全航道，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n多次進出那座『島』。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那艘船登記的公會是",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【龍族巢穴】。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小智妳應該也有聽過吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔！",
        "unit_id": 103711,
        "voice": "vo_adv_5027000_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "聽說他們是以公會當掩護，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "實際上卻是幫派的一個團體……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼要讓那種人參加開拓呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "幫、",
        "unit_id": 100511,
        "voice": "vo_adv_5027000_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "幫派嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那就是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "壞人對吧？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那可不能放過他們！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就像剛剛小智說的一樣，",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n開拓必然會伴隨著危險。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若他們不是個能做一定程度粗活的公會，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "協會也不可能送過去啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣啊，",
        "unit_id": 103711,
        "voice": "vo_adv_5027000_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也就是說，公會管理協會",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也不能太過要求囉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，也不能就這樣算了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果高額的報酬",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "成為幫派的資金來源，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n未來可能會成為大問題。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是這樣。",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以我們需要有人",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n去調查【龍族巢穴】的『開拓』情形。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "感覺",
        "unit_id": 100511,
        "voice": "vo_adv_5027000_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還真是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "辛苦呢……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我大致上理解了。",
        "unit_id": 103711,
        "voice": "vo_adv_5027000_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為身為團長的純",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不能離開蘭德索爾，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但是，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果派【王宮騎士團（NIGHTMARE）】的其他成員過去，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n對方也會有所警戒吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以……",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是妳們兩位祕密武器出場的時候了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我和",
        "unit_id": 100511,
        "voice": "vo_adv_5027000_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "祕密武器……！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我明白了。",
        "unit_id": 103711,
        "voice": "vo_adv_5027000_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "既然如此，這事就交給我吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【龍族巢穴】的尾巴，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我一定會好好抓住的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這種邪惡的組織，",
        "unit_id": 100511,
        "voice": "vo_adv_5027000_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就由我和小智姐一起消滅它吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不，",
        "unit_id": 103711,
        "voice": "vo_adv_5027000_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這次的工作是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "祕密調查喔，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104711,
        "voice": "vo_adv_5027000_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就交給妳們囉。",
        "unit_id": 104711
    }
]