[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在大江戶町內散步，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看見雪正被人群團團圍住。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等一下啦～",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣我很困擾耶～",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊！{player}！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你來得正好！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "發生大事了啦～",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算我再怎麼美，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也受不了大家這樣蜂擁而上～",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "喂，",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼說得好像我做了什麼壞事一樣，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這太奇怪了吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔喔，",
        "unit_id": 1412,
        "voice": "vo_adv_1176001_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "將軍！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n你來得正好！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以請你一起幫忙拜託她嗎？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "其實，",
        "unit_id": 1412,
        "voice": "vo_adv_1176001_004"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "因為發生了上次那件事，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n大江戶町",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "也開始提倡",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "平時就要注意健康。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "因為某位大人費盡心思提案張羅，",
        "unit_id": 1412,
        "voice": "vo_adv_1176001_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們現在要舉行健康檢查。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "所以",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我才拜託在深月醫生那邊當過護理師的雪，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n也務必來幫忙……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你這麼說……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就只有",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可愛美麗的外貌，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒有任何醫療知識耶。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我已經從蘭德索爾找了醫生來，",
        "unit_id": 1412,
        "voice": "vo_adv_1176001_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這點還請放心。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳在那間醫院的表現，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n在大江戶町的居民之間大受好評。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的表現？",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我不是只有跟大家聊天而已嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們從妳身上學到了，",
        "unit_id": 1412,
        "voice": "vo_adv_1176001_009"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那是一件非常重要的事情。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "經常聽到鎮上有人說，",
        "unit_id": 1412,
        "voice": "vo_adv_1176001_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雖然醫院感覺很可怕，\n但跟雪聊天很開心，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "所以比較願意去醫院了。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算你這麼說，",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "巧婦難為無米之炊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "別寄望我了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你們還是去找別人吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "她從剛剛就一直不為所動……",
        "unit_id": 1412,
        "voice": "vo_adv_1176001_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能幫忙想想辦法嗎？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說起來，",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種事打從一開始",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就沒有找我去的必要……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……你再說一次。",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好吧，",
        "unit_id": 100811,
        "voice": "vo_adv_1176001_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既然你呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都這麼說了嘛？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那我去幫忙一下也不是不行啦？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唉～真是的，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既然需要我的美貌，那就沒辦法了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "相對的，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也要一起來幫忙喔！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "所以",
        "unit_id": 1412,
        "voice": "vo_adv_1176001_016"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳是答應了？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真不愧是將軍，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "非常謝謝你們！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n事不宜遲，請跟我來……！",
        "unit_id": 1412
    },
    {
        "type": "background",
        "background": "501380"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪跟{player}開始幫忙健康檢查後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哼哼哼～♪",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n好～",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "今天也要加油！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是說，",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如何？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n果然",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在這裡工作",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還是該打扮成這樣才對，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n很適合我吧？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯嗯，",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很好，非常誠實！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n真不愧是",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我美貌的信徒，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "盡情欣賞",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美吧。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對吧～？",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真不愧是我～",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "{player}，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你該不會是想再看一次我的這副模樣，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n才希望我來工作的吧？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵……",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼了？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一直目不轉睛地看著我，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n雖然我能理解你看到入迷的心情……",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "難不成，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美貌",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有哪裡不一樣……？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你說",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看我這麼樂在工作之中，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "感覺很不可思議？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真失禮，",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_023"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要有獎賞……",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不對，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要有意義，我也是會努力工作的。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比起這個，",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n看到我的美貌，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你沒有什麼話要說嗎？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是的～",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你還不懂嗎？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "給你一個提示，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我開始用這身裝扮工作之後",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不一樣的地方！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是說",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "開心的原因啦。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n還不懂的話，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要靠近",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看看我的臉嗎？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你看……！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是不是變得更美了？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯～～",
        "unit_id": 117611,
        "voice": "vo_adv_1176001_027"
    },
    {
        "type": "dialogue",
