[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管怎樣。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n現實與夢境相互交錯變換，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是發生了如此嚴重的事件。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n從那瞬間開始，整個世界就完全變了一個樣。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不只是地形還什麼，就連記憶與內心也被人徹底重寫……",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被徹底改變，而這世界被完全再構築了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n夢境被當成現實，而現實被錯認為夢境，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣的狀況持續到了現在。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但這本來就是個，不可能會發生的狀態。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以似乎到處都發生了問題。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不管是被稱為『消失』還『闇影』的怪現象，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n似乎也都是因為這個緣故而產生的Bug。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Bug……？",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是在說蟲嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個說法會聽不懂嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是嘛，該說是世界的法則被顛覆嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之就是壞掉了的意思唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n再這樣繼續下去，也不知道到底會發生什麼事情。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以，不變回原樣可不行。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不把這個世界，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "變回它應該有的姿態可不行。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後，我們也必須該回到那真正的現實之中。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是這麼想的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然拉比林斯達等人也願意幫忙，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但我不會說要強迫你們得這麼做。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟每個人都不一樣，也許在現實中有更殘酷的事要去面對。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也不能就這樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "持續一直做著夢下去吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2008010_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是件難以理解又神奇的問題，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此也無法立即就全盤接受。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而這若真是事實可就糟糕了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以希望能再多給點時間讓人考慮。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但究竟為何會演變成如此這般的事態？",
        "unit_id": 105913,
        "voice": "vo_adv_2008010_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您說曾發生過了嚴重的事件，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能將世界徹底顛覆，",
        "unit_id": 105913,
        "voice": "vo_adv_2008010_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如同神魔般的所為，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是誰做的又是為了什麼？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或者是說，這是如同天災一般的災害嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n演變成這樣的事態，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我認為是持有惡意的某個人所冀望的結果。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就真如同神魔一樣，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是個無論怎麼樣的願望都能夠替人實現的存在。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而他，則是去實現了某個人如此令人驚駭的願望了吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "從結果來看，夢境和現實確實被顛覆了。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但當那個願望被實現的瞬間，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我並沒有在現場，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以某種程度也只能夠像這樣推測而已。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大概是，這麼一回事。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n帶著一絲絲的光明與善意，背負著夢想與希望挺身而戰的人們，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n卻因力量的不足而悽慘的敗北……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "令人作噁的壞人卻獲得了勝利。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他也因此實現了願望，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全就只是為了自身的慾望，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而將世界給徹底改變。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們所生活著的這個地方，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n則就是在那個悲劇結局之後，所徒留下來的醜惡世界。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難不成說……那個壞人，",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是現在自稱為尤絲蒂亞娜的那號人物嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "將我所有一切給奪走的那個大壞蛋。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當下，在這個被顛覆的世界中，",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能夠盡情貪圖享受權與力的，毫無疑問就是那個人。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個地方，就是那個人實現了願望創造出來的世界嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我認為那個推論是對的。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n現在自稱為尤絲蒂亞娜的那傢伙，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "本名為千里真那。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為『七冠』之一，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是以『霸瞳皇帝』的身分幹盡了壞事的存在。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}。\n你和你的同伴們，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n加上我們，為了要阻止他的野望也曾經與他戰鬥過了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但大概最後，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為力量的不足而敗北了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，曾經……？",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就像是，故事中登場的勇者一樣的存在嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但總覺得可以想像。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該說是總是處於命運的中心嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "偶爾也會有很帥氣的一面呢……{player}。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也是和{player}他們一起戰鬥過的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n其中一個同伴嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟就算是現在，",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在這個被改變過後的世界中，我們的感情還是一樣好嘛……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不……",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉，很遺憾的，我並不知道妳之前的事。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "至少就我來說，在世界被改變後才第一次看過妳。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那邊那個，叫可可蘿的女孩子也一樣。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n{player}他主要是\n和其他的女孩子們以及一個叫做菲歐，像是妖精一樣的傢伙一塊戰鬥的唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但為什麼現在，不是和那些女孩子們……",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而是和妳們一塊行動呢？這就連我也很困惑。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是這樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}和伙伴們結下了深厚的羈絆唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦……",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊，原來是這樣。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有點，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "超級失望的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過嘛，",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這也沒辦法呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這個被重新改寫的世界裡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能這樣子相遇就很幸運了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然對{player}的重要的伙伴來說、",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們…",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可能很討厭也說不定……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是把{player}，",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n硬生生搶走的第三者也說不定。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一這樣想，",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "心情就有點沉重了呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總感覺，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變得消沉起來了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……雖然這個世界變成這副德性。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如此相遇的你們所交織而成的羈絆，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也不會變成虛假的謊言唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也只能這樣，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "除了說些安慰人的話以外什麼都做不到了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會，不好意思打斷你說話了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算全部都忘記、世界也被改寫",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還能再一次相遇、再一次親近的話簡直是命中注定……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n簡直像童話一樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "忍不住讓人這麼想呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那樣的故事，",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我以前也很憧憬就是了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n欸嘿嘿……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_2008010_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，不好意思。",
        "unit_id": 105913,
        "voice": "vo_adv_2008010_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛剛，是不是晃了一下？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……的確。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而且，基地外面設置的警報裝置也啟動了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太大意啦～太專注在談話上發現的太遲了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以用空間跳躍去看看外面的情況嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我明白了。",
        "unit_id": 107311,
        "voice": "vo_adv_2008010_044"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n……請稍等我一下。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "發、發生了什麼事？",
        "unit_id": 105812,
        "voice": "vo_adv_2008010_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不清楚。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只是警報誤啟動、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "或搞錯了什麼的話就好了……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但從我們的立場看來，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n感覺不太能期待這種和平的展開。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "各位，",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "請做好發生什麼事都能應對的準備。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然還有很多不得不說的事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但恐怕是不能再悠哉下去的情況了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "靜流和璃乃，先別洗碗了過來這裡。",
        "unit_id": 106112,
        "voice": "vo_adv_2008010_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全員集合～！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n萬一出狀況的話就立刻逃離，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "先做好準備！",
        "unit_id": 106112
    }
]