    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──明明都年底了！！",
        "unit_id": 106012,
        "voice": "vo_adv_5056101_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻沒有錢！！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱、",
        "unit_id": 105913,
        "voice": "vo_adv_5056101_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下明白您著急的心情，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但還請您冷靜下來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在這種狀況下，",
        "unit_id": 106012,
        "voice": "vo_adv_5056101_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能冷靜啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n半毛錢都沒有，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們半毛錢都沒有！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新年就在眼前了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在的我們卻是個赤貧公會！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "早知道會這樣，",
        "unit_id": 106012,
        "voice": "vo_adv_5056101_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就不該在尾牙時得意忘形吃過頭……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不要",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明是新年",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻吃不到年菜跟年糕湯啊……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……也對。",
        "unit_id": 105913,
        "voice": "vo_adv_5056101_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n再這樣下去，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚至無法好好地度過年初。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然剩下的時間不多……",
        "unit_id": 105913,
        "voice": "vo_adv_5056101_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但若能在新年來臨前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想點辦法應付就好了──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "放心吧！",
        "unit_id": 1,
        "voice": "vo_adv_5056101_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n小凱留，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "小可蘿！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管是悠閒的年假！",
        "unit_id": 105812,
        "voice": "vo_adv_5056101_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或是擺滿美味料理的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "新年餐桌！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要大家同心協力，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就一定能取回來的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可……？",
        "unit_id": 106012,
        "voice": "vo_adv_5056101_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有什麼好主意嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105913,
        "voice": "vo_adv_5056101_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該說……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您手上那些",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像是網子和釣魚竿的東西是什麼呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
        "unit_id": 105812,
        "voice": "vo_adv_5056101_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說到冬季能一攫千金的機會，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就只有這個了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起出發吧──",
        "unit_id": 105812,
        "voice": "vo_adv_5056101_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "前往大海的漁場！！！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿、凱留",
        "words": "──什麼……！？\n──哈啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_5056101_012"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5056101_013"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「新春美食公主！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "賭上關鍵一擲的少女們」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "捕魚……",
        "unit_id": 6411,
        "voice": "vo_adv_5056101_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這正是",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "男子漢之魂，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是大海的",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "浪漫。",
        "unit_id": 6411
