[
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "妳們，",
        "unit_id": 15911,
        "voice": "vo_adv_5088323_000"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "蠻有能耐的嘛……",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你、",
        "unit_id": 121411,
        "voice": "vo_adv_5088323_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你才是呢！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "快點投降怎麼樣啊！？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "要是能那麼做就好了。",
        "unit_id": 15911,
        "voice": "vo_adv_5088323_002"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n可惜……",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我已經停不下來了。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n我們……",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……那是什麼意思？",
        "unit_id": 121411,
        "voice": "vo_adv_5088323_003"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我們也不是自願變成這樣的。",
        "unit_id": 15911,
        "voice": "vo_adv_5088323_004"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n只不過誕生在這個世上……",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我們已別無選擇了。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……那還真是",
        "unit_id": 121311,
        "voice": "vo_adv_5088323_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "令人痛心……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n真的沒辦法停手嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "沒錯……",
        "unit_id": 15912,
        "voice": "vo_adv_5088323_006"
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "我們別無選擇了！",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "\n妳們可別怪我啊……！",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "看來我們",
        "unit_id": 121311,
        "voice": "vo_adv_5088323_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "想阻止老鼠先生牠們，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就只有贏過牠們這個方法了……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "感覺這是牠們的最後手段了吧。",
        "unit_id": 121411,
        "voice": "vo_adv_5088323_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n因此",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們絕對不能輸！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "讓牠們瞧瞧",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們的潛力吧！",
        "unit_id": 121411
    }
]