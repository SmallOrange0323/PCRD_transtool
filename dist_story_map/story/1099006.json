[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咲戀育幼院的下午茶時間。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n愛蜜莉雅一臉正經地向可可蘿開口說道。"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可可蘿，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "妳跟我",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "去「約會」吧！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是說……",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "約會嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "沒錯。",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想要跟可可蘿妳加深感情，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n所以昨天跟昴請教了許多這方面的事。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "然後他說，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n只要約對方出去玩",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "或是交換禮物，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "感情就會加深了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "一起出門、",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n製造共同的回憶，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這就叫作「約會」對吧？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "所以，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想要跟可可蘿",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "出去「約會」。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可以嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是求之不得的事。",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下非常希望跟您去約會，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是主人這邊",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有些不放心……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "那麼",
        "unit_id": 2611,
        "voice": "vo_adv_1099006_006"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "大家一起去不就好了嗎？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "多一個人也沒有問題吧？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_007"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就這麼辦吧！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n大家一起去",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "一定會更好玩的。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的體諒。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣可以嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呵呵，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_009"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我也非～常地期待。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我們這就出發吧！",
        "unit_id": 109911
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯～",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_010"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "天氣真好！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n風景也很優美呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "氣溫也暖洋洋的，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是個絕佳的外出好日子呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們出外冒險時",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經常乘坐馬車行經這條路，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想不到像這樣行走在路上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能夠見識到不同於往常的風貌，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是新鮮的感覺。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這樣啊，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_013"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你們常常",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "會去各種不同的地方嘛。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那至今為止都經歷了哪些冒險呢？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這附近的話，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "討伐原野上的蜥蜴人吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當時接下了公會的委託，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與主人他們一同去冒險。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人在一旁支援在下等人戰鬥的英勇身姿，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n至今仍是記憶猶新。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n活躍的表現令人讚賞。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此外，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也去遠征過高聳入雲的高山，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或是到各地獲取貴重食材來品嚐的吃遍之旅……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n多不勝數。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真是不簡單的冒險呢！",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_017"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n那些",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "應該非～常地辛苦吧？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從前在故鄉便經常行走於山中，所以習慣了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在山裡走一走，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就採些野生的樹果",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或野菜來當午飯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n話題",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍微扯遠了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不會。",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_020"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "想了解更多關於可可蘿的事，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "所以聽得很高興。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說起來，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是時候該吃飯了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請用這個。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是在下帶來",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "作為零食的葡萄乾。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請邊吃邊稍待片刻，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去準備一些吃的東西……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可可蘿，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_022"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "其實……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我有帶便當喔。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "為了可以因應遠行，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_023"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我昨天請雷姆",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "幫忙準備的。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我們就快要到達目的地了，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "到了那裡再一起吃吧。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛蜜莉雅小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "承蒙您招待了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就快抵達目的地了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請再忍耐一下。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "到了。",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_025"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雖然有聽人家說過，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但是居然這～麼開闊……！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是個氣氛悠閒",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "的好地方呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡就是約會地點嗎。",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來愛蜜莉雅小姐",
        "unit_id": 105913
    },
    {
