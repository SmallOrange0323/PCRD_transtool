    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這道料理之所以好吃，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "靠的不光是在下的手藝。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更是因為與愛蜜莉雅小姐一起，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家合力才成就了這道料理吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能為料理增添風味的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並不是只有食材",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和廚師而已。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可可蘿……",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_055"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呵呵，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "謝謝妳。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n今天的「約會」",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真～的好開心喔！",
        "unit_id": 109911
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "約會之後過了幾天……"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可可蘿，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_056"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "請妳收下這個。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是……",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "菜刀",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_058"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是我在蘭德索爾請人打造的菜刀喔。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "因為我想加深跟妳的感情，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n所以準備了「驚喜禮物」。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我看可可蘿",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_059"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "好像很喜歡做料理，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "所以想說這個應該會很適合……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "妳覺得如何？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛蜜莉雅小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n相信今後每當使用這把菜刀時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下都會回想起那次美好的約會，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n以及與愛蜜莉雅小姐相處的點點滴滴。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是，",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "約會的事也是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "單方面接受您的好意實在過意不去。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛蜜莉雅小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "送您些什麼回禮好嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "回禮……",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_062"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我從來沒有想過耶。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n不過，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "既然這樣的話，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我就提一個要求好嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我啊，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "因為沒有兄弟或是姊妹，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "所以對這方面有點興趣……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "一次就好，",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_063"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想聽妳",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "叫我「姐姐」。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……可以嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是您如此期望的話……",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳咳。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……愛蜜莉雅姐姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_065"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想想，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就像有時",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "拉姆和雷姆在高興的時候那樣……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n是這個樣子嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇唔。",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……稍微",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有點難為情呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得好像有種安心的感覺。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "各方面也有許多的共通點，",
        "unit_id": 2611,
        "voice": "vo_adv_1099006_067"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "搞不好妳其實真的是她妹妹喔～♪",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貓精靈先生真是愛說笑……",
        "unit_id": 105913,
        "voice": "vo_adv_1099006_068"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔咕。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這就是",
        "unit_id": 109911,
        "voice": "vo_adv_1099006_069"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "當姐姐的感覺……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "總覺得好～溫暖喔。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿一直被愛蜜莉雅"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當作妹妹緊緊抱著，直到她滿意為止。"
    }
]