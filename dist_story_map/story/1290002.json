    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "厄莉絲的修復有了進展，在她甦醒過來的某一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}帶著她到城堡外面。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "………不小心，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就忘記了……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但城堡外面，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是長這樣的呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "非常地寬廣……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "明亮。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生？",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n怎麼了嗎，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "突然蹲下來……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雪……？",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊……",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……嗯。",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n好冰。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……仔細想想。",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我觸碰「這個世界」物體的次數，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "似乎是屈指可數。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "被幽禁在索爾之塔的時候自是不用說。",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就連在黑薔薇的城堡中，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我大部分也都在夢中度過。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "外出時，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都是以排除礙眼的障礙為目的……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有能夠在意其他事物的從容。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就連──",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雪是冰冷的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣的常識。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我也都沒能親身體會到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……從容，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗎……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要說這是因失去理想鄉而獲得的事物……",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n還真是不划算呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……咦……？",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "怎、",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "怎麼",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "回事，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "突然感覺癢癢的──",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "哈啾。",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n剛剛的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "打噴嚏……",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗎……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………！",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你、",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你沒有看到……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我的表情，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對吧？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我沒有打過噴嚏……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我想一定，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "露出了奇怪的表情。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不想要，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "被騎士先生看到……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真的嗎？",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "既然騎士先生，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這麼說了……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我就相信你。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……啊啊……",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_022"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n果然，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "被看到了呢……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過……",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不會奇怪，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "的話……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那就好……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "了嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "怎麼說，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都穿得太少了呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n因為一直以來，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都是用魔法來無視冷熱，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n所以不曾在意過氣溫……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果有積雪，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就表示氣溫也會是低的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那樣的常識……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我明明就知道才對。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……真是沒必要呢。",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這種因為寒冷而全身顫抖的從容。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生？",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_027"
    },
    {
        "type": "still",
        "still": "129000201"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……咦……",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可以嗎……？",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_029"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……謝謝。",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那麼，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我就先借用了。",
        "unit_id": 129011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "129000202"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒關係。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……我希望，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能再這樣待一下。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n多虧了騎士先生，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我現在也不冷了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……呵呵。",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_032"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "好溫暖。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……外面的世界，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真辛苦呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n還需要配合天氣和地區去做準備。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過……",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_034"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生你，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經習慣這些事了吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n在出發去冒險之前",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都會先採購東西……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯……",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我透過記錄，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "看到了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "努力地想做好萬全準備的事，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我都知道喔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "剛失憶的那時候，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_036"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "又不一樣就是了……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……呵呵，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_037"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有喔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n因為騎士先生無論何時，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都是騎士先生啊。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過，",
        "unit_id": 129011,
        "voice": "vo_adv_1290002_038"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果你會在意的話……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我可以告訴你喔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n關於我一直看著的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生的事情……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
