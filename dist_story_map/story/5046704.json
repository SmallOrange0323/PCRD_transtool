    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "はぁ……",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_000"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "はぁ……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "なんなの……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nもうクタクタだよ……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n追い払えたからいいけど……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あの大きさ、",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_001"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ねずみの親玉だったのかな？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "親玉を追い払ったんだから",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "もう大丈夫だよね。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "大丈夫だと思いたい。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "この子たちは……",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_002"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "よかった～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n傷一つないね。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ん？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "むしろさっきよりツヤツヤになってない？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そんなすぐに熟成されるものなのかな？",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_003"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "まぁ、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしも短時間でねずみ追い払うのうまくなったし、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nこの子たちがあっという間に育ってもおかしくないよね。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "心なしか",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_004"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "匂いもおいしく感じてきた……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "気がする。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "おかしいな。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ドングリと比べたら全然だったのに。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "これは確かに",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_005"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "エリザベスパーク印の製品が人気なのもうなずけるね。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nまっひ～はすごいよ。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "改めて見直しちゃう。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "まっひ～の期待に応えるためにも",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_006"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "このままチーズを守り続け……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あれ？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あそこになんか穴が開いてる。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ひょっとしてねずみの巣！？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ここから湧いて出てたの？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あ～もう！　",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_007"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "これまたねずみ出てくるパターンじゃん！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nいいよ！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "何度でも撃退するよ！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n掛かってきな！！",
        "unit_id": 102611
    }
]