[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "早、早安虐待狂先生。",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "很、很僵硬，怎麼這樣說……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "考、考慮到現在是早上，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這對思春期的健康男生來說是正常現象吧？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸，不是那個意思嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "原來如此……空花真是失態了。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那、那個……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花啊，被男生叫出來，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這還是第一次呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "去買東西啊……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n所以現在我們",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是要去買討伐魔物的時候，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n需要用到的東西對吧。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "因為是虐待狂先生，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n所以絕對不可能買完東西就這樣結束的……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "青、青年一定會對少女，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n伸出毒手……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊、等、等一下，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n請等一下啊～",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不好意思，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請給我們３瓶治癒藥水，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n和這個聖水。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "好的",
        "unit_id": 1511,
        "voice": "vo_adv_1045007_010"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這是……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "沒事，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n只是空花覺得",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個有點可愛而已。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請別在意。",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "休、",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "休息！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "該不會是要去那種……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n入口的地方像蛇紋管一樣有屏蔽，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一旦進入後就會被光彩奪目的粉紅景象所吸引──",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸，不、不是嗎……？",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這樣啊……好可惜。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦！",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n禮、禮物？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花沒想到可以從",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生那裏拿到禮物……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "該、該不會，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好好享受「我」這份禮物……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "青年說完就緩緩地，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n褪去身上的衣物──！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸，不、不是嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是從剛剛褲子裡面就發出磨蹭的聲音……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這是虐待狂先生，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_022"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n要解放隱藏力量的前兆嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這是……剛剛，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花說了覺得可愛的髮飾。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生是什麼時候買的？",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_024"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你說是平常照顧虐待狂先生的回禮……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_025"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、空花不記得",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "有做什麼值得感謝的事。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花才是那個……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "每、每天受到",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生照顧的人……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸，要空花別管了戴上看看嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還、還好……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "非、",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_029"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "非常可愛。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……而且空花的體內",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_030"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "感覺暖暖的……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是不是像平常的那種感覺，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_031"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n而是覺得非常平靜……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝謝……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_032"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "平時在書中讀到的情節，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_033"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n該不會就要派上用場了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……也就是說，",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_034"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生和空花要從這裡，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "走向兩人世界的祕密花園呢！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖、",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_035"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖然……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花還沒做好心理準備……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "少女總是突然地破繭而出……",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_036"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "小、小女子不才，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還請多多指教！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "欸，小、小姐，",
        "unit_id": 1411,
        "voice": "vo_adv_1045007_037"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我這樣的大叔妳也要嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸、虐、虐待狂先生呢？",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_038"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "跟您一起來的客人，",
        "unit_id": 1,
        "voice": "vo_adv_1045007_039"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n已經先去結帳了喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "大、大叔我跟年輕小姐，",
        "unit_id": 1411,
        "voice": "vo_adv_1045007_040"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n還是第一次呢，這樣也行嗎……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊、",
        "unit_id": 104511,
        "voice": "vo_adv_1045007_041"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊啊啊啊啊────！",
        "unit_id": 104511
    }
]