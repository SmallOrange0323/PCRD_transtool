    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣就結束了呢。",
        "unit_id": 128711,
        "voice": "vo_adv_5137411_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一切都結束了……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "志那都、埃拉……",
        "unit_id": 128812,
        "voice": "vo_adv_5137411_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有厄莉絲都平安無事。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "「紅霧精靈」也消失無蹤。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想事情算是告一段落了。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯。",
        "unit_id": 128911,
        "voice": "vo_adv_5137411_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n大家都平安無事，",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是太好了。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "發生了很多事呢。",
        "unit_id": 128711,
        "voice": "vo_adv_5137411_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不管是艱辛的事、",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓人驚訝的事、",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難過的事……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也發生了很～多",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有趣的事！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不管是哪件事都讓人印象深刻呢。",
        "unit_id": 128812,
        "voice": "vo_adv_5137411_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n每一件事，",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我都絕對無法忘記。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好好珍惜吧。",
        "unit_id": 128911,
        "voice": "vo_adv_5137411_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n跟大家的回憶……",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有這份情誼！",
        "unit_id": 128911
    }
]