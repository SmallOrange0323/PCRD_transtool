        "type": "dialogue",
        "name": "花凜",
        "words": "【王宮騎士團】\n也許會有相關情報，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_030"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我用通訊魔法聯絡他們看看好了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_031"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "好的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對呀，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "嗯。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這樣",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
