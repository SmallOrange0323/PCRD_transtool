[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}走在街上時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n碰巧遇見匆忙趕路的花凜。"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，{player}先生，真巧啊。",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不好意思，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "本來應該停下來好好打聲招呼的，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但我目前還有十分要緊的工作，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請容我失陪了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我正要去調查被魔物襲擊的村莊。",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "本來應該由公會管理協會派遣公會去解決，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但目前那些公會要不是有委託要處理，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "要不就是在遠處無法趕來……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "要對付魔物，必須盡早展開行動、研擬對策，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n不然災害的範圍很容易擴大，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因此我打算先過去看看情況。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "你願意嗎！？",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_003"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "能多點人手的話，會非常有幫助。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "當然，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我會為此",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "支付報酬的。",
        "unit_id": 190811
    },
    {
        "type": "background",
        "background": "500333"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然之前已經聽說了大致的情況，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但情況真是慘不忍睹呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "光是要掌握災情",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就得費一番功夫。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "幸好有您來",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "分邊幫忙。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你們難道是",
        "unit_id": 1511,
        "voice": "vo_adv_1185001_005"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "公會派來調查的人嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "太好了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我等你們好久了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我來自公會管理協會。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我想要直接向村裡的人",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "探聽目前的情況，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n請問可以找個地方讓各位聚集過來嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我去把有空的人聚集起來，",
        "unit_id": 1511,
        "voice": "vo_adv_1185001_007"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你們稍等一下。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "謝謝。",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_008"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我去向村民打聽被襲擊的情況，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n可以麻煩您",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "巡邏一下村莊嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "好的，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_009"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "麻煩你了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "快點",
        "unit_id": 911,
        "voice": "vo_adv_1185001_010"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "運出來！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "說是這麼說，",
        "unit_id": 811,
        "voice": "vo_adv_1185001_011"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "但我已經拉著搬運車來來回回都快累死了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "到底為什麼我們要這麼悲哀地運送這些雜草啊？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "不能讓我休息一下嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "被發現的話就會被抓去關，",
        "unit_id": 911,
        "voice": "vo_adv_1185001_012"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n不搬出去你要怎麼辦？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "有沒有腦袋啊？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "唉……",
        "unit_id": 811,
        "voice": "vo_adv_1185001_013"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "呃！？",
        "unit_id": 911,
        "voice": "vo_adv_1185001_014"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "你、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "你什麼時候……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "喔，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "算了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "沒什麼。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n我們沒事。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "謝謝",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "你的關心。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n就先這樣啦。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "喂！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "走啦，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "你這個蠢蛋！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "喔……",
        "unit_id": 811,
        "voice": "vo_adv_1185001_015"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "……就這樣，",
        "unit_id": 311,
        "voice": "vo_adv_1185001_016"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我們好不容易",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "才活著逃出來。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "原來如此。",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_017"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "嗯……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "從你們的描述聽看。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n村裡出現的魔物",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "本來並不是會攻擊人的種類。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我可以馬上安排人來修復壞掉的設備，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_018"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n不過在釐清魔物作亂的原因之前，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "想必各位也無法安心。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這時候還是",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_019"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請熟悉魔物生態的公會過來……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不過",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "安全起見，擅長戰鬥的公會最好也……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "能在最短時間內趕來的組合是……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "哇！？",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_020"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "你回來啦。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "村裡的情況怎樣？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n如果有嚴重損壞的地方，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請向我報告。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "……？",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_021"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "已經來到村子的外緣了，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_022"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "你要帶我看什麼……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這座倉庫嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "已經破破爛爛的了，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不太像是魔物的攻擊造成的，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "應該本來就相當老舊……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有人趁火打劫嗎？",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_023"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這種地方看起來實在不像是有東西值得偷。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "咦？",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_024"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那些人是在",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "搬運牧草嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n牧草的確是散落在地上……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "奇怪？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n難道說……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我記得【王宮騎士團】之前發的資料上有記載特徵……",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_025"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我看看……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不是這個，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也不是這樣……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "找到了！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是這個！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這裡！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這種牧草是一種飼料，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_026"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但最近發現給魔物食用",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "會產生興奮作用。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有非法組織利用這點讓魔物對戰來進行賭博，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_027"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我們正與【王宮騎士團】聯手，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n在調查這件事。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "本來不攻擊人的魔物突然變得兇暴，",
        "unit_id": 190811,
        "voice": "vo_adv_1185001_028"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這種牧草八成就是原因，",
