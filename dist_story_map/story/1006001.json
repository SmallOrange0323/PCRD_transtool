[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊……不行了！ ",
        "unit_id": 1,
        "voice": "vo_adv_1006001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這麼粗……又吱吱嘎嘎的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯、嗯嗯！",
        "unit_id": 1,
        "voice": "vo_adv_1006001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n再這樣下去，不行……會掉下去…… ",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n茜里會掉下去的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦、咦？等等、等等～！ ",
        "unit_id": 1,
        "voice": "vo_adv_1006001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n樹枝會斷掉…… ",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n啊、啊啊啊啊啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好痛…… ",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？不怎麼痛？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！茜里把誰壓在下面了！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對、對不起！你還好嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦？你問我有沒有受傷？",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒、沒有。多虧你，我一點都不痛喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你說好險來得及……？ ",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你該不會是為了救茜里而跑來當背墊的！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n謝謝你，哥哥！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是……那個……",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n雖然很高興被你搭救……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那、那個……哥哥的手……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "從剛開始就一直這樣喔。",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "牢牢地抓著茜里的……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是這樣嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，被誇獎了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸，才不是這樣呢。",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你要摸到什麼時候啦？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "吼！哥哥這色狼！",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里要生氣了喔！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……嘻嘻，開玩笑的喔。 ",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥馬上來救我，人超好的，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以絕對不是故意的吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，不能一直壓在你上面呢。",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里現在馬上起來。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿咻――",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……嗯，果然一點都不痛。",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "多虧了哥哥。 ",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n真的非常感謝。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥沒事嗎？ ",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好像……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒有受傷呢。真是太好了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我叫茜里。",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "能告訴我哥哥的名字嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "{player}啊……",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼就叫你{player}哥哥囉！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥問我為什麼要爬到樹上去？",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實我曬的衣服被風吹走了…… ",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n看起來好像卡在那棵樹上，可是……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯？怎麼了嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n……哥哥剛剛撿到東西了？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊～！就是那個！",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "謝謝哥哥！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這是我最喜歡的內衣，",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n能找到真是太好了～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哎呀、怎麼了嗎？ ",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎麼這麼慌張……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，難不成是在意",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n撿到茜里的內衣嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "該不會……哥哥想入非非了吧？ ",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "吼！哥哥這色狼！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘻嘻、不需要那麼慌張喔。",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "臉紅的哥哥也很可愛呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "曬的衣服也找到了，我差不多該回去了…… ",
        "unit_id": 100611,
        "voice": "vo_adv_1006001_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "下次再見喔，哥哥！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被年紀小的女孩子捉弄的{player}呆站在原地。"
    }
]