    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "……なんか今にして思えばメ団のねえさんたちいたような気するけど。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "で、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "世界の危機？（笑）",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "　つったっけ？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "結局アレって何だったワケ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "嘔吐、",
        "unit_id": 110811,
        "voice": "vo_adv_6038210_001"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "週末……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ああ、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なんか飲み会的なやつ？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "そいや派遣のねえさん、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nじゃぼじゃぼ飲み散らかしてるの一人いたけど……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ユカリさんかアレ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "で、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "その会になんでうち呼んだの。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "紹介したかった？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "きも、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "彼氏かよ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "そうそう、",
        "unit_id": 110811,
        "voice": "vo_adv_6038210_002"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "世界とか国とか、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "現場のねえさんたちわりと主語デカめで。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なんかみんな",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "「おのれ世界の敵め！」みたいなノリで若干引いたわ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "しゃーないからうちも一緒に",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "「おのれ！」みたいな顔しといたけどさ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "分からないって……",
        "unit_id": 110811,
        "voice": "vo_adv_6038210_003"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あー",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ハイハイ、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "うちには言えないってことね。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ま、理由とかいいけどさ、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "もしあんたがまたなんか困ったときは……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
