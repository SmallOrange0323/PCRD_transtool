        "voice": "vo_adv_5212411_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "璃乃自己做的嗎？",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這麼精緻，",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "做起來應該很費工吧？",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那當然！",
        "unit_id": 137912,
        "voice": "vo_adv_5212411_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "能夠有機會像這樣展示給大家看真是太好了。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……而且也讓哥哥看過了……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106818,
        "voice": "vo_adv_5212411_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以說是",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒有什麼遺憾了，",
        "unit_id": 106818
