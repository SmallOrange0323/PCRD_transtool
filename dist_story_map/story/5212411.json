        "voice": "vo_adv_5212411_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難得做好的和服，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還想再多穿一下啊……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那身和服是",
