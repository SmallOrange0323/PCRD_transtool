        "voice": "vo_adv_5212411_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道是想說有關工作的事？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "答對了！",
        "unit_id": 106818,
        "voice": "vo_adv_5212411_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n下個任務，",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "差不多可以拜託妳們了嗎？",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，",
        "unit_id": 137912,
        "voice": "vo_adv_5212411_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "已經有任務了！？",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "太快了吧！？",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果然福利待遇總是會伴隨著勞動啊……",
        "unit_id": 136511,
        "voice": "vo_adv_5212411_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唉。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好嘛好嘛。",
        "unit_id": 106818,
        "voice": "vo_adv_5212411_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這次少年也會一起來幫忙喔。",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那樣的話情況就不同了！",
        "unit_id": 136511,
        "voice": "vo_adv_5212411_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有弟弟在的話，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我就能多努力一下哦♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n得讓弟弟充～分見識到",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐帥氣的英姿♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也是，",
        "unit_id": 137912,
        "voice": "vo_adv_5212411_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥也一起的話，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "非常歡迎！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不管是怎樣的任務我都會努力完成的！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呵呵，",
        "unit_id": 106818,
        "voice": "vo_adv_5212411_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們兩個還真現實啊……",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過這倒挺符合妳們的風格的。",
