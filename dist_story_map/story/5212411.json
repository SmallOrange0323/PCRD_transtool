    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以說，少年。",
        "unit_id": 137912,
        "voice": "vo_adv_5212411_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n有個工作想拜託你啊。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n來自公會【拉比林斯】的委託……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你願意接下嗎？",
        "unit_id": 137912
    }
