[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來度假是很好，",
        "unit_id": 113111,
        "voice": "vo_adv_5044101_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒想到會被迫穿成這樣……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "麻煩你",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別一直盯著我看，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "七七香！",
        "unit_id": 113211,
        "voice": "vo_adv_5044101_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳為什麼會準備這種泳裝！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "竟然擅自暴露我的真名，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不可原諒～！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好啦好啦，",
        "unit_id": 113311,
        "voice": "vo_adv_5044101_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都來到海邊了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然就是約定俗成的泳裝篇！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "正是這種時候，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "更要以不同往常的打扮來展現魅力呀☆",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……雖是這麼說，",
        "unit_id": 113311,
        "voice": "vo_adv_5044101_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但享受度假只是一個藉口。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n真正的目的",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是要在七夕結束前，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n將只有這村子才有的「某個東西」拿到手呢！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "畢竟這也是為了流夏嘛……",
        "unit_id": 113211,
        "voice": "vo_adv_5044101_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們無論如何",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "都要在七夕的祭典之前找到那東西！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "哦，",
        "unit_id": 1411,
        "voice": "vo_adv_5044101_005"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你們對這種鄉下地方的祭典有興趣啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "但聽說",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "今年的祭典會中止喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "你說什麼──！？",
        "unit_id": 1,
        "voice": "vo_adv_5044101_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "陷入窮途末路危機之中的",
        "unit_id": 113311,
        "voice": "vo_adv_5044101_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女七七香與愉快的夥伴們，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n一行人",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是否能夠讓祭典順利舉辦呢！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5044101_008"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "\n「七夕劍客旅情譚",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "　天際川流夏之戀」！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……那兩個人，",
        "unit_id": 113111,
        "voice": "vo_adv_5044101_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "到底鬼鬼祟祟地在做什麼啊？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但願不是在打什麼壞主意才好。",
        "unit_id": 113111
    }
]