[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後。\n打工地點……是在瑪爾傑海岸的海之家，\n鈴莓困惑著。"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦、",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦咦……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n抱歉，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我有點困擾！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我沒聽說呢～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為除了我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其它的海之家成員都不在，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以要穿泳、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "泳裝服務客人……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我是",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "第一次做這樣的工作，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n都不見得能獨自處理全部的事了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "穿、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "穿泳裝…",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "…還要露出肌膚",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也太害羞了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "鈴莓別這麼說嘛，求求你了！",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_003"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n就當作幫前輩的忙，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "拜託你幫幫我！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "雖然我會負責料理之類的，",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_004"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n不過在搬運材料",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "興建海之家的時候",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "閃到腰了呢……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n實在是無法服務客人，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "只能拜託鈴莓幫忙了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但、但是……",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n只、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只是服務客人的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就算不特意穿著泳裝也可以吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "雖說是這樣沒錯，",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_006"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但話不能這麼說！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你不了解來海邊的客人的喜好！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "因為有穿著可愛泳裝的女孩子來服務所以會很開心，",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_007"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n幫大家留下一個夏天的回憶吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n那就是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "所謂的海之家啊……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "再說了，",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_008"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "一直穿著那麼厚的衣服走來走去，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n會馬上中暑昏倒吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你看，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我這邊準備好了泳裝，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "快去換吧快去換吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦？",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "店長，你為什麼知道我泳裝的尺寸呢……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你有回傳給我打工招募的履歷吧，",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_010"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n上面的個人資料有記錄呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "因為這個海之家也有租借泳衣之類的服務，",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_011"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n所以平常就備有各種尺寸呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "除了泳裝以外，",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_012"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "游泳圈和水槍等等的用品也都很齊全！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n還有設置更衣室和淋浴間！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n餐點也準備地很豐富，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這裡是理想的海之家啊……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "即使如此！",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_013"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "　明明是如此適合來海邊的季節！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "為什麼呢，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "都沒什麼人靠近海邊呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "甚至連其它雇用的海之家打工人員",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_014"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n也都到了當天才說「不能來」",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "辭職之類的……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n所以實際上，也只能拜託鈴莓了呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不過我本來",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_015"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "很期待客人來海邊玩，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n所以投入了大量資金在這個海之家身上！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n這樣下去的話會全部賠光，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是很嚴重的赤字啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "至少先好好地抓住現有的客人，",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_016"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n讓他們消費才行！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n就是為了這個才穿泳裝的，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你能理解吧！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "如果，連鈴莓也見死不救的話……",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_017"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我可能",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "得和留在城鎮的妻子跟兒子",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "一起流落街頭了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n最糟糕的狀況，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我們全家人只能上吊了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "只能拜託鈴莓你了啊！",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_018"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我還有這個海之家最後的希望了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n求求你，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "把力量借給我吧……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這、",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這個期待太沉重了……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是。",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果店長說的話是真的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也太可憐了呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好想為他做點什麼，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒辦法就這樣見死不救。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "都已經對大小姐他們，",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "精神抖擻地",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說出",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "「我出去工作了！」了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n而且也已經跑出來了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果什麼都沒做，就沮喪地回家的話好像有點丟臉。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……我知道了。",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不知道能幫到多少忙，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不過我會盡全力努力看看的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真、",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_024"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真的嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "　",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "謝謝你！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你是女神，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "化身成女僕",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "的女神……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那麼事不宜遲，希望你能快點換上泳裝！",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好、",
        "unit_id": 102511,
        "voice": "vo_adv_1077002_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "更衣室就借我用一下囉？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……我、我換好衣服過來了。",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_027"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "…………",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎、",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼了嗎？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請不要一直看啦，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很難為情耶……？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我可是很有眼光的！",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_030"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "　鈴莓，無敵漂亮呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你是人才，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是這個海之家的救世主！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "有你來幫忙的話，或許有辦法撐過去！",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_031"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我馬上就來做料理，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n麻煩你幫忙打掃店裡還有招攬客人哦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "工作的方法，希望你能一邊工作一邊慢慢記起來！",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_032"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n雖然很辛苦不過拜託你了唷，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我會出兩倍薪水地！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的……",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會想辦法加油的。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚～……",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n太丟臉了，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "臉紅地好像快燒起來了",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是。",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像還會幫我調整薪水呢，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為了經營困難【咲戀育幼院】得努力工作才行！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐～，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鈴莓會盡全力的！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "首先，是店裡的打掃呢！",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我可是很擅長打掃的！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n把店裡打掃得很乾淨之後，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "招攬客人進來……？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "客人什麼的，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的會來嗎？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n從來的路上看起來，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "海邊這裡好像空無一人的感覺……？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "算了，",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有客人的話，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n能不被其它人看到穿著泳裝的樣子就平安的度過也不錯。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但以海之家的立場來說，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一個客人都沒有的話",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很困擾吧……？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "打掃完之後，",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "來好好地招攬客人吧！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然很丟臉！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒問題，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家應該不會那麼注意海之家的店員才對！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只要沒有認識的人來，",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "應該馬上就會忘記我才對！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哈呼！？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n歡歡歡、",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "歡迎光臨～！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，{player}！？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼會在這裡？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n突、突然有認識的人光顧……！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎，",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你說抽到了招待券……？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說回來",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像和可可蘿",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "聊過這件事，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還一起陪她到店裡選了泳裝之類的呢～？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒、",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒想到是和我打工地點一樣的海邊……！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為說是要去南國，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以我還以為是更遠的地方呢～！？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "鈴莓，怎麼了嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_1077002_045"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n有客人來的話，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "別顧著閒聊要好好地幫客人點餐！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好，",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　點餐……？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那個",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要怎麼做才好！？",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇啊，",
        "unit_id": 107712,
        "voice": "vo_adv_1077002_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "前途好像",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "多災多難呢～！",
        "unit_id": 107712
