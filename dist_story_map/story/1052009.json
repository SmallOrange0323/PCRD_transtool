    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在參加玩偶裝舞會後的數日，\n莉瑪勤奮地進行伐木工作。"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘿～咿☆",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呼～",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "今天大概這樣就行了吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n最近一直去蘭德索爾",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以沒什麼在伐木，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "得多砍點木頭才行。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也謝謝你來幫我忙。",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "的幫大忙了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？　",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是你自己帶我出來的，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以幫忙是應該的？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你不需要在意那種事啊！　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我才應該",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "和你\n道謝才行呢！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然發生了點意料之外的事，",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但我真的很開心。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然很想再稍微多待一些，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n可是我也不能",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要求太多呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只要再去就行了嗎？　",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我記得",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只要使用變身蘋果，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n應該就能夠去蘭德索爾了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但一個人去好可怕。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟不曉得會發生什麼事啊。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你要再陪我一起去？",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你真的",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是個很溫柔的人呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可是我",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "有你那份溫柔就足夠了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你說不需要客氣",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你為什麼要為我做到這種程度？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為我",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "看起來很開心？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是嗎？　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "讓你稍微",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "聽聽我的任性要求",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也可以嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你前陣子送來的信件裡，",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n夾了舞台劇的傳單。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很想去",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "看看那個～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "才怪",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我不應該",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要求這麼多吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你真的",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要陪我一起去嗎？　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不會給你添麻煩？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是嗎……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼，",
        "unit_id": 105211,
        "voice": "vo_adv_1052009_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我就接受",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你的好意",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可以嗎……？",
        "unit_id": 105211
    },
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘿嘿。",
        "unit_id": 105212,
        "voice": "vo_adv_1052009_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等一下真的能夠看到舞台劇對吧。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好像在作夢！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "今天上演的戲劇是",
        "unit_id": 105212,
        "voice": "vo_adv_1052009_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "身分懸殊的悲戀！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n一對男女愛上了彼此，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "然後跨越障礙，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "接著",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "最後是……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，",
        "unit_id": 105212,
        "voice": "vo_adv_1052009_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我非～～",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "常期待喔。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為至今只能在書上讀到的東西，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "居然有機會能親眼看見呀！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
        "unit_id": 105212,
        "voice": "vo_adv_1052009_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不好不好。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "差不多要開始了，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要安靜點才行呢！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
