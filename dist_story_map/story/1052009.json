        "type": "dialogue",
        "name": "莉瑪",
        "words": "但能在這麼近的距離",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n看到許多人享受戲劇的樣子，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這也令人感到幸福呢！　",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不曉得{player}",
        "unit_id": 105212,
        "voice": "vo_adv_1052009_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是不是也有好好享受呢……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太好了～",
        "unit_id": 105212,
        "voice": "vo_adv_1052009_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "他看舞台劇看得非常投入呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然很擔心自己是不是勉強他來了，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但他似乎很享受呢！　",
        "unit_id": 105212
