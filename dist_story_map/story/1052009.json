        "voice": "vo_adv_1052009_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對不起！　",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等一下就要看劇了，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以不需要我的解說吧！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n如果你親眼觀賞後，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能覺得開心的話我會很高興的。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊～！　",
        "unit_id": 105212,
        "voice": "vo_adv_1052009_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的在親眼觀賞舞台劇呢！　",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "當然舞台劇也讓人超開心的，",
