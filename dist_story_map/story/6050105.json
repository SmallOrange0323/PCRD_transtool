[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "萬聖節呢，",
        "unit_id": 113911,
        "voice": "vo_adv_6050105_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是個讓裁縫師生意興隆、值得歡迎的活動。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過我還是第一次以這種形式扯上關係呢……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那還用說，",
        "unit_id": 113911,
        "voice": "vo_adv_6050105_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為這件事可是騎士先生提出來的。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可是會盡～情使喚你的，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請做好覺悟吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你為什麼看起來這麼高興啊？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓人很不舒服耶。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你還挺從容的嘛。",
        "unit_id": 113911,
        "voice": "vo_adv_6050105_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不過，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這也不是什麼需要勉強為之的事情啦。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就開心地去做吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說到底，一開始都是因為騎士先生說要幫忙的關係吧？",
        "unit_id": 113911,
        "voice": "vo_adv_6050105_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過算了，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "事實上也是不錯的契機啦。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "機會難得，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就讓我好好運用這個經驗吧。",
        "unit_id": 113911
    }
]