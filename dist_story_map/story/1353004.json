    {
        "type": "dialogue",
        "name": "旁白",
        "words": "仍帶著一點濕氣的午後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可璃亞結束了短暫的假期，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正準備與{player}一起踏上下一段冒險。"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……嘿",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咻。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這樣就收拾得差不多了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……這件泳衣",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也要留待明年的夏天呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這件充滿了",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_001"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥相關回憶的泳衣，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "要好好放到櫃子裡收起來。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……欸，哥哥。",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n明年的夏天，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們再一起──",
        "unit_id": 126012
    },
    {
        "type": "background",
        "background": "510171"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……唉。",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_003"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……對不起，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_004"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "奶奶。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n今年的夏天還是不行呢……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "──誰來……",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_005"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "誰來，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_006"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "把我從這裡……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "──咦？",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_007"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n哥哥！！？",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "什麼妳好……！？",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_008"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "這裡是禁止進入的，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "不可以隨便進來……！",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "呼……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "嚇了我一大跳……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "所以……",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_009"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "有什麼事情嗎？",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……唔！",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_010"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……沒、",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_011"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "沒有那種事，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "我才沒有",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "一臉寂寞的樣子。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n是哥哥誤會了吧……？",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "啊……！",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_012"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n不、",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "不是，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "這個是……！！",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……算了。",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_013"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n什麼事都瞞不了哥哥呢。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "我知道了……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "雖然有點害羞，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_014"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "不過……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "這是泳衣。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……謝謝誇獎。",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_015"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "我",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "也這麼覺得……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……那個，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_016"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "這件泳衣，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "是奶奶……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "是祖母送我的禮物。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "我之前有說過，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_017"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "你還記得嗎？",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "祖母是唯一",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "會把我當作普通女孩子看待，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n我最喜歡的人……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "但是，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "她去年",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "出了意外……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "嗯，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_018"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "這部分也有。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "但……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "更多的",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "是感到抱歉。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……去年夏天，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_019"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "祖母找我去海邊。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n說要一起",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "去海邊旅行",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "過夜。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n這件泳衣就是她為此",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "買給我的。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "說是",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_020"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "在百貨公司為我挑泳衣",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "真的很開心。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "她看起來非常地高興……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "但是，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n我卻沒有",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "穿過這件泳衣。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "結果那個夏天，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_021"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "我們沒辦法去海邊……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n因為",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "家裡的緣故。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……唔……",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_022"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "我",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_023"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "早就知道了。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "我",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "是重要的「聖女大人」……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n不可能會得到",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "自行外出的許可。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "所以",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_024"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "那件事就變成我和奶奶的祕密……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "但是，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n小孩子的祕密，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "根本瞞不過大人……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "所以……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "……這件泳衣。",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_025"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n到明年尺寸可能就不合了。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n如果要穿的話，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "今年是最後的機會……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "雖然這樣說，",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_026"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "結果還是什麼都做不到。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n時間轉眼就過去。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "夏天也快要結束了呢……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "真想讓奶奶看一次……",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_027"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
