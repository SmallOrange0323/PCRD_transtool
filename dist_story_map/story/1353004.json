    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "我會高興，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "是因為其他理由。",
