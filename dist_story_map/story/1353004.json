        "voice": "vo_adv_1353004_043"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "不是……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n我不是覺得自己穿起來很好看才高興……",
