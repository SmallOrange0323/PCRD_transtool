    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯。",
        "unit_id": 193211,
        "voice": "vo_adv_1353004_060"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "從根本上來說是這樣沒錯。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "但是那孩子……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n好像",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "有點迷失方向了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "迷失在甚麼是「真正的自己」？",
        "unit_id": 193211,
        "voice": "vo_adv_1353004_061"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n這件事上。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這可能是那個年齡的孩子",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "常常會有的情形呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你看",
        "unit_id": 193211,
        "voice": "vo_adv_1353004_062"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那孩子，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "在你面前的時候，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不是很放得開嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "「在哥哥面前，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "可以展現真正的自己♪」",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "像這樣子。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……但是，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那個想法",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "似乎有所動搖。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "在你面前展現出來的，",
        "unit_id": 193211,
        "voice": "vo_adv_1353004_063"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是不是真正的自己。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "又或者，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "其實還藏著連本人都不知道的其他面目──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……大概像這樣？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "也許是因為青春期──",
        "unit_id": 193211,
        "voice": "vo_adv_1353004_064"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "或者，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是與生俱來的奇怪力量，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我是也不曉得啦。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對本人來說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "應該會覺得很不安吧──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哇。",
        "unit_id": 193211,
        "voice": "vo_adv_1353004_065"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n好肉麻。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過，",
        "unit_id": 193211,
        "voice": "vo_adv_1353004_066"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n哥哥就是要保護妹妹嘛──？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……但是那孩子，",
        "unit_id": 193211,
        "voice": "vo_adv_1353004_067"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "能不能一直忍著當「妹妹」，就不得而知了──",
        "unit_id": 193211
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…………\n……",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_068"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……嗯。",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_069"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦……",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_070"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "又睡著了……？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n是身體的疲勞還沒完全恢復嗎……？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……唔！",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_071"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我已經沒事了……！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……呵呵。",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_072"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "今年的夏天，",
        "unit_id": 126012,
        "voice": "vo_adv_1353004_073"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我一輩子都不會忘記唷……♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，可璃亞的夏天"
    },
    {
        "type": "dialogue",
