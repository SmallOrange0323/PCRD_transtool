        "type": "dialogue",
        "name": "璃亞",
        "words": "好高興。",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n我們說好了喔？",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
