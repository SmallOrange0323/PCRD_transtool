        "name": "璃亞",
        "words": "我",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "穿這件泳衣的樣子……",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "咦……！？",
        "unit_id": 126031,
        "voice": "vo_adv_1353004_028"
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "\n等等，",
        "unit_id": 126031
    },
    {
        "type": "dialogue",
        "name": "璃亞",
        "words": "哥哥！？",
        "unit_id": 126031
    },
