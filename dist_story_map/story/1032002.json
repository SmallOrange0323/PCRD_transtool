[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在買東西時，\n與秋乃不期而遇。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，是{player}大人啊……！",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "前陣子受到你的照顧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我還沒有放棄要讓你成為本小姐的騎士喔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但是，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我今天就先暫停邀請吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n現在的我，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有其他非做不可的事……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "父親大人要我以",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "成為「獨當一面的商人」為目標，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n而我正在努力的這件事，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "以前跟你說過對吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為此，我今天被要求作為社會學習的一環，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n要像庶民一樣買東西。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖說如此，還真是令人頭痛呢……",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我完全不知道",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n庶民們平常是怎樣購物的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "即便如此，這也是父親大人的命令，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n非得完成不可。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "現在放棄的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就有損紫藤家的名聲了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "話說……{player}大人也是來買東西的？",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "果然是這樣沒錯呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那正好。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我很看重{player}大人，所以有事相求。",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n如果我買東西時，若有不符合庶民的感覺，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n{player}大人可以糾正我嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人願意幫忙呀！",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n你果然很值得信賴呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，請你拿著這兩個牌子。",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n一個上面寫著「○」，另一個寫著「×」喔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下來就請你跟我一起行動，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n當我買東西的方式不符合庶民的行為時，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n請舉起這個寫著「×」的牌子。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個牌子是本小姐剛剛在雜貨店裡找到的，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我早料到會派上用場，就事先買起來放啦。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我算是準備周到的人呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，我們趕快走吧！",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_012"
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "首先，就從這間布料行開始吧。",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_013"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨。我們什麼都有賣喔。",
        "unit_id": 511,
        "voice": "vo_adv_1032002_014"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n請問妳要找什麼呢？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可以給我一張桌巾嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_015"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "好的，請問要多大的尺寸呢？",
        "unit_id": 511,
        "voice": "vo_adv_1032002_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不好了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我忘記測量家中桌子的尺寸了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那就沒辦法了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總之，可以把這間店裡所有的布都賣給本小姐嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_018"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "全、全部！？",
        "unit_id": 511,
        "voice": "vo_adv_1032002_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我做到啦！",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n庶民購物，可說是大成功呢！！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "客、客人，",
        "unit_id": 511,
        "voice": "vo_adv_1032002_021"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這可不行！！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n這裡也有其他客人要買的份，如果全都被妳買走的話……！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……咦？",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這、這樣的行為是錯的嗎！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n你不要想騙我啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？你確定你沒有舉錯牌子嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那可是寫著「×」的牌子喔？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？沒錯……？",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那麼，你是說我買東西的方法錯了嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我全部都要的話，果然似乎有點超過呢。",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n你可以告訴我，怎樣才有庶民的感覺嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來如此……只要買一塊大一點的布……",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "憑感覺大概斟酌一下就可以了啊……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下來要買衣服。",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……哎呀，這件衣服真是漂亮呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我就馬上買下來吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "謝謝惠顧。",
        "unit_id": 411,
        "voice": "vo_adv_1032002_028"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n為了配合您的身形，請讓我為您測量尺寸。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒有這個必要，所有的尺寸本小姐都買了。",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我還在發育，所以只要先買下所有尺寸的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不管長多高，都能繼續穿啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "俗話說有備無患嘛！",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真不愧是本小姐啊！確實有庶民感覺呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "路過的小孩",
        "words": "媽媽，",
        "unit_id": 1,
        "voice": "vo_adv_1032002_031"
    },
    {
        "type": "dialogue",
        "name": "路過的小孩",
        "words": "我想要買新衣服啦……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的母親",
        "words": "之前不是才買剛買給你了嗎！",
        "unit_id": 1,
        "voice": "vo_adv_1032002_032"
    },
    {
        "type": "dialogue",
        "name": "路過的母親",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的母親",
        "words": "你馬上會再長高，到時媽媽會再買給你的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的母親",
        "words": "\n因為我們並不是有錢人家啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……咦？",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n啊，難、難道你剛剛的判斷是騙人的！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你、你給我認真點啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總之只要買一件符合自己身材的就可以了嗎！？",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_034"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我從沒這麼想過呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只是要買一件衣服而已就要花費這麼多心思，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n庶民們也真是辛苦呢……",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下來是這間水果店。",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_036"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我要在這裡買父親大人喜歡的水果回去。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨。",
        "unit_id": 311,
        "voice": "vo_adv_1032002_037"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n不管哪種水果都是最高級的喔。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_038"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有好多種呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但是，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "光用看的也不曉得味道呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對了！　",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "每一個都試吃一口看看吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對吧！只要試吃看看的話，",
        "unit_id": 103211,
        "voice": "vo_adv_1032002_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就能知道甜不甜了呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這就是所謂的庶民小智慧嘛！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "客、客人，這樣會讓我很困擾的，",
        "unit_id": 311,
        "voice": "vo_adv_1032002_040"
    },
