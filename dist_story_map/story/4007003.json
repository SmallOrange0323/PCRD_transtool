        "name": "莉瑪、貪吃佩可、凱留",
        "words": "是小莉瑪！？\n是我！\n莉瑪！？",
        "unit_id": 1,
        "voice": "vo_adv_4007003_035"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為、",
        "unit_id": 105211,
        "voice": "vo_adv_4007003_036"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為什麼母船長得跟我一樣！？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為什麼好像不是第一次看到的感覺……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "到底怎麼回事……",
        "unit_id": 105211,
        "voice": "vo_adv_4007003_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這種心裡不安的感覺……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好噁心……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "機械莉瑪",
        "words": "莉瑪莉瑪莉瑪——！！！！",
        "unit_id": 13011,
        "voice": "vo_adv_4007003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在不是在意的時候啊！",
        "unit_id": 106012,
        "voice": "vo_adv_4007003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不戰鬥的話我們會被幹掉哦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "…………是呢。",
        "unit_id": 105211,
        "voice": "vo_adv_4007003_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n蘋果被奪走的怨恨也不能不報！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "搶走蘭德索爾的食物，",
        "unit_id": 105812,
        "voice": "vo_adv_4007003_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還讓小凱留受盡苦難，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "接受制裁吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要上囉！　",
        "unit_id": 106012,
        "voice": "vo_adv_4007003_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接這招試試！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是我們的全力！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉瑪、貪吃佩可、凱留",
        "words": "喝啊啊啊啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_4007003_043"
    },
    {
        "type": "dialogue",
        "name": "機械莉瑪",
        "words": "莉瑪，",
        "unit_id": 13011,
        "voice": "vo_adv_4007003_044"
    },
    {
        "type": "dialogue",
        "name": "機械莉瑪",
        "words": "莉瑪莉瑪———！？",
        "unit_id": 13011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在閃爍的群星之間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n又出現了一道耀眼的新光芒……"
    }
]