        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "來，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一邊看著這個，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一邊跟我一起成為出色的淑女吧！",
        "unit_id": 105213
