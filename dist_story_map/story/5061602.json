    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "學會的教誨，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也就是淑女的規範哦。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n為了今後也不會忘記初衷，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "繼續當個楚楚可憐又美麗的淑女，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以我打算把它像這樣記錄在紙上。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然我有稍微改編得比較適合我，",
        "unit_id": 105213,
        "voice": "vo_adv_5061602_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但每一項都是很重要的事哦。",
        "unit_id": 105213
    },
