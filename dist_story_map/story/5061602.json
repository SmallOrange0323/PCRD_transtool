        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "鏘～！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳們看這個怎麼樣？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "「淑女五項」？",
        "unit_id": 102611,
        "voice": "vo_adv_5061602_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這是什麼？",
