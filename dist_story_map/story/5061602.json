        "type": "dialogue",
        "name": "鈴",
        "words": "咦～",
        "unit_id": 102611,
        "voice": "vo_adv_5061602_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才不要，好麻煩。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "既然要寫的話",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還不如寫「懶散五項」呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也已經有搞笑藝人這個目標了，",
        "unit_id": 103311,
        "voice": "vo_adv_5061602_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我需要的",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "應該是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "「搞笑五項」的啦！",
        "unit_id": 103311
    },
