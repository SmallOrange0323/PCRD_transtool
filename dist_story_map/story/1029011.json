[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隨著祭典的日期一天一天接近，慈樂之音也越來越投入於練習當中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而──"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "結束！",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……呼，",
        "unit_id": 105411,
        "voice": "vo_adv_1029011_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛才那段",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該算是練得差不多了吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，",
        "unit_id": 104211,
        "voice": "vo_adv_1029011_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "動作的確已經調整到位了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n妳說是吧，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望？",
        "unit_id": 104211,
        "voice": "vo_adv_1029011_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我覺得還挺不錯的喔。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……我說，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才間奏時的舞步",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是不是只有我有點沒對到拍子啊？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒有這回事喔。",
        "unit_id": 105411,
        "voice": "vo_adv_1029011_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對吧，千歌。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的。",
        "unit_id": 104211,
        "voice": "vo_adv_1029011_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "拍子很精準動作也很到位。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳不需要在意。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我去休息一下，自己稍微想一想。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小望她",
        "unit_id": 105411,
        "voice": "vo_adv_1029011_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然沒有再繼續讓自己過度操勞，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但這次換成苦惱的心事增加了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "她太堅持要讓演出完美成功，",
        "unit_id": 104211,
        "voice": "vo_adv_1029011_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以不管練多少次，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "她都沒辦法滿意的樣子……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這下子",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺誰去跟她說，她也都聽不進去了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "到底該怎麼辦才好呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說的也是。",
        "unit_id": 105411,
        "voice": "vo_adv_1029011_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種時候交給騎士先生處理也許比較妥當。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果是由受到她信賴的你去說，",
        "unit_id": 104211,
        "voice": "vo_adv_1029011_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想望一定會聽進去。\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那就麻煩你了。",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊，",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管怎麼想，事情都沒辦法如願。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我到底該怎麼辦才好呢……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊……",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌她們",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說了什麼嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊。",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是丟臉……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我這樣真是個失職的Center。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她們兩個說的沒錯，",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也覺得已經做得很好了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只不過",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要一想到",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「真的是這樣嗎？」、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n「還可以再做得更好吧？」，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就會一下子感到不安起來。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "換作是真正的頂尖偶像，",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n想必就不會煩惱這種事情了……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就、",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "燈光是不是",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有點太亮了？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "討、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "討厭，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "光芒越來越刺眼，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀啊啊～！",
        "unit_id": 102913
    },
    {
        "type": "background",
        "background": "510071"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那一天，{player}排了打工，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n要去當望PV拍攝的工作人員。"
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "不好意思，",
        "unit_id": 1231,
        "voice": "vo_adv_1029011_019"
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "我到處都找不到小望……",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "啊啊，",
        "unit_id": 1031,
        "voice": "vo_adv_1029011_020"
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "小望她會稍微離開一會兒。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "不用在意她也沒關係，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "趁現在先休息一下吧。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "嗯？",
        "unit_id": 1031,
        "voice": "vo_adv_1029011_021"
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "我記得你是新來打工的……",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "對啊，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "她偶爾會像這樣，一個人跑到外面去。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "沒人知道她是要去哪裡，",
        "unit_id": 1031,
        "voice": "vo_adv_1029011_022"
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "但她回來的時候都會給人一種豁然開朗的感覺，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "\n在鏡頭前的表現也會變好，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "所以也就沒有人會去特別追究了。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "這算是小望在工作時候的作風，",
        "unit_id": 1031,
        "voice": "vo_adv_1029011_023"
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "所以就稍微忍耐一下吧。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喂，是{player}嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想請你來接我，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我現在在──",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "510202"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}！\n不好意思突然叫你出來。",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你已經聽說過我偶爾會溜出來的事了啊。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "每當事情不順遂，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n或是工作遇到困境的時候，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就會來這個地方。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "──因為",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這裡是我的原點。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你想聽原因嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說是這麼說，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也只是件既常見又無聊的陳年往事。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過對我來說",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是段使我決定要成為偶像的重要回憶。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在我還小的時候，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有一次來這裡玩，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "結果跟爸媽走散了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我當時非常害怕不安，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一邊哭著一邊到處亂走，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "結果看到了三個",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正在練習唱歌跳舞的女孩子。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她們是",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我有在電視上看過的，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "名為「偶像」的人。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只不過，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和我所知道的偶像不同，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是群努力想成為偶像但技巧還不夠純熟的人。",
        "unit_id": 102931
    },
    {
        "type": "still",
        "still": "102901101"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "即使一個觀眾都沒有，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n她們仍舊用盡全力在展現著自身的魅力。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這景象使我大開眼界，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來人可以這麼閃耀奪目。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就連什麼是偶像都還搞不懂的小孩子，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也都能感受到她們的熱情，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以回過神來我的注意力都被她們的表演給吸引過去了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n先前的不安跟淚水全都拋到九霄雲外，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "非常專心地在幫她們加油。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而她們也對著",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "僅此一人的小小觀眾，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n露出了滿臉的笑容。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她們的身影",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在我心中留下了深刻的印象，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以我之後就在爸媽的面前，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n試著模仿她們唱歌跳舞。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但畢竟是小孩子在玩扮家家酒，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以模仿得一點也不像。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我爸媽卻感覺相當開心，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "笑著誇獎了我。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以父母來說那是理所當然的反應。",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我對這樣的反應感到非常高興。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也因此察覺到",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來讓人露出笑容，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是這麼令人開心的事。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是我的技巧更加熟練的話，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也許不只是父母，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就連朋友或是沒見過的陌生人，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也能夠讓他們露出笑容。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就想說，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然如此那我也成為偶像吧。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想要成為",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "像她們一樣，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "傳遞笑容的人。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這段回憶就是使我成為偶像的初衷。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……老實說",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我最近不斷接到大型的工作，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n今天的拍攝也不太順利，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因此心情有點煩躁。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我才來這裡讓自己回想起來。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "技巧與完成度雖然重要，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但還有更加重要的事。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再一次回顧",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "自己的初衷之後，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我已經不再感到不安了，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且現在還有人來迎接我，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以我沒問題的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才在你來之前，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想到了一個不錯的表演。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想要現在就先試試看。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只在你面前表演的，",
        "unit_id": 102931,
        "voice": "vo_adv_1029011_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的特別演出。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你願意欣賞嗎？",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，",
        "unit_id": 190011,
        "voice": "vo_adv_1029011_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "每個人都有自己的故事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "見識到了很棒的回憶呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感到煩惱，",
        "unit_id": 190011,
        "voice": "vo_adv_1029011_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是認真看待一件事情的最佳證據。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但有時候太過鑽牛角尖，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反而會像是迷路一樣陷入迷惘。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但望的心中其實早就有了能突破困境的答案。",
        "unit_id": 190011,
        "voice": "vo_adv_1029011_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n剩下就看她能不能察覺到了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當她察覺到的時候，她離成為真正頂尖偶像的日子，",
        "unit_id": 190011,
        "voice": "vo_adv_1029011_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該也就不遠了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來就靠慈樂之音的兩位",
        "unit_id": 190011,
        "voice": "vo_adv_1029011_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和你一起支持她了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也很期待那一天的到來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉──",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦……",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_051"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我這是……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不可以在這裡睡覺喔……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才我好像也跟著睡著了呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是我累了嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺還夢到很不可思議的夢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你也夢到了？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是我懷抱偶像初衷的夢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明自己沒有那段記憶，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "卻沒來由地覺得懷念。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我覺得",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個夢裡頭有著許多重要的事物。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺還差一點",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就能夠搞清楚那些事物是什麼了……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……你說的對。",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我並不是獨自一人在當偶像。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "即便是一個人難以處理的問題，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跟別人一起面對也許就能解決。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要我們慈樂之音三個人，",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後再加上你……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "像是那個夢裡的偶像一樣，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n互相支持對方就沒問題了對吧！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你。",
        "unit_id": 102913,
        "voice": "vo_adv_1029011_056"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我已經",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "回想起了很重要的心情，所以已經不要緊了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
