    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和貪吃佩可被困在像是「現實」的世界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不斷重複經歷同一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然後他們遇見了優衣，在她的帶領下來到椿丘高中。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔喔～！",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這就是",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個世界的學校啊……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺又和月光學院",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不太一樣呢～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個，",
        "unit_id": 100231,
        "voice": "vo_adv_1210002_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們要去上課，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但貪吃佩可妳……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我果然",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不能和你們一起進學校啊～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我很想",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "盡量待在{player}的附近……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你們兩位，",
        "unit_id": 101831,
        "voice": "vo_adv_1210002_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "早安～！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "早安，",
        "unit_id": 100231,
        "voice": "vo_adv_1210002_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "伊緒。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "早安。",
        "unit_id": 105532,
        "voice": "vo_adv_1210002_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 101831,
        "voice": "vo_adv_1210002_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你們兩位",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一大早就能朝氣蓬勃地打招呼，真了不起～",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那位女孩是……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "應該不是……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "轉學生吧？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃～～～",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯………………",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是{player}的親戚！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "伊緒、優衣",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_1210002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳應該覺得我們一點都不像，",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我們其實是關係很遠很～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "遠的親戚……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果要回溯族譜的話，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是在我們的上五代……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎、",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼辦啊～！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我順口就說我們是親戚，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但應該被看穿了吧～！？　",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 101831,
        "voice": "vo_adv_1210002_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "原來是這樣～！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳從國外和家人一起來旅行嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n是因為覺得日本的學校很稀奇，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "才會送他來上學吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵♪",
        "unit_id": 101831,
        "voice": "vo_adv_1210002_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳在日本要開心地玩喔。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "待會再跟你們兩位見囉。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她、",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她很乾脆地當真了……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是說，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來她在這個世界也是{player}的老師啊～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先不提這個，",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然是想辦法度過這個難關了，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但在放學之前，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我該去哪裡……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……",
        "unit_id": 100231,
        "voice": "vo_adv_1210002_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然我覺得這麼做不太好，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但妳要不要去頂樓呢？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那裡不會有人出入，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想沒有人會發現妳的。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果從後門進去，",
        "unit_id": 100231,
        "voice": "vo_adv_1210002_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該也不會在半路上被別人看到。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果妳不介意，我可以帶妳過去……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇～！",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "優衣！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我在頂樓等你喔！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請你上完課後",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再來接我！",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "510180"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……好閒喔。",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還要再等多久，課才會上完啊……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我能做的事情就只有",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在街景中尋找罕見的建築物而已……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為和從王宮望出去的景色完全不一樣，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的確是很有意思……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最重要的是，",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我又在不認識的世界",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變回孤單一人，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這比我想像中的還要寂寞……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我總覺得肚子也……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咕嚕嚕嚕嚕嚕嚕～～！！"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一想到這件事，反而覺得更餓了……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n等他們上完課，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我早就已經倒在路邊了啦……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在變成那樣之前，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快來接我吧……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "！？",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "糟糕！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有人來了！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我得找個地方躲起來……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡完全沒有地方能躲啊～～！！　",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "萬事休矣……",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會因為犯下非法侵入罪而遭到逮捕，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的在這個世界",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和{player}失散……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔～",
        "unit_id": 104331,
        "voice": "vo_adv_1210002_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "找到了找到了！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "貪吃佩可！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……是真琴",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和霞！？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "囉哈～☆",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來妳們也和{player}",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讀同一所學校啊！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105831,
        "voice": "vo_adv_1210002_027"
    },
    {
