[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在路邊攤被克蕾琪塔招待了一碗拉麵後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}拖著喝醉了的克蕾琪塔走在回去的路上。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚、",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚～嗯……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不小心喝太多了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n明明",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "已經跟",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那群混蛋貴族喝過一輪了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都是那拉麵店的大叔",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "拚命勸酒害的啦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗝！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "腳、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "腳不穩……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n少年，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你肩膀",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "借我扶一下……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的……",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒想到我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "竟會露出如此丟人的一面。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "別看我這樣……",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "拼了命地在努力唷？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "尤其是最近……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為了陛下……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也可以說是，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為了這個國家的人民……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可是只拿微薄薪水，",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "從早到晚……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "燃燒生命在工作……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且還要拚命抵抗",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "想做假帳來中飽私囊的衝動……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是可是，",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那些文官又不太願意聽我這種",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n突然迸出來的傢伙講的話……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "加上國庫也快見底……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "稅收也一直無法達標……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "欸欸……",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你有",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好好在聽嗎～？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "光～？",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n唔～",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "已經早上了嗎……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這樣的話，",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "得趕快開始工作了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n今天也要",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "賣力…………",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔…………",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在路上偶然遇見一名"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n叫克蕾雅的女性，並幫她帶路，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n卻不知為何變成她述說自身遭遇的對象。"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「剛才也提到過，",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n我是",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "靠投資討生活的。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「現在這時代可便利了。",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "只要有預測世事變化的能力，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "再加上一點點運氣，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n即使足不出戶，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "也能累積莫大的財富。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「沒錯，",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "就是你想的那樣。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n我便是",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "經由投資，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "從幾乎身無分文，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n爬上億萬富翁地位的。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "……然而……」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「大概是我太得意忘形了吧。",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "竟然不小心……",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "相信了從未見過面、",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n只有透過網路聯繫的對象。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "我賺到的資產，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "有一大半都被搶走了。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「而多虧如此，",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "我那之後就變得徹底不相信他人。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n才會像這樣，不僱用當地導遊，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "選擇用自己的眼睛判斷，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n親自找一個看起來人還不錯的少年",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "來幫我帶路。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「而最後，",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "騙走我錢的那個詐欺師也銷聲匿跡了。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "今天約好要見面的又是另外一位……",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "透過網路斥責、",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n取笑",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "可憐的我，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "一個不可饒恕的傢伙。」",
        "unit_id": 118031
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「好啦！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n總算是抵達椿丘大飯店了！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「都到這地步，我們算是患難與共了。",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n你也和我一起",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "殺進去吧！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "就給你機會",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "見證我打倒",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "『那個女人』的瞬間！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而{player}便跟著進去"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蕾雅口中「敵人」正等待著的飯店內，不過……"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「唔……！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n來偷襲這套！？",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n妳竟敢",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "這麼對我……！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「啊啊！？",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "快、",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "快點放開！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "這可是……",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "犯規吧！？」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "竟然也把少年捲入陷阱裡……！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「不、",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "不要！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n這樣、",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "這樣做的話！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n不行～～～～！！！」",
        "unit_id": 118031
    },
    {
        "type": "still",
        "still": "118000801"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好啦。",
        "unit_id": 1,
        "voice": "vo_adv_1180008_021"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n是我贏了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「我氣────！！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n為什麼！？",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n為什麼就是贏不了～～！？」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "當然是因為，",
        "unit_id": 1,
        "voice": "vo_adv_1180008_023"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我的技術「比妳強」。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n而且這麼一來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "也證明了至今為止的對戰成績，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n並沒有受網路速度的影響。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "要說的話，",
        "unit_id": 1,
        "voice": "vo_adv_1180008_024"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "玩這種懷舊格鬥對戰遊戲，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "說什麼網路有延遲\n而不肯認輸也太離譜了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "妳以為現在已經西元幾年了？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n還是說妳住在什麼",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "只能夠撥接上網的地區？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「可惡啊啊啊～！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n妳那張愛嗆人的嘴",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "不管是語音還是面對面都沒變啊──！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "初次見面，你好。",
        "unit_id": 1,
        "voice": "vo_adv_1180008_026"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n不好意思自我介紹晚了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n我是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "克蕾雅小姐的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "該說是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "遊戲同好吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「誰跟妳同好！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n是死對頭啦，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "死對頭！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "是是是。",
        "unit_id": 1,
        "voice": "vo_adv_1180008_028"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n雖然特地跑來那個死對頭在的國家，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n打算來場線下聚會的，可是克蕾雅小姐妳呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……雖然，",
        "unit_id": 1,
        "voice": "vo_adv_1180008_029"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "妳硬拉一個當地的男學生來的舉動，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n是超出我的預想啦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「哼！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n我只是覺得",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "需要第三者來當個公正的評審！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "雖然妳口中的評審，",
        "unit_id": 1,
        "voice": "vo_adv_1180008_031"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "也很自然地參加戰鬥了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n而且妳原本",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "似乎還盤算跟他一起夾擊我吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「什麼嘛什麼嘛！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n把人說得像卑鄙小人一樣！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n這可是多人數大亂鬥類型的遊戲，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "這種戰略可是基本！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「接關！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "我要繼續！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n不過一兩次落敗，",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "可無法讓我收手的喔！？」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好吧，我奉陪。",
        "unit_id": 1,
        "voice": "vo_adv_1180008_034"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n我就在事態演變成妳擅長的體力耐久賽前，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "讓妳徹底灰心喪志吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「……？",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n少年，怎麼了？",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "一直盯著這邊看。」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「啊啊！？",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_036"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n你的眼睛",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "是瞎了嗎！？",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n還是說",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "你大腦沒辦法正常判斷事物！？」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……看，",
        "unit_id": 1,
        "voice": "vo_adv_1180008_037"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n她很有趣吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「給我等一下！",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n你們在那邊說什麼悄悄話！？",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n可以請妳不要試圖拉攏評審嗎，莓小姐！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "莓",
        "words": "哎呀──",
        "unit_id": 1,
        "voice": "vo_adv_1180008_039"
    },
    {
        "type": "dialogue",
        "name": "莓",
        "words": "有機可趁",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莓",
        "words": "呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "啊啊啊啊啊！？！？",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n連續使用道具然後把人關廁所關到死未免也太卑鄙了吧！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n妳這個人！！？」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "莓",
        "words": "──呵。",
        "unit_id": 1,
        "voice": "vo_adv_1180008_041"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「嗤之以鼻！？",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_042"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n剛才妳那完全是用一副",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "嗤之以鼻",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "的態度看我吧！？",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "我氣────！！！！」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「可惡～～～",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_043"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "我生氣了！！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "忍無可忍了！！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n你們給我打開mimi！！",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n接下來就用",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "《阿斯特朗傳奇》來一決勝負～～！！」",
        "unit_id": 118031
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}被捲進兩人的遊戲對決，一直比到夜深。"
    },
    {
        "type": "still",
        "still": "118000802"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "「話說回來……",
        "unit_id": 118031,
        "voice": "vo_adv_1180008_044"
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "妳送我的這件衣服。",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n上面寫什麼呀？",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "\n我",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "克蕾雅",
        "words": "比較看不懂漢字……」",
        "unit_id": 118031
    },
    {
        "type": "dialogue",
        "name": "莓",
        "words": "噢，",
        "unit_id": 1,
        "voice": "vo_adv_1180008_045"
    },
    {
        "type": "dialogue",
        "name": "莓",
        "words": "那個呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莓",
        "words": "\n上面的詞，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莓",
        "words": "\n很適合用來形容特地跑到赤道這一頭來的克蕾雅小姐呢。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔、",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_046"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔唔……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "哦。",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_047"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n您醒了呀，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔唔唔……",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "已經早上了嗎……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我怎麼會在王宮……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "聽說是昨晚，",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_049"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n那位少年把喝得爛醉的",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐帶回來的。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n晚點您去致個謝吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "原來是這樣……",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_050"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……我知道了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……不過……",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我好像，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做了一個奇怪的夢……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐？",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_052"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n工作時間差不多要開始了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……秘書一號。",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n目前最優先工作是？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "雖然有許多課題需解決，",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_054"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n但要論目前最優先，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "便是得湊國家經費的部分。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n是否要考慮去拜託【墨丘利財團】，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請他們幫忙買點公債呢？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說的這件事",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_055"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "或許遲早都得做……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……但在那之前，",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_056"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n先陪我去個地方，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是可以。",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_057"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n去哪裡呢？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "──【里士滿工商會】。",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_058"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵……",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_059"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n呵呵呵……♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哦──呵呵呵呵♪",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_060"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n快看哪，秘書一號♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n好好看看我們【里士滿工商會】的寶物庫！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "因為有一陣子沒回來，",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_061"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "積了不少灰塵……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n啊啊，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "好想打掃……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "亮晶晶的金銀財寶！",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_062"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "眾多頂尖的高級藝術品！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n光是像這樣待在這裡，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就感到心靈獲得滿足哪～♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……幸好在豪紳議長有機會把魔爪伸到這裡前，",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_063"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "反亂就宣告失敗。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n也因此，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這個寶物庫裡的資產維持在我們成為公務員前的狀態。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也成功",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_064"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再次就任【里士滿工商會】的公會長。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "順利拿回了這個寶物庫♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不愧是陛下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是天真……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我是說寬宏大量♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只是……",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_065"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "曾經興盛一時的【里士滿工商會】，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也無法像以往那樣進行公會活動了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n除非我可以分身成兩個人啦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不過，",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_066"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n至今為止在克蕾琪塔小姐底下工作的人才",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "也都還留在會裡。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n現在這邊作為承接政府委外業務的組織，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "也是大為活躍……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "畢竟那個穢物議長不在了，",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_067"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是我有那個意思，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要中飽私囊或作假帳都會比以往來得容易。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號。",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_068"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n今早的工作──",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就是要來清算",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這個寶物庫。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n眼前所有資產",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都拿去捐給國庫吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……\n我明白了。",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_069"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不過……",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_070"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這樣真的好嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔之塔呢？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……當然不好。",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_071"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n雖然不好，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我已經不用將金銀財寶",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_072"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當作心靈寄託了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不用特地將自己成功的證明",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "化為實物了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "現在的我，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一定……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有辦法走下去的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "畢竟",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_073"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我有",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下和妳在呀。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那個少年，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也會成為我的力量。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n而且……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……而且？",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_074"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且，",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_075"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "試想一下？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我現在可是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "奉陛下之命管理國庫的人唷？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "即使將這些捐獻給國庫！",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_076"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n還是一樣在我的管理下呀！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要說這個國家的資產，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "全歸我管也不誇張──",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "原來如此，",
        "unit_id": 6111,
        "voice": "vo_adv_1180008_077"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是這樣啊。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "筆記筆記……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下！",
        "unit_id": 118011,
        "voice": "vo_adv_1180008_078"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n別筆記下來去跟陛下打小報告啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n剛才的當然是開玩笑的好嗎～！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──原本是商人的克蕾琪塔‧凱許。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "本來除了金錢以外，什麼也不相信的她，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在與貪吃佩可和{player}等人交流後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n心境似乎也逐漸地產生了變化。"
    }
]