[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ギルドハウス内を捜し回り、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nノウェムとオクトーはようやく跳躍王を発見する。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おい、",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "教授！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nやっと見つけたぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "はあ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_001"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ほんと神出鬼没だねえ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n捜すのも一苦労だよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "なんですか？",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_002"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n私は",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "あなたたちほど暇ではないのですが？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシたちだって暇じゃないぞ！",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_003"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "今日ボクらが来たのはクレームだよ。",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_004"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nクレーム。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "ほう？　",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_005"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "私にクレームですか？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "面白い。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "聞いてあげましょう。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "ただ、",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_006"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "つまらない内容だったら……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "わかってますね？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "つまらない内容なわけあるかよ！",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_007"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nこっちは結構切実なんだぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ま、",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_008"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "クレームだから面白いわけもないんだけどさ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ダイゴのことだよ！",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_009"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nなんでアイツ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "あんなにケンカ吹っ掛けてくるんだよ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "こっちが任務中でも構わず仕掛けてくるんだけど。",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_010"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n勘弁してほしいんだよね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "なるほど……",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_011"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "それで私に文句を言いに来たわけですか。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "ですが、",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "それは無駄としか言えませんね。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なんでだよ？",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_012"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nオマエのプリンセスナイトだろ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "彼は七冠の私にさえ",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_013"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "勝負を挑んできますからね。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n止めようがありませんよ。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "それじゃあアタシたちも困るんだよ～！",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_014"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nあれだ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ほごかん……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なんだっけ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "保護監督責任、",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_015"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "って言いたいわけ？　",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まあ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "厳密には違うけど。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "たださあ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "もうちょっと教育をちゃんとしてほしいよね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "それが無理なのは",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_016"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "あなたたちもわかっているでしょう？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "ああいう人間は",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "他にいませんからね。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "しっかし、",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_017"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なんであんな奴をプリンセスナイトになんか選んだんだよ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "逆ですよ。",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_018"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "それくらいじゃないと、",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\nプリンセスナイトというものは",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "務まらないからです。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "そういう特別な存在なのですよ。",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_019"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\nプリンセスナイトというものは。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "結局、",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_020"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "無駄足だったのか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "はぁ……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "しょうがない、",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_021"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "これからも適当にあしらって",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "撒いちゃうしかないねえ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ノウェムとオクトーは徒労感に苛まれ、力なくため息をつくのであった。"
    }
]