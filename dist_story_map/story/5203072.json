[
    {
        "type": "still",
        "still": "520307201"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "波波爺爺的",
        "unit_id": 9212,
        "voice": "vo_adv_5203072_000"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「克蘿茜的詳細介紹」",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "要開始啦～！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n把老夫解析的新型軀體的詳細資訊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n用大家都能懂的方式",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "仔細地",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "慢～慢地",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "講解給大家聽。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這次要講解的是，",
        "unit_id": 9212,
        "voice": "vo_adv_5203072_001"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "航空軀體裝備的克蘿茜。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n似乎是為了戲劇性地提升機動性而設計的型態。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n要說最重要的特徵，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就屬",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "在背後的這對機械雙翼！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這推進器在陽光照射下閃閃發光的模樣，",
        "unit_id": 9212,
        "voice": "vo_adv_5203072_002"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n實在是",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "無比",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "美麗……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n啟動機關的動作",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也十分優雅，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "令老夫看得",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "幸福至極。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "波、",
        "unit_id": 134612,
        "voice": "vo_adv_5203072_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "波波爺爺？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n感覺這次的解說特別投入呢……？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "波波爺爺偶～爾會這樣的。",
        "unit_id": 134511,
        "voice": "vo_adv_5203072_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n像是為了開發研究",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "而連續熬夜的時候。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不過，",
        "unit_id": 9212,
        "voice": "vo_adv_5203072_005"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "美麗也是需要代價的。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n啟動機械雙翼的高機動模式，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "雖然善於瞬間加速……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n卻有尚未查明的問題。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "要是不斷地",
        "unit_id": 9212,
        "voice": "vo_adv_5203072_006"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "進行突然加減速，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n發電系統可能會來不及散熱。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "──所以，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "除了緊急情況外",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "都不可以使用高機動模式喔！？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的！",
        "unit_id": 134511,
        "voice": "vo_adv_5203072_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我知道了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，",
        "unit_id": 134612,
        "voice": "vo_adv_5203072_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克蘿茜小姐。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n話說回來，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "妳是不是被說中午前要回去？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n好像是要幫忙沃爾加諾先生……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 134511,
        "voice": "vo_adv_5203072_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我都忘了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好～",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "高機動模式",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啟動！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n克蘿茜，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "出發了！！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "所以我說",
        "unit_id": 9212,
        "voice": "vo_adv_5203072_010"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不要這麼輕易地啟動啊～～！",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "end"
    }
]