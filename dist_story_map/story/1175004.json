[
    {
        "type": "background",
        "background": "500672"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "解決在溫泉發生的事件後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n深月與{player}準備好好放鬆一番，享受溫泉旅館。"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "那麼，",
        "unit_id": 1412,
        "voice": "vo_adv_1175004_000"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "我去準備房間！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n請稍待片刻！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "{player}，\n到了房間休息一會之後，",
        "unit_id": 117511,
        "voice": "vo_adv_1175004_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們去泡溫泉吧？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果你希望的話，",
        "unit_id": 117511,
        "voice": "vo_adv_1175004_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我可以陪你一起泡喔♪",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "開玩笑的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀？",
        "unit_id": 117511,
        "voice": "vo_adv_1175004_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大浴場那邊特別亮耶……？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n是怎麼回事──",
        "unit_id": 117511
    },
    {
        "type": "background",
        "background": "510400"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你還好嗎？",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來你似乎很累了，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要休息一下嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你是男孩子呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就請你再努力一會吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們再走一小段路",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就休息吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n在那之前，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你要好好跟上來喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呼，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "辛苦了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你在這裡休息一陣子吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我去那附近看看。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你可以慢慢休息。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我要去尋找",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "與採集蕈菇。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……當作研究的樣本。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為這一帶",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "生長著很好的蕈菇。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "{player}你也感興趣嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那也可以跟我一起去……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過你在體力上沒問題嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "比起擔心體力消耗，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好奇心佔了上風吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你的性格，或許也意外地",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "適合當科學家呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我知道了。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "跟我來吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我們一邊採蕈菇，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一邊前往目的地吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "找到了。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你看。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在那邊的樹樁處，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n長著白色的",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "鬆鬆軟軟、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "像花朵般的物體吧？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "叫繡球菌。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n雖然是菇類之一，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但漂亮得不像是菇類對吧？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "繡球菌沒有毒性，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "吃起來口感很有意思，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很好吃喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那棵倒樹那邊",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也生著蕈菇對吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這種形狀的菇類，在超市等地方經常看得到。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那是秀珍菇。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "味道溫和，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不管以任何吃法食用，都很可口。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我喜歡炸成天婦羅來吃。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個也摘下來好了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你說那個",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "樹蔭下的菇類？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那是月夜茸。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是毒菇喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然的確和秀珍菇長得很像……",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你看，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "像這樣擋住光線……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就看得到菌摺在發光吧？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這是它的特徵。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "撕開菌蓋後……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你看這裡。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n看得到裡面發黑的部分嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n以同樣的方式撕開秀珍菇不會有發黑的地方，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以用這裡",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "作區分。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "會腹瀉、",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "產生嘔吐感。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n有時還會引發休克症狀，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在最糟的情況下",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "會導致死亡。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然容易誤認，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這真的是很危險的菇類，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要小心喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼啦？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "明明談到危險的話題，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你卻一臉開心的表情呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你覺得這種話題很有趣？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這代表",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我激發了你的求知欲嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，這次我們邊聊",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "野菜與",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "野草的話題邊往前走吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n因為我想要的蕈菇大致上都採到了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──對了。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你也許會覺得意外，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n狗尾草……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也就是",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "貓仔尾可以食用喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只要從莖部取下花穗，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就和一般穀類一樣能夠食用。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我個人推薦的吃法是",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "保留顆粒略為炒過。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只要稍微加點",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "鹹味，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "吃起來相當美味喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼樣？",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n即使是這種話題也很有趣嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "老師……",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呀。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我只是個研究者，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當老師不太符合我的風格……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "教導像你這樣的學生",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "或許還不壞。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──啊。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n說著說著就到了呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這裡便是目的地。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是呀。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這裡是在健行路線途中，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n一片略寬敞的空地，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒有任何特殊之處。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不過，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是這裡沒錯。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這裡很適合。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我馬上去做準備，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你稍等一會吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果你閒著沒事又體力充沛，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以去附近散步。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這一帶也",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "生長著蕈菇與野草，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "到處看看一定很有趣的。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "卡式爐也準備好了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n接下來只剩下",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "烹調……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n差不多得叫{player}回來了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……找到了找到了。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "他發現了什麼嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……啊，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那邊是懸崖！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "{player}，危險……！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呼……",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_035"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "千鈞一髮呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你有沒有受傷？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n要不是我注意到，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你就要滑落山崖了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……唉，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_037"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "明明有危險的地方，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我卻讓你離開視線範圍，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這也算是我監督不周。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "從下次開始，我們彼此都要多加留意。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天是",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_038"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為了讓你玩得盡興而來到這裡的，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在生氣也無濟於事。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_039"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒錯。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "準備都做好了，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "過來這邊吧。",
        "unit_id": 105131
    },
    {
        "type": "still",
        "still": "117500401"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嚐嚐看。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然不是什麼豪華大餐……",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_041"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n在大自然中品嚐",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現摘的食材，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也相當不錯吧？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在這裡",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_042"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "除了料理，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n還能享受",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "藍天、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "風聲、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "樹木、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "花草等等的景致。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這是在城市裡很難體驗到的",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "奢侈時光喔。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為我",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_043"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "常常找你陪我做研究、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n對你提出亂來的要求……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我偶爾",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_044"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "想像這樣",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "向你表達感謝之情。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然這麼說……",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_045"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是一直以來只顧著做研究的人……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n對於你會不會感到高興",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "缺乏",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "自信……",
        "unit_id": 105131
    },
    {
        "type": "still",
        "still": "117500402"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真的嗎？",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_046"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你說料理也",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很好吃，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n能聽到各種話題",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很有意思……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這麼說實在誇過頭了。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_047"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那不是什麼特別講究的料理，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n至於話題",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也只是我在炫耀知識而已。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你不需要小心翼翼地顧慮我的心情。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_048"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n因為我是科學家，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你只要",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "提出事實就行了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦……？",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_049"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不是說謊或顧慮我，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你是真的這麼認為……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊。",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_050"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n那就",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "太好了。",
        "unit_id": 105131
    },
    {
        "type": "background",
        "background": "510400"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_051"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你肚子特別餓吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我應該採了很多",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "蕈菇與野菜，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你卻通通吃完了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼……",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_052"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n雖然捨不得離開，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們就收拾東西回去吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你也有禮物要給我？",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_053"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n是什麼呢？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是……",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_054"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "玫瑰花……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你剛才在",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "懸崖附近找到的……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊，",
        "unit_id": 105131,
        "voice": "vo_adv_1175004_055"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以你才會去那麼危險的地方……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
