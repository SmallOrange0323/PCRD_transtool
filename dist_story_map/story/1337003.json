    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在來這裡的路上，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我一直都是用走的吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不知道是不是始源冠裝變得不穩定的緣故，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n權能的使用也出現了問題呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不，怎麼說呢，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只是要用的話或許可以用……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但要是不能在穩定狀態下使用會很危險啊。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你想",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "想，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "假如我們想走方便的捷徑，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但是指定地點的座標出現異狀，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "結果活埋在土裡",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或是岩石中！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種事也是有可能發生的。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果是物理上逃得出去的地方倒還好，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要是困在不妙的空間，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一輩子出不來的話，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你肯定也不想要吧？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "困在石頭中一命嗚呼，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或是永遠在不知是何處的空間裡徘徊……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "至少",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在確定安全之前",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我不太建議使用呢～",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們就只能腳踏實地前進了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n前方的路還很長，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你也做好心理準備吧。",
        "unit_id": 133712
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這是",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "通往我們據點的道路。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這裡設計成了迷宮，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "即使是偶然迷路的人",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n或是懷有惡意的傢伙誤闖進來，也無法到達。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話雖如此，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟是通往自家的熟悉道路。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n放心跟著我走吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實要是璃乃和靜流也在的話，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n狀態會更萬全……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但我拜託她們去做其他事，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以她們沒辦法馬上回來。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，就是那裡。",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "首先在那個轉角向右轉──",
        "unit_id": 133712
    },
    {
        "type": "background",
        "background": "500253"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……奇怪，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這裡剛才是不是也有經過？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不──",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是不可能的！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n迷宮女王自己迷路這種事，可不是開玩笑的！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "等等喔，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們走回原路吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n目前為止走過的路線都記在我的腦中了，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n反過來前進的話應該就能回到原處……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……好奇怪。",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "絕對有問題。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "才沒有這回事！",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒想到",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我居然",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會搞錯路……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "慢著，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_040"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這面岩壁和物件配置……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如棋盤格子般整齊排列的道路……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我有印象。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣的話，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "該不會這裡也……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……果然是這樣！",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，我知道了！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不是我搞錯了──",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "錯的，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是這個世界！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，等一下！",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_043"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n抱歉，我會按順序來解釋的，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你別用一副",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「這傢伙已經神智不清了……」",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的眼神看著我啦！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "修復的資料出現問題時",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_044"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我就該預料到會變成這樣了呢……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "難怪我會有印象。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這裡",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_045"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是阿斯特朗開發途中的區域……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n是後來中止實裝的",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "特殊地下城。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似乎是在修復過去差點被還原的資料時，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n連同應該已經捨棄的開發資料都抽取出來了呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以通往據點的路好像就變成地下城了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的確，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_047"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在系統方面幾乎已經完成了……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但這裡的時間流動比較特殊，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "跟外面",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有點不太一樣。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "具體而言──",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只要玩家沒有前進一定的步數，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "時間就不會往前。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "更正確來說，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是「事件不會發生」。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "依里和鈴是不是有在玩這類遊戲？",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_049"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n像是《風來的古煉》",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "和《約魯內克大冒險》之類的。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然這個地下城顯現出來，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就表示系統中恐怕也加入了一些改變──",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，等等！",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_051"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不能隨便亂動──",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "魔物的集團",
        "words": "──咕喔喔喔喔喔！！\n──咕喔喔喔喔喔！！\n──咕喔喔喔喔喔！！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是怪物屋！",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_052"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這裡被設下了一大堆像這樣的陷阱啊！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "聽好了，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就保持這樣別動，冷靜地思考吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只要不動作，魔物應該就不會有反應……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "…………",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……好，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "決定好作戰計畫了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "準備好了嗎？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你就這樣踏出去，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "攻擊魔物看看。",
        "unit_id": 133712
    },
    {
        "type": "background",
        "background": "500253"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來如此，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對魔物造成了１點傷害啊。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "頭上會出現數字真是簡單明瞭呢！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "換我踏出一步對吧？",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "姑且也攻擊",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一下吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "果然是",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "１點傷害呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯～",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "闖入地下城時",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n好像會被強制固定在等級１啊。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯嗯。",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_060"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "果然是這樣。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們的行動回合結束了。",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n接著",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "輪到敵方的回合。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這麼一來──",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "魔物的集團",
        "words": "──咕喔喔喔喔喔！！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們就會被圍毆，然後Game Over。",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_062"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "初始等級遇上怪物屋就是個死局。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這樣的話重置是最快的。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_063"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一起咬緊牙關撐過去吧！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒事的，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果是依照系統設定，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們只會被送回「入口」！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該說，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "反正不管怎樣，在這種狀況下",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也沒救了！",
        "unit_id": 133712
    },
    {
        "type": "background",
        "background": "500253"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦──",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_064"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好痛好痛……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你沒事吧？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來體力已經恢復了呢。",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_065"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "跟設計的一樣。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且也回到起點了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也就是說，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_066"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們無論如何",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n都必須攻略這座地下城嗎……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這下麻煩了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "剛才我們往回走也行不通吧？",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這座迷宮變成了地下城，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n是與外界空間分離的另一個空間。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很遺憾，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若按照開發中的設計，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不攻略到最深處應該就沒辦法出去。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是能使用除錯指令就好了……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "果然不行啊……",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_069"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且可靠的權能也無法使用。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣的話……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是說啊。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然是這樣，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但目標本身非常單純。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要達成的目標有兩個。",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n攻略這座地下城前往據點。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "配合現行版本將始源冠裝最佳化。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只不過，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_072"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "已經好久沒有……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種感覺了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然不該這麼說，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但我的遊戲玩家之魂",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似乎有些躍躍欲試了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你是不太會接觸",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "限制條件玩法的類型嗎？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不如說，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正因為是這種狀況吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "遊戲",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_074"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一旦等級練得過高，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n大多情況都可以靠力量強行闖過。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "受到弱化的這種狀況就不能用那種方式了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正因為這樣，",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_075"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "才有必要思考。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "絞盡腦汁、",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "耗費苦心、",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "尋找最好的方法──",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是有這種唯有等級１才能體會到的樂趣",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對吧？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "簡直",
        "unit_id": 133712,
        "voice": "vo_adv_1337003_076"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就像是新遊戲，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓人興奮起來了對吧，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年！",
        "unit_id": 133712
    },
    {
