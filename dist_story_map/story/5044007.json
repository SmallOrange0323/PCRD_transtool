        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們想",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "送給流夏姐當驚喜呀☆",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "明明不需要這麼大費周章啊。",
