        "type": "dialogue",
        "name": "流夏",
        "words": "唔哇啊啊啊！？",
        "unit_id": 113111,
        "voice": "vo_adv_5044007_062"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦，",
        "unit_id": 113311,
        "voice": "vo_adv_5044007_063"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏姐！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳怎麼會在這！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那話是我要說的，",
        "unit_id": 113111,
        "voice": "vo_adv_5044007_064"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "麻煩妳們",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別突然嚇人好嗎！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n真受不了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳們不是有東西要找嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒有啦，",
        "unit_id": 113211,
        "voice": "vo_adv_5044007_065"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "應該說剛好找到了……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳說剛好找到……",
        "unit_id": 113111,
        "voice": "vo_adv_5044007_066"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是指這個",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "發光的竹子？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n妳們到底",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是為什麼要找這種東西？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個～",
        "unit_id": 113311,
        "voice": "vo_adv_5044007_067"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們是想找來送給流夏姐當禮物。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這個啊，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "似乎是一種叫作「祈願竹」",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的特別竹子。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們弄壞了釣竿，",
        "unit_id": 113211,
        "voice": "vo_adv_5044007_068"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳拿這個去做一把新的吧。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我們無論如何",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "都想為那件事賠罪……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "所以，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那個……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "對不起～！！",
        "unit_id": 1,
        "voice": "vo_adv_5044007_069"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不是說過不用介意了嗎？",
