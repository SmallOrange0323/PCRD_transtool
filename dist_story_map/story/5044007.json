        "voice": "vo_adv_5044007_075"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n也就是說，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "流夏也要加入我的",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n熾炎戰鬼煉獄血盟暗黑團是吧！",
