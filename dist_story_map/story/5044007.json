        "voice": "vo_adv_5044007_070"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難道說，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這趟度假也是為了這個……？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯。",
        "unit_id": 113311,
        "voice": "vo_adv_5044007_071"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是為了得到「祈願竹」",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "才來這裡的～",
