        "type": "dialogue",
        "name": "怜",
        "words": "真好吃。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這說不定是我至今吃過的糖果中最好吃的。",
