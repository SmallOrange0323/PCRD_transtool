        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然有點緊張，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但還是勉強說出口了呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n萬聖節快樂……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺好像變得有趣起來了。",
