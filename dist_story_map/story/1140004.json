    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不認識？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這就像打招呼一樣呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "萬聖節快樂！",
