[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在熱鬧的氛圍也已然沉寂下來的萬聖節樂園中，\n怜與{player}遠遠地望著那些正在收攤的攤販。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真讓人有點捨不得呢，",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哪怕有聽說過，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "慶典的結束總是會讓人感到寂寞。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是……",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "玩得很開心。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我有多久沒這麼樂在其中了呢，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這疲勞令人覺得心情暢快。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "夜也開始深了，",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "慶典也差不多要結束了吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這股捨不得的感覺，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該暫時不會消失吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你看，",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "月亮也高高掛起了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n月光是這麼地明亮──",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼回事？",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼覺得月亮特別地亮……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不行，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好睏……",
        "unit_id": 114011
    },
    {
        "type": "still",
        "still": "114000401"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "姐姐，",
        "unit_id": 1,
        "voice": "vo_adv_1140004_005"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不給糖就搗蛋！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃……",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是要給糖果對吧？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "給你。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "哇啊～",
        "unit_id": 1,
        "voice": "vo_adv_1140004_007"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "萬聖節快樂！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊、",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "萬聖節快樂。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n去好好享受萬聖節吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你覺得怎麼樣？",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就你來看，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的表現還算好嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你、",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你這要求",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還真難呢……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我可是第一次參加萬聖節啊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "妳好！",
        "unit_id": 1,
        "voice": "vo_adv_1140004_011"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "不給糖就搗蛋！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "不給糖就搗蛋！",
        "unit_id": 1,
        "voice": "vo_adv_1140004_012"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "如果不給糖，就要搗蛋囉！",
        "unit_id": 1,
        "voice": "vo_adv_1140004_013"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "要搗蛋囉～！",
        "unit_id": 1,
        "voice": "vo_adv_1140004_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下、",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下一批小孩子已經來了……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "更投入，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好──",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哦、",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哦哦，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是可怕的小鬼怪。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我給你們糖果，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "請放過我吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "嘿嘿，",
        "unit_id": 1,
        "voice": "vo_adv_1140004_017"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "太好了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "姐姐也萬聖節快樂！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "萬聖節快樂～！",
        "unit_id": 1,
        "voice": "vo_adv_1140004_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛、",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才那樣",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你覺得怎麼樣？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太好了……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n越來越多小孩子往這邊靠過來了！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然這樣我準備也是值得了，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但、",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但要應付不來了……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然有空在那悠哉地發表感想，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那你也來幫忙。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，真是的。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到居然會這麼忙碌……！",
        "unit_id": 100331
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──數小時前，\n熙來攘往的萬聖節鬧區。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "早知道是這樣就不來了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "之後的對應也很麻煩……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼辦才好。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好意思，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的話剛才就說完了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我和你們已經沒有什麼話好──",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哇！",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……怎、",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼，是你啊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我誤以為是他們追上來了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……嗯，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我到剛才",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都還在參加同學邀請我的派對。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n平時我的行程對不上，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因此我都只能拒絕他們。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說是什麼派對？",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是萬聖節派對……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "表面上。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我對萬聖節也有興趣，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想說去增加見識也不錯，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以才參加了，但是……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個似乎只是他們自認為的萬聖節派對。",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n徒有無聊的裝飾，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有任何玩樂和慶典的氛圍，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是將為了擴展自身人脈而算計、交涉的場合，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "套上那名稱罷了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只有表面的客套話，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "及以狡詐眼神打量他人的應酬。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他們希望親近的不是我，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而是要與我父親套關係。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是我",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "至今已經看到厭煩的場景，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我一秒也不想多留在那種地方。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……更別說，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他們不顧我的意願硬是想打聽我父親的事。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……只是想起來就讓人很不愉快，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我受夠什麼萬聖節了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "享受萬聖節……",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那提議是不錯，不過……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要做什麼？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然你看起來異常的有自信，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓我覺得有點不安……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過我知道了，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在就相信你，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不管有什麼事都交給你吧。",
        "unit_id": 100331
    },
    {
        "type": "still",
        "still": "114000401"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不對，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然我是說交給你，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但、",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但沒想到連我都要變裝……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你、",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說得沒錯，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "萬聖節就是享受變裝的慶典。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n既然要認真享受，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那按照傳統來才是對的呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且仔細一看，小孩子自然不用說，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連大人也都有變裝。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "尤其是大人的變裝更是不簡單，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "做得非常精細。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怪物、木乃伊男，",
        "unit_id": 100331,
        "voice": "vo_adv_1140004_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那邊是朋友們一起扮殭屍。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個是在電影中登場的外星人？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連那種的也可以呀。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "高品質的變裝，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是看看就很開心了呢。",
