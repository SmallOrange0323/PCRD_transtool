    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話又說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1140004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怜真是努力了呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看來和你過萬聖節讓她相當開心呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n沒想到會這麼大膽出擊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很好，做得好！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怜也是一個女孩子，",
        "unit_id": 190011,
        "voice": "vo_adv_1140004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n別因為她是大小姐就疏遠她對她有偏見，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n帶她到各種地方去也不錯啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我相信你就算不用人說出口也沒問題。",
        "unit_id": 190011,
        "voice": "vo_adv_1140004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那孩子身上背負了很多，你要幫她讓自己放輕鬆喔，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就再見囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我睡著了啊……",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "似乎還在睡夢中呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他為我",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_066"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "顧慮了不少事情呢，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再讓他稍微睡一下吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……謝謝。",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_067"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今年的萬聖節",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n多虧你，讓我有了寶貴的體驗。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你讓我",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看見了新的世界呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，都是因為那樣……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不對，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該說多虧如此、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n似乎讓我變得有點貪心了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想再發現更多未知的事物，",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_069"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我相信如果是和你一起",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就能做得到。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你、",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "居然醒著嗎！？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到底什麼時候醒的……",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_071"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才那就是我今天最驚訝的事了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那句話可是要在惡作劇之前",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_072"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "先說出來才對啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真是的……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵呵，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真拿你",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒辦法。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然我現在只有這種東西，但是……",
        "unit_id": 114011,
        "voice": "vo_adv_1140004_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "萬聖節快樂，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天很謝謝你。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人一起眺望著明月，\n並充分地享受了萬聖節的夜晚。"
    }
]