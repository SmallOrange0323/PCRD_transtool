        "voice": "vo_adv_1140004_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也不錯呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你說得沒錯，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很開心。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這麼說來，",
