    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的說～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈……",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我就在想你應該會這麼說。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你問我是不是也一樣",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個嘛……",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的動機",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有點更不單純吧～？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要怎麼說呢……",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n難得來到蘭祭玩，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我不希望他們留下",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "遇到麻煩～或是",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "遇到壞事～的回憶。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也不是說我沒有",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想幫助他們的念頭……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要說的話我比較像是想讓他們知道，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「這裡很開心喔～」",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣吧？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "簡單來說就是……",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想把他們拉進坑裡啦！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不知道你懂不懂～？",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n嘿嘿嘿……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "待在坑裡的人數越多會越開心喔～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說是這麼說啦……",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然我現在",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "除了你",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "和杏奈美眉之外，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n也跟鈴閣下、依里閣下",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "和智閣下她們",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "玩得很開心……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是之前的七七香",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跟周遭都格格不入呢～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我以前總是想著",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要鑽研宅宅之道，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "結果身邊的人",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都跟我保持距離。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後發生了很多事，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我才開始被叫做收藏家呢～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我當時並不覺得自己很倔強呢……",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當年的七七香也還很嫩啊。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "後來我發現了，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我一個人獨享這麼開心的事情，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不是太可惜了嗎！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一個人辦不到的事情，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跟大家合作就辦得到，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就像蘭祭這個活動一樣。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "大家各玩各的，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "大家全都很開心的話，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不就最棒了嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以啊，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_041"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我在這裡很開心喔～！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n大家也一起在坑裡越陷越深吧～！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會這樣",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不停地推坑！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其他人",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "平常好像都在各方面壓抑著自己呢……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你看嘛，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "像是智閣下",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不就是這樣嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在遠處看著以前的我的那些人，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_043"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會不會也是那樣壓抑自己的呢～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我現在",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不禁會這麼想……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_044"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我希望至少在這樣的地方，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n他們可以做自己啊～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當大家想要",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_045"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "鼓起勇氣的時候，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我想在他們的背後推一把。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦！？",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_046"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我嗎？",
        "unit_id": 123711
    },
    {
        "type": "still",
        "still": "123700301"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼啦～",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_047"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你這個人",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有時候",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會跟少年漫畫的主角一樣敏銳耶。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "平常明明就很遲鈍……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當我沒說當我沒說。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想要有勇氣的時候，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_048"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是嗎……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然有啊……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然我算是很隨心所欲的人，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_049"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過偶爾",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也是會覺得",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好像做得太超過了。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我偶爾",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_050"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會想起以前一個人",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "格格不入的時候",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呢……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n現在這樣",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的好嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n大家",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有樂在其中嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會想到這些。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_051"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "煩惱這些，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是很不符合",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香的人設嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我還是想要貫徹自我啊，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "作為一個宅宅。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_052"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "平常在其他人的面前，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我會盡量把這一面隱藏起來。",
        "unit_id": 123711
    },
    {
