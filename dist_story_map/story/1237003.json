    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我得",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "做點什麼當作回禮……",
