    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那麼，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你們也要玩得開心喔。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那當然！！",
