        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種為了Cosplay豁出去的幹勁，",
