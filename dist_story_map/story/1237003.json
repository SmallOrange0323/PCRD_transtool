        "voice": "vo_adv_1237003_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n嘿！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊！",
        "unit_id": 1212,
        "voice": "vo_adv_1237003_016"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "好溫暖……！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是去寒冷的地下城時會用到的魔法。",
