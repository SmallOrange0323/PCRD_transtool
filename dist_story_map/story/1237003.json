        "voice": "vo_adv_1237003_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n只要在蘭祭玩得開心就好……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "方便的話",
