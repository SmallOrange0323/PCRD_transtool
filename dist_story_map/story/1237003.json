        "voice": "vo_adv_1237003_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "各個攤位上，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n也有很多Cosplay的",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小精靈！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那些也要全部都看到喔，上吧！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喝啊啊啊──！",
