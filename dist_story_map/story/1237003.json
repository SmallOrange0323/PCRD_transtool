    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "原本預定要繼續傳授{player}蘭祭的玩法，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但七七香一直在各處解決事件和糾紛。"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這裡就是Cosplay會場嗎……",
        "unit_id": 811,
        "voice": "vo_adv_1237003_000"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "多虧有妳的幫忙我才能抵達……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "你終於來了！",
        "unit_id": 911,
        "voice": "vo_adv_1237003_001"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "真是的，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "慢死了──！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "抱歉啦！",
        "unit_id": 811,
        "voice": "vo_adv_1237003_002"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n人太多我完全找不到路……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "是你們帶他來的嗎？",
        "unit_id": 911,
        "voice": "vo_adv_1237003_003"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "謝啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒什麼沒什麼，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我只是舉手之勞……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "才不只如此呢。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟難得看到舔刀男的Cos嘛，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一定要讓你們搭檔會合才行啊。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嘿嘿，",
        "unit_id": 811,
        "voice": "vo_adv_1237003_005"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "對吧？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n抱歉占用到你們的時間。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "別在意啦。",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不說了，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你們去玩吧！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "好！",
        "unit_id": 911,
        "voice": "vo_adv_1237003_007"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那就再見啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "喂，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "走囉！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n頭帶手指虎也在那邊等我們！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "呀哈──！",
        "unit_id": 811,
        "voice": "vo_adv_1237003_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼……",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "順利帶他會合",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啦。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼厲害……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哦？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n啊，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你是在說",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "認出Cosplay的原作嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還好啦～！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才的三人組",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是巴哈姆提亞的四格漫畫的當紅角色，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那邊的是",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "Cos赤空的人！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為現在的七七香",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是經過千錘百鍊的宅宅呀～",
        "unit_id": 123711
