        "words": "\n不過……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "果然還是逃不過你的眼睛……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
