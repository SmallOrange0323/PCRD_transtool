    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以跟我",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "合照嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這樣就好了嗎？",
        "unit_id": 1212,
        "voice": "vo_adv_1237003_020"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "當然當然，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我很樂意！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好耶！",
        "unit_id": 123711,
        "voice": "vo_adv_1237003_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "拜託你幫我們拍嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "麻煩你了！",
