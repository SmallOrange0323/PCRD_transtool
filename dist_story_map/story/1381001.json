        "type": "dialogue",
        "name": "老狗頭人",
        "words": "大家都沒有受傷！",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "太好了……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_051"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "大家都平安無事。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "既然出現魔物了，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就不能悠哉地待在這裡。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n希望可以盡快",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "把水果運出去……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "把水果帶回去這件事，",
        "unit_id": 9111,
        "voice": "vo_adv_1381001_052"
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "已經拜託巨人族了。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n雖然我們",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "無法拿多少，",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n但巨人族可以輕鬆搬運",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "比我們多好幾倍的數量。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說得也是呢。",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_053"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "有如此可靠的國民，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我感到很驕傲。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好了，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_054"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "大家都在城裡等著。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "把水果帶回去吧。",
        "unit_id": 126511
    },
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士？",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_055"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你也來這邊了嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "平安",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_056"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "取得了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n多虧了大家幫忙。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "萊拉耶爾殿下，",
        "unit_id": 9111,
        "voice": "vo_adv_1381001_057"
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "請收下。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n這是要給萊拉耶爾殿下，",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "以及傳說食材搜索隊的慰勞品。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_058"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是蛋糕……？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "這是留在城裡的人製作的蛋糕。",
        "unit_id": 9111,
        "voice": "vo_adv_1381001_059"
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n這次去搜索傳說食材，",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "辛苦您了。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "還有，",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n恭喜您。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "他們所做的蛋糕",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "是帶著這樣的意涵。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "做得相當精緻呢。",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_060"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "明明應該很忙碌才對，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是感謝大家。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "剛才",
        "unit_id": 9311,
        "voice": "vo_adv_1381001_061"
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "我聽製作蛋糕的人說了。",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "\n雖然費工，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "但是正因為有大家一起分工，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "\n才能夠製作出很多份。",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "狗頭人族烤蛋糕，",
        "unit_id": 9311,
        "voice": "vo_adv_1381001_062"
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "貓妖精打發奶油，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "\n巨人族去採放在上面的水果，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "\n半身人做最後收尾……",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "聽說是這樣。",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "原來是這樣呀。",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_063"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n眾人齊心協力",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "完成了這些事……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……是啊。",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_064"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士也請用。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我們一起",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "享用大家的心意吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真的。",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_065"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這多種風味的和諧，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "正是大家心意的結晶呢……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "雖然蛋糕可以一個人製作，",
        "unit_id": 9111,
        "voice": "vo_adv_1381001_066"
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n但也能夠大家一起製作。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n不需要一個人",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "包辦所有事情喔，",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "萊拉耶爾殿下。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……是啊。",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_067"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說得沒錯。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不管是尋找，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還是製作，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "都不需要獨自承擔……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "各位",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "讓我學到了很重要的事。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "感謝你們",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_068"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "和我一起尋找傳說食材。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也感謝",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_069"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "留在城裡的人們，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "負責警備",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "和烹調準備，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n而且還為我們",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "製作了蛋糕。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在不安的情緒中，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_070"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "各自做到自己能做的事……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "跨越立場給我建議，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n跨越種族",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "來幫助我……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "各位",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_071"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "所做的這一切，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "令我感到",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "非常高興。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，平安取得傳說食材的萊拉耶爾，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和城裡的廚師們聯手開始烹調。"
    }
]