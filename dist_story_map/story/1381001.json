[
    {
        "type": "background",
        "background": "502040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾國際博覽會因為「六凶」梅莉莎而陷入一片混亂。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了處理此事，萊拉耶爾暫時回到吉歐‧提格尼亞，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隨後便獨自離開城堡去尋找傳說食材。"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "各位，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還有克蘿茜──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請等等我。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我一定",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會拯救大家的……！",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "為了和獄蜂戰鬥，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以及拯救被當成人質的人們，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我必須獲得",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吉歐‧提格尼亞的傳說食材才行……！",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……至今為止，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我還沒有獨自一人",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "去尋找食材過。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n總是會有人",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "陪在我身邊。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "然而……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "烏爾姆還沒醒過來，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "琳德正在照顧她……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n實在不能",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "讓她陪我出來。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……烏爾姆……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_006"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這可不行。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n不小心",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就沮喪起來了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n明明大家",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "都在各自奮戰著……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "傳說食材……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_007"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "「彩虹蜜糖果實」，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n雖然知道就在這座森林裡……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "光從空中俯瞰，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也十分廣闊呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "根據書籍記載，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_008"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那是長在",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這座森林某處的樹上。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "線索只有這些……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣的話，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "果然應該把城裡的人帶來，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n用人海戰術嗎……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_009"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣就好了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "城裡需要警備，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n能飛的人也不多。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而且，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "帶著食材回去後，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n為了能馬上開始料理，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也需要讓他們先準備好。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "最重要的是，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_010"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我是這個國家的公主。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n情況緊急，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而且可能有危險的話，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n就該由我來行動。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在尋找食材的途中，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_011"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說不定會遭到獄蜂襲擊。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n雖然不覺得",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "獨自行動是最佳選擇，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但到了緊要關頭，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我也無法保證能夠保護同行者。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "實際上，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_012"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在蘭德索爾時就被用人質威脅……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n使得行動受到限制。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_013"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "所以，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒問題的。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n單獨行動這件事",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "一定沒有錯，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "應該……",
        "unit_id": 126511
    },
    {
        "type": "background",
        "background": "501770"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呼……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不愧是傳說食材，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n果然沒那麼容易找到呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "因為從空中看也沒有進展，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就下來地面看看了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_015"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過真是令人著急呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我完全不知道，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要如何有效率地尋找東西。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n深切體會到",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "自己的無力……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_016"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n找不到的話，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就一直搜尋到找到為止……！",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_017"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "話雖如此，",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_018"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這座森林這麼廣闊──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n只靠我一人，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不知道得花多少上多久。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n明明時間有限……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "您不是一個人喔，",
        "unit_id": 9111,
        "voice": "vo_adv_1381001_019"
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "萊拉耶爾殿下～！",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "呼、",
        "unit_id": 9311,
        "voice": "vo_adv_1381001_020"
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "呼，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "終於追上了……",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你們……！",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_021"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n來這裡做什麼……！？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "當然是",
        "unit_id": 9111,
        "voice": "vo_adv_1381001_022"
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "來幫助萊拉耶爾殿下的。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "嗅",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "嗅……",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "水果的味道……",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "雖然不知道是什麼水果，",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "老狗頭人",
        "words": "\n但是有香氣從這裡傳來！",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "好了，我們走吧，",
        "unit_id": 9311,
        "voice": "vo_adv_1381001_023"
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "萊拉耶爾殿下。",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "\n城裡的警備以及烹調準備都有好好在進行，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "請您放心。",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "\n在這裡的，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "女半身人",
        "words": "都是有空檔的人。",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "很感謝",
        "unit_id": 126511,
        "voice": "vo_adv_1381001_024"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你們的協助。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n但是，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不知道什麼時候會被捲入危險之中。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n趕快回去城裡吧。",
