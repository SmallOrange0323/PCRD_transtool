        "voice": "vo_adv_5044431_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "今天就是度假的最後一天了啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我總覺得才剛來沒多久呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔唔唔，",
        "unit_id": 100911,
        "voice": "vo_adv_5044431_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這不是還有很多事沒完成嗎！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們還沒探查完",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沉睡在這片土地上的傳說啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳在說什麼啊杏奈美眉，",
        "unit_id": 101311,
        "voice": "vo_adv_5044431_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明年再來一次就好啦。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們也和織女約定好要再見面了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……",
        "unit_id": 100911,
        "voice": "vo_adv_5044431_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "確實，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "七七香說的沒錯。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那就沒辦法了，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "尋找傳說的事",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還是留到下次吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在回去之前一定要去逛街買東西啦！",
        "unit_id": 101311,
        "voice": "vo_adv_5044431_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要是不帶禮物回去給深月和惠理子大人，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "她們絕對會生氣的～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 105611,
        "voice": "vo_adv_5044431_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "最後就盡情地玩吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你是不是也",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還有一些想做的事？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就和我們一起，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "享受這假期直到深夜為止吧！",
        "unit_id": 105611
    }
