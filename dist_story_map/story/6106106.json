[
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "接客というのは、",
        "unit_id": 105312,
        "voice": "vo_adv_6106106_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "軍人の職務に負けず劣らず過酷なものだな。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "常に笑顔を浮かべていると、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "だんだん頬が引きつってしまうし、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n立ちっぱなしでは足も痛む……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "むむむ、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "どうしたものか。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "猫を……",
        "unit_id": 105312,
        "voice": "vo_adv_6106106_001"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "吸う？　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なにを言っているのだ。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n猫は液体だから？　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ま、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ますます意味が分からんぞ！？",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n後ほどタマキにも聞いてみるか……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "噓だったら承知しないぞ、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "き、",
        "unit_id": 105312,
        "voice": "vo_adv_6106106_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公がか？　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そのような技能があったとは初耳だが……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "──お、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "おおっ？　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "これは、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なかなか……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "んっ、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "心地がいいな。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n手から伝わる体温が、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ほどよく眠気を誘って……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ぐぅ……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そ、",
        "unit_id": 105312,
        "voice": "vo_adv_6106106_003"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そうか……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "私がこれほど疲労しているのだ。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nほかの者たちはさらに消耗しているに違いないものな。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "互いを労り、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "気遣う……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "大切なことだ。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公もつらいときは言うのだぞ！",
        "unit_id": 105312
    }
]