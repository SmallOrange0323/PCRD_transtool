[
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂、",
        "unit_id": 125014,
        "voice": "vo_adv_5110301_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "鎮、",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "鎮上有魔物出沒！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這到底是怎麼回事啊……",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是等城鎮的戒備變弱之後才闖進來的吧……？",
        "unit_id": 124811,
        "voice": "vo_adv_5110301_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為鎮上的人們",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都已經變成樂園的居民了……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，",
        "unit_id": 124911,
        "voice": "vo_adv_5110301_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我認為它們跟野生魔物不太一樣。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "給人一種詭異討厭的感覺……",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是啊，",
        "unit_id": 125014,
        "voice": "vo_adv_5110301_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也這麼認為！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說回來，那傢伙",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是不是盯上我們了？",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看來是這樣。",
        "unit_id": 124811,
        "voice": "vo_adv_5110301_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明我們什麼都還沒有做……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "該不會是我身為偶像的氣場吸引到魔物了吧？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哎呀。",
        "unit_id": 124911,
        "voice": "vo_adv_5110301_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在這種狀況下還能開玩笑，真是了不起。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總之，就由我來打頭陣吧。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我去看看它是哪種類型的魔物！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "竟敢大搖大擺地出現在我面前，我絕對會讓你後悔莫及的！",
        "unit_id": 124911,
        "voice": "vo_adv_5110301_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝啊──！！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她這麼說，",
        "unit_id": 124811,
        "voice": "vo_adv_5110301_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應該大概只是想快點打場架而已吧？　",
        "unit_id": 124811
    }
]