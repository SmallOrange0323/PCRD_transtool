[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在迎接新年的蘭德索爾，\n{player}走在路上，四處張望時遇上了怜。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗨，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是你啊。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然已經說過很多次了，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過還是再一次。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "祝你新年快樂。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但現在不是打招呼的時候了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好意思。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為我在趕時間，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下次再慢慢跟你聊──",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是別人在找我。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我剛從老家的宴會裡逃出來呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我在各大名門貴族眼裡看起來，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是很吸引他們的招牌。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要應付來來去去，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還一臉假惺惺笑著的那些人，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的很讓人困擾。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "光是昨天就見過太多人，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "身體撐不住之前，精神方面就先投降了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然我不像日和那樣，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但也已經精疲力盡了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是換成你待在那種地方，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n肯定也會跟我一樣想逃出來的……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然有點突然，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但陪我躲一下吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n現在",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我正要去我們的公會小屋。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就這麼決定了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "移動時盡量別引人注意吧。",
        "unit_id": 108911
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有人在……",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣回老家幫忙，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和在忙動物苑的事。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來這裡沒有遇到她們兩人，真是久違了……",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "平常總是很熱鬧的……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明逃出了吵鬧的地方，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n來到這裡卻因為沒有人而感到寂寞……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也真奇怪呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……可以",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "坐你旁邊嗎。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……果然這裡能讓人安心呢。",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總算能夠放鬆了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "老家總是讓我精神緊繃，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "幾乎就要窒息了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n什麼達官顯貴一個又一個不斷上門，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還要聽他們長篇大論……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從死板的問候開場，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "披著過剩謙虛的傲慢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "完全沒真實感的吹捧，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就一直被迫聽著這些交談。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "表面上裝得謙遜，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n背地裡卻計畫著如何把對方從現在的位置上扯下來……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "貴族什麼的，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過是遠比魔物低劣的",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一群魑魅魍魎啊。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而一想到我也是",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那些傢伙的其中之一……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的話說完了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "換我聽你說吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "昨天你在做些什麼？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟優衣去搗麻糬嗎……",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像很好玩。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一聽到食物的話題，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "肚子就餓起來了……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "新年的料理，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該還有剩吧……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我去廚房看看。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真羨慕優衣呢。",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是我跟他一起，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n過著這種平穩日常的話──",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……？",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "請問是哪位？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不好意思，",
        "unit_id": 1,
        "voice": "vo_adv_1089001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是來委託事情的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正值新年的跑來委託，",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該是有什麼大麻煩……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "外面很冷，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "準備個紅茶招待吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你啊。",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好意思，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能幫我帶委託人進來嗎？",
        "unit_id": 108911
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "衝進去！",
        "unit_id": 1211,
        "voice": "vo_adv_1089001_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼！？",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_026"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "發現目標！",
        "unit_id": 1111,
        "voice": "vo_adv_1089001_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是追兵！？",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個人竟然做到這種地步！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太大意了──！！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "抓起來！",
        "unit_id": 1211,
        "voice": "vo_adv_1089001_029"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "喝！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗚！糟糕……！",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_030"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "抓到目標。",
        "unit_id": 1111,
        "voice": "vo_adv_1089001_031"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "立刻撤離。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "怜小姐。",
        "unit_id": 1111,
        "voice": "vo_adv_1089001_032"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "請原諒我的無禮。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "老爺正在找您，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "我們會就這樣直接帶您回宅邸。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放開我！",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不要回去！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "真是可惜，",
        "unit_id": 1111,
        "voice": "vo_adv_1089001_034"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "您是不可能解除這魔法的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "您的朋友剛才也中了魔法，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "應該暫時不能行動了吧。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "父親那傢伙……！",
        "unit_id": 108911,
        "voice": "vo_adv_1089001_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "竟敢對我的夥伴……！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
