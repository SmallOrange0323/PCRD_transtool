[
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們應該",
        "unit_id": 123511,
        "voice": "vo_adv_5102203_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是打倒了才對，可是……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該怎麼說，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺好像沒有什麼真實感……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "……剛剛那一戰，",
        "unit_id": 16711,
        "voice": "vo_adv_5102203_001"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我已經大致掌握你們的實力了。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……她好像一點傷也沒有耶。",
        "unit_id": 123711,
        "voice": "vo_adv_5102203_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我明白了……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可見剛剛那一戰她並沒有拿出真本事。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "因為我想為觀眾帶來一點刺激感。",
        "unit_id": 16711,
        "voice": "vo_adv_5102203_003"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n如果我輕鬆獲勝，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "看起來也會很無趣不是嗎？",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "好了，",
        "unit_id": 16711,
        "voice": "vo_adv_5102203_004"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "現在這個階段",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "就吊吊粉絲們的胃口吧。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n我要暫時",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "先撤退了。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "等等！",
        "unit_id": 123611,
        "voice": "vo_adv_5102203_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……唔，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "被她逃掉了嗎！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……我懶得追上去──",
        "unit_id": 123511,
        "voice": "vo_adv_5102203_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "現在好像不適合這麼說呢。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒辦法了，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們走吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "趕快讓這種事",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "劃下句點吧。",
        "unit_id": 123511
    }
]