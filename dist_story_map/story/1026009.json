[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊麗莎白牧場的午後如往常一樣恬靜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n卻出現了難得一見的光景。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這裡的柵欄",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也沒有壞。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "牛群也跟平時一樣。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那接著就到西邊的區域看一下吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉～",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在這麼寬廣的地方做警備工作",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真辛苦耶。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在工作的松鼠，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "連貓咪的手都想借來用了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喵特要是到處走，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來牧場的人會嚇到吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "讓喵特和小栞休息，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就連他們的份一起努力吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇！？",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼時候出現的？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在的話早點說啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n嚇我一跳。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還有說這是夢是怎樣啊？",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太失禮了吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這毫無疑問就是現實喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要我捏你的臉頰看看嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀算了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你是又來送信嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n每次都辛苦你了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我幫忙把大家的份也收下吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不是？",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那你是為了什麼事……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是受到【哞哞自衛隊】的委託？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該不會",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "又要傳喚我吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我有確實訓練了啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n十年內都不該再被傳喚才對！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "他們要你來確認我有沒有好好在工作是吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣啊這樣啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那就沒有任何問題了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如你所見，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我很認真地在做警備工作喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我已經改過自新了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "從今以後我會認真拚命地，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為【哞哞自衛隊】與",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "【伊麗莎白牧場】工作的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……欸？",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才剛被傳喚過一陣子",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就找你來幫忙，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像不太好吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該說我應該要獨自加油呢，",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n或者說即使不監視我，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我在工作上也能獨當一面呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那、",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那只是比喻而已啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "別在意別在意。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是、",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是那樣沒錯啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但這也要看時間和場合吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉唉～",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀算了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那我就感激地接受你的幫助囉。",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這附近",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是莉瑪平時伐木的地方，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以沒問題吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要再走更深一點才能知道情況。",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對獸人以外的人來說是比較險峻的路，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你跟得上嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說來你平時走的距離",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是我的幾百倍，所以算不了什麼吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我不會爬到樹上的，因此安心跟過來吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "…………",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "從這一帶開始就變危險了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n得告訴真陽說，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "若是會經過這附近，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就要再稍微加強南側的柵欄才行。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好，",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那就繼續前往下個地方吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這附近是……",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有被破壞的樣子呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n太好了太好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這裡要是變危險的話，會很困擾呢～",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸？",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不是，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這該怎麼說呢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有一些只有專家才能察覺的趨勢之類的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是說那種感覺喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "外行人可能不懂，",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但這種事",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也是有的喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "下一處～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有問題。",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "下一處～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔……",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這裡……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為最近才來過嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "下一處～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喔～！",
        "unit_id": 102611,
        "voice": "vo_adv_1026009_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這可真是！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
