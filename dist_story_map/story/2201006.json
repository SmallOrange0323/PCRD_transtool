    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}等人接下冒險新手公會【幻變少女】的委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和她們一起闖進了「世界背面」。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人在那裡遇見的第一個人是──"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你們好呀～♪",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "叫做克蘿茜！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你們叫什麼名字呀？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈☆",
        "unit_id": 105812,
        "voice": "vo_adv_2201006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貪吃佩可！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "感謝您",
        "unit_id": 125812,
        "voice": "vo_adv_2201006_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "親切地為我們自我介紹，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "克蘿茜小姐。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我是",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "【幻變少女】的成員，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "名叫莉莉。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我是同公會的",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可璃亞。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n請多多指教♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "我叫",
        "unit_id": 126112,
        "voice": "vo_adv_2201006_006"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n普蕾西亞。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是主人的隨從，",
        "unit_id": 105913,
        "voice": "vo_adv_2201006_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "叫做可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n方才",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您似乎出手幫助了主人脫離險境，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "著實感激不盡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不用客氣啦♪",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n你們看起來都沒有受傷，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真是太好了。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "看到各位從天上掉下來時，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我真是嚇了一大跳呀～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也是",
        "unit_id": 105913,
        "voice": "vo_adv_2201006_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感到相當驚奇。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "未料",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "地底",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟會連結至這樣的場所……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "畢竟我們照理說是在往洞窟下層",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "前進呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "中途",
        "unit_id": 125812,
        "voice": "vo_adv_2201006_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "通過了一個像是奇妙通道的空間……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "等到",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "回過神來，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們就全都被扔到半空中了。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哦～",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來發生了這樣的事呀～",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那還真是辛苦各位了。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我說你們啊。",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在陌生的地方",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "面對初次見面的對象，未免也太鬆懈了吧──",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原本是想這樣吐槽啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "？？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但怎麼說……",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得警戒這傢伙也是白費功夫啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "凱留小姐？",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳叫克蘿茜",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我保險起見還是問一下，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳應該",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有打算把我們給趕回去之類的吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦！？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我不會做那種事啦～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "各位也一樣",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "沒有要襲擊我的打算對吧？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "沒問題。",
        "unit_id": 126112,
        "voice": "vo_adv_2201006_019"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n不會襲擊妳。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯！",
        "unit_id": 105812,
        "voice": "vo_adv_2201006_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是來找尋美味的食物而已！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原、",
        "unit_id": 125812,
        "voice": "vo_adv_2201006_021"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來我的們目的是這樣嗎……？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來如此！",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n那真是太好了♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這種悠哉悠哉的感覺，",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "簡直就像多了一個白癡佩可一樣，頭好痛……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉～",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘿",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咻。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我要休息一會～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "我也要。",
        "unit_id": 126112,
        "voice": "vo_adv_2201006_025"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n躺。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請稍待片刻，",
        "unit_id": 105913,
        "voice": "vo_adv_2201006_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "普蕾西亞小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下記得行李中應該有",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能提升恢復能力的藥水……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚噁。",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那東西很苦，我一點也不想喝啊～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且又很貴。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰叫用光魔力的魔法師根本派不上場呢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔～",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有夠難喝。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……普蕾西亞，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳要喝嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "（……搖頭）",
        "unit_id": 126112,
        "voice": "vo_adv_2201006_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們在來到這裡的路上",
        "unit_id": 105812,
        "voice": "vo_adv_2201006_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "遭遇了一大堆魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n數量甚至多到小凱留都被榨乾了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這附近看起來就挺和平的──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們一開始就能夠遇見",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_031"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "像克蘿茜小姐這樣的好人，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n真的是非常幸運呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "如果不介意的話，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "希望我們可以交個朋友……♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇～！",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n當然當然，我很樂意，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "來交朋友吧♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "太好了♪",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_033"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n呵呵，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那要不要",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "來握個手呢？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是說要抱抱？",
        "unit_id": 105812,
        "voice": "vo_adv_2201006_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留最喜歡抱抱了喔～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳這說法會被誤會啦，白癡佩可……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_036"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對不起！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "跟我握手或抱抱，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可能有點危險唷～",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "該說是我體內力量太多嗎，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "總之我超級不會控制力道啦。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦，",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_037"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這樣呀？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對呀。",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以所以……",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "很抱歉我沒辦法給妳抱抱喔，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "凱留～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是可惜呢，",
        "unit_id": 105812,
        "voice": "vo_adv_2201006_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼搞得好像是我被甩掉一樣啊～！",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……從方才開始，",
        "unit_id": 105913,
        "voice": "vo_adv_2201006_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就對一件事感到相當在意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n關於克蘿茜小姐的手和身體，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這真的是很巨大的拳套呢。",
        "unit_id": 125812,
        "voice": "vo_adv_2201006_042"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也難怪克蘿茜小姐會說自己力氣很大呀。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉，",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_043"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我想應該不是那樣……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是在說我的身體嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "實不相瞞！",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_045"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我在「吉歐‧提格尼亞」這裡也算是挺稀有的",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n機械人族喔～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "機械人族？",
        "unit_id": 1,
        "voice": "vo_adv_2201006_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿、莉莉",
        "words": "吉歐‧提格尼亞……？",
        "unit_id": 1,
        "voice": "vo_adv_2201006_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哎呀呀？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n你們那邊沒有像我這樣的種族嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n在各位的……",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "呃，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "天空上的世界？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是沒有呢。",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "更何況話說回來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們不是從什麼天空世界來的啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2201006_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管在阿斯特賴亞大陸，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實也存在著會說話的魔像……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊哈哈。",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我不是魔像啦～",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "……等等？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_052"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不過，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我和魔像或許有些相近呢。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n畢竟我不需要吃飯，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n也很喜歡服侍主人，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "也不會流血……",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真是怪了？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_053"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "搞不好，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "其實我是跟魔像差不多的存在呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊哈哈♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還啊哈哈咧，",
        "unit_id": 106012,
        "voice": "vo_adv_2201006_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這人啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對不起，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_055"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我是不太會煩惱的個性啦。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然要說的話，我也不太會感到傷心或憤怒就是了。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "泰然自若……",
        "unit_id": 125812,
        "voice": "vo_adv_2201006_056"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "應該說是從容自在吧。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我認為這樣的處世態度非常棒喔。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且……",
        "unit_id": 105913,
        "voice": "vo_adv_2201006_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛才您提到了",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「吉歐‧提格尼亞」，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是克蘿茜小姐所在國家的名字嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對呀～",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但比起國家比較像是世界？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "應該吧？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "順道一提，我們現在位於「吉歐‧提格尼亞」的",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n阿帕雷尤街道西側附近。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「吉歐‧提格尼亞」",
        "unit_id": 125812,
        "voice": "vo_adv_2201006_059"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "嗎。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這裡感覺很溫暖",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "且風光明媚……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "似乎是非常適合居住的",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "美好地方呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "第一眼望去，",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_060"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "給人一種氣氛悠閒的觀光勝地的印象。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……要是我家的奶奶",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也有一起來就好了……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_061"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "謝謝誇獎♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n聽到自己住的地方被稱讚，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "挺開心的呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "所以，",
        "unit_id": 126112,
        "voice": "vo_adv_2201006_062"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n克蘿茜，",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "也很悠閒？",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許克蘿茜小姐如此從容大方的個性，",
        "unit_id": 105913,
        "voice": "vo_adv_2201006_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n便是受「吉歐‧提格尼亞」此地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n的風土民情",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "影響而成的呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來如此，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_065"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "或許真的有可能呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可是可是～",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n最近",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "發生了一些",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n讓我感到有些困擾的事──",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼事呢？",
        "unit_id": 105812,
        "voice": "vo_adv_2201006_067"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……",
        "unit_id": 126112,
        "voice": "vo_adv_2201006_068"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "魔物。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_069"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普蕾西亞，",
        "unit_id": 126012,
        "voice": "vo_adv_2201006_070"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是哪個方向？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯──",
        "unit_id": 126112,
        "voice": "vo_adv_2201006_071"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "上面。",
        "unit_id": 126112,
        "voice": "vo_adv_2201006_072"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚呃呃！？",
        "unit_id": 106011,
        "voice": "vo_adv_2201006_073"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n搞什麼呀，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這些傢伙不是阿斯特朗的魔物嗎！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 105911,
        "voice": "vo_adv_2201006_074"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "天空中",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎出現了另外一個洞口，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n與我們來到此地時所通過的不同……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物就是從那裡掉出來的囉！",
        "unit_id": 105811,
        "voice": "vo_adv_2201006_075"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸，等等……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那個～",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_076"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "新來的各位，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你們好呀～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "克蘿茜小姐！？",
        "unit_id": 125813,
        "voice": "vo_adv_2201006_077"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您這樣毫無戒備地",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "接近魔物是很危險的呀……！",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_078"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n但是這幾位",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不是你們的朋友嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能是啦──！",
        "unit_id": 106011,
        "voice": "vo_adv_2201006_079"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我說妳呀，個性再怎麼從容大方也要有個限度啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來不是嗎？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_080"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不過，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "搞不好只要試著聊聊，就可以溝通──",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "呀啊！？",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_081"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "危險！",
        "unit_id": 126013,
        "voice": "vo_adv_2201006_082"
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……啊……",
        "unit_id": 126013,
        "voice": "vo_adv_2201006_083"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原本打算襲擊克蘿茜小姐的魔物，",
        "unit_id": 125813,
        "voice": "vo_adv_2201006_084"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n宛如陀螺被彈開般，飛到遠方去了……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對不起喔～！",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_085"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_086"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我老是忍不住就會想道歉。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不過不過！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "既然你們是「愛搗蛋的魔物」的話，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_087"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我身為萊拉耶爾殿下的騎士，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就要確實",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "打倒你們！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她一個人上去打會寡不敵眾的！",
        "unit_id": 106011,
        "voice": "vo_adv_2201006_088"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "辦法了……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_2201006_089"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您還可以嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然沒恢復多少，",
        "unit_id": 106011,
        "voice": "vo_adv_2201006_090"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但也只能硬著頭皮上場啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們用快攻徹底擊潰它們吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻煩莉莉妳們",
        "unit_id": 105811,
        "voice": "vo_adv_2201006_091"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n幫忙保護好{player}了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們這就來助您一臂之力，",
        "unit_id": 105911,
        "voice": "vo_adv_2201006_092"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克蘿茜小姐！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇，",
        "unit_id": 126411,
        "voice": "vo_adv_2201006_093"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "謝謝你們♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我也會加油的～！",
        "unit_id": 126411
