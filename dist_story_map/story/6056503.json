[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "諾維姆這人橫衝直撞，",
        "unit_id": 107011,
        "voice": "vo_adv_6056503_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "個性有些膽大妄為。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了防止她太亂來而做出什麼荒唐事，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n希望你也能夠幫忙留意她。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很好，",
        "unit_id": 107011,
        "voice": "vo_adv_6056503_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你願意協助，也算是幫了我一個忙。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n諾維姆很信任你，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n應該會聽進你的意見。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但希望你自己也別太過亂來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……因為對我來說，",
        "unit_id": 107011,
        "voice": "vo_adv_6056503_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "諾維姆很有可能是不可或缺之人。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這只是基於利用價值而下的判斷，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而不是你所想的那樣……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那笑容",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是什麼意思？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我已經說了並不是。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "絕不是你所想的那樣。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的，",
        "unit_id": 107011,
        "voice": "vo_adv_6056503_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她並沒有脆弱到一個人就一事無成。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "偶爾還是會需要他人協助。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "目前她少了那個懶洋洋的搭檔，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n希望你能暫代協助者的位置。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "麻煩你了。",
        "unit_id": 107011
    }
]