[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "喔，",
        "unit_id": 126311,
        "voice": "vo_adv_5120064_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不曉得為什麼，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的美……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "和我們是不同層次的呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n感覺是擁有特別功能的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "洗鍊之美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "獨一無二的功能美……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哼嗯，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得挺有趣的喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊不過，",
        "unit_id": 126311,
        "voice": "vo_adv_5120064_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她整身都是紅色的，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "去試試看別的顏色",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n應該也不錯吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有時候",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也需要能夠大膽地",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "接受新顏色的勇氣喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "靜流小姐她",
        "unit_id": 126311,
        "voice": "vo_adv_5120064_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "即使是在我眼中也是渾身都散發著美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她那身服裝的清純感自然不用說，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而且不時能在她背後看到天使的翅膀。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更重要的是，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她總是會有意識地讓自己看起來很美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……不過，",
        "unit_id": 126311,
        "voice": "vo_adv_5120064_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她對美的意識",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "全都只針對一個人呢，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我認為這是很可惜的地方。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只想讓一個人覺得自己美麗的這種情感，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n是我所難以理解的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不曉得我是否有一天也會明白那種情感呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "璃乃小姐的美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120064_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是為了實現夢想",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而全心全意努力的態度吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的志向似乎是成為服裝設計師，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "待她磨練技術，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓夢想",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n成真時，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或許能請她幫我製作服裝呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過在那之前，",
        "unit_id": 126311,
        "voice": "vo_adv_5120064_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她應該先學習各種知識比較好吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有時候她說的話，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很難只聽一次就理解呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n雖然會讓人感覺有種不可思議的力量就是了。",
        "unit_id": 126311
    }
]