        "name": "靜流",
        "words": "真的嗎！？",
        "unit_id": 104932,
        "voice": "vo_adv_1049011_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐的愛",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果然勝過所有藥呢♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊！",
        "unit_id": 104932,
        "voice": "vo_adv_1049011_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那再多親幾下，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "搞不好效果會更好呢！",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐的愛是即效性的～♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 104932,
        "voice": "vo_adv_1049011_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "已經夠了？",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為什麼～！？",
        "unit_id": 104932
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呼。",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛還真是驚險呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我強制讓你睡著，",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓你稍微梳理一下記憶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次你之所以會身體不舒服，",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是因為你的記憶受到過度的刺激。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你太想嘗試回想起\n靜流口中的「從前的弟弟」，",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給大腦和身體造成負擔了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，就像以往那樣。",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你很快就會忘記在這裡發生過的事情。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n包含這次",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "帶來負擔的記憶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這麼一來，你身體方面的不適就會舒緩了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次或許是靜流的行動太過草率了。",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她太急著採取行動了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過……",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也沒有辦法",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "譴責她的行為。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想奪回失去的東西，",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n任誰都會有這種想法──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就連我也一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "靜流",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n想必是得消沉一段時間了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該做什麼才好，",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你應該很明白吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "吶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她最寶貝的弟弟。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我能說的也只有這些了。",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "睡一整天也很無聊吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "快點醒過來吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1049011_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜拜。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n保重啊",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "。",
        "unit_id": 190011
    },
