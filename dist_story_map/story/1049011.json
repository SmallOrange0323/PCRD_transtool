    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇啊！",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_050"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n糟糕，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我睡著了……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "總覺得",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_051"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "作了一個很令人懷念的夢……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我完全想不起來。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "先不說這個了，",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_052"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_053"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太好了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你退燒了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n呼吸也和平時一樣平穩，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好像穩定多了……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚～",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_054"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我終於能放心了……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實很不安的呀～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哎呀，",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_055"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他還在睡覺，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我要小心不要吵醒他了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多麼幸福的睡臉呀～♪",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_056"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "永遠都看不膩呢♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……可是。",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_057"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我這樣",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_058"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是不行的吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對不起。",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_059"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是我害你",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這麼難受的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n居然讓重要的弟弟這麼痛苦，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我根本沒資格",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "當姐姐。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_060"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要走了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然沒辦法待在你的身邊，",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_061"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但我會一直守著你的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你一定要",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_062"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "健健康康的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不能因為姐姐不在了",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就偷哭喔？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……嘿嘿。",
        "unit_id": 104911,
        "voice": "vo_adv_1049011_063"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會哭的",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該是姐姐吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "──再見了，",
