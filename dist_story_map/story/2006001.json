[
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那，我出門囉。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "路上小心，大小姐～！",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請您",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一定要小心……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會小心的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n現在情況尚不明朗，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要是大意的話很有可能會送命的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟聽說山裡",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "發生了神秘的爆炸呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n而且，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "似乎還造成了史上罕見的大規模災害……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "到底",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "發生了什麼事呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不曉得。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話說",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就是為了調查這件事才出門的哦。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500154"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "發生大爆炸的",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那座山附近……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還有我打算讓孩子們疏散去避難的",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【伊麗莎白牧場】在呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}說",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要先去打個招呼，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但去了牧場以後",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就沒有回來了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真令人擔心。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n希望那傢伙",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒有被捲入那場爆炸就好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是啊。",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然情報錯綜複雜不太清楚實際狀況，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但牧場似乎已經整個毀滅了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這麼一來，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n疏散工作更是難上加難了呢。",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話雖如此，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們原本也打算去麻煩她們的……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n置之不理的話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有違人之常情呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我打算盡自己所能地救助她們，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n並且協助",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "牧場的重建唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "首先就從前往當地，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n確認現在的狀況開始吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是知道些什麼的話我會和妳連絡，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以通訊魔法要隨時保持聯繫哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我明白了～。",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n應該",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有問題。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然通訊魔法很困難我也並不擅長，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是我至少能",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n隨時隨地確認大小姐的狀況。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "【哞哞自衛隊】似乎也行動起來了，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她們會和我一起做好準備支援您的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然已經再三地",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n說過好多次了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還是請您務必要小心。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為這次受到波及的那個牧場，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是【哞哞自衛隊】的真步",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n介紹給我們的疏散地點呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "似乎對此感到有些虧欠，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因此很積極地協助我們呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無論是什麼樣的關係都得好好珍惜呢，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這世上有情的人還是很多的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "除了【哞哞自衛隊】以外，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我的舊識所屬的公會似乎也準備協助我們。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n您說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n舊識是嗎……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是【墨丘利財團】的",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n鈴莓，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳應該也有見過她吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就是那位很華麗的人對吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她是大小姐",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "從小就認識的朋友對吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們才不是朋友呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是她單方面隨便就纏上來而已。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在派對之類的場合中，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也沒有什麼同年齡的孩子……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以才像這樣一直玩在一起而已呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n秋乃小姐也建立了公會了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "叫墨丘利……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是什麼去了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "叫做【墨丘利財團】哦。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n好像是她的雙親，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為了讓她累積社會經驗，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n才強迫她加入那個公會的樣子呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然名稱裡有個財團這種很嚴謹的詞彙，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但規模上來說也就是個中小企業的大小吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "似乎是以金融業為基礎，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n涉獵許多生意買賣的樣子呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我經常能在早市的競標上",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看見她呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n她有幾個能力不錯的成員，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n的確是個不容小覷、很會做生意的公會哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃她，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n似乎也很樂在其中的樣子呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣子啊～",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果是秋乃小姐所屬的公會的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就能放心了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為她是位",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n既善良又純粹的人呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我雖然同意妳說的這點，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那她那樣可說是老實過頭呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂～！",
        "unit_id": 1,
        "voice": "vo_adv_2006001_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是不是有人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在說我的壞話啊……！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚呀？",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n發發發、發生什麼事了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n剛、剛才，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有個很大的聲音對吧！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "剛才的聲音……",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還真是說人人到呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是秋乃哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是怎麼感覺，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n聲音是從上面傳來的啊？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n她人",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在哪裡呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "您有沒有聽到種奇妙的聲音？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是風聲嗎……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像也不是，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會是什麼呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲～戀～啊～！",
        "unit_id": 103211,
        "voice": "vo_adv_2006001_042"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "快點出來啦，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n妳不是趕時間嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "身為妳摯友的我，",
        "unit_id": 103211,
        "voice": "vo_adv_2006001_043"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n特地準備了交通工具，還來這裡迎接妳哦～☆",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "交通工具……？",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳準備了一輛\n高速馬車之類的嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就秋乃來說還真是貼心呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n已經這麼晚了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還要徒步上山真的很辛苦，真是幫大忙了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，鈴莓。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n她來接我了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以我要出發囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【咲戀育幼院】的一切，",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就暫時交給妳打點了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n麻煩妳看家囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的。",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這裡就交給我吧，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為『闇影』的威脅尚未消失，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以孩子們對此好像還有點害怕。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但【哞哞自衛隊】也加強了巡邏，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想應該不要緊的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且「闇影」也沒有那麼強，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_051"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n只要小心應對，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "照理說就不會有問題。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比起這些事您還是快點出發吧，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_052"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要是讓秋乃小姐久等的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她會鬧彆扭的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也是～。",
        "unit_id": 102811,
        "voice": "vo_adv_2006001_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像沒有忘記帶東西。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那這次，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我真的要出發囉♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的，",
        "unit_id": 102511,
        "voice": "vo_adv_2006001_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "路上小心～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請您要跟秋乃小姐好好相處哦，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐♪",
        "unit_id": 102511
    }
]