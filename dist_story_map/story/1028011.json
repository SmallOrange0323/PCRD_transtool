    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對了，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼說來，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "差不多要全國模擬考了呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是因為這個啊。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "模擬考不是臨時抱佛腳就能考得好的，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n平常就要好好唸書。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然你有心想克服不擅長的部分，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是覺得很好啦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要我剛誇獎你，你又開始用土法煉鋼逃避公式啦！",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉～",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是我跟你唸同一間學校，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就可以每天幫你看功課了說。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在學校",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒有人",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以盯你唸書嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你其實",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "人脈滿廣的，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺應該會有人陪你呀。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "確實，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得靠自己努力才會記起來嘛。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真了不起。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然後",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也不否定有人盯你唸書這點是吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有也不奇怪啦，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟你很受歡迎嘛。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒有，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒什麼啦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我只是好奇，是怎樣的人",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在盯你唸書而已。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我看那個人應該也很辛苦吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是怎麼樣的人啊？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼？",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "人數居然多到需要思考嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這還真的是有點超乎意料之外了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉～",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然這很理所當然，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我真的不太清楚",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你目前的現況呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "確實體會到",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你跟以前有所不同了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對啦，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你不要一臉沾沾自喜的。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不是在說唸書這方面。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我是想說，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也有",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我所不知道的一面呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟我們唸不同學校，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這也很正常吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在學校",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "過得怎樣？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "開心嗎？",
