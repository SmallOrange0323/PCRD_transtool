    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「為了不留級」",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種消極又迫切的理由。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是再更有建設性一點的。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大學啦，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大學。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n如果是大學的話，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就還有機會",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以跟你唸同一間了吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你可以努力唸書，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_042"
    },
    {
