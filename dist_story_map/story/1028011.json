[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在郊外的某處角落。神色有些緊張的咲戀，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以及跟隨著她的{player}身處在此。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉喔，",
        "unit_id": 102811,
        "voice": "vo_adv_1028011_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要你陪我來做這種事。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n都是因為父親大人突然說他要離開領地，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來蘭德索爾待一陣子啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我只說要稍微跟他打聲招呼，",
        "unit_id": 102811,
        "voice": "vo_adv_1028011_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但其實我準備要好好地推銷，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓他投資我的生意。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然光靠通訊魔法交涉",
        "unit_id": 102811,
        "voice": "vo_adv_1028011_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "談不出個結果，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那就只能親自來拜訪了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喔，",
        "unit_id": 102811,
        "voice": "vo_adv_1028011_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你不必做任何事。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你只要幫我搬資料",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就很足夠了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "裡面包含了一些我至今為止交易過的商品，",
        "unit_id": 102811,
        "voice": "vo_adv_1028011_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以還蠻大的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "奇怪？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我、",
        "unit_id": 102811,
        "voice": "vo_adv_1028011_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我說！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像有東西在發光耶！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我不記得我有帶來會發光的東西啊！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該不會",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是你混了奇怪的東西進去吧！",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀，{player}。",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能在這裡遇到還真難得……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像也還好。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟我跟你",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都常來",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡嘛。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為什麼",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要問我",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好不好？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我跟平常一樣啊……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是瞞不過你呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對啦，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如你所見，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我現在有點沮喪。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然也不是",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "發生了什麼",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "討厭的事啦……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這應該",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算是討厭的事吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我剛才",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "遇到小時候欺負我的",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那些傢伙了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我現在已經不會再被他們欺負啦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "其實相反的，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他們莫～～名地對我很低聲下氣。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n害我也不知道",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要怎麼應對，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只有表面上裝樣子應付他們，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但感覺很不舒服。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還只是高中生耶？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n明明也不是在什麼社交場合，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n應該沒必要",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼虛偽地往來吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉，我這樣抱怨也不是辦法吧。",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幸好",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你和以前一樣",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒變。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不是啦，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我當然不是覺得你完全一模一樣……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你怎麼突然這麼說？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你為什麼要把包包舉起來？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "裡面裝著用功讀書的文具？",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那又怎樣？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你說你現在會好好唸書了？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哈哈哈！",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼跟什麼嘛！",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要說得一本正經啦。",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我還以為",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你要講出什麼更嚴肅的話題呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看你都沒有變，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我真的很開心。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼啦，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你怎麼一臉不服氣的表情？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我覺得你現在變得會好好唸書",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很棒啊。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的～",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "剛才笑你，真是抱歉。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對了，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "做為補償，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我陪你唸書好了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也正好沒有其他事情要做。",
        "unit_id": 102832
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像就可以靜下心來唸書了呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來吧，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你說你有所改變了，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "證明給我看看。",
        "unit_id": 102832
    },
    {
        "type": "still",
        "still": "102801101"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呃～",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要把所有組合一個一個的列出來暴力破解，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n用我剛才教你的公式吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你這種算法",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "考試時間會不夠用吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不是，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算你把寫出所有組合的速度加快也……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你努力的方向錯了啦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且，這不是",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該很久以前就學過的東西嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為什麼你到了現在",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還在練習這部分啊。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你該不會",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是一直在偷懶，沒有好好唸書吧？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你猶豫了一下，讓人有點在意呢，",
