        "voice": "vo_adv_1028011_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不曉得會怎麼樣呢？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我可能要一直照顧你，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "被你整得暈頭轉向，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺會很累呢，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但那樣",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像也挺開心的。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且還可以",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "每天都盯你唸書呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你幹嘛",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一臉嫌棄啦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唸書是學生的本分吧？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果唸同一間學校，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就可以每天看到",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你那副表情了吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這麼說起來，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是有可能呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這主意聽起來也是滿有趣的，",
