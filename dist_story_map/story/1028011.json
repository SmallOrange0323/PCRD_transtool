    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……雖然是我自己問的，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這問法好像家長喔。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當我沒問吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "趕快忘掉。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我嗎？",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "過得",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "滿開心的啊。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然因為是名流貴族學校，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以比較特別，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但有些事，也是只能在那裡才體驗得到的。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但那裡沒有我以前認識的人，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是有點寂寞啦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "開玩笑的。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我怎麼可能會這樣想嘛。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "過得開心就好。",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖說你看起來",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不管在哪裡都會過得很開心啦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算轉學來我的學校，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "似乎也會立刻跟同學混熟。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果我們唸同一間學校，",
