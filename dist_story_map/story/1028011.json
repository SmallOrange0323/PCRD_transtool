        "voice": "vo_adv_1028011_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我不是指這個。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那個啦，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是說你現在唸書的理由。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……不對，",
        "unit_id": 102832,
        "voice": "vo_adv_1028011_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不是在說",
