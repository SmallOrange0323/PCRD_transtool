[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯唧唧……！",
        "unit_id": 101111,
        "voice": "vo_adv_1011005_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n把弓弦拉到極限～發射",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "☆",
        "unit_id": 101111
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唉～……以我的腕力和這把弓，要射到那裡還差一點點呢。",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真不甘心，明明總算發現稀有植物了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我只能放棄，另尋他處了嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是呢……我在這個布里薩溪谷來回找了一整天，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "才總算讓我找到。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n總覺得我要是錯過這次機會，就會永遠都找不到了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那種稀有植物可以作為特殊染料的材料……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "它只生長在這個布里薩溪谷裡，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n而且去店裡買非常貴。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說，應該就是因為可以賣到好價錢……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為了拿去店裡賣，這種植物才會被肆意亂採。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而長在容易採集的地方的植物",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n感覺都已經被連根拔光了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只剩長在那種懸崖峭壁的山腰處還沒被採光，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就是因為沒有人可以採得到吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我必須考慮除了那裡以外的地方，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n應該都沒有了吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我的作戰計畫是發射綁了繩子、前端呈掛鉤狀的箭……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n順利勾住植物再收回來。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔～嗯，可是就物理上來說似乎是辦不到呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要是射偏，直接射穿植物的話就太糟了，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這個作戰計畫的難度太高了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "剛想到時還覺得",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "『這真是個好方法！』，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是實際上很難達成。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒辦法，我就暫時放棄那種植物……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "用弓箭狩獵一些魔物，賣掉毛皮等材料……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n然後買更厲害的弓，同時磨練自己的技術吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就慢慢地努力磨練吧！",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "俗話說欲速則不達，千里之行始於一記背摔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n說不定我要是拖太久，植物就會枯掉了？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是，嗯，我就再試試最後一次吧！",
        "unit_id": 101111,
        "voice": "vo_adv_1011005_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好好地拉緊弓弦……",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n嗯唧唧唧，我要射出灌注全力的一支箭！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯啊！？",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n危險，請不要突然衝到我面前！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "差一點就要發生大慘案了，真是『箭』不容髮啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥在這種地方做什麼？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔？",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這一帶常有魔物出沒，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以實在不太適合散步喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥也不是很強，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以必須更謹慎行動才是。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥如果受傷的話就糟了，我會擔心的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，其實有種叫作多角四角四角的東西……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，哥哥沒聽懂？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個，多角？",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n鹿、鹿什麼的？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是像那種感覺的東西啦，哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "先不提那個了，哥哥……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥知道那邊長著一種奇形怪狀的植物嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有沒有曾在哪裡見過和那個相同的植物呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想採那種植物，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為它可以做成染料。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我沒什麼錢，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以都是靠自己張羅做服裝的材料。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "錢不夠的部分，就得耗費勞力不可……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯，沒錯。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為有一種顏色，不論怎麼試都只有那種植物才能調製出來。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我的公會上司，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n應該說高層拜託我替她做衣服……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想做到最好，而且那個人對顏色的喜好也很挑。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我想取得那種植物來製作染料。",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是憑我現在的實力，似乎是辦不到呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過至少能把弓箭射過去的話，或許就會有辦法了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，我想到一個好主意了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們來把弓固定在地上～？",
        "unit_id": 101112
    },
    {
        "type": "still",
        "still": "101100501"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，請過來這邊！",
        "unit_id": 101111,
        "voice": "vo_adv_1011005_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們一起盡量地拉緊弓弦吧！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要結合我們兩人的力量，說不定可以把箭射到植物那邊？",
        "unit_id": 101111,
        "voice": "vo_adv_1011005_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "由我來負責瞄準，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥只要盡量地拉緊弓弦就好了！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒問題嗎？",
        "unit_id": 101111,
        "voice": "vo_adv_1011005_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝哥哥♪",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，集結我們兄妹兩人的力量拉緊弓弦……嗯唧唧唧！",
        "unit_id": 101111,
        "voice": "vo_adv_1011005_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我一說『發射！』，就請哥哥放手喔，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們要配合好時機射出弓箭喔！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯唧唧唧……！",
        "unit_id": 101111,
        "voice": "vo_adv_1011005_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是現在，預～備！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n發射～☆",
        "unit_id": 101111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔哇！",
        "unit_id": 101111,
        "voice": "vo_adv_1011005_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "？",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對、對不起，哥哥！",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n弓弦斷掉害哥哥倒下去了吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥沒有受傷吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚，作戰計畫失敗！",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我還以為這是個好主意呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哈嗚……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對、對不起，我緊貼著哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這是意外，意外！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n以前，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥常像這樣陪我睡覺呢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒事，嗯，對不起。\n現在的哥哥應該不記得了吧。",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n總之，我把箭收回來喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為箭上有綁著鋼絲，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n只要拉動它就會回到我手上。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿咻，嘿咻♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥的記憶如果也能像這樣",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_042"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n拉動一下就回復的話，事情就很好辦了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "果然，現實是沒辦法事事都如自己所願呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哎呀？好厲害！箭碰巧直接命中我先前瞄準的植物，",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n順利地把它鉤住了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我歪打正著取得染料的材料了♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我好開心～！",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也是會有這種事的吧，真是非常幸運！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不，應該說只要不放棄持續挑戰的話……",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_045"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也就有可能像這樣受到幸運之神眷顧呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_1011005_046"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n謝謝哥哥。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得我從哥哥身上獲得了許多東西♪",
        "unit_id": 101112
    }
]