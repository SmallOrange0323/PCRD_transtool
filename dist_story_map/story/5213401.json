        "voice": "vo_adv_5213401_008"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n自古以來，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "蝦乃長壽之兆的吉祥之物。",
        "unit_id": 129711
