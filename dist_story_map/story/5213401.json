        "voice": "vo_adv_5213401_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "關於這個。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "簡單說明的話，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "大概就是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……吃了龍蝦後",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就會覺醒。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "目前是這樣。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "「「吃了龍蝦後……？」」",
