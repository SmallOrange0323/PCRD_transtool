    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁那副姿態，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n能否依自身意志",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "自由變化呢？",
