    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "看來我的身體，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "好像還無法完全適應黃泉鯨命的力量……",
