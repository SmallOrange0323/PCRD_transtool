        "voice": "vo_adv_2104008_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不能使出恰巧讓他們麻痺的法術……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n總之，我先凍結他們的手腳，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在他們嘴裡塞了冰塊。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他們暫時沒有辦法施放魔法，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也就不會失控胡鬧了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雪菲寶好棒棒～！",
        "unit_id": 101611,
        "voice": "vo_adv_2104008_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呼，",
        "unit_id": 105011,
        "voice": "vo_adv_2104008_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真受不了呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這下子",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "應該停止了所有人的行動……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "居然連其他班的學生",
