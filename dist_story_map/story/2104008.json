        "name": "美咲",
        "words": "抱歉了，各位！",
        "unit_id": 105011,
        "voice": "vo_adv_2104008_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我下手會輕一點的，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原諒我！",
        "unit_id": 105011
    },
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是現在，",
