        "voice": "vo_adv_2104008_003"
    },
    {
        "type": "dialogue",
        "name": "學生們",
        "words": "……！！！！",
        "unit_id": 1,
        "voice": "vo_adv_2104008_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大事不妙了，",
        "unit_id": 101611,
        "voice": "vo_adv_2104008_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家都變成硬梆梆的冰塊了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n看起來好冰呀～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這、",
