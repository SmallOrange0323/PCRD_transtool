        "voice": "vo_adv_2104008_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "都被她操控住了……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "鈴奈妳們",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒有受傷吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "完全不痛不癢☆",
        "unit_id": 101611,
        "voice": "vo_adv_2104008_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然距離有點遠，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過秀才幫我強化了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "老師，",
