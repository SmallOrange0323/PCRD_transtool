        "voice": "vo_adv_2104008_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也沒事。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是……",
        "unit_id": 106411
