    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當貪吃佩可等人追趕美空時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n伊緒和美咲等人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在學院裡努力阻止被洗腦而失控的學生們。"
    },
