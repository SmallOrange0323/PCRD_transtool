[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【美食殿堂】的一行人，\n抽獎抽到「迷人的南國之旅」的幾天後。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喂～{player}～！",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是巧遇呢！",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來還真難得～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天你沒有和小可蘿在一起嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔嗯。",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n原來因為她知道可能會晚回家的關係，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才會跟我說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要我先吃飽飯先睡～是吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她另外還說了，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「{player}會在外面吃完飯才回去，\n所以不用準備他的那一份」……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n哦哦，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說的話{player}還沒有吃晚餐嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣正好！",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那…",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你要不要和我一起吃晚餐呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在打工的地方，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是間以賣魚料理為主的店……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最近好像因為業績不好而在煩惱的樣子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以想去幫他們增加點業績呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇～",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有問你真是太好了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那我們走吧馬上走吧，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以挽著你的手嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿嘿～",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "往這邊哦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們一起用美味的食物來填飽肚子吧，{player}♪",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到達～！",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "店長現在還有在營業嗎，我們方便用餐嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝您！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼我幫兩位客人帶位～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不小心就說出打工講習慣的話了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦？",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你看你看，{player}！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像有什麼奇怪的東西在店裡面呢……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "輸、",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "輸送帶？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是什麼啊……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}也不太清楚是嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n唔～嗯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說不知道為什麼腦中會浮現出那個單字嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會不會是失去記憶的{player}，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n腦中的某處所殘留下來的知識呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那東西我有在其他店裡看過。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "叫做迴轉壽司哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在轉圈圈的路徑上面放上盤子，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n客人可以自由地從上面拿取想吃的食物。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈哈……",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來是想解決業績問題，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n店長就採用了迴轉壽司的機制呀。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為這家是門檻較高的高檔餐廳，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以大概是想營造出輕鬆的氛圍……哦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "壽司接連地往這邊移動過來了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔嗯唔嗯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貼在牆上的紙說每盤均一價一百盧幣……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n非常的便宜呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想不到竟然能以這樣的價錢吃到壽司！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這可以說是壽司業界的革命啊！",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n哇～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要吃哪一個才好呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你想要吃哪一種壽司呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想壽司基本上都是以魚類為主就是了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這間店大致上也都經常進一些高級的魚貨，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n像是貝類、章魚，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或是海膽之類的也超好吃的哦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論選擇哪一種，我想你都不會失望的！",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿嘿～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃東西真是讓人期待呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肉、",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肉的壽司嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為壽司本身在這個地方算是非主流料理，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我也不是很清楚……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會有不是魚，",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而是放肉的壽司嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是握飯糰之類的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想就會有放肉的壽司了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為幾天後就要去南國旅行了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到時候應該會各種海產吃到飽……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以理解你想趁現在",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "多吃點肉的心情啦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是不是選錯店了～。",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好吃的東西無論吃多少都不會膩的♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵呵～",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然每個看起來都很好吃，令人目不暇給，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但我要一盤接一盤地拿囉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一盤、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩盤、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "三盤……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿……",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不知不覺就拿了好多盤。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要先吃哪一盤才好呢～",
        "unit_id": 105812,
        "voice": "vo_adv_1075001_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n壽司一顆一顆的好像寶石一樣，真漂亮，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就這樣吃掉好可惜哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
