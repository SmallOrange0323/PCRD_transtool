    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萬聖節慶典即將到來──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾的鬧區正忙著準備慶典。"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你好～",
        "unit_id": 411,
        "voice": "vo_adv_5076000_000"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "請多關照～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我們攤位今年也在你們隔壁呢～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔喔！",
        "unit_id": 311,
        "voice": "vo_adv_5076000_001"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們也是，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "今年也請多關照！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們會努力賣出很多杯子蛋糕，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不會輸給你們的聖代的～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "當然，",
        "unit_id": 411,
        "voice": "vo_adv_5076000_002"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "正合我意！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "慶典再過幾天就要開始了……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們快努力準備吧！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "為了客人的笑容！",
        "unit_id": 311,
        "voice": "vo_adv_5076000_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n努力做出許多香甜可口的甜點吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊！",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真是香到不行～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這邊也是那邊也有，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "到處都是看起來又甜又好吃的甜點攤～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "才剛開始準備",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就已經這麼熱鬧了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n聽說越接近萬聖節慶典還會有更多攤販，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這也太棒了吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家今年萬聖節已經安排了休假，",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的好期待喔～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不知道秀才有沒有空～？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "找他出來約會吧♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "約會之前先預習一下場地吧！",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "街上已經開始裝飾了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n也得好好確認",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今年變裝流行趨勢！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喔喔～！",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "南瓜、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "燈籠、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "點心攤！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這就是萬聖節慶典嗎！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我第一次看到是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "死者",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "會從彼岸回到人間這一點，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n跟東國的盂蘭盆節很像，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但氣氛完全不同呢！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "盂蘭盆節",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不是用南瓜裝飾，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而是用茄子跟小黃瓜是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且在東國，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "南瓜是冬天吃的吉祥食物是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "希望能讓將軍",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "從統一天下的大業中喘口氣是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了讓將軍玩得開心，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我這個家臣應該趁現在先行勘查是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "已經開始準備了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我看看～",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有些什麼攤位呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "聖代跟杯子蛋糕……",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還有棉花糖！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有好多看起來很好吃的東西～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看來還是沒有賣開口笑的攤位呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "自從離開故鄉，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我就只吃過自己做的開口笑，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n偶爾也想買現成的來吃……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我自己做的也很好吃，所以也沒什麼不滿啦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且我先做足了想吃的分量，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "帶在身上隨時都吃得到～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚼嚼……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好好吃喔～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真步也說我偶爾可以休息一下，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我就好好放鬆一番吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真希望趕快到萬聖節那一天～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對了，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不知道{player}",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "萬聖節是不是也放假～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想找他一起玩～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "下次約他看看吧～",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚼嚼……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可可愛愛！",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n已經有超可愛的飾品攤擺出來了～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要戴哪個呢～？",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n啊～不過，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要戴的話，人家想跟秀才戴一對的～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "其他還有什麼呢～？",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 7611,
        "voice": "vo_adv_5076000_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哎呀！",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個狗狗飾品是怎麼回事！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n軟綿綿的好好笑～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這不是超讚的嗎～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 7611,
        "voice": "vo_adv_5076000_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過，",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個當飾品會不會太大了？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這樣會不會",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太可愛過火啦？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是要放在頭上頂著嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "來試戴看看吧……",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "戴起來怎麼樣呢～？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………！！",
        "unit_id": 7611,
        "voice": "vo_adv_5076000_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等一下！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦咦～！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n怎麼跑掉了！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今年流行會動的飾品嗎！？",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家都不知道！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是說",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家還沒結帳，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "店裡也沒有人，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這下不妙了！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總之最好先抓起來，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拿去還給店家！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "得趕快追上去才行！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯……",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_034"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "吸血鬼、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "狼人……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是妖怪雜貨嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒想到這類東西也能擺在攤位上賣……！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖說還在準備中，",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "萬聖節跟盂蘭盆節真的很不一樣呢……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n真是不可思議……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很有意思是也！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等一下～！",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_036"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……哎呀？",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………！！",
        "unit_id": 7611,
        "voice": "vo_adv_5076000_038"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個人……",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_039"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "她的狗好像跑走了！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這邊就讓我來助她一臂之力是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻啪！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也跑太快了吧～！",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_040"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "簡直就像真的狗一樣～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘿──！",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_041"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也來幫忙抓牠！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不能對有困難的人坐視不管！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻啪啪啪！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的假的？",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_042"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝啦～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "給我站住──！",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_043"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "別想逃──！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………！！",
        "unit_id": 7611,
        "voice": "vo_adv_5076000_044"
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "應該跑到這附近來了才對……",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_045"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都沒看到呢……",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_046"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_047"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "別這樣啦～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咦！？",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_048"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "聲音是從那個轉角後面傳來的！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我們去看看吧！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不可以，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_049"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那是我的開口笑喔～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "汪汪！",
        "unit_id": 7611,
        "voice": "vo_adv_5076000_050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣啊～",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_051"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這麼好吃嗎～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那就再給你一個～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "吃吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不會吧……",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_052"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那隻狗在吃甜點……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n難道牠其實是真的狗……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是說，",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_053"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這不是香織嗎！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超久不見～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔～！",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_054"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是鈴奈啊～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看妳這麼有精神真是太好了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是說，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_055"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳們兩個都在追牠嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我不知道牠是誰家的狗，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但是牠剛剛撲上來想吃我的開口笑～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "唔唔，",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_056"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "原來妳們兩個都不是牠的主人？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不管怎麼說，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "牠好可愛喔！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "毛茸茸的是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為人家是在飾品攤看到牠的，",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_057"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還以為牠是新款商品，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太意外了，真是搞不懂～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "唔……",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_058"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就算牠沒有主人，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "丟著不管沒問題嗎……？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n是不是該把牠送去什麼地方是也？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_059"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真傷腦筋～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就算是我們公會，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也沒辦法處理這種事情……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！？",
        "unit_id": 101611,
        "voice": "vo_adv_5076000_060"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！？",
        "unit_id": 103011,
        "voice": "vo_adv_5076000_061"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}，",
        "unit_id": 101711,
        "voice": "vo_adv_5076000_062"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你怎麼背著奇怪的機器～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n而且，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你說要把牠帶回去，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是怎麼回事～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織一行人",
        "words": "咦……？",
        "unit_id": 1,
        "voice": "vo_adv_5076000_063"
    },
