    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就很費力了……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
