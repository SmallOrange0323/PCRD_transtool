        "type": "dialogue",
        "name": "純",
        "words": "\n如果",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有辦法聯繫的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好想現在馬上告訴他這件事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……呵呵。",
