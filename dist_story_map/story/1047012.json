        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "身為【王宮騎士團】團長，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在敵人面前",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可不能退縮。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我該守護的東西就在這裡！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喝啊！！",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_025"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即使斬除了面前的魔物，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n馬上",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就有其他魔物毫不畏懼地",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "衝過來……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒有",
