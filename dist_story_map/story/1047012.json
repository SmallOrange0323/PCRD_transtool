    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n沒有什麼複雜的理由……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_066"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是因為想成為",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能夠守護別人的正義夥伴。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想守護",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_067"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "國家、人民，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有和平。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣的日子如果能持續下去，我就很開心。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "……我",
        "unit_id": 711,
        "voice": "vo_adv_1047012_068"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "也曾想要守護。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "但是……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……我只能說，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_069"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不要想得太複雜，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只要坦率面對就好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你要更加珍惜自己真正的心情。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……抱歉。",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_070"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我本來就不太會說話。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n說的這些似乎沒有什麼重點……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "不，",
        "unit_id": 711,
        "voice": "vo_adv_1047012_071"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "沒這回事。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n受到團長鼓勵，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "我……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "……那邊",
        "unit_id": 711,
        "voice": "vo_adv_1047012_072"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "好像還需要幫忙，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n我先過去了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……好像打起精神了，太好了。",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_073"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n說實話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我還不確定是否真的有鼓勵到他。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_074"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "平常鼓勵了各種人的少年都這麼說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也許我真的做到了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "珍惜自己真正的心情……",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_075"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n既然都這麼說了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也該好好面對呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……呼。",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_076"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "繼續戴著這個的話，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會忍不住想蒙混過去呢……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個頭盔",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_077"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原本只是習慣性戴著，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看來也變成隱藏表情、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "隱藏心意的工具了。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_078"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果要向你傳達真正的心意，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還是把它拿下來比較好吧。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也為了不要讓自己蒙混過去。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年……",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_079"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n剛剛戰鬥時……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你說了下次",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再一起去玩，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對嗎？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……如果少年同意，",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_080"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以現在就一起去玩嗎？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是認真想和你",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一起出去玩。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_081"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我的臉沒戴面具，如果被直直盯著看……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒問題的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我可不覺得難為情。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_082"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我絕對會努力遵守約定的……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我希望……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你能看一看",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是否能表現得像個普通女孩子。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我知道",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_083"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個要求很突然。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果你有別的事",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或是不感興趣，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也可以拒絕──",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……謝謝你，",
        "unit_id": 104712,
        "voice": "vo_adv_1047012_084"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有沒有什麼想吃的……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這種事等等再說。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們快點",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一起去玩吧！",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雙頰染紅的純，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n牽起{player}的手走向街上。"
    }
]