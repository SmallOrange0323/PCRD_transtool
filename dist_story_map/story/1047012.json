        "type": "dialogue",
        "name": "純",
        "words": "……抱歉啊，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看來我是沒辦法前往約定的地點會合了。",
