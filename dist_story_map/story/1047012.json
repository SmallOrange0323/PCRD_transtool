        "voice": "vo_adv_1047012_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "來……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然虛張聲勢了，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個數量……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能夠爭取多少時間呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不管我會變得怎麼樣，",
