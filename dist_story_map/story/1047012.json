    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "純在和{player}的約定時間之前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正進行著和前陣子相同的任務。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為今天會跟少年見面，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望可以盡可能避開工作……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是最近",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團】整體都很忙碌，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n導致王宮的警備維持在最低限度這點很令人介意啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大家主動接手外面的任務很令人感謝，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n保險起見",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "來當作下次討論的議題吧……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唉呀，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "光想著工作的事情，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n又差點趕不上約定的時間了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n下次得注意不要遲到……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團、",
        "unit_id": 712,
        "voice": "vo_adv_1047012_004"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團長！！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼了，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼慌張。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天沒有和新人團員在一起嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "大、",
        "unit_id": 712,
        "voice": "vo_adv_1047012_006"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "大事不妙！！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n我和新人一起",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "去森林幫忙討伐魔物，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n卻在那邊",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "遇到大量魔物……！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大量魔物……？",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "究竟為何？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "恐、",
        "unit_id": 712,
        "voice": "vo_adv_1047012_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "恐怕是",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "魔物的巢穴……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n新、",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "新人受傷了，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "正在往這裡逃跑。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n而我",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "則是為了呼叫救援",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "先一步回來。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……事情不妙啊。",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "現在沒有可以馬上行動的團員。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然只要發出召集，我想大家都會趕過來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但很花時間。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……總之，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我先過去現場。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n告訴我魔物從哪個方向過來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而你留在這邊",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請求救援。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我、",
        "unit_id": 712,
        "voice": "vo_adv_1047012_011"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我知道了！",
        "unit_id": 712
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……是那邊嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_012"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "魔物數量不尋常……",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n該不會，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在距離王都不遠的地方還有這樣的巢穴吧……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "團、",
        "unit_id": 711,
        "voice": "vo_adv_1047012_014"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "團長……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "很抱歉",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "事情變成這樣……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "快退下，",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "把傷口包紮好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n待在這裡很危險。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在其他部隊抵達之前，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我會守在這裡。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "但、",
        "unit_id": 711,
        "voice": "vo_adv_1047012_016"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "但是，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "這個數量……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "雖然有城門，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n但還不知道會變成什麼樣……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "等待部隊過來比較好……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒這個時間了。",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你不相信\n身為【王宮騎士團】團長的我嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "唔、",
        "unit_id": 711,
        "voice": "vo_adv_1047012_018"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "唔唔……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "很抱歉，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "團長……！！",
        "unit_id": 711
