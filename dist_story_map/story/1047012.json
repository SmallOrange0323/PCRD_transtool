    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喘息的空間……！　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
