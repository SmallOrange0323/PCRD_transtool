        "voice": "vo_adv_1047012_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒想到就算變成這種狀況，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還會考慮這種事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "變了啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是……",
        "unit_id": 104711,
        "voice": "vo_adv_1047012_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也有不變的東西。",
        "unit_id": 104711
    },
