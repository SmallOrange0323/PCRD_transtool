[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "愛梅斯一如往常地關注著{player}一行人的動向。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而意料之外的某種東西正悄悄逼近她。"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哼。",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n{player}真是的，又要去海邊呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又是什麼委託嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正肯定是和平時一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想趁著委託順便大玩一番吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真搞不懂那種又鹹又大片的水窪到底有哪裡好了？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n人類這種生物還真是不可思議啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然也正因如此，",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我才會想了解他們。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──真的是，",
        "unit_id": 1,
        "voice": "vo_adv_5152000_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "意見相同呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "領域……",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正受到干擾！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不行，",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會被覆蓋過去……！",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "502340"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳說妳是……",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "強欲的魔女，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "艾姬多娜？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "請多指教。",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是，",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼請多指教啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以這麼形跡詭異的方式登場，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n怎麼可能有什麼好指教的啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "被這麼直接地說很詭異，我好受傷啊。",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_010"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "如妳所見，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我可是纖弱的少女喔？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這什麼滿溢而出的可疑感。",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "完全就是不能放鬆警戒的類型嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哎呀，",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_012"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我想說要讓妳安心，反而導致妳閉口不言了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我本來",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還想多跟妳聊聊的。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──畢竟",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_013"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是難得一見的「異世界」呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "異世界……",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也就是說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這傢伙……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n和先前來的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那些傢伙",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有所關聯嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "老實說，",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我有很多事想問妳，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但總覺得不該和妳有太多的對話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "向冠有強欲之名的傢伙提問，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可不是個好主意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "妳不用這麼提防我。",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_016"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就如同剛才說過的，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我是纖弱的──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就問妳一件事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳的目的是什麼？",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_018"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就如自我介紹時所說的，",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_019"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我很貪婪呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就只是想要知道這個世界的事情而已。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "為了消除妳的不安，我就直接明說吧。",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_020"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──我不是敵人喔。",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_022"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這樣妳有比較放心了嗎？",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一點都沒有呢。",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我知道妳不是會突然就大打出手的傢伙了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好吧，",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就陪陪妳吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n與妳來段有趣的對話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "真是太開心了呢。",
        "unit_id": 132012,
        "voice": "vo_adv_5152000_026"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "能在異世界與未知邂逅──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我的內心好雀躍啊。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可不能讓這樣來歷不明的傢伙離開我的視線。",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果我能夠在這裡把她擋住，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就再好不過了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺我這樣的想法也被她看透了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟麻煩事扯上關係了啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管怎麼說。",
        "unit_id": 190011,
        "voice": "vo_adv_5152000_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎又要交會了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n與來自異世界的來訪者──",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你很吵啊，巴魯斯。",
        "unit_id": 109812,
        "voice": "vo_adv_5152000_029"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n快去拿新的飲料來。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "還真是會使喚人的姊姊啊！",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_030"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我也是正值青春的男孩子！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我也想去玩啊！？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "夏天！",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_031"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "大海！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "在海邊嬉戲的愛蜜莉雅醬！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n這可是",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "人人夢寐以求的夏日假期！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "「夏日佳期」？",
        "unit_id": 131911,
        "voice": "vo_adv_5152000_032"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我不太懂你在說什麼。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "在海邊嬉戲的昴，",
        "unit_id": 132112,
        "voice": "vo_adv_5152000_033"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "好可愛……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "但是他看莉雅的眼神讓人有～點無法接受呢。",
        "unit_id": 2612,
        "voice": "vo_adv_5152000_034"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "要不要讓他變成冰塊",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "在休息處冰鎮一下？",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "那會死人的啊！？",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_035"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "而且我才沒有用那種猥瑣的視線看著……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "是說就算有一點也沒有辦法──",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哎呀，",
        "unit_id": 109812,
        "voice": "vo_adv_5152000_036"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你的手指間有縫隙呢，巴魯斯。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n真是下流。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "妳，",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_037"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "就算這樣也不要突然戳眼睛啊！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呵呵。",
        "unit_id": 131911,
        "voice": "vo_adv_5152000_038"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "大家，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "看起來都好～開心。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可是……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這個樣子沒問題嗎。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這裡……",
        "unit_id": 132112,
        "voice": "vo_adv_5152000_039"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n自從我們來到阿斯特賴亞大陸，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "都已經過了相當長的時間了。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "說的也是……",
        "unit_id": 132112,
        "voice": "vo_adv_5152000_040"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n透過之前獲得的「福音書」",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "和碧翠絲小姐取得聯絡後，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "應該已經找到了回去的辦法才對……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "那時候的我，",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_041"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "還說了「",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "就算明天可能會回去，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "也要向今天的我們舉杯」",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這種話。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是丟人現眼。",
        "unit_id": 109812,
        "voice": "vo_adv_5152000_042"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "來到了別的世界，竟然還玷汙羅茲瓦爾大人的顏面。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你去死吧。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "姊姊妳對我不會有點太嚴苛了嗎！？",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_043"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "妳以為妳手上的那杯果汁",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "是誰做的啊！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這也是沒辦法的事。",
        "unit_id": 2612,
        "voice": "vo_adv_5152000_044"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n我之前也說過了，",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "那裡和這裡似乎有時間上的落差。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "以前",
        "unit_id": 132112,
        "voice": "vo_adv_5152000_045"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "大精靈大人曾說過，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "「這裡的一天",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "在那邊可能是一分鐘」",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這樣的話呢。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "也就是說，",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_046"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "如果碧翠子看了30分鐘的書，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "可能就過了30天是嗎。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "沒錯，",
        "unit_id": 2612,
        "voice": "vo_adv_5152000_047"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "如果貝蒂睡了一小時的午覺，",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "就是60天呢。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "喂喂喂喂。",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_048"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n那樣的話，要是在碧翠子想把那頭豎捲髮換造型的日子……！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "說不定",
        "unit_id": 2612,
        "voice": "vo_adv_5152000_049"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "得要有耗上個幾年的心理準備呢～",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真是的，",
        "unit_id": 131911,
        "voice": "vo_adv_5152000_050"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "昴，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "帕克，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你們不要鬧了。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n碧翠絲現在也在努力地",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "準備轉移……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "準備機遇門呀。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "要連結完全不知道的地方和屋子。",
        "unit_id": 131911,
        "voice": "vo_adv_5152000_051"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這一定是很～辛苦的事。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "……也是呢。",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_052"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不過話雖如此，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "就算愛蜜莉雅醬煩惱也沒有用啊。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n碧翠子正在努力。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這就是我們能回去的最快捷徑。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "啊……",
        "unit_id": 131911,
        "voice": "vo_adv_5152000_053"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "即便不是現在這樣的情況，",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_054"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "平時的各種事情就已經很辛苦了。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我認為轉換心情",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "也是很重要的事喔。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "妳看？",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_055"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "大家看起來很開心吧？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n海邊就是像這樣，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "會讓大家露出笑容的地方。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n所以啊──",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛蜜莉雅醬也",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "盡情地享受當下吧？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "昴……",
        "unit_id": 131911,
        "voice": "vo_adv_5152000_056"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "多麼深奧的話語……",
        "unit_id": 132112,
        "voice": "vo_adv_5152000_057"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "真不愧是昴。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆深感佩服。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哼！",
        "unit_id": 109812,
        "voice": "vo_adv_5152000_058"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "反正只是巴魯斯自己想偷懶而已吧。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆可是一清二楚──",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "沒錯，",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_059"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這裡是海邊！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n這是和愛蜜莉雅醬共度夏日假期的機會！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "是我夢寐以求的",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "異世界慢活人生！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "──巴魯斯。",
        "unit_id": 109812,
        "voice": "vo_adv_5152000_060"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你要發呆到什麼時候。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "咦？",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_061"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "什麼……？",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_062"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n有東西從海上",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "逐漸靠了過來？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "……又白、又大……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 18511
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "鯨魚──────────！？",
        "unit_id": 2713,
        "voice": "vo_adv_5152000_063"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正當昴想要盡情享受夏日之時，巨大的鯨魚出現在他的眼前。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n映照在鯨魚巨大眼眸裡的他，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聽到了異世界慢活人生之夢碎裂的聲音。"
    }
]