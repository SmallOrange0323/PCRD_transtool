        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 105213,
        "voice": "vo_adv_5106606_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不是馴鹿耶……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過只要不會嚇到街上的人",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就好了。",
