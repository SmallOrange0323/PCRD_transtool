        "voice": "vo_adv_5106606_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "幫了大忙的啦！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好～",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那我們就",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "出發前進啦～！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 124214,
        "voice": "vo_adv_5106606_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像這樣和夥伴一起努力工作……",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這也算是一種幸福吧。",
        "unit_id": 124214
    },
