        "words": "真是有點麻煩呢……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "不過，",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
