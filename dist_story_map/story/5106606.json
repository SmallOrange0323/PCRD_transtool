        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥和……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是哪位呀？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 124214,
        "voice": "vo_adv_5106606_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "失禮了。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是【王宮騎士團】的純。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔，",
        "unit_id": 119211,
        "voice": "vo_adv_5106606_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是純小姐啊～",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……什麼，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "純小姐！？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n妳怎麼了，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼穿成這樣啦！？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我現在在幫這幾位天使的忙。",
        "unit_id": 124214,
        "voice": "vo_adv_5106606_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是特別準備的服裝……",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔～",
        "unit_id": 119211,
        "voice": "vo_adv_5106606_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是不是叫Cosplay啊？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n之前鈴鈴也做過一樣的事啦！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呃，",
        "unit_id": 124214,
        "voice": "vo_adv_5106606_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以這麼說吧……",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "比起這個！",
        "unit_id": 8912,
        "voice": "vo_adv_5106606_008"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "妳是不是在傷腦筋呀？",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "儘管向我",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "這位天使艾米說說看吧。",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這一位是扮成了天使嗎？",
        "unit_id": 119211,
        "voice": "vo_adv_5106606_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好可愛的啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唔～",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也不算是傷腦筋吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場的牛奶最近銷量很好。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我正忙著配送啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "該說是甜蜜的負荷嗎……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我期待的就是這種願望！",
        "unit_id": 8912,
        "voice": "vo_adv_5106606_010"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n用天使的力量就可以解決了！",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那不太好吧……",
        "unit_id": 119211,
        "voice": "vo_adv_5106606_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場的事情得牧場自己解決啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "用願望的力量迅速俐落地配送也沒關係吧。",
        "unit_id": 8912,
        "voice": "vo_adv_5106606_012"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "來，",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "妳快在心裡希望工作快點結束吧。",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等等，",
        "unit_id": 124214,
        "voice": "vo_adv_5106606_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "艾米。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n擅自斷定別人的願望是不好的。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n先別先入為主，",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "問問人家心中真正的幸福怎麼樣？",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "……有道理，",
        "unit_id": 8912,
        "voice": "vo_adv_5106606_014"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我的做法有點粗暴了。",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "那麼，",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "如果有想要的東西或想見的人，",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "就在腦海裡想像一下吧。",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我沒有",
        "unit_id": 119211,
        "voice": "vo_adv_5106606_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想要的東西，不過……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n想見的人的話，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "倒不是沒有啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "很好。",
        "unit_id": 8912,
        "voice": "vo_adv_5106606_016"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "那請妳在腦海裡一直想像著那個人！",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n要開始囉！",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n天使之箭！",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "什、",
        "unit_id": 119211,
        "voice": "vo_adv_5106606_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "什麼！？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n啊，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我的確",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是覺得有莉瑪莉瑪在會更放心啦……",
        "unit_id": 119211
    },
    {
