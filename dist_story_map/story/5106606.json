        "voice": "vo_adv_5106606_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我才不是動物！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是失禮。",
