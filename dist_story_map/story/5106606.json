    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我看家也看膩了，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就來幫真陽的忙吧！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真不愧是莉瑪莉瑪！",
