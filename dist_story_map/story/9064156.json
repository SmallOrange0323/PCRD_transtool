[
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘶啊啊啊啊啊！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "總算是打倒了……！",
        "unit_id": 126013,
        "voice": "vo_adv_9064156_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "凱留小姐，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "非常謝謝妳。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒、",
        "unit_id": 106011,
        "voice": "vo_adv_9064156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒什麼啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過就是一點擦傷。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是在執行",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的護衛任務而已……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵呵☆",
        "unit_id": 105811,
        "voice": "vo_adv_9064156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留也真是的，竟然在害羞～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然有點被嚇到，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過我們打倒了魔物，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n食材也都到手了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是太好了呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是啊。",
        "unit_id": 126013,
        "voice": "vo_adv_9064156_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "雖然魔物也可以吃這件事，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n起初讓我感到很驚訝，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不過可以一石二鳥真是方便。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n感謝貪吃佩可小姐",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "告訴我這麼棒的資訊♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可、",
        "unit_id": 106011,
        "voice": "vo_adv_9064156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可璃亞……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不僅吃野菜，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然還學會了吃魔物。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳這孩子……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不知道妳以前遭遇過什麼，",
        "unit_id": 106011,
        "voice": "vo_adv_9064156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但現在已經可以不用勉強自己了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請妳好好吃正常的食物！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃過苦的人更是要好好對待自己！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦……？",
        "unit_id": 126013,
        "voice": "vo_adv_9064156_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n勉強？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "吃苦？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "妳在說什麼啊？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還、",
        "unit_id": 106011,
        "voice": "vo_adv_9064156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有什麼，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說妳……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳之所以會這麼了解野菜，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就是因為妳曾經有過飢荒貧困的時期，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……",
        "unit_id": 126013,
        "voice": "vo_adv_9064156_008"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n討厭，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "凱留小姐妳也真是的。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n事情不是妳想的那樣的。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我會這麼了解野菜，",
        "unit_id": 126013,
        "voice": "vo_adv_9064156_009"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n是因為我一直跟在祖母旁邊學習。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我祖母她有一座很大的溫室。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼……！",
        "unit_id": 106011,
        "voice": "vo_adv_9064156_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "祖母……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n懂、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "懂得吃野菜這件事，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來都是老奶奶的智慧嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼嘛！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "害我還那麼擔心～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵呵，",
        "unit_id": 126013,
        "voice": "vo_adv_9064156_011"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "抱歉讓妳擔心了。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n不過妳的這份心意，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真的讓我很感動……♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對了！",
        "unit_id": 126013,
        "voice": "vo_adv_9064156_012"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "為了表達歉意，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n今天晚上就來道",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "用狗尾草煮的草本湯如何？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "狗尾草？",
        "unit_id": 106011,
        "voice": "vo_adv_9064156_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒聽過的東西。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嚐起來是什麼味道？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "味道類似大麥或番茶。",
        "unit_id": 105911,
        "voice": "vo_adv_9064156_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又叫做……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "逗貓草。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "逗貓草！？",
        "unit_id": 106011,
        "voice": "vo_adv_9064156_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可璃亞妳這傢伙……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳是不是把我當貓了！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳當我是貓吧～！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我怎麼會呢？",
        "unit_id": 126013,
        "voice": "vo_adv_9064156_016"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我只是覺得",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "凱留小姐妳好可愛而已♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n……呵呵呵♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_9064156_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n徹底被玩弄於股掌之間呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到",
        "unit_id": 105811,
        "voice": "vo_adv_9064156_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可璃亞還蠻厲害的呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼一來，就是可璃亞和我之間的",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "疼愛小凱留比賽了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我不會輸的喔～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不准展開那種比賽～！！",
        "unit_id": 106011,
        "voice": "vo_adv_9064156_019"
    }
]