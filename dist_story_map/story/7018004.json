[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了尋找出口而在露娜之塔內四處走動的{player}等人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在稍作休息。"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉……",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我明明是想幫這位的忙，",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "盡量報答他的恩情……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n最後卻讓大家陪著沒用的我，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是本末倒置啊……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且在剛才的戰鬥中……",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我總覺得",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "自己的魔法好像失控了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果原因在於我體內的惡靈，",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我是不是別和大家待在一起比較好……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鈴莓，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n妳絕對不可以",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想著要獨自行動喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍……",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿嘿，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "被妳看穿了啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一煩惱起來",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就老是在想些消極的事情，我這樣不行啊……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我很害怕……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "害怕要是傷害到重要的人，我該怎麼辦才好。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "至今犯了許多冒失的錯誤。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是我第一次因為自己的冒失，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而讓大家身陷在危險之中……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這樣簡直",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就像瘟神啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鈴莓，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請妳別說這種讓人傷心的話。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在我感到沮喪時，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n鈴莓給予了我",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好吃的餐點，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "美好的笑容",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "及話語。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "瘟神",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是不會讓我打起精神的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳不是什麼瘟神，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "絕對不是。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍……",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿嘿，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝妳。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太好了，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鈴莓露出笑容了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣還是什麼都沒有解決。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n為了拯救鈴莓……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "已經只剩下這個方法了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍，",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_011"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n本大爺照妳說的，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "把那個花心又個性惡劣的可惡小伙子叫來了。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你別這麼不高興啦。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哼……",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_013"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n只依靠本大爺也就算了，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "為什麼要找這傢伙一起來？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n啊，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "果然還是很讓人火大！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "本大爺馬上就來把你詛咒到死！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "拜託你。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n為了拯救鈴莓，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請你幫我吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為了讓那個儀式成功……",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}和",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸的力量是不可或缺的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗯嗯？",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_016"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "儀式？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n慢著慢著，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "本大爺開始有種不好的預感了！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n本大爺可是反對的喔！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……我什麼都還沒說啊。",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_017"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "為了拯救女僕妹妹，",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_018"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳是想執行危險的儀式吧！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n就算這是可愛女兒的請求，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "本大爺也不願意幫忙！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n絕對是",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "No！！！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸……",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_019"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗚……",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_020"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "瞧妳淚眼汪汪的！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這樣太詐了，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n本大爺剛才也是因為這樣，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "才不小心把這個小伙子帶過來的，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n但這次攸關妳的性命！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我絕對不會同意的！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你說我淚眼汪汪……",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但我沒有那個意思啊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也不能因此放棄。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也要拜託",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "父親說",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「攸關我的性命」，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但這麼說有點太誇張了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但以需要把我的瑪那",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "使用到瀕臨極限這點來說，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可能是很危險……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……那個，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你為什麼要別開視線？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你不願意",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幫忙嗎……？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔哇哇！？",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_025"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n臉，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "臉！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳的臉和小伙子靠得很近耶！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n小伙子，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你也趕快給本大爺離遠一點！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍，",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_026"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳冷靜一點啦。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n實在不需要做到這個地步吧！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這跟有沒有需要",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "無關。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n鈴莓",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幫助了我。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且她還不顧自己的安危……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "比起受傷的自己，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她先擔心的卻是毫髮無傷的我，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n還說我平安無事真是太好了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "輪到我來幫助",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這麼溫柔的人了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我只是想這麼做而已……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "再說，爸爸，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鈴莓",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是我的救命恩人喔？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n爸爸不會對",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幫助女兒的恩人",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "見死不救吧？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "本、",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_030"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "本大爺是很清楚這一點啦……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n但",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "只讓妳一個人身陷於攸關性命的危險之中，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這果然還是……妳懂吧？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果是{player}，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n應該就能理解我的想法。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n……拜託你，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請你助我一臂之力。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "條件？",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是什麼樣的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "條件……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n……咦？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「希望妳也能使用我的瑪那」？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一起？",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是這麼回事啊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你就是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣的人。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我應該拜託你的事情……",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是「請和我一起",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "跟那個惡靈戰鬥。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n然後我們全都要",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "平安無事地離開這裡」",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……這樣才對吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊──！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是鈴莓的慘叫聲！？",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們快回去吧！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鈴莓，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n妳怎麼──",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_7018004_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "痛痛痛……",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n只是因為發生了一些事情，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我才會踩空跌倒。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂喂喂！？",
        "unit_id": 2411,
        "voice": "vo_adv_7018004_040"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳這不是全身都濕答答的嗎！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n可惡──！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "明明能清楚地看出身體的曲線，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n關鍵部分卻若隱若現的，看不到啊！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請你適可而止。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鈴莓，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳受傷了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且妳身上",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有幾道像是被魔物攻擊的傷口……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這也是跌倒時造成的？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其實是……",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我突然能夠看見那個惡靈，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "它還朝我攻了過來。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我是在那時候",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "遭到了攻擊……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但在我跌倒時，它已經消失不見了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哈啾！",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n……嗚嗚，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我開始覺得有股寒意了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝你的體貼，",
        "unit_id": 102511,
        "voice": "vo_adv_7018004_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是抱歉……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你果然很溫柔呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……惡靈開始表現出對鈴莓的殺意了。",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_046"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是很危險的狀態。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "各位，",
        "unit_id": 103111,
        "voice": "vo_adv_7018004_047"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們快去尋找寬闊的地方吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n要在那裡開始儀式。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了與惡靈展開最終決戰，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}等人在露娜之塔做起了準備。"
    }
