        "voice": "vo_adv_1028009_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就說了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那些事跟現在沒有關係嘛。",
