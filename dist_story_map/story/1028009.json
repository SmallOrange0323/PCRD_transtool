    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉……",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正大概是以為我是什麼都不懂的貴族大小姐，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n想要隨便找個理由，來便宜買下這些商品吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為了今後著想，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我還是別繼續跟這種人往來比較好吧。",
