[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}走在街上時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聽見通訊魔法設施裡傳來了耳熟的聲音。"
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以請你再說一次嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來如此。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "下訂數量其實是之前我聽到的兩倍",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這句話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看來並不是我聽錯了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我沒有說交不出來。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會好好在交件期限之前準備妥善的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n好，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等交件時再聯絡。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我就",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先失陪了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在這種緊要關頭把下訂數量加倍？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n而且還說一開始就是訂那麼多？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我根本沒聽說啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "趁人之危……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀，是{player}。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "被你撞見不開心的場面了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒什麼啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是交易時",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "出了一點問題罷了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有時總會有人",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "覺得我是靠父親大人的人脈在做生意，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "故意來找麻煩。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的很沒禮貌耶。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒有啦，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟你說這些",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也不是辦法。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有時間在這邊抱怨，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不如趕快去取得追加的貨物。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼突然，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要找業者進貨也很難吧，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只能直接去採集了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼靠爸媽，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是能依靠的話",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我倒想試試看呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我給不了你太多報酬喔？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別跟我說你不需要酬勞。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想想……",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那你採集到的份",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓我買下來。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就這麼辦吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會用跟付給業者一樣的金額",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來跟你買的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "交件期限是今天傍晚，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "已經沒時間了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們趕快出發吧。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抵達目的地了，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我大致跟你說明一下。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我想要你",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幫我採集這座森林裡",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "結成的果實。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼說來",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我之前也有和你一起來過這裡呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然那時候",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "冒出了一堆蟲子很累人，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這次",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也沒有撒什麼藥劑，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該能平安無事地……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來沒那麼簡單呢！",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_012"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是來吃果實的魔物嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然不強，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但要一邊打倒魔物，一邊採集果實也是很麻煩呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然說讓我去打倒魔物，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你去採集果實，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣應該會比較有效率，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但要找到那種果實",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "需要技巧……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又冒出來了！",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的很麻煩耶！",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你做得不錯嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然如此，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "改成我去採集果實，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你去打倒魔物好像也行。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你覺得這樣如何？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那你的酬勞就改成為護衛費用吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要好好保護我喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我很看好你的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又出現了！",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拜託你了！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你幫了我一個大忙。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "多虧有你在，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也順利採集到果實，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "差不多可以回去了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，我說你啊。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你的臉上有擦傷，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓我看看。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "擦上這個藥膏，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嘿。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣就沒事了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只是擦傷，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該很快就會好的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這不是需要道謝的事啦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過話又說來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真沒想到以前被蟲追",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就慌慌張張的你，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n現在居然會變得這麼可靠呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不可以因為那種程度的敵人而受傷喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你要是覺得危險，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不用客氣儘管來依賴我吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "稍微讓我",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "擔心你一下嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟那是你為了保護我而受的傷啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然這次你沒事，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但會痛的時候就要說會痛喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "忍耐是不好的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那樣只會使周遭的人更擔心你而已。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "傷口也處理好了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就去交貨吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們有湊齊數量，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這下對方可沒話說了吧。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我有準備好你說的數量。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n請你確認。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "唔嗯……",
        "unit_id": 511,
        "voice": "vo_adv_1028009_028"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "確實數量是剛好，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "但品質方面又如何呢？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "品質也沒有問題喔。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我有好好在採集時一邊確認品質。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "究竟貴族大小姐",
        "unit_id": 511,
        "voice": "vo_adv_1028009_030"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "有沒有辦法好好做出判斷呢？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "哦，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這顆果實上不都是污漬嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n這也是，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這顆也是。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "有這麼多的不良品！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該沒有什麼污漬啊……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼嘛，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這不是污漬啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這是有熟透的果實上",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會浮現出的斑點。",
