    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等、",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你突然開始說什麼啦！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這件事跟現在在談的沒有關係吧。",
