    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "別看我這樣，",
        "unit_id": 511,
        "voice": "vo_adv_1028009_053"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我也是白手起家",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "一路爬上來的商人。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "所以那種能靠關係跟地位輕鬆做生意，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "甚至還把我們建立起來的事業，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n給從旁硬是搶走的那群貴族，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我真是恨死了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "所以",
        "unit_id": 511,
        "voice": "vo_adv_1028009_054"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我才以為咲戀小姐妳也是會做那種事的人，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "忍不住就找了妳麻煩……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我真的很抱歉！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不在意啦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_055"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟這種事",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也不是第一次了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我想也是。",
        "unit_id": 511,
        "voice": "vo_adv_1028009_056"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "但",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "畢竟我也是一介商人。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n不只是口頭上道歉，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我要用行為來表達歉意。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "行為？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼意思？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這次的交易，",
        "unit_id": 511,
        "voice": "vo_adv_1028009_058"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我用市場價格的三倍來跟妳買下來。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣我是會很高興啦……",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但你不就會",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大虧損了嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "無所謂。",
        "unit_id": 511,
        "voice": "vo_adv_1028009_060"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "但",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我有個請求。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n如果妳願意，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "能請妳繼續跟我做生意嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "當然",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "今後我會全都以正當價格來跟妳交易的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這……",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說的也是。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n對我來說，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正經的生意對象能增加也是好事，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "務必想拜託你。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "謝謝妳！",
        "unit_id": 511,
        "voice": "vo_adv_1028009_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你今後不可以再找人麻煩了喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算對我以外的那些貴族也一樣。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這",
        "unit_id": 511,
        "voice": "vo_adv_1028009_064"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我知道了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那這筆交易就成立了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_065"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n今後也請你多多光顧囉。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉～～～",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_066"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n總覺得真是累壞了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才不是什麼",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_067"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「辛苦妳了」！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我這份疲勞，有一半以上",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都是你造成的！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還不是你在那邊說一些",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_068"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有關我無關緊要的情報。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "害我害羞到不行。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你的行為舉止，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_069"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果在正常商人眼裡看來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n完全不值得誇獎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然訴諸於情感，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也算是一種手法。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我只想要",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_070"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "單純地用我準備的商品的品質，來跟人打交道。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是用上其他要素，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我覺得就跟那些利用貴族立場，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n恣意妄為的傢伙們",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒什麼兩樣了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_071"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這次你是有幫到我。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因為這場交易",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只靠我的做法是無法順利進行的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是你把它導向了成功。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且……",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_072"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也不可能會討厭",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "被你稱讚嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒什麼！",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_073"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正交易也順利成功了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們今天",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就吃點好吃的來慶祝吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "走在{player}前方的咲戀，她的腳步，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n感覺似乎比平時還要輕盈。"
    }
]