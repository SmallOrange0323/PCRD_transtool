    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "少年啊，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "你可以再多說一些嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "沒想到這個小姑娘居然就是【咲戀育幼院】的公會長。",
