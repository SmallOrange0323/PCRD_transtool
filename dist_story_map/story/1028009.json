        "voice": "vo_adv_1028009_032"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這邊的果實上的傷痕妳要怎麼說明？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是成長過程中自然會出現的，",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這傷痕",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "越細越多，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就證明它越好吃喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為沒請你採集，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以沒有跟你說明，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但我是有好好選擇高品質的果實",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在摘取的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過還真奇怪呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你平時就有在交易這種果實，居然會不知道這些事。",
