        "voice": "vo_adv_1028009_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "趕快結束交易……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "不，",
        "unit_id": 511,
        "voice": "vo_adv_1028009_045"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "既然是好眼光的商人的情報，聽了我也沒損失。",
