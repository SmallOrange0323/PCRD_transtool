    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我想知道",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "妳有沒有好好用自己的眼光選擇商品。",
