        "voice": "vo_adv_1028009_048"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在做生意時，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把這些事拿出來講也沒用啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "確實，小姑娘，",
        "unit_id": 511,
        "voice": "vo_adv_1028009_049"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "不，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "咲戀小姐妳說的沒錯。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n但是",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我倒覺得能聽到妳的事蹟，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "真是太好了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_050"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "咲戀小姐這麼聰明，",
        "unit_id": 511,
        "voice": "vo_adv_1028009_051"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n應該有察覺到我是",
