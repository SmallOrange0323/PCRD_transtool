    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "趕快",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "結束交易吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼？",
        "unit_id": 102811,
        "voice": "vo_adv_1028009_040"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "什、",
        "unit_id": 511,
        "voice": "vo_adv_1028009_041"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "什麼跟什麼啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "突然說這些有的沒的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n嗯，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "什麼？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "是嗎，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "是嗎是嗎……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "原來有關橄欖的買賣，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "是這個小姑娘開始的啊！",
