    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【美食殿堂】吃遍之旅……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吼唷，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡到底是怎樣啦～！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好高！",
        "unit_id": 106012,
        "voice": "vo_adv_4003013_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太高了啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼會有城堡在這麼高的地方呀！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "掉下去不就完蛋了嗎！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留♪",
        "unit_id": 105812,
        "voice": "vo_adv_4003013_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳就是往下看才會害怕啦～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算這裡這麼高，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們不也一路",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冒險過來了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也許是那樣沒錯啦……",
        "unit_id": 106012,
        "voice": "vo_adv_4003013_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼可蘿仔一臉沒事的樣子呀！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我確實",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也感到害怕，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是比起那個……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一想到我們好像現在伸手就能碰到星星，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我內心就忍不住激動起來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿真是浪漫主義者呢！",
        "unit_id": 105812,
        "voice": "vo_adv_4003013_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咻咻♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這、",
        "unit_id": 106012,
        "voice": "vo_adv_4003013_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個小鬼頭……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽說這裡是",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈和",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "神聖的存在",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聚集之地──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過如果沒有跟【墨丘利財團】他們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "借飛空艇，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n打從一開始就不可能來到這裡呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多虧有主人助一臂之力，",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次的【美食殿堂】吃遍之旅才能成行。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的非常感謝您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這裡",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "埋藏著什麼樣的美食呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個嘛……",
        "unit_id": 105812,
        "voice": "vo_adv_4003013_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也不太清楚♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過一定有很不得了的美食，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想這是錯不了的啦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿嘿～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼！？",
        "unit_id": 106012,
        "voice": "vo_adv_4003013_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以妳明明沒搞清楚",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還拉我來這麼危險的地方！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的會宰了妳喔！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真有貪吃佩可小姐的風格呢……",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下記得",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "古文書上有記載：",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n「克服試鍊者",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應可獲得",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n甜美之獎勵。」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「甜美之獎勵」……",
        "unit_id": 105812,
        "voice": "vo_adv_4003013_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那一定是指甜甜的、吃下去連身體都會融化的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n甜點呀～！！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要隨便亂講呀，",
        "unit_id": 106012,
        "voice": "vo_adv_4003013_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太馬虎了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那不見得是指食物吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好了，凱留小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算獎勵不是食物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不變的是這趟旅程依然",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會成為我們精彩冒險的一頁。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對呀！",
        "unit_id": 105812,
        "voice": "vo_adv_4003013_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "走，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們打起精神出發吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等、",
        "unit_id": 106012,
        "voice": "vo_adv_4003013_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，妳們幾個！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦，去就去嘛！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等我一下！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼，",
        "unit_id": 106012,
        "voice": "vo_adv_4003013_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們爬了好一大段了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過這地方",
        "unit_id": 105812,
        "voice": "vo_adv_4003013_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是越看",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "越不可思議耶～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟是這麼廣闊的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一片土地飄在空中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "建築相當古老了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也看不到有管理人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻充滿了莊嚴的氣息。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "古文書說的",
        "unit_id": 105913,
        "voice": "vo_adv_4003013_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈和神聖的存在",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聚集之地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這點看來是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正確的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相信這裡真的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n埋藏著「甜美的獎勵」。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧，小可蘿！",
        "unit_id": 105812,
        "voice": "vo_adv_4003013_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我看那一定是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "遠遠超越我們過去吃過的美食的極致甜點喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 106012,
        "voice": "vo_adv_4003013_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都說了不知道是不是食物吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別亂下定論啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說這種話沒關係嗎～",
        "unit_id": 105812,
        "voice": "vo_adv_4003013_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請想像看看……",
