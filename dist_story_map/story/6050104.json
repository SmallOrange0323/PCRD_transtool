    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯～",
        "unit_id": 113911,
        "voice": "vo_adv_6050104_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎覺得那個組長，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還是應該說那個鬼魂教父？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n給人一種非常討厭的感覺呢－－",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看他把那些孩子們當成笨蛋就很讓人火大呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "師、",
        "unit_id": 113911,
        "voice": "vo_adv_6050104_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "師傅？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你在說什麼啊？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不是那麼一回事啦！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我只是",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為那些孩子拜託所以才負責……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該不會我不知不覺變成他們師傅了？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不是吧？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說的也是呢！",
        "unit_id": 113911,
        "voice": "vo_adv_6050104_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "絮絮叨叨的也沒用！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那種傢伙就只能靠結果讓他刮目相看了！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生偶爾也會提出不錯的建議嘛。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "偶爾。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你怎麼可以害怕啦。",
        "unit_id": 113911,
        "voice": "vo_adv_6050104_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那種傢伙就要",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n堅定地面對他才行……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可怕是指",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛剛的我？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哈哈哈，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭啦騎士先生，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我不知道你在說什麼呢～",
        "unit_id": 113911
    }
]