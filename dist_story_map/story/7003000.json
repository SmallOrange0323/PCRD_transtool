[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇啊啊……",
        "unit_id": 101611,
        "voice": "vo_adv_7003000_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好厲害的一座塔啊，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是看不到頂端的那種？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超有趣的～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那就是露娜之塔了，",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是有夠大了呢……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "歌詞的靈感不斷湧現出來了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "得趕緊記下來！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才",
        "unit_id": 101611,
        "voice": "vo_adv_7003000_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你的記憶就在那裡了對吧。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天就由我們來好好幫幫你了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "受了你不少的照顧，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "至少也該讓我報答你一下才對。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "話是這麼說，",
        "unit_id": 101611,
        "voice": "vo_adv_7003000_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我還真沒想到\n【慈樂之音】的望望居然和秀才認識呢。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真是嚇我一跳～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也是啊。",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒想到超級模特兒鈴奈\n和{player}互相認識呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵。",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和{player}在一起",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n真的會發生很多事情呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在認識的服飾店裡",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看到你準備開始工作，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n過去一看",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就見到{player}和鈴奈\n一面談笑風聲――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之後不一會兒便一起來探險了呢。",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是嚇了我一跳。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……想說不知怎麼回事，",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈\n還取了一個這麼可愛的稱呼。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可愛的稱呼，",
        "unit_id": 101611,
        "voice": "vo_adv_7003000_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是說秀才嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒錯沒錯，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是那個。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不愧是望望，",
        "unit_id": 101611,
        "voice": "vo_adv_7003000_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你知道秀才的好對吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "果然就是秀才對吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102911,
        "voice": "vo_adv_7003000_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊、",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　我就覺得是秀才嘛！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到、",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到底是什麼意思啊……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好了秀才，",
        "unit_id": 101611,
        "voice": "vo_adv_7003000_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "走吧走吧♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n包在我身上！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "讓我來幫秀才",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "找回記憶吧！",
        "unit_id": 101611
    }
]