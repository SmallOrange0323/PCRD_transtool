[
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我到最後",
        "unit_id": 113712,
        "voice": "vo_adv_6048107_000"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "都不是很了解雪……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n她到底是什麼人呢？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "也、",
        "unit_id": 113712,
        "voice": "vo_adv_6048107_001"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "也是啦！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "如果長得那麼漂亮，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "連她捉摸不定之處",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n也會讓人覺得很有魅力呢。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "真的",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "是個不可思議的人啊！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "總覺得雪給人的印象很不受拘束，",
        "unit_id": 113712,
        "voice": "vo_adv_6048107_002"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "竟然有加入公會啊。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "但是她",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那個樣子能夠好好參加公會活動嗎？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n雖然不關我的事，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "還是有點擔心呢！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這、",
        "unit_id": 113712,
        "voice": "vo_adv_6048107_003"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這樣啊……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不過就算是朋友，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "也並不是非得要\n將一切了解到鉅細靡遺吧？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "說不定反而有那種",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n正是因為不知道才持續下去的友誼呢！",
        "unit_id": 113712
    }
]