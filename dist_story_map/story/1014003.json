[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那麼，調查要開始囉，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們要",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "針對城裡最近發生的怪現象……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所謂「闇影」做調查喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是從你現在貌似正在叨擾的，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n【咲戀育幼院】提出來的委託唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為孩子都很害怕，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n因此希望能夠解決這個事件。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就算無法解決，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也希望至少能查明真相……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了保護孩子們的笑容。",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是件十分有價值的工作呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然而，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說來慚愧……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n對於「闇影」，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在仍然幾乎一無所知。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "儘管持續好一段時間，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n每天",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都以踏破鐵鞋的決心去調查了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在過去似乎也沒有過",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "類似的奇怪案例。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真可說是前所未聞，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "又讓人毫無頭緒的事件呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "姑且再和你說明一次吧，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有關這事件的概要。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」是最近，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這座城市……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "僅在蘭德索爾裡",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被目擊過的一種奇妙存在。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然被認為",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是一種魔物，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但仍是無法確定。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為主要出沒的時間點",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "與被目擊的情況都在夜晚，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以也被認為是鬼怪呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也耳聞有勇敢之人試圖與之戰鬥，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然而最後卻好像都沒什麼顯著的效果。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "正如其名所示，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像是影子一般的存在呢。",
        "unit_id": 101411
    },
    {
        "type": "still",
        "still": "200300402"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並且這個「闇影」，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n似乎常常以目擊者所認識的人的樣貌現身。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "外觀幾乎一模一樣，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n乍看之下幾乎無法區別唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽說雙眼還會閃著詭異光芒，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n而且全身上下纏繞著不明黑霧……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並有著朦朧幻變的輪廓呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後是",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "毫無例外地皆會反覆著相同的行為，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n並且複誦著同樣",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "意義不明的台詞的樣子。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以有著「他們缺乏智慧以及思考能力」",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這種普遍認知。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果只是這樣的存在，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說實話是無害的呢。",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然有點恐怖……",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但「闇影」還有過危害過他人的案例，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以也不能擱著不管了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n說來你也親身目擊過呢，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n聽說當時",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還演變成了戰鬥。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你的那份經歷，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也算是我會選你當助手的……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "理由之一。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對我來說，只是在遠處輕瞥過一眼的程度，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對於「闇影」到底是怎樣的東西，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "仍沒有什麼實感。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若不介意的話，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n希望你能把跟「闇影」接觸時的情況",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "詳細地告訴我。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很抱歉問得這麼籠統，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但那是什麼感覺呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔呣，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真誠實呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然一點參考價值都沒有。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也不用這麼消沉啦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "遭到「闇影」襲擊時，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n根本沒有辦法能夠冷靜觀察呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣啊……",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那是實際上",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有親身目擊過「闇影」的人，共同的感想呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然不知道為什麼，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但「闇影」似乎會讓見到的人，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "特別感到惶恐不安喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "像是侵蝕了精神一般，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n似乎會為人帶來某種獨有的恐懼感。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會使人心神不寧、",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "驚慌失措，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也或許是散發了某種特殊的魔力也說不定呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總而言之。",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n「闇影」會主動襲擊人類的案例，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "其實相當稀少。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟那東西幾乎沒有意志，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以一般不會自主性的行動。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而你卻被那「闇影」給襲擊過，",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n可是為數不多的例外呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」襲擊人類的原因",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然還不明確，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但我認為會再找上同一個人的可能性相當高。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014003_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯沒錯，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然把你當餌有點過意不去……",
