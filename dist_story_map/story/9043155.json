        "voice": "vo_adv_9043155_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是為了餵飽小孩子所以才強行外出狩獵吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106011,
        "voice": "vo_adv_9043155_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們還悠悠哉哉的幹嘛！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "身為家長的魔物來了啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是想要保護小孩子吧，",
        "unit_id": 105911,
        "voice": "vo_adv_9043155_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠看起來相當地生氣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然襲擊過來了，",
        "unit_id": 105811,
        "voice": "vo_adv_9043155_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就只能應戰了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來吧，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一決勝負！",
        "unit_id": 105811
    }
