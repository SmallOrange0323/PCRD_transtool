        "voice": "vo_adv_9043155_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠不管怎麼想都是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……",
        "unit_id": 105911,
        "voice": "vo_adv_9043155_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛剛的魔物……",
