        "voice": "vo_adv_9043155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳從剛剛就在東張西望些什麼呀？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9043155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要突然摸我脖子啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很冰耶！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……什麼東張西望，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是在注意有沒有魔物啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀，",
        "unit_id": 105811,
        "voice": "vo_adv_9043155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳太愛操心了啦☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是妳什麼都沒在想而已吧！",
        "unit_id": 106011,
        "voice": "vo_adv_9043155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再多抱持一點警覺心啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位……",
        "unit_id": 105911,
        "voice": "vo_adv_9043155_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都請小心一點。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這棵樹上有魔物的爪痕……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這附近",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "恐怕已經是魔物的地盤了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂、",
        "unit_id": 106011,
        "voice": "vo_adv_9043155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那不就真的慘了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拜託妳們兩個好好提高警覺喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊啊！",
        "unit_id": 105811,
        "voice": "vo_adv_9043155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9043155_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎怎怎、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼了？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有魔物！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們看，小凱留！",
        "unit_id": 105811,
        "voice": "vo_adv_9043155_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我發現一隻好可愛的狗狗！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "狗、",
        "unit_id": 106011,
        "voice": "vo_adv_9043155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "狗狗？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦，",
        "unit_id": 105911,
        "voice": "vo_adv_9043155_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實如此。",
        "unit_id": 105911
