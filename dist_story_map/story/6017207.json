[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "問這個有點突然，",
        "unit_id": 109711,
        "voice": "vo_adv_6017207_000"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可否請你說幾個姊姊的優點。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "如果你說錯了……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可要對自己說的話負責喔。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這個答案還可以。",
        "unit_id": 109711,
        "voice": "vo_adv_6017207_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那讓人難以望其項背的囂張態度，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "總是讓雷姆佩服不已。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n為了讓姊姊能夠一直維持這種不加掩飾的真實模樣，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆以後也會繼續努力。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "答得真好！",
        "unit_id": 109711,
        "voice": "vo_adv_6017207_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆會連姊姊的工作也一起完成，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n好好照顧姊姊。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不論是以女僕或是以妹妹的角度來看，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "能夠如此帶給別人成就感，真的很了不起。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "你真有眼光！",
        "unit_id": 109711,
        "voice": "vo_adv_6017207_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n不論是什麼樣的難題，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "姊姊總是能用她的開朗打破僵局……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "所以我們現在才能像這樣",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "受到各位的照顧。",
        "unit_id": 109711
    }
]