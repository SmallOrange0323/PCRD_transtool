[
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呼、",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_000"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呼……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗚……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "搞、",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "搞砸了……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n我竟然在這種到處充滿著危險的世界，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n跟姊姊她們",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "走散……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "只有我一個人，",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "一旦遇到魔物，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n馬上就會被當成點心吃掉，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "連骨頭都被啃得精光啊。",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "怎、",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "怎麼辦……？",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──沙沙沙！"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "咿咿咿咿！！",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_003"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n才剛說完魔物就出現了！？",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "小樂",
        "words": "噗嗚！？",
        "unit_id": 9511,
        "voice": "vo_adv_9067157_004"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "咦……",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_005"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "發現了。",
        "unit_id": 126113,
        "voice": "vo_adv_9067157_006"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n獵物。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦，",
        "unit_id": 126013,
        "voice": "vo_adv_9067157_007"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "奇怪？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n普蕾西亞，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這人是……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您是",
        "unit_id": 125813,
        "voice": "vo_adv_9067157_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "【蠻賊三姊妹】的次女……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n記得是叫",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "若菜小姐對吧。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想跟妹妹的布武機一樣，",
        "unit_id": 106011,
        "voice": "vo_adv_9067157_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一個人單挑我們是嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就把妳片成三片，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓白癡公主把妳連骨頭都啃得精光！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水……☆",
        "unit_id": 105811,
        "voice": "vo_adv_9067157_010"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "噫欸欸欸～！！",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_011"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n我不是點心啦～！？",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先等一下，",
        "unit_id": 105911,
        "voice": "vo_adv_9067157_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐跟貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來若菜小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並沒有要挑起事端的樣子。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……確實呢。",
        "unit_id": 125813,
        "voice": "vo_adv_9067157_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "至今為止",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "戰鬥的",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "主要都是長女跟三女，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n感覺若菜小姐似乎",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "只是在一旁看著。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不僅如此，",
        "unit_id": 126013,
        "voice": "vo_adv_9067157_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好像還被當成肉盾……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對、",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_015"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對啊。",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "所以說，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "拜託請不要吃我……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n而且我吃起來",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "大概不會好吃喔？",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然不會吃掉您……",
        "unit_id": 105911,
        "voice": "vo_adv_9067157_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但畢竟您是敵人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請恕我們拘捕您。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊……",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_017"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n或、",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "或許對我來說反而是求之不得呢……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不然我一個人，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "會被魔物襲擊咬掉頭……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼放心好嗎～",
        "unit_id": 106011,
        "voice": "vo_adv_9067157_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們這裡",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有一群比魔物更糟糕的貪吃鬼在。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞不好會趁妳睡覺時",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咬掉妳的頭也說不定喔～？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可、普蕾西亞",
        "words": "流口水……☆",
        "unit_id": 1,
        "voice": "vo_adv_9067157_019"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不要啊啊啊～！？",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_020"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n救命～～！！",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "刺蝟型魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 50311
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "咦！？",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_021"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n是、",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是小車輪們！？",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那些巨大的刺蝟，",
        "unit_id": 126013,
        "voice": "vo_adv_9067157_022"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n就是先前充當「蠻賊貪鯊號」車輪的刺蝟們吧？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "怎麼好像",
        "unit_id": 125813,
        "voice": "vo_adv_9067157_023"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常生氣的樣子……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "難道是認為",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我們在欺負若菜小姐……？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "刺蝟們朝這裡",
        "unit_id": 105911,
        "voice": "vo_adv_9067157_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "滾過來了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請準備迎戰！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "小構架、",
        "unit_id": 130111,
        "voice": "vo_adv_9067157_025"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "小墊木，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "還有小龐克！",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n大、",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "大家住手啊～！",
        "unit_id": 130111
    }
]