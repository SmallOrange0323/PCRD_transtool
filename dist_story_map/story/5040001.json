[
    {
        "type": "background",
        "background": "500159"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被神秘的一行人一隻不留地帶走了所有牛隻的牧場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被一股悲傷的寂靜包圍著。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我、",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我的牛群……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我說過這是扣押。",
        "unit_id": 13311,
        "voice": "vo_adv_5040001_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我就是在問，",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼我們的牛必須遭受扣押呢？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這個牧場",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "的確因各種緣故而到處破爛不堪，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n經營也相當吃緊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但我們並沒有向任何人借錢……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀哎呀哎呀。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這話可真奇怪。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這個牧場應該欠下很多錢才對啊？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "畢竟，",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳們沒有繳交應繳給國庫的稅金啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼又來了一個怪人……",
        "unit_id": 102611,
        "voice": "vo_adv_5040001_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "請問你是哪位……？",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_006"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "我是這個地區新上任的監察官。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔～",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來是新上任的監察官大人啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n難怪我從沒見過你。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個，",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "監察官大人。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "【伊麗莎白牧場】",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然是個沒錢的公會，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但我們可沒有做出逃漏稅那種不合情理的事。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這其中是不是有什麼誤會？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "區區一個牧場主人，",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_010"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "對身為貴族的我所說的話，有什麼異議嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不是那個意思……",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_011"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "沒錯吧沒錯吧。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_012"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n畢竟做出那種事可是無法被原諒的呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "不過呢？",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_013"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "我為人寬宏大量，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "就讓我來回答妳們這些庶民的疑問吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "真正有錯的啊，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "是過去一直以來的做法呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "我上任之後，就一直在改善前任監察官遺留下來的問題，",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_014"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "他工作的做法真的是很糟糕～很糟糕啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "因為他對許多公會都沒有徵收該徵收的稅金。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_015"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n真希望能替我這個幫他到處奔走擦屁股的交接者想一想。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "對了，",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_016"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "順帶一提。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n如果妳能夠立刻把欠繳的稅繳清，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "我就馬上把家畜還給妳。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欠繳的稅額總共是多少？",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_017"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "這一份文件裡面，",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_018"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "統整了牧場所有欠繳稅金的詳細內容。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我看，",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "【伊麗莎白牧場】的欠繳金額是…………",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一千萬盧幣！？　",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這麼多！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "光看到這金額就嚇到，那可就傷腦筋了。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_021"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "請妳把整份文件看完。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你說看完，",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "意思是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "後面還寫著什麼嗎……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我看看……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "若沒有在期限前繳納一千萬盧幣，",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就要沒收【伊麗莎白牧場】…………",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒收的意思，",
        "unit_id": 103811,
        "voice": "vo_adv_5040001_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n是指整個公會都會消失嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "只要能籌到錢，",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_025"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "就不會有任何問題囉。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "妳們就好好努力去籌那些錢吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你叫我們籌錢，",
        "unit_id": 102611,
        "voice": "vo_adv_5040001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是牛被帶走，不就沒辦法賺錢了嗎！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "但除了家畜以外，根本沒有任何東西能夠當作擔保，不是嗎？",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個嘛……",
        "unit_id": 102611,
        "voice": "vo_adv_5040001_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你說得的確沒錯……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "我可是很忙的。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_029"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "那我就先失陪了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等一下！",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_030"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "半藏。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_031"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "是。",
        "unit_id": 13311,
        "voice": "vo_adv_5040001_032"
    },
    {
        "type": "background",
        "background": "500159"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇！？",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你幹什麼啊！",
        "unit_id": 102611,
        "voice": "vo_adv_5040001_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳沒事吧！？",
        "unit_id": 103811,
        "voice": "vo_adv_5040001_035"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "誰叫她打算用那骯髒的手碰我呢。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽她",
        "unit_id": 103811,
        "voice": "vo_adv_5040001_037"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一點都不髒！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒、",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒關係的，栞栞。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "才剛去賣完東西回來，所以身上才有點髒啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n抱歉，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "監察官大人。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不、",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，我想要跟你確認一下。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是不是只要籌到錢，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牛跟牧場都能恢復原狀呢？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "那當然。",
        "unit_id": 2511,
        "voice": "vo_adv_5040001_040"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "我很期待妳們能確實把稅繳清喔。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "畢竟，我也是為了國家才這麼做的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "…………他走掉了。",
        "unit_id": 102611,
        "voice": "vo_adv_5040001_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……………………",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_042"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽，",
        "unit_id": 103811,
        "voice": "vo_adv_5040001_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳還好吧？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？　",
        "unit_id": 103311,
        "voice": "vo_adv_5040001_044"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我沒事！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只是因為事情發生得太突然，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以有點\n不知所措而已啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請妳先休息一下吧。",
        "unit_id": 103811,
        "voice": "vo_adv_5040001_045"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真陽，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳的臉色好蒼白……",
