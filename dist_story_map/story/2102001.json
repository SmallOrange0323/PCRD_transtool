    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盡是些難以理解之事呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論是那名少年的目的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "亦或是方才兩位變身的姿態……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過佩可小姐，",
        "unit_id": 100111,
        "voice": "vo_adv_2102001_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像知道一些事情的樣子呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話又說回來，",
        "unit_id": 106012,
        "voice": "vo_adv_2102001_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我已經等到快不耐煩了啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們想要趕快討論那些事，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以妳們快點給我吃完啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對、",
        "unit_id": 100211,
        "voice": "vo_adv_2102001_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起～！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再等一下！　",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請再等我一下嘛，小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等我把這個香蒜義大利麵和蟹肉炒飯還有洋蔥湯",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n加上三人份的鮪魚握壽司吃完就好了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2102001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位有乖乖嚼碎，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並且吃了相當多了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是太棒了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯～！",
        "unit_id": 106414,
        "voice": "vo_adv_2102001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_2102001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請與在下一同……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "向愛梅斯大人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "獻上感謝的話語吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝招待。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝～招呆～！",
        "unit_id": 106414,
        "voice": "vo_adv_2102001_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感謝招待～♪",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣不用試毒也不用在意禮節，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能夠隨意地吃好吃的東西，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "實在太讚了啦～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哈啊……",
        "unit_id": 100211,
        "voice": "vo_adv_2102001_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n感、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "感謝招待……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣……",
        "unit_id": 100311,
        "voice": "vo_adv_2102001_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳吃了這麼多食物，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "胃沒事吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "量多到甚至都開始擔心，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳的胃會不會因此破裂了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯、",
        "unit_id": 100211,
        "voice": "vo_adv_2102001_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該沒事。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就連我自己",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都嚇了一跳……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的會嚇一跳對吧！",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我第一次使用皇家裝備的時候，也忍不住會想",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「自己的這個吃相也太不妙了吧☆」　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣呢～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是優衣",
        "unit_id": 100111,
        "voice": "vo_adv_2102001_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "應該沒有使用像佩可小姐那樣的裝備才對……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是因為什麼原因，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以才變成這樣類似的狀態",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『什麼原因』……",
        "unit_id": 105913,
        "voice": "vo_adv_2102001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若如此一說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼果然，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是方才變身成與平時截然不同樣貌……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的緣故？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_2102001_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那提升的力量真令人嘆為觀止……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～♪",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n點心吃餡蜜，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然最讚了呀～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳夠了沒！",
        "unit_id": 106012,
        "voice": "vo_adv_2102001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n趕快告訴我們了啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個嘛！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎是{player}的\n公主騎士之力成長了之後的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『公主型態』！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……的樣子唷☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『公主型態』……",
        "unit_id": 105913,
        "voice": "vo_adv_2102001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那也是主人的力量造就的東西呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，",
        "unit_id": 106012,
        "voice": "vo_adv_2102001_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個「似乎是」是什麼意思？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個名字是似似花取的。",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「沒有名字的話很麻煩對吧」她是這樣說的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "似似花……",
        "unit_id": 100211,
        "voice": "vo_adv_2102001_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n是我們和霸瞳皇帝戰鬥時，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也有出手幫助我們的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n是七冠之中",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的一個女孩子……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對吧？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似似花小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2102001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她是怎麼說的呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人如今的現況，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她是否也知曉呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我有辦法知道大家被抓起來的這件事情，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也是變化成了士兵的似似花過來告訴我的就是了……",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——幾個小時之前——"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個肉包，",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳的招待！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的非常好吃唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃……",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳來找我有什麼事嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n特地瞞過警衛的目光也要來找我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有什麼",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很重要的事情要跟我說對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是呢。",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那我就開門見山地",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這麼告訴您好了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "——這是世界的危機，",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陛下。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我想有能力能夠與之抗衡的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n或許就只有{player}而已……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n世界的危機……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗎！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且還說，",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能夠抗衡的就只有{player}一個人而已！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是那個人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在好像不是講這種事的時候耶……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起拿劍，\n現在感覺說不定奶嘴還比較適合他唷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是呢。",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我知道。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……再怎麼說。",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他現在",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還活著的此事……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就連此事，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都如同奇蹟一般了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這事您也心知肚明不是嗎，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陛下？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……！",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……說、",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的也是……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和霸瞳皇帝",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "戰鬥時……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "替我擋下了攻擊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在那個當下，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是真的還以為他死掉了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我猜，",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個『奇蹟』是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "模索路晶……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是那個拉比林斯達所寫下的劇本才是。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……然而若要使用超出所能的力量，",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "便會伴隨著代價。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n從結論來看……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在的他，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "便是靈魂本身受到了傷害的狀態。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦……？",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n靈、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "靈魂嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯。",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "靈魂。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是做為魔力根源的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "精神之核。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是能建構出闇影的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原本的型態……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也有稍微",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "試著調查了一下……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n然而目前似乎",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並無有效的治療方式。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "靈魂受到傷害這件事，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "本身就是稀有的案例……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會這樣……",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼到底",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼做，\n{player}才能變回原樣呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "基本上關於語言能力",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和判斷能力……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要重新學習，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n又或是藉由某些契機，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我認為就有可能得以修復。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若有需我來教授也是無妨……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而……",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若是要他完全恢復原貌，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想恐怕是沒那個機會了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗚……",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_044"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……但也並非只有壞事。",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他的公主騎士之力，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也變化得更加強大了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而您也親身體驗過了才是，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陛下。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……是的。",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是{player}給了我以往不曾有過的力量，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我才有辦法在霸瞳皇帝",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "全力施展的魔法下守護大家……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "成長過後的，",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他那全新的力量。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……是呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就稱之為『公主型態』吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『公主型態』……",
        "unit_id": 105812,
        "voice": "vo_adv_2102001_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今後{player}，",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還有妳們……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n務必得變得能夠自在使用那份力量才行。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這也是，為了拯救這個世界",
        "unit_id": 107011,
        "voice": "vo_adv_2102001_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011
    }
]