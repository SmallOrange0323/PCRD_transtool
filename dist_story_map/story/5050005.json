    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萬聖節活動大受歡迎，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n許許多多的遊客來到萬聖節樂園，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n紡希她們經營的鬼屋也是人潮絡繹不絕。"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "呀──────！",
        "unit_id": 1,
        "voice": "vo_adv_5050005_000"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嗚哇啊啊啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_5050005_001"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那間引起話題的鬼屋好像就是這裡呢。",
        "unit_id": 112,
        "voice": "vo_adv_5050005_002"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好期待！",
        "unit_id": 212,
        "voice": "vo_adv_5050005_003"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "快點進去吧！",
        "unit_id": 212
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "沒想到那些傢伙的鬼屋竟然會這麼受歡迎啊，",
        "unit_id": 1411,
        "voice": "vo_adv_5050005_004"
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "真是意外之喜啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "組長",
        "unit_id": 511,
        "voice": "vo_adv_5050005_005"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "是來視察的嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "嗯，正好來看看。",
        "unit_id": 1411,
        "voice": "vo_adv_5050005_006"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "生意很好，真是再好不過了。",
        "unit_id": 511,
        "voice": "vo_adv_5050005_007"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n來萬聖節樂園的遊客人數也",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "創下歷史最高紀錄了喔。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "喔？",
        "unit_id": 1411,
        "voice": "vo_adv_5050005_008"
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "這樣遊行應該也會十分熱鬧呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "我的手都癢了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "一定會舉辦一個讓人印象深刻的遊行。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "剛好，",
        "unit_id": 511,
        "voice": "vo_adv_5050005_009"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "關於這件事還有一些想討論的……",
        "unit_id": 511
    },
    {
        "type": "background",
        "background": "501140"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "各位，上午的工作都辛苦了。",
        "unit_id": 113911,
        "voice": "vo_adv_5050005_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "照這個步調下去，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該也會創下入場人數新紀錄呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "哇──！",
        "unit_id": 5712,
        "voice": "vo_adv_5050005_011"
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "好厲害，",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "大受歡迎呢！",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "\n",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "這也多虧了紡希妳們唷！",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是因為你們都非常努力喔。",
        "unit_id": 113911,
        "voice": "vo_adv_5050005_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們只是幫了點忙而已。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我覺得今天的表現",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的非常棒呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "休茲",
        "words": "我們做了什麼嗎？",
        "unit_id": 5912,
        "voice": "vo_adv_5050005_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來玩的小朋友哭出來的時候，",
        "unit_id": 114011,
        "voice": "vo_adv_5050005_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n維多不是還逗他笑了嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "那、",
        "unit_id": 5812,
        "voice": "vo_adv_5050005_015"
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "那是因為我擔心他，想要跑過去，",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "中間不小心跌倒而已啦～",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "艾迪　",
        "words": "啊──！",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_016"
    },
    {
        "type": "dialogue",
        "name": "艾迪　",
        "words": "那個的確是很好笑呢！",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "馬修也很了不起唷。",
        "unit_id": 114011,
        "voice": "vo_adv_5050005_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n沒有現身，而是偷偷地幫他照亮了路線。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "我其實是想要出來的，",
        "unit_id": 5712,
        "voice": "vo_adv_5050005_018"
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "但如果突然現身，",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "\n怕會嚇到人家……",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "休茲",
        "words": "明明鬼屋就是要來嚇人的，",
        "unit_id": 5912,
        "voice": "vo_adv_5050005_019"
    },
    {
        "type": "dialogue",
        "name": "休茲",
        "words": "真是奇怪啊！",
        "unit_id": 5912
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "說的也是啊～",
        "unit_id": 5712,
        "voice": "vo_adv_5050005_020"
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "\n不過那時候",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "總覺得不該嚇他，",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "\n",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "怎麼回事呢～",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "跟只想要嚇人的那時候相比，",
        "unit_id": 114111,
        "voice": "vo_adv_5050005_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大家都成長很多了呢！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真懷念你們被魔物嚇得四處逃竄的時候呢。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "現在的我們即使遇到魔物也能夠讓它發出悲鳴的！",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_022"
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "魔物的悲鳴，",
        "unit_id": 5812,
        "voice": "vo_adv_5050005_023"
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "好吃嗎～",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "感覺應該沒有",
        "unit_id": 5712,
        "voice": "vo_adv_5050005_024"
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "鬼屋的悲鳴好吃呢～",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這裡的悲鳴有那麼好吃嗎？",
        "unit_id": 114111,
        "voice": "vo_adv_5050005_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "光聽你們說，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我都覺得想吃了……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "好吃啊！",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_026"
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "而且還變得越來越好吃！",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "休茲",
        "words": "這是不是表示我們",
        "unit_id": 5912,
        "voice": "vo_adv_5050005_027"
    },
    {
        "type": "dialogue",
        "name": "休茲",
        "words": "成為越來越恐怖的鬼怪了啊！",
        "unit_id": 5912
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "如果我們的鬼屋都這麼好吃了，",
        "unit_id": 5712,
        "voice": "vo_adv_5050005_028"
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "\n那其他鬼屋的悲鳴說不定更好吃呢～",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還以為他們都成長了呢，",
        "unit_id": 113911,
        "voice": "vo_adv_5050005_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該說這些孩子還是老樣子",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒什麼變嗎……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "紡希？",
        "unit_id": 5712,
        "voice": "vo_adv_5050005_030"
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "妳說了什麼嗎？",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒事啦，",
        "unit_id": 113911,
        "voice": "vo_adv_5050005_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n好了，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們差不多可以中場休息囉。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "太好了！",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_032"
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "那我們就立刻去玩吧！",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "休茲",
        "words": "本大爺累了，要先睡個午覺──",
        "unit_id": 5912,
        "voice": "vo_adv_5050005_033"
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "我還想要練習一下，",
        "unit_id": 5712,
        "voice": "vo_adv_5050005_034"
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "今天就不去了。",
        "unit_id": 5712
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "什麼嘛，大家都很不配合耶～",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_035"
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "\n",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "維多，",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "你會跟我一起來吧？",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "我是想去啦，",
        "unit_id": 5812,
        "voice": "vo_adv_5050005_036"
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "可是……",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "去好好監視艾迪，",
        "unit_id": 113911,
        "voice": "vo_adv_5050005_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不要讓他玩過頭囉。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "……！",
        "unit_id": 5812,
        "voice": "vo_adv_5050005_038"
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "\n",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "嗯！",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "我知道了！",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "嘖！",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_039"
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "什麼態度嘛。",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "\n",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "算了，沒關係。",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "反正也徵得紡希同意了，",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "走吧維多──！",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "啊～",
        "unit_id": 5812,
        "voice": "vo_adv_5050005_040"
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "等等我啦～",
        "unit_id": 5812
    },
    {
        "type": "background",
        "background": "501130"
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "接～",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_041"
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "下來，",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "要去哪裡呢？",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "不、",
        "unit_id": 5812,
        "voice": "vo_adv_5050005_042"
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "不可以",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "玩過頭喔。",
        "unit_id": 5812
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "我知道了啦！",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_043"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇啊──────！！",
        "unit_id": 1,
        "voice": "vo_adv_5050005_044"
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "好悽慘的悲鳴……",
        "unit_id": 5812,
        "voice": "vo_adv_5050005_045"
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "我還以為我們都成長了，",
        "unit_id": 6012,
        "voice": "vo_adv_5050005_046"
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "\n結果根本沒讓客人發出過那樣的悲鳴啊，",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "艾迪",
        "words": "去看看吧！",
        "unit_id": 6012
    },
    {
        "type": "dialogue",
        "name": "維多",
        "words": "啊，",
