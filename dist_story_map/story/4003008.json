[
    {
        "type": "background",
        "background": "500406"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼……",
        "unit_id": 105812,
        "voice": "vo_adv_4003008_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可真是見面更勝聞名的難關呢，這『蒼海孤塔』！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有一大堆一踩上去就瞬間沒命的地雷呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過呢，不管是怎麼樣，能夠攻略完成就好了。",
        "unit_id": 105812,
        "voice": "vo_adv_4003008_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要結局好就是萬事 OK 的☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_4003008_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大概都習慣了呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種艱困的吃遍之旅。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過說起來，得到的重要食材都沒事吧？",
        "unit_id": 105913,
        "voice": "vo_adv_4003008_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "路上還幾度被爆炸波及，有點擔心呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事的啦，我有用魔法先保護起來。",
        "unit_id": 106012,
        "voice": "vo_adv_4003008_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這種連神都會上癮的珍品食材，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "令人期待享用的時刻～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個～……剛才就覺得氣氛有點怪。",
        "unit_id": 105812,
        "voice": "vo_adv_4003008_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難道說是神被搶走期待著享用的食材，所以生氣了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你看，雷雲都在響呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，不會吧……只是湊巧的吧？",
        "unit_id": 106012,
        "voice": "vo_adv_4003008_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說什麼神的，也只是傳說吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總，總之我們先避難吧。",
        "unit_id": 105913,
        "voice": "vo_adv_4003008_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "千辛萬苦攻略了祕境，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n卻干犯天忌遭到全滅～可不想要落的這種結局啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，沒嘗過這些珍品食材之前可不能死的喔！",
        "unit_id": 105812,
        "voice": "vo_adv_4003008_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位跑起來逃命吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快快快快快快♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喔喲，老是這樣子……",
        "unit_id": 106012,
        "voice": "vo_adv_4003008_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就不能正常點，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n直接到附近的攤子逛兩圈過過癮就好嗎？",
        "unit_id": 106012
    }
]