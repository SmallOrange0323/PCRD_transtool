[
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你問我如果有了小孩，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "會想為他們做什麼……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "現在就討論這個還太早了吧。",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不過，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我並不討厭想這些事情唷。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對於今後的生活懷抱著夢想不也很好嗎♪",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我想想，",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是我的話……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我果然會想在新年或七五三節",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "替孩子盛裝打扮，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n慶祝孩子每年的成長吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然，",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "生日也要慶祝。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但不光是生日，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也想要好好",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n重視每個節日的習俗活動。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等到孩子長大後，",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哪天就會突然回想起來這些事情。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "屆時就會想說",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "自己小時候……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "爸媽有好好幫我慶祝過呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "從孩子的角度來看，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "或許會覺得明明沒主動拜託，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "卻要被強迫穿上那麼不便的衣服很麻煩。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我自己也是長大以後，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "才理解這些事情的好。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且如果只論新年的話，",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我很憧憬在那時期",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "才會有的家族團圓。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在我家，",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大家很少有機會能聚在一起。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然我倒也沒有因此而覺得寂寞，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但要是自己有了孩子，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想多陪陪自己的孩子玩。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一起打板羽球、",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "玩歌牌、打陀螺……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我們一起",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "教孩子怎麼玩這些遊戲。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後，",
        "unit_id": 127612,
        "voice": "vo_adv_5128084_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等到哪天孩子長大結婚生子，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n再來就換我們的孩子教孫子怎麼玩。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……你不覺得這樣的傳承",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "很棒嗎？",
        "unit_id": 127612
    }
]