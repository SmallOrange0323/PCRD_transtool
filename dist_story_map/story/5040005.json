[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為抓到懸賞犯"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而得到一筆意外收入的真陽和鈴，興奮不已地"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到了咲戀育幼院。"
    },
    {
        "type": "dialogue",
        "name": "真陽、鈴",
        "words": "我們回來了～",
        "unit_id": 1,
        "voice": "vo_adv_5040005_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "歡迎回來。",
        "unit_id": 102811,
        "voice": "vo_adv_5040005_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "從妳們的表情看來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "工作進行得似乎很順利呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算是啦。",
        "unit_id": 112711,
        "voice": "vo_adv_5040005_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒想到因為在進行第一件委託的途中",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "捉到了懸賞犯，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n結果造成了話題，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "之後不斷地有委託湧入呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n賺了不少錢喔。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "照這個樣子下去",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "拿回牧場的那天",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也不遠了啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我回來",
        "unit_id": 103811,
        "voice": "vo_adv_5040005_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "歡迎回來，小栞。",
        "unit_id": 112711,
        "voice": "vo_adv_5040005_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳怎麼悶悶不樂的，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "發生了什麼事嗎？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n難不成，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你們遇到了什麼問題？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103811,
        "voice": "vo_adv_5040005_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不是的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也不能說是",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有問題……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n該怎麼說才好呢……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "嘿，",
        "unit_id": 1411,
        "voice": "vo_adv_5040005_007"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "打擾囉。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "打擾了。",
        "unit_id": 414,
        "voice": "vo_adv_5040005_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "…………他們是誰？",
        "unit_id": 112711,
        "voice": "vo_adv_5040005_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這兩位的",
        "unit_id": 103811,
        "voice": "vo_adv_5040005_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "農場和牧場也跟【伊麗莎白牧場】一樣，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n被那個監察官沒收了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "最後沒有籌到錢，",
        "unit_id": 1411,
        "voice": "vo_adv_5040005_011"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "牧場就被徵收了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "我經營的果園",
        "unit_id": 414,
        "voice": "vo_adv_5040005_012"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "被徵收之後，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "\n就成了來路不明的貴族的別墅。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這……",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這種時候該說什麼呢……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "這件事已經過去了。",
        "unit_id": 1411,
        "voice": "vo_adv_5040005_014"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "什麼都不用說。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "更重要的是，",
        "unit_id": 414,
        "voice": "vo_adv_5040005_015"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "我希望這些能幫上妳們的忙。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是……",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_016"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "這是我們為了取回自己的公會",
        "unit_id": 1411,
        "voice": "vo_adv_5040005_017"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "而存下的錢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這、",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這怎麼可以！　",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不能收下",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這筆錢啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "我可沒說要送妳。",
        "unit_id": 1411,
        "voice": "vo_adv_5040005_019"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "這只是借給妳而已。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "等妳們取回牧場後再還給我。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "我稍微打聽了一下，",
        "unit_id": 414,
        "voice": "vo_adv_5040005_020"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "妳們似乎受到很多人的喜愛呢。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "所以，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "這筆錢就借給妳們。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可、",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽。",
        "unit_id": 103811,
        "voice": "vo_adv_5040005_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n其實，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們收到的錢不只有這些。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "什麼意思？",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這、",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這也是你們的？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "這些不是我們的錢喔。",
        "unit_id": 414,
        "voice": "vo_adv_5040005_025"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "我們是因為看到這些",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "才決定把錢借給妳們的。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們在遞送郵件的途中，",
        "unit_id": 103811,
        "voice": "vo_adv_5040005_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不斷地被村人們叫住，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n大家都在問牧場現在到底是什麼狀況。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "當我解釋完之後……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "解釋完之後……？",
        "unit_id": 112711,
        "voice": "vo_adv_5040005_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家就",
        "unit_id": 103811,
        "voice": "vo_adv_5040005_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "紛紛捐了錢給我們……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？　",
        "unit_id": 112711,
        "voice": "vo_adv_5040005_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為、",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼事情會變成那樣啊？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽去兜售過的遠方村落裡的村民，",
        "unit_id": 103811,
        "voice": "vo_adv_5040005_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有那場戰役時",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "來牧場避難的人們，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家都說想要表達他們的感謝之意……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我明明",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就沒有做什麼值得大家這樣感謝的事……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這些錢",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不能收下……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也有跟他們說過了。",
        "unit_id": 103811,
        "voice": "vo_adv_5040005_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要他們等我",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "問過真陽再說。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是大家說，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們每個人都只有拿出一點點而已。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "每個人一點點",
        "unit_id": 112711,
        "voice": "vo_adv_5040005_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就累積成這麼多……？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "因為有非常多人捐贈啊。",
        "unit_id": 1411,
        "voice": "vo_adv_5040005_034"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "那個人數真的是多得驚人呢。",
        "unit_id": 414,
        "voice": "vo_adv_5040005_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀～",
        "unit_id": 102811,
        "voice": "vo_adv_5040005_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你們看，都是你們幾個",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一直扭扭捏捏的不趕快交出去，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "結果被人家搶先了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真陽等人",
        "words": "……？",
        "unit_id": 1,
        "voice": "vo_adv_5040005_037"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那個呀，",
        "unit_id": 211,
        "voice": "vo_adv_5040005_038"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "真陽姐姐。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n我們幾個也一樣，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "雖然只有一點點，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不過……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "這個給妳！",
        "unit_id": 111,
        "voice": "vo_adv_5040005_039"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "真陽姐姐，",
        "unit_id": 211,
        "voice": "vo_adv_5040005_040"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳們不是很需要錢嗎？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n我們要把平常幫忙做家事存下來的錢給妳！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不，",
        "unit_id": 112811,
        "voice": "vo_adv_5040005_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "鈴，",
        "unit_id": 111,
        "voice": "vo_adv_5040005_042"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "謝謝妳教我怎麼玩遊戲，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "這是回禮！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "鈴",
