    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "翌日──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可在競技場裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在向曾被梅莉莎的毒侵蝕的市民們分發飯糰。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣一來，所有人都分到了呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公主米的飯糰！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "多虧了各位公主的幫忙，",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才能讓大家都開心地享用到美味的飯糰！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯，",
        "unit_id": 126511,
        "voice": "vo_adv_5213013_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我也希望能讓",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "蘭德索爾的各位品嚐到我們的文化。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n用來自吉歐‧提格尼亞的上等紅豆餡，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n包裹了貪吃佩可公主親手捏的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "飯糰。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家則是準備了經典的鮭魚飯糰。",
        "unit_id": 129711,
        "voice": "vo_adv_5213013_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "雖曰鮭魚，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實為棲於熔岩之",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "紅蓮鮭──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "其魚肉之溫度，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "從未低於百度。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我則是",
        "unit_id": 133111,
        "voice": "vo_adv_5213013_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "捏了昆布飯糰。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n吉歐‧尼布爾黑爾的昆布鹽分非常充足，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "甚至會讓亡靈超度成佛。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n……蘭德索爾的人",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "應該可以吃吧？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，用紅豆餡包飯根本是萩餅吧，",
        "unit_id": 106012,
        "voice": "vo_adv_5213013_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且超燙鮭魚會燙傷啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n話說從剛才就沒看到宮子了耶！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_5213013_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到最後仍需進行一連串猛烈吐槽，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "辛苦您了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您還好嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在身上還殘留著毒的狀態下如此吐槽。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以及克蕾琪塔小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳們把大家的事情",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "優先放在第一位。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來，",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請享用。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是我用滿滿愛心捏出來的喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下……",
        "unit_id": 118011,
        "voice": "vo_adv_5213013_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n多虧了您，拯救了這個國家。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還有……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還有……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您能夠吃得下飯……",
        "unit_id": 118011,
        "voice": "vo_adv_5213013_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是太好了……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這都是多虧了妳哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了讓我能再次吃下飯，",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳拼命努力。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n即使是在牢裡……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也正因為妳的話語在背後推了我一把，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我才能重新振作起來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛、",
        "unit_id": 118011,
        "voice": "vo_adv_5213013_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很謝謝妳。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有，妳能陪在我身邊這件事。",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也是我最珍貴的寶物之一喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛……",
        "unit_id": 118011,
        "voice": "vo_adv_5213013_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛陛……！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下啊啊啊～～～～～！！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 106012,
        "voice": "vo_adv_5213013_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吵死了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點吃啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不然毒會發作喔～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！",
        "unit_id": 106412,
        "voice": "vo_adv_5213013_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊啊……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想起來了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不，",
        "unit_id": 106412,
        "voice": "vo_adv_5213013_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是在吃到下毒的料理時……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我吃的是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "萊拉耶爾小姐的料理，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那真的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "非常好吃……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "吃下",
        "unit_id": 106412,
        "voice": "vo_adv_5213013_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "料理的瞬間……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n有種衣服",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好像爆開的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留・克蕾琪塔",
        "words": "「「啊！！！」」",
        "unit_id": 1,
        "voice": "vo_adv_5213013_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啊……",
        "unit_id": 106012,
        "voice": "vo_adv_5213013_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼一說確實有那回事！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那絕對是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙的毒造成的吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊，",
        "unit_id": 118011,
        "voice": "vo_adv_5213013_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "光是回想起來就讓人不寒而慄呢！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還是趕快吃下陛下的飯糰來淨化吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我就不客氣地享用了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「「「嚼……」」」",
        "unit_id": 106012,
        "voice": "vo_adv_5213013_024"
    },
    {
        "type": "still",
        "still": "521301301"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「「「呀啊啊！！！」」」",
        "unit_id": 1,
        "voice": "vo_adv_5213013_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦咦！？",
        "unit_id": 105812,
        "voice": "vo_adv_5213013_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼了！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難道是發生了什麼事……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不不不，",
        "unit_id": 118011,
        "voice": "vo_adv_5213013_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不是那樣的，陛下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n而且……",
        "unit_id": 118011
    },
    {
