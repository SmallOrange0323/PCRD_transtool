[
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞，",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞什麼鬼？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n突然間貪吃佩可她們就不見了……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就還沒有好好的向她們道歉！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最重要的事情，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也還沒有告訴她們呀！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊可惡，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是怎麼一回事？ ",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我該怎麼辦才好啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "凱留！　",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "發生了預料之外的問題！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為{player}他們已經醒了過來的關係，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這個夢境也要結束了！　",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "繼續待在這可能會有危險！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳也一樣，趕快醒過來吧！",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不然的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "夢境的終結……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被捲入崩壞之中可是會消失的！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊真是的，",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n果然在戰鬥中讓大家做這場夢還是太勉強了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是要和被洗腦魔法壟罩，",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n與那深沉意識沉睡在最深處的凱留接觸，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也沒有其他的方法了啊～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在，",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在講什麼？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是誰啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我叫愛梅斯喔、",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "至少名字有沒有從可可蘿那聽過？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "愛梅斯？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那不就是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "印象中可蘿仔她一直崇拜著的那個神嗎……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊真是的，",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在沒有時間跟妳說明了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總而言之，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在趕快過來我這邊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算是來硬的也要讓妳醒過來了喔！",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "貌似『王宮』正在崩毀當中的樣子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還傻傻的睡在那裡的話可是會被瓦礫給砸死的啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？　",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說『王宮』？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底怎麼一回事啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "稍微暫停一下。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在那之前，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我有點話想要說呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……晶！？　",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼會在這裡？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳不是在『現實』醒過來了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "欸嘿嘿。",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可不要小看了我啊，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n再怎麼講",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我可也是『七冠』",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我在『那邊』用上了限定的線路，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n讓我也可以暫時連接上『這邊』了呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可真折騰死人啦～",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "到處都充滿了Bug。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n話說這",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "根本",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就成了像是Bug的大集合了嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "從外頭重新",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "檢視了一下，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這世界真奇怪啊～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "更有這樣的感覺了呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼搞的，",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然口氣有點隨便，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但感覺她不是個小角色！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳就是凱留？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": " ",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "初次見面～！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我的老友，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『真那』是妳在照顧的嘛？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要應付他可不是件簡單的事情對吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟性格那麼的扭曲嘛♪",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真、",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真那？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那不是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』的本名嗎……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳和『陛下』認識嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，老朋友了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我在『再構築』時，記憶一樣受損了所以也陷入混亂了嘛，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我全部都想起來了，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但講白了其實也是最近的事情而已。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大約",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "和用混亂時的腦袋瓜所收集的情報，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n然後整理後",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "推導出來的結論差不多呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唉呀～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還真是成了一發不可收拾的局面了呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……？",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀，抱歉。",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n好像不快快從這裡退散會不太妙的樣子呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我不會廢話太多的啦，放心吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "凱留，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我現在，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "處在有一點不自由的狀態，所以不太能充分地行動。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "像這樣在短時間內連接上『這邊』，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n做些資料調整修復……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或對話之類的就是極限了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我要把這東西交給妳囉。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這本來，是我必須得要交給那孩子的東西。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那，",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那孩子是……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "{player}少年。",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我那可愛的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『公主騎士』♪",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "晶。",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳說要交給他的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難不成……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是借放在妳那兒的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n{player}他『前世』的記憶？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不行啊！",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果讓{player}他現在把所有事情都想起來的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說不定腦袋會承受不住啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以說，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就只打算先把一小部分還給他。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只有戰鬥經驗之類的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "優先而已。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該能驚人地",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n強化他做為『公主騎士』的能力才對。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接下來看起來像要最終決戰了嘛，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很需要的對吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉呢～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "明明如果我也能夠順利趕上的話就好了嘛！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "像之前真那轟了那大量破壞魔法的時候一樣，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n再慘我也至少能和他打到平手就是了呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在的我",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是想回到『這邊』也回不來的嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過嘛，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若是有個萬一的情況，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我就是拼了命也會趕來助陣的啦。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但可不要太期待了唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那未來，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我還是希望妳們能靠自己的雙手闖出來的嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我支持妳們，",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也相信如果是妳們的話一定辦得到的。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n雖然我不像真那一樣可以預知未來，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但我的預想",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可是經常猜中的唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "先這樣吧。",
        "unit_id": 106831,
        "voice": "vo_adv_2012099_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n得暫時分開一陣子囉，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "下次見面時若能在",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『現實』的話就太好囉♪",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下！",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n晶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我有事情得要跟妳說……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……啊啊真是的，",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經消失了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "每次每次，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都像這樣把事情全推給了別人啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明如果是晶她自己來做的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "兩三下就解決了啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "優衣的事之類的，",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明有很多事想和她討論的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過嘛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她說要講講話的話還是有可能的嘛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n留到下次有機會再說就好了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "愛梅斯，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這到底是怎麼回事？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我到底該做什麼，又要怎麼做才好？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯～……",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總而言之妳趕快醒過來就對了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這之後就看妳自己了唷，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳就做妳想要做的事情就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "誰也不會",
        "unit_id": 190011,
        "voice": "vo_adv_2012099_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "命令妳也不會強迫妳唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳只要依照妳心裡所想的來做就行了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能讓妳的人生，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓妳能夠走在現實這條路上的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就只有妳自己而已喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106031,
        "voice": "vo_adv_2012099_045"
    }
]