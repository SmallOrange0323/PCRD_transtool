[
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～",
        "unit_id": 128411,
        "voice": "vo_adv_5134322_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔嗯唔嗯……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這次",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有沒有好好地醒過來呢……？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我",
        "unit_id": 128311,
        "voice": "vo_adv_5134322_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "覺得世界真的是",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "非常地",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "閃亮呢。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就像現在從眼前飛過的",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "眾多隕石一樣。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不，",
        "unit_id": 128411,
        "voice": "vo_adv_5134322_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看來似乎是沒有呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個",
        "unit_id": 128511,
        "voice": "vo_adv_5134322_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是石質隕石嗎？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果是的話……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真有種",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "命中注定的感覺呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說那顆隕石",
        "unit_id": 128411,
        "voice": "vo_adv_5134322_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "正在朝著這邊飛過來！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要是不去迎擊，後果會很嚴重啊～！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "迎擊",
        "unit_id": 128311,
        "voice": "vo_adv_5134322_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗎……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼，我們沒辦法停止鬥爭呢？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還要再迎接多少次新年，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才能結束這重複不斷的輪迴？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然是很殘忍的抉擇，",
        "unit_id": 128511,
        "voice": "vo_adv_5134322_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但必須要有人來下決定。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而這，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是所謂的跨年……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n妳說對吧，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "初音？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔嗯唔嗯……",
        "unit_id": 128411,
        "voice": "vo_adv_5134322_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總覺得好像不太對……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這次應該",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有好好地醒來了吧！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我已經",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不想再作惡夢了……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕……",
        "unit_id": 128411
    }
]