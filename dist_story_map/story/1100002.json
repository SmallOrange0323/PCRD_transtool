        "type": "dialogue",
        "name": "女性",
        "words": "好的好的，",
        "unit_id": 411,
        "voice": "vo_adv_1100002_014"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我明白的沒問題啦。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n快點，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "專心拍照吧～！",
        "unit_id": 411
