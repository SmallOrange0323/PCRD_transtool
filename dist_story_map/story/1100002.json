    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有！",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才才不是我的男朋友啦～！",
        "unit_id": 110011
