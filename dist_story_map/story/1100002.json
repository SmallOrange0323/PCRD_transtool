        "voice": "vo_adv_1100002_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "那麼，",
