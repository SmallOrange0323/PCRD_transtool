    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇啊！　",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "比起剛剛的模仿，這一次的叫聲更像呢！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的太有才了！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n剛剛的不是秀才嗎……？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "哇啊啊啊啊！！",
        "unit_id": 411,
        "voice": "vo_adv_1100002_029"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n從海中冒出魔物啦！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼吼吼吼吼！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "魔物向他的方向前進！？",
        "unit_id": 1212,
        "voice": "vo_adv_1100002_030"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "該不會，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "對剛剛的叫聲有了反應吧！？",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "鈴奈，",
        "unit_id": 411,
        "voice": "vo_adv_1100002_031"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不趕快逃的話很危險的！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不可以放著秀才不管！",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才！　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "快來我這裡！！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦！？",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n因為魔物的裝扮很笨重，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒辦法隨心所欲移動嗎！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼吼吼吼吼！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！！",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n等一下！　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我現在、",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "馬上用弓將魔物……！！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不行，",
        "unit_id": 411,
        "voice": "vo_adv_1100002_035"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "鈴奈！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n有可能會射到他呢！",
        "unit_id": 411
    },
    {
