    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "不錯呢――！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n能不能模仿一下魔物的叫聲呢？",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇！　",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像真的一樣！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你有演魔物的才華呢！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像開始有感覺了！",
