        "voice": "vo_adv_1100002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好過分～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n應該還有其他該說的評語吧～？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？　",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為我平常就很酷嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哎呀～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家會害羞別這麼說～！",
