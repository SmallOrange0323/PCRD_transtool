        "voice": "vo_adv_1100002_025"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "保持這樣繼續拍攝唷！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好――！",
        "unit_id": 110011,
        "voice": "vo_adv_1100002_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼秀才，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "扮演魔物的角色就麻煩你了～♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "魔物",
