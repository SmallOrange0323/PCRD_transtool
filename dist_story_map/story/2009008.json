    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是就連環遊世界一周都用不完的，",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_049"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這些非常非常多的能量我們全都收到囉！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們直到最後一刻，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都會以最燦爛的笑容唱下去的唷！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來吧來吧～♪",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要開始囉，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "兩位！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的，",
        "unit_id": 104212,
        "voice": "vo_adv_2009008_051"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "已經等不及了。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家一塊開心歌唱吧♪",
