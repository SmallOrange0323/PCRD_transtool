    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像從",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那一側的方向傳來了陣陣騷動呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是為何事呢？",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貌似有大批的人群。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還能聽見樂器的演奏聲響呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "廣場上",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是不是有人正在進行著什麼表演呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "慈、",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "慈樂之音？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您是在指什麼呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦。",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是主人您的舊識，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正在演奏樂器的意思嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這城中的廣場上？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了何等事……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管有些許地在意，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而在下等人可說是逃犯一般的存在……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在人來人往的場所中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不得如此掉以輕心地閒逛嘛？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……啊～",
        "unit_id": 100511,
        "voice": "vo_adv_2009008_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "找到囉！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "找到{player}他們了喲！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦哦，",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "優秀優秀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳的鼻子真靈呢，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哼哼，",
        "unit_id": 100511,
        "voice": "vo_adv_2009008_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我可是獸人……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇啊不是？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "從以前，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就很擅長靠嗅覺找到人的喲！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這個是",
        "unit_id": 100511,
        "voice": "vo_adv_2009008_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "身為【王宮騎士團】的一員，\n可以說派得上用場的特技吧！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "托妳的福，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n能夠比想像中的還更早來和{player}接觸囉♪",
        "unit_id": 103711
    },
    {
        "type": "still",
        "still": "200900801"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！？",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n妳們兩位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "記得是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【王宮騎士團】的人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好！",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n趕緊逃吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊……",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n等等，先等一下？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然好像有什麼誤會的樣子，",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但我們可不是專程要來抓你們的唷？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真的啦真的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "相信我♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳這樣說反而很假唷，",
        "unit_id": 100511,
        "voice": "vo_adv_2009008_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請往這兒！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要我們，",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仍和王宮處於敵對的一日……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那王宮所直屬的【王宮騎士團】，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就絕非是我們能夠有所接觸的怨敵！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若被捉到了，",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可不知道會遭受如何的對待！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n此時無論如何，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都該趕緊逃走才是！",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀呀，",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來是完全不相信我們的話了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過嘛這也沒辦法，",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果【小小甜心】的那些孩子們說的是真的……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們可就真能說是你們不共戴天的敵人了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以嘛……",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "簡直像是哪來的臉說這種話的感覺了嘛……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但還是希望能相信我，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "至少我和茉莉不是你們的敵人唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說得沒錯喲！",
        "unit_id": 100511,
        "voice": "vo_adv_2009008_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}是一位好人的喲，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是能夠理解我的一位好朋友喲！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟說是朋友，",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此不知羞恥。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若要博得人的信任，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就先將在下等人真正的友人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把貪吃佩可小姐給安然無恙地釋放出來！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這可能還挺困難的呢，",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "老實講。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "現在，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "王宮裡的內幕也幾乎是亂七八糟的狀態呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "大家，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "似乎也都是不太正常的樣子呀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且以我們倆的身份地位，",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可是連踏進王宮一步也都辦不到唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果真要替妳們將那位叫做貪吃佩可小姐的人從牢房裡接出來，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就更是痴人說夢了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若真是如此，",
        "unit_id": 105913,
        "voice": "vo_adv_2009008_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就更沒有得與妳們兩位談上任何話的道理了！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還真是被討厭了呢……",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這下該怎麼辦呢～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "硬是把他們給綁起來也行就是了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過假如造成了騷動，",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那就真的會引起其他【王宮騎士團】團員的注意了呀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還是暫時",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "先撤退……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "等事情稍微平息後再來接觸會比較好嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511,
        "voice": "vo_adv_2009008_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不追上去沒有關係嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n{player}他們，\n好像打算混在人群中準備逃掉了唷！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果要捉他們的話，",
        "unit_id": 100511,
        "voice": "vo_adv_2009008_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不趕快追上去就會跟丟了呀！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔呣。",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這到底是在幹嘛呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼誇張的人潮？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊……",
        "unit_id": 103711,
        "voice": "vo_adv_2009008_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n似乎是這陣子在城內瘋傳的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n『那幾位偶像』所開的演唱會嗎？",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500581"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "各位～！",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝大家今天能夠一起到這來♪",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們是，",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們是能歌善舞的偶像公會！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "【慈樂之音】唷～♪",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵。",
        "unit_id": 104212,
        "voice": "vo_adv_2009008_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n非常感謝大家盛大的掌聲，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還有聲援……♪",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為了一直給我們加油鼓勵的粉絲們，",
        "unit_id": 104212,
        "voice": "vo_adv_2009008_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們會更努力……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱下去的！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呵呵。",
        "unit_id": 105412,
        "voice": "vo_adv_2009008_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "【慈樂之音】的全大陸巡迴演唱會的首日，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就在這！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n在我們的故鄉……",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在蘭德索爾，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在的這個瞬間開始囉！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "希望大家，",
        "unit_id": 105412,
        "voice": "vo_adv_2009008_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能夠替我們加油到最後唷～！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵。",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為得巡迴整個阿斯特賴亞大陸直到每一個角落，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以暫時沒有辦法回到蘭德索爾了……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是不用擔心！",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也不用因為這樣覺得寂寞唷！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "用最新型的影像播放魔法，",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就能時常看到我們活躍的身影囉！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n隨著抵達的國家小鎮不同也會有特別的服裝唷，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果能夠多加關注的話我們會很高興的呢！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呵呵～",
        "unit_id": 105412,
        "voice": "vo_adv_2009008_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "負責服裝的我可是盡了全力喔！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當然，",
        "unit_id": 104212,
        "voice": "vo_adv_2009008_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不僅僅是服裝也請各位能夠多多關注歌曲的部分。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "配合著各國不同的風俗民情也精心製作了特別的編曲，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n其中也會穿插些新曲的演唱。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯嗯！",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "直到最後也絕不會讓大家冷場，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這將會是場最棒的巡演唷！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們會讓【慈樂之音】的名聲轟動這整片大陸的，",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請替我們加油一面等著我們吧！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼那麼～♪",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這值得紀念的首場巡演，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "蘭德索爾場就要開始囉！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家～！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要嗨起來了唷！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家的笑容，",
        "unit_id": 102912,
        "voice": "vo_adv_2009008_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是我們的原動力！",
