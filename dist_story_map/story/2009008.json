    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯嗯，",
        "unit_id": 105412,
        "voice": "vo_adv_2009008_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來創造一場最棒的舞台吧！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n比那太陽還更加的耀眼吧，",
        "unit_id": 105412
