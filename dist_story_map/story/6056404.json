[
    {
        "type": "background",
        "background": "501161"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你問我新年都怎麼過？",
        "unit_id": 114711,
        "voice": "vo_adv_6056404_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我從以前到現在，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都不太在意什麼新年就是了……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以新年有這麼好玩嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家都做些什麼事啊？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來你們說的年菜是指食物嗎！？",
        "unit_id": 114711,
        "voice": "vo_adv_6056404_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果能吃新年才有的特別食物，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聽起來應該挺有意思的。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要是真的很好吃，那我也要吃吃看！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "參拜？",
        "unit_id": 114711,
        "voice": "vo_adv_6056404_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……你說去寺院投錢，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後向神許願？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是願望應該不會因為這樣就成真吧……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我開始有點好奇你們是怎麼做的了。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到時也找我一起去吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "毽球板？",
        "unit_id": 114711,
        "voice": "vo_adv_6056404_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "記得好像是……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "用板子打像球一樣的東西是嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "果然沒記錯！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個的話我應該也能樂在其中！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會把你打得落花流水，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "馬上就去玩玩看吧！",
        "unit_id": 114711
    }
]