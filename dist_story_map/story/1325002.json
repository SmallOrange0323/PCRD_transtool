    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天的假日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}在散步時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在廣場的人群中看到了苑。"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "咦～",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_000"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "為什麼～！？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n討厭討厭，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我也要參～加～啦～！！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我也",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "很淘氣啊！！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "超級淘氣！！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "唔哦！！？",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_001"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n……等，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哥",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哥……！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我、",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我們去",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那邊講……！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "糟透了。",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_002"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "被看到了超羞恥的一面……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "真是的，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "天氣這麼好的假日",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你一個人在做什麼啦。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你說散步？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊啊，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這樣啊。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你問我……？",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_003"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是想參加這個……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這個叫做",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "「淘氣小孩慶典」",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "的活動……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我、",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_004"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我並不是",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "真的想參加喔……！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我的目標",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是優勝獎品……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n黃金捕蟲網，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我想要那個。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……嗯，",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_005"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是啦，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "就是這麼回事。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n最近",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那孩子很乖，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "所以想說要給她個驚喜……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "但是說參加活動需要監護人的同意。",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_006"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "唉……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我可就是監護人啊。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "咦？",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_007"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我想那",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "應該",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是可以吧……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n啊，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "該不會",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你願意當監護人……？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你是神嗎……？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……抱歉啊，你明明是在散步……",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_008"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "但",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這幫了我大忙。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n那",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我是妹妹的小苑，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "就這樣說好了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n拜託你囉，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哥哥。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呼……",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_009"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "多虧有你，總算是成功報名了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "然後啊，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這個「淘氣小孩慶典」",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "總共有三個項目，\n是要比綜合成績，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "簡單來說就是小孩版的鐵人三項。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "前兩個項目已經公開了……",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_010"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "首先是",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "大胃王大賽。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n再來是",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "相撲。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你那個表情是怎樣。",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_011"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不過，嗯，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我知道",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你想說什麼喔。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "就是說啊。",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_012"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "畢竟，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我可是頭腦派的嘛……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不過嘛，",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_013"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是啦。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "淘氣小孩的話，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "感覺很適合那孩子。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不過",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_014"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "對手可是小孩子喔。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "雖然對大家很不好意思，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "但我會收下優勝的。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哦，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "第一個項目差不多要開始了呢……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我去去就回。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呃……",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_015"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "什麼！？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "繽紛砂糖甜甜圈",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "大胃王對決……！？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這種色素跟碳水化合物的化身，",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_016"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "對身體絕對是毒吧……！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "怎麼能用彩羽的身體來吃這種東西……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "等等，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n周圍的孩子都開始吃了！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……嗚嗚，",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_017"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這是為了優勝。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "彩羽",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "抱歉了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "明天開始我會好好注意健康的，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n就只有今天",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "讓我攝取滿滿的糖分吧……！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那麼，",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_018"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我開動了！！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嚼嚼………………………………",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嚼嚼………………………………",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不，",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_019"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "要是不慢慢吃",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "血糖會飆升的……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嚼嚼………………………………",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嚼嚼………………………………",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗚嗚……",
        "unit_id": 132512,
        "voice": "vo_adv_1325002_020"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "動不了了。",
        "unit_id": 132512
    },
