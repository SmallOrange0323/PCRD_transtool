    {
        "type": "dialogue",
        "name": "旁白",
        "words": "華音。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她一邊策畫下一個陰謀，"
    },
    {
        "type": "dialogue",
