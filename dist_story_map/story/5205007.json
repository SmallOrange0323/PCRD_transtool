        "voice": "vo_adv_5205007_036"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "雖然你是個不中用、沒骨氣且天真的人──",
