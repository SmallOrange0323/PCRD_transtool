    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "因為騎士閣下之友人，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "與紡希閣下和華音那傢伙如此赫赫活躍，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n詛咒祭典終於得以落下帷幕。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而，",
        "unit_id": 129711,
        "voice": "vo_adv_5205007_047"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "杯中猶有蛇影──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "應為蜘蛛之影。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "迷惘之事永無止盡啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "根據默涅的報告，",
        "unit_id": 129711,
        "voice": "vo_adv_5205007_048"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n阿剌克涅──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那個魔蜘蛛已改換姿態，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如浪人般四處徘徊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但總而言之，",
        "unit_id": 129711,
        "voice": "vo_adv_5205007_049"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吉歐‧格黑納的熱度猶未平息。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "下回又會迸出何種火花呢？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "身為煉獄皇女，",
        "unit_id": 129711,
        "voice": "vo_adv_5205007_050"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家得事先做好準備──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5205007_051"
    }
