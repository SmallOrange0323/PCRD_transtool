        "voice": "vo_adv_5205007_031"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n我隨時都歡迎妳",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "來我腳邊磕頭喔──！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……哼。",
        "unit_id": 134912,
        "voice": "vo_adv_5205007_032"
    },
