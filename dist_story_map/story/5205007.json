        "voice": "vo_adv_5205007_003"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "完全就是這麼回事。",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n我可是對這個時刻翹首以盼。",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有──",
