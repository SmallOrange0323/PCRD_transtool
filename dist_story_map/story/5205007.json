        "type": "dialogue",
        "name": "華音",
        "words": "一個人──",
        "unit_id": 134911,
        "voice": "vo_adv_5205007_005"
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "──是我必須打倒的對手！",
        "unit_id": 1,
