    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "更重要的是！",
        "unit_id": 134912,
        "voice": "vo_adv_5205007_038"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那股強化之力！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n讓本小姐原本就很高的潛力",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "更是高到",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不合理的地步！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n不過那都是源自",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我的潛力喔！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "只要有這份力量，就能勝過",
