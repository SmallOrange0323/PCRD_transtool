        "words": "」一百次吧♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……不過，",
        "unit_id": 134912,
        "voice": "vo_adv_5205007_035"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "嗯。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "你好像",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "也還算是、",
