    {
        "type": "dialogue",
        "name": "華音",
        "words": "為我貢獻吧♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哦～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呵呵呵♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……原來如此，",
