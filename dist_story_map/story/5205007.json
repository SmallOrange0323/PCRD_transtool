        "type": "dialogue",
        "name": "紡希",
        "words": "這是",
        "unit_id": 134812,
        "voice": "vo_adv_5205007_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了拯救怜大人的、",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "決勝服裝……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n用的是配合吉歐‧格黑納環境的布料……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這就等之後再說！",
