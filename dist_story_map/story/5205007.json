        "voice": "vo_adv_5205007_044"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "高貴的大小姐，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "華音。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是不久的將來，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n要肩負成為這個吉歐‧格黑納支配者命運的",
