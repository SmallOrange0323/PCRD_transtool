        "voice": "vo_adv_5205007_013"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "麼～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "～～～～！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳～",
        "unit_id": 134812,
        "voice": "vo_adv_5205007_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "想～",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎～",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "樣～",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊～！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唉……",
