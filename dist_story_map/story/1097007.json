        "name": "鈴莓",
        "words": "那個！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n放在比較裡面的",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "找到了！",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是我一直在找的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐的炒麵麵包專用盤～～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "真的在這裡呢……！",
        "unit_id": 109711,
        "voice": "vo_adv_1097007_031"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "能找到真是太好了！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太感謝兩位了……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣子，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我就能再端出炒麵麵包給大小姐吃了～～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……不過雷姆小姐，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真虧妳能發現呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n在這種地方居然會有孩子們的祕密基地。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "其實，",
        "unit_id": 109711,
        "voice": "vo_adv_1097007_034"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆很早就注意到地板的縫隙了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n只是，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為是寄人籬下之身，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "所以擔心會太多管閒事。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n就在這段期間，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "他們似乎把這個空間擴大了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我想這對孩子們來說，",
        "unit_id": 109711,
        "voice": "vo_adv_1097007_035"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "或許是他們能就近體驗的冒險吧。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "所以，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "希望可以不要責備他們。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不會不會，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我不會罵他們的～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼微妙的異樣感，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳居然能注意到呀？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對於地板間的縫隙，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一般根本不會去在意呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要是沒有專注打掃細部，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n根本不會注意到這種事～～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "如果只因為是細微的小事就視而不見，",
        "unit_id": 109711,
        "voice": "vo_adv_1097007_038"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n總有一天會變成無法挽回的事，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這是雷姆從姊姊那裡學來的。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雖然跟姊姊相比",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆還差得很遠就是了……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不要這樣批評自己！",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的非常地感動！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒想到妳會這麼用心地",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "打掃育幼院。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……而且，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "仔細一看……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這處地板下面，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "非常地",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "乾淨。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難道說雷姆小姐，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是連地板的下面都打掃了嗎……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的。",
        "unit_id": 109711,
        "voice": "vo_adv_1097007_042"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雖然說是地板的下面，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但還是希望孩子們能在乾淨的場所遊玩。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦咦～～！？",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這也就是說……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "打掃的時候",
        "unit_id": 109711,
        "voice": "vo_adv_1097007_044"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "先把地板下的玩具全部拿起來，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n結束之後",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "再把玩具放回原本的地方。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n而那些餐具",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆以為都是已經沒有在使用的東西。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雖然雷姆有盡可能地把東西放回原位……",
        "unit_id": 109711,
        "voice": "vo_adv_1097007_045"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但感覺比較敏銳的孩子或許有發現到也說不定呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚嗚～～",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n真是太厲害了～～！！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我從之前就在想……",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這個觀察力，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "以及對居住者的體貼之心，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還有超群的家事能力……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雷姆小姐果然，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可以稱得上是真正的女僕。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對於我這個冒失女僕來說，",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n簡直就是遙不可及的存在……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n像這樣隨便地搭話實在是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太惶恐了……",
        "unit_id": 102511
    },
