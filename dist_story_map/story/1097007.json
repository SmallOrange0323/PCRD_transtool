        "voice": "vo_adv_1097007_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是一個形狀很適合",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "用來盛裝大小姐最愛吃的炒麵麵包的",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n專用盤子。",
