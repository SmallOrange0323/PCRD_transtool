    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "絕對不能打破、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也不能弄丟，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一直以來都很小心翼翼地對待。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚嗚……",
