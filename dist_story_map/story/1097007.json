        "voice": "vo_adv_1097007_014"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不過，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這還真是不可思議呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
