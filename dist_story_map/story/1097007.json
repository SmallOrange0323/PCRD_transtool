    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是當天晚上──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鈴莓順利地，端出了炒麵麵包給咲戀。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～",
        "unit_id": 102811,
        "voice": "vo_adv_1097007_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "乾鬆的麵包口感",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "以及比一般更濃郁的調味。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n炒麵麵包是最棒的呢♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是這個盤子吃起來最合適呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……不過。",
        "unit_id": 102811,
        "voice": "vo_adv_1097007_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這是怎麼回事？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個盤子。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不是不見了嗎……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦！",
        "unit_id": 102511,
        "voice": "vo_adv_1097007_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚欸欸欸欸！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼妳會知道這件事……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為。",
        "unit_id": 102811,
        "voice": "vo_adv_1097007_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n搞丟這個盤子的人……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是我啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "前陣子，",
        "unit_id": 102811,
        "voice": "vo_adv_1097007_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳不是拿這個盤子",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "裝炒麵麵包來給我當消夜嗎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那天晚上，",
        "unit_id": 102811,
        "voice": "vo_adv_1097007_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "實在是太累了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就這樣把盤子放著，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "趴在桌子上睡著了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然後，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "隔天早上醒來的時候，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "盤子已經消失不見了……",
