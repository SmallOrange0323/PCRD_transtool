[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與可可蘿，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n用挑戰雙人羽織快速吃蕎麥麵後所得到的獎品折價券，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在廟會攤販盡情地享受了美食。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀。",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的嘴角沾到東西囉。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下來替您擦掉。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……擦呀、",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擦呀♪",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擦乾淨囉。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然每個攤販的",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "折扣都滿多的，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但還是有點吃太多了呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經很飽了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吃美食過新年",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是個很棒的過節方式，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但可不能在新年長胖了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人吃得",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如何呢？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有沒有",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "覺得非常滿足了呢？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "壓歲錢還有剩，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是沒有吃夠的話，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請別客氣，儘管告訴在下。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能在新年一開始",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就得到您的誇獎，在下真是備感光榮。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "支援主人",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是在下的職責。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "引導您快樂地度過新年，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是在下應該做的事。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下回家鄉後，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "向長老和同鄉的舊識們",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n報告了主人",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去年的活躍表現。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和同鄉舊識們之間的談話，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令人感到心情平靜，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下度過了一段安穩平和的時光。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在與主人相遇，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又接觸過主人的溫柔之後，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在，主人的身邊",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經是在下的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "另一個新的故鄉了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不只是談話而已，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下連家鄉的傳統活動也都大致上參與了一遍，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經盡情地享受過新年了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不對。",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還有一件",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "新年活動沒有做過。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下說的不是家鄉的習俗，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而是以前",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "曾經聽聞神殿職員所說的，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n蘭德索爾",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡的討吉利活動。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這本來應該是",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要在元旦當天進行的活動，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在才開始進行，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經有點太遲了……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那可不行。",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下今天",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是要帶主人來過新年的，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n怎麼能夠臨時加入自己的行程呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然是那個活動的話……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然還是",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接受主人的好意吧？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣的安排說不定對主人也有幫助……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們走吧。",
        "unit_id": 111911
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是這裡，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您帶著一臉不可思議的樣子在環顧著四周呢……",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來您很在意",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡缺少了新年的氣息吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您安心。",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在這座湖邊有……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然還在！",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "神殿職員們",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "元旦時使用的舞台",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還留在這裡沒有被拆掉。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就稍微",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "借用一下這個舞台吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是第一次在別人面前做這件事，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以對於自己能不能順利做到",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒什麼自信……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但懇請您",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以寬大的心",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "陪在下做這件事吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽見主人您說期待，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令在下感到輕鬆了一點。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼～……",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要開始了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "慢慢地舉起手，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接著應該是",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "扭動腰部……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀？　",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您別那樣",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盯著在下看……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下沒自信能做得很好，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣子讓人非常難為情。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是要獻給主人的祈福之舞。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下又希望您能好好看著，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真令人焦慮。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了不打壞您",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "享受新年的興致，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會極盡所能地",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去表現，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來讓主人",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感到開心……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白這支舞說不上是",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完美無缺。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唯獨在下對主人的思慕之情……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唯有這件事",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有半點虛假，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是在下發自內心的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唯一一個願望。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "懇請您今年",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也讓在下待在您的身旁。",
        "unit_id": 111911
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓這拙劣的舞技",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傷了您的眼睛，真是非常抱歉。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才那段，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是蘭德索爾自古流傳至今的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "新年之舞的其中一節。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實在去年年底",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前往神殿時，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下從一名職員那裡，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽聞了新年之舞的事情。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要在新年的第一天",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為自己最珍視的人",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "獻舞，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就可以許下願望……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓自己在那一年",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也能繼續待在對方的身邊。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若這個祈願能夠成真，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的願望就會實現，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而主人，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也能夠接受在下的支援。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對在下而言，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這就是",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最棒的新年討吉利活動。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下雖然想過，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總有一天要展現給主人看，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但沒想到",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會在今年就獻舞給您看呢……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下在家鄉時，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然一有時間就會去練習一下，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但在下的表現，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在無法說是有模有樣。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問您覺得如何呢……？",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望主人您",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會感到無趣才好……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是在下一心一意只想著主人，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n懷著真心",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "、誠心誠意地跳給您看的舞。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎、",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼這麼說。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您這樣稱讚在下，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反倒令人感到不安了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然是主人所說的話，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下今天",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就這樣老實地接受吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來主人十分高興呢，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下感到安心多了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下那拙劣的舞蹈，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也得到了您過多的讚譽……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下人生中最大的",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "願望與幸福，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就是待在主人的身邊",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "支援您。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 111911,
        "voice": "vo_adv_1119003_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不只是為了主人，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是為了在下自己，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明年也請",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "務必",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下再次為您表演這段舞蹈吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就像那將清澈的冬日天空給染紅的夕陽一般，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可可蘿凝視著{player}的眼眸，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也溫柔地閃動著光芒。"
    }
]