    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你在這裡！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "工作稍微拖了一點時間。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "別擔心，我是把工作做完才過來的！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以，今天是有什麼事嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇，",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你～！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好開心喔，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "居然可以收到你送的禮物！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵。",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓你為我慶生，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n總覺得有點害臊呢……♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是偶像的我的這一面，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只有你能看到。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇，",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "生日禮物請透過事務所轉交……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "開玩笑的啦！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n謝謝你！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我會好好珍惜的！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "像這樣收到禮物或粉絲信，",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就能確切感受到大家的支持，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也會更加有精神！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也謝謝你",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一直支持著我！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然我立志成為頂尖偶像，",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n當然不能因為是生日就休息呀！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這些都是小事啦♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊……",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個難道是",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的生日禮物嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "收到這個，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管多麼辛苦，疲憊都會一掃而空呢！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿，",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我今天的工作已經結束了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難得的機會，我們一起出去轉轉吧！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之前我發現了",
        "unit_id": 102913,
        "voice": "vo_adv_1029500_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一間隱密的甜點店哦。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為不想變胖，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我平時都很克制吃甜食……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但今天你也在，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶爾一次沒關係吧♪",
        "unit_id": 102913
    }
]