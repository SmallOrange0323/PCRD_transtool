[
    {
        "type": "background",
        "background": "500038"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和優花梨，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在聖誕節熱鬧的蘭德索爾街道上走著。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然聖誕約會行程泡湯了……",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但像現在這樣兩個人漫無目的地走著好像也不壞。",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "比起硬是要主導約會，",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還是順其自然更好呢……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "天色完全暗下來了呢……",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那、",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們現在要做什麼？",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哦、",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哦哦……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那我在這裡等你……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唉……",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這也可以說是很像他的風格啦。",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "哈囉～",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_005"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "優花梨～！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呀！",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦、",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦咦咦？",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n妳為什麼會在這裡啊？",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "哪有為什麼，",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_007"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "當然是和你們一樣在聖誕約會呀♪",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "然後啊，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "我在約會途中看見你們，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "本來想說",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n還是別來打擾好了，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "但剛剛看到妳男朋友跑掉……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_008"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "你們該不會分手了吧？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不是啦！",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才不是",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那樣！",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "啊哈哈，",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_010"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "開玩笑的啦。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "我剛剛都聽到了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "你們之間的氣氛不錯嘛。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是、",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是那樣嗎？",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "本來以為你們之間會有些彆扭的，",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_012"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n但他竟然在約會中提出要上廁所，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n看來你們相處得很自在，我也放心了呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個嘛，",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "說來話長……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈哈……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "對了，",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_014"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "妳知道這附近",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "有個看夜景的地方嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好像有在雜誌上看到過……",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但那種地方人通常都很多，不好玩吧？",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "是這樣沒錯啦，",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_016"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "但那裡氣氛超好的。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n「想讓關係更進一步，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "就趁現在了！」",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "的時候正適合去走走喔？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什、",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什麼讓關係更進一步啦……！",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我很享受像現在這樣和他悠閒地散步……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "呵呵，",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_018"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "你們很甜蜜嘛。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒、",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒有這回事啦……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1146003_020"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "妳男友也差不多該回來了吧？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "我男友也在等著我，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "就先走一步啦。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "那麼，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "要加油唷，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "優花梨♪",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊……",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "走掉了。",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "「想讓關係更進一步，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就趁現在了！」",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗎……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對我們而言好像還太早了。",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但如果，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是他約我去的話……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哇呀啊啊！",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒、",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒什麼！",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒什麼啦！",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我只是在自言自語，你別介意！",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "接、",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "接下來要做什麼呢？",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你有想去的地方啊。",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好啊，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們走吧。",
        "unit_id": 114612
    },
    {
        "type": "background",
        "background": "500025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這裡",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "該不會……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是剛剛提到的看夜景的地方……？　",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你竟然想來這裡啊？",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真虧你會知道耶……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "該不會……",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "想讓關係更進一步，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就趁現在……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是指這一刻嗎！？",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "怎怎怎、",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "怎麼辦！",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太突然了，我還沒做好心理準備……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳、",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳要冷靜啊優花梨……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在就像個成熟的大姐姐，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n保持從容……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊啊啊啊啊！",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我辦不到！　",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們的關係",
        "unit_id": 114612,
        "voice": "vo_adv_1146003_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也沒有淺到",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "說一句「還太早了」就能劃分清楚的……",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過，",
        "unit_id": 114612
    },
    {
        "type": "dialogue",
