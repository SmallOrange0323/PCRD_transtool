[
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟、",
        "unit_id": 117111,
        "voice": "vo_adv_5070323_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱著頭趴在桌上了……！！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "別再寫作業了……",
        "unit_id": 117011,
        "voice": "vo_adv_5070323_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是以前的我，應該會這麼說吧。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 117111,
        "voice": "vo_adv_5070323_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是看著弟弟到現在一路的努力，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n實在說不出這種話呢。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓他克服這場戰鬥，",
        "unit_id": 117011,
        "voice": "vo_adv_5070323_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "才是真的為那位大人著想。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然如此……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們只需要傾盡全力來守護他。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一切都是為了弟弟！",
        "unit_id": 117111,
        "voice": "vo_adv_5070323_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們上，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "惠理子！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "凡是妨礙那位大人的傢伙，",
        "unit_id": 117011,
        "voice": "vo_adv_5070323_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我會把他們消滅得片甲不留……！",
        "unit_id": 117011
    }
]