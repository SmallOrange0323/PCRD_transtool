    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可能有點不妙～",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "溫泉之神的體內，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n好像有股非常龐大的力量……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "充滿並沸騰著。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "祂該不會是",
        "unit_id": 124711,
        "voice": "vo_adv_5108321_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "打算把累積下來的罪惡與汙穢吐出來吧？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喝太多了啦，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "明明是神明。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 124611,
        "voice": "vo_adv_5108321_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真叫人擔心……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "喝太多對身體來說是毒嘛。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就算是神明大人，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "像那樣一直喝，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n肯定也會對身體帶來負擔的吧……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真不愧是美里，",
        "unit_id": 124511,
        "voice": "vo_adv_5108321_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真敏銳呢～♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……換句話說，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要利用那份負擔，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我們也能有趁隙而入的機會吧。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "原來如此啊。",
        "unit_id": 124711,
        "voice": "vo_adv_5108321_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n意思是既然喝太多，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就要自己承擔後果的意思吧。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼就讓祂稍微",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "再受點教訓吧。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是啊……",
        "unit_id": 124611,
        "voice": "vo_adv_5108321_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要是沒有親身體驗過，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n一定無法真正學到東西吧。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我知道了。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就算因此受傷，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師也會幫忙治療的。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那我也要再接再厲，",
        "unit_id": 124511,
        "voice": "vo_adv_5108321_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n好好看照客人囉～♪",
        "unit_id": 124511
    }
]