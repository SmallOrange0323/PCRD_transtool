[
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──呼、",
        "unit_id": 106411,
        "voice": "vo_adv_0000081_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哈……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是這附近",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在居住區傳聞的",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「可以見到消失的人的祭壇」。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……還以為可以找到尋找贊恩哥哥的線索，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "無數插在地上的劍……",
        "unit_id": 106011,
        "voice": "vo_adv_0000081_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "簡直像是墓碑一樣。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雷也是一直轟隆轟隆地打下來……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正常人可不會特地跑來這裡。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來",
        "unit_id": 105911,
        "voice": "vo_adv_0000081_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "別說是贊恩先生了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "連一隻老鼠的氣息都沒有。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只能說傳聞",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是真的吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明為了跑來吉歐‧格黑納深處",
        "unit_id": 106011,
        "voice": "vo_adv_0000081_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而精疲力盡了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "糟透了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "至少要帶什麼伴手禮走，不然太不划算了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算要找，",
        "unit_id": 105811,
        "voice": "vo_adv_0000081_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也先休息一下之後再找吧，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n走了這麼長的路大家應該都累了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且我的肚子也餓扁了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先放下行李",
        "unit_id": 105811,
        "voice": "vo_adv_0000081_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開始點心時間吧♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛好有個很合適的柱子──",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐，",
        "unit_id": 106411,
        "voice": "vo_adv_0000081_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不是柱子而是劍！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n隨便亂碰會很危險的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦！？",
        "unit_id": 105811,
        "voice": "vo_adv_0000081_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我都沒發現，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的耶……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好大的劍啊。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到底是誰用過的呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔喔喔喔喔喔……"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……剛才，",
        "unit_id": 105811,
        "voice": "vo_adv_0000081_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是不是有",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像狼嚎一樣的聲音？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 106011,
        "voice": "vo_adv_0000081_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才沒聽到那種聲…",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那把劍，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在發光啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳做了什麼好事啊白癡佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦？",
        "unit_id": 105811,
        "voice": "vo_adv_0000081_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我什麼都沒做……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在那邊的人",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是誰……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明直到剛才，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "除了我們之外都沒有任何人。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "贊恩？",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_0000081_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "騙人的吧，",
        "unit_id": 106411,
        "voice": "vo_adv_0000081_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的是，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的是哥哥嗎……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請等一下，",
        "unit_id": 105911,
        "voice": "vo_adv_0000081_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "狀況好像不太對勁。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的是贊恩先生嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝？",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_0000081_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛、",
        "unit_id": 106011,
        "voice": "vo_adv_0000081_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼陛下會在這裡……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "霸瞳皇帝！？",
        "unit_id": 105811,
        "voice": "vo_adv_0000081_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是聖誕節時的巴西利斯克！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明已經和大家一起享用了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有許多",
        "unit_id": 105911,
        "voice": "vo_adv_0000081_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之前享用過……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對決過的強力魔物",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都出現了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "全都是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不可能出現在這裡的存在。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "贊恩等人",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_0000081_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！",
        "unit_id": 105811,
        "voice": "vo_adv_0000081_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來完全不像是能溝通的樣子呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我提議",
        "unit_id": 105911,
        "voice": "vo_adv_0000081_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這邊先暫時撤退。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要和他們戰鬥",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在是太危險了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我贊成。",
        "unit_id": 106011,
        "voice": "vo_adv_0000081_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算是冒牌貨，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又要和陛下戰鬥什麼的就算是惡夢也要有個限度。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒關係吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……好。",
        "unit_id": 106411,
        "voice": "vo_adv_0000081_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我不會放棄的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n因為有可能可以找到，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "尋找哥哥的線索……！",
        "unit_id": 106411
    }
]