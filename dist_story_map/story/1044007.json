        "voice": "vo_adv_1044007_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "做得太好了！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n貝殼啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓妾身恢復成原本的模樣吧！",
