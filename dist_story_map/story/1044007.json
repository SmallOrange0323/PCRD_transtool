    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有時候能變回原本的姿態……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但這種暫時性的變身是不行的。",
        "unit_id": 104412
