        "voice": "vo_adv_1044007_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n雖說身為妾身的眷屬，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也優秀過頭了吧！？",
