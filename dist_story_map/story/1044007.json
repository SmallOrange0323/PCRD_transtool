        "voice": "vo_adv_1044007_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個真的很不好找。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身花了三天三夜都還――",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就說了你也太快了啦！？",
