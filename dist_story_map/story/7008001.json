[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說回來，",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n小栞之前",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是不是說過",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "自己有一個姐姐？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊名叫初音，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n隸屬於【森林守衛】。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你姐姐是什麼樣的人呢？",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n應該和",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "小栞很像吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這個嘛……",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很溫柔，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有點愛操心……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "和我不一樣，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是個活力十足的人。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是……",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "活力十足……",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "睡得很好？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而且不管到什麼地方都能睡得很好？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不管在哪裡都睡得著。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我提醒過她，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣很危險……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聽起來真是狂野奔放呢～？",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我原本以為",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "她和小栞一樣，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是個端莊賢淑的人呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "狂野奔放……",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然有點",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不太一樣，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過她是很堅強的人。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我希望",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "自己有一天能變強到",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n足以保護姊姊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "小栞……",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳好了不起……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這麼說來，璃乃",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n偶爾也會提到關於姊姊的事吧？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她是個什麼樣的人呢？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔。",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳說的……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n指的應該是靜流姐吧……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖說是姐姐，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但是跟妳們姊妹的感覺有點不一樣～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過啊，我們之間確實存在著強烈的羈絆。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哎呀，",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "簡單來說……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "她是個",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "古怪偏執的人。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "古怪偏執？",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "她是個堅強",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "且值得信賴的人……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過只要遇到關於哥哥的事，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就變得",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有點恐怖……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過不過，",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "她平常其實很溫柔喔？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊～",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的滿痛的……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵……",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她一定",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是個很有趣的人。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對了對了，",
        "unit_id": 101112,
        "voice": "vo_adv_7008001_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說到姐姐，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "前陣子啊――",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊",
        "unit_id": 103811,
        "voice": "vo_adv_7008001_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也為了我――",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在攀登高塔的過程中，\n兩位妹妹興高采烈地聊著關於姐姐的話題。"
    }
]