    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萬聖節的早上，有人來敲了美咲家的大門。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來了～",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是誰啊～？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼歐歐歐歐歐！",
        "unit_id": 1611,
        "voice": "vo_adv_1083003_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呀啊啊啊啊啊！",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為什麼會有魔物來我家……！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不要靠近我！　",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "快給我滾開～！",
        "unit_id": 105011
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "打倒了……？　",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "太好了太好了――！　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我一個人打倒魔物了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我要去跟班上的男生炫耀……",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "魔物說話了！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "噫！　",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "光憑小孩子的力量……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要是不在這裡打倒牠，那媽媽他們就……！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……嗯？　",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "牠剛才",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是不是說話了？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……啊啊啊啊啊！",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是{player}吧！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "想瞞混過去也沒用唷！",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這套衣服，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不就是之前我們去服飾店我幫你選的那套嗎！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一大早的，你跑來做什麼啦！",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嚇死我了……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不對，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我只是稍微被嚇到而已！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你說這是萬聖節的搗蛋？",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是笨蛋呢……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "萬聖節是要問，要給糖，還是搗蛋選一種啦！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒拿到糖果才能夠搗蛋！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是說，",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你就為了做這種事情還特地早起嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……唉，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你還真像是個小孩子。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "偶爾像這樣陪小孩子玩",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也是一個成熟淑女該做的事情。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "美咲，早安啊～！",
        "unit_id": 211,
        "voice": "vo_adv_1083003_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，早安。",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼了嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們接下來",
        "unit_id": 211,
        "voice": "vo_adv_1083003_016"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n要去學院借教室舉辦萬聖節派對～",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哦，",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在學院開派對啊！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那不是很棒嗎！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "伊緒老師說我們可以開派對沒問題的～",
        "unit_id": 111,
        "voice": "vo_adv_1083003_018"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "所以",
        "unit_id": 211,
        "voice": "vo_adv_1083003_019"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "才想說來約美咲一起去！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "一起去玩吧！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "派對……",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對呢，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那我也……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "約她也沒用啦！",
        "unit_id": 111,
        "voice": "vo_adv_1083003_021"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n美咲才不會來參加這種小孩子氣的派對呢～",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼！？　",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為、為什麼突然這麼說！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "因為嘛，",
        "unit_id": 111,
        "voice": "vo_adv_1083003_023"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "每次我們在玩，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n她不是都會笑我們說簡直就跟小孩子一樣嗎！？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什……",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_024"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就是這樣！　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你們真的就是小孩子啊！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我才不會跟你們一樣隨便就玩開了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那種孩子氣的派對，我才不去呢！",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_025"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "可是，",
        "unit_id": 211,
        "voice": "vo_adv_1083003_026"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我覺得美咲來參加的話，一定會很好玩的說……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "算了啦，",
        "unit_id": 111,
        "voice": "vo_adv_1083003_027"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "美咲不是說她不來了嗎，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我們走！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯、嗯……",
        "unit_id": 211,
        "voice": "vo_adv_1083003_028"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那再見囉，美咲……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……哼！",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼嘛……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我才不羨慕他們呢！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我最討厭萬聖節了！",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_030"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才不要呢！",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_031"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "反正我去了也會覺得不好玩……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那還不如跟你待在一起比較好！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為我跟大家不一樣，不是小孩子了，",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我才不去那種派對呢！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……咦？　",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要我回想一下之前可以拿到點心的那個活動？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要是固執地",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_034"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不說出真正的想法，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就沒辦法拿到自己真正想要的東西……？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……的確，",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_035"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那時候我說我才不要什麼點心之後，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n結果卻看到了真的很想要的點心，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真的很後悔……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你、",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_036"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你這樣說的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我會害羞啦，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "笨蛋。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唉……",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_037"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "老實說你在這方面有話直說的地方，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n真的很像大人呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "連在這種時候都能冷靜應對，",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_038"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才是一個成熟的淑女。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我得跟你學習一下才行。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "坦然面對自己真正的想法。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也想",
        "unit_id": 105011,
        "voice": "vo_adv_1083003_039"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "跟大家一起參加派對！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為那樣一定會很好玩的！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "既然決定了，",
        "unit_id": 105011,
