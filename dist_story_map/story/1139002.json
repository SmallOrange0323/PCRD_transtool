[
    {
        "type": "background",
        "background": "501130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "最後變成要擔綱戲劇主演和特效的紡希，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和{player}一起展開行動。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒想到不只是特效，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n連主演都要由我來負責……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這絕對是騎士先生害的啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這不是害我被你那種無法對困擾的人",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n視而不見的濫好人個性給傳染了嗎！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也沒辦法了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n既然都答應了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就只能全力以赴地去做。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你聽好囉，騎士先生！",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n既然如此，我一定要打造出優秀的舞台劇！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的尊嚴可不允許自己拿出不上不下的成果！",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會要騎士先生成為我的左右手，為我工作喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然我總覺得你好像只有氣勢，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但回答得很好。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那麼，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "距離舞台劇上演也沒多少時間了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們馬上開工吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說回來，騎士先生，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你不知道這次的舞台劇",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要上演的戲碼對吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要騎士先生看劇本好像會很花時間，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我就簡單地說明一下……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在萬聖夜裡，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有一名吸血鬼女孩來到鬧區，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n在和人們相處的過程中，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "最終和某位男子……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "反正，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就是像這樣的故事。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接著我要問問題了。",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你知道我們一開始該做的事情是什麼嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真虧你能這麼充滿自信地回答我耶！？",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你是怎麼一回事啊？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n把嘗試思考的精神",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "忘在某個地方了嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟俗話說",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "餓肚子就沒辦法戰鬥啊。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我懂我懂。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然你能開這種玩笑，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就代表還不需要吃飯對吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉，不過雖然出題的是我，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但坦白說我也對演戲這領域不怎麼熟悉，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以也不太清楚",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一開始該做什麼。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……該從什麼事情開始著手才好呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小望她在演戲的時候，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "又是怎麼做的啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對了……",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "揣摩角色！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n她是先從",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "化身為主角這件事情開始的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓自己的心境和主角同化，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "藉此來熟悉整個故事……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那就趕快來揣摩角色……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這個故事的主角是……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吸血鬼",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對吧……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "偏偏是傳說中的生物嗎……",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要是時間夠充裕，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "或許就能到處查找文獻之類的",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n來研究生態等部分……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真讓人傷腦筋呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只靠我的想像來演戲也不太好……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種狀況",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是要我怎麼揣摩角色才好啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "根本不可能有人了解吸血鬼的事情吧～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊？",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你說有認識吸血鬼？",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你是睡昏頭了嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你的表情看起來非常認真呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "先不論這件事情的真假……",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n和騎士先生尋求揣摩角色的意見或許會很不錯呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖說這也只是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "比一個人毫無頭緒地摸索……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要來得好。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟你不論好事壞事都會直率表達，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n應該會毫無顧忌地說出意見……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼騎士先生，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我接下來要開始揣摩角色了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生的任務就是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對我的演技發表感想！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再說得誇張一點，",
        "unit_id": 105411,
        "voice": "vo_adv_1139002_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是指導我的演技！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你要做好這件事喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哼哼。",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這就是人類的城鎮嗎……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還真熱鬧呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你是指哪一部分？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……你說語氣",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要有老婆婆的感覺？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是這種感覺嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哼哼。",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這就是人類的城鎮嗎……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "多麼地熱鬧呀。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "的確，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣子感覺比較像個吸血鬼呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也就是說，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "演技也要更加成熟和妖豔",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n才會比較好嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "像是這樣──",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呵呵，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我要讓你成為我的俘虜……♪",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有點不太對？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "女吸血鬼的感覺不是這樣的？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要更孩子氣一點？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但一牽起手就會變成熟的感覺？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你在說什麼啊？？？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃……",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算問你細節，我也搞不太懂。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但簡而言之",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是這種感覺嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哈哈哈哈哈！",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就讓你們成為妾身的俘虜！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好好感謝妾身吧！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這、",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣啊。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我這不是在懷疑騎士先生……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但這位吸血鬼",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給人的感覺還真有趣耶……？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後──"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然已經決定好演技的方向了，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這樣應該就能開始處理特效的部分了呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟主角好像會是一個挺有趣的女孩，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "把舞台的特效",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "做成喜劇風格應該會比較好吧……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "最後的場景",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就利用之前的開朗感覺，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n刻意營造出感人的氣氛……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然自己實際飾演後，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n更容易決定特效要怎麼做呢……！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "問題在於",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這個特效所需的器材……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n雖然燈光和煙霧",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些基本設備他們會準備好，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但只靠這些沒辦法做得很細膩呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我果然太貪心了嗎？",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n活用現有的東西是不是比較……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……！",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你說得對，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妥協不是件好事呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可以拜託你一件事嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n在蘭德索爾",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有個工作人員，慈樂之音舉辦演唱會時",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n經常請他幫忙，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "希望你可以去跟那個人借器材。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會把需要的器材列一張清單交給你。",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我想只要報上我的名字，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他一定會願意出借的。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為大概沒辦法一次就搬完，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n會麻煩你來回跑好幾趟……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你做得來吧？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就拜託你囉！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會趁這段時間",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "確認舞台細節的！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "又過了幾天──"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這件服裝……",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n以角色來說",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再華麗一點會比較好吧……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但現在才重新下訂也……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然自己動手做也是一個辦法……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不。",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們說過，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要把所有能做到的事情做好啊！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可以麻煩你一下嗎！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n能不能拜託你去幫我張羅我接下來提到的素材？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但當中",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還包含了很難取得的東西，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以可能會需要你找遍整個城鎮……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "拜託你把縫紉道具──",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好快！？",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你挺機靈的嘛……！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你相當了解我呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n有種默契十足的感……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不、",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還不夠！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這樣還不夠喔！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不可以得意忘形！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也真是的，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼會坦率地稱讚騎士先生啊！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們才沒有默契十足呢，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總而言之，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "素材的事情",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就拜託你囉！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因為舞台劇上演的日子就快到了！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和騎士先生在一起時，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的會讓人亂了步調……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後，到了舞台劇的前一天──"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "器材的確認，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_055"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "OK。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n服裝已經準備完成，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也把劇本徹底記熟了。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來只需要",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "迎接明天的到來……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總覺得時間過得好快……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟我同時也有在做裁縫店的工作，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n幾乎沒有休息的時間呢……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊……",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼啊，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是騎士先生啊。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……那個。",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生也累了吧？",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為我一直在使喚你啊！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你居然能不說喪氣話，跟著我走到這一步，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "以騎士先生來說，算是做得很棒不是嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣不對。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次辛苦你了，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我真的沒想到你會一路陪我走到現在。",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_063"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n雖然我說過",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "「你要成為我的左右手～」什麼的，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但我拜託你的事情",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "卻比那還要更強人所難呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這次真的幫了我很多。",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_064"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……謝謝你。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "稍微有點……",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對你刮目相看了。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的就那麼一點點",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而已喔！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你、",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你那是什麼表情啊！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一臉簡直就像看到了珍禽異獸的表情！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我坦率地稱讚人有這麼稀奇嗎！？",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_067"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這個人很失禮耶！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種事可沒有第二次了喔！？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_069"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明天就要正式上場了！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天要好好休息，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "以萬全的狀態迎接表演當天！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "工作還沒有結束，",
        "unit_id": 113911,
        "voice": "vo_adv_1139002_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就麻煩你要好好做到最後一刻囉，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "滔滔不絕地說完了這番話的紡希，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雙頰卻像是有點害羞似地泛紅了起來。"
    }
]