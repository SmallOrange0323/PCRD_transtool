    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}將關係人聚集在宴會會場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n向真正的凶手這麼說道──"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "什麼！？",
        "unit_id": 134712,
        "voice": "vo_adv_5210009_000"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為為為、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為什麼是我！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不對，難道是我嗎！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "騙，",
        "unit_id": 136212,
        "voice": "vo_adv_5210009_001"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "騙人的吧，小騎士。",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "小鳳不可能做這種事的！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n對吧？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "……不會對吧？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "對啊對啊對啊！",
        "unit_id": 134712,
        "voice": "vo_adv_5210009_002"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "說到底",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我也差點遇害了不是嗎！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n你說我到底犯了什麼罪呀！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "！！！！！！！",
        "unit_id": 136212,
        "voice": "vo_adv_5210009_003"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "！！！！！！！",
        "unit_id": 136011,
        "voice": "vo_adv_5210009_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "！！！！！！！",
        "unit_id": 137411,
        "voice": "vo_adv_5210009_005"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "！！！！！！！",
        "unit_id": 134712,
        "voice": "vo_adv_5210009_006"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n…………",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不不不！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "雖然我順勢驚嚇了一下！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n但你這句話是什麼意思啊！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "原來如此，",
        "unit_id": 136212,
        "voice": "vo_adv_5210009_007"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "小鳳的確",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "是個美女……",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是、",
        "unit_id": 136011,
        "voice": "vo_adv_5210009_008"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是啊，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "有一種神聖的優雅……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不，",
        "unit_id": 134712,
        "voice": "vo_adv_5210009_009"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "沒有啦，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "這………………",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "畢竟我是非常偉大的",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "神明嘛？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "美麗又華麗？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "的確是事實？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "要是達到鳳凰大人一般的境界，",
        "unit_id": 50711,
        "voice": "vo_adv_5210009_010"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "\n光是存在",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "就足以魅惑一切……",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "的確",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "可說是罪孽深重的存在呢。",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "鳳凰就是美之傳說！",
        "unit_id": 1,
        "voice": "vo_adv_5210009_011"
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "小鳳傳說由此展開！！",
        "unit_id": 1,
        "voice": "vo_adv_5210009_012"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "怎麼淨說這些真話……",
        "unit_id": 134712,
        "voice": "vo_adv_5210009_013"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……嘿、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嘿嘿嘿嘿……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "真、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "真的嗎？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我有那麼美麗嗎？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯……",
        "unit_id": 134712,
        "voice": "vo_adv_5210009_014"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "好吧，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "既然你們說到這個份上，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那就沒辦法了！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我就爽快一點",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "承認自己的罪刑吧！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "民眾",
        "words": "唔哦哦哦哦哦────────！",
        "unit_id": 1,
        "voice": "vo_adv_5210009_015"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嘿嘿嘿嘿……",
        "unit_id": 134712,
        "voice": "vo_adv_5210009_016"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咦、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "奇怪？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我們原本",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "到底在討論什麼呢？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我說騎士先生？",
        "unit_id": 134712,
        "voice": "vo_adv_5210009_017"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "這副手銬是怎麼回事？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "呵呵呵，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "很失禮喔！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "別這樣別這樣別這樣！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n奇──────怪──",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "────！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鳳凰就這樣認罪並接受審判，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被判處要用拔下的羽毛製作和服之刑──"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不……",
        "unit_id": 137412,
        "voice": "vo_adv_5210009_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小鳳的確是很可愛沒錯……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但這麼對她會不會太過分了？",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過",
        "unit_id": 137412,
        "voice": "vo_adv_5210009_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能打破「差點遇害的人不會是凶手」",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這先入為主的觀念，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你真厲害呢。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以此為前提，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再推理一次看看吧。",
        "unit_id": 137412
    }
