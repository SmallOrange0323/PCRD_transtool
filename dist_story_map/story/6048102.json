        "words": "嗚嗚……",
        "unit_id": 113811,
        "voice": "vo_adv_6048102_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "明明就是【惡魔偽王國軍】，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n卻穿著天使的衣服……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總覺得無法冷靜下來啊……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 113811,
        "voice": "vo_adv_6048102_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真的很麻煩呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一開始思考就停不下來了，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個話題到此為止，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "聽到了沒！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不是，",
        "unit_id": 113811,
        "voice": "vo_adv_6048102_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我根本沒聽說過有那種公會。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "繼續用這個樣子",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "待在【惡魔偽王國軍】裡\n真的好嗎？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊～討厭！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不要說這種會讓人不安的話！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、",
        "unit_id": 113811,
        "voice": "vo_adv_6048102_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你的感想根本一點也不重要啦！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "穿成這個樣子",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "的確很可愛呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總覺得心情好複雜啊……",
        "unit_id": 113811
    }
]