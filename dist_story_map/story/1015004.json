[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美里正在和{player}談論自己所照顧的孩子們。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那孩子真的很愛撒嬌呢，",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n如果我摸摸其他的孩子，馬上就會吃醋喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "若看到有其他孩子正在躺膝枕，他雖然會投來羨慕的眼神，",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n但要是跟他說「過來吧～」，就會因為害羞而逃跑喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖然有各式各樣的孩子，但是大家都像我的小孩一樣可愛唷。",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵♪不介意的話，你要不要也試試看膝枕呢？",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我的膝枕，在孩子們之間可是大受歡迎喔～\n來～過來吧～♪",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀？那是什麼呢～",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n散發著強烈的光芒呢～",
        "unit_id": 101511
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚哇──嗚哇",
        "unit_id": 131,
        "voice": "vo_adv_1015004_005"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "──！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，跌倒了呢～沒事的喔～",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n老師幫你施個魔法。痛痛、痛痛，飛走囉──♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚嗚……",
        "unit_id": 131,
        "voice": "vo_adv_1015004_007"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚……",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嘿嘿、",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "耶嘿嘿♪",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n美里老師謝謝你─！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不謝～好乖好乖。",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n停止哭泣了呢～真不愧是男孩子。好帥氣啊～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀？這不是{player}嗎。",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你好呀，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在散步嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "老師我要膝枕─！",
        "unit_id": 131,
        "voice": "vo_adv_1015004_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀，好的好的。真是個撒嬌鬼呢～",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，剛好也到了與孩子們一起在公園遊玩的時間了～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可以的話{player}要不要也一起來呢？",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "能陪他們一起玩的話，孩子們也會很開心的─",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "什麼什麼──！大哥哥也是為了美里老師的膝枕而來的嗎──？",
        "unit_id": 131,
        "voice": "vo_adv_1015004_013"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯！老師的膝枕很舒服的喔──！",
        "unit_id": 131,
        "voice": "vo_adv_1015004_014"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n總覺得呢──軟綿綿又好暖和！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，得到這樣的評語真高興呢～",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_015"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "果然沒錯──！老師的膝枕超級舒服的對吧──！",
        "unit_id": 131,
        "voice": "vo_adv_1015004_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，撒嬌鬼又多了一名♪",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_017"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那也可以讓大哥哥先喔──！",
        "unit_id": 131,
        "voice": "vo_adv_1015004_018"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n因為我平常可以常常躺！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀。",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n真溫柔呢～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵♪那麼，",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n來躺在老師的腿上吧～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "怎麼樣呢～",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n這在幼稚園孩子們之間大受好評……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀♪{player}真是的♪\n真愛撒嬌呢。",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好乖好乖，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我是媽媽哦～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "老師和大哥哥好恩愛──！",
        "unit_id": 131,
        "voice": "vo_adv_1015004_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀這個孩子，從哪裡學來這個詞的呢。",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_024"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我的爸爸跟媽媽啊，一直都很恩愛喔！",
        "unit_id": 131,
        "voice": "vo_adv_1015004_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，爸爸跟媽媽感情真好呢～",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_026"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯！老師和大哥哥不親親嗎──？",
        "unit_id": 131,
        "voice": "vo_adv_1015004_027"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "爸爸和媽媽總是在親親喔──？很陶醉地！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀，怎麼辦才好呢～",
        "unit_id": 101532,
        "voice": "vo_adv_1015004_028"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦你了。",
        "unit_id": 190011,
        "voice": "vo_adv_1015004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1015004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後大部分都會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即使如此，你撒嬌成那樣……",
        "unit_id": 190011,
        "voice": "vo_adv_1015004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n年紀也不小了，不覺得害羞嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對看著的人來說都要起雞皮疙瘩了喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1015004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然你或許是順著氣氛也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，完全沒露出厭惡的表情，包容一切的美里小姐，",
        "unit_id": 190011,
        "voice": "vo_adv_1015004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "果然就像聖母一樣呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也想被那樣的老師給照顧呢～",
        "unit_id": 190011,
        "voice": "vo_adv_1015004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說得太多也有點不識相，這次就到此為止吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1015004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再怎麼撒嬌也要適可而止哦？再見囉──",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯……",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_036"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n哎呀哎呀，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一不注意兩人似乎都睡了午覺呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是因為睡著前聊到這個話題的關係嗎……",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_037"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "感覺好像在夢中讓你膝枕了唷～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀！難不成你也做了一樣的夢嗎？真不可思議呢～！",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_038"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵♪",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_039"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n……膝枕，要試試嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒關係的喔～",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_040"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n盡量向我撒嬌吧♪",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你看，我是媽媽喔～",
        "unit_id": 101511,
        "voice": "vo_adv_1015004_041"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}雖然很開心能夠享受膝枕，\n另一方面，也覺得有些害羞。"
    }
]