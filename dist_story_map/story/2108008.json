        "unit_id": 191711,
        "voice": "vo_adv_2108008_001"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n你還沒走嗎？",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……你這傢伙，",
        "unit_id": 191611,
        "voice": "vo_adv_2108008_002"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n剛才說的那些都是認真的吧？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你說要一個人",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "獨自對付公主騎士那些人。",
        "unit_id": 191611
