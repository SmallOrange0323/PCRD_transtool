    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "沒錯。",
        "unit_id": 191711,
        "voice": "vo_adv_2108008_003"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "…………",
        "unit_id": 191611,
        "voice": "vo_adv_2108008_004"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "如果美空提供的「情報」屬實，",
        "unit_id": 191611,
        "voice": "vo_adv_2108008_005"
    },
