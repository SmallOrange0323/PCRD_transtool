[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了收到下一本活動紀錄，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}來到了神殿。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦，",
        "unit_id": 104411,
        "voice": "vo_adv_9004011_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那果然非常美味呢！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n魔力要滿出來了……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如此一來，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就能變回原來的模樣……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊，",
        "unit_id": 105611,
        "voice": "vo_adv_9004011_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的很好吃呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "非常值得等待啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔，",
        "unit_id": 104411,
        "voice": "vo_adv_9004011_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然連{player}也來了嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n勸你趕快去排隊比較好。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不然馬上就要賣光了哦。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀，",
        "unit_id": 105611,
        "voice": "vo_adv_9004011_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "瞧小哥一臉不知情似的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n新年時",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒買到的吉祥年糕就要重新販賣了──",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n難道小哥不是這麼聽說而趕來的？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦，",
        "unit_id": 104411,
        "voice": "vo_adv_9004011_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "辛苦了。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不過，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "反正都來這裡了，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你就休息一下，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吃份年糕吧。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 105611,
        "voice": "vo_adv_9004011_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在我們這樣聊天的過程中，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "隊伍也在愈排愈長呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那是……",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500560"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哇哇，",
        "unit_id": 102511,
        "voice": "vo_adv_9004011_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼辦……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n在迷路的時候，居然已經排了這麼多人！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣一來，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就算現在開始排，也買不到的……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "怎麼會、怎麼會！",
        "unit_id": 118011,
        "voice": "vo_adv_9004011_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我趁著工作的空檔來光顧，結果卻大排長龍！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這樣肯定是買不到了，真是的……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……那是妾身在某處看過的臉，",
        "unit_id": 104411,
        "voice": "vo_adv_9004011_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是你認識的人嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她們看起來",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "被如此之長的隊伍嚇到說不出話了……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是，",
        "unit_id": 105611,
        "voice": "vo_adv_9004011_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只要堅持到最後，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就能像先前的雪菲一樣地順利的哦。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚……",
        "unit_id": 102511,
        "voice": "vo_adv_9004011_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我是因為之前在新年會上",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n吃到的手作年糕很美味，所以才來的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但是人這麼多，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看來是吃不到了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "在新年會上，陛下嘴上一直說著美味，非常高興──",
        "unit_id": 118011,
        "voice": "vo_adv_9004011_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為了那樣的陛下，我悄悄得到能再次買入的機會，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "本來想讓陛下再次開心的說！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呀！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好不甘心呀～！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}！？",
        "unit_id": 102511,
        "voice": "vo_adv_9004011_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n說、說得沒錯……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只要撐到最後，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就有逆轉的可能性……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我明明就有公會競速賽時的經驗，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "卻忘得一乾二淨……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我沒有被您訓責的理由，",
        "unit_id": 118011,
        "voice": "vo_adv_9004011_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "輕易放棄",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "確實不像我會做的事情呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然已經超過休息時間一下子了……",
        "unit_id": 118011,
        "voice": "vo_adv_9004011_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但還差一點！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就差一點了……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "店員，",
        "unit_id": 102511,
        "voice": "vo_adv_9004011_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不好意思！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請問",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還有我們的份嗎……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n咦，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還有？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太好了～！！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總算是買到了！",
        "unit_id": 118011,
        "voice": "vo_adv_9004011_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這樣一來，就能看見陛下的笑容了！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下，請等著我，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我會證明我有多麼忠心耿耿～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也",
        "unit_id": 102511,
        "voice": "vo_adv_9004011_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能讓咲戀小姐們感到開心了……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒有放棄，真是太好了～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}，謝謝你！",
        "unit_id": 102511,
        "voice": "vo_adv_9004011_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "今後我也會",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "以不放棄的心",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "繼續努力……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "腳、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "腳滑了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊啊！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一邊思索著直到最後都不放棄的重要性，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊品嚐著吉祥年糕的美味，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}收下活動紀錄，前往了下一個目的地。"
    }
]