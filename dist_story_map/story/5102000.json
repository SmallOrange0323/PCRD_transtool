    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以就拜託她",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "來幫小智上課。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀──",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_057"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我在公會小屋跟鈴閣下玩著遊戲的時候，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n【王宮騎士團】的團長突然跑來了啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的嚇我一大跳啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "害我以為",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「我要被逮捕了！？」",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是，",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_058"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在聽她解釋之後，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我覺得很有趣所以就接下任務了～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會好好教智閣下",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很多宅宅知識喔～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先不說那個，",
        "unit_id": 102611,
        "voice": "vo_adv_5102000_059"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼連我都要當講師啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n七七香一個人就夠了吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我覺得我比較適合當",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在旁邊滾來滾去耍廢的角色啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀哎呀，",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_060"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有什麼關係嘛！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這絕對會很有趣的！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n而且這樣",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說不定",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "能讓玩遊戲的夥伴增加喔？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "玩遊戲的夥伴……！？",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_061"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果能有那種夥伴感覺會很有趣呢！",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_062"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我有",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "繼承御久間流的使命！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我不能分心到……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "遊戲上……！　",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我、",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_063"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我對",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "遊戲什麼的沒興趣啦。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔～？",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_064"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n在體會到遊戲的魅力後，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳還有辦法這麼說嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_065"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不只是遊戲而已喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我也會好好為妳解說",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女之類的魅力喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼，",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_066"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "魔法少女……！！？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔……！",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_067"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我其實很喜歡，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也有很多想跟她們聊的東西……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是我必須要",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "忍住！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我已經決定要為劍術而活了啊……！　",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……雖、",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_068"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我並不喜歡什麼魔法少女。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是這是為了任務，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我姑且",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "聽聽看吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是姑且喔。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔嗯唔嗯……",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_069"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來如此。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n智閣下是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種類型的人嗎。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "教起來應該會很有成就感呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小七七香、",
        "unit_id": 104711,
        "voice": "vo_adv_5102000_070"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小鈴。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這次謝謝妳們願意擔任講師。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小智她",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就拜託你們了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯嗯，",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_071"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "交給我們吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我會把智閣下",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "變成喜歡遊戲、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喜歡漫畫的人喔♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不、",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_072"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不不不！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不管是",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "遊戲、",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "漫畫",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還是魔法少女！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我都絕對不會喜歡上的！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼──",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_073"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是個有趣的女人！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們還要做一些準備，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天就先到此為止！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n妳就好好期待",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明天的講義吧～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼辦……",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_074"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然講義本身感覺會很有趣……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是我要注意，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "絕對不能被她們發現我喜歡什麼……！　",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "身為【王宮騎士團】成員，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然後又是御久間流繼承人的這些身分，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n讓智加深了要保密到底的決心。"
    }
]