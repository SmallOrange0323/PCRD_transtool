        "voice": "vo_adv_5102000_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想交給小智的任務。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "內容是──",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "──當超人氣直播主",
