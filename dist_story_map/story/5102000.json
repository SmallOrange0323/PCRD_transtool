[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──蘭德索爾的人們最近十分浮躁。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這是因為「蘭德索爾文化祭」就快要到來了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這樣浮躁的人也存在於【王宮騎士團】中……"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "……我說啊。",
        "unit_id": 711,
        "voice": "vo_adv_5102000_000"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "這次的蘭祭，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "\n你決定要從哪開始逛了嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "\n我打算",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "以遊戲展示會為主喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "其實",
        "unit_id": 717,
        "voice": "vo_adv_5102000_001"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "我這次有報攤，然後抽中攤位了啊。",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "\n現在",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "正在畫新刊……",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "目前",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "處於趕稿修羅場之中。",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "真的嗎。",
        "unit_id": 711,
        "voice": "vo_adv_5102000_002"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "你要擺攤啊。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "感覺很辛苦呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "\n是說，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "你畫了什麼同人誌啊？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "是原創作品喔。",
        "unit_id": 717,
        "voice": "vo_adv_5102000_003"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "\n內容是主角以成為頂尖直播主為目標，",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "\n努力做遊戲實況的故事……",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "前輩們，",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "現在正在巡邏中不是嗎？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "同人誌的話題",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就等你們下班之後再聊吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "哎呀，",
        "unit_id": 711,
        "voice": "vo_adv_5102000_005"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "抱歉抱歉。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "\n不過，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "小智妳",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "真的很認真呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "前輩過獎了。",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n身為【王宮騎士團】團員這是理所當然的。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為了守護人們，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "必須先遵守紀律才行。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "是啊，",
        "unit_id": 711,
        "voice": "vo_adv_5102000_007"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "妳說的對。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "我因為蘭祭近了而有些鬆懈了呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "\n……啊，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "對了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "我想起來了，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "團長在找小智喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純找我……？",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "她好像",
        "unit_id": 711,
        "voice": "vo_adv_5102000_009"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "是要拜託小智執行特別的任務的樣子。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "\n不過，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "詳情妳就去問團長吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "謝謝你告訴我這件事。",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這附近的巡邏",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就拜託你們了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "了解。",
        "unit_id": 717,
        "voice": "vo_adv_5102000_011"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "好啦，",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "我們也向小智看齊，",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "\n認真工作吧。",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "就是說啊。",
        "unit_id": 711,
        "voice": "vo_adv_5102000_012"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "話說回來……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "同人誌",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "如果畫不完就跟我說吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "\n如果是塗黑或是貼網點的話，我能幫忙喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "嗯，",
        "unit_id": 717,
        "voice": "vo_adv_5102000_013"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "謝謝你……",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "那，",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "可以請你今天就來幫忙嗎？",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "\n我一個人看不到終點，",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "已經三晚沒睡了……",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "……你今天",
        "unit_id": 711,
        "voice": "vo_adv_5102000_014"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "要好好睡覺喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的。",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就算祭典快要到了，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n大家也太興奮過頭了吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "同人誌",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗎。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那種東西……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那種東西……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我好想讀……！",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好想讀讀看！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我至今都沒有讀過任何一本同人誌啊！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "大家",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都畫了怎樣的漫畫啊？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我好在意……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "蘭祭上",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也會舉辦新遊戲的展示會吧？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我好想去喔……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我之前就對",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "格鬥遊戲之類的有興趣了！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "RPG跟棒球遊戲感覺也很有趣啊！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……啊！",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不行！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我要振作一點……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是我自己決定的……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我不會對遊戲或漫畫這類的興趣出手……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是【王宮騎士團】的團員，",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也是歷史悠久的御久間流的繼承人。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我還不夠成熟……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我沒時間投入到劍術以外的地方。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我對遊戲跟同人誌",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都有興趣……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是為了將劍之道登峰造極，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我不能隨便繞遠路。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還有，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我也要注意不能被人發現",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我喜歡魔法少女這件事。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然很遺憾，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是如果跟別人說我喜歡魔法少女，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可能會有人說",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我很孩子氣之類的。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "身為肩負責任的人，",
        "unit_id": 103712
    },
