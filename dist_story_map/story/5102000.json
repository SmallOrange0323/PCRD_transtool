        "voice": "vo_adv_5102000_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒錯。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次文化祭上，",
