        "voice": "vo_adv_5102000_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "事件對他們造成很大的心靈創傷吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……不能再繼續",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "放任加害者製造下一個受害者了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "犯人是會做這種過激行動的人。",
        "unit_id": 104711,
        "voice": "vo_adv_5102000_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n他有可能盯上參加文化祭的人氣直播主。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以",
