        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還有LIVE舞台等活動的祭典。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然是護衛任務，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是既然都跟文化祭有關，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "加深對它們的理解很重要吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且，",
        "unit_id": 104711,
        "voice": "vo_adv_5102000_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "理解護衛對象，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在執行任務上也是件很重要的事情啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……就是這樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "老師，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "拜託妳們了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有人喊我就蹦出來鏘鏘鏘鏘～！",
        "unit_id": 1,
        "voice": "vo_adv_5102000_051"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼……！？",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳們是……！？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是",
        "unit_id": 101311,
        "voice": "vo_adv_5102000_053"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女七七香！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這位是",
