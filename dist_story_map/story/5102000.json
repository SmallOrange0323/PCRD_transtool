        "voice": "vo_adv_5102000_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那是",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼任務……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近整個蘭德索爾，",
        "unit_id": 104711,
        "voice": "vo_adv_5102000_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n流行著應用通訊魔法進行的動畫實況……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正如小智所知，",
        "unit_id": 104711,
        "voice": "vo_adv_5102000_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n發生了多起人氣直播主被攻擊的事件。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……就是那個",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "「直播主獵人」對吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然被害者們沒有生命危險，",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是不幸中的萬幸……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是聽說很多被襲擊的人都終止實況了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那也難怪。",
