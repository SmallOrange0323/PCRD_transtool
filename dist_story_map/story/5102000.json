    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "某個人……？",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次",
