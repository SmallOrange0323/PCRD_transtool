        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_5102000_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不對。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "比起這個……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n純她在找我。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要快點過去才行……",
        "unit_id": 103712
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗨，",
        "unit_id": 104711,
        "voice": "vo_adv_5102000_025"
    },
    {
