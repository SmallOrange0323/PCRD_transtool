    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我聽說",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她是蘭德索爾現在",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最有人氣的直播主。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
