        "voice": "vo_adv_5102000_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我聽前輩說了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n他說",
        "unit_id": 103712
    },
