        "name": "純",
        "words": "小智。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳來啦。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n事情妳已經聽說了吧？",
