        "voice": "vo_adv_5102000_055"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這到底是……！？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說到【暮光流星群】的收藏家，",
        "unit_id": 104711,
        "voice": "vo_adv_5102000_056"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n她對遊戲之類的",
