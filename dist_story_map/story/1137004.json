[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "作為天使在努力著的茜里，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n讓因為吵架而心情沮喪的孩子們和好了。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "來，",
        "unit_id": 113711,
        "voice": "vo_adv_1137004_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好好地說對不起吧？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗯……",
        "unit_id": 416,
        "voice": "vo_adv_1137004_001"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n對不起，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我對妳惡作劇……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "沒關係，",
        "unit_id": 415,
        "voice": "vo_adv_1137004_002"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我沒事。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我們和好吧！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呵呵，",
        "unit_id": 113711,
        "voice": "vo_adv_1137004_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "相親相愛才是最好的。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "以後",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "吵架要適可而止，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有精神地一起玩吧。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好──！",
        "unit_id": 1,
        "voice": "vo_adv_1137004_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿♪",
        "unit_id": 113711,
        "voice": "vo_adv_1137004_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n被哥哥誇獎了呢。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "看到許多的人露出開朗的笑容，",
        "unit_id": 113711,
        "voice": "vo_adv_1137004_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "連茜里也跟著高興了起來。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n雖然讓他人打起精神是天使的職責，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但反而是茜里從他人那裡獲得了活力呢。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒錯沒錯！",
        "unit_id": 113711,
        "voice": "vo_adv_1137004_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "開朗的笑容",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "看起來",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就會像這樣閃閃發光呢。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "看到這種閃閃發亮的感覺，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "會讓人感到非常幸福！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦？",
        "unit_id": 113711,
        "voice": "vo_adv_1137004_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……不是看起來好像在發光，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "該不會",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥你真的在發光吧～！？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀啊啊～！",
        "unit_id": 113711
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唉……",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥！",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓你見笑了。",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我遇到了點讓人沮喪的事情……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀啊！？",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n下、",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "下雨了……？",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "突然就下起雨來了～！",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我們去找地方躲雨吧！",
        "unit_id": 100632
    },
    {
        "type": "still",
        "still": "113700401"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇啊啊……",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好大的雨喔。",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "差一點",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就要被淋成落湯雞了……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然馬上就躲進了公車站裡……",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但茜里還是淋濕了啦～！",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊！",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "討厭～",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥這個色狼！",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n你別盯著我一直看啦～！",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里的衣服",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "都變透明了！",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我今天穿的是決勝內衣……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "給哥哥看的話就沒關係♪",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦？",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你沒怎麼淋濕呢，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n是因為站的地方正好有遮到雨嗎？",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對了！",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n只要和哥哥緊靠在一起，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里應該也一樣不太會淋濕了！",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿咻……♪",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n嘿嘿，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好溫暖♪",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你問我剛才嘆氣的理由",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是嗎？",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實今天",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有薩克斯風的發表會，\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但我有點失誤了……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我為了今天",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "做了很多的練習，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n可是",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "卻在不擅長的地方太緊張了……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只不過",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我心想不能因為太在意失誤而影響演奏，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以很快就在演奏中轉換了心情。",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為了不讓聽演奏的人",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "注意到我的失誤，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我有帶著笑容",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一直演奏到最後……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因此我",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "現在",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才會一個人感到沮喪。",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n唉……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是不是我練習得還不夠呢～",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為了讓自己有幹勁，",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我還特地",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "穿了決勝內衣呢……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦！？",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里明明失誤了，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥卻還誇獎茜里？",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我自己",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "的確",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "無法接受那場演奏，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但會場的聽眾",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "都給了我許多的掌聲……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "大家還都露出了笑容，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "看起來真的很高興的樣子……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就、",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_029"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就算那樣誇獎我",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也沒什麼好處喔……",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥該不會",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是什麼奇怪的企圖吧？",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呵呵，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "說笑的♪",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "總覺得……",
        "unit_id": 100632,
        "voice": "vo_adv_1137004_030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "和哥哥傾吐煩惱之後，",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 100632
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就變得有精神了！",
        "unit_id": 100632
