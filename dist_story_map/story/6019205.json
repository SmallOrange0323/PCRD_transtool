    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒想到鈴奈",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是那樣想的，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我好高興。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幫了我，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我很感謝你……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你那麼坦率的接受道謝，",
        "unit_id": 110211,
        "voice": "vo_adv_6019205_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真讓人有點",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不甘心呢。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難得",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你這次真的讓人覺得",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很可靠呢……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "明天的活動",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要盡情的享受喔！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哎呀？　",
        "unit_id": 110211,
        "voice": "vo_adv_6019205_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還真是成熟的應對呢。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n是因為夏天的關係嗎？　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你看起來",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "感覺更可靠了……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也要",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "以成為更成熟的淑女為目標，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好好享受夏天！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "當然囉！　",
        "unit_id": 110211,
        "voice": "vo_adv_6019205_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為我是最棒的朋友。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "明天的活動我也會",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "拚命幫鈴奈",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "加油的！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幫她加油這件事，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我可不會",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "輸給其他粉絲的～！",
        "unit_id": 110211
    }
