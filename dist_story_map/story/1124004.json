    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是你在發光嗎！？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "你沒事吧！？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n難不成，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "被施了什麼奇怪的魔法嗎……",
