[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一個沒有【哞哞自衛隊】和老家工作的休假日。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真琴為了打發時間而在街上散步。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼啊……",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只要沒有工作做，就好無聊啊～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "最近這陣子都在老家的店裡不停工作，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有必要休息一下就是了～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比我想像中的還要更無事可做。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哎呀，這可不行。",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這樣搞得我好像工作狂一樣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "即使是我，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也是有好幾個假日嗜好的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……這種時候，",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只要{player}在，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就不會覺得無聊了啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒辦法，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為了打發時間，就去找一下他……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "找到了找到了♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂──",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "他是在跟誰說話嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那是……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是好險，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "差點就打擾到他們了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…………",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "笑得很開心的樣子耶。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這是件好事。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……他們果然很登對啊。",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不能打擾他們……",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "走人吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "糟糕，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "他看見我了？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是被發現了嗎……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "幹嘛過來這裡啦，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要管我了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "繼續跟優衣待在一起……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼了……？",
        "unit_id": 104311,
        "voice": "vo_adv_1043011_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這道光",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好刺眼……！",
        "unit_id": 104311
    },
    {
        "type": "background",
        "background": "510180"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……怎麼，",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "又是{player}你啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你一到午休就會到頂樓來耶，",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是很閒嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還是說你在班上沒朋友？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不太可能吧。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "畢竟你人脈很廣嘛，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "主要是認識很多女生。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～？",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那是什麼意思，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是在說我嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是有時間理我這種人，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那你更應該去跟其他人聊天吧……？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不讓這傢伙",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "多跟優衣聊天的話，我會很困擾的啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……才不是和我聊天咧。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n像這樣單獨和他在頂樓聊天",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是第幾次了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……完完全全",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "變得理所當然了啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "過",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還滿意外的，感覺並不壞。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n畢竟我們很聊得來，這還挺神奇的。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n之前也是，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聊到午休時間不知不覺就結束了♪",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不不不，",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我幹嘛要這麼開心啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這種時候正是",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "幫優衣一把的好機會啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃～",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要不要偶爾也讓我試試開個話題啊～？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你、",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你這個人啊，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n喜歡什麼樣的女孩子？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊？",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼叫任憑我想像！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你可別以為我會接受這種模稜兩可的答案喔！？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好啦，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你就和我說說看嘛～♪",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……？",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你幹嘛啊？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼要那樣子盯著我看……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n騙人",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "的吧？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你……！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咳咳。",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我知道你不打算坦白了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你的防備心還真堅固，",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我挺意外的。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我還以為你的個性會再更輕浮一點耶。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你這樣比較強悍，我滿中意的！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是說，",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這跟我中不中意沒什麼關係吧。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘖，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我果然不該自己開話題的～",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯？",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n有人來了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "…………",
        "unit_id": 6732,
        "voice": "vo_adv_1043011_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是女生……",
        "unit_id": 104331,
        "voice": "vo_adv_1043011_029"
    },
    {
