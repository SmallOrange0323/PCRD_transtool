        "type": "dialogue",
        "name": "鈴莓",
        "words": "爆炸了～！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n救救我呀～！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "魔物植物",
        "words": "──嘎喔喔喔喔喔！？",
