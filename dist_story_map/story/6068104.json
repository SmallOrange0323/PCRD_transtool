[
    {
        "type": "background",
        "background": "501340"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你是指領班對吧？",
        "unit_id": 116711,
        "voice": "vo_adv_6068104_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我不敢",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "直呼她的名字！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "她工作總是很俐落，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且深受大家的信賴，讓我很佩服她！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要怎麼做才能變得像領班一樣能幹呢……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此，",
        "unit_id": 116711,
        "voice": "vo_adv_6068104_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要變強，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就能像領班那樣充滿自信地工作，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你是這個意思對吧！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "傭兵有一種可怕的感覺，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以我可以先跟好朋友號練習嗎……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟領班",
        "unit_id": 116711,
        "voice": "vo_adv_6068104_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總是",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說效率很重要嘛！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也想從辦得到的事情開始努力起！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就先從吐槽1000次開始效率化……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟領班說",
        "unit_id": 116711,
        "voice": "vo_adv_6068104_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自己是打工鐵人嘛。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果能同時打好幾份工，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "確實是能縮短跟領班的距離……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過我自己一個人沒有自信，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你可以陪我一起嗎？",
        "unit_id": 116711
    }
]