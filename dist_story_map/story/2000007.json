[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "非常感謝你們！",
        "unit_id": 100211,
        "voice": "vo_adv_2000007_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "多虧了你們的幫助……\n我差點就要被吃掉了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不用客氣，您沒事就好。",
        "unit_id": 105913,
        "voice": "vo_adv_2000007_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您為什麼會被那一大群魔物追捕呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "比起那女孩，我想牠們的目標應該是我喔。",
        "unit_id": 105812,
        "voice": "vo_adv_2000007_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那女孩應該只是剛好路過，",
        "unit_id": 105812,
        "voice": "vo_adv_2000007_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n而被捲了進來吧…………",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很抱歉造成了你們的困擾",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是您嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2000007_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，是怎麼回事呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，您到底是什麼人……？",
        "unit_id": 105913,
        "voice": "vo_adv_2000007_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n甚至連您的名字都還不清楚呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，我也還沒報上我的名字呢。",
        "unit_id": 100211,
        "voice": "vo_adv_2000007_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我叫優衣。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真的非常感謝你們的幫忙……♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，好的。",
        "unit_id": 105913,
        "voice": "vo_adv_2000007_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下名叫可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這位是在下的主人。{player}大人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……我們是不是在什麼地方有見過呢？",
        "unit_id": 100211,
        "voice": "vo_adv_2000007_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂～！",
        "unit_id": 105812,
        "voice": "vo_adv_2000007_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n大家請過來這裡！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好像有人昏倒了喔～",
        "unit_id": 105812,
        "voice": "vo_adv_2000007_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡應該有人會使用回復魔法吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_2000007_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我擅長回復魔法！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "至於那個昏倒的人……嗯？",
        "unit_id": 100211
    },
    {
        "type": "still",
        "still": "200000202"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………。",
        "unit_id": 1,
        "voice": "vo_adv_2000007_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個人是怎麼了呢？",
        "unit_id": 100211,
        "voice": "vo_adv_2000007_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "跟我一樣都是因為剛好經過而被捲入的嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n看上去雖然沒有外傷，卻不知道為什麼昏過去了！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "治療之類的就交給妳囉。",
        "unit_id": 105811,
        "voice": "vo_adv_2000007_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n附近還有魔物在蠢蠢欲動，我去把牠們趕走！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請大家帶著那位昏倒的人一起避難吧～♪",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算要避難，這裡這麼多魔物也很難行動啊。",
        "unit_id": 105911,
        "voice": "vo_adv_2000007_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105911,
        "voice": "vo_adv_2000007_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n饑腸轆轆的貪吃佩可小姐……先這樣稱呼您吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在我們是在同一條船上了，一起脫離險境吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～貪吃佩可是在叫我嗎？",
        "unit_id": 105811,
        "voice": "vo_adv_2000007_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被取了個可愛的綽號呢～太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只有這些魔物的話，我一個人就能輕易～地殲滅牠們呦♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這可不行呢，怎麼可以老是讓人幫忙！",
        "unit_id": 100211,
        "voice": "vo_adv_2000007_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也要參戰！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也一起參戰吧，主人。",
        "unit_id": 105911,
        "voice": "vo_adv_2000007_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是不好意思，",
        "unit_id": 105911,
        "voice": "vo_adv_2000007_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然這場相遇突然間就這樣變得十分混亂。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從今以後還請多多指教。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們的故事，",
        "unit_id": 105911,
        "voice": "vo_adv_2000007_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就從這裡開始吧……♪",
        "unit_id": 105911
    }
]