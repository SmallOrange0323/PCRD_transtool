[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "醫院的事件解決後，深月回到蘭德索爾，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n作為密醫，一如往常過著忙碌的每一天。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好，",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣就治療完畢、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "呀啊！",
        "unit_id": 911,
        "voice": "vo_adv_5074007_001"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "醫、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "醫生啊，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "拜託對受傷的人再溫柔一點吧……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對待因為興奮過頭而受傷的冒失鬼，",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這麼做是剛好而已。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你下次要是再做同樣的事，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我就拿你來做人體實驗哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "咿！",
        "unit_id": 911,
        "voice": "vo_adv_5074007_003"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "我、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "我知道了啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "所以拜託妳千萬別這麼做──！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉真是的，",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "明明好不容易回來蘭德索爾了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n結果還是這麼忙，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "和在醫院時沒兩樣呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼可能。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "去幫助人",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種事實在是不像我。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我還是比較適合當個密醫。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳嘴上這麼說，",
        "unit_id": 1,
        "voice": "vo_adv_5074007_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看起來還是做得挺開心的啊♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這聲音是……",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "鏘──",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是我唷！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗨～醫生，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好久不見了呢♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n妳也差不多",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "開始想見我了吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了，那我們回家吧。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等一下啦！",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳這樣對待一起戰鬥的夥伴",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "太過分了喔！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳不就只是個不請自來的護理師嗎？",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯，算了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳今天來有什麼事呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這還用說嗎！",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "之前問妳能不能成為我的主治醫師，我是來聽妳的答覆的！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難道",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳是以我會答應為前提嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "難道妳要拒絕嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "醫生妳真是的，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比頭目還要固執欸。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這話我可不能當作沒聽到。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "剛好這裡有款新藥，妳要施打看看嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是使用從醫院沒收來的院長的研究資料，",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n以及一部分貴重的素材所特製而成的藥品哦？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這該不會，",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是會變成那種怪物的藥……？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不要不要！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是變成那副模樣，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還不如死了算了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "安心吧。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我不會做出那種",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "品味低級的成果。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這只是營養劑而已，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過效果太強，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "三天內都會睡不著覺就是了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管是哪種我都不要！",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是我是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不會放棄讓醫生成為我的主治醫師這件事的！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這我倒是希望妳快點改變主意呢。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要有醫生在，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就能毫無壓力地健康過活，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也能維持美麗的肌膚呀？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我變得越美麗，",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這個世界就會變得越幸福啊！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳能不能也為我是否會壓力激增而考慮一下呢？",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_023"
    },
    {
        "type": "dialogue",
        "name": "頭目　",
        "words": "怎麼了怎麼了？",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_024"
    },
    {
        "type": "dialogue",
        "name": "頭目　",
        "words": "我還想說怎麼這麼熱鬧，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "頭目　",
        "words": "\n英雄們這不都聚在一起了嘛。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是頭目！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好久不見，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你該不會",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是想見我了吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "哈，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_026"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "那種事",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "等五年後再說吧。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好久不見了呢。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你看起來很有精神真是太好了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼樣？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要不要打一針試試？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "不用了。",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_028"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我的傷好不容易才癒合完，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n那種可怕的東西妳就自己收著吧。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我已經受夠藥這種東西了。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這倒也是。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大病初癒的你來這種地方是有什麼事呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "啊啊。",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_030"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "在那場戰鬥之後，我因為要療養暫時動彈不得，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "沒能好好地向你們道謝。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "所以我來打聲招呼。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "這次",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_031"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "你們實在幫了大忙。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "就讓我再鄭重地向你們道個謝吧。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "謝謝你們。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還真是重禮節啊。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我那是因為是工作，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要道謝的話，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就謝那邊那兩人吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啊好啊！",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_033"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你可以大大地感謝我喔♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "身為醫生我就姑且問一下，",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你在那之後還好嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話是這麼說，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "長期作為院長的實驗品，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n再加上受了那種傷卻還能活蹦亂跳的，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應該是不必擔心就是。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "嗯，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_035"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "身體很健壯就是我",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "唯一的優點哪。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "總之，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_036"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "身體方面是沒問題啦。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "不過，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "其他問題可就堆積如山了。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "受院長欺騙，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "給咱們一家的那些傢伙們添了麻煩。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "害得來道一家變得衰弱，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_037"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "最後連鎮上都受害。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我真的是太沒出息了。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "所以現在我正在為了一家的重振、",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_038"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "鎮上治安的恢復、",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n還有",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "尋找繼任者而四處張羅著。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "繼任者？",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_039"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也就是說……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "對，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_040"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "目前的問題都解決完後，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n我就要從頭目這個位子退下來了。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我必須得為這次的失態負責，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_041"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n而且我也想重新修復",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "因我而分崩離析的家庭關係。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "女兒和妻子當然不會輕易原諒我吧。",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_042"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n但是，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我想讓她們看見我想好好面對家人的決心。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是",
        "unit_id": 100811,
        "voice": "vo_adv_5074007_043"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "頭目不在的話沒問題嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我並不是馬上要退下來。",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_044"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我會趁現在",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "好好鍛鍊那些傢伙的。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "而且因為這次事件，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_045"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n他們應該也了解到",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "不能老是依賴我了吧。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "哈哈，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_046"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "既然將軍都這麼說了，我就放心了。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼既然",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_047"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "頭目要展開這樣全新的旅程，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也來",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "送你個餞別禮吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "嗯？",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_048"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "這是什麼？",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請款單呀。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_049"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你該不會打算要賴帳吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "別說蠢話了，",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_050"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我會完完整整付給妳的。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "唉，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "既然找了像妳這麼精明能幹的人來幫忙，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "\n",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "我也有心理準備相應的金額會……",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "嗯嗯？",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "喂、",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_051"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "喂，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "這個……",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "零的個數會不會太多了啊？",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哪裡。",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_052"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我可是有跟委託人清楚告知過哦？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說過了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我可不便宜。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但既然我和你關係這麼好，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以讓你分期付款哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "唉……",
        "unit_id": 7411,
        "voice": "vo_adv_5074007_053"
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "妳這傢伙，",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "地痞頭目",
        "words": "果然是地下社會的人啊。",
        "unit_id": 7411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_5074007_054"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "從今以後",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也請多關照囉♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "深月露出了一如往常有點壞心眼、且帶點魅惑的微笑。"
    }
]