    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "歡迎光臨！",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n歡迎光臨",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "海之家，『鹽味・西瓜』♪",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個海之家取了好像很好吃的名字呢！？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，奇怪？",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你好！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n記得好像是【咲戀育幼院】的女僕……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n等等，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你是鈴莓對吧？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好巧呢！",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好開心能在這遇見你～，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以抱一下嗎？",
        "unit_id": 107511
    },
    {
        "type": "still",
        "still": "107700302"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這位客人這樣我很困擾～！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然已經聽說了事情的來由……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n今天真的是",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "【美食殿堂】的大家一起來海邊玩呢。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好羨慕你們感情這麼好～。",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我們家的可可蘿和{player}，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n平常受到你們的照顧了。",
        "unit_id": 107711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊別這麼說，",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們才是！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來{player}和小可蘿，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是住在【咲戀育幼院】嗎……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才會說",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我們家的』",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呢？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真好。",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}和小可蘿，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經有家人了呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然也許感覺很親暱……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}和可可蘿，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n說到底也只是暫時寄住在我們家白吃白喝而已。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也許有一天會離開這裡也說不定，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n太投入感情可是不行的呢。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有什麼關係呀。",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「有一天」",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之類的悲傷未來永遠不會到來，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也許這樣說可能太誇張了……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這種事想再多也沒用的吧？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來，",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以點個飲料之類的嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊是，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請說！？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果中暑的話就糟糕了，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請好好地補充水分呢！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要在店裡喝嗎？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果晚點能把杯子歸還的話，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要外帶也是可以的哦～？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只要來點餐的話，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "近距離也是有外送的！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "服務一百分呢！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可要多捧場呢～，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟這裡有可愛的店員呢！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱抱♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就、",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就說了不要抱著我！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這位客人，我很困擾～！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}！　別擔心！\n只是這位客人他，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n在尋求過多的肌膚接觸而已啦～！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔，",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}！\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}竟然穿著海之家的圍裙，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難道{player}在這裡工作嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　想說最近都不見人影……！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊……",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其實海之家，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為人手不足所以很辛苦呢。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也是第一天上班還沒適應工作，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n很冒失還跌倒之類的，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "挫折不斷。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為看不下去，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以{player}",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就來幫助我。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過我沒問題的，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然說了好多次～",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請和大家一起來玩吧。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很像{player}的風格呢～，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是看到有困難的人沒辦法放著不管",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的好人♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的。",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "他很溫柔的，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}……\n在【咲戀育幼院】也是，\n非常主動的幫忙做家事。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說，",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果真的很辛苦的話，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也來幫忙工作之類的吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "放心吧，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也常常在餐廳打工，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以已經習慣了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊不，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的沒問題的！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然不知道原因，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為沒什麼客人來",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以還滿空閒的～？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "現在這時候，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n頂多也只有【美食殿堂】",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "的大家來買飲料之類的。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就算增加",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "店員人手，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也沒什麼意義。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}也",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "別顧慮我快點去玩吧。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然說人手不足，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但因為比想像的還不忙，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我想只要我和店長就可以處理得過來。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔。",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果客人蜂擁而來，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n忙不過來的話，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就把我們叫來幫忙吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "千萬不要客氣，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也超喜歡工作♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是。",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說確實都沒什麼客人，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知為何",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變成只有我們包場的狀態呢……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還以為是來海邊的季節，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底為什麼呢？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我也覺得很奇妙……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不過總覺得",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣比被人群淹沒在沙灘上好。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n在安靜的大海，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可以悠閒度日呢。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好讓人羨慕呢。",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n真好啊，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "度假的感覺……♪",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 107511,
        "voice": "vo_adv_1077003_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼鈴莓",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "工作結束後一起來找我們玩吧！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "充分工作後，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果還有體力的話……♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那麼請務必，讓我參加哦～♪",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 107711,
        "voice": "vo_adv_1077003_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n今年的夏天，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像會變得不太一樣……♪",
        "unit_id": 107711
    }
]