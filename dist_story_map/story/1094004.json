        "type": "dialogue",
        "name": "安",
        "words": "對吧！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，幸福的時光轉瞬即逝。"
    },
    {
        "type": "background",
        "background": "500353"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――從外面隱隱約約地傳來，某人正在哼著歌的聲音。\n跟隨那美麗的歌聲，向前走去……"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……呼。",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_013"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "唔、",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_014"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "奇怪？　",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "哇……{player}！",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "剛、",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "剛才的，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "你都聽到了？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "嗚嗚、",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_015"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "你全都聽到了對吧……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "好害羞～……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "因為晚上太開心了，",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_016"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "總覺得還有點興奮",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "睡不著覺……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "於是試著出來散步後，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "卻發現今天是個寂靜又美好的夜晚，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "所以就……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_017"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "不過，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "這是一首很棒的歌曲對吧。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我聽說這是可可蘿教安",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "唱的歌曲……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "想感謝她給我如此美妙的禮物，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "晚點還得向可可蘿說才行。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "還有{player}……",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_018"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n安在練習唱歌的時候，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "你一直都陪在她身邊對吧？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "謝謝。",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_019"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "多虧有你，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我才能留下這麼美好的回憶。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "那是一段十分明亮",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "又快樂、",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "閃閃發光的時光……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……和安在一起的時光",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_020"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "總是那麼地美好。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我之前說過吧？",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_021"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "來到馬納歷亞之後，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "還是有點害怕和大家互動，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n所以就常常待在音樂塔……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "這件事。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "那天我也是",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_022"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "一如往常地一個人彈奏著鋼琴。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n然後――",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "安就出現在我的面前了。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "對著這樣的我",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_023"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "搭了話……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "陪我",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "一起彈奏鋼琴。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "那時候的光景，",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_024"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "直到現在我都還記得很清楚。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我所看到的世界，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "就像瞬間染上色彩一般……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n突然",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "眼前事物都綻放出耀眼的光芒似地。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_025"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "你是不是覺得",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我太誇張？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "不過，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "對我而言，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "安真的是",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "一個改變我的世界的人。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "鋼琴合奏、",
        "unit_id": 109411,
        "voice": "vo_adv_1094004_026"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "一起出去玩、",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "留宿……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n這些快樂的時光",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "全都是安讓我體會到的。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "今天也是……",
        "unit_id": 109411,
