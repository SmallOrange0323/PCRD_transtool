[
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "各位～！　",
        "unit_id": 103211,
        "voice": "vo_adv_2013002_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "從現在開始",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們要進行避難了唷，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n大家跟著我的腳步走！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n雖然已經說了無數次了，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但還是請大家莫急莫慌莫害怕！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不！",
        "unit_id": 103211,
        "voice": "vo_adv_2013002_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n反而讓我們更加高雅地來行動吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔～呵呵呵呵☆",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯。",
        "unit_id": 104811,
        "voice": "vo_adv_2013002_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再再感受到，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "果然還是秋乃最適合在前頭引領著大家了呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不僅外貌出眾，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "聲音也很宏亮……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n是在前頭，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "搖旗吶喊身先士卒的最佳人選呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等到全部解決了……",
        "unit_id": 104811,
        "voice": "vo_adv_2013002_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "並且回到和平之後，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要不試著找找看這類型的工作來做呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n感覺聞到了一門好生意的味道了呢♪",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚～咕，",
        "unit_id": 103411,
        "voice": "vo_adv_2013002_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸嘿嘿嘿嘿……♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哇……",
        "unit_id": 104811,
        "voice": "vo_adv_2013002_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳不要亂動。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "美冬？　",
        "unit_id": 103211,
        "voice": "vo_adv_2013002_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "把背著喝醉酒後睡著的優花梨這份工作，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n交給妳沒問題嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "看妳走起路來搖搖晃晃的，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不介意的話要不要交給我呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳",
        "unit_id": 103211,
        "voice": "vo_adv_2013002_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為了祭典的準備工作之類的一直忙到今天，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n甚至通宵了好幾天吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果太勉強的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可是會倒下的唷？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳以為又是誰，",
        "unit_id": 104811,
        "voice": "vo_adv_2013002_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "才會害得我的工作必須搞得這麼勉強才能完事啊？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過別擔心，",
        "unit_id": 104811,
        "voice": "vo_adv_2013002_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨就放心交給我吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這是適材適所唷，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳就去完成妳的責任吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……再怎麼說我們也只能靠妳了嘛，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "隊長。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好的！",
        "unit_id": 103211,
        "voice": "vo_adv_2013002_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n呵呵，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那就更得讓妳瞧瞧本小姐那帥氣的一面囉♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸嘿嘿……",
        "unit_id": 103411,
        "voice": "vo_adv_2013002_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n美冬醬的背上，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "冰冰的",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好舒服耶……♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗚呀，",
        "unit_id": 104811,
        "voice": "vo_adv_2013002_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳不要用臉蹭我！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是的，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這不是完全喝醉酒了嗎……？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個。",
        "unit_id": 103711,
        "voice": "vo_adv_2013002_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【墨丘利財團】的各位，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們並不是要去野餐，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以還是稍微有一點緊張感吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過嘛，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看妳們感情這麼好有點讓人羨慕就是了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們【王宮騎士團】和\n【哞哞自衛隊】會負責找出安全的路線，",
        "unit_id": 103711,
        "voice": "vo_adv_2013002_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "或是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "殺出一條血路，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以還請妳們不要走散，跟緊我們。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好喔！",
        "unit_id": 103211,
        "voice": "vo_adv_2013002_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "城內……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "像是陷入了大混亂之中的感覺，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣真的還會有安全的路線嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔～嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_2013002_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不只到處都有『闇影』，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還有",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "應該是它們變成的",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像黑色泥濘的東西，溢的到處都是。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以也打算，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "盡可能迂迴地前進就是了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因此，",
        "unit_id": 103711,
        "voice": "vo_adv_2013002_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不論如何大概都會耗費不少的時間吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以雖然得避免急躁與慌張，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但還希望大家能盡量積極一點來行動。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那種事我們最擅長囉。",
        "unit_id": 104811,
        "voice": "vo_adv_2013002_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過就連【哞哞自衛隊】也願意來幫忙指引避難呢，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n究竟是什麼風把妳們吹來了？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳們不是和【王宮騎士團】，\n可說是水火不容的嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_2013002_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在是非常時期。",
        "unit_id": 101011,
        "voice": "vo_adv_2013002_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "或許",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該說是戰爭時期，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但我們可不能夠再繼續鑽牛角尖下去了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "過去的事",
        "unit_id": 101011,
        "voice": "vo_adv_2013002_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就讓它過去，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓我們攜手互助一同前進吧……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就算耳朵和尾巴有所不同，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但我們也都同是人類呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103711,
        "voice": "vo_adv_2013002_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是幫大忙了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n之前，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "明明克莉絲提娜還給妳們添了那麼大的麻煩。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我選擇了原諒。",
        "unit_id": 101011,
        "voice": "vo_adv_2013002_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以說，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在這之後每個人都能夠更加地",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和睦相處就好了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不論誰都能笑著，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和平且幸福地居住著的世界，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然或許只是童話故事",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也說不定。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但人家，",
        "unit_id": 101011,
        "voice": "vo_adv_2013002_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "希望能夠朝這目標邁進呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "公會長，",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然我也很欽佩妳的這份理想，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但現在看來並不是能悠哉聊天的場合了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我一直都在調查著『闇影』，",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也進行過了一些研究，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因此對那些傢伙的性質有某種程度的掌握。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因此『闇影』，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或者說也能預測它變化而成的黑色之物的行動。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是很簡單的推理。",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就讓我推導出安全的路線，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後讓大家能夠安全地避難吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "感謝妳，",
        "unit_id": 101011,
        "voice": "vo_adv_2013002_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "霞。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是可靠呢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真不愧是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "【哞哞自衛隊】中首屈一指的頭腦派呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們其他的人都完完全全不去用腦袋瓜的嘛，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以也就只能靠我來動頭腦囉。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哇呀……",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n最喜歡",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "每次被真步稱讚的時候了♪　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總而言之。",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "黑色之物是從城內各個固定的場所上產生了噴發，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n然後朝著『王宮』而去。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而基本上黑色之物似乎就如同它的外型，",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n和液體，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或是質量較重的氣體有著類似的性質。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "簡言之，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是它們會從高處流向低處。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因此就讓身形輕巧的人",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從屋簷之類的高處，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n換句話說就是從安全地帶上，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "進行偵查來確認路線，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好能夠指引大家來前進，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如此才是上策。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果在無處可逃的死胡同中，",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "迎頭撞上了那像黑色泥濘一般的洪流，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是當場全滅也不無可能。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我們相當謹慎小心地向前邁進吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然某種程度來說",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可以用魔法來讓那黑色之物的動向稍稍改變，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然而那量實在是過於龐大……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是以個人力量無法顛覆的災害，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是先避之再前進較佳。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說得是呢。",
        "unit_id": 101011,
        "voice": "vo_adv_2013002_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但到底為什麼，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會演變成這麼樣的事態呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "完全搞不懂理由呢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "明明是場",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "開開心心又難得的祭典呀～？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "究竟是為何……",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要解開這真相也得等到安全避難之後了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來名偵探的出場還有得等呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總而言之現在，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也只能為了活下去竭盡全力了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是呢……",
        "unit_id": 101011,
        "voice": "vo_adv_2013002_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "獸人居住區那邊",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也很令人擔憂呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n沒辦法和在那兒擔任警備的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴她們",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "取得聯繫。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "通訊魔法",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "聯絡不上，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那兒是不是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也發生了什麼事情呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或者是說。",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n幾乎整座城中，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "弄個不好",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或許是整個世界都被捲入了的大異變也說不定呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這種事若再來一次可無法奉陪呢，",
        "unit_id": 101411,
        "voice": "vo_adv_2013002_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n畢竟這事件的規模可不是一介偵探所能夠解決的呀。",
        "unit_id": 101411
    }
]