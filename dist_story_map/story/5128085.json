[
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想不太起來了呢……",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但再怎麼說，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也不可能會有那種事吧……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊，",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來得正好。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我想跟你確認一下……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們到底",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是怎麼締結婚約的呀？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "因為我想來想去，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都沒有被求婚的記憶。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你記得當時的事嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n……果然，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也不記得自己有求過婚啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然覺得有點奇怪，",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過算了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不記得有求過婚的話，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只要現在再求一次就好了對吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以，",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拜託你",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再重新對我做一次",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n令人動心的",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "俐落告白吧♪",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……什麼？",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說你沒有告白過，所以不知道怎麼做？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要我",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "先示範給你看……？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒、",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒想到竟然來這招……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是傷腦筋……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我也不可能",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "會有求婚的經驗吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不過，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "明明我比較年長，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是說出這種沒面子的事感覺也有點……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……我知道了。",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我不喜歡拐彎抹角的，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是聽起來很平淡也不准抱怨唷？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那麼……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咳咳！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我愛你。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你願意……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "跟我",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "結婚嗎……？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "流夏不安地牽起{player}的手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不發一語。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊……",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呵呵♪",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n謝謝你……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要再稍微……",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接著繼續下去呢？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我現在終於",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對彼此的心意有信心了……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我",
        "unit_id": 127612,
        "voice": "vo_adv_5128085_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "愛你。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "比世界上",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的任何人……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都還要更喜歡你唷。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，兩人彼此相擁，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n直到心滿意足為止。"
    }
]