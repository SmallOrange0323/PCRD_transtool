[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "該怎麼說呢，",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "人生真是難以預料呢……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒想到",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "居然會和你訂下婚約。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喂喂，",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我怎麼可能會不情願呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要是那樣我早就鄭重拒絕了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我看起來像是那種因為順水推舟，就跟人結婚的女人嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個嘛，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n和你結婚這件事，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的確也決定得有點草率。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但就算是這樣，",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我的心意也是千真萬確的哦。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我是因為愛你，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以才會在一起的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了，",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然已經好好確認過彼此的心意了，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就必須把這件事告知身邊的親朋好友才行呢……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……你覺得該怎麼告訴惠理子才好？",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我希望可以盡量",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "避免發生流血衝突。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那樣不太行吧……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一想到在那之後會發生什麼事，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我實在難以說出口啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我也是想盡量穩妥地處理……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過仔細想想，",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "反正也要和咲戀結婚。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "乾脆",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再加上惠理子不就好了？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是那麼做，之後搞不好會換深月生氣……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那不然這樣好了，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "和【暮光流星群】的全部成員結婚！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這樣就不會出問題了，很棒對吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……你說要是和那麼多人結婚，",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "跟我相處的時間就會變少？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這麼說……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也沒錯呢，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "抱歉。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n是我太欠缺考量了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想要和你一起相處的時間。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且還有咲戀在，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不能自己一個人獨占你。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話說回來……",
        "unit_id": 127612,
        "voice": "vo_adv_5128081_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "終於在一起了呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我開心到都要懷疑自己是不是",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在做夢了。",
        "unit_id": 127612
    }
]