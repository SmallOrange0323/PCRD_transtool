[
    {
        "type": "background",
        "background": "500193"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和美美，\n在精靈之森接受鏡華的知識教學。"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "鏡華，這裡要怎麼做呢～？",
        "unit_id": 102011,
        "voice": "vo_adv_5002007_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，這裡呢，這樣計算的話……妳看！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_001"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇～！真的耶～！嘻嘻嘻～",
        "unit_id": 102011,
        "voice": "vo_adv_5002007_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n鏡華的教法真的既簡單又明瞭呢～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真，真的嗎？那真是太好了……",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n對了，妳的燒退了嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯！吃了大家給的藥之後，很快就復原囉♪",
        "unit_id": 102011,
        "voice": "vo_adv_5002007_004"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "一定是很刺激的探險吧？我已經聽哥哥說過了～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯！充滿了陷阱的迷宮，還有",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n長得像油燈一樣的巨大魔物！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好厲害！",
        "unit_id": 102011,
        "voice": "vo_adv_5002007_006"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "如果是美美，說不定太害怕途中就放棄了呢……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也很害怕啊，還好有禊和這個人在……",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n再想到要讓美美恢復健康，就完全不怕了唷！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以呢，下次要大家一起去探險，一定要！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_008"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯！探險♪探險♪好期待哦～♪",
        "unit_id": 102011,
        "voice": "vo_adv_5002007_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華~！鏡華~！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_010"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊～！是禊～！",
        "unit_id": 102011,
        "voice": "vo_adv_5002007_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "又那麼慌張……難道又考了壞成績嗎──！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_012"
    },
    {
        "type": "still",
        "still": "500200701"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華大老師！禊辦到了──！！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇！禊怎麼回事……哦？這個！滿分的考卷！？",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "多虧在那之後鏡華又教了我一次！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n原來禊不是個笨蛋！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊只要願意做就做得到的！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "話說，也是因為我的教法很高明才會……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，又得意起來了！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過這也是事實呢！謝謝妳，鏡華！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "開玩笑的啦！當然這是禊努力的結果呀！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我只是稍微幫了一下忙而已！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華──！嗚嗚──我最喜歡妳了──！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_019"
    },
    {
        "type": "background",
        "background": "500193"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嘻嘻……啊，這樣的話，禊的媽媽不就也很高興了吧？",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "確實沒錯！給媽媽看了之後，",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_021"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n結果增加了我的零用錢呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "所以啊，為了感謝……來，這是禮物！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦！？這，這樣不好啦！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒問題～！是為了鏡華買的呢！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "（會是什麼呢……哈！莫非是蘭德索爾的高級杯子蛋糕！？）",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼就，恭敬不如從命囉。謝謝妳，禊──",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊哈哈哈！上當了──！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊的新惡作劇產品！粉塵嚇人箱～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "因為想看鏡華吃驚的表情就買了嘛～♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……禊、你～！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊哈哈哈！鏡華生氣了──！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那當然的啊！我今天絕對不原諒妳！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請你別說話！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這次完全是禊的錯！一定要懲罰妳！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇──！鏡華對不起！啊哈哈哈哈～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊～！等一下！",
        "unit_id": 103611,
        "voice": "vo_adv_5002007_034"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "怎麼可能會等呢！來抓我啊～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002007_035"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "鏡華和禊果然感情很好呢～♪",
        "unit_id": 102011,
        "voice": "vo_adv_5002007_036"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "那美美就代替鏡華，",
        "unit_id": 102011,
        "voice": "vo_adv_5002007_037"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n來教哥哥唸書吧～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果還是像平常一樣愛吵架的鏡華和禊。\n到頭來被這兩個人晾在一旁，\n教{player}唸書的人就變成美美了。"
    }
]