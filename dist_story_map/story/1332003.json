[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "仍在享受著新年假期的莫妮卡與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到了蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "蘭德索爾，我回來了！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哎呀，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在蛇之騷動時雖然有回來過一次，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但那時候實在是太匆忙了呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然這裡還處在新年氛圍中，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但熱鬧的氣氛",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "已經在吉歐‧格黑納充分感受過了呢，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是時候想來悠閒放鬆一下了。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下你",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有什麼想做的事嗎？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可以的話",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "希望是不會演變成重大事件的那種。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "蕎麥麵嗎。",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "除夕時",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "的確因為工作的關係，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "根本沒那個時間呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "被你這麼一說就開始想要吃了啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好吧，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那就來吃蕎麥麵！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要去哪間店吃？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這次就由我親自",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來招待你吃蕎麥麵吧！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我每年",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都會跟公會的成員一起吃呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就請閣下",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好好期待吧。",
        "unit_id": 133212
    },
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然誇下了海口，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但其實",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我根本沒有做過蕎麥麵……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為每年都是妮諾她在製作，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我跟其他成員",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "專門負責吃而已。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我知道大略的作法，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n還好",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "蕎麥粉也非常充足。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "應該總會有辦法的。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算賣相差了點，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只要加個天婦羅上去",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "肯定沒問題。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "凡事都得挑戰。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就來做吧！　",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為、",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼沒辦法順利成功！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不管做幾次",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "麵團都會散掉，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "無法漂亮地擀開。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "即使追加蕎麥粉跟水",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也完全不行……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "本想說離開最前線的中年男子",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會突然開始做起蕎麥麵，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n還以為我也能夠",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "輕易辦到，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "太天真了……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n到底",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該怎麼辦才好！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……好，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先不管蕎麥麵，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來做天婦羅吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "暫時去處理其他工作",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "轉換",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "心情。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊、",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊啊……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "糟糕，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這可不妙啊……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n天婦羅怎麼炸都炸不脆！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不只是蕎麥麵，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "連炸天婦羅都失敗了……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都要怪我太小看料理的難度，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這些就讓我",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "負起責任全部吃掉吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我還是希望",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "至少",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "能招待那傢伙",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n吃個可以入口的蕎麥麵，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該怎麼辦才好呢……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哈嗚哇！",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個是……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可、",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果現在讓這傢伙來幫忙的話，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有違我當初的想法。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "再這樣下去又什麼都做不出來……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "抱歉，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然我誇下海口，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但不管是蕎麥麵還是天婦羅",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我都做不好。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以我要厚著臉皮",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "拜託你，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "希望你可以幫我。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……是嗎，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不好意思，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感激不盡。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "首先",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是最重要的蕎麥麵，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如你所見，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "麵團一下就會破碎。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我很確定沒錯。",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "袋子上也確實",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "寫著「蕎麥粉」。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
