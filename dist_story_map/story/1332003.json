        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但因為加了很多天婦羅，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n稍微",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有點油膩呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過──",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊啊，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_045"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真的很好吃！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我原本",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_046"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是不打算麻煩這傢伙，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "想要好好招待他",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n吃美味的料理，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但卻因為兩人一起製作",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而感到莫名美味。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也算是因禍得福吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，",
        "unit_id": 133212,
        "voice": "vo_adv_1332003_047"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "事情可不會就這樣結束。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n下次不是臨時起意，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而是好好進行特訓，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一定",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要讓你吃到美味的天婦羅蕎麥麵。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "莫妮卡在心中心默默立下了要挑戰雪恥的誓言。"
    }
]