[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來神殿參拜的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遇上了前來參觀的矛依未。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡就是神殿啊……",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡的氛圍和繁華街廟會上的完全不同，",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但也相當熱鬧，感覺很有趣耶！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有沒有什麼趣事可做呢～？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔哇！",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼啊，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來是你……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別嚇我啦！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "與其說是來參拜，",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不如說是",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺新年時的神殿很有趣才來的。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n畢竟，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不相信世上有神嘛！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該說啊，",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有聽過「言出必行」這句話嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在我看來啊，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "自己許的願就要由自己實現！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我倒是想去抽籤挑戰一下自己的運勢。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我從來沒抽過「這一側」的籤呢。",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也一起來抽吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……嗯？",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這是怎麼了？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n太陽明明早就出來了，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼突然這麼耀眼……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是你",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在發光嗎……？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……是的話……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也太刺眼",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "了吧……",
        "unit_id": 114711
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新年的某一天，矛依未藉米奈娃之力暫時避開了監視，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在大街上閒逛著。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抽了獎、",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還吃了許多好吃的東西……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "日本的新年真棒啊！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼……",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "接下來要做什麼呢～",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n難得的自由時光，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我還沒玩夠呢！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "商店街前有一群人排著隊耶？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我記得那裡……",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像有一間小神社？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來啊，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家是要去參拜。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我不信神，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但去神社湊湊熱鬧好像也挺有趣的！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我也混入人群裡排排看吧……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……嗯？",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙是……！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "完蛋了！",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看見認識的人下意識就上前搭話了，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n忘了我們在「這一側」可是第一次見面啊！　",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就、",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個啊……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是和你同校的學生啦！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是啊！",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我們都只是擦身而過而已！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我有好幾次都有稍微打個招呼喔！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "稍微而已！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呼……",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幸好這傢伙是個超級濫好人……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也排在這個隊伍中，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就表示你也要去神社吧？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那我就跟著你吧。",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我也正好要去那裡呢。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我沒有打算去參拜。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我不相信求神拜佛有什麼用啦。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只是感覺",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "新年時去那裡會很有趣而已！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我已經決定今天要把新年會做的事通通做一遍了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "問你喔，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "去神社除了許願之外，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還有什麼有趣的事可做嗎？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "測試運勢啊！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那我也要抽！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……哦，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看到神社了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼啊，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這個隊伍裡都是排隊等待參拜的人，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抽籤好像不需要排隊耶。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，我在這裡替你排隊，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你先去抽籤吧！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦，歡迎回來。",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n隊伍前進很多了，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像馬上就能進神社囉。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以呢，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "結果如何？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看你那表情，應該是……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈哈，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "果然啊！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你的表情超級陰沉的，不問也能猜到個大概呢！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真是遺憾啊！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "籤紙上還寫了什麼？",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也讓我看看吧！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我看看……",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「旅行：",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最好適可而止」，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n「姻緣：",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會碰上大麻煩」",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……啊。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唉唉，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真慘啊……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這只是個測試而已，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你不必太沮喪啦！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像快要能進神社了耶。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你就繼續排隊，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "進去參拜吧！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我要去抽籤了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你結束後再來找我！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好！",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要抽出比那傢伙更好的籤！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔喔喔喔喔！",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是它了！",
        "unit_id": 106131
    },
    {
        "type": "still",
        "still": "114700401"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼樣！！",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你在說什麼啊！",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哪裡遺憾了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這是最棒的結果耶！！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你剛剛也是因為沒抽到大凶",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才這麼失落的吧！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……喂，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你為什麼愣住了啊。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你該不會，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聽不懂我的意思吧？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「凶」",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是指壞的意思吧？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那比「凶」更壞的「大凶」，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是壞的最高等級。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我很高興能抽到最壞的籤喔！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n哈哈哈哈！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和你一起求籤很開心喔！",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你讓我度過了快樂的新年！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝謝啦！",
        "unit_id": 106131
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呼……",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一不小心就和那傢伙搭話了，",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幸好沒暴露。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "神社意外地有趣呢。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對了！",
        "unit_id": 106131,
        "voice": "vo_adv_1147004_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要拿這張大凶的籤",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "去和尾狗刀炫耀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他一定會嚇一大跳──！",
        "unit_id": 106131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀……",
        "unit_id": 190011,
        "voice": "vo_adv_1147004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然一樣施加了能力防護，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但那孩子的記憶好像在偶然間被播放出來了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許是因為和那傢伙之間的羈絆變得更強烈了吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1147004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望記憶再現",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不會對現況造成什麼影響……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次也沒得到什麼有益的資訊呢……",
        "unit_id": 190011,
        "voice": "vo_adv_1147004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對那孩子來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這應該是她在「那一側」為數不多的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n美好回憶吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她和那傢伙之間",
        "unit_id": 190011,
        "voice": "vo_adv_1147004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "竟然有過這麼快樂的回憶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然有點驚訝，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也讓人放心了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "存取結束。",
        "unit_id": 190011,
        "voice": "vo_adv_1147004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開始重新啟動。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……妳已經與那傢伙和大家成為夥伴了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n今後要創造更多難忘的回憶喔，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "諾維姆。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔、",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_054"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔唔……？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼時候睡著了啊。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_055"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "竟然夢到了以前的事……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還在這種大白天下做了新年初夢。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我都快忘記了，",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_056"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們以前還用抽籤決過勝負呢。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那時兩人互相交換看結果……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對了。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……喂喂！",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_057"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n和我用抽籤決勝負吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "規則只有一個……",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_058"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就是抽到大凶的人勝利！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "吉利？",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_059"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種事啊，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我只會在自己願意相信的時候相信！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以你也別在意這麼多了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來吧，",
        "unit_id": 114711,
        "voice": "vo_adv_1147004_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別廢話了，要開始囉！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n決勝負吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我這次也會贏你的！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順應一臉開心的矛依未，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}向著求籤處走去。"
    }
]