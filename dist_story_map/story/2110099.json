        "voice": "vo_adv_2110099_040"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n話說回來諾維姆，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n妳是如何保有「現實」的知識啊？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊，",
        "unit_id": 106113,
        "voice": "vo_adv_2110099_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那是因為我有自己的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "超能力護盾……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也可以說是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "活用像防禦魔法之類的東西……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該也做了一樣的事……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "的確。",
        "unit_id": 104311,
        "voice": "vo_adv_2110099_042"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也覺得尾狗刀前輩看起來像在裝傻，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但其實知道很多事。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那咱們",
        "unit_id": 101011,
        "voice": "vo_adv_2110099_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也可以施展嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那個什麼",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "防禦魔法的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "活用方法。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這……",
        "unit_id": 106113,
        "voice": "vo_adv_2110099_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不知道。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像不是很擅長",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "教別人學些什麼呢……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀……",
        "unit_id": 101011,
        "voice": "vo_adv_2110099_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們一起想辦法吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家也有",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在學習",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如何駕馭魔法呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說的沒錯。",
        "unit_id": 101411,
        "voice": "vo_adv_2110099_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n該怎麼做比較好……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大家一起思考，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一起行動吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──為了從這個看起來不像是密室，卻又是密室的地方",
        "unit_id": 101411,
        "voice": "vo_adv_2110099_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "逃出去。",
        "unit_id": 101411
    }
]