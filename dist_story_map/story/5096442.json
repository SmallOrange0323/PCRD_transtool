    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ほんと、",
        "unit_id": 117411,
        "voice": "vo_adv_5072442_002"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "いつも順風満帆とはいきませんよね、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n私たちのライブって。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "でも",
        "unit_id": 117211,
        "voice": "vo_adv_5072442_003"
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "最高に輝いてたと思う。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "私たち、３人とも。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "だけど",
        "unit_id": 117211,
        "voice": "vo_adv_5072442_004"
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "まだ安心しちゃダメだよ？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "\nライブが終わったわけじゃないんだから。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "ほら、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "お客さんたちが待ってる！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "これだけ歌って踊って戦って、",
        "unit_id": 117411,
        "voice": "vo_adv_5072442_005"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\nどうしてこんなに元気なんですか～！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "チカ",
        "words": "ノゾミだから、",
        "unit_id": 117311,
        "voice": "vo_adv_5072442_006"
    },
    {
        "type": "dialogue",
        "name": "チカ",
        "words": "としか言いようがありませんね。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "チカ",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "チカ",
        "words": "ですが、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "チカ",
        "words": "私もまだ歌い足りなかったところです。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "……チカさんも元気いっぱいですね。",
        "unit_id": 117411,
        "voice": "vo_adv_5072442_007"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ええいいですよ、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "私もまだまだ動けますし！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "ノゾミ",
        "words": "じゃあ行こっか、",
        "unit_id": 117211,
        "voice": "vo_adv_5072442_008"
