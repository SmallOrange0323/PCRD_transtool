    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可透過mimi聯繫了{player}後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他便來到了鬧區。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘿～！",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你好！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「啊，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得用翻譯功能才行呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "容我重新打聲招呼。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈☆",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你好！」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「嘿嘿，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你特地過來一趟♪",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "實在是太想在今天見到你了，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以把你叫了出來。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「這個嘛……",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實呀！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天是我在阿斯特朗傳奇",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n第一次見到你的紀念日！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你記得這件事嗎？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「我可是記得很清楚呢♪",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當時我還是個剛登入遊戲，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼都不懂的新手，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是你幫了我呢。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「託你的福，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我才能體會到",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n阿斯特朗傳奇是很好玩的。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「我們國家有出資的關係，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我之所以能夠來日本出差，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我覺得也是因為",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我有玩阿斯特朗傳奇。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「多虧如此，我每天都過得很開心。",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不管是在那邊的世界",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是這邊的世界 ♪」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「我想這一切",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也都是多虧有你。所以，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我希望能在與你相遇的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個特別的日子裡，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n表達我的感謝和祝福……」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「以後你也會",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "繼續幫助我，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就像我們初次見面的時候一樣……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「我就知道你會這麼說♪",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是你能",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就這樣",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的能成為我的騎士就好了♪」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「所以，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是你",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "願意的話，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們一起去吃點東西慶祝吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，對了！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蛋糕或許是不錯的選擇呢♪」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「怎麼了？",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你看起來好像有點擔心……」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「你該不會",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "覺得",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會吃一堆昂貴的蛋糕吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才沒那回事呢！」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「雖然我是公主，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我之前也說過，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我平時過得還是很儉樸的。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以你可以放心，沒問題的。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「不過，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我急著出來見你，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都還沒吃東西，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在有一點點餓了……」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「嘿嘿，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的♪",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論在哪裡……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要是在你面前，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我就是那個肚子餓得咕嚕咕嚕叫的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貪吃佩可♪」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「我還不是很熟悉這個這個城鎮，",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有什麼不錯的店的話，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就帶我去吧。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的不用顧慮錢的哦？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「那我們走吧！",
        "unit_id": 105831,
        "voice": "vo_adv_9006002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "相信無論你帶我去哪裡，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都能吃到",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好吃的東西的♪」",
        "unit_id": 105831
    }
]