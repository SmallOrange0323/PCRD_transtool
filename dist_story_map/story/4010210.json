    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "哎～呀，",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_000"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "這不是阿貓阿馬嗎！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "你來得正好，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n這肯定也是",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "我平時常做好事的關係吧～♪",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "什麼！？",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_001"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "你居然忘記本小姐的尊容，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n阿貓阿馬的腦袋果然空空如也嗎！？",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "…………呃",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_002"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "……哎呀？",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "像這樣的庶民，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "本小姐怎麼可能",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "認識",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n呢……？",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "嗯……",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "算了，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "就這樣吧。",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "哦～呵呵，",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_003"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "你記得很清楚嘛！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "不過",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "就算太陽打西邊出來，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n你也不可能忽然忘記本小姐美麗的名字吧？",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "今天是",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_004"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "慶祝本小姐降生的日子，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "也就是",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "我的生日。",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "但不知為何，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "黑衣人們都表示身體不適，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n宴會的成員不足……！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "所以，",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_005"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "我要把這個重大的職責交給你！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n給本小姐準備一場和誕辰慶典相襯的款待。",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "當然，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "我不接受肯定以外的回應！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "真不愧是阿貓阿馬，",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_006"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "看來你很理解自己的立場",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n與我的美麗嘛！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "那就",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "開始",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "你最豪華的款待吧！",
        "unit_id": 134931
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "嗯……",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_007"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "清爽宜人的風，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "還有燦爛耀眼的",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "太陽！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "世界都在祝福我的生日～",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "呃，",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_008"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "這樣不就只是散步嗎！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "這可是慶祝作為世界千金的本小姐生誕的",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "大活動啊！？",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "你是準備用這種野餐就搪塞過去嗎？",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "這個嘛……",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_009"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "的確是？",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "高高在上地俯瞰庶民們的生活，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n再次實際感受本小姐的",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "地位和",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "權力，",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n作為生日活動也還不壞……",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "那麼接下來──",
        "unit_id": 134931,
        "voice": "vo_adv_4010210_010"
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "就去更近的位置",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "眺望庶民的生活吧♪",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "我們去你家吧，阿貓阿馬！",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "\n",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "我會徹底",
        "unit_id": 134931
    },
    {
        "type": "dialogue",
        "name": "伽音",
        "words": "幫你檢查每個角落的～♪",
        "unit_id": 134931
    }
]