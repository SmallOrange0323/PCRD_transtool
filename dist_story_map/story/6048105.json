[
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "唉～",
        "unit_id": 113712,
        "voice": "vo_adv_6048105_000"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "好多人！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "好熱！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這就是音樂節！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n總、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "總覺得和我的世界太不一樣了……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "會不會看起來格格不入啊？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗯、",
        "unit_id": 113712,
        "voice": "vo_adv_6048105_001"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗯，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "有好多穿得很花俏的人，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n更何況站在鈴奈和雪旁邊的話，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n我一點都不顯眼呢！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "說、",
        "unit_id": 113712,
        "voice": "vo_adv_6048105_002"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "說的也是呢。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "如果太戰戰兢兢",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "反而會顯得格外突出啊。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "而且",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "要是茜里的話，一定會全心全意去享受吧……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n我也要這樣才行呢。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "你、",
        "unit_id": 113712,
        "voice": "vo_adv_6048105_003"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "你耍什麼帥啊。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "明明就不適合……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不過，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "你也沒有什麼音樂節的感覺，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n我們都是格格不入的同伴，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "好像稍微有點安心了……",
        "unit_id": 113712
    }
]