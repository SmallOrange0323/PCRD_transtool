        "voice": "vo_adv_5156701_010"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n這個大會，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "要贏到什麼程度才算優勝呢？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "怎麼了雜碎哥哥？",
