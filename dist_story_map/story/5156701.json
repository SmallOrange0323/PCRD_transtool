        "voice": "vo_adv_5156701_007"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "來吧笨菜姊妳也一樣，",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "抬頭挺胸一點啊♪",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗯、",
        "unit_id": 130112,
        "voice": "vo_adv_5156701_008"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗯……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n但是，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我稍微有一點在意。",
