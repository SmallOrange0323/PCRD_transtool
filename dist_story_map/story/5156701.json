        "type": "dialogue",
        "name": "倭",
        "words": "原來如此，",
        "unit_id": 130012,
        "voice": "vo_adv_5156701_013"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "希望對戰的不是只有一兩個呢。",
