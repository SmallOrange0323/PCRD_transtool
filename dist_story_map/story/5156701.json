    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n這個，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "應該是場很正式的大會吧？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "呀哈，",
        "unit_id": 130212,
        "voice": "vo_adv_5156701_015"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "這樣不是很好嗎♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n讓大家通～通變成雜碎吧♡",
        "unit_id": 130212
