        "type": "dialogue",
        "name": "若菜",
        "words": "先、",
        "unit_id": 130112,
        "voice": "vo_adv_5156701_016"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "先等一下。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n在那之前，",
        "unit_id": 130112
    },
