        "type": "dialogue",
        "name": "布武機",
        "words": "引擎OK──",
        "unit_id": 130212,
        "voice": "vo_adv_5156701_020"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "武裝也沒問題。",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "那麼倭姊，",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "拜託妳下指令囉♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "全",
        "unit_id": 130012,
        "voice": "vo_adv_5156701_021"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "給我聽好了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這群不要命的傢伙們！！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這場大會的優勝，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "將會由我們【蠻賊三姊妹】來獲得！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "有意見的傢伙儘管放馬過來！！",
        "unit_id": 130012,
        "voice": "vo_adv_5156701_022"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n讓最強的盜賊跟究極的戰車，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來當你們的對手！！！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "歡呼聲撼動著吉歐‧格黑納的大地。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n戰車駕駛們激烈又盛大的祭典，才正要開始……"
    }
