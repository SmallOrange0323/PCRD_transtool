        "type": "dialogue",
        "name": "若菜",
        "words": "\n或是確認一下優勝條件之類的……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈！",
        "unit_id": 130012,
        "voice": "vo_adv_5156701_017"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那種事，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "才不需要呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n激烈地打殺一番，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "留到最後的才是勝者。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n簡單明快不是正好嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "如果這就是吉歐‧格黑納的作風，",
        "unit_id": 130012,
        "voice": "vo_adv_5156701_018"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那就來奉陪到底吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "很久沒遇過像這樣熱血沸騰的祭典了。",
        "unit_id": 130012
    },
