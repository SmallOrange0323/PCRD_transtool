        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "紙糊的戰車、",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "廢物般的動力♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "比起那種竹筒槍不如先裝個輔助輪如何？",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "雜碎過頭讓我的嘲諷詞彙都快不夠用了～♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "布武機、",
        "unit_id": 130112,
        "voice": "vo_adv_5156701_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "妳說過頭了啦……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不過大家都很積極參加，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n就算輸了也很開心，好像也沒關係？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "有一些傢伙甚至讓人搞不懂",
        "unit_id": 130012,
        "voice": "vo_adv_5156701_002"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "到底為何來參加呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不過算了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "只要能賺錢什麼都好。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "多虧了這樣資金也很充裕，",
        "unit_id": 130012,
        "voice": "vo_adv_5156701_003"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n照這樣下去貸款啥的也能很輕鬆地還清吧……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "是說，",
        "unit_id": 130212,
        "voice": "vo_adv_5156701_004"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "這根本就是狩獵源源不絕雜碎的獎勵關卡嘛？",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "那當然要來拿個優勝囉～♪",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "優勝，",
        "unit_id": 130112,
        "voice": "vo_adv_5156701_005"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是嗎……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "最強的稱號，",
        "unit_id": 130012,
        "voice": "vo_adv_5156701_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "戰車駕駛的頂點",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "雖然沒辦法賣錢，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "卻是很適合我們的寶物呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "真不愧是倭姊～",
