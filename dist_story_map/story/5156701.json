        "type": "dialogue",
        "name": "若菜",
        "words": "怎、",
        "unit_id": 130112,
        "voice": "vo_adv_5156701_019"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "怎麼這樣……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n雖然這的確是倭姊姊很喜歡的發展……！",
        "unit_id": 130112
