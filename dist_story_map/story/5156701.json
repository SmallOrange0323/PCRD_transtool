        "voice": "vo_adv_5156701_011"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "是說你太拼命了吧～ｗ",
        "unit_id": 130212
    },
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這、",
        "unit_id": 130112,
        "voice": "vo_adv_5156701_012"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這是怎麼回事！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n聚集了好多其他隊伍……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我們，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "被包圍住了！",
        "unit_id": 130112
    },
