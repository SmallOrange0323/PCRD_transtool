[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀？",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你好啊，{player}。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明就沒有去叫你，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "竟然自己就跑過來了，嚇了我一跳。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你呀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看起來是累垮啦，所以直接就昏睡過去了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一回，還真是挺驚險的呀。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在你失去記憶之前，明明能那麼輕鬆的攻略地下城，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但真正在現實中實行時卻是這麼困難。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在沒有經過人為整理的地方弄得全身泥向前進，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n與魔物戰鬥，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還不忘要一面探索周遭……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最後還是得",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從即將自爆的研究組織中逃出。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "慘到希望能放過你呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你終究用盡了體力，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後現在做了這個夢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，放心。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那個叫做拉基拉基的人，正把昏睡過去的你扛著走了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "順帶一提。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們現在似乎正被帶往的所在地，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是祕密社團【拉比林斯】的據點呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若能在那，能聽到多一點情報就好了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以探究著世界之謎為目標的公會、【拉比林斯】，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在究竟觸及了多少事情的真相，也還不清楚呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能與他們接觸、",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對談，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並且交換情報，我想這絕對不是白費。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還得再加緊腳步一點呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟這可不是給小孩子看的漫畫故事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n敵人可不會乖乖等你們做好了萬全準備才行動呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管用上任何手段，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他們也會想盡辦法把你們給摧毀的喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也因此，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "於不遠的將來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你大概得親自去面對相當殘酷的事態就是了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別輸哦。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n至少，也別就因此一蹶不振了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若真那樣，就全都結束囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然只能像這樣給你聲援，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但我永遠都會和你站在同一邊的唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並且，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你的同伴也不只我一個。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管是這一次對你們伸出援手的，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n【惡魔偽王國軍】的忍她們……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還是其他各式各樣的人們，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都會提供協助給你的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你與她們所連繫而上的羈絆，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將會幫助你繼續前進。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而這也是你所擁有的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最強大的武器唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請不要再忘記了呢，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你不會是孤獨的一人唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當然。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "與你相遇的人們都很善良，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也不一定只會做對你有益的事",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "。\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為大家，都有各自的人生，拚著命活著。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "特別是『七冠』，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還有與她們有相關連的人物們，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很可能會因為自身的利害關係和你產生對立。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以這一次，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n當你們決定要去見『七冠』的似似花時，看的我冷汗直流呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他們相對於這世界，也是相當重要的人物，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是如同主角般的存在唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不但和你有著相同的性質，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "甚至是連立場都相似。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以呢，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在記憶喪失的你，所遺忘的那『前世』之中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你和『七冠』，可曾多次慘烈的征討與戰鬥呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然而，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也總和那些曾是敵對的人們，變成良好的同盟呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不僅是『前世』，就是現在的你也借此增加了夥伴，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並且有朝一日，終將成為那足以拯救世界的英雄吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也就是這樣的你，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "絕對不會輸給那孤獨、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "處於這世界的頂點……，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "試圖成為上帝的尤絲蒂亞娜的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這裡是以那真摯的祈求為本，卻被惡意扭曲而成的，",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n――被再構築後的世界……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過。",
        "unit_id": 190011,
        "voice": "vo_adv_2007099_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我相信，你所抱負的那崇高之情，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n將會引領你的心不受扭曲，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並且成長茁壯呢。",
        "unit_id": 190011
    }
]