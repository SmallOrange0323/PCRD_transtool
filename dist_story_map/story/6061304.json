[
    {
        "type": "background",
        "background": "501250"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "課程總算結束了。",
        "unit_id": 115911,
        "voice": "vo_adv_6061304_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n起初還在擔心不知會變成什麼樣，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一切順利真是太好了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所謂的千金小姐，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也是能很有幹勁的呢。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊。",
        "unit_id": 115911,
        "voice": "vo_adv_6061304_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然幾乎都是沒拿過劍的千金小姐，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n大家還是都好好地堅持到最後。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就連我也對課程熱衷起來了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，",
        "unit_id": 115911,
        "voice": "vo_adv_6061304_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然我原本有放點水，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過她還是漂亮地擊敗了我。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她那一擊真的很猛。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "期待有一天可以跟她來場使出真本事的對戰。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才沒有那麼簡單呢。",
        "unit_id": 115911,
        "voice": "vo_adv_6061304_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她們這次所學到的東西，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n如果可以幫助她們日後守住各人的重要之物，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼我教這堂課也值得了。",
        "unit_id": 115911
    }
]