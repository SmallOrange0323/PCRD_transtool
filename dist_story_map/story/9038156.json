[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒聽說牠會變成霧逃走耶！",
        "unit_id": 106011,
        "voice": "vo_adv_9038156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不會讓牠這麼簡單脫逃的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "1000萬盧幣！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過據說牠會在不同的湖間移動，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去別的湖看看吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唔，",
        "unit_id": 106011,
        "voice": "vo_adv_9038156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好重！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以不要突然抱過來好嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會突然嚇到人的啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_9038156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請等一下。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要放棄把傳說聖獸當珍奇佳餚吃掉的夢想了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳也不能屈服輸給欲望唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……什、",
        "unit_id": 106011,
        "voice": "vo_adv_9038156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼呀這麼突然？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被那片白霧包圍的瞬間……",
        "unit_id": 105811,
        "voice": "vo_adv_9038156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我徹悟了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……一直沉溺在那食欲原罪中的我，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是隻被本能驅使的醜陋野獸！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因此從今日起，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我準備開始食用大量的素齋料理！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這段話的吐槽點也太多了吧！？",
        "unit_id": 106011,
        "voice": "vo_adv_9038156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個可蘿仔！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也說些什麼吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "笑容滿開——",
        "unit_id": 105911,
        "voice": "vo_adv_9038156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106011,
        "voice": "vo_adv_9038156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很棒的笑容呢……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳整個人的氣質更加幼化了……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說這是，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼！？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們到底怎麼了呢！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……該、",
        "unit_id": 106011,
        "voice": "vo_adv_9038156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這就是那傢伙的能力？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n淨化慾望，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓人失去鬥志！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_9038156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們已經沒必要戰鬥了唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今日起【美食殿堂】的目標",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是對人、大自然、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物都友善的飲食生活！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "口號就是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Love&Peace！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Love&Peace♪　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Love&Peace♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "Love Love♪　",
        "unit_id": 105911,
        "voice": "vo_adv_9038156_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "Peace——♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來吧，",
        "unit_id": 105811,
        "voice": "vo_adv_9038156_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留也來一起～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\nLove&Peace♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別隨便圍著人跳舞啦！　",
        "unit_id": 106011,
        "voice": "vo_adv_9038156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別再唱了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n快給我清醒過來———！",
        "unit_id": 106011
    }
