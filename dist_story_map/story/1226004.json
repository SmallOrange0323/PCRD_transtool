[
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "欣賞完星空後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優衣和{player}回到了人潮退去的海灘──"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "水上步行球、",
        "unit_id": 122611,
        "voice": "vo_adv_1226004_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "愛的一心一意炒麵、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n兩人羽織刨冰跟",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "情侶騎馬打仗啊……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛開始",
        "unit_id": 122611,
        "voice": "vo_adv_1226004_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我有點嚇到，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n想說怎麼會想出這種活動……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過，",
        "unit_id": 122611,
        "voice": "vo_adv_1226004_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我現在覺得",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "正是因為這樣，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n遊客才能玩得開心吧。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是有那種，",
        "unit_id": 122611,
        "voice": "vo_adv_1226004_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對戀愛很膽小的人嗎……？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想可能有些人，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒有什麼契機時，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就會下意識把自己心情的順位",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "擺在後面……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以我想這個大聲催促著客人",
        "unit_id": 122611,
        "voice": "vo_adv_1226004_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n「戀愛吧～！」、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "「享受吧～！」",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的慶典，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n一定能成為",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "讓人面對戀愛的",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "良好契機。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為不管哪項活動，",
        "unit_id": 122611,
        "voice": "vo_adv_1226004_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都讓人心跳得很快嘛。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "實際體驗過的我都這麼說了，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "肯定不會錯。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯？",
        "unit_id": 122611,
        "voice": "vo_adv_1226004_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "奇怪，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "周遭突然變亮了？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這也是什麼活動的準備──",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊啊啊，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "奇怪？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n好、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好刺眼，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "什麼都看不見了～！",
        "unit_id": 122611
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼，",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好熱啊……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──{player}！？",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你、",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你怎麼會在這裡！？",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這、",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣啊！",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說得也是。",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n夏天來海邊還會有什麼理由嘛。",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊哈，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊哈哈……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚嗚，",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我真是的，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "到底要什麼時候才會習慣啊……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "小、",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "小麥色？",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "曬得那麼黑",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒問題嗎……？",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有點想看看",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他曬成小麥色的樣子……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我嗎？",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──啊，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對、",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對呀！",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我跟弟弟一起",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "來海邊玩水。",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我弟弟好像遇到了朋友，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才一到海邊人就不見了……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……！",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "跟{player}，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩個人游？",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個………………",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊。",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哇、",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哇啊……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "結果要一起游泳了……！",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n平常在變成這樣之前，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不是嚇得慌慌張張，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就是會逃走的說……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然夏天的海灘",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是有種特別的力量嗎……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n有著連這麼害羞的我，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都、",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都能變得大膽之類的",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "力量嗎……？",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "今天",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有來真是太好了……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n真是要感謝",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一直吵著想去海邊的",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "弟弟……！　",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "{player}，等等我～！",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "────！",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過，",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "先等一下……　",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他說的一起游泳……",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是要一起游泳嗎？",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n咦、",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦咦咦咦咦，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "仔細一想……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這不是……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "非常",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "害羞的事情嗎！？　",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……因為",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "像是在換氣的瞬間",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "表情肯定會很奇怪，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n蛙式看起來也像青蛙，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而仰式什麼的……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不行！",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "絕對游不來的啦～！　",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果是游泳課還會分男女，",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "離得遠遠的就還好……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但今天只有我們兩個嘛，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會被他近距離看得一清二楚的……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "討厭……",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "該該該、",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "該怎麼辦……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃，",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過",
        "unit_id": 122631,
        "voice": "vo_adv_1226004_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都走到這一步了也沒有理由拒絕，",
        "unit_id": 122631
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n說有急事呢？",
        "unit_id": 122631
    },
    {
