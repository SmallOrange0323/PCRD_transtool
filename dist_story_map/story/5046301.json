    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣根本",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒辦法比賽了呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n可是",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "牠那麼生氣，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "感覺也沒辦法溝通……",
        "unit_id": 113511
    },
    {
