        "voice": "vo_adv_5046301_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖然很可憐，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "現在看來只能這麼做了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n抱歉，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小魔物……",
        "unit_id": 113511
    },
