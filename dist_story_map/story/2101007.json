    {
        "type": "dialogue",
        "name": "優衣",
        "words": "到、",
        "unit_id": 100211,
        "voice": "vo_adv_2101007_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "到底發生什麼事了！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "建築物",
        "unit_id": 105812,
        "voice": "vo_adv_2101007_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突然就爆炸了唷！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這也是典禮活動的一部分嗎～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哪有可能是活動的一部分啊！",
        "unit_id": 106012,
        "voice": "vo_adv_2101007_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那不是毫不留情地整個被炸掉了嗎！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我猜剛剛的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該是攻擊魔法的爆炸唷！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "怎、",
        "unit_id": 118011,
        "voice": "vo_adv_2101007_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "怎麼會！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n怎麼會怎麼會怎麼會～！！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的克蕾琪塔之塔竟然！",
        "unit_id": 118011,
        "voice": "vo_adv_2101007_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我耗資了10億盧幣竟然就這樣灰飛煙滅了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "到底是為什麼，又是誰，竟然做出、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做出這種事情……！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實，",
        "unit_id": 105913,
        "voice": "vo_adv_2101007_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照克蕾琪塔小姐的那副模樣看來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這並非是活動一環之事相當顯而易見了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若方才的爆炸是攻擊的話……",
        "unit_id": 105913,
        "voice": "vo_adv_2101007_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼那名犯人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該還在這附近才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此處相當危險，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請兩位千萬",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不可離開在下的身旁。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好～哦！",
        "unit_id": 106414,
        "voice": "vo_adv_2101007_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "！",
        "unit_id": 100211,
        "voice": "vo_adv_2101007_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n又發生爆炸了……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次是",
        "unit_id": 100111,
        "voice": "vo_adv_2101007_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "從那邊那個屋頂上傳來的唷。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！",
        "unit_id": 100111
    },
    {
        "type": "still",
        "still": "210100701"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊啊啊！",
        "unit_id": 100312,
        "voice": "vo_adv_2101007_010"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜！？",
        "unit_id": 100211,
        "voice": "vo_adv_2101007_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n怜",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在屋頂上和魔物戰鬥著……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了，",
        "unit_id": 100111,
        "voice": "vo_adv_2101007_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜她今天",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有要負責城內警備的工作呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "各位，",
        "unit_id": 100312,
        "voice": "vo_adv_2101007_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "提高警覺！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n除了這傢伙以外，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有其他好幾隻在！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這些傢伙是怎樣！",
        "unit_id": 106011,
        "voice": "vo_adv_2101007_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到底是從哪裡冒出來的啦！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃、",
        "unit_id": 100111,
        "voice": "vo_adv_2101007_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n總而言之，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要去幫怜戰鬥就好了對吧！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若考慮到主人與雪菲小姐的安危，",
        "unit_id": 105911,
        "voice": "vo_adv_2101007_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應當先避難到安全區域才是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊！？",
        "unit_id": 100211,
        "voice": "vo_adv_2101007_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這邊也過來了唷！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的話聚集在廣場的人們",
        "unit_id": 105812,
        "voice": "vo_adv_2101007_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會很危險！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們去救他們吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喂欸！",
        "unit_id": 118011,
        "voice": "vo_adv_2101007_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n還在那邊發什麼呆啊，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n趕快上啊，你們這些傭兵！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "傭兵1",
        "words": "咦咦，",
        "unit_id": 911,
        "voice": "vo_adv_2101007_020"
    },
    {
        "type": "dialogue",
        "name": "傭兵1",
        "words": "可是……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵1",
        "words": "\n竟然要和那種傢伙戰鬥，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵1",
        "words": "契約上可沒寫呀！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果想要契約以外的獎金，",
        "unit_id": 118011,
        "voice": "vo_adv_2101007_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我一點都不會少給你們啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n給我把那些魔物全都打扁，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n然後再把那群臭傢伙全都堆在我那座塔的原處上啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "傭兵２",
        "words": "獎金！？",
        "unit_id": 811,
        "voice": "vo_adv_2101007_022"
    },
    {
        "type": "dialogue",
        "name": "傭兵２",
        "words": "\n呀哈～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "傭兵２",
        "words": "\n獎金呀！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "傭兵1",
        "words": "閃邊閃邊你們這些傢伙！",
        "unit_id": 911,
        "voice": "vo_adv_2101007_023"
    },
    {
        "type": "dialogue",
        "name": "傭兵1",
        "words": "\n額外獎金全都是老子的……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵1",
        "words": "嘎呀～！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵２",
        "words": "嘎呀啊啊～！",
        "unit_id": 811,
        "voice": "vo_adv_2101007_024"
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等……！",
        "unit_id": 118011,
        "voice": "vo_adv_2101007_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也太快就被幹掉了啊！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好歹讓人見識一下你們的骨氣行不行啊～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那些魔物，",
        "unit_id": 100211,
        "voice": "vo_adv_2101007_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像很厲害的樣子……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 100312,
        "voice": "vo_adv_2101007_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "實際上確實相當棘手……！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n別掉以輕心了，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 100111,
        "voice": "vo_adv_2101007_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n包在我身上吧，怜！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也要一起上喔！",
        "unit_id": 105811,
        "voice": "vo_adv_2101007_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看我的～……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "請您稍等一下，陛下！",
        "unit_id": 191411,
        "voice": "vo_adv_2101007_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔欸！？",
        "unit_id": 105811,
        "voice": "vo_adv_2101007_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n議、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "議長！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "吾等的公主‧尤絲蒂亞娜陛下！",
        "unit_id": 191411,
        "voice": "vo_adv_2101007_032"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n百般無禮下人知曉，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "但還請聽蘭德索爾貴族議會長的豪紳侯爵一言！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "請您於此收起手中之劍，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "與下屬一同回到宮殿內吧！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來是",
        "unit_id": 105911,
        "voice": "vo_adv_2101007_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又出現了一位相當饒舌之人呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "乍看之下似乎是相當有地位的貴族人士……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噁，",
        "unit_id": 106011,
        "voice": "vo_adv_2101007_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是可是，",
        "unit_id": 105811,
        "voice": "vo_adv_2101007_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "豪紳先生！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明就有一大堆魔物出現在廣場上呀……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "您那統領此國家之龍體，",
        "unit_id": 191411,
        "voice": "vo_adv_2101007_036"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "面對魔物竟得親自動劍可豈有此理！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n若有個萬一，",
