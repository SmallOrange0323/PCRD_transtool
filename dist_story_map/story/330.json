[
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼各位。",
        "unit_id": 190811,
        "voice": "vo_adv_0000330_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "調查遺跡的事情，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就麻煩各位了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n在遺跡所發現的，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這種『公主之心（碎片）』……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "可以任由各位自行帶回處理。",
        "unit_id": 190811,
        "voice": "vo_adv_0000330_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也算是報酬的一部分呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『就麻煩各位了』，",
        "unit_id": 106011,
        "voice": "vo_adv_0000330_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說得",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真簡單啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說是聖跡？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像是新的遺跡，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比如說那個超高的露娜之塔",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這片大陸上，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是出了太多的怪異遺跡啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是在下",
        "unit_id": 105911,
        "voice": "vo_adv_0000330_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最喜歡和主人、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐、凱留小姐\n一起出去冒險，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以還有點高興呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿還是一樣常常說好話呢～♪",
        "unit_id": 105811,
        "voice": "vo_adv_0000330_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次連優衣也來了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這次調查會更歡樂的喔♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說的也是！　",
        "unit_id": 100211,
        "voice": "vo_adv_0000330_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我今天",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "做了很多份便當帶過來喔♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那各位，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "聽我一下好嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105911,
        "voice": "vo_adv_0000330_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得您有在意的事情呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "優衣小姐？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才看到花凜小姐帶著，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在遺跡發掘的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個碎片是嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個碎片、",
        "unit_id": 106011,
        "voice": "vo_adv_0000330_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像藏有什麼不可思議的力量呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_0000330_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "其實，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛才花凜給我們看那時，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那之後",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就覺得有股跟騎士先生很像的力量。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然我覺得是我想太多了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此原來如此。",
        "unit_id": 105811,
        "voice": "vo_adv_0000330_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼越快越好！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到聖跡去調查，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "找出碎片來吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要發現越多，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這謎題應該就越能解開！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後",
        "unit_id": 105811,
        "voice": "vo_adv_0000330_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再一起去找好吃的東西吧～♪",
        "unit_id": 105811
    }
]