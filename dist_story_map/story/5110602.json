[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆與尾狗刀兩人組隊之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n過了一小段時日。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂，尾狗刀！",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我們來決定由誰當隊長吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哇啊～",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳又提出麻煩的事情來了──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "沒有啦，",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "因為「那群傢伙們」一直都是合力戰鬥，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n才有辦法連戰連勝到現在，不是嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我一直在思考我們跟他們有何不同，",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_003"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "最後想到",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "很可能是因為我們",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "沒有選出隊長的關係！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "他們那邊",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "固定都是以那傢伙為中心。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們這邊基本上只有兩個人吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n沒必要選出隊長來吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不，",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_005"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "有必要！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "呵，",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳一點都沒變，還是那麼熱血啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "決定好指揮系統",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "的確也不是什麼壞事。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果讓諾維姆無拘無束地行動，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "感覺會很危險。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "所以說，",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_008"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我們這就來選出",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "隊長吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "聽好了，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "隊長的命令",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是絕對的！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不管隊長下達什麼樣的命令，都必須遵守喔！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "哼哼哼！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哇啊，",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n就算沒有超能力，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我也很清楚知道妳在心裡所打的邪惡算盤。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我說啊，",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆之所以",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "想當隊長，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n只是想讓我聽命於妳吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "啥！？",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_011"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "才、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "才沒這回事！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我完全沒有想過",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "要讓怕麻煩的尾狗刀",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n聽命於我喔！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……枉費我稍微對妳另眼相看。",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那麼，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們要怎麼決定呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n該不會是要手持武器對戰一場吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就是這樣沒錯！",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_013"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n自古以來，不都是這麼決定的嗎！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "最強的人最偉大！",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "從妳這句發言絲毫感受不到半點領袖風範。",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "或者說，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就力量而言，很明顯是妳優於我吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n況且妳還帶著一把很危險的劍──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "什麼嘛，",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_016"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "還沒開戰就要投降了嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "既然如此，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "隊長就決定由我來當囉！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好啦好啦，",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_017"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是我輸了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那麼，接著來進行下一場比試──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "咦？",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_018"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "下一場？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不能只靠對妳自己有利的勝負",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_019"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n來決定隊長吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n所以，接下來將由我來制定比試的規則。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "唔……",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_020"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那麼，就以數學來一較高下。",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_021"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們互相給對方出題，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "像這樣輪流解題下去。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那我就先來出題……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "等、",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_022"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "等一下！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n這樣一來，絕對是對尾狗刀比較有利啊！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n太卑鄙了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦？",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_023"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還沒開戰就要投降了嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那麼，就算我們平手～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n如何？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "要進行下一回合了嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嗚唔～～～～～！",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_024"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n這樣",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "要比到什麼時候",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n才能決定誰當隊長啊～～～～～～～！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "尾狗刀聽著諾維姆的慘叫聲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不禁微微一笑。"
    }
]