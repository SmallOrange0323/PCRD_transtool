[
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！",
        "unit_id": 100211,
        "voice": "vo_adv_9006524_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "索爾魔珠，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "已經找回七個了喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n還剩下",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一個……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拍手拍手拍手拍手……"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "哎呀這真是……",
        "unit_id": 192613,
        "voice": "vo_adv_9006524_001"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "超乎想像。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n沒想到你們能抗戰至此。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "剩下的一個──",
        "unit_id": 192613,
        "voice": "vo_adv_9006524_002"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "我手中的這個索爾魔珠如果也被奪走，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n這個巨神將失去作為容器的功能，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n厄莉絲小姐",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "也將無法使用米奈娃的力量……",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣一來，",
        "unit_id": 105811,
        "voice": "vo_adv_9006524_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是我們的勝利了……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_9006524_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n湊齊索爾魔珠的話，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就能通往索爾之塔的塔頂了……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "彌勒！",
        "unit_id": 106011,
        "voice": "vo_adv_9006524_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n快點死心，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把最後的索爾魔珠交出來！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不然宰了你喔！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "很遺憾。",
        "unit_id": 192613,
        "voice": "vo_adv_9006524_006"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n我",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "還不能消失呢。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "反倒──",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "是時候",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "該收下你們的靈魂了。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……",
        "unit_id": 106411,
        "voice": "vo_adv_9006524_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "魔、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "魔物從地上",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "冒出來了！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不……",
        "unit_id": 100312,
        "voice": "vo_adv_9006524_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不只是從地上，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "牆上和天花板也是……！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "現在的終炎巨神",
        "unit_id": 192613,
        "voice": "vo_adv_9006524_009"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "是充滿了龐大魔力的容器──",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n將它的身體組織分離出來的話，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "要多少隻魔物就能生成多少隻。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是，",
        "unit_id": 105811,
        "voice": "vo_adv_9006524_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "幾百隻……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是幾千隻吧……！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "即使和其他人聯手，",
        "unit_id": 100111,
        "voice": "vo_adv_9006524_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這個數量也是打不完啊……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "呵呵呵……",
        "unit_id": 192613,
        "voice": "vo_adv_9006524_012"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "那麼，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "就留在這裡和魔物一起滴血不留地被啃食殆盡吧。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n不……",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "說來你們全部人",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "都已經在肚子裡了呢。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "那麼，",
        "unit_id": 192613,
        "voice": "vo_adv_9006524_013"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "再會。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n之後我會來迎接",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "失去角色、只剩下靈魂的你們。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "呵呵呵、",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "哈哈哈哈……！",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個傢伙……！！",
        "unit_id": 106011,
        "voice": "vo_adv_9006524_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一開始就打算這麼做了吧──！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留，",
        "unit_id": 106411,
        "voice": "vo_adv_9006524_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在不是生氣的時候……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們完全被包圍了……！！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 105911,
        "voice": "vo_adv_9006524_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "快到在下身後──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "──不！",
        "unit_id": 190711,
        "voice": "vo_adv_9006524_017"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n現在立刻到我身後！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "全部人都過來！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇！？",
        "unit_id": 100111,
        "voice": "vo_adv_9006524_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你是……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太吾！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是大吾！",
        "unit_id": 190711,
        "voice": "vo_adv_9006524_019"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "都這種時候了別讓我吐槽啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喝啊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "去吧，本大爺的",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "超級無敵厲害結界！！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "把魔物彈開了！？",
        "unit_id": 100311,
        "voice": "vo_adv_9006524_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "魔物無法進入這個結界呢……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "嗯，",
        "unit_id": 191011,
        "voice": "vo_adv_9006524_021"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "千鈞一髮呢……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "真是",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "膽顫心驚啊。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "多虧了拉基拉基啊！",
        "unit_id": 106113,
        "voice": "vo_adv_9006524_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n找他幫忙是正確的決定！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們……",
        "unit_id": 106011,
        "voice": "vo_adv_9006524_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在這個時間點空間跳躍過來嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼一回事啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "菲歐在下面吵鬧不休啊。",
        "unit_id": 106113,
        "voice": "vo_adv_9006524_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "已經沒有救兵，陷入大危機了──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "她是這樣說的。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以我們直接",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "用空間跳躍過來救援！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "真是的……！",
        "unit_id": 190711,
        "voice": "vo_adv_9006524_025"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "跑到敵人的肚子裡什麼的，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n很明顯就是個陷阱不是嗎！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "至少也準備個後路吧蠢蛋！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "大吾，",
        "unit_id": 191011,
        "voice": "vo_adv_9006524_026"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "現在沒有時間說教了喔？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n身為最後的救兵得趕緊動作了……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "各位，",
        "unit_id": 191011,
        "voice": "vo_adv_9006524_027"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "根據似似花大人和拉比林斯達的分析，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n彌勒現在在我們上面──",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "也就是魔物的背上。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "背上？",
        "unit_id": 105811,
        "voice": "vo_adv_9006524_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這樣～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從肚子裡過去的話",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會花太多時間的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，",
        "unit_id": 100211,
        "voice": "vo_adv_9006524_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也是呢……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n而且現在",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
