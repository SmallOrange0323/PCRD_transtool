[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "所有成員到齊並備好食材，當【美食殿堂】正順利地進行"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n年菜派對的準備時，那名人物出現了。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來了來了～",
        "unit_id": 111811,
        "voice": "vo_adv_5082007_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以麻煩妳去看是誰嗎？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啊。",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n來了～請問是哪位……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您好，",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我是公會管理協會的人員。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "剛才妳",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「呃」",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "地叫了一聲嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來客是花凜小姐。",
        "unit_id": 111911,
        "voice": "vo_adv_5082007_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "歡迎，",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "花凜小姐。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n請問怎麼了？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼了？",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該不會又是什麼麻煩事吧……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "才不是那麼一回事呢。",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次我可是……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "帶了感謝狀",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "要給【美食殿堂】的各位！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是給我們的嗎？",
        "unit_id": 111811,
        "voice": "vo_adv_5082007_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這真是太光榮了！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯，",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是對什麼事的感謝狀？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_010"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "你們前幾天解決獨占強奪吉祥物的事件！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們接獲了流夏小姐和伊莉亞小姐的報告。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是主人和雪菲小姐的功勞呢。",
        "unit_id": 111911,
        "voice": "vo_adv_5082007_011"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呃，",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_012"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "報告上說",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是【美食殿堂】所有人的協助……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳妳妳、",
        "unit_id": 111811,
        "voice": "vo_adv_5082007_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳在說什麼啊～？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是",
        "unit_id": 111911,
        "voice": "vo_adv_5082007_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說啊。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我不知道妳在說什麼耶。",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_015"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位，",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_016"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "妳們是怎麼了？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "請妳別在意……",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_017"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這樣啊，",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_018"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我知道了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "然後，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "除了感謝狀之外，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次事件的受害者們，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n也給了你們非常多的謝禮。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那就不必了，",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我們只是做了應當的事情。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我就知道妳會這麼說，",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_020"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n因此謝禮",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "現在由公會管理協會暫時代領了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是這種部分",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很狡猾啊……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因此，",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_022"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "公會管理協會將舉辦新年會兼表揚派對，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n並想招待",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的各位以主賓的身分來參加！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們準備了謝禮與許多的料理，",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_023"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n請你們務必來參加。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "派對嗎？",
        "unit_id": 111811,
        "voice": "vo_adv_5082007_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不錯耶！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這真是太棒了。",
        "unit_id": 111911,
        "voice": "vo_adv_5082007_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下。",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那我們目前正在準備的年菜派對要怎麼辦啦？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "既然如此，",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就帶著我們的年菜",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "去和大家一起吃吧。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這主意",
        "unit_id": 111811,
        "voice": "vo_adv_5082007_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不錯耶！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真不愧是小雪菲！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是好主意。",
        "unit_id": 111911,
        "voice": "vo_adv_5082007_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吧，",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然你們都這麼說了……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣可以嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "花凜。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的，",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_031"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒問題。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n呵呵，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我覺得這主意非常有【美食殿堂】的風格。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她是這樣說的呢，",
        "unit_id": 111811,
        "voice": "vo_adv_5082007_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是很有",
        "unit_id": 111911,
        "voice": "vo_adv_5082007_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐風格的好主意。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不錯嘛。",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_035"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_036"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "詳細的地點，會在近期內聯絡各位。",
        "unit_id": 190811,
        "voice": "vo_adv_5082007_037"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在各位繁忙時打擾了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "祝各位",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有個好年。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也祝花凜小姐",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_038"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有個好年。",
        "unit_id": 120711
    },
    {
        "type": "still",
        "still": "508200701"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼",
        "unit_id": 111811,
        "voice": "vo_adv_5082007_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然決定好了，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就來努力做料理吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}也要來幫忙喔。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一起來把新的一年",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也變成最棒的一年吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也會",
        "unit_id": 111911,
        "voice": "vo_adv_5082007_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盡全力來照顧主人的。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之",
        "unit_id": 112011,
        "voice": "vo_adv_5082007_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就在別太勉強自己的範圍內努力吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過這些話",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算對你說也是白說吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一定沒問題的，",
        "unit_id": 120711,
        "voice": "vo_adv_5082007_042"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為有大家在啊。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "謝謝你",
        "unit_id": 1,
        "voice": "vo_adv_5082007_043"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "這一年的關照。",
        "unit_id": 1
    },
    {
