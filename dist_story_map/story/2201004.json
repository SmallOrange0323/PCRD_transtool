        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n得先設法",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從眼下的危機中脫身才行！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然有點擔心",
