        "name": "貪吃佩可",
        "words": "就算砍斷了繩子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n周遭有這麼多魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光憑我們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該很難逃出生天吧……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且……",
        "unit_id": 105812,
        "voice": "vo_adv_2201004_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你有注意到嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這些魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該不是居住於這個洞窟裡的魔物呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就外觀而言，",
        "unit_id": 105812,
        "voice": "vo_adv_2201004_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當中完全沒有看起來像來自北方的魔物。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有的都是東方森林的魔物或",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沙漠的魔物……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這些魔物全都居住在",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿斯特賴亞大陸上的偏遠區域……？",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天前。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在蘭德索爾繁華街的某間食堂裡──"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的各位♪",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_038"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "非常感謝你們承接了",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n【幻變少女】",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所發布的委託♪",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說出來了呢，該……",
        "unit_id": 106012,
        "voice": "vo_adv_2201004_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "花凜。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過──這個委託好像也沒想像中那麼棘手……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了，",
        "unit_id": 105812,
        "voice": "vo_adv_2201004_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "莉莉。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就方位上來說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們想去的目的地是泰美斯銀嶺吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我記得",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "出沒於那一帶的魔物沒有那麼危險呀？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……那、",
        "unit_id": 125812,
        "voice": "vo_adv_2201004_041"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我們幾個",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還沒有什麼像樣的冒險經驗。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "【美食殿堂】的各位",
        "unit_id": 125812,
        "voice": "vo_adv_2201004_042"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都是身經百戰的冒險者，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n即使是你們覺得沒什麼大不了的魔物，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "肯定也能輕易全滅我們……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 105913,
        "voice": "vo_adv_2201004_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位才會需要護衛對吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
        "unit_id": 105812,
        "voice": "vo_adv_2201004_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳們就當作是搭上了安全的飛空艇，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "儘管交給我們！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這不是立了墜落Flag嗎──！！",
        "unit_id": 106012,
        "voice": "vo_adv_2201004_045"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_046"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對了對了。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n雖然稱不上是",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「順便」……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "最近這陣子，",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_047"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n發生於蘭德索爾近郊的",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "魔物相關事件忽然減少了，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n各位知道",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這件事嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2201004_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "純小姐他們也有和我報告過。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "多虧如此，我們才閒得發慌啊──",
        "unit_id": 106012,
        "voice": "vo_adv_2201004_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和平",
        "unit_id": 105913,
        "voice": "vo_adv_2201004_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是好事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但一想到這可能是異變的前兆，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就叫人有些不放心呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "公會管理協會",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_051"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也發布了委託，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n請【純白之翼 蘭德索爾分部】、",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n【拉比林斯】等公會，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "幫忙調查魔物的動向。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拜託了莫妮卡她們？",
        "unit_id": 105812,
        "voice": "vo_adv_2201004_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，",
        "unit_id": 106012,
        "voice": "vo_adv_2201004_053"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "事情到底是怎樣？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "嗯，",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_054"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然還不明白原因，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但魔物們現在",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "似乎正集體",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n向著蘭德索爾的西北方移動。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜之所賜，",
        "unit_id": 105913,
        "voice": "vo_adv_2201004_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蘭德索爾一帶才會這麼和平……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "並不只有",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_056"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "蘭德索爾",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "喔。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n各地的冒險者管理協會分部，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也都取得了相同的調查結果……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_2201004_057"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那這是怎樣啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n大陸上的所有魔物",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都像候鳥一樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n捨棄了自己的地盤，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正向著同一個地方移動？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是那樣。",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_058"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然根據魔物不同，也有個體差異的樣子，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但目前",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "似乎還沒對村落造成損害，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所以沒有掀起太大的騷動。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913,
        "voice": "vo_adv_2201004_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來自大陸各處的魔物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正聚集",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並擠在那塊西北之地上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會不會已經在那個地方掀起了可怕的混亂……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這個嘛……",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_060"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "根據利用飛空艇協助調查的【墨丘利財團】",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所提供的情報，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "聽說弗麗嘉雪原或",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n泰美斯銀嶺附近一帶，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "完全沒看到魔物的蹤影。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2201004_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那麼，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物們都到哪去了？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "……這個嘛……",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可、可可蘿",
        "words": "？",
        "unit_id": 1,
        "voice": "vo_adv_2201004_063"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……欸，",
        "unit_id": 106012,
        "voice": "vo_adv_2201004_064"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "花凜，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳剛才",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n說了什麼",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「雖然稱不上是『順便』」，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難不成……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒錯♪",
        "unit_id": 118511,
        "voice": "vo_adv_2201004_065"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n能不能麻煩你們在護衛【幻變少女】之餘，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "順便幫忙調查魔物們的動向呢……♪",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
