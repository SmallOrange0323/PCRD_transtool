    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克莉絲，",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "別站得太前面。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 133911,
        "voice": "vo_adv_5201332_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感覺有種不好的預兆。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "它好像在蓄積力量。",
        "unit_id": 133711,
        "voice": "vo_adv_5201332_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似乎是要施展消耗資源的招式。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們來打斷它累積力量吧。",
        "unit_id": 133811,
        "voice": "vo_adv_5201332_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒必要等對手施放大招。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連同大招一起斬開才稱得上戰鬥吧？",
        "unit_id": 133911,
        "voice": "vo_adv_5201332_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果妳願意當肉盾，我倒是很歡迎喔？",
        "unit_id": 133711,
        "voice": "vo_adv_5201332_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵，",
        "unit_id": 133911,
        "voice": "vo_adv_5201332_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當妳們的肉盾我敬謝不敏。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的樂趣可是只屬於我的──！",
        "unit_id": 133911
    }
]