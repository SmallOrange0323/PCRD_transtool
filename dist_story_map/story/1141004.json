    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "救了他們的是",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純就是了……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不對啦！",
        "unit_id": 114111,
        "voice": "vo_adv_1141004_074"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就像超級英雄與搭檔那樣，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這是我和你",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "兩個人的功勞！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "今後也要拜託你了！",
        "unit_id": 114111,
        "voice": "vo_adv_1141004_075"
    },
    {
