        "words": "哇！",
        "unit_id": 114111,
        "voice": "vo_adv_1141004_066"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "怎麼",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不小心睡著了！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是因為任務結束",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "放鬆下來的關係嗎……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過",
        "unit_id": 114111,
        "voice": "vo_adv_1141004_067"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "多虧如此，我現在完全清醒了喔！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就這樣輕鬆地在萬聖節樂園逛一逛……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "白虎英雄秀",
        "unit_id": 112,
        "voice": "vo_adv_1141004_068"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "超逼真的耶～",
        "unit_id": 112
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n雖然很快就結束了。",
        "unit_id": 112
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯，",
        "unit_id": 212,
        "voice": "vo_adv_1141004_069"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "還想多看一下子的說～",
        "unit_id": 212
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好，",
        "unit_id": 112,
        "voice": "vo_adv_1141004_070"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那我們來玩白虎扮家家酒吧！",
        "unit_id": 112
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我要當白虎～！",
        "unit_id": 212,
        "voice": "vo_adv_1141004_071"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那我當那個黑色盔甲！",
        "unit_id": 112,
        "voice": "vo_adv_1141004_072"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "喝啊！",
        "unit_id": 112
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那些孩子們……",
        "unit_id": 114111,
        "voice": "vo_adv_1141004_073"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "能在不被發現的情況下救了他們",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是太好了！",
