[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾的夜空突然變紅後，過了一陣子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n忍他們邊走邊看著在街角談論的人們。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "和前一陣子相比，",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "赤色之夜的騷動也平息下來了呢。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但大家的內心",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "似乎還是惴惴不安……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "正因如此，",
        "unit_id": 2411,
        "voice": "vo_adv_5136069_001"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "才需要有像我們這樣的人。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n也是為了要貼近大家不安的心，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "給予支持啊。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說的也是。",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然還不知道原因，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但如果我們也能多少幫上忙的話……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "所以啦，",
        "unit_id": 2411,
        "voice": "vo_adv_5136069_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "年輕貌美的美女們～！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n在睡不著的夜裡，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "務必要把俊俏的骷髏頭一起帶上床！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我會為妳送上連不安都能趕跑的刺激夜晚～！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是的，",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸還是老樣子……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哎呀，",
        "unit_id": 2411,
        "voice": "vo_adv_5136069_005"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "說著說著就發現美女了！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n那邊那位小姐，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "要不要跟我",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "傾訴看看",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳心中的煩惱呢～！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "等等，爸爸！？",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不要造成別人的困擾啊！",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咦？",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗚哇喔……",
        "unit_id": 2411,
        "voice": "vo_adv_5136069_008"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "還真是大膽的打扮啊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n小姐，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳會不會冷？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "一個人的夜晚會不會很難熬？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這種時候就交給我",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "骷髏老爸──",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊……",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊啊！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n你們難道是骷髏老爸",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "跟忍？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對不起，",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請妳不要放在心上。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸你真是的，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "差不多該適可而止──",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "噢噢，到此為止！",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_011"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "忍，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "停下、停下～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "什麼……？",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_012"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那個，忍呀？",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n老爸他啊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "只是稍～微開了點玩笑而已！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以說啊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "希望妳可以忍住",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不要把他劈成兩半喔",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "劈成兩半……？",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n請問，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳究竟是……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n妳認識我們嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊，",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_015"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "奇怪？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n妳不是要對老爸下重手嗎……？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊，",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "莫非這是……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n與我的世界",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "個性不同的那種情況？　",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "沒想到會在日和不在的時候碰上這種事……",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_017"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我一個人要說明的話感覺有點困難啊……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……嗯。",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_018"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n總之，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就先蒙混過去吧！　",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "欸──",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咳咳。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "其實呢，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "兩位，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就實話實說了，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我認識跟你們很相似的人。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很相似的人……？",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_020"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "而且！",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_021"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n他們也是一個占卜師，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "帶著變成骷髏頭的父親。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這不只是很相似了吧！？",
        "unit_id": 2411,
        "voice": "vo_adv_5136069_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……難道，",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n妳剛才說",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "劈成兩半的事情是……！",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對，",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_024"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我說的就是他們。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "說到那個骷髏頭啊？",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_025"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n也很～常對女人出手呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "而他的女兒",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_026"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "似乎很討厭他那樣騷擾人家。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我絕不原諒！！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "她每次都這樣說，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "然後就會進行很～嚴厲",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "的懲罰……！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "劈成兩半，",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_027"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "在火上面烤，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "或是用銼刀磨……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n雖然每次結束後都會確實恢復原狀，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但我看著都覺得好痛……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抖抖抖抖……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咿、",
        "unit_id": 2411,
        "voice": "vo_adv_5136069_028"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咿……！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n爸爸",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "光用想的，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "牙齒就喀答喀答作響！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我雖然也會進行懲罰……",
        "unit_id": 103113,
        "voice": "vo_adv_5136069_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但沒有想過要做到那種地步呢。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他姑且算是我的血親……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "姑且是。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "姑且要說兩次！？",
        "unit_id": 2411,
        "voice": "vo_adv_5136069_030"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那就好了～！",
        "unit_id": 135512,
        "voice": "vo_adv_5136069_031"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n如果老爸因為跟我搭話，",
        "unit_id": 135512
    },
    {
