    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這場騷動終於平息了。",
        "unit_id": 113811,
        "voice": "vo_adv_5048411_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這麼勞神費力的事，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是受夠了……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是嗎？",
        "unit_id": 113711,
        "voice": "vo_adv_5048411_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然碰見了各種狀況，一路很艱辛，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但我覺得很開心呢♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "唔，",
        "unit_id": 113811,
        "voice": "vo_adv_5048411_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這倒是……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都是我平時",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "絕對不會去的地方、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不會見到的人。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n接觸這些事物",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也是個不錯的經驗吧。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對呀，",
        "unit_id": 113711,
        "voice": "vo_adv_5048411_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "線下聚也滿好玩的！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們下次一起去音樂節嘛！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好不好嘛，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說的也是，",
        "unit_id": 113811,
        "voice": "vo_adv_5048411_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們好不容易更加了解彼此了，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n一起去經歷各式各樣的事也不錯。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "在這之前──",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我知道啦。",
        "unit_id": 113711,
        "voice": "vo_adv_5048411_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一旦要做，就要堅持到底，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對吧？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘻嘻，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有所成長的人可不是只有姊姊妳而已哦♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里……",
        "unit_id": 113811,
        "voice": "vo_adv_5048411_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳說得對。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那我們就再加把勁，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一起迎接",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "美好結局吧！",
        "unit_id": 113811
    }
]