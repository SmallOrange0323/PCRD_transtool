[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是{player}一行人成功逃到了安全區域……\n並且抵達了【拉比林斯】所築的另一個據點後，\n又過了一天以後的事。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我回來了。",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "【小小甜心】",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來著……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}認識的那些孩子們，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n全都平安地",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "送回家了唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911,
        "voice": "vo_adv_2009001_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "諾維姆歡迎回來！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這麼晚才回來害人擔心死了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "發生什麼事了？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一切都還好吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n托拉基拉基已經復原的福，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能夠使用空間跳躍了嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是為了小心陷阱，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以瞬間移動到了較遠的地方，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才再徒步回到街上的嘛……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n加上又到處調查了一下，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以多花了些時間。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "言而總之，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "目前看來城裡並沒有什麼變化唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話雖這麼說，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟是那麼大規模的軍事行動嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n人民多少也有稍微感到了不安呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣呀……",
        "unit_id": 104911,
        "voice": "vo_adv_2009001_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟也是經歷了長久和平的時代，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n看到群軍隊大行軍自然也會覺得",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "『出什麼事了？』都會這樣想的嘛。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n話說回來，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}他們還好嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯～",
        "unit_id": 104911,
        "voice": "vo_adv_2009001_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "再怎麼說昨天那樣到處東奔西跑也累壞了吧，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以就一整個昏睡了過去……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "直到剛剛才醒來，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在正在吃早餐唷。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但這個據點裡也沒有儲備什麼食材，",
        "unit_id": 104911,
        "voice": "vo_adv_2009001_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以吃得很簡單就是了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過嘛，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能應急就算不錯了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能夠平安的逃過一劫就算是老天保佑了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過也還不能夠就此放心呢……",
        "unit_id": 104911,
        "voice": "vo_adv_2009001_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "之前的據點，明明也是非常嚴謹地藏匿起來了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但結果也是一下子就被敵人給發現了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了當做潛藏地，",
        "unit_id": 104911,
        "voice": "vo_adv_2009001_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這裡也是由我們會長她……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n利用『物件變更』所造出來的其中一個小規模據點。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "跟之前的據點相比，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "更沒有徹底進行過任何危機管理。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要敵人有那個打算，",
        "unit_id": 104911,
        "voice": "vo_adv_2009001_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也許我們馬上就會被找到。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了隱匿我們的所在地，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我認為之後要頻繁地移動會比較好唷。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說真的，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們現在",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就真的像是恐怖份子一樣了呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊～",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到底為什麼會變成現在這樣子呢。",
        "unit_id": 106112
    },
    {
        "type": "still",
        "still": "200900101"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早餐，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "承蒙招待了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是{player}你們呀。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "早呀。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n昨晚，睡得還好嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎……",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒辦法嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再怎麼說昨天都發生了那樣的事。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們的同伴，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "叫貪吃佩可",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n她被敵人給抓走了嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為擔心，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以睡不好也是當然的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道是否沒事呢……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對方的目的似乎是活捉，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n希望",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能保住性命。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但可能會遭到惡意的對待，",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令人相當擔心呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看起來很奇怪的",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也非常令人在意。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼事情會成這樣……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明是以笑相隨一同圍著餐桌，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如同家族的關係。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻得如此各分東西。",
        "unit_id": 105912
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊嗚……",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是在安慰在下呢，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下，",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不太喜歡被人摸頭就是了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是主人的隨從，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非是隻可愛的小寵物。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過現在，",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從主人摸的地方開始，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感覺到溫柔的情感",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "逐漸湧上心頭……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總覺得，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被治癒了。",
        "unit_id": 105912
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……好的。",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下能夠理解，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在不是沮喪的時刻。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管遇上如此艱困的狀況，",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下與主人也",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "存活了下來。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與眾人攜手，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不管如何",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都得跨過這窮途末路不可。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後再一次，",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和【美食殿堂】的大家，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和樂融融地在餐桌前歡笑。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能夠為此再繼續努力下去。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人明明不善於言辭，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n卻仍竭盡全力，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "願意為在下費盡唇舌……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不禁感慨萬千。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下似乎，",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n比自己所想的",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更加軟弱無能……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在就先保持這樣，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下做個",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『撒嬌的孩子』吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然現況嚴峻，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過能振作起來我很開心喔。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之順利保住了小命，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但狀況依舊相當不明朗。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "若還以為能夠置身事外，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可會被趕盡殺絕唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管怎樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不找到個起死回生的辦法可不行嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有心理準備了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……但是，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好呢？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "關於這點",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等一下，大家再一起想想吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們也一起",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "參加作戰會議吧，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "希望能借助你們的智慧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以的話……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想要向在下等人寄於籬下的",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【咲戀育幼院】",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "取得聯絡。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下等人沒有回去，",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必是相當的擔心吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～……",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在還是",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別這麼做比較好。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "敵人可是用上一切手段，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也要把我們給擊潰，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因此有在城鎮裡",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被當成罪犯通緝的可能性。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "輕率的和誰聯絡，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n或是接觸的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很可能會把對方也捲了進來。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為我們現在面對的，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是國家權力……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是與王宮為敵呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說、",
        "unit_id": 105912,
        "voice": "vo_adv_2009001_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的也是。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咲戀小姐她們和平的生活，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果因為我們",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而不復存在就太對不起她們了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是嘛，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只是想跟對方報平安的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那方法還多著。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n偷偷的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "送出個暗號之類的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就連同這件事，",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓大家一起來想想看該怎麼辦吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要還活著就不算輸。",
        "unit_id": 106112,
        "voice": "vo_adv_2009001_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n只要不放棄，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總有天一定會有逆轉的機會。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如此堅信著，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "並且盡最大的努力吧。",
        "unit_id": 106112
    }
]