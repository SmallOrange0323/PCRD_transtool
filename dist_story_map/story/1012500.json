        "voice": "vo_adv_1012500_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "開玩笑的啦～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n因為今天是我生日嘛。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，不過",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我是真的很高興喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝你！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
