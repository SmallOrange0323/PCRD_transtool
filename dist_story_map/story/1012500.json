    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "居然能得到你的生日祝福……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n雖然嚇了我一跳，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但我很開心喔☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "想不到能讓珍視的人為自己慶生，",
        "unit_id": 101211,
        "voice": "vo_adv_1012500_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我真是太幸福了～",
