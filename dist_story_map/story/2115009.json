    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "帆稀……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "獨自一人，",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "背負了七冠們的力量，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這點……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "很值得稱讚。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n但對我來說，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也只是這點程度的阻礙。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……真空虛。",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這種勝利的滋味……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和過去，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "好幾度將霸瞳皇帝，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n消去時的感覺",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一樣……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……已經，",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "夠了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n對我來說，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "最重要的……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只有一件事。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我現在，",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要過去囉。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "嘉夜、祈梨",
        "words": "老大～！！",
        "unit_id": 1,
        "voice": "vo_adv_2115009_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好快……！",
        "unit_id": 106411,
        "voice": "vo_adv_2115009_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n已經看不見嘉夜小姐",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "與祈梨小姐的身影了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為她們倆",
        "unit_id": 100211,
        "voice": "vo_adv_2115009_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒受什麼傷呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且……",
        "unit_id": 105911,
        "voice": "vo_adv_2115009_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在剛才巨大的衝擊之後，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n帆稀小姐那強大的魔力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就這麼消失了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莫非……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "帆稀小姐，",
        "unit_id": 100111,
        "voice": "vo_adv_2115009_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可能輸掉了……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一時間難以想像，",
        "unit_id": 100311,
        "voice": "vo_adv_2115009_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但對手那麼強……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……帆稀小姐……",
        "unit_id": 106411,
        "voice": "vo_adv_2115009_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也",
        "unit_id": 105811,
        "voice": "vo_adv_2115009_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "過度使用力量了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是就這樣去和厄莉絲戰鬥……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……老實說會很辛苦吧。",
        "unit_id": 190011,
        "voice": "vo_adv_2115009_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先回去",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拉比林斯達那裡一趟……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "厄莉絲！？",
        "unit_id": 100111,
        "voice": "vo_adv_2115009_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是空間跳躍嗎……！",
        "unit_id": 100311,
        "voice": "vo_adv_2115009_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "糟了！",
        "unit_id": 190011,
        "voice": "vo_adv_2115009_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們大家快逃──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──去死吧。",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_020"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "呀啊啊啊",
        "unit_id": 1,
        "voice": "vo_adv_2115009_021"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "！！！！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜、",
        "unit_id": 100211,
        "voice": "vo_adv_2115009_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有大家！！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要是能早點……",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這麼做就好了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……唉。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "確實……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "實在是，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "太不自由了……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "草野優衣──",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不能殺了妳，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "實在可恨。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但雖然不能殺了妳，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n卻可以折磨妳。",
        "unit_id": 129013
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──唔",
        "unit_id": 100211,
        "voice": "vo_adv_2115009_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……草野優衣，",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_027"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就算迷宮女王干涉我，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也在那瞬間就會探知到",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "並殺害她。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n已經，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有人能保護妳了……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……唔……",
        "unit_id": 105811,
        "voice": "vo_adv_2115009_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……？",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_029"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n有人，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還活著……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "為了不波及到騎士先生，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我似乎下手太輕了呢。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……既然如此，",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就這樣，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "給予最後一擊……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生？",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不要阻撓我。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你只要，",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_032"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再等我一下。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我現在，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就讓其他女人消失，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n將草野優衣，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "永遠幽禁起來……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……？沒事的。",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n她們至今為止，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也消失過好幾次。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "像是被霸瞳皇帝打敗、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "或是被百地希留耶背叛……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有各式各樣的原因。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣也只是，",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_034"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "多消失一次而已。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n所以……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生。",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n拜託你。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n安靜點……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我……",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_036"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "終於，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "稍微自由一點了，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n所以……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_037"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_038"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無論你，",
        "unit_id": 129013,
        "voice": "vo_adv_2115009_039"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再怎麼否定我，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我仍會不斷向你傾訴，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "等待你改變答案。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
