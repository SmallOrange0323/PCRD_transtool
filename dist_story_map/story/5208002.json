        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我回基礎世界",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "再聽厄莉絲講一次……！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳等我一下哦！！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦、",
        "unit_id": 135712,
        "voice": "vo_adv_5208002_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
