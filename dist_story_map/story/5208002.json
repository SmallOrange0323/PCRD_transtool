        "voice": "vo_adv_5208002_025"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "原來如此完全看不懂！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "畢竟那時候是生死關頭，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也沒辦法嘛。",
