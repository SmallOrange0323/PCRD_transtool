    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是剛剛的事情吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這個世界的大家，都開始意識到重置之前，",
