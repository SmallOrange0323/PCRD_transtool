    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯……？",
        "unit_id": 135511,
        "voice": "vo_adv_5208002_023"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n那個皺巴巴的紙片是什麼？",
