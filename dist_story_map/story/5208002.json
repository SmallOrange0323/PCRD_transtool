        "type": "dialogue",
        "name": "日和",
        "words": "所以我就有做筆記。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "傳送過來發現",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我在空中，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嚇了一跳……",
