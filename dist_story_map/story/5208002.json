    {
        "type": "background",
        "background": "502520"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……做了那個夢，",
        "unit_id": 135511,
        "voice": "vo_adv_5208002_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "想說這個世界是不是發生什麼事。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n就去找了厄莉絲……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n然後她告訴妳的，",
        "unit_id": 135511
