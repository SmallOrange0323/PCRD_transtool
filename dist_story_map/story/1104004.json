    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過你還真的是，",
        "unit_id": 190011,
        "voice": "vo_adv_1104004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總是會撞上真琴害羞的場面呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這就像是『夢境』一樣的東西，",
        "unit_id": 190011,
        "voice": "vo_adv_1104004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以你馬上就會忘記了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但你還真是賺到了呢♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的，",
