    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你在說什麼啊，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別說夢話了。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過也真的是累了啊。",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_047"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n居然會在這種地方睡著。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "狼姐姐！",
        "unit_id": 113,
        "voice": "vo_adv_1104004_048"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "是狼姐姐！",
        "unit_id": 213,
        "voice": "vo_adv_1104004_049"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_050"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是剛剛那兩個孩子啊！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好像很有精神呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "太好了。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "謝謝妳今天救了我們！",
        "unit_id": 113,
        "voice": "vo_adv_1104004_051"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝妳！",
        "unit_id": 213,
        "voice": "vo_adv_1104004_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔。",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_053"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要讓家人太擔心你們喔？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男孩子、女孩子",
        "words": "嗯！",
        "unit_id": 1,
        "voice": "vo_adv_1104004_054"
    },
    {
        "type": "dialogue",
        "name": "男孩子、女孩子",
        "words": "　再見囉～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_055"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_056"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總覺得幫助別人……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還真的是",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很不錯呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈哈，",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_057"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說了些不像我會說的話呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼了啦。",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_058"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n可以說一些「很不像我」",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之類的話來笑我啊？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你也這麼想",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_059"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是嗎。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是嗎是嗎。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我今天邀{player}來真是太好了呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果，",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_060"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你方便的話。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還可以……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "再邀請你嗎？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}可是",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_061"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很值得依賴呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在西沉的夕陽照耀下，\n真琴對著{player}露出微笑。"
