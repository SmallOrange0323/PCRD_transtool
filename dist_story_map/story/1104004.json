    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隨著太陽西斜，\n海邊的遊客也幾乎都離開了。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "明明白天有那麼多人，",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n卻一下子都不見了呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣我們的工作也就告一段落",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "了呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "辛苦你了。",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝謝你今天來幫忙。",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……非常地活躍呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你能這麼說我很高興，",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過我也被{player}救過了呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣子你也成為",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n能夠獨當一面的海邊巡守員了呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然游泳的時候",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要用游泳圈呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n哈哈♪",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你看。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n夕陽漸漸沉進海裡，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好亮啊……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個，",
        "unit_id": 110411,
        "voice": "vo_adv_1104004_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是不是有點太亮了啊？",
        "unit_id": 110411
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "明明只是偶遇，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n為什麼會變成一起回家的狀況。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　你問不行嗎……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也沒有說不行吧。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們的",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感情並不是那麼好吧？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼這麼明顯地擺出好像很寂寞的表情啊！？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "知道了知道了啦，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快點回去吧！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然一起回家也可以啦，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可是在這種時候，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我不知道該說些什麼好。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……最、",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "最近怎麼樣啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我是你老爸嗎！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對了，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你跟優衣怎麼樣了？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說什麼怎麼樣……",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是、",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼說呢……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……不，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還是算了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是什麼我該說的事情啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　怎麼了，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一直看著河那邊？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說什麼！？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不會吧，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "連著紙箱一起被沖走了……！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你幫我拿一下書包！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　你問我要做什麼？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還用問嗎！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要去救牠啊！",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_022"
    },
    {
        "type": "still",
        "still": "110400401"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好乖好乖，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒有事吧―？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要亂動啊！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這麼有精神的話應該沒事吧。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　這毛巾",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是要借我的嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你真貼心啊，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝啦。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說這樣會感冒？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我才沒有那麼虛弱呢。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等一下喔？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　仔細一看，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我現在……",
        "unit_id": 104331
    },
    {
        "type": "still",
        "still": "110400402"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呀啊……！？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你你你你你，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看到了吧！？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說沒有？",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼可能啊！？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還有",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快點轉過去啦！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快忘記！",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n聽好了，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "絕對不准想起來！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "每次跟你這傢伙在一起的時候，步調都會被打亂呢。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這麼說起來……",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "剛剛發出了像女孩子一樣的叫聲……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "應該、",
        "unit_id": 104331,
        "voice": "vo_adv_1104004_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒有聽到吧……？",
        "unit_id": 104331
    },
