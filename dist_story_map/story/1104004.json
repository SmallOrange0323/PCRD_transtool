        "voice": "vo_adv_1104004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真琴她如果是為了幫助某人就會衝出去的這一點，",
        "unit_id": 190011,
        "voice": "vo_adv_1104004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說不定跟你很像呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以後也請你好好支援她喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1104004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就這樣了，",
        "unit_id": 190011,
        "voice": "vo_adv_1104004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～♪",
        "unit_id": 190011
    },
