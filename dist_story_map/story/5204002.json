    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "你跟彩羽到底哪邊比較強，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
