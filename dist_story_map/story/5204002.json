    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這傢伙哪裡是又溫柔又有品格的人了？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n整個正值青春期",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "過激得不得了耶？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……青春期，",
        "unit_id": 132512,
        "voice": "vo_adv_5204002_052"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是嗎。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "沒啦，",
        "unit_id": 132512,
        "voice": "vo_adv_5204002_053"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我的父親……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "對彩羽來說是爺爺。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n在父親他還小的時候，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "在瑪莉絲黛菈小姐的鍊金工作室",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "當保鑣，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n當時他好像被當成弟弟一般疼愛。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "聽說年輕時的瑪莉絲黛菈小姐",
        "unit_id": 132512,
        "voice": "vo_adv_5204002_054"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是個很誇張的不良少女，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n會使用鍊金術的力量",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "為所欲為。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "例如引起龍捲風、",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "或是讓魔物四處作亂……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "直到她某一天",
        "unit_id": 132512,
        "voice": "vo_adv_5204002_055"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "改過自新為止，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n真的完全不受控制……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……唔！",
        "unit_id": 132512,
        "voice": "vo_adv_5204002_056"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "原來如此……！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n瑪莉絲黛菈小姐……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "在鍊金術上是不會失敗的。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼意思？",
        "unit_id": 101311,
        "voice": "vo_adv_5204002_057"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這並不是什麼",
        "unit_id": 132512,
        "voice": "vo_adv_5204002_058"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "失敗的副作用，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n而是露易很常說的那個……！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
