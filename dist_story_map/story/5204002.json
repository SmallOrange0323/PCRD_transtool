    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "而且更重要的是，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "這會讓我心情很舒暢！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這跟之前聽到的差太多了吧……",
