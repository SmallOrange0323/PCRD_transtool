[
    {
        "type": "background",
        "background": "500203"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "布里薩溪谷──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【阿爾克絲鍊金堂】與【暮光流星群】，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在與一名神似露易絲瑪莉的鹿少女對峙中。"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "什……",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_000"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "什什什……",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "呼……",
        "unit_id": 132312,
        "voice": "vo_adv_5204002_001"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "呼……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n終於找到妳了……！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "沒有到",
        "unit_id": 132512,
        "voice": "vo_adv_5204002_002"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "「終於」",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那麼辛苦就是了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n幾乎是在出發後",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "就馬上發現。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "哇～！",
        "unit_id": 132412,
        "voice": "vo_adv_5204002_003"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "妳們看妳們看！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n好厲害，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "就好像有兩個露易一樣好有趣哦～！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "也想要有另一個彩羽～！！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "啊，",
        "unit_id": 132412,
        "voice": "vo_adv_5204002_004"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "對了！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "我說～",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "露易",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "妳過來一下，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "並排站一起！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n好，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "預備～！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "靈魂～",
        "unit_id": 132412,
        "voice": "vo_adv_5204002_005"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "出竅～～～！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉‧瑪莉絲黛菈",
        "words": "妳這是在做什麼啦！！",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_006"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……祖母！！",
        "unit_id": 132312,
        "voice": "vo_adv_5204002_007"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n妳是",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "瑪莉絲黛菈祖母對吧！？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "妳、",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_008"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "妳為什麼會知道我的名字！？",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "不對……",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "比起這個，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "妳叫誰祖母啊！！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n對我這個水噹噹的摩登辣妹來說",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "未免太失禮了吧！！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "話說妳到底是誰啊！？",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_009"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n難道是在模仿我嗎！？",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n快點從我眼前消失，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "妳這模仿我的",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "冒牌貨！！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "誰是冒牌貨啦！",
        "unit_id": 132312,
        "voice": "vo_adv_5204002_010"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "是我，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "露易絲瑪莉啊！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n是超越瑪莉絲黛菈祖母的天才鍊金術師，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "妳的孫女！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "若無其事地偷踩對方……",
        "unit_id": 132512,
        "voice": "vo_adv_5204002_011"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "孫女！？",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_012"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "妳說連男朋友都沒交過的我",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "有孫女",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "是在開什麼玩笑！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "不過嘛，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "我這麼受歡迎！？",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n要找到阿娜答",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "當永久飯票",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "也是輕輕鬆鬆啦！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "荷姆荷姆",
        "words": "咦……",
        "unit_id": 19311,
        "voice": "vo_adv_5204002_013"
    },
    {
        "type": "dialogue",
        "name": "荷姆荷姆",
        "words": "那跟我在一起怎麼樣？",
        "unit_id": 19311
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "而且再說，",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_014"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "怎麼可能會有能超越我的天才鍊金術師！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n少在那胡說了！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "真是的，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "真想看看教育妳的父母長什麼模樣！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我的父母之一就是妳女兒啊……",
        "unit_id": 132312,
        "voice": "vo_adv_5204002_015"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不、",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不對比起那個。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "居然會不認得我，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "這是怎麼回事……！？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "先不管那隻被妳們華麗地無視的巨人……",
        "unit_id": 101311,
        "voice": "vo_adv_5204002_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我說露易美眉，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "她的確是妳奶奶",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這是最終答案囉？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是假冒的？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "確實先來確認一下這點比較好呢……",
        "unit_id": 132312,
        "voice": "vo_adv_5204002_017"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "說，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "祖母！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n妳身上戴的那個金墜飾，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "把它打開看看。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n裡面應該有張相片。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "妳對這有印象嗎？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "別再",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_018"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "叫我祖母了，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "我扭斷妳哦！！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n真是的……",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "這個墜飾怎麼了嗎？",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "說起來不知道什麼時候我就戴著了呢，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "這金墜飾。",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "照片……",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_019"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "呃，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "裡面有位不認識的老婆婆跟小孩子的照片！？",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "好詭異喔……！！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "所以說那就是妳和我啦！",
        "unit_id": 132312,
        "voice": "vo_adv_5204002_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……瑪莉絲黛菈。",
        "unit_id": 105111,
        "voice": "vo_adv_5204002_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳還記得我嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "哼！",
        "unit_id": 53111,
        "voice": "vo_adv_5204002_022"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "我才不會特別去記女生的臉呢！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "除了摩登又年輕的帥哥以外",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "我都不需要！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……妳可別裝傻哦？",
        "unit_id": 105111,
        "voice": "vo_adv_5204002_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我不允許妳說妳忘了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "10年前，",
        "unit_id": 105111,
        "voice": "vo_adv_5204002_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "暴風雨之夜的新手醫生。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……我這樣說妳應該就懂了吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……？",
