        "voice": "vo_adv_5204002_050"
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "那還用說嗎？",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n當然是為了讓全世界都知道",
