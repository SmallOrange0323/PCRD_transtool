[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～雖說是受到『陛下』的命令去監視那傢伙，",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我就一直隱藏氣息跟蹤，小心不被發現……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但那傢伙，從早開始就只是一直漫無目的地亂走啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會，",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙發現我在跟蹤他了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以才故意做著沒有意義的行為？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不會吧～……",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙看起來不像是頭腦很好的人啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的跟蹤應該很完美才對。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可是很擅長隱藏腳步聲的呢。 ",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且還順便用魔法隱藏了氣息。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，沒問題沒問題。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我一定能確實地把任務完成。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管怎麼說，",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可是陛下最寵愛的優秀屬下呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要我能好好地把工作處理完成的話……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該也能被陛下誇獎一次吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙也太沒有動靜了吧，我都膩了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n啊～好煩啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我該不會是注意力不足吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，有小貓。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小貓～快過來快過來。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你好可愛呀，把你收做我的屬下吧……♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我現在還在進行重要任務呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可跟你們不一樣，是有主人的寵物……",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果對主人沒有用處，就會被丟掉呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘻嘻。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喵喵叫，真可愛……咦",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "？\n那傢伙不見了！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～真是的，那傢伙可說是沒有任何氣息呢！",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n稍微轉移目光，竟然就不見蹤跡啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底去哪裡了～現在可不是跟小貓玩的時候啊……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、怎、怎麼辦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，用探知魔法來找那傢伙的話……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～嗯～？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，我身後有那傢伙的氣息？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n剛剛還走在我前面的說？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～是我的魔法式建構上有錯嗎……？",
        "unit_id": 106011,
        "voice": "vo_adv_1060001_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就是不擅長這種小魔法啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呀，糟糕了！",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙的氣息正在靠過來！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我好像～來不及躲了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉呀……",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n啊，那個？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、你好！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃、那個？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今、今天天氣很好呢 ♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇呀啊啊啊啊啊啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嚇、嚇、嚇了我一跳！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開什麼玩笑啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你不要一邊發出那麼大的聲音，一邊一個勁地靠過來啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "害我以為心臟要停止了，宰了你喔……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（嗯～那個～那個、怎麼辦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我要怎麼做才好呢！？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（我很正常地跟他交談了，",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n事到如今也不能裝做是認錯人了～？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真、真巧呢！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你在這裡幹嘛啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（怎～麼辦，怎～麼辦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就、就只能隨便說點什麼矇混過去，趕快撤退了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，就這麼辦！）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，你問我有什麼事……嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說我從早上就一直跟蹤你嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "騙人的吧，被你發現了嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、我的跟蹤應該很完美的說～！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不不，",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在說什麼呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我才沒有跟蹤你呢～是你自我意識過剩吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不要在那說什麼莫名其妙的事喔。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n開什麼玩笑啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "宰了你喔～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼，你知道就好囉～ ♪",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼，總算唬弄過去了呢！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你，是想要問路嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以你才會跟我搭話啊",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這樣說的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你從早上開始就一直晃來晃去的，是因為迷路了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被迫要跟著你的我，可已經受不了啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、你的目的地是哪裡呢？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算這麼說，我也對這個城鎮不熟，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可能沒辦法帶路什麼的……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是，我要做的話也不是不可能啦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別小看人了喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你找不到住宿飯店的位置了啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "(啊，這搞不好是個機會。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只要查到這傢伙睡覺之處，然後我也在那附近住宿的話。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不管是早上還晚上，我都能監視這傢伙啦）。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……好。",
        "unit_id": 106012,
        "voice": "vo_adv_1060001_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我改變決定了，我來為你帶路。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "遇到困難時要互相幫忙嘛～對吧？",
