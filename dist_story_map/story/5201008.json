        "type": "dialogue",
        "name": "澄花",
        "words": "看起來很開心啊。",
        "unit_id": 52731
    },
    {
        "type": "dialogue",
        "name": "澄花",
        "words": "\n他說是因為能見到女兒",
        "unit_id": 52731
    },
    {
        "type": "dialogue",
        "name": "澄花",
        "words": "喔。",
        "unit_id": 52731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 105932,
        "voice": "vo_adv_5201008_075"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "──可蘿。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_076"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "！",
        "unit_id": 105932,
        "voice": "vo_adv_5201008_077"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親大人……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "沒想到妳在這種地方。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_078"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n我剛剛在找妳喔。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "非常抱歉，",
        "unit_id": 105932,
        "voice": "vo_adv_5201008_079"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親大人。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "都是因為",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下沒有遵守",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親大人的囑託……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "不，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_080"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "沒關係。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n雖說妳是個比實際年齡更加可靠的孩子，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "但讓妳",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "在遠處等待的父親才有錯。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "而且讓妳見到其他的七冠，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_081"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "似乎也會對妳的成長有過度影響啊。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "以後",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我會注意的。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "……是妳發現迷路的她吧。",
        "unit_id": 105932,
        "voice": "vo_adv_5201008_082"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "感謝妳",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "引導可蘿。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "嗯。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_083"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "那麼，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "走吧，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "可蘿。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n妳肚子餓了吧，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我們",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "先去吃飯。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好的，",
        "unit_id": 105932,
        "voice": "vo_adv_5201008_084"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親大人。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "請",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "稍等一下。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那個，",
        "unit_id": 105932,
        "voice": "vo_adv_5201008_085"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下與您，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還能不能在哪見到面呢……！",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "…………",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_086"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七冠──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嚮導老君。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與棗宙"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "女兒的小小相遇。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這是由命運引導而誕生的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "連結。"
    }
]