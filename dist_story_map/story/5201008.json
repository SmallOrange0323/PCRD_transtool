[
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──那是"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過去確實存在過的一段時光。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n你的意識慢慢地甦醒過來。"
    },
    {
        "type": "background",
        "background": "510460"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "…………",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "長老，",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可以打擾一下嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "是晶啊。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_002"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我現在",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "正在和「她」進行研究中，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "等一下再說。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "長老只是讓那孩子登入",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "並看著而已。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n……你在讓她做什麼？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我在讓她感受風。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "…………原來如此。",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n是要讓她感受暫時假定的人工自然現象，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n並將現象調整得盡可能接近自然的觸感，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "妳想談的事會講很久嗎？",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那就要看長老了吧。",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我只是希望你告訴我一些事而已喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "唔，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_008"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "關於「她」的事嗎？",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n其他人似乎也都被支開了啊。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "算是吧。",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總覺得我",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "似乎很容易孤立於七冠之外，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n所以談話的時候都僅限一對一為上。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "那",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_010"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我就聽聽妳要問什麼吧。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……為什麼",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_011"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是那孩子？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果是在醫術方面比我這種人還更為精通的長老，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n應該已經知道那孩子的狀況了吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "是啊。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_012"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "這是我實際診察後得出的判斷。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "…………",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_013"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "幸雨澄花。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_014"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n我是在某間醫院",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "和那名少女相遇的。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "對於她的症狀，現代醫學無藥可醫，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_015"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "這個階段留給她的選項，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "只剩緩慢倒數殘存的時光了。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "反正一定是那樣吧，",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_016"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n醫院那方",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是抱著姑且一試的心態才向七冠求助。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……你竟然敢接受呢，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "長老。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "醫院那方應該也嚇到了吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "考量到人類的未來，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_017"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n就不能留下",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "束手無策這種結果。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n我認為一一消除現在的不可能，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "也是引導者的責任。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "可是，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_018"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "她的病情進展，即便是我來看，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n也不得不做出時間不夠的判斷。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……也是",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_019"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "要是至少還有時間……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就會有更多方法……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我和她交談，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_020"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "並問了她的願望。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n要是她還有什麼希望，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我打算幫助她──",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "但是──",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……她說了",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_021"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "什麼？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "「沒有」。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_022"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "她是這麼回答的。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_023"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_024"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "……晶啊，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_025"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我曾經",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "知曉了這個世界的深淵。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "那是超越了我們現在所見的，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "遍布星辰的彼方。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "意思是……",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_026"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "當我認知道「那一端」時，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_027"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我覺得我的願望誕生了。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "妳也有過吧，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n願望誕生的瞬間──",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "就是與那位少年的邂逅。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "但是……",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_028"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "對她而言。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n就連願望誕生的瞬間也不曾擁有吧。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "所以我把「這個」",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_029"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "交給了她。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "「mimi」",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_030"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而且長老",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還做了相當多改造吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗚哇，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這絕對是黑盒子的集合耶……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我引導她",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_031"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "踏入現在正要誕生的新世界。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "結果……",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "妳知道的吧？",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她順利成功用了「那個系統」登入。",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_032"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她擁有我們所夢寐以求的才能，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這就是結果。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "嗯。",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_033"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……我了解原委了，",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_034"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n也了解長老",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是想以自己的方式引導她。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "沒有願望",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_035"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那種事確實",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "太令人悲傷了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這樣的話，",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_036"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "絕對得幫她找到才行啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "找到那孩子的邂逅。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──願望",
        "unit_id": 106831,
        "voice": "vo_adv_5201008_037"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "誕生的瞬間。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "是啊，",
        "unit_id": 107231,
        "voice": "vo_adv_5201008_038"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "那當然。",
        "unit_id": 107231
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "……狀況如何？",
        "unit_id": 107211,
        "voice": "vo_adv_5201008_039"
    },
