    {
        "type": "dialogue",
        "name": "雪",
        "words": "今天就是",
        "unit_id": 117611,
        "voice": "vo_adv_5074451_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在大江戶町的最後一天了呢。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我揭穿了院長的陰謀，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "戰勝了一場激戰！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀～",
        "unit_id": 117611,
        "voice": "vo_adv_5074451_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的名聲",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "又要再次轟動全大江戶啦。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗真是罪過呢♪",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……算了，",
        "unit_id": 117511,
        "voice": "vo_adv_5074451_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳要這麼想我是沒意見啦。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過只看妳這膽量的話，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也許真有資格稱得上是英雄吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我這次也付出了不少勞力呢，",
        "unit_id": 117511,
        "voice": "vo_adv_5074451_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就先悠哉休息一下吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳在說什麼啊？醫生。",
        "unit_id": 117611,
        "voice": "vo_adv_5074451_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們都",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一直在工作，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n根本沒機會好好聊天耶？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不如一邊辦慶功宴，",
        "unit_id": 117611,
        "voice": "vo_adv_5074451_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n一邊讓醫生",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "徹底了解一下",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美麗吧♪",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉……",
        "unit_id": 117511,
        "voice": "vo_adv_5074451_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳真的很令人傷腦筋。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過說來也奇怪，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我竟然不覺得討厭。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這也是因為你的影響嗎？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "總之，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你也要奉陪到底喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "待在大江戶町的",
        "unit_id": 117511,
        "voice": "vo_adv_5074451_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "最後一天，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我們好好享受吧♪",
        "unit_id": 117511
    }
