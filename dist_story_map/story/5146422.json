[
    {
        "type": "background",
        "background": "502283"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呼……",
        "unit_id": 131011,
        "voice": "vo_adv_5146422_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總算是打贏了呢。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這樣遊行應該就能繼續下去了……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……員工先生。",
        "unit_id": 130911,
        "voice": "vo_adv_5146422_001"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n沒想到事情會變成這樣，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我真的真的感到很遺憾……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "但是和你一起工作的那些時光，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我覺得非常開心。",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "如果你有一天洗心革面，",
        "unit_id": 130911,
        "voice": "vo_adv_5146422_002"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "想要露出笑容的話。",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "到時還請你務必務必",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "以客人的身分來玩喔……！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "到時候我們會以笑容來迎接你的！",
        "unit_id": 130911,
        "voice": "vo_adv_5146422_003"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n由我和真步小小姐兩個人一起！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 131011,
        "voice": "vo_adv_5146422_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n到時候，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們會一起在門口",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "出聲迎接你。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露、真步",
        "words": "歡迎你，",
        "unit_id": 1,
        "voice": "vo_adv_5146422_005"
    },
    {
        "type": "dialogue",
        "name": "庫露露、真步",
        "words": "\n來到「大夢想樂園」……",
        "unit_id": 1
    }
]