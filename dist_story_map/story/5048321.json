[
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等、",
        "unit_id": 113811,
        "voice": "vo_adv_5048321_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等一下──！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "弓箭又失控了啦！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還有，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個水晶到底是什麼……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "拉菲，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這是怎麼回事呀！？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "對、",
        "unit_id": 5511,
        "voice": "vo_adv_5048321_001"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "對不起！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "好像是受到願望的強烈程度影響，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n再加上它也是剛剛才獲得新的力量，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n它沒有辦法完全抑制住～！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過，",
        "unit_id": 113711,
        "voice": "vo_adv_5048321_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "它好像比之前失控的時候還要強耶？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "拉菲，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳很努力呢，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "了不起、了不起♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嘿嘿，",
        "unit_id": 5511,
        "voice": "vo_adv_5048321_003"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "也沒有妳說的那麼誇張啦……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "現在是閒聊這個的時候嗎！",
        "unit_id": 113811,
        "voice": "vo_adv_5048321_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總之，我們要阻止弓箭。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我本來可沒有打算要\n變成天使處理這麼累人的工作啊……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒關係啦，",
        "unit_id": 113711,
        "voice": "vo_adv_5048321_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這也是為了讓大家變得幸福快樂嘛，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 113811,
        "voice": "vo_adv_5048321_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說的也是。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們就快點解決吧。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n拉菲，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這裡就交給我們，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳往後站。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這樣我心裡會過意不去的，",
        "unit_id": 5511,
        "voice": "vo_adv_5048321_007"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "至少讓我在遠處替妳們打氣吧！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "加油～",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "加油～！",
        "unit_id": 5511
    }
]