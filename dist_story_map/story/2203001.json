    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "怎麼連普蕾西亞小姐也這樣……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n你們突然跑回來，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我們根本來不及準備餐點。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "如果現在馬上就要吃，",
        "unit_id": 127712,
        "voice": "vo_adv_2203001_045"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n那就請去居住區那邊問問看，有沒有可以讓妳們拆吃的住家。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的可以嗎！？",
        "unit_id": 105812,
        "voice": "vo_adv_2203001_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "謝謝妳。",
        "unit_id": 126112,
        "voice": "vo_adv_2203001_047"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "女僕龍",
        "unit_id": 126112
    },
    {
