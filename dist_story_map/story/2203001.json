        "words": "？",
        "unit_id": 127712,
        "voice": "vo_adv_2203001_037"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──咕嚕嚕嚕～！！！"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "哇！？",
        "unit_id": 127712,
        "voice": "vo_adv_2203001_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇啊，",
        "unit_id": 126411,
        "voice": "vo_adv_2203001_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是貪吃佩可肚子的聲音♪",
        "unit_id": 126411
