        "type": "dialogue",
        "name": "凱留",
        "words": "說到這裡的餐點，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得平均熱量都很高的樣子……",
