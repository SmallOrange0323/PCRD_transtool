    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、",
        "unit_id": 106012,
        "voice": "vo_adv_2203001_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼都沒有～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n話說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果有在這世界找到值錢的東西，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在帶回我們的世界之前，都會向你們報告一聲啦～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
