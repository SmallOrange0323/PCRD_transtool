        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "最近在「吉歐‧提格尼亞」",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "已經很習慣這邊的生活了吧！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "嚇了我一跳……",
        "unit_id": 127712,
        "voice": "vo_adv_2203001_040"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "咦！！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n妳剛剛不是才說已經吃了很多好吃的餐點嗎！？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈……",
        "unit_id": 105812,
        "voice": "vo_adv_2203001_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一不小心，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子很快又餓了～",
