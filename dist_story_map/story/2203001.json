        "voice": "vo_adv_2203001_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "花凜小姐也還在等著我們。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n等著我們把冒險旅程中所找到的謎樣物品",
