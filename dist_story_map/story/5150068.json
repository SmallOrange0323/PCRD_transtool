[
    {
        "type": "background",
        "background": "502330"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "蘭德索爾總是很熱鬧呢～",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "然後，",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你又總是處於那個中心。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒事吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不會累嗎？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣啊、這樣啊。",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n要是開心，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那就再好不過了吧～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過啊～？",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n偶爾",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "度過什麼也",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不做的悠哉時光",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也是很好的喔～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "尤其是……",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這樣",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "跟成熟的大姐姐在一起的時光之類的。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也可以",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "什麼都不想地和我撒嬌喔～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "愛梅斯",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "去追涅比亞，也和你分頭行動了，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n現在就只有我和你兩人獨處。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒有任何人在看，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以就稍微──",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──放鬆一下吧？",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "懂得聽話很了不起呢～♪",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們就去搭上那邊的船，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "隨波逐流一下吧。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……啊，",
        "unit_id": 131813,
        "voice": "vo_adv_5150068_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是坐那邊喔。",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這樣",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "把背靠著我……",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好嗎？",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "放鬆，",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想像你飄浮在水面上，將自己委身於我。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你看～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開始感覺輕飄飄了吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如何？",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n有好好喘口氣……",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "了嗎？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊……",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "身體的緊繃感消失了呢。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這次是",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "深呼吸～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的心跳聲",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有傳過去吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n配合著那個",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "慢慢地、",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "慢～慢地",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很好呢～",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很棒很棒～♪",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我來摸摸你的頭吧～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦？",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你該不會開始睏了？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你的眼神變得迷離了喔～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒關係喔～",
        "unit_id": 131811,
        "voice": "vo_adv_5150068_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不要忍耐。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n閉上眼睛，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要聽著我的聲音",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就好了哦～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唰啦",
        "unit_id": 131813,
        "voice": "vo_adv_5150068_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唰啦，",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "波浪的搖晃真舒服呢～",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n夏天的陽光",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "暖洋洋的，",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "會讓身體溫暖起來喔。",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我撫摸著的手",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也很舒服吧～？",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來，",
        "unit_id": 131813,
        "voice": "vo_adv_5150068_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "繼續放鬆吧。",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n把一～切都交給大姐姐。",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵呵，",
        "unit_id": 131813,
        "voice": "vo_adv_5150068_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你是個好孩子呢～♪",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵♪",
        "unit_id": 131813,
        "voice": "vo_adv_5150068_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵呵……♪",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "…………",
        "unit_id": 50213
    }
]