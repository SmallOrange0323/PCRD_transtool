[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "漁師のおっちゃんたちって、",
        "unit_id": 106113,
        "voice": "vo_adv_6056401_000"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "変わった魚の釣り方するよなー。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "アタシもたまに川で釣りはするけどさ、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n結構コツが必要なんだよ……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "好きっていうか……",
        "unit_id": 106113,
        "voice": "vo_adv_6056401_001"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "腹が減った時にやるくらいだな！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n川ごとぶった斬れば、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "すぐに魚が浮いてきて……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "へっ？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "　それは釣りじゃない？　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……そうなのか？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "おお、",
        "unit_id": 106113,
        "voice": "vo_adv_6056401_002"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "オマエもそう思うか？　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "陸の魔物を狙うのは簡単なんだけどな……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "天楼覇断剣でドカーンってさ！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "魚だと骨も残んない時があるからな。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "いやー、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "釣りって奥が深いよな！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "今度一緒に釣るか？　",
        "unit_id": 106113,
        "voice": "vo_adv_6056401_003"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "だったらどっちが多く釣れるか、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nアタシとオマエで勝負だ！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ふふっ、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ワクワクしてきたぞ！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nアタシは天楼覇断剣で釣るからオマエは……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "え？　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "反則？　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "知るか！",
        "unit_id": 106113
    }
]