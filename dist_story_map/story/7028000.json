    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在露娜之塔塔底──"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "鏘鏘鏘～♪",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n終於輪到",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "壓軸‧",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "迷宮女王，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也就是拉比林斯達姐姐我登場",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "了喔！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀～",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我本來就想著",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總有一天要來這裡喔？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只是",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "得優先處理的事實在是太多了～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "露娜之塔……",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這裡的構造充滿謎團，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且與你的記憶有所關連，這點我也有聽說。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總而言之",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "終於可以認真起來調查了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n既然我出馬，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "目標就是把那層祕密的薄紗",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n揭得一乾二淨對吧！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼就趕快打起精神出發～！",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……雖然我是很想這樣說。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……少年。",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你身邊那位可～愛的女孩子是？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "初次見面妳好！",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_006"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "大姐姐！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比呀，",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_007"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n是來幫忙",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從工作的！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣啊～",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "請多指教囉班比！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n謝謝妳這麼有精神地跟我打招呼！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只是，",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然很感謝妳願意幫忙……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但這場調查可能會挺危險的喲？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比知道！",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_010"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n這裡",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "有很多魔物對吧～？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "既然如此，",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_011"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比就得保護僕從才行！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "因為，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比和僕從有訂「契約」",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘛！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "契約？",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_012"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嗯！",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_013"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "如果僕從遇到困難，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比就會保護他。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "然後，",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_014"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "當班比遇到困難的時候，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從就會來幫班比。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這就是「契約」！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯～",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣啊……！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那就沒辦法了！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我同意班比也一起來幫忙！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "大姐姐，",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_016"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "謝謝妳──！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "那個……？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是拉比林斯達。",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以用妳喜歡的方式叫我喔！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "像是「拉比林斯達小姐」",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或是「拉比姐姐」。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還有",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我有在經營可麗餅店，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以叫「老闆」之類的？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要取暱稱我也很歡迎！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比知道了！",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_019"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "請多指教喔，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "拉比林斯達！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔喔，",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "居然直接喊名字……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "姐姐我",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "感受到妳的大器量了！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿嘿♪",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_021"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "拉比林斯達",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好帥喔！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "感覺是很可靠的大姐姐！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是嗎？",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "誇獎我也",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "得不到什麼好處喔？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n啊，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "之後來做可麗餅給妳吃好了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然我是希望能盡量減少",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n調查中的不確定因素……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但也不能把她一個人留在這裡吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也罷，",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "反正就算出了什麼事，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只要用權能把他們兩個帶回去就好了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且…………",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_025"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "貝斯在睡午覺，",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_026"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以留下來看家了！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "因為",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "把牠叫起來不是很可憐嗎？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "別擔心！",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_027"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比會",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n好～好地",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "保護僕從的！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在的你和大家所繫起的羈絆……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我也想盡最大努力為你珍惜啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我來啟動這個傳送魔法術式……",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好了，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "準備完成。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "為了不讓僕從走丟，",
        "unit_id": 122311,
        "voice": "vo_adv_7028000_030"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比來牽著你的手！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哈哈，",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有位可靠的姐姐跟著，真令人安心♪",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼兩位，",
        "unit_id": 106815,
        "voice": "vo_adv_7028000_032"
    },
