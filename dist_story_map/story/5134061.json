        "voice": "vo_adv_5134061_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "初夢啊……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我果然",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "比較想夢到{player}……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "吧？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖、",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然自己說這些讓人開始害羞起來，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但明年想跟他變得更要好……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想做那種夢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "現在雖然也已經很要好了，",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要是",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "他能再稍微把我當作女孩子來看待，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我會很高興呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這種願望……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "會不會太過奢求了啊……",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在夢裡面的話也沒關係吧？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那就",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不再多煩惱了。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為了做個美好的初夢，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "馬上來睡覺吧～☆",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕……",
        "unit_id": 128411
    },
    {
        "type": "still",
        "still": "513406101"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……奇怪？",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為什麼會在這種地方？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦！？",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n新年快樂……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說你平常是這樣講話的嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "跟平常一樣！？",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是哪個平常！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有跟你做過那種事嗎！？",
        "unit_id": 128411
    },
    {
        "type": "still",
        "still": "513406102"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果我們",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有那樣做過，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那我絕對會記得吧～！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "等等，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太近！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太近了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然我不討厭，",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但是突然被這麼做的話……！",
        "unit_id": 128411
    },
    {
        "type": "still",
        "still": "513406103"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇啊啊……！？",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不好啦。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n……這樣子……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果被別人看到的話……",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "會很困擾……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你說那就做給他們看……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n咦～！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你到底是怎麼了！？",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "果然跟平常不一樣……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我才做不到",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那種事啦……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我這麼地",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "重視你……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我現在……",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n心臟跳得好快喔……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦，",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼意思？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你想說你就是規則嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說的話明明就很莫名其妙……",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我卻被那帥氣的聲音吸引，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n開始心跳加速了啦！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總之",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "先冷靜一下……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個真的先等一下啦！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你的臉要是再繼續靠近的話，",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘴唇就要……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n啊……！",
        "unit_id": 128411
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呀啊啊啊啊啊啊啊啊啊啊！？",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……奇怪？",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n難道……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這全部",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "都是夢？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唉……",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不管怎麼想，他都不會說那種話嘛。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺似乎鬆了口氣，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "卻又好像很遺憾……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "夢境太過刺激，",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "害我的心臟還在蹦蹦跳……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這個夢應該沒辦法跟小栞說吧。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是",
        "unit_id": 128411,
        "voice": "vo_adv_5134061_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "從內容來看，說不定可以期待能跟他變得更要好！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "既然如此，小初音",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今年一整年也要加油～☆",
        "unit_id": 128411
    }
]