    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "遵、",
        "unit_id": 1,
        "voice": "vo_adv_5142001_069"
    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "遵命！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "其他新兵也跟上！",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_070"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n第二排去掩護第一排的，避免讓他們",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "受到攻擊！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "遵命！！",
        "unit_id": 1,
        "voice": "vo_adv_5142001_071"
    },
    {
        "type": "dialogue",
        "name": "失控的新兵1",
        "words": "嗚、",
        "unit_id": 711,
        "voice": "vo_adv_5142001_072"
    },
    {
        "type": "dialogue",
        "name": "失控的新兵1",
        "words": "嗚吼嗚嗚嗚……！？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什麼……！",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_073"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n士兵們",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被包圍了？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼……！？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿嘿……！",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_074"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就算每個人都很強，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n只要進入多對一的狀況，就是我們比較有利！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很好……",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_075"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "各位！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就這樣把他們逼到一起，抓住他們──！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "喔喔喔──！！",
        "unit_id": 1,
        "voice": "vo_adv_5142001_076"
    },
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "失控的新兵們",
        "words": "嗚……",
        "unit_id": 1,
        "voice": "vo_adv_5142001_077"
    },
    {
        "type": "dialogue",
        "name": "失控的新兵們",
        "words": "嗚吼喔喔……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的士兵們",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_078"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被抓住了……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼可能……！",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_079"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n是我的藥效果太弱了嗎……！？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才不是呢。",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_080"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說啊，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "「破壞者」小姐～",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n當教官",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可不光是讓士兵變強就好。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "必須鍛鍊那些毫無經驗的菜鳥，",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_081"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n讓他們適應團體生活、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "能夠作為組織來戰鬥，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n像這樣培訓他們，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才是教官的工作。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唔…",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_082"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n作為組織，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來戰鬥……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒錯。",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_083"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這就是騎士團的戰鬥方式。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然對一個人也強得離譜的妳來說，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "大概很難理解就是了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳應該",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "連團體戰這個詞都不知道吧？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "才、",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_084"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "才沒有這回事。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這種小事我也知道……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "至少聽過這個詞彙。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉……",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_085"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那跟不曉得是一樣的吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "算了，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我就知道是這樣。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以我也沒有打算責怪妳。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_086"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "教育他人可是比想像中的",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還要更加困難喔。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "尤其是對妳這種從一開始就很強的傢伙。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算這樣，妳還是真的",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_087"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "想當教官嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_088"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……我要當。",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_089"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為我已經對這位大人發誓了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我不會放棄的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然培育出能作為組織戰鬥的人",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_090"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n才算是這裡的教官，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那我就做給妳看。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而且我絕對",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會拿到勳章的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯……",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_091"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這全都是為了這位大人！！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_092"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n有幹勁是很好，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也不會去阻止她啦……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是那個「破壞者」",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_093"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "居然要當教官啊……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的不要緊嗎……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說，",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_094"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你也跟她勸個幾句吧？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉……",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_095"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看來你也很辛苦呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我知道了，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也來幫忙看著她吧……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "惠理子重新下定決心要邁向教官之路。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對於這樣的她，{player}和真琴"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n滿臉擔心地在一旁觀望。"
    }
]