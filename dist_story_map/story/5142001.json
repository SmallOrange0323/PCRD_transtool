[
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "成為了新兵訓練所教官的惠理子"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與決定陪同她的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一起來到了【王宮騎士團】的訓練營地。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就是訓練營地呀。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "乍看之下，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只是普通的平原呢……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唉……",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "果然沒有必要勞煩您",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n特地來到這種荒郊野外呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在還不遲。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "勳章我一定會帶回去的，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您可以先回去也沒關係喔？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然替我擔心……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您是多麼地溫柔呀……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然您願意和我待在一起的話，",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了盡早從這裡回去，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會拚上全力的！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不管要使用什麼樣的手段！！",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您居然如此替我耗費心神……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我深刻感受到",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您的溫柔了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過請您放心吧！",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n為了能盡快達成目的，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我自己也有準備了「祕密策略」。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣一來，",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "勳章最快在明天就會是您的了……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻嘻……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂──！",
        "unit_id": 1,
        "voice": "vo_adv_5142001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那邊的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們在做什麼啊──？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "差不多要到開始訓練的時間了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……咦？",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你們……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "！",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳是……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗨……",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在奇怪的地方碰面了呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你們為什麼會在這裡……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什麼",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "用看的還不明白嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "用、",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "用看的……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我想想……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就我所見，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子身上穿著教官服，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n和{player}出現在訓練所……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳這不是很清楚嘛。",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我成為了這間訓練所的教官。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這位大人",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是來陪我的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什……",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊啊！？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n惠理子",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "當教官！？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不不不，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼啊！？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一些事……？",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣啊……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我不會詳細過問的。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "反正大概不會是什麼正經的理由……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了這位大人，我願意做任何事。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉……",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "算了，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然是上層決定的，我是無所謂啦。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "畢竟我也是受人僱用的教官，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒什麼立場批評。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "受人僱用的教官……？",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這麼說來妳才是，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼會在這裡呢？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡是【王宮騎士團】的訓練所，",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n由【哞哞自衛隊】的妳來當教官這種事很不自然。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "關於這點，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "前陣子這裡的騎士團",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不是改成了不限種族都能入隊嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "從那之後",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "想入隊的獸人族就變多了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "然後，",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "最近跟他們慢慢開始建立良好關係的\n【哞哞自衛隊】也決定",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要派遣臨時教官。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n其中的一人",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是我。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "畢竟，",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也想支持那些希望成為騎士的獸人族嘛。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以說，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我會在這裡當個幾期的教官。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "原來如此。",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我大概理解情況了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也就是說……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳的目的並不是勳章，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯吧？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然如此，",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這一期的勳章就由我收下了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳應該沒有異議吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、",
        "unit_id": 129811,
        "voice": "vo_adv_5142001_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我是沒意見。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "新人教官收到勳章這種事，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可是前所未有的耶？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "更重要的是，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳會訓練人嗎……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻嘻。",
        "unit_id": 129911,
        "voice": "vo_adv_5142001_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "關於這一點無須擔心──",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
