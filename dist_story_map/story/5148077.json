    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "什麼什麼～",
        "unit_id": 131111,
        "voice": "vo_adv_5148077_000"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n大家",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "在講悄悄話──？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "好像很有趣呢～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "美空小姐跟",
        "unit_id": 131611,
        "voice": "vo_adv_5148077_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "蘭法小姐的紙杯傳聲筒。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n傾聽涅比亞小姐低語的兄長大人。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這是可以感受到大家親密度的",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常好的照片呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "妳們兩個",
        "unit_id": 131213,
        "voice": "vo_adv_5148077_002"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "等一下。",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "妳們不覺得",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這張照片有點奇怪嗎？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯……？",
        "unit_id": 131111,
        "voice": "vo_adv_5148077_003"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n啊……！",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "沒錯──★",
        "unit_id": 131213,
        "voice": "vo_adv_5148077_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這是張",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "靈異照片喔～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "莉莉身旁",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "有個骷髏幽靈……",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真的耶，",
        "unit_id": 131111,
        "voice": "vo_adv_5148077_005"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不妙啊。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "要把這張照片拿去做個除靈儀式嗎～？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n妳看起來被附身了耶？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊，",
        "unit_id": 131611,
        "voice": "vo_adv_5148077_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不是的……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那是",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我見過的人……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "唉～說白了",
        "unit_id": 131213,
        "voice": "vo_adv_5148077_007"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n那其實是忍的爸爸呢★",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "莉莉看起來覺得很困擾耶？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那是……",
        "unit_id": 131611,
        "voice": "vo_adv_5148077_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n因為骷髏老爸先生他……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n他一直在我耳邊低語著",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "沒辦法在這邊說出口的話……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那些話，",
        "unit_id": 131213,
        "voice": "vo_adv_5148077_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n該不會是所謂的詛咒吧──？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "妳果然",
        "unit_id": 131111,
        "voice": "vo_adv_5148077_010"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "被附身了啦～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "去找人除靈比較好吧～？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 131611,
        "voice": "vo_adv_5148077_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不是那種言詞……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "該怎麼說明才好……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "嗚嗚嗚嗚……",
        "unit_id": 131611
    },
