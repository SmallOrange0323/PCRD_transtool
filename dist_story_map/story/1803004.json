        "voice": "vo_adv_1803004_079"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "天亮了啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_080"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼會在這裡……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來我們兩個",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_081"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都累到直接睡著了呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "快醒醒。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該回公會小屋了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可可蘿她們一定都很擔心你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_082"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就好。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼回事……",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_083"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或許是睡得太沉，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺得到了充分的休息。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n身心都",
