    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們準備一下去吃早餐吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n作為昨天的回禮，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天就由我來成為你的力量。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不只是今天。",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_086"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從今往後，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我都會是你的力量。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了過上和夢中一樣，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那微不足道……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻又平靜祥和的時光。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我相信，",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_087"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在的我能夠辦到。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我一定會跨越前方的種種挑戰，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
