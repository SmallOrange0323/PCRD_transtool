[
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從雪山返回蘭德索爾的怜與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有說有笑地回顧著一天的經歷。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……在大雪紛飛的山頂與幽靈戰鬥什麼的，",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這種體驗，或許會被人說是看到幻覺了吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要不是你也在場，",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n連我都要懷疑自己是不是修練過度燒壞腦子了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哎呀，",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經這麼晚了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天謝謝你陪了我這麼久。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你應該也很累了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我送你回公會小屋吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然當時保持著公主型態，",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但或許是太急著下山了？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連我也都精疲力盡了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……嗯？",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你看，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個在發光的物體是……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不對，",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是物體在發光……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那道",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "光……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是什麼……",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "老師再見。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天非常感謝您。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "花藝講師",
        "words": "妳也辛苦了。",
        "unit_id": 1,
        "voice": "vo_adv_1803004_007"
    },
    {
        "type": "dialogue",
        "name": "花藝講師",
        "words": "關於展覽的事，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花藝講師",
        "words": "\n記得幫我向士條先生知會一聲。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好的。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那我就先失陪了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……完全把我當成傳聲筒呢。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我的花藝技術到底有沒有進步，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "老師根本就不在意吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話雖如此，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也只是在學著自己沒興趣的東西罷了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以實際上，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我和老師對彼此的不尊重應該是半斤八兩吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了……",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "轉換一下心情吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n難得這麼早結束，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "去散散步再回家好了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "反正就算回家",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也沒什麼好事。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……咦？",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個人",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該不會是……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗨，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "居然在這裡遇見你，還真是巧呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "稍微來辦點事。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那你……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的學校在這附近，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會路過這裡也不奇怪呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你該不會，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n正打算去哪裡辦事吧？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就好。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n難得的寶貴假日，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是打擾到你就不好了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也差不多該──",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下雨了……？",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真傷腦筋啊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我今天沒帶傘出門耶。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我先走了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也趁淋濕之前",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "趕快回家吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說著說著雨就越下越大了……！",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是先找個地方躲雨吧！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼、",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡應該不會淋到雨。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……在這麼短的時間內竟然就濕透了。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你我都是……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你看看自己。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你現在超級狼狽喔。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n簡直就像從河裡或海裡爬上岸一樣。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這倒也是……",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈啾！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算找人來接，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這種濕漉漉的",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "狀態下搭車，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在回到家前就先感冒了吧……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦……？",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你家、",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎……？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……那麼，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就打擾了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n拒絕難得的邀請也不太禮貌呢。",
        "unit_id": 100331
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……打擾了。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這樣真的可以嗎？",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不用了啦。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不能這麼麻煩你……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只要能暫時避雨就行了……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈啾！",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不好意思。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就恭敬不如從命了。",
        "unit_id": 100331
    },
    {
        "type": "still",
        "still": "180300401"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我換好衣服了，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你可以進來囉。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你家有沒有能晾乾衣服的地方？",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝、",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……總覺得有點不自在。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這裡就是",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他的房間啊……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……話說回來，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我是第一次",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "進男孩子的房間耶……！？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊啊啊，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "突然緊張起來了……！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣或日和",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有來過嗎！？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是說，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他經常帶別的女孩子回來……！？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這麼說來，他剛剛準備換洗衣物的動作，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n看起來十分熟練……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不不！",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我到底在想什麼啊！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他怎麼可能會是那種人！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呀、是！？",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好啊！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我就不客氣了！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嘶嘶……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好燙！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈、",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈哈……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或許是覺得身體冷起來了，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不自覺地想要趕快喝掉……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈哈哈哈……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呼。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好溫暖……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……雨，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下個不停呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……那個，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我本來沒打算這麼麻煩你的。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只是",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想稍微躲個雨而已……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼說呢。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得很抱歉。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也對一直給你添麻煩的自己感到心煩……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n畢竟，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我總是受到你的幫助……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……雖然是偶然，但能像這樣",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和你待在一起，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n老實說，我覺得很開心。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是我能",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "回報你什麼就好了……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "阿斯特朗的……？",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒問題。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這點小事我當然很樂意奉陪。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說到冒險……",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你知道嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n聽說有個只在雪山山頂出現的",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "限時任務……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……原來是這樣。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你察覺到了我的不自在，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n為我的心情著想才會說這些的吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你真的",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很溫柔呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我都不自覺地",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沉溺於",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那份溫柔中了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "回去後得玩一下阿斯特朗才行呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……真不可思議。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明直到剛才我還完全不想回家的。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一想到登入遊戲前",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "得聽父親的種種嘮叨，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就覺得心情鬱悶，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不太想馬上回家。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_057"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的花藝老師住在這附近。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n老師平時會來我家上課，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但今天是我去拜訪她。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的意思是，我平時太沒氣質，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n看起來不像是個大小姐嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……開玩笑的啦。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_059"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "父母硬逼著我學花藝，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我本來就已經受夠了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在阿斯特朗裡砍殺花朵怪物",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才更合我意呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……真奇怪。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_060"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明是在他的房間，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n卻比在我自己的房間裡",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "更輕鬆自在……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……雨啊。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_061"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "拜託了，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "請就這樣持續下不停吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n讓我",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再多和他待一段時間……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_062"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這件衣服",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是你家人的嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我改天得好好答謝……",
        "unit_id": 100331
    },
    {
        "type": "still",
        "still": "180300402"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是、",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是你的嗎！？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這、",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我還以為是別人的衣服呢……！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n哦……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來是你的啊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……啊啊，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_064"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "衣服上確實有他的味道……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不對，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我在幹什麼啊啊啊啊！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒、",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒什麼！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒什麼啦，你別介意！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這、",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_066"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種感覺……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一旦意識到是他的衣服，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就有種被他抱住的錯覺……！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n冷靜下來，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "冷靜下來啊我！　",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "總算恢復冷靜的怜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n直到雨停為止，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "都在{player}的房間裡\n與他共度兩人時光。"
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天真是謝謝你。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_067"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "幫了我一個大忙呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會想想除了遊戲冒險以外的回禮，",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你就好好期待吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……那個！",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_069"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……下次，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還能來",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……躲雨嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……謝謝你。",
        "unit_id": 100331,
        "voice": "vo_adv_1803004_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "改天見。",
        "unit_id": 100331
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，",
        "unit_id": 190011,
        "voice": "vo_adv_1803004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "天氣真是陰晴不定呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總是不顧我們的意願隨意變化。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "突如其來的降雨，",
        "unit_id": 190011,
        "voice": "vo_adv_1803004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對大部分的人而言都是個困擾，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但對怜來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這或許是場及時雨呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對每天被諸多束縛綁住的那孩子而言，",
        "unit_id": 190011,
        "voice": "vo_adv_1803004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n與你一起共度的瑣碎時光",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或許才是最珍貴的寶物吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，當怜得知身上穿的是你的衣服時，",
        "unit_id": 190011,
        "voice": "vo_adv_1803004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她那副慌忙的模樣……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是有趣得不得了啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她那不擅長應付男性的一面",
        "unit_id": 190011,
        "voice": "vo_adv_1803004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的很可愛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看著都不禁露出微笑了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1803004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你應該有把借怜的衣服拿去洗吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算問了你恐怕也不記得。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果在這邊也發生了相似的事，",
        "unit_id": 190011,
        "voice": "vo_adv_1803004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也要保持著紳士風度喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你大概也知道，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想讓那孩子變得坦率，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "需要很多時間呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1803004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見啦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯嗯……",
