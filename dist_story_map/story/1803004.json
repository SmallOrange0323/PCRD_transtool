    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比以往來得更輕鬆舒暢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你有睡個好覺嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1803004_084"
    },
    {
