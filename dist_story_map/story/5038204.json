[
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_5038204_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "氣溫上升，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "濕度下降中。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的體溫",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也隨之上升，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而且口腔黏膜乾燥，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好想喝點什麼。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那不就只是口渴了而已嗎。",
        "unit_id": 110911,
        "voice": "vo_adv_5038204_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "順帶一提，",
        "unit_id": 110811,
        "voice": "vo_adv_5038204_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "想吃果凍的話我有。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_5038204_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "常常會不知道從哪變出點心來呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～",
        "unit_id": 110811,
        "voice": "vo_adv_5038204_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為我家有一堆頑皮的小鬼。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇～是果凍耶！　",
        "unit_id": 111011,
        "voice": "vo_adv_5038204_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好甜～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來如此，",
        "unit_id": 110911,
        "voice": "vo_adv_5038204_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是這樣用的啊。\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦……？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，優妮學姐應該不是那種對食物沒有抵抗力的",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那種可以用食物釣她的女孩啊——",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好甜……",
        "unit_id": 111011,
        "voice": "vo_adv_5038204_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯嗯？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只有甜而已……？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是什麼啊，克蘿依。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我要求要公開成分。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 110811,
        "voice": "vo_adv_5038204_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我也不知道，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "大概是砂糖和吉力丁？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該是吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那不就只是一般的懷舊零食而已嗎！",
        "unit_id": 111011,
        "voice": "vo_adv_5038204_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不然妳以為那是什麼？",
        "unit_id": 110911,
        "voice": "vo_adv_5038204_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不然妳以為我是誰？",
        "unit_id": 111011,
        "voice": "vo_adv_5038204_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不要再不然了，",
        "unit_id": 110811,
        "voice": "vo_adv_5038204_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好啦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "趕快往前進吧～",
        "unit_id": 110811
    }
]