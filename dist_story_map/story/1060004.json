[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "窣窣窣……",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～真美味♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放入藥草的粥，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n流進了疲憊的腸胃裡啦～……♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也點你喜歡吃的東西啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡的料理可是對腸胃很溫和的喔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且還無敵美味！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你有跟大家一起來吃過，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以應該知道吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那次吃完後就深得我心呢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我很常來這裡吃喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "特別是早餐很常來這裡吃呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這家店離我工作的地方……離王宮也很近呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可跟和平大眾家庭裡的少爺、大小姐不同，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒有會煮三餐給我吃的父母呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我必須要自己想辦法弄到食物，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不然會餓死",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以囉……",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說真的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n能跟你們一起吃遍天下，可說是幫大忙啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也因此知道了許多",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n便宜又好吃的店呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說真的，不只是晚餐而已，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n早中晚任何時候我都想要一起吃遍天下呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我想跟其他人一起熱鬧地吃吃喝喝啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，不過你們也有自己的生活……",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n每一次都要讓你們陪我也很不好意思呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可沒有像那樣",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟你們打成一片、當好朋友的權利呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈。",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n抱歉。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種事情就算跟你說，也沒用呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過呢……",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我忘了是什麼時候，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔有說過『吃就是為了活著』呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "飲食生活如果充實的話，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就會有好～幸福的感覺。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不知怎麼，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最近我的心情非常好呢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是多虧了你們。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果能像這樣",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "每天都能持續下去就好啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇……！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，你？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你好像在發光喔，怎麼這麼突然？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（這是什麼？",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n『陛下』也從來都沒提過這種事……！？）",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "510352"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊～可惡！",
        "unit_id": 1,
        "voice": "vo_adv_1060004_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真糟糕！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我的錢包不曉得掉在哪了，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_021"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不對，還是被扒手摸走了……！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "怎～麼辦……",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_022"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我家離這個車站很遠呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不搭電車用走的話，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_023"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "何止是太陽下山，根本就要走到天亮啦。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "補習完太晚回到家的話，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_024"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n又會被罵……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "如果我不聽",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_025"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我家老媽的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n她就會擅自認為 『我是不是在哪裡做壞事啊？』",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "因為這樣，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n害我打工不知道被開除幾次了……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n好不容易才好像能交到好朋友的說……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊～煩死了！",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_027"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那傢伙，死不了嗎！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我在這裡亂生氣也不是辦法啊。",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_028"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n總之得想辦法籌到電車費……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還是我先去打工的店，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_029"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "預支點薪水好了？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可是打工的地方，不管哪個都是在家附近……",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_030"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但是老媽竟然說什麼『風水上很吉利』，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n就只有補習班選在離家這麼遠的車站前。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼風水啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_031"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n她是笨蛋嗎！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊～真是不幸……",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_032"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "全部都是老媽害的……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我想離家出走啊～",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_033"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我就這樣不再回家，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n去哪個遙遠的城鎮住吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不行，我必須要忍耐。",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_034"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "至少我也要大學畢業，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n現在就業之類的好像很嚴苛呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我就忍耐到那時，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_035"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n然後獲得一份好工作……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "之後我再找個好男人，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "過上幸福的生活。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "然後再跟老媽說",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_036"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n『我會幸福絕對不是托妳的福！』……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那就是我的報仇！",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_037"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊～真是討厭的人生啊。",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_038"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n為什麼都只有我這樣……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……嗯？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_039"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n幹嘛啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你在看哪裡啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "看什麼看啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_040"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n宰了你喔！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_041"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n什麼怎麼了嗎，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "跟你有關係嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "沒有吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然我不知道你是要搭訕還是要推銷兜售，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_042"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n反正去找別人啊，笨蛋～！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗄？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_043"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不要在那給我裝傻喔！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "幹嘛啊？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_044"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你是想跟我吵架嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n快滾啦，礙眼死了，我真的宰了你喔！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗯嗯？什麼？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_045"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我聽不到啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "講清楚一點？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗄？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_046"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你說……如果可以的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你要借我電車費？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你說因為我在大叫，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_047"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n所以擔心起我來了？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不要管我！",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_048"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n管什麼閒事啊，笨蛋～！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對悲慘的女國中生溫柔，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_049"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你是想要沈浸於自我滿足之中嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但是很可惜，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_050"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我才不相信別人的溫柔！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不管是什麼阿貓阿狗都裝作一副好人樣，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_051"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n用高姿態瞧不起別人！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不要把別人當笨蛋啊！",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_052"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n只要大家大家大家……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "死了最好！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "哇呀？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_053"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n什、什麼？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "喂，你剛拿什麼東西丟我了吧……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "來啊！",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_054"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n要吵架的話，我奉陪到底啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我可是在巷弄裡長大的品性惡劣壞小孩喔，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_055"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n暴力事件什麼的我熟得很喔！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊，喂！\n不要逃跑啊！",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_056"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你給我回來，我要宰了你……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "哼……",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_057"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真是的，噁心。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那傢伙到底要幹嘛啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "從他身上的制服來看，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_058"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n像是這附近高中的傢伙呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我已經記住那傢伙的臉了。",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_059"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "下次再讓我碰到的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我就要馬上用指甲抓他兩下。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗯……？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_060"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那傢伙丟過來的到底是什麼？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "仔細一看，竟然是錢包？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊，有留言在裡面。",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_061"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這麼說的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n剛剛那傢伙好像邊跑邊寫了什麼呢……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗯。",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_062"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "上面寫著『請當作電車費使用』嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗄……？",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_063"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼啊……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這樣子，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_064"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n不就跟勒索沒兩樣嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過確實，",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_065"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n有了這個的話我就能像平常一樣搭電車回家了……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n真是幫了大忙呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……啊、裡面有學生手冊。",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_066"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "哼，那傢伙叫這個名字啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "上面也有寫住址呢。",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_067"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "總之我就先只借用電車費，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n之後再把錢還回去這個住址就好了吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只借不還的話，\n",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_068"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "會讓人覺得不舒服呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "哼……",
        "unit_id": 106031,
        "voice": "vo_adv_1060004_069"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n總之就先謝謝你啦！",
        "unit_id": 106031
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真恐怖……",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n凱留，品性非常不好呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我光看著就覺得害怕啦，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她的行為舉止完全就是個不良少女嘛！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到底是在怎樣的環境下長大，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n才會讓女國中生有那樣的言行舉止出現呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總覺得，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有點在意呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n抱歉抱歉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不先稍微說明一下的話，你會很困惑呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反正你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你在『那邊』的時候，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像跟凱留幾乎沒有什麼交流呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "實際上，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你能回想出的回憶可說是幾乎沒有呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再稍微讓我",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n補充說明一下……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這件事發生過後幾天……",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你會再次",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n跟來還錢包跟電車費的凱留見面喔！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後，你們會發現",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n其實你們已經在阿斯特朗……遊戲上碰過面，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而互相嚇了一跳！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也就是，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_081"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有你常經歷到的慣例上的那個喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只是，在那之後你們也幾乎沒有什麼交集……",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_082"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n直到最後都沒有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你跟凱留感情變好的發展喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟你們的生活圈\n好像幾乎沒有重疊呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_083"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "凱留也似乎因為家庭因素，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_084"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不太能登入阿斯特朗。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正因為如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_085"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你現在能跟凱留相遇，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還一直有互動交流，是非常不可思議的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我覺得是誰",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_086"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n存著什麼樣的意圖。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，現在想那種事也沒用。",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_087"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n搞不好單純是巧合呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_088"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n既然說這麼多廢話也沒用，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次就先到這裡失陪囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～",
        "unit_id": 190011,
        "voice": "vo_adv_1060004_089"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n下次見囉♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}？",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_090"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還好嗎……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你身體不舒服嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_091"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n感冒了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "依照症狀不同，我的恢復魔法搞不好會有效……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我還蠻擅長魔法的呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_092"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我經過了重重學習與修行，所以會各式各樣的魔法喔♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_093"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你幹嘛啊，一直盯著我看……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的臉上有什麼東西嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啊，真是的，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_094"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n奇怪的傢伙……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比起那個，餐點會冷掉喔，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_095"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n趕快把它吃完吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我從下午開始也要工作，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_096"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n跟閒閒沒事做的你不同呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果你沒有要再加點的話，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_097"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就先去結帳吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_098"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你忘記帶錢包了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是糊塗呢～……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒關係啦。",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_099"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n反正我們今晚",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也要跟大家一起吃飯嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到時你再幫我付錢就好啦，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_100"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這裡我就先幫你墊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_101"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n幹嘛啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不要一副很意外的表情啊，真沒禮貌呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我，",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_102"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看起來有那麼像是貪財的人嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，你到底怎麼啦……",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_103"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你幹嘛那麼害怕，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還道歉了好幾次。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我又沒有在生氣～",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_104"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的臉有這麼恐怖嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈。",
        "unit_id": 106012,
        "voice": "vo_adv_1060004_105"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你今天真的有點怪怪的喔……♪",
        "unit_id": 106012
    }
]