        "name": "流夏",
        "words": "就只是群社會脫節者聚集在一起而已。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以我決定，",
        "unit_id": 105611,
        "voice": "vo_adv_1056010_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要來教你們如何釣魚。",
        "unit_id": 105611
    },
