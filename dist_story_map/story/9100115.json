        "voice": "vo_adv_9100115_007"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "無駄飯喰らいの腹ペコ王女様！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\nお供をゾロゾロ引き連れて、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "あの世へのお散歩ですかな？",
        "unit_id": 191411
    },
