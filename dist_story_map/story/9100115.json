    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "クレジッタ・キャッシュ……！",
        "unit_id": 191411,
        "voice": "vo_adv_9100115_010"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n薄汚い女商人め、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "貴様さえあのとき始末しておけば……！",
        "unit_id": 191411
