        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "おーっほっほっほ♪　",
        "unit_id": 118011,
        "voice": "vo_adv_9100115_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "礼を申し上げますわクソ議長どの♪",
        "unit_id": 118011
