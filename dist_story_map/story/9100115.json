    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "貴方が仕向けた刺客から救っていただくことで、",
