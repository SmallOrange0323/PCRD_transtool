[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊緒接受了自己體內的力量之後，過了一陣子──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n月光學院一如往常地在和睦的氣氛中上課。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "──因此，",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這個問題的答案是……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "35喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家明白了嗎～？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "聽不懂，",
        "unit_id": 211,
        "voice": "vo_adv_1190004_001"
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "不過讀書還真有趣～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊哈哈，",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣啊～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那直到妳聽懂為止，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師都會慢慢教導妳喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼～",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "下一個問題是……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "欸～",
        "unit_id": 211,
        "voice": "vo_adv_1190004_004"
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "課已經上完了嗎？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "\n好想多聽伊緒上課哦～",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一直唸書會累哦。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n適時轉換心情是很重要的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好好休息過後，",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "下次上課會教大家更多東西。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "麼",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "課先上到這裡。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "接下來是午休時間囉！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "好～",
        "unit_id": 211,
        "voice": "vo_adv_1190004_007"
    },
    {
        "type": "dialogue",
        "name": "學生1",
        "words": "那我到中庭去玩！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "學生2",
        "words": "我也要去～",
        "unit_id": 415,
        "voice": "vo_adv_1190004_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "盡情地去玩吧。",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但要小心",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "別受傷了哦～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}，",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你午休想做什麼呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你要睡午覺嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "養足精神面對下午的課程也不錯。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀……",
        "unit_id": 101811,
        "voice": "vo_adv_1190004_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好溫暖的光哦……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "討厭，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也覺得愛睏了……",
        "unit_id": 101811
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你好。",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我是你的班導師支倉。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我突然決定來做個家庭訪問。",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n可以讓我進去嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "打擾了。",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我記得你父母都出差去了，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在是一個人住，對嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然這是你父母的房子，",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我還是第一次",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來到",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一個人生活的男生住的地方。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哇～",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看來你有在認真打掃……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "喂～",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "內褲怎麼直接丟在地上呢？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不可以脫了就隨手丟呀。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要放進洗衣機去才對。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你呀……",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "最近果然有點散漫呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "時間寶貴，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "馬上開始家庭訪問吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我想談談你的成績。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你最近",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "成績是不是下滑了？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "之前的期中考",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "排名也掉了很多……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這讓我有點擔心，",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以我今天才會來這裡找你。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且，",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你一個人住也讓我不太放心。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你還只是高中生，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "家事也全都要一個人做，肯定很辛苦吧？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "飯有好好吃嗎？",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n洗澡的時候",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有沒有用浴缸好好泡澡？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還有……",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你枕頭下的書是什麼呢……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是不是",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "參考書呢？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n看來你有在認真唸書。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真了不起！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看看……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "～～～～！？",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這、",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這是黃色書刊……！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你把這種書放在",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "枕頭底下……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這是",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為什麼呢……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣啊，",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是人家借你的……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒想到你會看這種書……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和你給人的印象差很多……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我不是很懂男生的事情……",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不過",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我既然是老師，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看來有必要和你講清楚……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我平常是不太會罵學生的……",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但我這次要狠下心",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好好訓話了！　",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咳咳……",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你畢竟是青春期的男孩子，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n而且又一個人住……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是！",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這不能當作藉口！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n要看這種書是沒關係，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但你該唸的書還是要唸。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你明白嗎？",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_033"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個時期對你很重要。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n雖然你現在才二年級，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過很快就要畢業了！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你可能還沒有決定畢業後的方向，",
        "unit_id": 101831,
        "voice": "vo_adv_1190004_034"
