[
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說回來克蘿依學姐，",
        "unit_id": 116311,
        "voice": "vo_adv_5064602_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n聖學祭那天午休的時候妳跑去哪裡了啊？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211,
        "voice": "vo_adv_5064602_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對耶，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "跑去哪裡了啊～",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那妳們呢？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "為什麼要用問題來回答問題啊？",
        "unit_id": 116311,
        "voice": "vo_adv_5064602_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒什麼，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒就只是和",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "美衣子她們",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "吃了頓吵吵鬧鬧的午餐而已。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我在中庭",
        "unit_id": 116411,
        "voice": "vo_adv_5064602_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "躺在羅塞塔的大腿上打了段吵吵鬧鬧的瞌睡。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依是跟誰一起吵吵鬧鬧的呢？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我……",
        "unit_id": 116211,
        "voice": "vo_adv_5064602_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我家人有來嘛。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n所以就會合然後吵吵鬧鬧地吃了便當，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就這樣。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就很",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "普通啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然說很普通，",
        "unit_id": 116311,
        "voice": "vo_adv_5064602_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但回答得很不自然呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真奇怪……",
        "unit_id": 116411,
        "voice": "vo_adv_5064602_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真的是普通的嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～",
        "unit_id": 116211,
        "voice": "vo_adv_5064602_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我想起來了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這麼說來",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "{player}好像也在一起的樣子。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 116311,
        "voice": "vo_adv_5064602_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在和樂融融的天倫之樂時，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n有那種特別來賓參加居然還會忘記？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那會說是普通嗎……",
        "unit_id": 116411,
        "voice": "vo_adv_5064602_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳給我差不多一點哦，克蘿依……",
        "unit_id": 116411
    }
]