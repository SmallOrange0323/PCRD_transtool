[
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵、呵呵呵！　",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n哈哈哈、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈哈哈哈哈……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真快樂啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蒂亞娜！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那令人憐愛的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的公主啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我們再繼續互相殘殺吧，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓禮服沾滿血跡狂舞到天明吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "互相傷害，濺出火花，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n互相啃噬，萌發愛情！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "傾聽人民的請求，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就是妳們的天命！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可別跟我說妳已經累了唷，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可是一點都還沒滿足啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即使午夜十二點的鐘聲響起，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "舞會也不會結束！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n來，請容我牽起妳的手，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "美麗的公主！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳就拚命揮舞妳的劍，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來抹殺掉我的無聊吧……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呀咿～！？",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個人實在有夠煩的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是怎樣，一直追在人家的背後～！？",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n天色都已經，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全暗下來了哦！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}他們，",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一定因為我一直都沒有回去，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而感到相當擔心吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是太對不起大家了～",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是事先準備好跟大家聯絡的方法就好了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這種事態發展，",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也無法預測到，所以也是無可奈何的事呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟，怎麼樣也想不到",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n自己會被奇怪的人一直追著跑嘛。",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼啦怎麼啦，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有心事嗎？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n已經累了嗎？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要不要休息一下？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拜託妳，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再加油一下好嗎！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我命運的戀人啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好不容易才遇到妳的呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "起舞吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可愛的可愛的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蒂亞娜公主……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔～？",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個人到底是怎樣啊？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她好像知道我的『本名』耶～",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就這件事來說，雖然是讓人有點開心啦？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟大家好像都忘了我的事情了。",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論是父親、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "母親……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有其他的所有人。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然很想好好地問問她這件事情。",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但那個人，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺一點都不想跟我對話的樣子對吧！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼辦才好呢～。",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不知道為什麼，我的攻擊好像都打不中那個人的樣子。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺是用某種很狡猾的超自然方式在閃避攻擊。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟她戰鬥也只是徒勞無功呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且不知為何，那些大鬧的魔物們",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像四散開來跑走了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【伊麗莎白牧場】應該，\n也都平安無事了才對。",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我已經完成了我的職責。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟我的目的是解決掉",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n操控魔物的幕後黑手，拯救牧場。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以啊，老實說我好想趕快回去唷～……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就時機點來思考的話，",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "操控魔物的人……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會是現在追著我的那個人嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是她看起來，\n不太像是擅長使用那種魔法的人耶？　",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n唔～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身體能力看起來挺優秀的，",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且在閃避攻擊及被擊中時感覺也不太自然……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不知道她是不是什麼『特別的存在』。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像奪走我一切的",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n『那個男人』一樣。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也因為這點。",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓我蠻想跟那個一直追著我的人，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好好地促膝長談一番呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟應該也是個人類嘛～",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n『殺掉之後吃掉』的話就太可憐了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼做呢？",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖說為了逃跑，已經將『皇家裝備』",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n調整為低輸出，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但還是保持著隨時都可發動的狀態。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚、肚子開始餓了起來。",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再這樣下去，狀況會變得越來越糟的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……唔？",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蒂亞娜！　",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n剛才妳有沒有聽到什麼聲音？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n很像是地鳴一樣的聲音？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼？　",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這麼說起來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像是有什麼東西爆炸了的那種聲音！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是說，",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳突然這麼正常地跟我說話，害我嚇了一大跳啦！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們現在正在戰鬥吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n太好了太好了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳還知道我們現在正在戰鬥呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像妳這樣逃跑，也是某種作戰對吧？",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實在是太棒了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n再讓我多享受一點！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊嗚～……",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在這種深山裡發生爆炸實在太不自然了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可能是某種人為災害，或是某種事故。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以，",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "過去看看嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果有人受傷的話，我想幫幫他們。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈，妳還真是善良！　",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沒問題唷，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要暫時停戰也可以！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "傳來爆炸聲的那方向，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "本來就是我的目的地……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就是那個叫什麼【拉比林斯】的祕密基地的方向",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有點在意呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n姑且還是，過去看看狀況比較好吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或許是注意到基地位置被人給發現了……",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n為了消滅證據，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n刻意把基地給炸掉，從那撤退也說不定。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果是這樣，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事情就麻煩了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我收到的命令是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要把【拉比林斯】的人給活捉回去說。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【拉比林斯】畢竟是個祕密社團，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n應該很擅長逃跑跟藏匿。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是好不容易才找到的基地被他們給放棄的話，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n應該又會躲藏得無影無蹤吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，既然都決定了就趕快出發吧，蒂亞娜！　",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我們可以手牽著手，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像小鳥一樣唱著歌過去吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "等事情都辦完之後，",
        "unit_id": 107111,
        "voice": "vo_adv_2005002_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就要再來互相殘殺唷！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n啊哈哈哈……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚～……",
        "unit_id": 105811,
        "voice": "vo_adv_2005002_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快來人救救我啊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我被一個怪怪的女生給纏住了啦～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n拜、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拜託妳饒了我好嗎～？",
        "unit_id": 105811
    }
]