    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對！",
        "unit_id": 105812,
        "voice": "vo_adv_9008001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天把大家都找來這裡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是想請你們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "協助當「廣播節目主播」！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然一秒就答應了……",
        "unit_id": 106012,
        "voice": "vo_adv_9008001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你真的是有聽懂要做什麼才回答的嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這看上去就是沒有懂啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_9008001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "廣播……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "據在下所知，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應為一種通訊魔法。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只不過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「結木煮播」……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是不太耳熟的詞彙了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽上去似乎不太像食物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問是什麼樣的東西呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105812,
        "voice": "vo_adv_9008001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳問得很好！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "廣播是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能將聲音傳遍廣範圍區域的通訊魔法。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而負責透過廣播將資訊傳遞出去的人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "便是「廣播節目主播」。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實……",
        "unit_id": 105812,
        "voice": "vo_adv_9008001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從前陣子開始，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "王宮和公會管理協會就已經",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在合作進行讓「國營廣播」問世的準備囉♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "直到最近",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總算是準備完成了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "平時能",
        "unit_id": 105812,
        "voice": "vo_adv_9008001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "介紹蘭德索爾的各種新聞和美食，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n遇上緊急情況時",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "甚至還可以用來廣播避難情報，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼萬能的通訊魔法……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
