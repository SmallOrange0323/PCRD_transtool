[
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七七香，獨自一人前往熟識的雜貨店――"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喵哈囉――！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你好啊――！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "哦哦，",
        "unit_id": 1411,
        "voice": "vo_adv_5008003_001"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "這不是「收藏家」嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "竟然會來到這種邊境。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那當然啊！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只要聽說有特別的珍品，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n二話不說立刻發動特攻就是我的個性啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "哈哈，",
        "unit_id": 1411,
        "voice": "vo_adv_5008003_003"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "的確沒錯。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "這麼說，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "妳想要的就是從洞窟發掘出來的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "古文書吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然。　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "東西就在這裡吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "還是老樣子，消息真靈通。",
        "unit_id": 1411,
        "voice": "vo_adv_5008003_005"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "真了不起。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "但是……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "很遺憾，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "這次只能請妳放棄了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦～！！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼為什麼！？　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒道理啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "理由！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "給我詳細的理由！！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "已經被人買走了呢。",
        "unit_id": 1411,
        "voice": "vo_adv_5008003_007"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "一本也沒留下來。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "都被住在王都的某個貴族大人全部買下來了。",
        "unit_id": 1411,
        "voice": "vo_adv_5008003_008"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n而且是我們用盡全財產也無法觸及的高價買下的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說全部買下來了！？",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "打擾了。",
        "unit_id": 2511,
        "voice": "vo_adv_5008003_010"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "才說到他，那個貴族大人就來了。",
        "unit_id": 1411,
        "voice": "vo_adv_5008003_011"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "……歡迎光臨！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是這個人！？　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好啊――絕佳的好機會來了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你好，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那邊的旅人。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "請問找我有什麼事嗎？",
        "unit_id": 2511,
        "voice": "vo_adv_5008003_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個～",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的目標是成為魔法少女，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n聽說溪谷洞窟挖掘出古文書～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n所以希望至少可以得到一本就好了～♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "……",
        "unit_id": 2511,
        "voice": "vo_adv_5008003_015"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "既然是以魔法少女為目標，",
        "unit_id": 2511,
        "voice": "vo_adv_5008003_016"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那放棄古文書，\n將身心奉獻在魔法修鍊上如何？　",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "失禮了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真、",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是華麗的無視！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這就是貴族與生俱來的特技嗎……！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "店長，",
        "unit_id": 2511,
        "voice": "vo_adv_5008003_018"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我拜託的東西送來了嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "是，",
        "unit_id": 1411,
        "voice": "vo_adv_5008003_019"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "就在這裡。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "請看。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個是……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "古代文字的解讀書？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n為什麼貴族大人要親自去買那種書？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "……",
        "unit_id": 2511,
        "voice": "vo_adv_5008003_021"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "嗯，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "很好。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "感謝。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n這裡是費用",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "和我的一點心意。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "希望你能收下。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "哎呀哎呀……！　",
        "unit_id": 1411,
        "voice": "vo_adv_5008003_022"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "非常感謝您！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n請務必再次光臨！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那麼，先失陪了。",
        "unit_id": 2511,
        "voice": "vo_adv_5008003_023"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "小姐也是，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "再會。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總覺得剛才",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從那位高貴人士的視線裡，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n感受到了討厭的氣息……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是為什麼呢？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "算了無所謂。",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉呀，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是白忙了啊。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我要不要也和杏奈美眉一起去打工算了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是已經和流夏姐約好要會合了，",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就這麼辦吧。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n畢竟杏奈美眉也說過打工完會過去啊。",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只要沿著這條路前進就行了吧，",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我記得。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "出發吧——",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "喂，小姐。",
        "unit_id": 1011,
        "voice": "vo_adv_5008003_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊～啊，",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不曉得要走多久才會到～。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "希望不會太遠～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "喂，",
        "unit_id": 1011,
        "voice": "vo_adv_5008003_030"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "妳沒聽到嗎！？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "…………話說回來，",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我要怎麼把抵押的老婆們贖回來呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然我不是杏奈美眉，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但要是哪裡有個通緝犯就好了～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "喂！　",
        "unit_id": 1011,
        "voice": "vo_adv_5008003_032"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "妳絕對有聽到吧！！　",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "我不是叫妳站住嗎！！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "香蕉堵住耳朵了，聽不到啦～！",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼哼！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我在這～裡～唷～！！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "別想跑！　",
        "unit_id": 1011,
        "voice": "vo_adv_5008003_034"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "把弓箭帶著跟上來！！",
        "unit_id": 1011
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過是弓箭怎麼可能對我這個大魔法師七七香……",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "欸，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這人數也太多了！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "弓箭數目也太多了！！",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哇哇哇！！",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且還是瞄準頭，也太拼命了吧！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "噫呀！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇哇哇！！？？",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "――噫呀啊啊啊！！",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "救命啊啊啊啊啊啊！！？？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "――就讓我來幫妳一把吧。",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_038"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "才想說這哀號聲似曾聽過，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來是七七香啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流流，",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏姐～！！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "HELPHELPHELP～！！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "又多一個人了！　",
        "unit_id": 1011,
        "voice": "vo_adv_5008003_040"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "全員射擊！！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "七七香！　",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_041"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "借用妳的魔法！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "複製！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "附魔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "風嗎？　",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_043"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "正好呢！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喝啊！！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "全部都被吹走了！？　",
        "unit_id": 1011,
        "voice": "vo_adv_5008003_044"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "怎麼可能！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了，",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_045"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "已經結束了嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼接下來要把你們全部吹飛，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒關係吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "這，",
        "unit_id": 1011,
        "voice": "vo_adv_5008003_046"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "這傢伙……！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "\n撤、撤退！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "回去重整態勢！！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "活該～活該～！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_047"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "別再來了啦～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀～",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_048"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是危險～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏姐真的很謝謝妳！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "愛妳喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "突然就被人包圍，",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_049"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我還以為是\n魔法使七七香的攝影會要開始了呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "結果卻突然降下箭矢之雨！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那真是不得了呢。",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n妳得到妳說過的古文書了嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯。",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_051"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個啊，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "被奇怪的貴族男性給獨占了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "貴族男性？",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_052"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯。",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_053"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感覺很高傲不討人喜歡。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我在要去買書的雜貨店遇到他的。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後，",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_054"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就在離開店的時候，正如妳所見被人襲擊了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n奇怪？　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我為什麼會被襲擊？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳和那個男人說過話了嗎？",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_055"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個啊～",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_056"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我有和他說希望他能把在溪谷洞窟\n發掘的古文書讓給我，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是被華麗地無視了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊。",
        "unit_id": 101311,
        "voice": "vo_adv_5008003_057"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼說來，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個貴族好像有盯著我看耶……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這該不會是那傢伙指使的！？　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不會吧！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "溪谷洞窟……",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_058"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "果然，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那裡就是所有事情的根源呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "七七香。",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_059"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這是比想像中還大的事件。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n利用通訊魔法",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "聯絡深月和惠理子。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "聯絡完畢後，",
        "unit_id": 105611,
        "voice": "vo_adv_5008003_060"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就去洞窟看看吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我很擔心她們倆人！",
        "unit_id": 105611
    }
]