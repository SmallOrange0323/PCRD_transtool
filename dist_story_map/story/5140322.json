[
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「一對一＜單挑＞」也差不多膩了呢……？",
        "unit_id": 18211,
        "voice": "vo_adv_5140322_000"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "很好～",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "接下來就由敵我雙方「全體＜大家＞」和樂融融地，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n進行地獄的火焰死鬥吧…",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "…！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「廝殺＜宴會＞」的時刻開始了！",
        "unit_id": 18211,
        "voice": "vo_adv_5140322_001"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "呀～哈哈哈哈……！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像出現了",
        "unit_id": 110911,
        "voice": "vo_adv_5140322_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "很誇張的氣場！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好熱！",
        "unit_id": 110811,
        "voice": "vo_adv_5140322_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是什麼，好熱！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是……！",
        "unit_id": 111011,
        "voice": "vo_adv_5140322_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會影響廣域範圍的特殊力場嗎！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "糟糕……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在場的所有人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "體力和恢復力都會大幅降低。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可惡的瘋狂聖女，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "竟然把我們捲入這場麻煩的遊戲中。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "哼呵呵……",
        "unit_id": 18211,
        "voice": "vo_adv_5140322_005"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n是哪邊會先倒下呢……",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "接下來要比「忍耐＜毅力＞」了！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦……",
        "unit_id": 110811,
        "voice": "vo_adv_5140322_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我是能理解她讓我們陷入不利的狀況，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n但那個人為什麼要刻意對自己也用同樣的限制玩法呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "天曉得呢，",
        "unit_id": 111011,
        "voice": "vo_adv_5140322_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "誰知道戰鬥狂在想什麼。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然她看起來那樣子，",
        "unit_id": 110911,
        "voice": "vo_adv_5140322_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但本性意外地是個超級被虐狂嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "才不是呢，蠢蛋，",
        "unit_id": 18211,
        "voice": "vo_adv_5140322_009"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "這叫做「背水一戰」。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "很「愉悅＜有趣＞」吧？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n削減彼此的「毅力＜性命＞」，互相「激戰＜衝撞＞」！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_5140322_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "錯不了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "完全就是超級被虐狂。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "就說不是了，",
        "unit_id": 18211,
        "voice": "vo_adv_5140322_011"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "妳們幾個！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然妳這樣說……",
        "unit_id": 111011,
        "voice": "vo_adv_5140322_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但以透過腦內物質所帶來的亢奮感為目的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n刻意讓自己的身心受到外部刺激的這種想法，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n正是被虐愛好者的行為喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣只能診斷出是超級被虐狂。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "啊啊！？",
        "unit_id": 18211,
        "voice": "vo_adv_5140322_013"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n或許是那樣沒錯，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "不過啊，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "小官充其量只是個不超級的普通被虐狂啊！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "她發火了。",
        "unit_id": 110911,
        "voice": "vo_adv_5140322_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個人禁不起捉弄呢，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "明明是超級被虐狂的說。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "混帳，揍妳喔！",
        "unit_id": 18211,
        "voice": "vo_adv_5140322_015"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "就說不要加上超級兩個字了！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是",
        "unit_id": 110811,
        "voice": "vo_adv_5140322_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是，很抱歉，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那就是稍微被虐狂呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "也不是稍微，",
        "unit_id": 18211,
        "voice": "vo_adv_5140322_017"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "只是普通的被虐狂！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "可惡，給小官記得不多不少啊！？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼奇怪的自尊心啊……",
        "unit_id": 110811,
        "voice": "vo_adv_5140322_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n怎樣都好啦……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好了，琪愛兒，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要開始囉～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好～！",
        "unit_id": 110911,
        "voice": "vo_adv_5140322_019"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n好朋友社，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "稍微使出點力上吧！",
        "unit_id": 110911
    }
]