[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和七七香因為定期巡迴\n而來到了鬧區。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "準備好了嗎……",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "少年！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天要來做約好的定期巡迴呦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "厚，",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "累積了好多新作品，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "害我超期待今天的喔～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "即使說",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是為了這個而活也不過份……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦，",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇哇！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這道光是什麼……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該不會是要轉世到異世界之類的──！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從未見過的美少女們在等著我！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "能阻止能力破格像是開外掛的七七香的人是……",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼哼哼～哼！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天會有什麼樣的相遇呢！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔、是你啊──！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真巧呢～",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你在做什麼呀──？",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "散步呀──！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真不錯──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "搞不好走到一半會在街角撞到美少女也說不定！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為撞擊力道而撲倒在她身上，然後被罵「變態」之類的！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但是但是，隔天發現那個女生轉來班上──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嘿嘿嘿……",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真不錯……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔──！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那可真棒──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在室內待久了，偶爾還是會有想呼吸新鮮空氣的時候呢──",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "宅到分不清楚晝夜，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "突然感到一股不安感襲來，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n擔心自己再這樣下去是不是不妙！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是御宅族都會遇到過的感受！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說不定御宅族更需要外出呢！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼說來，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你很閒吧？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就跟我一起去定期巡迴吧！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "{player}隊員，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "快入列──！",
        "unit_id": 101332
    },
    {
        "type": "background",
        "background": "510370"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "姆哈──！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這裡果然是最棒的地方呢──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好想住這裡，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想永遠住在這裡！　",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n好，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就把這裡當營地吧！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天要做……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊──！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "出現了──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇──！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "神滅的巴哈姆提亞的新版動畫廣告！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n簡直是神品質！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太讚了，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這真的太讚了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接、著、是！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莉莉艾利出現啦──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼呼，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗅嗅！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呀呀──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "快看這邊──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看過來了──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "竟然回應了我的祈禱……",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的老天呀！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊啊啊！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "居然用聖光擋住了若隱若現的地方啊──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "快住手！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香生命值歸零啦！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，果然還是不要停下──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再給我多一點──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈呼，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不行了不行了……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莉莉艾利的可愛",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "讓我失去自我了……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為了能與全世界的人一起分享這種可愛，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "得更常讓莉莉艾利出現在主要角色群裡才行……！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呵呵呵，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "辦得到呀～",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "聽了可別嚇一跳！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我的爸爸竟然",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是神巴哈的製作人！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以如果我拼命哀求的話，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "他就會聽我的願望喔！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實之前我也在最終檢查時讓他們重做，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "趕在播出前換了內容！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然對現場的大家很抱歉……",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但這都是為了莉莉艾利……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚嘻嘻……",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莉莉艾利真是太可愛了……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果能當女主角的話……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊啊，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莉莉艾利她……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好尊貴，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太尊貴了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n啊啊，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不行了……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我又，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "又……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莉莉艾利！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛剛失態了真抱歉呀～",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為真的太喜歡莉莉艾利了，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n簡直近乎抓狂。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在已經進入聖人模式，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "已經不會像那樣興奮……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊啊！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "找到阿斯特朗的攻略本了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔──！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "像字典一般！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過嘛，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是不看攻略派的！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n想要",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "靠自己的力量，一邊犯錯一邊學習的玩！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果攻略本上有可以讓魔法師在前線打肉搏戰的方法，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我還真想看看……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過挑戰失敗後再好好思考也滿好玩的！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在阿斯特朗的話，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還能成為我所憧憬的魔法少女！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對現實中只是區區一個御宅族的我來說，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "能化身遊戲世界中的樣子，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "簡直再好不過了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊～！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若那邊才是現實世界就太好了呢！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不只在遊戲中，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而是真正的魔法少女的故事……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼哈！",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妄想又更進一步了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣的話一回家就必須馬上登入才行！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "{player}隊員！今天的定期巡迴就到這裡──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就這樣吧，",
        "unit_id": 101332,
        "voice": "vo_adv_1013004_041"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再在阿斯特朗見喔──！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再會了青春！",
        "unit_id": 101332
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1013004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1013004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過七七香還真是喜歡魔法少女呢──",
        "unit_id": 190011,
        "voice": "vo_adv_1013004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "諷刺的是現在她的夢想實現了……",
        "unit_id": 190011,
        "voice": "vo_adv_1013004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "卻感覺是件殘酷的事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我覺得現在的情境對七七香比較好，",
        "unit_id": 190011,
        "voice": "vo_adv_1013004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但還是不得不面對現實呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為施在魔法少女身上的魔法，",
        "unit_id": 190011,
        "voice": "vo_adv_1013004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總有解開的一天……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說了些無聊的話呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1013004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我只是在自言自語呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不用在意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就先聊到這裡囉。",
        "unit_id": 190011,
        "voice": "vo_adv_1013004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……咦？",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_050"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我怎麼在這種地方睡著了……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好像做了個夢，",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_051"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且好像和你在一起呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_052"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你也是嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈哈～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感覺是命運呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該不會是前世的記憶之類的！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_053"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該是杏奈美眉會喜歡的情節呢──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯──",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_054"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "除了和你在一起的部分之外，幾乎不記得夢的內容了，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但記得有出現一個叫莉莉艾利的角色呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明明是第一次聽到的名字，",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_055"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n卻有股非常熟悉的感覺……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跳過細節而言總之，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那孩子，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是我的菜！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊～",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_056"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好想再見她一次啊，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莉莉艾利。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "去找她不就得了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就這麼辦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "被那前所未見的可愛衝擊到……",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_057"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果她正在這城裡沉眠著，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我得立刻找到她，給她滿滿的愛才行！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好，",
        "unit_id": 101311,
        "voice": "vo_adv_1013004_058"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就這麼決定了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天的定期巡迴就決定要用來找莉莉艾利了～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "撇開傳說中的魔導書，轉而開始尋找傳說中的莉莉艾利，\n兩人在城裡四處走動著。"
    }
]