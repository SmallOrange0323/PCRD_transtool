[
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在恢復了和平的牧場中，公會成員各自做著自己的工作，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鈴則是滿足地享受著懶散的生活。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼～",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是和平呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "邊享受和平邊吃著的橡子，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "特別好吃呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然前陣子",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "多虧了媽媽給我的鎧甲，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "讓我碰巧大顯身手了一番，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我果然還是一點都不想戰鬥啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不需要穿上鎧甲，正是和平的證明，",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今後你就成為房間裡的裝飾品",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來渡過你的後半生吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎喲！",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嚇我一大跳……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我說你啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就算對象是我，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也至少敲個門嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是松鼠耶？",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是小動物耶？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我很纖細的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要小心謹慎地對待我啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不，你聽我說話啦。",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "到底是有多我行我素啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你這個人。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那封信是從哪寄來的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這不是【哞哞自衛隊】寄來的嗎。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔哇～",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好不想打開來看……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "信上絕對沒有寫什麼好事啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我看看……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "工作委託！？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼是找我！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔啊～",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "別開玩笑了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那次只有真陽她們很努力，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我完全沒做什麼大事啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "討厭啦討厭啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好不容易恢復了和平的日常生活，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就不要再煩我了啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果你真的這麼覺得，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那你真的是有眼無珠耶。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n塞個橡子進去吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這、",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這我是知道啦……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是可是，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不想工作啦～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚，",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "去了也是地獄，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不去也是地獄，根本無處可逃嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太過分了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是有做什麼壞事嗎！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……話說你",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼從剛才開始就一直盯著我的鎧甲看啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不、",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不是啦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個現在就只是個室內裝飾品……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "連說明都好麻煩！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要是偷懶的話又會被要求去訓練，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是趕快去把事情處理掉好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對了，",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "機會難得，就穿著鎧甲去吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這樣就算任務失敗了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也可能會被評價說我有心想要做事呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "希望這次",
        "unit_id": 102611,
        "voice": "vo_adv_1127001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的是我最後一次穿這套盔甲了。",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我看看，",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "工作內容是要救出遇難者對吧。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "幸好不是要打倒魔物之類的～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "姑且還算是有派給我比較擅長的任務，",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但她們搞錯貼心的方式了吧。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了，",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "既然都有困擾的人在，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就趕快出發吧～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}，你要好好跟上喔。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼，",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "又黑，路又難走，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是個麻煩的森林。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對我這個松鼠獸人而言不算什麼。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來來，",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "小心不要走丟或跌倒了喔。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可別造成救難者遇難這種麻煩的情況了。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這點程度",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "每個獸人都辦得到啦。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "比起稱讚，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我更想要紅豆麵包呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯？",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有一股氣息呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不是動物也不是魔物的氣息……",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在那邊！",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "找到了找到了。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喂～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒事嗎～？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "遇難者1",
        "words": "太好了，",
        "unit_id": 311,
        "voice": "vo_adv_1127001_025"
    },
    {
        "type": "dialogue",
        "name": "遇難者1",
        "words": "有人來救我們了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遇難者1",
        "words": "得救了～",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遇難者2",
        "words": "真是抱歉，",
        "unit_id": 1411,
        "voice": "vo_adv_1127001_026"
    },
    {
        "type": "dialogue",
        "name": "遇難者2",
        "words": "我們在採蘑菇的時候不小心迷路了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是是是，",
        "unit_id": 112711,
        "voice": "vo_adv_1127001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "別說了我們趕快回去吧。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再拖拖拉拉下去",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "魔物就要來了──",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看吧我才剛說就來了！",
