    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "最初はペコリーヌが食べたいだけなんじゃって\n思ってたけど、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "捕まえられたら本当に一攫千金も夢じゃないわよね？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n一千万ルピって言ってたけど……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "ふふっ、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "なにに使おうかしら？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "いいこと言うじゃない♪　",
        "unit_id": 106012,
        "voice": "vo_adv_6056302_001"
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "一千万ルピも使えるんだったら、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n十段重ねの超豪華おせちだっていくらでも頼めちゃうわよね。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "……まぁ、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "ペコリーヌがほとんど食べちゃいそうだけど……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "うっ……",
        "unit_id": 106012,
        "voice": "vo_adv_6056302_002"
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "確かに貯金も大事よね……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\nあんたってぼんやりしてるように見えて、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\nたまーにすごく納得のいくこと言うわよね……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "一千万ルピがあったら",
        "unit_id": 106012,
        "voice": "vo_adv_6056302_003"
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "どんな秘境にだって旅行できちゃうわ……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "って、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
