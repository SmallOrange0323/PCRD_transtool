[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼嚕、呼嚕……♪",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯嗯，哥哥～……欸嘿嘿♪",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯……？",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼嚕、呼嚕……♪",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（……嗯嗯？",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n咦，這是什麼情況？）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（我睡著了……？",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "居然在戶外睡著，我實在太不小心了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一時不注意，終身抱酒瓶！）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（啊～……",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為我一直在縫製的圍裙總算做好了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我是要拿過來給會長吧。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（然後順利親手交給會長，看會長很開心，我就放心了。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為一下子鬆懈下來，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n加上我努力熬夜縫製圍裙，睡眠不足加上疲勞積累。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（我正想休息一下，結果一坐到廣場的板凳上，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就這樣睡著了吧。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（我這樣不行呢，要更小心一點才行。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n聽說蘭德索爾最近的治安不太好。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要睡覺的話就得好好回到家後再睡才行。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（啊，可是我好想睡……",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "辛苦做圍裙，也因此有了許多感慨。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（我真是做了一件非常不錯的圍裙呢。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我的成就感與滿足感都達到最高點，真暢快～♪）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（啊，再讓我睡一會……",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想繼續在幸福的夢境中迷迷糊糊地睡下去……♪）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（嗯？",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n咦，感覺好像有人在摸我的頭……？）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（而且總覺得非常溫暖……？）",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……咦、咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦咦咦？\n哥哥？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為為為、為什麼哥哥會讓我枕著大腿睡？",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不，那個，我是很開心，可是就這樣在大庭廣眾下！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們好像笨蛋情侶！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？哥哥是看到我在長椅上打瞌睡，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n而且看起來睡得很不舒服，所以才讓我睡在哥哥的大腿上嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "託哥哥的福，我的確睡了一個舒服的好覺？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我不會說哥哥多管閒事，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過哥哥叫醒我就好了喔？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、我覺得好丟臉！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我要起來了喔！",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得給哥哥添麻煩了，對不起！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇喔！？我剛睡醒還站不太穩，又倒下去了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而且又是倒在哥哥的大腿上！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥的大腿是那個嗎，會吸引我的陷阱還是什麼的？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔～……哥哥說不覺得麻煩，所以我可以再睡一會？",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也想順著哥哥的好意再睡一下，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為我真的很累又很睏，啊哈哈♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔？",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥也覺得讓我枕著大腿睡，會變得很平靜嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "應該是吧，因為我以前就常像這樣對哥哥撒嬌。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥即使失去了記憶，但身體還是記得的吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這讓我覺得有點開心。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的，哥哥可能忘記了吧。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "打從我還很小的時候，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我就常像這樣頻繁地對哥哥撒嬌了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我的母親是一位繪本作家，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當時她剛好在畫一部非常暢銷的作品……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "她為了畫續集非常忙碌，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就把我託給住在附近的哥哥家照顧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我見不到媽媽覺得很寂寞……",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "態度極為傲慢，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "甚至還有段時間都不和哥哥說話的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但哥哥都沒因此受挫，持續地陪我呢。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那時候我是個愛哭鬼，當我為一些無聊小事哭……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥就一直拼命地安慰我。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一直笑著聽我說些沒什麼邏輯的話……",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後我在不知不覺中平靜下來，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n漸漸就把哥哥當成有如真正的家人了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我才會像這樣……",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "開始稱呼你為哥哥的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在那之後也是，我沒事就去待在哥哥家裡，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n親近哥哥，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n開始和哥哥聊些芝麻小事。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在遇到哥哥前，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我可以說是個性格畏縮消極的孩子。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥不管什麼話題都聽得津津有味，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n讓我很開心。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我才會變成現在這樣",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n說話有如連珠炮喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n啊哈哈☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……我很感謝哥哥。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "多虧哥哥把我培育成這麼開朗的個性，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我交到了許多朋友呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥拓展了我的世界，讓我的世界閃閃發光喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然哥哥不知道是不是因為失去記憶的關係，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n變得很沉默寡言，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但我希望有一天，哥哥能像以前一樣有精神地說話。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我會不客氣地向哥哥搭話喔。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥就沉浸在我的大量會話裡，藉此吸收累積……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如果哥哥也變得能和我多多聊天，就萬萬歲了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會說許多雞毛蒜皮的事喔。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥只要偶爾回應一下就可以了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只是一直默默地聽我說也沒關係。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為光是這樣，我就有得救了的感覺。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我因為父母工作的關係，搬到離這裡有點遠的地方……",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就在我想著總算搬回來了的時候，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥卻完全變了一個人。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當時我的眼前有如一片黑暗，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過哥哥果然還是哥哥。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥是一個溫柔到無法放任我在戶外睡得毫無防備，",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_042"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n讓我枕著大腿睡的人。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我最喜歡這樣的哥哥了。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我可以像這樣再和哥哥見面聊天，真的很開心。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只有這一點請哥哥要了解。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈，哥哥一臉搞不懂的表情。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n真抱歉，我只會說些邏輯不通的話，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過哥哥果然還是很老實地聽我說完了呢♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哎呀，時間已經不早了，我先就此告退了喔。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_045"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥也最好快點回家。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n今天屢次受哥哥諸多照顧了♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們下次再見吧。",
        "unit_id": 101112,
        "voice": "vo_adv_1011007_046"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不，我們要多多聊天喔……哥哥♪",
        "unit_id": 101112
    }
]