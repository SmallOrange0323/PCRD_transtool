[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "鬼屋……",
        "unit_id": 113911,
        "voice": "vo_adv_6050106_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "鬼屋啊……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一開始思考就覺得萬事皆難呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你有什麼想法嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以說為此該怎麼做啦……",
        "unit_id": 113911,
        "voice": "vo_adv_6050106_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但說得也是，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這也很重要呢，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因為首先得要累積經驗嘛。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過招攬客人",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n可是騎士先生的工作喔？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你的責任重大，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請好好加油喔。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所謂的鬼屋，基本上是禁止直接接觸的吧？",
        "unit_id": 113911,
        "voice": "vo_adv_6050106_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是如果，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能對怜大人可以做出這種事或那種事……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不行呢，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n可想而知一定會被發現然後挨罵的。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這、",
        "unit_id": 113911,
        "voice": "vo_adv_6050106_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這想法意外地很粗暴呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n咦？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "用蒟蒻碰臉頰？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣啊……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這意見先留下來當候補吧！",
        "unit_id": 113911
    }
]