[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看來這一次，很和平呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然安心了不少。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但畢竟上次幾乎像是腰斬漫畫的最終回一樣了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n突然來這樣的急轉彎好像也過於極端了點呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，在你不知道的地方……",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可說是發生了相當重要的相遇，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還有些驚為天人的新展開呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的周遭較為和平有理由的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "似乎，身為你那頭號敵人的尤絲蒂亞娜……",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在上一次，因為施放了大量破壞魔法的關係，現在魔力已經見底了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而在恢復完成之前，她將不能隨意行動呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但同時間【拉比林斯】的領袖，拉比林斯達也成了意識不明的狀態……",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不管是敵方還我方的核心人物，都陷入無法動彈的膠著狀況呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎像是冷戰一般互相大眼瞪小眼的情況唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管如此，也不能夠就此大意喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該要趁敵方無法行動之際，盡量為接下來的發展提前做準備喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總而言之。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這一次的事件中最重要的核心內容，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n正是貪吃佩可她的真面目了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是啊，我也是第一次聽到所以嚇了一跳呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總覺得像是個和世俗脫了節的怪孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n沒想到竟然真是位公主殿下呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，姑且說一聲，這可是事實唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她毫無疑問的，是一位真正的公主呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然聽起來有一點像開玩笑，但現實總是比故事還離奇嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但現在貪吃佩可的身分，",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻被尤絲蒂亞娜給奪走了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然也還不清楚究竟他是用了什麼手段，",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n才會演變成這樣的狀態就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "過去的尤絲蒂亞娜，",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n將世界的法則……之類的東西給玩弄於鼓掌間，也做了不少壞事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n當然也有奪取過他人身分之類的事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一次，估計也是作了同樣的事吧。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若想顛覆這個狀態，並奪回貪吃佩可的地位，",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼就需要獲得與敵人同等級的，可說是神一般的力量協助呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "實際上，對方也就是用著超脫常識的神秘能力啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "濫用著那除了神明以外不可能辦到的奇蹟，",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n尤絲蒂亞娜可說是肆意妄為想幹嘛就幹嘛了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若要阻止他的野心，你也必須取得那同等的神力才行唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而這世界的神，名字為『七冠』。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因此在今後，你該要去找尋並且與『七冠』接觸，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並且試著將他們納入自己的夥伴之中唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從當前來看，你與好幾位『七冠』照過面呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n若只是要與之接觸，並不是什麼難事才對唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛……",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n敵人當然會覺得那與自己同格的『七冠』相當礙眼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而因此有所動作吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會想用大量破壞魔法一次把『七冠』給斬草除根，",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n大概也是因為如此吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那次慘烈的攻擊現場中，也有幾位是『七冠』喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他們因種種的因素，看來現在是處於【拉比林斯】的庇護之下呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因此，先想辦法和【拉比林斯】接觸，或許不失為個好主意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有這一次碰巧聽聞、那名為似似花的孩子，也是位『七冠』唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然不知道她的所在處，但應該是存在於這個世界的某個角落呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n若有機會，試著與她接觸吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，在那之前還得先幫忙牧場的復興呢……",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n該做的還是得去做呢，對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你接下來這陣子，得要去幫忙牧場的重建了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油哦。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n幫助他人，是件與你相襯且值得驕傲自豪的工作唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "善待他人，總有一日將會得到回報喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不，應該說這就是你的正義，也是你的強項唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "連失去記憶的你，似乎也沒將這件事給忘記，真是幸運呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2006099_028"
    }
]