        "voice": "vo_adv_5092323_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說的也是呢。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那妳占卜看看",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "財寶要怎麼有效利用吧。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳們兩個，",
