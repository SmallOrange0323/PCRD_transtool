    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可是，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不可思議的是",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我一點都不覺得害怕或緊張。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "霞",
