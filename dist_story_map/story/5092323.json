    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這下有點吃力呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是啊，",
        "unit_id": 121911,
        "voice": "vo_adv_5092323_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不過好久沒有遇到",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
