        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看來到剛剛為止",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "它的力量都有受到限制呢。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "霞",
