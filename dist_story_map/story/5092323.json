        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "既然大家都曉得結果，",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "占卜也沒有意義。",
