        "voice": "vo_adv_5021007_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "難不成想要一起跳舞嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_5021007_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 104311,
        "voice": "vo_adv_5021007_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　搞什麼，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來{player}也在啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這麼多人不跳舞就太可惜啦～♪",
        "unit_id": 101711,
        "voice": "vo_adv_5021007_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好耶～♪",
        "unit_id": 101711,
        "voice": "vo_adv_5021007_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼伴奏就交給真琴負責啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，我根本不會伴奏啊！？",
        "unit_id": 104311,
        "voice": "vo_adv_5021007_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 104311,
        "voice": "vo_adv_5021007_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的要嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　呃、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是拿你沒辦法……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我來伴奏吧～♪",
        "unit_id": 101711,
        "voice": "vo_adv_5021007_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好了好了。",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要跳舞可以，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但在那之前",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家有東西要想送給你們。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "送給我們？",
        "unit_id": 104311,
        "voice": "vo_adv_5021007_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對呀。",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "前陣子",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是給你們添麻煩了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這也是為了平時的感謝之意，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家想送禮物給你們。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔喔……",
        "unit_id": 104311,
        "voice": "vo_adv_5021007_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這是",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "以我為原型的玩偶嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是好可、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃不，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是做得相當出色……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "無敵開心呀～！",
        "unit_id": 101711,
        "voice": "vo_adv_5021007_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "　真步手真靈巧呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看到你們這麼喜歡，人家也好高興。",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "霞也很喜歡的樣子，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有試著做出來真是太好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣好嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_5021007_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　真的可以收下禮物嗎。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們也沒做什麼……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們只是順著自己的想法行動啊～♪",
        "unit_id": 101711,
        "voice": "vo_adv_5021007_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒關係的。",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這裡面可是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家對你們的一番心意。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "心意？",
        "unit_id": 104311,
        "voice": "vo_adv_5021007_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒錯。",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n「人家很重視你們」，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這就是人家的心意。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝妳～真步！",
        "unit_id": 101711,
        "voice": "vo_adv_5021007_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n果然應該要跳舞呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴也一起來跳，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂、",
        "unit_id": 104311,
        "voice": "vo_adv_5021007_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "住手別拉啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好啦、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "知道了知道了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵。",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓您久等了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對不起。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "給您，",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這個是王子先生的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "玩偶。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還有……",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "另一個。",
        "unit_id": 101011
    },
    {
        "type": "still",
        "still": "502100701"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這個",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也願意收下來嗎。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這個是",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家的玩偶。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖說也可以我自己留下來好好地珍惜，",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但果然還是",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "希望能",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "交由某人愛惜呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為您知道的，",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "心意終究會傳達到，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生如果願意珍惜，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家和那孩子",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也一定",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會感到",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很開心呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您願意",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "接受它嗎？",
        "unit_id": 101011
    },
    {
        "type": "still",
        "still": "502100702"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您，",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "等到某一天那孩子也有靈魂時，",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n它一定會",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "替我好好地保護王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "　您說人家沒有自己的玩偶怎麼辦？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "至於這點",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就不必擔心了唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家還有",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這座城堡裡的夥伴們在呀――",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且，保護人家的這個角色，",
        "unit_id": 101011,
        "voice": "vo_adv_5021007_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生會負責擔任不是嗎……♪",
        "unit_id": 101011
    }
]