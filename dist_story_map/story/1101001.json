[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "快進入暑假的月光學院。\n期盼暑假已久十分興奮的學生當中，\n伊緒深深嘆了口氣。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "唉～",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼辦才好呢～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "討厭，",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "被學生看到我嘆氣的樣子！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明明身為老師，",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣很沒形象吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果你能假裝沒看到的話我會很開心的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就像{player}你說的，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實有件事一直困擾著我呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真不知該拜託誰才好……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了！　",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "或許拜託你很適合！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個，",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你周末有空嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n能聽一下我的請求的話……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我身為老師",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "假日跟男同學兩人單獨前往的話……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感覺好像不好呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不，",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這是老師",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為了學生必須做的事，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以沒問題的……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒、",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒什麼！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師的請求，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你願意聽一下嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了，",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "周末跟我一起去海邊吧！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對呀，",
        "unit_id": 101811,
        "voice": "vo_adv_1101001_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我很期待。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "禁止遲到唷。",
        "unit_id": 101811
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "久等了―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不好意思呢，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總算趕上了約定的時間，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但是你有等一下了吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為花時間做了一些準備……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看來你今天沒有遲到呢，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真了不起〜",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n馬上下水嗎？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的呢，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好大好漂亮的海灘呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "話說，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你要去哪裡～？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "給我等等。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n下水之前",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要先做好熱身運動才行！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果不小心腳抽筋溺水那就不好了。",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n假如看到有學生溺水的話，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果你溺水的時候……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我會好好用人工呼吸救你！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "人工呼吸就是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n嘴對嘴",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "把空氣吹進對方身體裡唷。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣做的話，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "溺水已經停止呼吸的人也能恢復呼吸呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖、",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然我沒有接吻的經驗，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但有用急救講習用的人偶練習過，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以我一定可以的……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還、",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還有",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "人工呼吸就只是人工呼吸！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以不能算成初吻唷……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總之，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了不要發生意外，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "跟我一起好好熱身吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一、",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "二……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "三、",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "四……！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看看你。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣完全不對啦。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不好好拉筋的話就不算是完成熱身了唷？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓我好好教你。",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你看，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要這樣做……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼突然臉變紅了？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什麼，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "原來身體已經暖和，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "準備好了呀。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我說，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還不行唷―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "的確已經完成熱身，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是只有這樣還不夠！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "突然跳到海裡的話，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "身體不適應很危險的。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n最糟的狀況，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "心臟還可能突然停止唷？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以，我們首先",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在海濱附近先休閒地玩吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n必須要先讓身體慢慢習慣海水的溫度。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘿～！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看招―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘩啦嘩啦嘩啦―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n呵呵呵，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好冰好舒服唷～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵。",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "差不多已經適應水的溫度，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n那麼，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "進入今天的正題吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看你有點傻住，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼了嗎？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n該不會，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天來海邊的理由，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n都還沒跟你說嗎？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不、",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_033"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不好意思呢！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我呀，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好像能跟你一起來海邊就滿足了呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然有點晚提，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我現在跟你說明唷。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_034"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是馬上就是暑假了嘛？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因此",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我想有很多學生跟家人或朋友一起到海邊",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "遊玩。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_035"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在我的班級當中，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像美咲一樣不會游泳的孩子很多，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以我想在暑假之前教會她們游泳。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_036"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡還有一個問題……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為其實，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_037"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也不會游泳〜！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n請保密不要跟大家說唷〜？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我從小就不擅長游泳，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_038"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n漂浮我還行，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但就是無法前進……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以學生時代很少和朋友一起來海邊玩。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_039"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我想要練習游泳，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是一個人練習的話會很可怕，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n希望能有人能陪我一起，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以才拜託你。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也就是說，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天就要靠你了――",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_040"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也不會游泳嗎〜！？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "請不要這麼充滿自信地說出來吧〜",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不會游泳也能幫我吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只要確實拉住我的手，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我就可以練習打水呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就麻煩你了唷！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗚嗚～，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_042"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我的腰泡在海裡讓人好緊張唷。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "竟然讓學生陪我練習游泳，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_043"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n跟平常的立場對調，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感覺好奇怪呢〜",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，我要游看看嘍，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_044"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "請不要放手唷？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n開始唷……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘶―……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼嗚―！",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_045"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如何呢？　",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我是不是有游了一小段了呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦―？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_046"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "完全沒有前進嗎―？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "已經長大成人，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "想說會不會自然地就會學會游泳，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "內心一直這樣默默期待的說。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且要為不會游泳的你示範，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_047"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我要努力練習，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在今天學會游泳！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "再來一次吧！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀啊！？",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_048"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊～！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_049"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什麼東西碰到我的腳了～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要―，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "快去別邊―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀呀～，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_050"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為太慌張地不斷動著雙腳，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "結果又被纏上了～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n觸感好滑溜溜～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該不會是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_051"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "海底人搞的鬼吧～？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "把愉快前來海水浴場的旅客的腳一把抓住",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "拖進海裡，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "然後帶回海底城市吃掉嗎―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "喂，拜託。",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_052"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n可以幫我看看水裡的狀況嗎？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊～！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_053"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "快點救我～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_054"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我的腳、",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在如何了呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "海底人表情如何呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_055"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只是被海帶纏住了嗎……？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了～",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_056"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果真的是海底人的話，還在擔心該怎麼辦才好，心跳好快呢……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然知道不太可能是海底人，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_057"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但想說引起危機感的話，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你會趕快來解救我！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊～，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_058"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好像越動反而越被緊緊纏繞呢～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n可以潛進水裡，幫我拿掉嗎？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n已經一步也動彈不得了啦～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗚嗚～，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_059"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "拜託。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n雖然沒有想到會在海中被東西纏住，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但只是海帶的話就安心了～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "話說，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_060"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀―！？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊、",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_061"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哇啊、",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊哈哈哈！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "討厭，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你在摸哪裡啦～？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好、好癢唷～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哇！？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_062"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這次",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好像碰到什麼硬硬的東西了啦～？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_063"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在我的腳碰到的、",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是你的臉嗎！？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該不會，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我踢到你了吧……？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對、",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_064"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對不起！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為好癢，不由得就……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n會不會痛？　",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓老師好好看你的臉？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_065"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好像沒事呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n果然男孩子很強壯呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘿嘿，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_066"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛踢人的氣勢好像已經甩掉海帶了呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天讓你幫忙了。",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_067"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n感覺好像老師跟學生的立場對調了。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_068"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n幹嘛一直盯著我身體看呢？",
        "unit_id": 110111
    },
    {
        "type": "still",
        "still": "110100101"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_069"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該不會身上又有海帶了吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦―，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_070"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在哪兒呢―？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊―，",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_071"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我找不到啦～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一定是在我看不到的地方。",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_072"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為我自己看不到，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能不能再幫我取下呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_073"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為什麼你的手停住了呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛不是才幫我拿掉嗎。",
        "unit_id": 110111,
        "voice": "vo_adv_1101001_074"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要鬧我了啦―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這樣根本沒有辦法練習啦～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "心跳不已的{player}，\n對於今天整天可否維持住體力感到不安。"
    },
    {
        "type": "still",
        "still": "end"
    }
