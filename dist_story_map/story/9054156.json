[
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "糟糕……",
        "unit_id": 106411,
        "voice": "vo_adv_9054156_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓牠逃走了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳有沒有受傷！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106011,
        "voice": "vo_adv_9054156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "勉強算沒事。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我還是要道個謝。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n謝啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們是夥伴，",
        "unit_id": 105911,
        "voice": "vo_adv_9054156_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "理當挺身相救。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 106411,
        "voice": "vo_adv_9054156_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說得沒錯。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很少會看到凱留",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣老實道謝，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n讓我感到好高興呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "少、",
        "unit_id": 106011,
        "voice": "vo_adv_9054156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "少囉嗦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說剛才那魔物是怎樣啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n竟突然撲上來想把我吃掉……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我一定要好好教訓牠！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個魔物",
        "unit_id": 106411,
        "voice": "vo_adv_9054156_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想必就是傳說中",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「與沙塵暴一同出現的惡魔」吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "既然如此，更不能放著不管。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "得想想對策。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論如何，",
        "unit_id": 105911,
        "voice": "vo_adv_9054156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要繼續沙塵暴中探索",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "恐怕過於危險。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "欲速則不達，可不能太心急。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那不然，",
        "unit_id": 105811,
        "voice": "vo_adv_9054156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們找地方紮營，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等沙塵暴過去，如何？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然我是很想立刻追上去，",
        "unit_id": 106011,
        "voice": "vo_adv_9054156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但也只能這麼辦了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，可惡！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我等著瞧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等我逮到那魔物後，就要用魔法把牠做成烤肉！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811,
        "voice": "vo_adv_9054156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嚇我一跳，",
        "unit_id": 106411,
        "voice": "vo_adv_9054156_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留居然會說這種話。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐原本還那麼抗拒的……",
        "unit_id": 105911,
        "voice": "vo_adv_9054156_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來這也是【美食殿堂】冒險的成果呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……？",
        "unit_id": 106011,
        "voice": "vo_adv_9054156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在說什麼啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我剛剛講了什麼奇怪的話嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不怪不怪！",
        "unit_id": 105811,
        "voice": "vo_adv_9054156_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "烤肉啊～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣最能夠嚐到魔物的原汁原味呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也有很多調味料可以用，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以享受各式口味的吃法喔☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸？",
        "unit_id": 106011,
        "voice": "vo_adv_9054156_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "烤肉……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是啦！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不是真的要烤來吃，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是比喻，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比喻啦！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不想吃魔物烤肉呢！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過呀，",
        "unit_id": 105811,
        "voice": "vo_adv_9054156_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拿魔物的瘦肉來慢慢燉，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該也很好吃喔♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到會有這麼一天，\n可以跟小凱留大聊魔物料理，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好高興喔♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳聽人講話啦！",
        "unit_id": 106011,
        "voice": "vo_adv_9054156_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我才沒有要跟妳聊魔物料理～！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……太好了，",
        "unit_id": 106411,
        "voice": "vo_adv_9054156_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "原來是誤會。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我還以為",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留已經踏入了遙不可及的高深境界……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_9054156_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雪菲小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "用不著擔憂太多的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要能悠閒地",
        "unit_id": 105911,
        "voice": "vo_adv_9054156_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一次……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又一次地",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跟大家一起吃飯，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n創造這般幸福的時光，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n相較之下，吃的是什麼料理，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便不是那麼重要了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐……",
        "unit_id": 106411,
        "voice": "vo_adv_9054156_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼說，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，雪菲！",
        "unit_id": 106011,
        "voice": "vo_adv_9054156_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也來勸一下白癡佩可啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳也不想吃魔物料理吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106411,
        "voice": "vo_adv_9054156_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個嘛，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "確實是不想……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……但畢竟",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這也是【美食殿堂】的公會活動之一。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我會盡量不嫌東嫌西，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "努力吃下去的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什……",
        "unit_id": 106011,
        "voice": "vo_adv_9054156_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這個背叛者──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n少在那邊裝乖了──！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……呵呵呵♪",
        "unit_id": 106411,
        "voice": "vo_adv_9054156_024"
    }
]