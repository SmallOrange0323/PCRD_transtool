[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦囉。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "歡迎來到，夢中的世界。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是半買半相送的，幕間的小故事～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開個小玩笑嘛♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "回正題囉。你的故事終於正式展開了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也看到了唷～，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n突然馬車就被炸了，還被奇怪的傢伙們襲擊，真是慘烈呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是說，都可說是被整得慘不忍睹了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但被這麼突然間捲入這些問題，你也還一點也都摸不著頭緒吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以和先前約好的一樣，就由我來加減補充一下囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次，重點在矛依未……",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或是說，那被稱為諾維姆的存在。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這個世界中，這是你與那孩子第一次的相遇呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n與其他女孩子……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鈴莓呀，或是靜流還有真琴她們，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在這故事的結構本質上，有點不同對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但對現在的你來說，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她只像是位不斷說出意味不明台詞的怪孩子就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但那孩子相對於這個世界，可是相當重要的唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那能夠解開這世界之謎的關鍵就握在她的手裡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因此，才會大家都對她這麼感興趣喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而你們只不過就是很不巧的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n捲入了想將她納入囊中的群眾的紛爭之間。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只能說請節哀呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛……主角就是就是得要像這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一天到晚被捲入事件中呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "主人公還真是辛苦呢，{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總而言之。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在這個世界中，存在著謎團唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不。與其說是謎團，也可以稱為謊言也說不定。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是個相當大的謊言……是虛偽、荒謬，又矛盾的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而有個想要讓大家相信這謊言，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因此試著將所有顧慮給排除的勢力存在。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而那個勢力，也正是這次在檯面下操縱尾狗刀的一方呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "相對的，也有識破了這謊言，試圖想將世界之謎給解開的另一股勢力。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就是被稱為祕密社團、【拉比林斯】的那群人唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為試圖把世界之謎解開的【拉比林斯】，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n想把將握有關鍵的矛依未給納入旗下，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n才會遇襲的呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以才會與擔心世界之謎被解開的尾狗刀一行人，發生了衝突囉。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這就是，造成了這次事件大略上的結構唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從結果來看，這次是【拉比林斯】取得勝利了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而矛依未，也成功地被【拉比林斯】給確保住，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n且將會被藏匿起來一陣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之後，雖然現在還不清楚矛依未究竟會發生什麼事。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，畢竟【拉比林斯】也不是個危險的集團，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再怎麼說，也不會遭遇到什麼淒涼殘忍的對待才是。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "況且你呀，不也早就認識了【拉比林斯】中的",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n靜流和璃乃並且感情也還不錯嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都是群好孩子嘛，應該是不會做出什麼非人道的行為唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但這麼群乖孩子，卻以奇襲行動來進行誘拐，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n表示對她們來說，已經只能使出強硬的手段……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這也充分顯示，矛依未是個如此重要的存在呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以理所當然的……",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和【拉比林斯】敵對的、那個不允許世界之謎被人解開的勢力，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也不會輕易投降唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鑒於此次的失敗，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n往後勢必還會不斷派出更厲害的角色出手呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且你也見到尾狗刀那游刃有餘的態度了，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說不定還在策畫著什麼壞主意呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player} ，你得要小心一點唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你被捲入的可說是大災難、處於那巨大的命運洪流之中呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一不小心，可會輕易地失去你最珍貴的寶物唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請謹慎、仔細思考過後再採取行動。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，你大概連思考的時間都沒有，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n又會被捲入一波接一波的麻煩之中吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加把勁去面對這些問題，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n保住你這條小命……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後盡可能地去更接近這世界之謎吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，先和在大危機之中保護了你們的那群人……",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也就是真琴所屬的武鬥派公會、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n【哞哞自衛隊】的成員，先好好談談吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。你們在這之後，",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將會被納入她們的保護之下喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在【哞哞自衛隊】裡，也有不少你認識的女孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可以放心依靠她們也沒問題唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但說到頭來，你還是得自己做決定就是了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我呀，只會在你困擾的時候，提出一點小建議而已。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟，我可沒有權力干涉你所在的那個現實喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以啊，如果你太依賴了我，可會讓人相當困擾呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "相信我吧。",
        "unit_id": 190011,
        "voice": "vo_adv_2001006_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我一直都是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的同伴喔，\n{player}。",
        "unit_id": 190011
    }
]