    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "度過了混亂與插曲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n四人在那之後依然埋首於淨化大海。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "終於，全部的祕密魔物"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n都被歸還給了所有者。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太棒了────！",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n祕密魔物",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "全數歸還！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n大海淨化",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "完成～～！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "放眼望去，",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一整片都是乾乾淨淨的海底！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這下子，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "金槍鮪也能恢復原本的味道了吧！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "太感謝了……",
        "unit_id": 6411,
        "voice": "vo_adv_5122005_002"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "真的太感謝了！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n這份恩情",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我一輩子都不會忘記！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 126611,
        "voice": "vo_adv_5122005_003"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "似似花大人，",
        "unit_id": 191011,
        "voice": "vo_adv_5122005_004"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "您的祕密物品有出現嗎？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒有……",
        "unit_id": 126611,
        "voice": "vo_adv_5122005_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是奇怪。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼就立刻把海水灌回去……",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖然",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "很想這麼說，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過在那之前還有一個問題。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n漁協協會長？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你能正式答應我，",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不再承辦祕密廢棄服務嗎？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是為了大間的海、",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這裡的居民，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n以及",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "期待吃到大間的魚的所有人。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "好……",
        "unit_id": 7511,
        "voice": "vo_adv_5122005_008"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "我答應妳，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "我們再也不會做出",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "汙染這片大海的行為。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "謝謝你……！",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "──那麼，",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就把海水",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "恢復原狀吧。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "紫藤土木相關企業的各位～！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請將海水──",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "給我等～～",
        "unit_id": 1,
        "voice": "vo_adv_5122005_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一下～～～～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "一夥",
        "words": "……！？",
        "unit_id": 1,
        "voice": "vo_adv_5122005_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什、",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什什什麼！？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n海底……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "裂了開來……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n有什麼東西出現了──！？",
        "unit_id": 126811
    },
    {
        "type": "still",
        "still": "512200501"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你是……",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "島鯨！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n你還活著嗎！？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "又──",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_015"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "是你們在礙事啊？",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n你們還是一樣高舉著低級正義感的旗號，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n看不出半點成長的跡象啊。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一見面就說得那麼難聽……",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不先打個招呼嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "像是好久不見～",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "或是",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "久疏問候～",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "之類的。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "話說",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什麼叫做我們在礙事？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大海被淨化似乎讓牠很困擾呢……",
        "unit_id": 126611,
        "voice": "vo_adv_5122005_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來這一切的背後主謀",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是這傢伙……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "什麼！？",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n可、",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可是，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我記得你想要的",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是人類的「欲望」吧？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那跟祕密物品有什麼關係……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "越是強烈的欲望，",
        "unit_id": 126611,
        "voice": "vo_adv_5122005_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "人就越是會想要藏起來。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "哦，",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_020"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "也有很敏銳的人嘛。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也就是說，",
        "unit_id": 126611,
        "voice": "vo_adv_5122005_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你看上的",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是隱藏在「祕密」之中的",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「欲望」……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "從慫恿漁協協會長，",
        "unit_id": 126611,
        "voice": "vo_adv_5122005_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "誘使他展開祕密廢棄服務的那一步起，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你就已經展開你的陰謀了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "正是如此。",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_023"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "「東西一旦沉下去就永遠不會浮起的漩渦」",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "就是我的噴氣孔。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n你們拚命丟了一堆祕密物品下來呢，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "我要向你們道謝啊，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "大間的人類們♪",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "和正、漁協協會長",
        "words": "什麼──！？",
        "unit_id": 1,
        "voice": "vo_adv_5122005_024"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "祕密的「欲望」",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_025"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "充滿愧疚感，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n又濃郁深沉，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "非常美味呢。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你就是靠著這個方式利用大間的人們，",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n在海底苟延殘喘的吧……！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "是啊。",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_027"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n不過你們也充分享受到了好處吧？",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n漁協協會長，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "之後也要繼續麻煩你囉♪",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "這、",
        "unit_id": 7511,
        "voice": "vo_adv_5122005_028"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "這可不行。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n我已經決定不會繼續提供祕密廢棄服務了！",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "哇──",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_029"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "哈哈哈哈！",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n少自以為是了，人類們。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "你們",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "可沒有",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "決定權。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "喝──",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_030"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "哈！",
        "unit_id": 10412
    },
    {
        "type": "still",
        "still": "512200502"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咚嘣────！！"
    },
    {
        "type": "dialogue",
        "name": "一夥",
        "words": "──！？",
        "unit_id": 1,
        "voice": "vo_adv_5122005_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "從、",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_032"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "從島鯨的噴氣孔……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "又有更多的祕密魔物……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "噴出來了～！？",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_033"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n而且數量非常多～～！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "討厭，",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_034"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好不容易才把海底清乾淨的！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這下不就又回到原點了嗎～！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "看～啊，",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_035"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "你們快看，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "要多少有多少喔！",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n這是你們人類所丟棄、",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "成堆的自私念頭！",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……！",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_036"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那樣的話，",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "由我們親手處理也是應該的呢……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既然如此，就只能用體力跟牠耗下去了。",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_038"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n直到牠的祕密魔物耗盡為止，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n讓我們一個不剩地",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "歸還、",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "淨化那些祕密吧！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "了、",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_039"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "了解！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n那麼，每個人",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都盡可能多抱一點祕密魔物──",
        "unit_id": 126811
    },
    {
        "type": "background",
        "background": "502014"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "──！",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_040"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……奇怪？",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_041"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我的腳……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "動不了……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我、",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_042"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我也是……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我的腳……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "正確來說，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是身體",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "動不了……！？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨、秋乃",
        "words": "為、為什麼……！？\n怎、怎麼會這樣……！？",
        "unit_id": 1,
        "voice": "vo_adv_5122005_043"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "因為「罪惡感」啊。",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_044"
    },
    {
        "type": "dialogue",
        "name": "優花梨、秋乃",
        "words": "咦……？",
        "unit_id": 1,
        "voice": "vo_adv_5122005_045"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "看來你們什～",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_046"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "麼也不知道，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "就一頭栽進來了啊。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n真可憐哪。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "雖然為時已晚，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "不過我還是告訴你們吧。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "所謂的祕密呢，",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_047"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n一半是由「欲望」，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "另一半",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "是由「罪惡感」所組成的。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "這種叫罪惡感的東西",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_048"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "對我來說沒有任何味道，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "但對人類來說好像非常難吃，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n聽說是種會侵蝕身心的",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "毒藥呢♪",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "你們揚言要淨化魔物，",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_049"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "因而與他人共享了太多的祕密。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n在那個過程中共同承擔的罪惡感，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "都累積在你們那瘦弱的身體裡了。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n唉唷，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "真是可憐啊。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "優花梨、秋乃",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_5122005_050"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_051"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "糟糕……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "心也……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "變得消沉了……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒錯，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是我們",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不好……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是啊……",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_052"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這種事……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不該只憑自己的一廂情願",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就出手干涉的……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我感覺",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_053"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就連一根手指也動不了了……",
        "unit_id": 126811
    },
    {
        "type": "background",
        "background": "502020"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "雖然很遺憾，",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_054"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "不過事情就是這樣。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n你們",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "試著回想一下吧，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n那些被歸還了祕密的人",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "露出的那狼狽模樣，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "還有哀號慘叫。",
        "unit_id": 10412
    },
    {
        "type": "still",
        "still": "512200401"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "或者是",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_055"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "只因一個祕密就輕易扭曲的",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "人際關係，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "以及這個社會。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_056"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "502014"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "無法承受。",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_057"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "想放手拋開。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n就是因為這樣，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "他們才會主動廢棄這些祕密不是嗎？",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "要是你們沒有把這些東西挖出來，",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_058"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n祕密就會永遠沉在深海之中，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n不會擾亂任何人的心。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "人類是",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_059"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "難以承擔祕密的。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n正因為如此，我才會提議",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "繼續提供祕密廢棄服務。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "你們別誤會了，",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_060"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "我可不是想單方面壓榨人類喔？",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "這就好比是",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "共存協議。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "共存",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_061"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "協議……？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "以前",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_062"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "你們也跟我提過吧？",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "就跟那個協議一樣。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n把潛藏在祕密之中的「欲望」給我。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n作為交換，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "我會將人類的祕密永永遠遠、",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "確實地",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "埋葬起來。",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "永永",
        "unit_id": 126811,
        "voice": "vo_adv_5122005_063"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "遠遠……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "確實地……",
        "unit_id": 126711,
        "voice": "vo_adv_5122005_064"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "這對我們雙方都有好處，",
        "unit_id": 10412,
        "voice": "vo_adv_5122005_065"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n我覺得是個不壞的提案呢？",
        "unit_id": 10412
    },
