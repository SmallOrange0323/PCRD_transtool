[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和與怜結束旅行並回到了基礎世界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人在回去冒險前的短暫時間內，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "暢談著各自在旅行時的所見所聞。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈哈，",
        "unit_id": 100111,
        "voice": "vo_adv_5208068_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳在志那都的世界",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "遇見了莫妮卡呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和正先生竟然是將軍！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "將軍和正公，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我也好想看看喔。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺會出奇地合適呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_5208068_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過我見到他時，他碰巧是穿著漁夫的服裝。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而妳在埃拉的世界",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "則是見到了珠希和香織呀。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真想看看",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當潮流傳道者的香織呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧對吧！",
        "unit_id": 100111,
        "voice": "vo_adv_5208068_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓我驚訝的是珠姐呢～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次讓我再次認知到了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說到珠姐就會想到……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「喵」，",
        "unit_id": 100111,
        "voice": "vo_adv_5208068_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「喵」怎樣了喵？",
        "unit_id": 125111,
        "voice": "vo_adv_5208068_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_5208068_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "珠姐！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n果然聽到那個語尾就很讓人放心～♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵？",
        "unit_id": 125111,
        "voice": "vo_adv_5208068_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n總覺得好噁心喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也聽到了我的名字喔。",
        "unit_id": 125212,
        "voice": "vo_adv_5208068_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n怎麼了嗎？怜閣下。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100311,
        "voice": "vo_adv_5208068_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒什麼。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "先不說這個，莫妮卡，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這趟旅行的伴手禮。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哦哦，",
        "unit_id": 125212,
        "voice": "vo_adv_5208068_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是感激不盡……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這紙牌！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是小孩子的玩具嗎！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……我姑且就先收下了！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "安布拉",
        "words": "喵～！",
        "unit_id": 1731
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哦～",
        "unit_id": 100111,
        "voice": "vo_adv_5208068_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "安布拉，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你過得還好嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，",
        "unit_id": 125111,
        "voice": "vo_adv_5208068_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牠已經完全融入了我們的貓咪咖啡廳喵♪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這孩子非常聰明，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "客人也都很疼愛牠喵♪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣啊，",
        "unit_id": 100111,
        "voice": "vo_adv_5208068_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那我就放心了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為很危險，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以沒辦法帶你去冒險，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但我們每次回蘭德索爾",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都會來看看你過得好不好喔♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "安布拉",
        "words": "喵～♪",
        "unit_id": 1731
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，",
        "unit_id": 100311,
        "voice": "vo_adv_5208068_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "差不多到了跟優衣會合的時間了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們走吧，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哦～",
        "unit_id": 100111,
        "voice": "vo_adv_5208068_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這裡正在辦什麼活動！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "上面寫著「咱們村子的",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "土產展」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喔～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "來來來～",
        "unit_id": 6411,
        "voice": "vo_adv_5208068_015"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "走過路過不要錯過！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n大間產的",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "道地究極金槍鮪解剖秀要開始啦！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨呵～♪",
        "unit_id": 101711,
        "voice": "vo_adv_5208068_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n藉由三線聲與舞蹈，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "感受南國的風吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_5208068_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看起來很好玩呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等跟優衣會合以後，我們去看看吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯，",
        "unit_id": 100111,
        "voice": "vo_adv_5208068_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那我們快回去吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n回到優衣的身邊♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是日和與怜在享受完短暫的異世界旅行後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次回到了冒險生活中。"
    }
]