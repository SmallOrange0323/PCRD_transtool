    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀呀，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們幾個。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在大馬路上還這麼恩愛呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咦，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_012"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咲戀小姐？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗨，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "愛蜜莉雅。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有拉姆和雷姆妳們好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來妳們跟可可蘿處得不錯呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯。",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_014"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我們",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "感情",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "非～常好。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對吧？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都、",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都說請不要摸在下的頭了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感情和睦是件美事。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且妳們也很照顧我們的孩子，真的幫了大忙。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為我們受到育兒院的照顧。",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_017"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而且鈴莓小姐和孩子們也都對我們很好。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "鈴莓又總是少根筋，",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_018"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看都看不膩。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不曉得雷姆來幫忙之前",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "育兒院到底是怎麼營運的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "平常的話綾音和胡桃會幫她的忙喔。",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們幾個來了以後",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓似乎也很努力。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說到這個……",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "胡桃小姐最近正感慨打破的盤子和燒焦的鍋子",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "越來越多……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因、",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_021"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為鈴莓小姐",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是一位很努力的人。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_022"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也因為這樣所以綾音和胡桃都很細心呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n年紀那麼小，但做菜和打掃樣樣拿手，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "而且非～常乖巧！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "小孩們也不會怕我……",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_023"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n雖然現在不該這麼悠哉，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但我",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的有點幸福。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感受到幸福和時機可是一點關係也沒有喔。",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只要愛蜜莉雅妳感覺快樂幸福，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就足夠稱做幸福了嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咲戀小姐……",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也是，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聽到妳們稱讚那些孩子也很高興喔？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不論妳想待到什麼時候都沒關係。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這並不是基於我們都是精靈族的關係，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但彼此都是精靈族，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像這樣互相幫助不是也很好嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真了不起，",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咲戀小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下和主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都很敬佩您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯。",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_029"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我因此也得到了許多的勇氣。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n真的，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咲戀小姐真的很厲害。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別連你也叫我「媽媽」啦。",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才十七歲而已喔？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "十、",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_031"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "十七歲……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我得",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "更努力才行了……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼連你也變得這麼正經八百的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒關係啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家就像一家人一樣嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔喔，",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "家人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這真是一個很棒的字眼。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也想要和主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "建立這麼深厚的羈絆。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過話又說回來，",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咲戀小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鮮少在這個時間見到您呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我被【王宮騎士團】找去啊──",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "路上",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "突然想看看育幼院的大家，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就繞過來看一下。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "王宮……",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_036"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咲戀小姐是城堡裡的大人物嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "並不是那樣的。",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是我曾擔任過【王宮騎士團】的副團長。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因為這層關係，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "到了現在有事的時候他們還是偶爾會找我去。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聽說最近",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "蘭德索爾附近的村莊",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有人失蹤，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有一些怪異的目擊情報。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然目前還沒有造成明顯的騷動，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但等到真的發生什麼事就太遲了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以他們",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也找我過去了解狀況。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "失蹤，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_040"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "還有怪異的目擊情報……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那個，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "拉姆、",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雷姆。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那該不會就是……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是啊，",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_041"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "愛蜜莉雅大人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆也覺得",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "十之八九不會錯的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "大罪司教……",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "――？",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳們幾個",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼了？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那個，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_044"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咲戀小姐。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n妳們在城堡討論的內容，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n之後是否可以告訴我呢？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那個，",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_045"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "詭異事件的犯人",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n可能就是我們在找的人也說不定。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是這樣子嗎，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我知道了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是為了妳們呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我會去多了解詳情。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在那之前請妳們不要胡來喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這就是我對妳們提出的條件。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_048"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我知道了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "拜託妳了，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咲戀小姐。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很好，",
        "unit_id": 102811,
        "voice": "vo_adv_5017002_049"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "回答得好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先去一趟王宮。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳們",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "去買東西也要注意安全喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咲戀小姐",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_050"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的很了不起。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "明明都是妖精，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但我跟她真的差太多了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下覺得您不需要和咲戀小姐比較",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而感覺自己不如她。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咲戀小姐有咲戀小姐的優點。",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛蜜莉雅小姐則有愛蜜莉雅小姐的優點。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可可蘿……",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_053"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "謝謝妳。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我覺得自己好像恢復了精神。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "把迅速就重新振作起來的愛蜜莉雅大人先放一旁，",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_054"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n那個魔女教在王宮似乎也已經成為話題了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "失蹤再加上目擊證詞……",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_055"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "究竟",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "大罪司教有什麼陰謀？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "目前還不清楚，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_056"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不多注意不行。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n而且，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我們現在也還不知道昴到底身在何方。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真的是個",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_057"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不管到哪裡都很會給別人添麻煩的男人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那傢伙真的是個問題之王。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不論何事能專精為王就是好事。",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_058"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "真不愧是昴，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "就是個充滿潛力的原石！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真的很仰慕那位昴先生呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下懂的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對主人的心情也是一樣的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的！",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_060"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可可蘿小姐！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "妳能理解這種心情真的讓我很開心！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雷姆雖然是我可愛的妹妹，",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_061"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但竟然會選擇巴魯斯，這種品味實在令人難以苟同。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "總之，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_062"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我們得趕快找到昴才行。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "彷彿",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "他一直在躲我們一樣，怎麼找也找不到他。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "若再不快點，",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_063"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "在打倒大罪司教之後",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n我們就要自己回宅邸了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "拉姆，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_064"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "妳也真是的。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不要說那麼壞心的話嘛！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――――"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您怎麼突然停下腳步？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會被大家丟下喔？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對對，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_066"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "手腳要俐落一點。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "把鈴莓囑咐要買的東西買回來後，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我們也去幫忙做育幼院的工作吧。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "好的，",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_067"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "打掃、洗衣",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還有做菜全交給雷姆吧！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "然後",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_068"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "在一旁監督就是拉姆的工作。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "來吧，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_069"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可可蘿也一起去吧？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "畢竟",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "被這麼樣的委託買東西了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也出發吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼，",
        "unit_id": 2712,
        "voice": "vo_adv_5017002_071"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好險好險。",
        "unit_id": 2712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我還以為會被發現，",
        "unit_id": 2712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那傢伙直覺真準。",
        "unit_id": 2712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好了，",
        "unit_id": 2712,
        "voice": "vo_adv_5017002_072"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就從這裡開始，",
        "unit_id": 2712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡……",
        "unit_id": 2712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我呢，",
        "unit_id": 2712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可別出差錯才好喔。",
        "unit_id": 2712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "命運，",
        "unit_id": 2712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等著瞧。",
        "unit_id": 2712
    }
]