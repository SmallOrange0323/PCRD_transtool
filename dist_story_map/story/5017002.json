        "voice": "vo_adv_5017002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n愛蜜莉雅小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎也已經習慣了這裡的生活。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "501700201"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是啊，",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的很感謝大家。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n這一切",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "都多虧了【咲戀育幼院】裡的人這麼照顧我們，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "還有把咲戀小姐介紹給我們的可可蘿他們！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的非～常感謝。",
        "unit_id": 109911,
        "voice": "vo_adv_5017002_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "好孩子好孩子♪",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那、",
        "unit_id": 105913,
        "voice": "vo_adv_5017002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不要摸在下的頭。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下並不討厭這樣，只是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "妳看，",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_005"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "姊姊。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n愛蜜莉雅大人",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "非常喜歡可可蘿小姐呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "因為兩人不僅同是妖精，",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_006"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "連髮色和眼睛的顏色都一樣嘛。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n即使有多了個妹妹的感覺也不奇怪。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "姊姊力很強的拉姆我懂這種感覺……",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_007"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n擁有可愛妹妹的姊姊，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是世界上最幸運的人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不是的，",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_008"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "姊姊。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不是那樣的。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "擁有好姊姊的妹妹，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "才是世界上最幸福的人。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哎呀，",
        "unit_id": 109811,
        "voice": "vo_adv_5017002_009"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "妳嘴巴變甜了耶，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雷姆。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真可愛。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "姊姊……",
        "unit_id": 109711,
        "voice": "vo_adv_5017002_010"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "still",
