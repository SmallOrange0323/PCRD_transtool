[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼、",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天的交朋友特訓也很嚴格……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然趁著興致順勢就開始做伏地挺身……",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是果然，交朋友和伏地挺身，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n沒有多大關係吧……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "無、無論如何，今天也讓我",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n送你到森林入口吧。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……？那是什麼東西呢，",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n森林入口的附近，有奇怪的光芒……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀、",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀啊啊啊啊！",
        "unit_id": 104011
    },
    {
        "type": "still",
        "still": "104000801"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……啊，你好……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_005"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在下著雨的假日中午，\n遇見了被雨淋濕的碧。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？你問我在雨中做什麼嗎？",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……啊哈哈……這是因為，出現了奇蹟，",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我今天要和同學們出去玩了。",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊哈……謝謝。",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這是因為至今",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在BB團和你聊天才有的成果。",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "然後，我非常期待地等著……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是大家都還不來……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也認為我可能搞錯時間了……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我現在已經等了6個小時左右……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "大概……大概吧。",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我是早上6點來的，",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想大家約的時間可能是晚上6點吧。",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為大家說好要去吃飯……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我以為是吃早餐……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n結果是要吃晚餐啊，一定是這樣沒錯……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是不知道該去哪裡，距離約定的時間，",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n還有6小時，所以就想說在這裡等……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哈啾！",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊哈哈……雨好冰喔……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，為了不破壞大家今天的心情，",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我一定要努力微笑才行……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒事的。我……就是這樣過來的……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？{player}？",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你說隨便去個地方消磨時間嗎……？",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你、你要把你寶貴的時間花在我身上嗎……？",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝、謝謝……！",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我有你這樣的朋友……真好！",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n果然，你才是我最好的朋友！",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你的手，好溫暖……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說實話……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n雖然也很期待等一下要和",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "同學們一起玩……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是我更希望像這樣……",
        "unit_id": 104032,
        "voice": "vo_adv_1040008_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n和你一起相處的時間能持續更久……",
        "unit_id": 104032
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？ 這是我給你的禮物！ 你做了個好「夢」嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1040008_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是我依照你跟碧以前的記憶創造出來的「夢」，",
        "unit_id": 190011,
        "voice": "vo_adv_1040008_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n原來現在的你會採取這樣的行動呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來你也挺貼心的嘛！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1040008_023"
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……？這裡是，森林……",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "剛才的是夢……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，你也做了同樣的夢嗎……",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好奇妙喔……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，即使在夢裡你也對我那麼好……",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n讓我覺得很溫暖……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "明天也請你",
        "unit_id": 104011,
        "voice": "vo_adv_1040008_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "繼續關照BB團的活動囉！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天兩人也愉快地進行著BB團的活動。\n碧和{player}之間的感情又加深了一步。"
    }
]