[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "結束以後回頭一看，",
        "unit_id": 123912,
        "voice": "vo_adv_6104107_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "和平活動也挺開心的……",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "對吧？",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "過程的確亂七八糟的，要說辛苦也確實很辛苦，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是俗話說「只要結局好就一切都好」",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不是嗎♪",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真要我說的話，",
        "unit_id": 123912,
        "voice": "vo_adv_6104107_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我是感到安心了。",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因為我們成功達成了和平活動這個任務，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "順利回應了純他們的期待♪",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就是說啊……",
        "unit_id": 123912,
        "voice": "vo_adv_6104107_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們去造訪了各種獸人族的聚落，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n跟他們一起吃飯、",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "玩樂，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還有體驗他們的工作。",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n雖然很辛苦，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是最後順利結束真是太好了！",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我有股",
        "unit_id": 123912,
        "voice": "vo_adv_6104107_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很～不好的預感，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但還是姑且問一下。",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那疊紙是",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "克莉絲提娜阿姨給的追加資料嗎？",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那也就是說，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "又要寫報告書了對吧……？",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託饒了我吧～！！",
        "unit_id": 123912
    }
]