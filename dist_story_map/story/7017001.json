[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "登上露娜之塔的{player}與克莉絲提娜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪也跟在他們後方。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哦……",
        "unit_id": 100811,
        "voice": "vo_adv_7017001_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來是這樣。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n來這裡是為了找尋{player}的記憶線索啊？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊，",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽說跟小子有關我還期待了一下……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒想到只是不斷地爬樓梯而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果我就這麼無聊死了怎麼辦？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來我得教教你",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓淑女愉悅的領導方式呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼啦？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不用這麼客氣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我和小子都是什麼關係了♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我們享受刺激的剎那──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯嗯？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "終於肯出來迎接了嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也起得太晚了吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "面對賓客，還真是沒有接待的熱情啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我正好等到閒得發慌呢。",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n來讓我找點樂子吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看招！",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跳支舞給我看吧！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼啊，",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真是不過癮。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "抵抗啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正面反抗我吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n否則",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "便會被我吞噬殆盡！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇～",
        "unit_id": 100811,
        "voice": "vo_adv_7017001_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一瞬間就打倒了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可以請妳保持這個步調嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也樂得輕鬆呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "新敵人的登場嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不錯嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "越來越熱鬧了♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來，",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳叫做……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雪對吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳對自己的評價似乎相當高啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種程度對妳來說應該不在話下吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "見識下妳的本事吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦，",
        "unit_id": 100811,
        "voice": "vo_adv_7017001_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好麻煩啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我又不是負責這種事情的……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吶，魔物先生。",
        "unit_id": 100811,
        "voice": "vo_adv_7017001_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼要這麼生氣呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n稍微放輕鬆一點，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來看看我的美貌嘛。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "吼喔喔喔喔喔……",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵。",
        "unit_id": 100811,
        "voice": "vo_adv_7017001_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算是魔物的你，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也懂得欣賞我的美貌呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你的感受力……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "非常棒喔。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "吼喔喔喔喔喔……",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為何不打倒魔物。",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓牠叫來夥伴的話，陷入苦戰的是妳喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不會是",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在期待",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會去救妳吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不是的。",
        "unit_id": 100811,
        "voice": "vo_adv_7017001_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "萬一",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不小心受傷，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n讓我的身體留下一絲傷痕就糟糕了呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而且",
        "unit_id": 100811,
        "voice": "vo_adv_7017001_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大部分的弱小魔物用魅惑的就可以了……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更何況",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "牠們是能理解我的美貌的魔物唷？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "別說打倒，",
        "unit_id": 100811,
        "voice": "vo_adv_7017001_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我反倒希望牠們能夠更加沉浸在",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我這能夠",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "跨越種族藩籬的美貌……♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳的想法似乎很異想天開啊……",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我完全聽不懂妳在說什麼。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "確實，",
        "unit_id": 107111,
        "voice": "vo_adv_7017001_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "平安度過了這次的危機……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如同小姑娘所言，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是天生的美貌所致嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "單純只是個妄想自大狂呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克莉絲提娜凝視著照鏡子的雪，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n試圖鑑別出她的價值。"
    }
]