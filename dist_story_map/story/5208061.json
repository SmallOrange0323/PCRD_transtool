[
    {
        "type": "background",
        "background": "501650"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在埃拉、志那都，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "還有厄莉絲三人去了溫泉旅行的幾週後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n怜與日和為了再次前往埃拉和志那都複製品世界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了索爾之塔。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……好慢。",
        "unit_id": 129011,
        "voice": "vo_adv_5208061_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "厄莉絲！",
        "unit_id": 100111,
        "voice": "vo_adv_5208061_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "菲歐！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抱歉",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們來遲了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等等，",
        "unit_id": 190011,
        "voice": "vo_adv_5208061_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們的行李數量",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是怎麼回事啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是打算要移居到那邊嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100311,
        "voice": "vo_adv_5208061_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這趟只是普通的旅行。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為在前一陣子的狀況下，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "根本沒辦法觀光呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這些",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是要送給那邊的人的伴手禮。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 100111,
        "voice": "vo_adv_5208061_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們把討伐魔物的委託報酬",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "全都用上了♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳看，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有蘭德索爾饅頭～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有蘭德索爾糰子……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我最推薦的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "蘭德索爾奶油夾心餅！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "別把好不容易整理好的行李又攤開來。",
        "unit_id": 100311,
        "voice": "vo_adv_5208061_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 190011,
        "voice": "vo_adv_5208061_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就去盡情地享受旅行吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想埃拉和志那都應該也很想見妳們。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那邊世界與這邊的差異也很值得看看呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與這邊的差異？",
        "unit_id": 100311,
        "voice": "vo_adv_5208061_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那邊是被複製出來的世界。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "除了索爾之塔所在之處外，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該沒有太大的差異吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像也不能這麼說喔。",
        "unit_id": 190011,
        "voice": "vo_adv_5208061_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那邊的世界",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是被重複模擬了好幾次嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以說世界應該產生了一定程度的變化。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "尤其，",
        "unit_id": 190011,
        "voice": "vo_adv_5208061_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是在人的方面呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣啊！",
        "unit_id": 100111,
        "voice": "vo_adv_5208061_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n啊，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼說來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉之前好像也說過類似的事呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此，",
        "unit_id": 100311,
        "voice": "vo_adv_5208061_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼那些差異或許也很值得一看……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n日和，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "差不多該走了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "厄莉絲她一直盯我們，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "眼睛連眨都不眨。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_5208061_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "確認伺服器。",
        "unit_id": 129011,
        "voice": "vo_adv_5208061_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n「獵犬座α」……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n確認士條怜的存取權。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "取得存取權。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "確認伺服器。",
        "unit_id": 129011,
        "voice": "vo_adv_5208061_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n「天貓座」……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n確認春咲日和的存取權。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "取得存取權。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……快出發吧。",
        "unit_id": 129011,
        "voice": "vo_adv_5208061_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "厄莉絲，",
        "unit_id": 100111,
        "voice": "vo_adv_5208061_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝妳！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們走吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……那個，",
        "unit_id": 100311,
        "voice": "vo_adv_5208061_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "厄莉絲。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為我們一直在麻煩妳，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "其實沒資格說這種話，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但我有個請求。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能不能把傳送目的地，",
        "unit_id": 100311,
        "voice": "vo_adv_5208061_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從空中改成其他地方……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜的請求並沒有被聽進去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人就這樣被傳送到了各自世界的上空。"
    }
]