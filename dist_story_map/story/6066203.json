[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話說，",
        "unit_id": 116611,
        "voice": "vo_adv_6066203_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "居然是祈梨當上了老大。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就算聽了緣由，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我還是不懂事情怎麼會變成這樣。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然那傢伙應該有用她的方式在努力啦……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哎，",
        "unit_id": 116611,
        "voice": "vo_adv_6066203_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也是啦……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我很～懂你的心情。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然說是成功當了老大，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但那傢伙不要因此賣力過頭、勉強自己就好了……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊。",
        "unit_id": 116611,
        "voice": "vo_adv_6066203_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不管怎麼說，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "現在的老大就是祈梨。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不管是我還是那傢伙，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只要有你在身邊就能放心了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……話雖如此，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是得注意別讓她勉強自己呢。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是嗎？",
        "unit_id": 116611,
        "voice": "vo_adv_6066203_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她可是祈梨喔？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你真心這麼認為嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看著我的眼睛。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣你還講得出剛才那句話嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……我就知道。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總之，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她不要又莫名的得意忘形起來就好了……",
        "unit_id": 116611
    }
]