[
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人前往厄莉絲的所在之處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了節省時間，他們乘著志那都所操控的風來進行移動。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇啊～！",
        "unit_id": 100111,
        "voice": "vo_adv_5137067_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n好厲害喔，大家！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "正在天上飛耶！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和，",
        "unit_id": 100311,
        "voice": "vo_adv_5137067_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣很危險，不要亂動。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "手再握緊一點也沒關係喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯、",
        "unit_id": 100213,
        "voice": "vo_adv_5137067_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……怜。",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n妳要好好記住這陣風的感覺。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這對之後的修行會有幫助。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不愧是志那都！",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_004"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n連這種時候都不忘修行呢♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大家，",
        "unit_id": 190011,
        "voice": "vo_adv_5137067_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要慌張，保持冷靜！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只要不亂動就不會有問題的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這句話從菲歐口中說出來",
        "unit_id": 100111,
        "voice": "vo_adv_5137067_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺好有說服力呢……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過……",
        "unit_id": 190011,
        "voice": "vo_adv_5137067_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼不用傳送水晶呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果用那個，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就能更輕鬆地移動了不是嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……因為我們並不知道厄莉絲的確切位置。",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_008"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n而且",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "傳送水晶的數量也有限。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n要是優衣每次探測都使用的話，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "馬上就會用盡。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "早知道這樣，",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我就帶一些過來了～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n因為我平常都沒在用，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以完全忘記有這東西存在了。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……咦？",
        "unit_id": 100213,
        "voice": "vo_adv_5137067_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你的臉色",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "看起來有點差耶……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是暈風了嗎！？",
        "unit_id": 100311,
        "voice": "vo_adv_5137067_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n志那都，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "先休息一下！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們休息一下吧！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我知道了。",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_012"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這樣啊……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "因為我操控得不夠好…………",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "唉……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要每天精進自己呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n有能夠鍛鍊的地方是好事喔♪",
        "unit_id": 135512
    },
    {
        "type": "background",
        "background": "500540"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣穿插著適當的休息，以及優衣的探測……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人來到了泰美斯銀嶺。"
    },
    {
        "type": "dialogue",
        "name": "日和、埃拉",
        "words": "哈啾！",
        "unit_id": 1,
        "voice": "vo_adv_5137067_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 100213,
        "voice": "vo_adv_5137067_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這裡很冷呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n手指",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要變冰了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "確實是遠離人煙的地方呢。",
        "unit_id": 100311,
        "voice": "vo_adv_5137067_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n厄莉絲就在這裡嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100213,
        "voice": "vo_adv_5137067_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雖然還要再調查看看才能確定……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但這裡所散發出來的存在感，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是目前為止最強烈的。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}對於前往「背面世界」的洞窟做了說明……"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 100111,
        "voice": "vo_adv_5137067_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "從這裡就可以前往「背面世界」囉！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還真是湊巧耶？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "甚至連往返蘭德索爾的魔法陣都有……",
        "unit_id": 190011,
        "voice": "vo_adv_5137067_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真想早點知道呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這也沒辦法呢。",
        "unit_id": 100311,
        "voice": "vo_adv_5137067_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會有這種巧合嗎……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "「背面世界」啊……",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_021"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我沒聽過耶。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n志那都有聽過嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……沒有，",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_022"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我是第一次聽到。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "「這個世界」",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_023"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是所有世界的基礎。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我跟埃拉的世界是以這裡來創造的。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……正因如此，",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_024"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "正因為是基礎，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "所以也留下了世界被創造出來的",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n過程資訊，可以這麼說吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在「模擬實驗」中被視為不必要的東西，",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_025"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就存在於這裡。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……果然，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這個世界真是深不可測啊。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "本來要是時間允許，",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_026"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我會想調查得更仔細──",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_027"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "剛才，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "丟雪球過來的是誰……？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不知道耶～？",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_028"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "會是誰呢～？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這樣啊，",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_029"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是埃拉吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "完全沒有一點猶豫！？",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_030"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n雖然是猜對了啦！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "因為，",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_031"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這裡可是有這麼多的雪耶？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n這樣不打一場雪仗就太失禮了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是對誰失禮……",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_032"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "對雪嗎。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……埃拉說的話，",
        "unit_id": 100111,
        "voice": "vo_adv_5137067_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也有點能體會。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "覺得這雪……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就讓人很想摸摸看對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟雪又冰涼又美麗呢。",
        "unit_id": 100213,
        "voice": "vo_adv_5137067_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果要打雪仗，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就有點可怕了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過玩玩雪倒是可以。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……志那都，",
        "unit_id": 100311,
        "voice": "vo_adv_5137067_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n大家都這麼說了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就稍微玩一下吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "連怜都這樣……",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這不是很好嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_5137067_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n接下來應該又會變得很忙，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就當作是留下最後的回憶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "留下回憶……",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_038"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗎……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然一起戰鬥也是一種回憶啦。",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_039"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過增加一些悠～閒的回憶也不錯吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以說，",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_040"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好嘛？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_041"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "只能一下下喔。",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_042"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是要這樣才對♪",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_043"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "首先來打雪仗吧──！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n想參戰的人舉手～？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在那之前，",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_044"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "埃拉，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我要先回敬妳剛剛的雪球。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "等等，",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_045"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "志那都！？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "用風來做雪球太犯規了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n是說，根本沒變成球啊！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就只是個龍捲風而已啊！？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "看我的。",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_046"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嘴上毫無感情地說著，還同時捲起一股好強的風──！？",
        "unit_id": 135512,
        "voice": "vo_adv_5137067_047"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "快、",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "快逃啊～！！！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……呵呵。",
        "unit_id": 135614,
        "voice": "vo_adv_5137067_048"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人休息了一下後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便繼續前往厄莉絲的所在之處……"
    }
]