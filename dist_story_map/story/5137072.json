    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……厄莉絲。",
        "unit_id": 135613,
        "voice": "vo_adv_5137072_036"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n妳就陪她聊吧。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "陪我聊嘛～",
        "unit_id": 135512,
        "voice": "vo_adv_5137072_037"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……妳以為是因為誰，才害我這麼忙？",
        "unit_id": 129011,
        "voice": "vo_adv_5137072_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……這三個人，",
        "unit_id": 190011,
        "voice": "vo_adv_5137072_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒有共通的回憶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就算原有的情報相同……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n每個人",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所走的路線卻都不相同。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過……",
        "unit_id": 190011,
        "voice": "vo_adv_5137072_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……她們三個人，",
        "unit_id": 190011,
        "voice": "vo_adv_5137072_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都「懷抱著極為相似的傷痛活著」。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種「共感」，",
        "unit_id": 190011,
        "voice": "vo_adv_5137072_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n沒有其他人辦得到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論是多能同理他人的人……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都辦不到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唯有以【破曉之星】的身分",
        "unit_id": 190011,
        "voice": "vo_adv_5137072_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來到這裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n然後被創造出來的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這三個人",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才做得到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "確認伺服器。",
        "unit_id": 129011,
        "voice": "vo_adv_5137072_044"
    },
    {
        "type": "dialogue",
