[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在位處於山上的【伊麗莎白牧場】中，\n也傳來了與那場襲捲整座蘭德索爾城的異變相關的消息。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【伊麗莎白牧場】的成員，\n和以森林做為居所的【森林守衛】雙方進行了協調並做出了行動，\n現在正在替那些從城中逃亡而來的人們設立避難場所。"
    },
    {
        "type": "still",
        "still": "201300601"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯嗯！",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我知道囉，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就包在初音的身上吧～☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "【伊麗莎白牧場】的各位！",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n再過沒有多久從城中趕過來的難民們就要蜂擁而至了喔，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n在那之前",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓我們趕快完成搭建帳篷之類的準備吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然這麼少的人數做起來會相當辛苦，",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但讓我們盡上最大的努力吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "交給我，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這種事讓我來辦的話根本就小菜一碟啦～☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇呀！？　",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "建材",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "飄到空中了呀！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳是怎麼做到的？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是魔法……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿，",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這可是商業機密唷☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "商業？　",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可是，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的是幫了大忙了呀～……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那～個，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳是小栞的",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "姐姐嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是叫初音來著？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對於妳提供各式各樣的協助，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的很感謝！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們【伊麗莎白牧場】中，",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n沒有會用魔法的孩子……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以沒辦法用通訊魔法",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "和城內取得聯繫的嘛。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以也就沒辦法了解狀況到底怎麼樣了，",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n若是平時的話",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一定沒有辦法做出這麼迅速的對應。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這時小栞的姐姐，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n剛好來探病實在是幫了大忙了呀～♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哼哼，",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這就是所謂的不幸中的大幸嘛～？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但也不需要這麼感謝我啦，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這也算是報大家一直很關照我們家小栞的恩唷♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿。",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "【伊麗莎白牧場】的各位，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n如果可以的話，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "往後也請和我們家的小栞當好朋友唷。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那孩子，",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為從小體弱多病",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以都關在家裡頭，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n也因此交不太到什麼好朋友……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但現在，",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "能夠在【伊麗莎白牧場】中和大家這麼和睦相處的過生活，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想她一定非常的開心。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而我",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "身為小栞的姐姐～，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "只要小栞她能夠開心我就一樣很開心的唷～☆",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊、",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "以前沒有交到什麼朋友的事，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很丟臉啦不要亂說。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊～小栞，",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不好好躺著可是",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "『壞壞』",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唷？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳還是很不舒服的吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事的。",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "託大家照顧我的福，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我已經好得差不多了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟是非常時期嘛，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可不能只有我一個人倒頭呼呼大睡呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不是，",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳真的不要太勉強了喔？　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很擔心的！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說得對唷～",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這一次很罕見的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就連我也都盡可能的來幫大家的忙了嘛，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n小栞妳就好好躺著吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "之前一直臥床，",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "體力也衰退了吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n努力過頭可又會倒下了唷。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗚嗚。",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "又說了任性的話了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘻嘻。",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也明白大家的擔心，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但沒事的唷。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n小栞是個很堅強的孩子。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果我們不讓她做些什麼事，她也會很不安的嘛。",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就讓她適度地幫幫忙吧。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊……♪",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯～",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也是呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "的確人手不足也是事實。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n如果真的覺得不舒服了就要休息，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能這樣",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "向大家保證的話就讓妳幫忙吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "讓我們一起加油吧，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "小栞妳工作努力過頭了啦……",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真佩服妳呀，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也得好好向妳學習才行了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵。",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n和以前比起來，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "最近小鈴也很努力了不是嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼、",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "搭帳篷這種",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "力量活就讓我來做吧，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n小栞妳",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可以幫忙做料理的事前準備嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "放在倉庫裡的食材，",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "全部都用上了也沒關係。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我明白了，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我會加油的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那，",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就去準備睡袋和生活用品囉。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣剛好是我們這裡的那些，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為了重建牧場而送來的物資",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "派上用場的時候了呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯。",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n好像也是算到了這一點，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以她們才會把牧場選為避難場所的樣子呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "正確的判斷呢……",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明城裡的人們現在應該很辛苦，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但大家還是很努力的冷靜下來應對的樣子。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n大概是",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有哪些優秀的人們正在率領著大家吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是厲害呢……",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n只要人們能夠攜手互助合作，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一起同心協力的話，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不論是什麼異變還是疾病都能夠趕走呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也想要成為像那樣子的人呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "獨自一人努力的話應該會很困難，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會不會願意幫我呢？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "當然。",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那樣的請求可是完完全全不麻煩的唷，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "小栞。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯！　",
        "unit_id": 105211,
        "voice": "vo_adv_2013006_036"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "讓我們集合起每個人的力量，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "渡過這場困難吧！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣才更像是人類會做的事情呢♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……？",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_037"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎、",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼了嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳臉色不太好呢……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒事。",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_039"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "正好我在山中森林的夥伴中，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "前往查看城內情況的……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個小碧她傳來了聯絡。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "負責幫忙轉接通訊魔法的是美里老師就是了。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總之。",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_040"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好像",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "城裡面情況變得更奇怪了的樣子。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但小碧她好像有點混亂的模樣，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以也有點搞不清楚狀況。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "似乎是有大量的魔物闖到了城裡頭，",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_041"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "正到處搗亂著……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "的樣子？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦咦？",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_042"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先不說原本就已經陷入完全讓人理解不了的糟糕事態之中了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n而現在魔物還開始鬧起來了嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "究竟怎麼一回事？",
        "unit_id": 102611,
        "voice": "vo_adv_2013006_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n到底",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "城裡頭發生了什麼事情……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我、",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_044"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也不知道。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但正打算過來避難的人們好像會被那些魔物襲擊的樣子，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以我",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要去救救他們。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那邊就交給我們【森林守衛】，",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_045"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就麻煩牧場的大家",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "繼續進行搭建帳篷之類的準備了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不管是哪一邊都不能夠棄之不管的嘛。",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_046"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也只能隨機應變，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "盡自己最大的力量來努力了。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊啊可惡……",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_047"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n如果能用我的超能力把所有事一次搞定，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n然後讓世界變得和平就好了呢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但果然沒有那麼簡單呀。",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_048"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因此，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "才更要堅持不放棄繼續加油下去才行呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我先走一步囉，小栞！",
        "unit_id": 101211,
        "voice": "vo_adv_2013006_049"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n之後的就交給妳啦～☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，",
        "unit_id": 103811,
        "voice": "vo_adv_2013006_050"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯？　",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然有點不太懂，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但交給我吧！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "路上小心，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要小心一點唷……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊！",
        "unit_id": 103811
    }
]