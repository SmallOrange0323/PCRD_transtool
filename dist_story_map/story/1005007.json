        "words": "打、",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "打擾了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n沒有人在嗎……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哈囉～！",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我是【王宮騎士團】的人，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我有事情要找住在這邊的{player}！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇，{player}！",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "太好了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "原來你在家啊～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "前幾天，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一起去了牧場……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "受了你",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不少的照顧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "托你的福，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "平安達成了任務，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還被其他團員稱讚了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "先不說這個……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我從小智姐那裡問到{player}",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n住在這裡後就跑來見你了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在你時間上方便嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣啊。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n今天沒有打工，所以很閒是嗎。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那真是太好了～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不好意思！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n總之請你先讓我打一下！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒問題的，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我會用刀背攻擊！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n應該是不會死的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "覺悟吧！",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n接招，必殺～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n老虎斬擊……！",
        "unit_id": 100511
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦哇！？",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是的，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不可以避開啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是亂動的話，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一個失手就會打中奇怪的地方了哦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n說不定還會不小心死掉，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所以請不要躲開！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦哦？",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "連理由也不問，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就打算讓我砍是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真不愧是{player}，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真有男子氣概！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那我就恭敬不如從命，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n全力砍下去了哦～！",
        "unit_id": 100511
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……哦哇！？",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咕呃，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "失敗了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n劍砍到牆壁了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還沒有受過室內的戰鬥訓練呢～",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所以砍偏了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "奇怪？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "劍卡在牆壁裡拔不出來了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "傷腦筋！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯～嗯～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……唔嗯。\n{player}，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你擺出一副無法釋懷的臉呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一臉「不知道為什麼自己會被砍」的感覺。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過是啦，你也不可能會知道就是了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "反正你也會忘記，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所以說明也沒什麼意義呢～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯不過，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那樣的話也很不合情理呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}你，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n失去記憶了對吧？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "失去記憶的梗，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在英雄電影裡意外的算是固定橋段，所以我很清楚。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "頭部受到強烈的打擊，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_024"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一時之間就會忘記很多事情了呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我聽說{player}，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為了想找回記憶而相當努力。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以說，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了報答你一直以來照顧我的恩情……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我想助你一臂之力。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄故事裡那些約定俗成的橋段中，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只要重現與失去記憶時一樣的情況的話，就可以解決了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大致上，只要對頭部進行強烈打擊就可以恢復記憶。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以剛才，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我才會想全力地砍向{player}。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只要給予頭部強烈衝擊的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "記憶應該就能恢復了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔嗯，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那是什麼表情？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄可是教會了我，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這世界上所有重要的事情！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只要照著這個劇本走，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就能夠解決任何麻煩了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以說，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我要打{player}的頭！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n打一下之後讓你找回記憶！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "做好覺悟哦～",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_032"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "喝啊啊！",
        "unit_id": 100511
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔嗯，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為什麼要躲開呢？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不想因為那種模糊不清的理由被打？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話說你也不喜歡疼痛吧？",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n說得也是呢～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呿……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是順利的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就能夠找回{player}的記憶了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不然我也想說用力攻擊你的頭的話，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_036"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n說不定你就能夠忘記前陣子",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n看見的事情～也說不定。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_037"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你說，「魔法少女真的讓妳感到這麼害羞」嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這個嗯…",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然是害羞到很想死沒錯，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但我要你忘記的才不是那件事啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……{player}。\n那個時候，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_038"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你看到",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "長在我頭上的耳朵了吧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我希望你能忘掉那件事情。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "既然沒辦法攻擊你讓記憶消失的話，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n希望你至少答應我，不要跟任何人說這件事喔。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託你了，{player}。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如你所見是個獸人。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我所屬的公會【王宮騎士團】，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n歷史上一直都與獸人敵對。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是被發現我是獸人的話，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就沒有立足之地了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "被糟的情況……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_042"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還有被原是同伴的其他團員，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n當作敵人攻擊的可能性。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我果然還是不想那樣。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_043"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那樣太令人難過了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我會忍耐不住的……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以拜託了，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_044"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請你不要對任何人說。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是你不替我保守祕密的話……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_045"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就只能",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "打{player}的頭，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n讓你失去記憶了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我想了很久，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_046"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但也想不到其他辦法了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……唔啊？",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_047"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那個，{player}？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為什麼，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要突然抱住我呢？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_048"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「一定很辛苦吧」",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n「沒問題，我不會跟任何人說的」",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真、",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_049"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真的嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你能替我向大家保密，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n自己是獸人的這件事情嗎……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_050"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我相信你。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n{player}，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是個好人。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不會說謊。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_051"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就像故事裡登場的，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「正義的夥伴」一樣。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "對不起，{player}。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_052"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我剛才還想攻擊你……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "竟然想要用暴力來解決事情，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_053"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我真是個壞孩子呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒資格當英雄，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好丟人。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過說真的，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_054"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我原本還不曉得該怎麼辦才好……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_055"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還好發現祕密的人是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n{player}，真是太好了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "約好了哦。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_056"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n希望你能發誓，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n保證絕對不將我的祕密對任何人說。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "勾勾手指，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_057"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n說謊的人要吞一千根針～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯？",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_058"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n咦，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為什麼要對我說「謝謝」啊？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那是我的台詞啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊啊……",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_059"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因為{player}失去記憶的緣故，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所以不想再忘掉任何事情了呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以才",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_060"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不想被攻擊，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n讓記憶失去啊。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "然後，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_061"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你才會說",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n謝謝我沒有奪走你的記憶啊。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_062"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……我剛才還真的是，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n打算做一件很過分的事情呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我會反省的。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_063"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "從今以後洗心革面，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n當一個好孩子。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_064"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你說「茉莉是個好孩子」嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我還遠遠不及呢！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……耶嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_065"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以我想要，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "當個更好的孩子。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "吶，{player}。",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_066"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n可以的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我希望你能讓我幫你找回記憶。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不，",
        "unit_id": 100511,
        "voice": "vo_adv_1005007_067"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "任何事情我都會幫助你的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n什麼事情都能和我說吧，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
