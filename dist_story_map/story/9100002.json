    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "幸虧拉基拉基先生幫忙，",
        "unit_id": 105811,
        "voice": "vo_adv_9100002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們總算回到這裡了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【憤怒‧軍團】那夥人",
        "unit_id": 106011,
        "voice": "vo_adv_9100002_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像在城裡到處作亂……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐和真軌先生，",
        "unit_id": 106411,
        "voice": "vo_adv_9100002_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n似乎分頭",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "去阻止他們了……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們也",
        "unit_id": 100311,
        "voice": "vo_adv_9100002_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "馬上前往救援吧！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「嗯！」\n「好！」",
        "unit_id": 1,
        "voice": "vo_adv_9100002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人。",
        "unit_id": 105911,
        "voice": "vo_adv_9100002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【憤怒‧軍團】個個都是強敵。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不曉得只發動一次攻擊",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能不能擊敗對方……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過別輕言放棄，",
        "unit_id": 105811,
        "voice": "vo_adv_9100002_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管幾次都一起挑戰吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定要保護",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "城裡的人們！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……呵呵♪",
        "unit_id": 192011,
        "voice": "vo_adv_9100002_007"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我們",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不會輕易戰敗的喔──★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦！",
        "unit_id": 106411,
        "voice": "vo_adv_9100002_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n美空！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "用影像魔法強行介入……",
        "unit_id": 105911,
        "voice": "vo_adv_9100002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "公主殿下，",
        "unit_id": 192011,
        "voice": "vo_adv_9100002_010"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然妳說「不管幾次」──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不過在一定時間內",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "能挑戰的次數是有限的。★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "如此一來……",
        "unit_id": 191911,
        "voice": "vo_adv_9100002_011"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "最好不要平白浪費挑戰次數，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n謹慎挑戰為妙吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "儘管放馬過來，我們會把你們打到心服口服！",
        "unit_id": 191611,
        "voice": "vo_adv_9100002_012"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你們這些沒用的傢伙",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "全都吃癟去吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈！",
        "unit_id": 106011,
        "voice": "vo_adv_9100002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "終於可以把你徹底打垮了啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "臭矮子！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那是我要說的話，垃圾貓！",
        "unit_id": 191611,
        "voice": "vo_adv_9100002_014"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我要把妳跟其他小嘍囉",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "統統痛扁一頓！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "小、",
        "unit_id": 118111,
        "voice": "vo_adv_9100002_015"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "小心點……",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "如果卡里莎和",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "大家",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "受傷……",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n我會",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "很難過",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "的……",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人。",
        "unit_id": 105911,
        "voice": "vo_adv_9100002_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果擊敗了某位【憤怒‧軍團】的人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就會對其他人產生影響，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許會對戰況有利。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說無法輕易戰勝對手時，",
        "unit_id": 105811,
        "voice": "vo_adv_9100002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n先把他擺到後頭，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n轉而集中攻擊其他人",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也許會比較好喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106411,
        "voice": "vo_adv_9100002_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我感覺似乎比平常",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "湧現出更多力量。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說不定",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也能",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "幫到大家了……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不只是雪菲小姐而已。",
        "unit_id": 105911,
        "voice": "vo_adv_9100002_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎有一部分的人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能藉由主人的力量",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "達到超越平時的強化。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能獲得強化的人好像會",
        "unit_id": 106011,
        "voice": "vo_adv_9100002_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根據對戰的對手而變化。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然只有這次會有這種效果的樣子……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過我們就盡量有效地運用吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好──！",
        "unit_id": 105811,
        "voice": "vo_adv_9100002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我們走吧，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位！",
        "unit_id": 105811
    }
