    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這隻曼德拉草，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有一股非常危險的氣息……！",
