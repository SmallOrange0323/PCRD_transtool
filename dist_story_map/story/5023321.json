    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就如同所說的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那株曼德拉草的毒性非常強。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n請務必小心不要碰觸到它的觸手。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "說什麼務必小心，",
