[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "大家一邊吃著早餐，一邊閒話家常後，\n{player}一行人便開始展開了行動。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "首先得將{player}平安無事的消息，\n傳達給出於擔心而前往查看狀況的咲戀。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於她似乎前往了牧場，\n{player}一行人便循著她的足跡前進。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到達☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真奇怪？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【伊麗莎白牧場】的成員們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該是在這附近搭帳篷避難才對啊……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是看起來，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像沒有人在呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～……",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真奇怪呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過倒是有看到生過火的痕跡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是不是",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經撤走了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也不可能所有人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都像煙霧一樣消失了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是傷腦筋呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看來因為受到戰略級大量破壞魔法的影響，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這整個區域的魔力流動十分紊亂……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為沒辦法使用通訊魔法，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以也沒有方法能取得聯繫了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是平常，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n太過仰賴魔法所造成的缺點呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔力的流動受到大規模的阻礙，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這還真是前所未聞。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這一點，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n實在沒有預想到。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該怎麼辦才好呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的傳信鴉，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n必須依循著對方的魔力才有辦法送出……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在魔力流動紊亂的情況下，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n無法找出聯絡對象的資訊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以也無法使用。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "由於沒有能夠聯絡的方法，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以為了跟牧場的大家以及前往救援的咲戀小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n報告我們沒事的消息……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以才像現在這樣，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n實際跑一趟到現場來呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但看來似乎錯過了，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或者該說時機不太對的樣子。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這下到底該怎麼辦才好呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是至少能知道，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家往哪裡去了就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的話只要朝那個方向走，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就能和他們會合了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道有沒有留下紙條之類的東西呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們來找找看吧。",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n最糟的狀況也只能假設大家都回牧場了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就再朝那個方向前進就好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但要是大家已經前往城鎮的話，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們就會白跑一趟。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算想兵分兩路都去看看，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但以現在的狀況來說，希望能避免這麼做呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟對方才很明確地想取走我們的性命，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這時候應該避免戰力上的分散。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯。",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您不要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從在下的身邊離開。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對於主人身陷險境在下卻身在遠處一事，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下已經",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "深深地反省過了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這一次，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n無論遇到什麼情況，在下都會好好保護您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會再",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "離開您了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿，\n緊緊抱著{player}呢……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣看起來，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就好像真正的兄妹一樣♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……如果想讓{player}遠離危險的話，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想你們必須跟我分頭行動才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟那個『冒牌尤絲蒂亞娜』的目標，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是我呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這點倒是無法斷言。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "依照主人所言，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個『冒牌貨』……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "容在下先這樣稱呼她。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎也是對主人有興趣才接近他的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然還不清楚她的目的，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但是她施放的魔法強大到能夠將一整座山轟飛，\n是一位強敵。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以我們，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該要同心協力對付她才對。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜託您了，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們一起",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對付那股巨大的邪惡吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您也別說那麼見外的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們不是同個公會的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "夥伴嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿……",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很開心唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好～乖，好～乖♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "摸在下的頭。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n其實，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在那個『冒牌貨』施放大量破壞魔法之前……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她也說了一些類似這次的目標",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並不是我之類的話。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，的確無法斷言",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「因為目標是我，離開我就安全了～」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種話呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼一來，我們就是生死與共了。",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一起攜手",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突破這難關吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下覺得主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該也是這麼想的呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n他現在",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是露出了一副很有幹勁的表情呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您那目光炯炯的神情……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不用和在下道謝。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下只是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很直接地說出自己的想法而已。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那也是當然的吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您才剛面對可能會喪失生命的危險。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反過來說，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是您不覺得害怕，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那才奇怪呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能夠像這樣感受到主人的人性，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就安心了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳還真是擅長觀察{player}的表情呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道是不是因為{player}失去記憶的關係，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n幾乎都是一副沒表情的樣子，看不出來他在想什麼呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為在下在故鄉的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是負責照顧動物的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以即使面對",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不會說話、沒有表情的野獸，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也多少能掌握牠們內心在想什麼哦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你被說成是野獸了哦，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……哦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔哇，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_049"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我竟然睡過頭了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是人生中最大的失誤！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是可是，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_050"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那是因為昨天很晚睡的關係啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "各位～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你們在哪啊～！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_051"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我違反了英雄守則了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "竟然這麼晚才到達現場，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_052"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n沒資格當英雄了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "猛烈反省！",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_053"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n明天的自己，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n會變得比今天的自己還強～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那孩子是……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她迷路了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也不太清楚。",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但這種地方有人經過還蠻難得的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n加上我們也沒有其他線索了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以機會難得，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不如就去向她詢問看看吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您好？",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不好意思，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能夠耽誤您一點時間嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊嗚？",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_058"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n怎、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "怎麼了？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一群可疑的傢伙！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們在和妳問好哦。",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們聽說【伊麗莎白牧場】的人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都到這裡來避難了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳知道",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她們現在去哪裡了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "喔喔，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_062"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你們要找【伊麗莎白牧場】的人啊……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我記得好像是因為牧場在經過判斷後確定沒有危險，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所以她們就回去進行房屋之類的重建工程了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n果然大家",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都已經回到牧場那邊了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是的。",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_064"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n好像昨晚就把帳篷拆了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n讓來避難的人陸續回去的樣子。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我想大家",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_065"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n應該早就回到牧場了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "牧場",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_066"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為離爆炸地點有點距離，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n據說並沒有受到太大的損害。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_067"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那裡在爆炸前就因受到魔物襲擊，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n而被糟蹋的殘破不堪就是了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但只要蓋個臨時住宅的話，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_068"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n也不是沒辦法住啦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以似乎是要趁著白天時，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_069"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n盡量修復周遭環境的樣子。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她們很堅強呢～",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_070"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n真令人佩服。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了協助她們的重建作業……",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_071"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n有許多的公會都伸出援手，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n派人到牧場去了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我本來也是",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_072"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n要和同伴一起過去的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是不小心",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_073"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "遲到了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n嗚嗚，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我沒辦法早起啦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n露出那種陰沉的表情，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是會被太陽公公取笑的哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳告訴我們這麼貴重的情報，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_075"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳幫了我們一個大忙。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不會不會！",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_076"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄守則第一條，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n好心有好報！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很高興能幫上妳們的忙～",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_077"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n日行一善♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2006005_078"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在很少看見這麼乖的孩子了呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好可愛哦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n姐姐可以摸摸妳的頭嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "等？",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_079"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請妳不要摸我的頭啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是說啊貪吃佩可小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_080"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是您的壞習慣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是",
        "unit_id": 105913,
        "voice": "vo_adv_2006005_081"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您很了解狀況呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在無法認為妳只是個剛好路過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這裡且住在附近的小孩而已？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_082"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我太晚自我介紹了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄守則第三條，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不論如何都得先華麗地報上自己的名字才對！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我竟然連這麼基本的事情都忘了，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_083"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "今天的我實在是不及格！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那就重新來過！",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_084"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　雖然有些遲了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n讓我來自我介紹吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "鏘鏘～☆",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_085"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我就是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "天下無敵的超級英雄，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n虎虎……！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的超級粉絲，",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_086"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因而嚮往成為英雄的茉莉！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "身為【王宮騎士團】見習騎士的我，\n",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_087"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是個不分日夜地",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "鋤強扶弱，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "與邪惡對抗的孤高戰士！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "今後",
        "unit_id": 100511,
        "voice": "vo_adv_2006005_088"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還請各位多多指教了……☆",
        "unit_id": 100511
    }
