[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拉比林斯達讓凱留前往霸瞳皇帝的所在地，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n之後獨自來到了據點。"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想應該差不多完成了，",
        "unit_id": 106812,
        "voice": "vo_adv_1212003_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但有趕上嗎……？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……喔喔！",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "分析結束了！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我看看啊……？",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊～！",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來啊原來！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "果然是這樣啊！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒想到本該和靈魂聯繫在一起的公主騎士之力，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "居然會以這種形式造成影響……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "以少年的情況來說，",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好像是因為靈魂和精神的連結尤其牢固，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n才會造成這麼嚴重的反應……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然這是我自己製造的東西，",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但真虧這股力量能變得這麼莫名其妙呢。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總而言之，",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣就大致理解打造出「路」的方法了。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然手段會很強硬，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但現在就來測試一下吧……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唔！",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗚～！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不是燙，而是痛！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是因為這不是在重現肉體上發生的現象嗎？",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這股疼痛和竄改數據的痛楚很像啊……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就算我嘗試獨自干涉，",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "別說是鎖定精神的所在位置了，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n根本無法造成什麼大變化……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也就是說，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我的手段還不夠多啊……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1212003_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會長妳回來啦……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n妳那是怎麼回事啊！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳不覺得燙嗎！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐，水！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "快拿水來！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "水？",
        "unit_id": 104914,
        "voice": "vo_adv_1212003_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是怎麼……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呃，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會長燒起來了！？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等一下喔，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我馬上拿水過來！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，這個嗎？",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我沒事，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們別放在心上。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n畢竟這不是真的在燃燒。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是這樣嗎？",
        "unit_id": 101112,
        "voice": "vo_adv_1212003_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的話就好……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但會長是那種",
        "unit_id": 104914,
        "voice": "vo_adv_1212003_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "明明有事，卻會說自己沒事的人，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我姑且還是未雨綢繆一下吧。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我這個人實在不被信任得恰到好處耶～！",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但我",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真的沒事。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們別擔心。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不提這個了，",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我希望妳們馬上去做一件事。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我想請你們去我指定的幾個地方，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n把在那裡的人們",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "集合到同一個地點。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我明白囉，會長！",
        "unit_id": 104914,
        "voice": "vo_adv_1212003_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "說到這個，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們這麼做是為了什麼目的啊？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聽妳這麼一問，我們的確是不知道呢。",
        "unit_id": 101112,
        "voice": "vo_adv_1212003_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為這是會長",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "給我們的任務，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們就什麼都沒過問。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "簡單來說，就是……",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_017"
    },
    {
        "type": "dialogue",
        "name": "靜流、璃乃",
        "words": "就是？",
        "unit_id": 1,
        "voice": "vo_adv_1212003_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了少年！",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我這次沒有說謊囉。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很抱歉沒跟妳們說，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實少年他",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼嘛～",
        "unit_id": 104914,
        "voice": "vo_adv_1212003_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是為了弟弟啊～！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會長，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "快告訴我地點吧！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請讓我去比姐姐更多的地方！",
        "unit_id": 101112,
        "voice": "vo_adv_1212003_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我之後要讓哥哥誇獎我！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊～！",
        "unit_id": 104914,
        "voice": "vo_adv_1212003_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳好詐喔，璃乃！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……妳們不問詳情嗎？",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為會長",
        "unit_id": 104914,
        "voice": "vo_adv_1212003_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "說我們執行任務",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是為了弟弟時，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n從頭到尾都只會說真話啊。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以我覺得這次也是真的。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳說對吧？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不會在哥哥的事情上說謊",
        "unit_id": 101112,
        "voice": "vo_adv_1212003_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是會長少數的優點之一！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果是為了哥哥，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要我們努力去做什麼事情都沒問題！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們兩個……",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝妳們。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "等所有事情結束後，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我會好好解釋的。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話雖如此，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也還沒掌握到事情的全貌就是了。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果連會長都不清楚，",
        "unit_id": 104914,
        "voice": "vo_adv_1212003_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那我們現在多問也無濟於事，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想趕快為了弟弟採取行動！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哈哈，",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們是很可靠的姐姐和妹妹呢。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那我就先造出一條路來吧！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後是地圖，地圖……",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "找到了。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這裡跟這裡，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接下來是這裡，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後還有這裡嗎……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來，給妳們。",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我有個別寫上妳們兩人的目的了，",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就用我剛才造出的路",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "去把大家集合起來吧。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "拜託了！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "靜流、璃乃",
        "words": "我們出發了！",
        "unit_id": 1,
        "voice": "vo_adv_1212003_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣就準備好一種手段了。",
        "unit_id": 106814,
        "voice": "vo_adv_1212003_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我接下來得去支援凱留才行。",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊～好忙啊好忙……",
        "unit_id": 106814
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似～似花，",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哈囉～♪",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶，",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要進別人的城堡時，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "至少先敲個門吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這座城堡也不是妳家吧。",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "關於少年他們的事情，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想請妳幫一點──",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可以啊。",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦？可以嗎？",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且妳在聽我說明前就一口答應了？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n好可怕！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "之後妳應該不會跟我要求很誇張的回報吧？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算我對妳有所期待，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n難道妳之前有給過我任何回報嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯喵。",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我不記得有給過！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想也是。",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳不用再嘮叨了，快告訴我要做什麼。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我知道了啦，似似花老師。",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呃，首先是……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "如此這般，得到似似花的協助後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉比林斯達自己也在王宮內部執行了物件變更，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n成功讓凱留與霸瞳皇帝重逢。"
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我沒想到真那他，",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n居然會做出那種事情。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶，",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我收回前言。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是我第一次收到",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳給我的回報啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳讓我看到了奇觀。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也是喔。",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_044"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "坦白說",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是在賭一把，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "幸好有成功。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總而言之，\n這樣就準備好",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "兩種強力的手段了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳會這麼說，",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就代表並不是只有兩種手段而已吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是啊，",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果目前得到的數據和我的預測",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "互相吻合，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只要接下來能鎖定座標，應該就會進行得很順利。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣啊。",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那在妳離開前，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請妳做好善後工作啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦？",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳不打算再繼續幫忙了嗎？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然了。",
        "unit_id": 107011,
        "voice": "vo_adv_1212003_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然是妳自己選擇的騎士出了問題，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那就請妳自己處理吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n因為能夠扛起這份責任的人",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也就只有妳而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……是啊。",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳說得沒錯。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那我能扛多少",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就會扛多少的。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這份責任。",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話又說回來，",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_051"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真沒想到我們七冠竟然會有為了某個人，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而配合地互相幫助的這一天……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們這些人簡直像是",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_052"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "帶著唯我獨尊這四個字誕生的，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n卻還是攜手合作了耶。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但要是我們能更早做到這件事就好了。",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n明明每個人都是完整的，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "聚在一起後卻會變得不完整……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "連我自己都覺得",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這群人實在是無可救藥啊。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們之所以能出現這樣的改變，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "毫無疑問地是你的功勞喔，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你們等等我啊，",
        "unit_id": 106811,
        "voice": "vo_adv_1212003_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大家。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我們會",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "拯救你的！",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500271"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後──"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我要接受從少年身上流過來的力量，",
        "unit_id": 121211,
        "voice": "vo_adv_1212003_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n並納為己有！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好，",
        "unit_id": 121211,
        "voice": "vo_adv_1212003_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "成功了！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接下來只要把思念化為「道路」",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並連結起來就好！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "回來吧，",
        "unit_id": 121211,
        "voice": "vo_adv_1212003_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你的世界，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就在這裡！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在此同時，",
        "unit_id": 121211,
        "voice": "vo_adv_1212003_060"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我要一口氣",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "完成事先為少年準備好的",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "除錯",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "與更新──！　",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還要同步處理空間穩定化，",
        "unit_id": 121211,
        "voice": "vo_adv_1212003_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "腦袋好像要燒壞了……！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我會成功的。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我會成功做到的！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為我是天才，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是七冠啊！　",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好，",
        "unit_id": 121211,
        "voice": "vo_adv_1212003_062"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "更新完畢──！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n剩下的，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就交給少年你囉！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，在{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和夥伴的合作下，\n他們成功控制住了失控的力量。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉比林斯達為事情的經過見證到了最後……"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……你真厲害啊，",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_063"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這才是",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我的公主騎士──",
        "unit_id": 121212
    },
    {
        "type": "background",
        "background": "501500"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_064"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這裡是……",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_065"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦？",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年？",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大家",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "跑去哪裡了……？",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唔哇！？",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_066"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……流淌進來的是",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……少年的思念……",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這股珍惜所有人，",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "熾熱到",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "使人眩目的心意……",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來如此，",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能感受到這些的，",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就只有我和少年嗎……",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "辛苦你了，",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_069"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你經歷了不少辛勞啊。",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……抱歉啊，",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "歸根究柢起來，",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這次會發生這種事情，",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n其實是我託付給你的",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "公主騎士之力所導致的。",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真的是不管再怎麼向你道歉",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都不夠啊……",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年……",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_072"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你是這麼看待這件事的啊……",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝。",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我很慶幸",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "自己選上的人是你。",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……少年，",
        "unit_id": 121212,
        "voice": "vo_adv_1212003_074"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "從今以後，",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我也會繼續看著你，",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n以及你這份可能性的未來喔。",
        "unit_id": 121212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「我所選擇的騎士應該能讓我見證到吧」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n如此心想的拉比林斯達凝視著充滿未知可能性的未來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n同時露出了溫柔的微笑。"
    }
]