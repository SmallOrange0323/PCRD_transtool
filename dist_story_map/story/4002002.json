[
    {
        "type": "background",
        "background": "500380"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自從{player}們參加鬥技大會，\n也經過了一段時間。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去吧！",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_000"
    },
    {
        "type": "background",
        "background": "500380"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好欸，",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次也贏了～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們這一隊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "狀況還不錯呦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還出乎意料之外的沉迷呢，",
        "unit_id": 105811,
        "voice": "vo_adv_4002002_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "本來就是喜歡分勝負的事情就是了～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我對於不能夠吃的對手，",
        "unit_id": 105811,
        "voice": "vo_adv_4002002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還是感受不到太多戰鬥的意義。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有意義了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在『戰鬥競技場』戰鬥就可以獲得獎勵，",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也可以當作是實際作戰，累積經驗提升自己！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不都算是好事情嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}們，\n也都是這樣想的吧？",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐真是的……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n發現在下跟主人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都沒有參與到對話之中，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都會顧慮到我們，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把話題丟給我們呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的，",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是個好溫柔的人啊……♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才、",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是呢？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直跟貪吃佩可一對一的聊天，會變得越來越不正經，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒辦法，才會這樣子的！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就在下而言，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n參加鬥技大會，還是有其意義的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "報酬相當的不錯，",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也可以做為家中支出的來源。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跟平時工作相比，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也算是收入比較多的工作。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實際上，",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "待遇算是不錯了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過沒有什麼觀眾，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到底是從哪裡獲得利益的呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這部分根本是塊謎，",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓人感到微妙的不安。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "它的錢從哪裡來的啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們的對手，",
        "unit_id": 105811,
        "voice": "vo_adv_4002002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也感覺有點怪怪的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然有點像『闇影』，",
        "unit_id": 105811,
        "voice": "vo_adv_4002002_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但總感覺哪裡怪怪的……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有點像，又有點不像的感覺。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼。",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果有在意的事情，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全部都問那個叫做『米奈兵衛』不就好了嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是『米奈β』大人喔，",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說話不可以太過於失禮。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位大人，",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎跟神或是精靈一樣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是一種超然的存在。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是這樣嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實看起來有點神聖，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n或是不食煙火的感覺……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下每一天都會進行祈禱時，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都會得到愛梅斯大人的天啟……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "米奈β大人，",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n她是跟愛梅斯大人一樣是屬於超然的存在。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像我們這樣的人，",
        "unit_id": 105911,
        "voice": "vo_adv_4002002_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或許被她一瞪，就會消失也說不一定。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "呵呵。",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_023"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "有點誇張了，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "我還沒有那麼強大的物理力量。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "你們各位，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_024"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "其實也算是特別的存在……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "而目前的我，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "也有許多的機能被限制起來。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇，",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "出現了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，米奈β、",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然聽您的話在『戰鬥競技場』進行戰鬥……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是這個事情，到底有什麼意義呢？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然是個華麗又快樂的活動……",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但如果更加廣泛的做廣告來招募客人，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也將會成為一個大的商機。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，每次除了對戰的對手以外，都沒有其他人，",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得有點浪費。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "目前的狀況……",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_029"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n一般的人們",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n是沒有辦法認知到這個鬥技場的。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "所以這樣默默地進行，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_030"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n是認為最不會發生問題的。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "但如果認為有觀眾會比較有幹勁，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_031"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n那也會再檢討看看開放給一般觀眾。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "比起這個。",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_032"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "有件事情，必須通知給大家。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "多虧大家的表現，成果比預期中的還要好，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_033"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n所以好像可以擴展鬥技場的性能。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "比現在還要複雜，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_034"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n更高階的實……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "實戰場景給大家使用。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳給我等一下，",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳剛剛是不是差點說出『實驗』？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不會是想藉由我們，",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n打什麼壞主意呢！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "才不是。",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_037"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n請相信我、",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "雖然只能一直重複說同樣的事情……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "但是，我",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_038"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "基本上是站在各位那一方的。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "話雖如此。",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_039"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "聊天就先暫停一下，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "請先準備承受衝擊。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "或許會有一點點的暈眩，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_040"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "也請多多見諒。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等一下，還有很多想問的事情……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚呀！？",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "500381"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……喔喔？",
        "unit_id": 105811,
        "voice": "vo_adv_4002002_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "鬥技場的樣子好像不一樣了呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像變比較豪華的樣子？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "事到如今，",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n對於這個不可思議的空間發生什麼事情，也不會再吃驚了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但還是不要突然來啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "差點要咬到舌頭了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該說。",
        "unit_id": 106011,
        "voice": "vo_adv_4002002_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這個東西，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是什麼啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "是的。",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_045"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n這裡是將『戰鬥競技場』更加進化的",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n『公主競技場』。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "做為你們新的戰鬥舞台，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_046"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n更加進化的鬥技場。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "在這裡，有多數人參加的集體戰，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_047"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n或是參加難度更高的戰鬥。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "如果有參加的話，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_048"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n在這裡也當然會給予巨大的報酬。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "如同『戰鬥競技場』的鬥技大會一樣，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_049"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "這個地方也是想參加的時候過來就可以了。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "並不會強制大家。",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_050"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "所有事情，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "都看各位的意願。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "由於會是多人數的戰鬥，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_051"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n邀約朋友們共同參加也是不錯的方法。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "隨著參加的人數增加，戰鬥也會更加的複雜，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_052"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "需要更仔細的去思考。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "運用各式各樣的計謀，",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_053"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "鼓起勇氣與智慧戰鬥……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "能夠看到各位產生的許多故事，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n是我一直引頸期盼的。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "編織許多",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_054"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "像人類一樣交錯複雜的故事……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n讓我，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "見識更多、更多的故事。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "我衷心的",
        "unit_id": 191111,
        "voice": "vo_adv_4002002_055"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "這麼期盼著。",
        "unit_id": 191111
    }
]