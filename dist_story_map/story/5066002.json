[
    {
        "type": "background",
        "background": "501290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "回到時光隧道的{player}、祈梨、嘉夜三人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了返回原本的時間，正等待著時空之門開啟。"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "時間儀啟動中。",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_000"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n返回原始點的時空之門……",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "無法開啟。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "無法開啟……",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們回不去了？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎怎怎、",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼回事？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "檢查時間座標中……",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_003"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n因先前產生的時間矛盾，",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "原始點已損壞。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……所以狀況很糟嗎？",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_004"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "檢查損壞中……",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_005"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n根據檢查到的毀損狀況，",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "可勉強修復。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n是否執行原始點修復？",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來沒問題吧。",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那就趕快回去囉！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的沒問題嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "若修復成功便沒有問題。",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_008"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n是否執行原始點修復？",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "知道了。",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拜託了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "原始點修復中……",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_010"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "原始點修復中……",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "修復",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "成功。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n已確認通往修復後的原始點的連結。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n即將開啟時空之門。",
        "unit_id": 14611
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這裡是……",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "蘭德索爾",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "正確。",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_012"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n因之前產生的時間矛盾",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "而損壞的原始點已修復，\n目前處於修復後的時間軸。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也就是說",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們偏離了原本的時間是吧？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那是差了幾分鐘呀？",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_014"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "自修復前的原始點的時間算起，",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_015"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n這裡是四萬三千兩百分後的未來。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是哦，",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "四萬……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "四萬！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那是幾天啊！？",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_017"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "若換算成天數則為三十天。",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_018"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n現在分析時間矛盾影響的連續性。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊啊啊？",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那不就是一個月嗎！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n大有問題呀！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的假的啊……",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼辦？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總之先看看公會小屋的狀況吧……",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳等一下。",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n萬一又像剛才那樣",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "遇到這個時間的我們\n不就慘了嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對、",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n怎怎怎、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼辦才好呀？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "由於原始點已修復，",
        "unit_id": 14611,
        "voice": "vo_adv_5066002_024"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "因此於該時間軸未查出\n主人及陪同者的同位存在。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總之",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_025"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不必擔心會撞見自己是嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然確定沒事了就事不宜遲啦！",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_026"
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喂喂喂──！",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小子們！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "大幹部祈梨大人回來了唷！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "奇怪？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒有人耶……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真稀奇啊。",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "發生什麼事了嗎？",
        "unit_id": 116611
    },
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也好。",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在是大好機會！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我記得要把這個書架的開關……",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_030"
    },
    {
        "type": "background",
        "background": "501330"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好，",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_031"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "開了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n壺呢……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊啊啊啊！",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_032"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了？",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨！？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還在！",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_034"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個壺！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒事！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還好好的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼啊，",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_035"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別亂嚇人啦……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這下可以鬆口氣了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n祕密房間的魔導具也都還在……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊、",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_036"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊啊啊啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨，",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_037"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳又怎麼了？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不見了……",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_038"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯？",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "時間儀不就在這……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我不是說那個……",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_040"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那時候",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我拿走的魔杖不見了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這也不奇怪吧。",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為妳那時候把它拿走……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦，妳、",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該不會……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我好像把魔杖忘在那邊了啦啊啊啊啊！",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的假的啊……",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真沒辦法。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n只好回到剛才的時間點把它拿回來……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等等……",
        "unit_id": 116611,
        "voice": "vo_adv_5066002_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有人來了。",
        "unit_id": 116611
    },
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉嘉嘉、",
        "unit_id": 106611,
        "voice": "vo_adv_5066002_045"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該怎麼辦！？",
        "unit_id": 106611
    },
    {
