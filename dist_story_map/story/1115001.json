[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克莉絲提娜一個人走在因聖誕佳節而熱絡的\n蘭德索爾街上。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊好無聊。",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "世上的人們只要到了聖誕節就會雀躍地忘我，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但對我來說也太無聊了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要發生任何一個紛爭，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就能衝進去",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n激烈地打個痛快了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過聖誕節會散發出這種氛圍，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就表示城鎮很和平吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "接下來要去哪裡呢？",
        "unit_id": 311,
        "voice": "vo_adv_1115001_004"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "和你一起的話去哪都好！",
        "unit_id": 411,
        "voice": "vo_adv_1115001_005"
    },
    {
        "type": "dialogue",
        "name": "男性、女性",
        "words": "呵呵呵，啊哈哈……♪",
        "unit_id": 1,
        "voice": "vo_adv_1115001_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……每個傢伙都黏在一起，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到底哪裡好玩。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說不定嘗試看看會意外地開心？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……乾脆，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就試試看吧♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然如此就找個人，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n了結這份不慍不火的無聊吧……♪",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500115"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――打擾了！",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲提娜‧摩根，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n堂堂正正進來打擾了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是一如往常地粗心大意啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n剛剛毫無阻礙地就能入侵家裡囉？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是有我這種人闖進來的話該怎麼辦啊♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "早安☆　",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那對睡眼惺忪的眼睛……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才剛起來嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "已經不早了",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也差不多都要中午了啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n貪睡也要有個限度啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先不管這個了，小子。",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我克莉絲提娜",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來邀請你一起去聖誕約會了唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你幹嘛歪著頭愣在那。",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在世上",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正值聖誕佳節對吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是男人和女人忙著讓感情升溫的時期吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是我克莉絲提娜",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "選擇你這小子當對象唷？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n應該要表現得更雀躍、更高興吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？　",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看你的表情感覺不太懂啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是因為喪失記憶的關係吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原來如此，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣也有不同的樂趣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼就",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我把聖誕節烙印在你的身體上",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓你牢牢記住吧♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可能多少會有點痛喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉呀你不知道嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你是沒辦法從我身邊逃走的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有我這個美女在眼前，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "突然逃之夭夭是很失禮的行為喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明我這麼熱情地追求你了……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆　",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "疼痛什麼的只是開玩笑啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是稱讚一下你的直覺吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不這樣的話",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是沒辦法在戰場上生存下來的！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總之，",
        "unit_id": 107111,
        "voice": "vo_adv_1115001_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你沒有選擇的權利。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n乖乖當我打發時間的犧牲品吧♪",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――來吧，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "開心愉快的聖誕約會要開始了！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼又露出驚嚇的表情啊。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次又怎麼了？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "衣服？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你指這套服裝嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "剛剛有提到是聖誕約會吧？",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我認為做出相應的打扮是一種禮貌。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是當然。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要找到不適合我的東西還比較辛苦啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "剛剛你說的不錯，小子。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為我已經聽膩了過度奉承的讚美。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很久沒聽到這種",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "簡潔有力的稱讚了啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "照著這個步調",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "享受聖誕約會吧。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣離真正的約會還是有點距離，真令人在意呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n既然要做就要做徹底……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "吶，",
        "unit_id": 311,
        "voice": "vo_adv_1115001_030"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "手……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以牽妳的手嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "當然可以。",
        "unit_id": 411,
        "voice": "vo_adv_1115001_031"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "來吧，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "十指交扣吧……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性、女性",
        "words": "呵呵呵，啊哈哈……♪",
        "voice": "vo_adv_1115001_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n喂，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "手借我一下。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "牽手，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "手指和手指交扣……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是這樣的感覺嗎……？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "太軟弱了吧，小子。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "照這樣施力的話也許會把小子的手指給折斷……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "玩笑就開到這裡好了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "又想逃跑的話我會很困擾的。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你力氣滿大的嘛。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也有充滿男人味的一面嘛……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n比起一般的牽手，這種方式的肌膚接觸面積更多啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼樣，小子？　",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽說這就是所謂的十指緊扣喔？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉呀……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一臉不值一提的表情呀。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "覺得只是牽手也沒什麼了不起嗎？",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了你這小子可能早就習慣了吧。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那這樣如何？",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n像這樣挽著手……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如此一來就比牽手更親密了吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……還是很淡定啊。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我本來",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還期待",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "更純情的反應啊？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我對你這麼積極的身體接觸，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒反應也要有個限度。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是說怎麼樣？",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n覺得我克莉絲提娜沒有魅力嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這真是讓我有點驚訝。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原本想趁著約會隨便調戲一下這小子打發時間，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓他中圈套之類的……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒想到，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他也許是個強敵？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過這樣也好，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n即便是不用劍的戰鬥，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要是強敵就有打倒的價值♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣的話，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在還沒找到有效對付手段",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n的狀況下該怎麼攻陷他呢……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以閉上眼睛嗎……？",
        "unit_id": 311,
        "voice": "vo_adv_1115001_048"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "嗯，",
        "unit_id": 411,
        "voice": "vo_adv_1115001_049"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我知道了……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性、女性",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_1115001_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……從剛剛開始那些傢伙就在做什麼啊。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n害我都不自覺地想伸手拔劍了啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊不過，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即便是那小子……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果被親吻的話，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也會開心地雀躍起來吧？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，但是……",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果這樣還是沒反應的話，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不就不得不拔劍了嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就這樣不小心手滑也是沒辦法的。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然我不是那種會吝於一個吻的少女，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但到底為什麼",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會有這種難以割捨的情緒呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n想不通啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為對象是這傢伙？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼了小子，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "臉突然靠這麼近。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這小子，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該不會要學剛剛的傢伙吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "認真的嗎，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然可能只是想趁我沒防備時嚇嚇我，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別看我這樣，我克莉絲提娜可是討厭認輸的呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『絕對』不會退縮哦？",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n若只是單純想惡作劇，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "勸你還是放棄吧。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不會改變我的誓言。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n被考驗的可是你的覺悟喔？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……！",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很有趣，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就接受你的挑戰。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……應該閉上眼嗎？　",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "氛圍……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還不錯啦。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "心情比想像中",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還要激動呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "彷彿就像是少女啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個小子，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然本來就知道他有點難以預測，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但還真的滿知道怎麼討我歡心的嘛……！　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我這人只要說出『絕對』，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_066"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算這個吻會被奪走我也不會退縮……！　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "！",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_068"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……喂。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_069"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼要摸我的頭？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我頭上有積雪嗎？",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_070"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以才踮起腳啊？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此，",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "謝謝。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就對幫我整理儀容的你說聲感謝吧。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來小子。",
        "unit_id": 111511,
        "voice": "vo_adv_1115001_072"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我現在，",
        "unit_id": 111511
