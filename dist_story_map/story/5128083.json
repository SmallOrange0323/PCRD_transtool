[
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了，",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然新家也有了……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就來談談我們一直很在意的那件事吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥你",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "現在還是隸屬於【美食殿堂】對吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "明明都已經有我和咲戀這兩位妻子了，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但是現今也依然在和其他的女孩子來往。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看你這反應",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "應該是已經被叮嚀過了吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也不是",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想對你的交友關係",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說三道四。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可是，",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是發生了什麼不好的事，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不僅是我，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還有咲戀也會很傷心的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是變成那樣，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再怎麼說我也沒辦法輕易放過你哦？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來你似乎也明白了呢。",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然可能不需要我再多說什麼，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是這種事情得嚴格叮囑清楚才行。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我啊，",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想和大家一起變得幸福。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說真的，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也是會",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n想要一個人",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "獨占小哥你。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可是，",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果我那麼做的話，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這個家一定會變成讓人待不下去的家。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以，",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能夠偶爾獨占一下你就足夠了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不管是愛情，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還是時間，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們一家人一起分享吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我認為這才是家庭圓滿的祕訣呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……所以說。",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "首先就讓在場的兩人",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來分享愛情吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n咲戀她和孩子們一起出門了不是嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說我偷跑？",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不懂你在說什麼。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n好了，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "快點過來這邊吧……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我好好地抱抱你。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "像這樣，",
        "unit_id": 127612,
        "voice": "vo_adv_5128083_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在空閒的時間就可以了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也要讓我好好地",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感受到",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的愛哦……",
        "unit_id": 127612
    }
]