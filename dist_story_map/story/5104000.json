[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾市中心，獸人族的居住區。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在這人聲鼎沸的熱鬧街上，傳出一道特別響亮的孩子聲。"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所～以～說～！",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n昨天",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "忘了要幫家裡的忙是我的錯！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我希望妳不要說【王宮騎士團】的工作，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n以及大家的壞話啦！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "真是的，",
        "unit_id": 8511,
        "voice": "vo_adv_5104000_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "這孩子又在說這種話……！",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "每天都看到女兒精疲力盡地回家，有那個父母會不擔心？",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "妳昨天也是一回來",
        "unit_id": 8511,
        "voice": "vo_adv_5104000_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "就如同昏倒般睡著了！",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "難道是",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "大家都把工作推給妳……",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "才沒有這種事！",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n【王宮騎士團】的大家都是好人！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……不，",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也是有克莉絲提娜阿姨之類的例外。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "整體來說，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大致上，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "幾乎都是好人！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "真的嗎……？",
        "unit_id": 8511,
        "voice": "vo_adv_5104000_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "怎麼說，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "媽媽很擔心啊。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n在妳突然說出要加入【王宮騎士團】時也很擔心。\n",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "另外……",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊～～～",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好了啦！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我不想聽媽媽說教！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我要出門了，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣下去會遲到的！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "茉莉，",
        "unit_id": 414,
        "voice": "vo_adv_5104000_008"
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "妳今天也很有幹勁呢！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "這是今早剛採的蘋果，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "在工作前拿去吃吧！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇～",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就心懷感激地收下了！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那麼",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我出發了！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "我家女兒真是抱歉……",
        "unit_id": 8511,
        "voice": "vo_adv_5104000_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "那個，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "請問多少錢呢？",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "沒關係沒關係！",
        "unit_id": 414,
        "voice": "vo_adv_5104000_011"
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "茉莉",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "經常陪我兒子玩，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "\n還會來幫忙顧生意，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "實在受了她不少照顧呢。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "不過，",
        "unit_id": 414,
        "voice": "vo_adv_5104000_012"
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "身為父母還是會擔心吧……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "明明是個好孩子，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "為何會喜歡去那種地方……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "是啊……",
        "unit_id": 8511,
        "voice": "vo_adv_5104000_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "不過因為是那孩子的期望，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n我是希望盡可能",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "讓她去做自己想做的事。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊────！！",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因為拿到蘋果害我完全忘了！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n媽媽！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "今天的便當～～！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "但是看她這個樣子，",
        "unit_id": 8511,
        "voice": "vo_adv_5104000_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "實在讓人放心不下啊。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "……真是丟臉。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "哈哈！",
        "unit_id": 414,
        "voice": "vo_adv_5104000_016"
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "有精神最重要啊。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "茉莉",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "蔬果店的獸人族",
        "words": "順便再拿一個去吧！",
        "unit_id": 414
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳帶了蘋果來吃啊？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咬，",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嚼嚼……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "吞下。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳已經來啦。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "【王宮騎士團】的全員召集，",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這還真是稀奇，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "發生了什麼事嗎？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也不知道詳細情況。",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喔，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們的團長登場囉。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所有人，",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "聽我說。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n今天集合各位只為了一件事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然我想所有團員應該都已經知道了，",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n最近獸人族的首領會議，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "將會在蘭德索爾舉辦。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個，",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "首領會議是什麼？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是由統率各地區的",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "獸人族首領所召開的會議喔。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "由於獸人族有各自的社會制度及受任命的代表權限等等，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n深入了解的話，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就會發現各族的不同之處……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "社會制度……？",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "任命……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呃，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我記得好像有在【王宮騎士團】的",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "講座上的課本裡面看過！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊～",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是呢……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "用非常粗略的講法，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就是獸人族的大人物們",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會集合來開會喔。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嘿～",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "原來如此。",
        "unit_id": 100512
    },
    {
