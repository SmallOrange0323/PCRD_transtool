        "type": "dialogue",
        "name": "智",
        "words": "獸人族跟【王宮騎士團】的關係會變得更加惡化，",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_060"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真要講起來，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原因就在於妳先前引發的糾紛吧？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正是因為如此喔，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "智。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "公主殿下說是希望我這個製造與獸人族禍根的當事者，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n能前往出席兼謝罪呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別慌，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可是個一諾千金的女人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以相信我喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相對的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也請團長要好好遵守約定……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "約定……",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_064"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗎？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為了讓小克莉絲答應我提出的條件，",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_065"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也必須做出某種程度的讓步。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_066"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我們",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "做了一個約定。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在任務結束後，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "希望團長能認真跟我一戰……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是這樣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長每次面對我愛的呼喚，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n都只會給我冷淡的反應啊……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就像這樣！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……小克莉絲，",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_068"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我先前也說過吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不要突然就砍過來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然嘴上這麼說，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_069"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長妳還是只防守不攻擊啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n又不是無聊的劍術修行，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不是躲開",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是架開，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣熱情跟興致不就冷掉了嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_070"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要完成約定，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就能跟認真起來的團長戰鬥……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果團長最後反悔，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那樣我也能有",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拔劍一戰的理由。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論怎麼發展，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的劍都能因歡喜而顫抖。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就我個人而言，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "比較推薦後者就是囉♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_072"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這就不必了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我可不能讓可愛的部下",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也被牽扯進小克莉絲的暴行中。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_073"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真可惜♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唉，",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_074"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原來是這麼一回事啊……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我就覺得克莉絲提娜，",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_075"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不可能沒有",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "任何條件就聽從命令。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_076"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純也是做了一場豪賭呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n過去",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "人族與獸人族可是一路以血洗血互相抗爭……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "竟然要將這場兩族間的和平協議",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "交給這兩個人。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一方是",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_077"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "身為獸人族，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n卻加入【王宮騎士團】的團員。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "另一方",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是過去引發與獸人族爭端的當事者……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉雖然",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_078"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "覺得有隱瞞住自己是獸人族的事實……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但說實話，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "其他團員應該也都發現了吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_079"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正因為如此，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n茉莉也是",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "獸人族與人族順利共融……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "能為和平攜手合作",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最好的證明。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……話說如此，",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_080"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為茉莉本人覺得有順利騙過大家，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以無法跟她明說。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但、",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_081"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有這個人在場，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "別說增進感情，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n甚至有可能火上加油吧！？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳別說那麼冷淡的話啦，",
        "unit_id": 107111,
        "voice": "vo_adv_5104000_082"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "茉莉。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們不是要一起創造通往和平的道路嗎♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然應該會很辛苦，",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_083"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我相信茉莉能做得到。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想把這個任務交給妳，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳意下如何？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗚～",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_084"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "太狡猾了。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "聽到純這樣講，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我怎麼可能拒絕。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我",
        "unit_id": 100512,
        "voice": "vo_adv_5104000_085"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "知道了。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "既然是陛下跟純的命令就沒辦法了。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我會好好監視，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不讓阿姨做出奇怪的事！",
        "unit_id": 100512
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊…………",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_086"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼了嗎？",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_087"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我忘記跟茉莉說了。",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_088"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是關於",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茉莉這次的幫手。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個人不是小克莉絲……",
        "unit_id": 104711,
        "voice": "vo_adv_5104000_089"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊……",
        "unit_id": 103712,
        "voice": "vo_adv_5104000_090"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原來如此。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這真是值得信賴的夥伴♪",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "茉莉和克莉絲提娜吵吵鬧鬧地從王城的入口離開。"
    },
    {
