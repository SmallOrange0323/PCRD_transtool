    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "喜歡的食物是什麼？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "我是沒有什麼特別的意思啦。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只是",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "因為受人幫助，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n我覺得至少應該知道你的喜好而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真普通。",
        "unit_id": 109811,
        "voice": "vo_adv_6017301_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "普通到很無聊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n改成番薯吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "我沒有問你是哪一派啊。",
        "unit_id": 109811,
        "voice": "vo_adv_6017301_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不過我很推薦番薯喔。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "呵呵。",
        "unit_id": 109811,
        "voice": "vo_adv_6017301_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你的品味不錯呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "既然這樣，那我就做給你真正美味的蒸番薯吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "能夠吃到拉姆的蒸番薯，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你可要心懷感謝喔。",
        "unit_id": 109811
    }
]