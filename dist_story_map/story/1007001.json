    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁真是太好吃了！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這次就特別原諒你剛剛的事情喲！",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_021"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "會給宮子布丁的人，就不是壞人來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我叫做宮子來的～",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_022"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你叫什麼名字呢？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯，嗯。",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_023"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}，謝謝你給我的布丁喲～",
