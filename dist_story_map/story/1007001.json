        "voice": "vo_adv_1007001_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "得、得救了～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n剛剛好痛苦來的……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你覺得很抱歉嗎？",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那就用你的態度表現出來喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚，好過分呀……",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不能因為宮子是幽靈就這麼隨便對待人家～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子不會就這麼輕易原諒你來的～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你要把布丁交出來表示歉意喲～！",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n布丁～！布丁～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哇！是布丁來的～！",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_018"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子要開動了喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嚼啊嚼……嚼啊嚼……",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "多謝款待～！",
