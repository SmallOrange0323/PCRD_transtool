    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯……跟丟了～",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "應該是這個方向沒錯的。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "只要穿過建築物，應該就能找到的～",
        "unit_id": 100711
    },
    {
        "type": "still",
        "still": "100700101"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咻……",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，終於找到了～",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "果然是這個方向來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯？你幹嘛嚇成這樣啊？",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n……因為宮子從牆壁穿出來？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子是幽靈，所以就算有牆壁也無所謂來的～♪",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_011"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚哇！？",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_012"
    },
