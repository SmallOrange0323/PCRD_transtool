        "words": "{player}買了布丁要和夥伴們一起分享。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "布丁～布丁～",
        "unit_id": 1,
        "voice": "vo_adv_1007001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n好想吃布丁來的～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯嗯！",
        "unit_id": 1,
        "voice": "vo_adv_1007001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好香的味道喔～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是布丁的味道～從哪裡來的呢～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，找到了喲！",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是從這傢伙手上拿的袋子裡發出來的～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n好……偷～偷拿出來……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咦、咦？",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你看得見宮子嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子現在應該是隱形的呀～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔唔唔……",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你該不會是",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所謂靈感很強的人吧～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這樣的話，宮子就直接說了～",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n快把布丁交出來喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布～丁！布～丁！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊！逃跑了！",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "等等～！快交出布丁來的～！",
        "unit_id": 100711
