    {
        "type": "dialogue",
        "name": "宮子",
        "words": "快、",
        "unit_id": 100711,
        "voice": "vo_adv_1007001_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "快住手～",
        "unit_id": 100711
