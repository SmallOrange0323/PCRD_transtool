[
    {
        "type": "background",
        "background": "501622"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說回來，",
        "unit_id": 128711,
        "voice": "vo_adv_5137422_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「紅霧精靈」真的很強耶！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不愧是守護世界的精靈啊──！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "志那都跟埃拉被附身的時候，",
        "unit_id": 128911,
        "voice": "vo_adv_5137422_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我還想說不知道該怎麼辦才好呢。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她們的戰鬥力",
        "unit_id": 128812,
        "voice": "vo_adv_5137422_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原本就很驚人了，",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而紅霧精靈居然",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "操控那兩個人來攻擊我們。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能夠成功打倒精靈，",
        "unit_id": 128711,
        "voice": "vo_adv_5137422_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都是多虧有大家同心協力呢。",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣、",
        "unit_id": 128711,
        "voice": "vo_adv_5137422_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜、",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生、",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "菲歐……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "厄莉絲。",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有我……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n以及埃拉跟志那都。",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她們兩個直到最後的最後，",
        "unit_id": 128812,
        "voice": "vo_adv_5137422_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都在抵抗精靈。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以精靈",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也沒辦法奪走她們的一切吧。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算她們失去自我意識也一樣。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是啊。",
        "unit_id": 128911,
        "voice": "vo_adv_5137422_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n要是少了其中一個人，",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就沒有辦法打倒它了。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以……",
        "unit_id": 128911,
        "voice": "vo_adv_5137422_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝妳，",
        "unit_id": 128911,
        "voice": "vo_adv_5137422_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "厄莉絲。",
        "unit_id": 128911
    }
]