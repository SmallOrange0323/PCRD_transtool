[
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "～……♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很好，很好很好。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "今天的蘭德索爾也很平靜～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "天色也已經晚了，",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n差不多可以結束巡邏了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也沒有什麼特別的狀況，",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n明天再去公會報告……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "得先回家去店裡幫忙。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "晚上反倒是居酒屋生意最好的時候。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，那邊的那個人！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是叫你啦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n怎～麼啦，看你在這邊晃來晃去的……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～可疑人物。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉，能讓我盤查一下嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "最近上面的體制好像有不小的改變……",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "行政方面變得非常鬆散。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n該說是治安變亂了吧，有種不尋常的氛圍呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "災厄的幼苗得在成長起來之前摘掉才行。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，不用那麼緊張沒關係啦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你如果不是壞人，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我就沒有逮捕你的理由和必要了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對了……",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n雖然自我介紹得有點晚，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我叫真琴。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我隸屬於【哞哞自衛隊】，",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是獸人的互助組織【動物苑】旗下的公會。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，請多指教啦？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈哈，你彬彬有禮呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我不討厭你這種人哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n看來你應該不是壞人♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，一般人不太清楚啊……",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "像我們這樣的獸人，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n基本上都隸屬於名叫【動物苑】的公會哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "順帶一提，是「動物苑」，",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不是「園」是「苑」。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "字面的意思就是讓人覺得安穩的地方。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，名字怎麼取都無所謂就是了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n守護獸人們平靜生活的，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就是我們【哞哞自衛隊】的責任。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你啊，看起來只是個普通的人類……",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可不要涉入太多哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然也不可能和其他的種族完全無關。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過我還是希望不要引發什麼麻煩事，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n想大家和平共處。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "蘭德索爾基本上是一個普通的人類城鎮呢……",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們獸人啊，在這裡雖然有點不自在，不過也沒辦法啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，這不是重點。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之，能不能告訴我你的名字和公會？",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，你叫{player}啊。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……慢著，你說{player}？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你認不認識叫優衣的人？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "果然是！",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣她啊～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n說受到一個叫{player}的人幫助哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來是這樣啊，你就是優衣的恩人嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我早就想見你了～啊哈哈♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她真的非常感謝你哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她要我見到你的時候替她道個謝。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n謝謝你保護了優衣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她從以前開始就是個冒失鬼呢……♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊……我是優衣的兒時玩伴哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "多虧優衣，讓我了解到",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就算種族不同也能夠好好相處。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我非常感謝她。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然我們長大之後，彼此間的規矩也變多了……",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n和小時候相比，變得有點疏遠。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過到現在，她還是我最重要的朋友哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n優衣的恩人是不可能有什麼壞企圖的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那你為什麼這麼晚在街上晃來晃去的？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這樣啊，原來你迷路了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "蘭德索爾的街道，微妙地複雜呢……",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你找不到自己",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n投宿的旅館在哪裡對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好，我知道了。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不介意的話就由我帶路送你回旅館吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就當作是你幫助優衣的回報。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那就跟我來吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n走這裡、走這裡♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要客氣。",
        "unit_id": 104311,
        "voice": "vo_adv_1043001_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我是不會放著有困難的人不管的哦。",
        "unit_id": 104311
    }
]