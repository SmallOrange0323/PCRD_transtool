[
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "島鯨……",
        "unit_id": 107911,
        "voice": "vo_adv_5005011_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你錯了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n願望無法實現的話就不有趣？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n沒有那種事喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是因為難以實現，才有去做的價值喵。",
        "unit_id": 107911,
        "voice": "vo_adv_5005011_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我會和【墨丘利財團】的大家一起，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n活出比在這個島上更有趣的人生給你看喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒錯。",
        "unit_id": 108011,
        "voice": "vo_adv_5005011_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "夢想，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不是讓人去幫忙實現的東西。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是要用我們的手去抓住的東西喔。",
        "unit_id": 108011
    }
]