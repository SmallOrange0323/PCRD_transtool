[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人繼續往露娜之塔上方前進。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不過只是一語不發地前進。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號被挖角……？",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "很難以置信……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過她的確很優秀。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話雖如此，",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "她竟然要拋下相處這麼久的我……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "正因為",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "認識夠久，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也很清楚她是多追求合理的人……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "偷瞄……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "…………",
        "unit_id": 6111,
        "voice": "vo_adv_7024003_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "連看都不看這裡呢……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我才不擔心呢！",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然這樣，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我就靠自己的力量",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n來幫助陛下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "前方有一群魔物聚集。",
        "unit_id": 6111,
        "voice": "vo_adv_7024003_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "準備進行戰鬥。",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳待在最後方看著敵人的動向。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是的。",
        "unit_id": 6111,
        "voice": "vo_adv_7024003_008"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要上囉。",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_009"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "似似花在前陣迎擊魔物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和克蕾琪塔則是在後方掩護。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只要一進入戰鬥",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就無事可做啊……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "至少你還能幫忙強化啊。",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不像我真的只能在旁邊看……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "似似花小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_7024003_012"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "右前方有",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "敵軍增援。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n數量20。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我要直接壓制前線。",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n跟我來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "明白了。",
        "unit_id": 6111,
        "voice": "vo_adv_7024003_014"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "光是哭喪著臉也沒用。",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算我只能在一旁看著，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "至少能集中注意……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n只能把我握有的資源做最大化的利用了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "說不定",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就這樣被我找出了弱點呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話說……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這個叫似似花的魔法師的戰鬥方式……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總覺得有點不對勁，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好像有點奇怪呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "她在使用",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "分身對吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我曉得有些魔法道具可以做出分身，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是沒辦法像這樣簡單地出現、消失，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "更別說能自由自在地操縱了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果這是幻影魔法創造出來的分身，",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n幻影有辦法施放魔法……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那看起來簡直像是",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "本體自由地在不同分身間穿梭……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這不過是猜想罷了。",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "看來你比較清楚呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那究竟是怎麼回事……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是的……",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "淑女的祕密可不行隨便說出去啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼……？",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n咦？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳剛才",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不是還在那裡戰鬥……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在被包圍前我們貫穿過去。",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "敵人數量最少的地方在哪裡？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "中間有大型魔物。",
        "unit_id": 6111,
        "voice": "vo_adv_7024003_025"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n只要擊倒它",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "應該就能開出一個洞。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "知道了。",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n讓它消失吧。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳不是在最前線迎擊嗎？",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那我現在眼前的妳究竟是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳就說說",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳的猜想讓我當參考吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我來幫妳審查看看。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好啊……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n正在迎擊的妳和我面前的妳，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "兩邊都擁有自我意識。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因此，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這應該不是幻影也不是自動人偶……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這有兩種可能，",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一個是原本就有叫做似似花的兩個人物。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n或者是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "用不明手段",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "讓同一個人分裂。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哦。",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "後者比較恐怖呢。",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n如果只有兩個人的話至少能分開擊倒。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果會不斷分裂的話那就沒完沒了了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我從妳老神在在的樣子……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感受到這種恐怖。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此，",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算妳及格吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼要如此大費周章？",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "兩個人一起上的話",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "應該很輕易就能打倒敵人……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳覺得是為什麼呢？",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_036"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "依我猜想，",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可能是因為其中一方並無戰鬥力，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n只能夠負責監視。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "說不定連我都能打贏……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳要試試看嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……還是算了吧。",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_039"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳最令人恐懼的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並不是魔法技巧……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "像現在妳和我談話的時候，",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n另一個妳",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "正在和秘書一號一起迎擊魔物……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也就是說",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "存在著多個有思考能力的同一號人物。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如妳這般造詣的魔法師，",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_041"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "竟然在世間默默無聞，那原因恐怕是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因為妳不想被發現……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一般人不可能如此徹底保守祕密。",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_042"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳卻擁有這樣的力量。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "喔……",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說得好，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "繼續講。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳的本領是",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_044"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "使用這份能力進行諜報……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只要用分身或變身潛入，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n無論什麼組織都沒辦法保守祕密。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可以說幾乎全對呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來妳比我想像得還要聰明呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這樣糟糕的能力……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_046"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要不是我親眼看見實在無法相信。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這種東西，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "簡直像童話故事裡的七……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "到此為止，",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "別再說下去了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我只是陪妳這個小人物玩玩而已，",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要是妳隨便探究……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "明白吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_049"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說到底，",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的真實身分",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和妳又有何相干？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然有啊。",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "像妳這種擁有怪物般力量的人存在……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "比起我，陛下更寵愛妳",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也無可奈何。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就是因為我不中用……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_052"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n陛下才會找妳來",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n監視我呢……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唉……",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳竟然在意這種無聊的小事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "無聊小事？",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_054"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳竟然說這是無聊小事？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳說我的忠義無聊？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳嘴上說著忠義，",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但實在很膚淺。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "難不成妳所謂的忠義",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不和他人比較就無法確定嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要我說的話，",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這種忠義根本是假的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "竟然說我的忠義……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_057"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "假的……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳其實自己也有自覺吧？",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以才會",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "整天把忠義掛在嘴上。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "到頭來……",
        "unit_id": 118011,
        "voice": "vo_adv_7024003_059"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我還是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "心裡只在乎得失的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "商人嗎……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼了？",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你該不會",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在擔心她吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "公主也好你也好，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們真的是想法很天真。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她過去",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "曾和想要殺公主的一夥人有關係……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼可以隨便相信呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話說……",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_062"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "虧我都親自出馬了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "結果卻如此無趣。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你沒有察覺到嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_063"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要說的話，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "調查塔只是順便。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在聽到你講的事情後，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就有了幾個猜測。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我真正的目的是……",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_064"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "摸清",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克蕾琪塔‧凱許的底細。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算本人沒有這個意圖，",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_065"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並不代表沒有幕後黑手。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要對方不再和我們作對就好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是對方不這麼想的話……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了保護你",
        "unit_id": 107011,
        "voice": "vo_adv_7024003_066"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我可是會不擇手段。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "她自信的說道，語畢同時，受到最前線的似似花的攻擊"
