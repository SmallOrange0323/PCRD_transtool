[
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "嗯……",
        "unit_id": 16711,
        "voice": "vo_adv_5102322_000"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "你們還滿能打的嘛。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "……哎呀，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "這些是……",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼……",
        "unit_id": 123711,
        "voice": "vo_adv_5102322_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那是！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n怎麼長得跟我們一樣……！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "呵呵呵。",
        "unit_id": 16711,
        "voice": "vo_adv_5102322_002"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "看來就連非人類族群，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n也成了我的粉絲了。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "如果是一般粉絲，",
        "unit_id": 16711,
        "voice": "vo_adv_5102322_003"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我是絕對不會讓他們遇險的，但……",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "這群女孩應該不用我擔心。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我就借用她們的力量吧。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 123611,
        "voice": "vo_adv_5102322_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們才不會輸給冒牌貨！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會直接",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "殺出一條活路的！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "氣勢十足呢。",
        "unit_id": 123511,
        "voice": "vo_adv_5102322_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也有相同想法喔。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像該拿些幹勁出了。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……啊，",
        "unit_id": 123511,
        "voice": "vo_adv_5102322_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說回來，七七香妳可能要小心一點喔。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為對面的那個我",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像進入有福不用忙模式了。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 123711,
        "voice": "vo_adv_5102322_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那、",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那也就是說？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對面那些傢伙對抗魔法的能力會變強。",
        "unit_id": 123511,
        "voice": "vo_adv_5102322_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼！？",
        "unit_id": 123711,
        "voice": "vo_adv_5102322_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "輝美閣下會把我的魔法砍得七零八落！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n冒牌鈴閣下又有魔法抗性！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我這次的處境",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也太艱難了吧！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……嗯，",
        "unit_id": 123711,
        "voice": "vo_adv_5102322_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也罷！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "管她有抗性還是有什麼，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n反正只要狂施魔法直到有效為止就是了！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要上囉──！",
        "unit_id": 123711
    }
]