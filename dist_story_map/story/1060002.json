[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喵～……♪",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喵、喵～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喵～……♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……喵！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、你不要突然跟我搭話啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，是你啊？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在這種地方幹嘛啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問我？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我～……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟、跟你沒有關係吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（可惡～失敗了！",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才想說～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也潛伏在這傢伙住宿的飯店附近，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n來監視這傢伙的舉動而已！）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（嗯，畢竟那是我的任務！）",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（可是我又不知道使用飯店的方法，",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也沒有任何像住址之類可以證明身份的東西……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以被旅館的人覺得可疑，只好逃出來了啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（我也不想被這種小事阻擾，害任務失敗……",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是我已經報備說今天要住在外面，沒辦法回去王宮～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在正在煩惱著無處可去呢。）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（然後，不知道為什麼貓咪們都聚集過來了。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以我就在這裡摸牠們、餵牠們吃買來的飼料囉。）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（這麼奇怪的情節，我又不能對這傢伙說。）",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n幹嘛，你那副表情……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、你有意見嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你、你幹嘛擔心我啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "自大狂！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的……",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你還真是個奇怪的傢伙呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊、嗯……",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經這麼晚了，會打擾到附近住家呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被你搞得好像我連常識都不懂，真火大啊～……？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問我為什麼發出奇怪的聲音？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為我發出喵喵的叫聲，所以你才過來看我的嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你還真是好奇寶寶呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖說是在城鎮內，但最近蘭德索爾的治安也不好，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你還是不要隨便出來亂晃比較好喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說我也一樣？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也對～而且我才剛痊癒……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果遭到流氓的襲擊，我也抵抗不了啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，算了，我還是回家吧。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就跟陛下說好像被這傢伙發現了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以才趕快跑回來躲～之類的藉口吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，與其說被發現，",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n根本就是面對面地聊起來了啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～怎麼這麼不順利啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，我說出來了嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就當作沒聽到吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把它忘了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拜託啦♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉呀呀……",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貓咪們怎麼開始爬到我衣服上啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快住手～會沾到毛啦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要當乖寶寶啊，喵喵♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你幹嘛啊，一直盯著我看……貓咪很稀奇嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊對了，你好像是記憶喪失了吧？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個是叫做貓咪的動物喔，很可愛吧 ♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你要抱看看嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "輕輕的喔，小心不要讓牠掉下去囉？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貓咪很不喜歡你呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被抓到就糟糕了，把牠放回這邊。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貓咪的爪子跟嘴上可是有很多細菌的，會感染破傷風喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘿咻……",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～好溫暖 ♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹嘛啊，你不要一直盯著我看啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你說貓咪很喜歡我嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈……",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我很容易被動物或魔物之類的親近喔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有些原因啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是因為我的特殊性質，",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以我不覺得貓咪們有特別喜歡我。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為，",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一定不會有人愛我的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要知道了真正的我，大家大概都會變得討厭我吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你說你喜歡我？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨～蛋。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要這麼輕易就對不太了解的人說喜歡啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是搞不懂你這傢伙",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種事情，你應該講給更應該被愛的好人聽。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n果然到了半夜，就會覺得有點冷呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趁還沒感冒之前，我要先回去啦。",
        "unit_id": 106012,
        "voice": "vo_adv_1060002_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
