[
    {
        "type": "background",
        "background": "500024"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在看完了元旦日出之後，\n便到了優衣老家的店裡，幫忙準備要發送的年糕。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……米也都蒸熟了，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "準備好了。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然現在要開始做年糕了……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但你知道年糕是什麼嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼說呢，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們得要杵搗這些一粒一粒的白米，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n一邊搗碎一邊把它塑型成一整塊唷。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒錯。",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有擺了一些在神殿上裝飾呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個也是用和這邊一樣的白米搗出來，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "然後再塑型成一整塊的唷。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "神殿上看到的鏡餅，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為得放在那供奉比較長的時間，所以都硬掉了呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是呢，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個在之後，大家也會一起分著吃掉的唷。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "年糕就算變硬了，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只要浸在水裡的話，就又會變軟囉。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n在這個時期，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只要好好保存就能放很久，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可說是相當便利的食品呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "搗年糕的部分就由我來做吧，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生的話，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就麻煩你負責把年糕揉在一起了唷。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是喔。",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "難不成你想試試看",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "搗年糕的嗎……？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然往常都是乖乖用杵來搗的，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但今年為了順便修行，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以我想用魔法來搗年糕試試看。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果我能把魔力控制得比現在更細緻，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也許就能學會更多魔法了也說不定。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你願意幫我嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你！",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼就，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "差不多該開始了呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n首先把加溫臼用的熱水給倒掉……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在輕輕擦過臼之後，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再把蒸好的糯米都……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "倒進去！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一開始讓我把",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "米的外型碾碎，直到被搗爛為止，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生就先看著吧。",
        "unit_id": 108811
    },
    {
        "type": "still",
        "still": "108800201"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "開始囉……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘿～！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "感覺不錯……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就照這樣小心，不要弄錯力量的大小，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一面讓魔力的量保持均衡，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再發動更快速一點，應該就沒問題了……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "搗到變成這樣應該就夠了呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從這開始，騎士先生，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就麻煩你幫忙了唷。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當我搗了一次年糕後，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你就用手，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "把年糕往正中間集中並且拌在一起。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩個人保持著默契，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n一邊維持著固定的節奏一邊小心來做吧。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼我要開始了唷……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘿！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘿！",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……果然會變成這樣呢。",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生他，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "開始配合起我的指示做動作了……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "差一點點就……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "明明就不能分心去想其他的事呀……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n如果魔力的調節失敗了的話，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可就大事不妙了啊。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果、",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然對現在的我來說，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要這樣做還是太難了呢……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯、",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我知道了！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "吸……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "吐……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太用力……？",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……真的呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從什麼時候開始就這麼……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你告訴我，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "用力過頭太僵硬就不好了呢。",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "並不是靠身體，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "術式的展開靠的是心靈……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "盡可能把魔力凝聚起來……",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n並且將意識給集中……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘿！",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛剛的感覺不錯！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "若身體能夠把這感覺記起來的話，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該就能好好搗到最後了！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵！",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生伸手揉的動作，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也比剛才流暢很多了。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這麼說起來，",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然和騎士先生有一起戰鬥過的經驗，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但像這樣，互相在意著對方一起做同件事，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是第一次呢……",
        "unit_id": 108811
    },
    {
        "type": "still",
        "still": "108800202"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 108811,
        "voice": "vo_adv_1088002_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "難不成這是，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我和騎士先生第一次的共同作業……！？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "附近的女性1",
        "words": "哎呀？",
        "unit_id": 411,
        "voice": "vo_adv_1088002_038"
    },
    {
        "type": "dialogue",
        "name": "附近的女性1",
        "words": "優衣妹妹正在搗年糕呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "附近的女性1",
        "words": "\n會幫忙店裡的事情，真乖呢。",
        "unit_id": 411
    },
