    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "登登登登登登！",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我要發表囉！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "經過嚴謹考量後……",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我決定要邀請",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "鈴奈加入大奧！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大奧是",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這世上最",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "絢爛豪華的",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "美麗場所是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n鈴奈可是",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "以模特兒身分，",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "引領蘭德索爾流行",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "的人！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一定",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "會把大奧",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "點綴得很美好是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "她一定",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也會為將軍",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "選擇流行服飾吧！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n時髦的將軍",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "肯定",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "會很棒是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且鈴奈的話，",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一定會這麼說是也……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "妮諾～～～！！！",
        "unit_id": 1,
        "voice": "vo_adv_5207067_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "\n妳看妳看～～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "來幫人家",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "搬一下東西！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "鈴、",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "鈴奈～～～！？",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那到底是什麼是也！？",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n堆積如山的蝴蝶結、",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "玩偶",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和氣球……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看起來不是",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要給將軍的禮物是也……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "對對對！",
        "unit_id": 1,
        "voice": "vo_adv_5207067_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "人家是聽說秀才將軍的家蓋好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "\n才過來玩的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "但這是不是有點不起眼？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "\n真的是冷冷清清啾啾～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "所以說──♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "在老虎的掛毯上",
        "unit_id": 1,
        "voice": "vo_adv_5207067_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "加個蝴蝶結～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "\n再給",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "金色的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "門",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "這樣",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "那樣……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "\n加上蝴蝶結，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "肯定會非常可愛吧♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "至於這邊的樹～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊哇哇哇哇，",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "庭院的松樹上",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "開了氣球花～～！？",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n大奧",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "逐漸",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "被改造成鈴奈的風格了──！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這也太驚人了是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "然後啊──",
        "unit_id": 1,
        "voice": "vo_adv_5207067_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "這是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "秀才將軍的衣服！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "是新大奧風喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "\n就讓將軍",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "穿上這個，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "在碎紙花下",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "登場吧♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "\n衣服",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "當然也準備了",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈？",
        "words": "咱們的份～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "居然是金黃色……！",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這就是",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大奧的時尚最前線……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "鈴奈，",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太棒了是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然跟我在祕密特集號",
        "unit_id": 137111,
        "voice": "vo_adv_5207067_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看到的大奧",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有些不同……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但這樣",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "感覺也很嗨！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祕密大奧名冊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n追加了一個人的資料。"
    }
]