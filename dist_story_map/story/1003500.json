    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聽你一說，我就馬上趕過來了，",
        "unit_id": 100311,
        "voice": "vo_adv_1003500_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是不是讓你等很久了呢？",
