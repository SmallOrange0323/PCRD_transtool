    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "終於成功打倒啦！",
        "unit_id": 106011,
        "voice": "vo_adv_5084422_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "支援得好。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雪菲，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不少次都讓妳出手相救啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也十分感謝，",
        "unit_id": 105911,
        "voice": "vo_adv_5084422_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n多虧有凱留小姐願意在前方打頭陣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令在下感到十分安心。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然偶爾會讓人分不清楚是發出悲鳴還是在詠唱魔法，",
        "unit_id": 106411,
        "voice": "vo_adv_5084422_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但凱留剛才還是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很帥氣的喔。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "用、",
        "unit_id": 106011,
        "voice": "vo_adv_5084422_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "用不著勉強誇獎我啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n老實說，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我太過拼命戰鬥，已經連自己在做什麼都搞不清楚了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……貪吃佩可她",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真有辦法老是做這種事呀。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實，",
        "unit_id": 105911,
        "voice": "vo_adv_5084422_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次親身體會到其艱辛了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也體會到那個人的力量",
        "unit_id": 106411,
        "voice": "vo_adv_5084422_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對我們來說有多重要……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5084422_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……好啦！",
        "unit_id": 106011,
        "voice": "vo_adv_5084422_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "差不多該回去了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們可還有很多事得做呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全部交給我吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_5084422_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說得也是呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得趁凱留小姐還充滿幹勁的時候，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n將累積的委託給處理一下才行。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不曉得其他委託是什麼樣的內容呢。",
        "unit_id": 106411,
        "voice": "vo_adv_5084422_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n記得似乎有親身測試藥劑的實驗數據、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "陪人說相聲之類的……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "工作告一段落後，",
        "unit_id": 106011,
        "voice": "vo_adv_5084422_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然還是得休息一下才行呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我看今天就先休息了吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣比較好！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "凱留小姐……",
        "unit_id": 1,
        "voice": "vo_adv_5084422_011"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "\n凱留……",
        "unit_id": 1
    }
]