[
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "救援任務結束後過了好一陣子，鈴一如往常地沒有在工作，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和{player}一起在房間裡懶散地度過。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哼哼～",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "從大白天開始就不工作，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一邊打滾一邊品嘗到的",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n紅豆麵包真是太讚了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "甜到好像要融化了一樣～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "從上次那件事之後就沒有派新的任務過來了，",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然和平才是最棒的呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不要再提那件事了啦～",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就說那只是單純的偶然罷了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "希望【哞哞自衛隊】也不要對我有什麼期待。",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但如果是撿橡子之類的任務，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我倒是可以考慮看看啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是誰啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好的～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "請進～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "打擾了。",
        "unit_id": 414,
        "voice": "vo_adv_1127002_005"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "請問妳就是鈴小姐嗎？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是沒錯啦……",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼事？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你是誰？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我是隸屬於【動物苑】的人。",
        "unit_id": 414,
        "voice": "vo_adv_1127002_007"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "今天是來通知妳",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n【動物苑】想直接委託妳工作。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼？",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "抱歉，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不太明白你在說什麼。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "【動物苑】要找我？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那絕對",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是搞錯人了吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不，",
        "unit_id": 414,
        "voice": "vo_adv_1127002_009"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "沒有搞錯。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我們想請鈴小姐妳",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "與我和其他公會合作，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n參與潛入盜賊團基地、",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "解放人質，\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "以及討伐盜賊團的任務。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那些應該是【哞哞自衛隊】的工作吧！",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你看看，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這又大又可愛的尾巴。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是松鼠欸，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "松鼠。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不適合做粗魯的事啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "詳細內容都寫在這些文件上了。",
        "unit_id": 414,
        "voice": "vo_adv_1127002_011"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n請妳仔細閱讀一下。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸你有在聽嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哈囉哈囉～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "聽得見我說話嗎～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "……鈴小姐。",
        "unit_id": 414,
        "voice": "vo_adv_1127002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎、",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎樣？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你有什麼不滿嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真要說的話",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我比你還要不滿一百倍喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不。",
        "unit_id": 414,
        "voice": "vo_adv_1127002_015"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我很期待",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳大顯身手喔。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼……",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "剛才那是怎樣！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那種意味深遠的說法是怎樣！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "他是在挖苦我嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是是認真的？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好可怕～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這種來路不明的事情真的很可怕欸～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……我知道了，",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "逃跑好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要救遇難者也就算了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但要去挑戰盜賊團，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "根本就跟去找死一樣嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你看，",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "文件上也寫著一些很強的公會成員的名字啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "少我一個人去也沒關係的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這、",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這報酬金額是怎麼回事啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要是能拿到這麼多錢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不但可以把想要的遊戲全買起來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還能過用找的錢吃高級紅豆麵包的奢華生活耶？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……可是，",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對方是盜賊團欸？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很可怕，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "又很危險。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是我又好想要錢哦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不、",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不是啦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這是……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喂，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不要擅自開始準備起鎧甲啦～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉，",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是沒辦法，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就去",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "跟在大家後面走吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "然後",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "假裝有在戰鬥，蒙混過去好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你想笑我就笑吧，",
        "unit_id": 102611,
        "voice": "vo_adv_1127002_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這就是弱者的生存戰略！",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉，",
        "unit_id": 112711,
        "voice": "vo_adv_1127002_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "抵達集合地點了……",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_1127002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總、",
        "unit_id": 112711,
        "voice": "vo_adv_1127002_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總覺得大家好像都在看我這邊？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這也是理所當然的吧。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n畢竟來的不是【哞哞自衛隊】的大家，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而是我嘛。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺就會被嫌棄說",
        "unit_id": 112711,
        "voice": "vo_adv_1127002_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "「這種小姑娘做得了什麼？」",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好討厭喔～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過既然沒人期待我，應該很容易偷懶。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "她就是傳聞中的那位？",
        "unit_id": 1211,
        "voice": "vo_adv_1127002_028"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "看起來就只是個普通的女孩子啊……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳仔細看。",
        "unit_id": 414,
        "voice": "vo_adv_1127002_029"
    },
    {
