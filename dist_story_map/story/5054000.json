[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咲戀身穿「派對禮服」、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n別上「黃金玫瑰胸針」，手裡握著「一封信」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n走在蘭德索爾冬天的街道上。"
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "「給肩負著蘭德索爾未來，",
        "unit_id": 1,
        "voice": "vo_adv_5054000_000"
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "特別的紳士淑女們。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "「被玫瑰選中的您，",
        "unit_id": 1,
        "voice": "vo_adv_5054000_001"
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "受邀參加愛的交流會，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "\n一起共度如美夢般",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "特別的一天吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "\n誠摯等候您的到來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "──愛的使者",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "邀請函",
        "words": "薔薇假面。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……收到這種可疑的邀請函時，",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "本來還想說要拒絕呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "送信來的人，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼看都確實像是",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n「貴族大人的差使」……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼一想，",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也能夠理解這種拐彎抹角的文體了。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n聚集各個名門出身的紳士淑女的社交界……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無論從哪個角度來評估，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這都是個",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "談生意的大好機會呢！　",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟我的貴族身分只有名號，",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也還只是個初出茅廬的企業家，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最重要的是，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想和育幼院的大家一起",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "過一個經費充足的\n聖誕節啊。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然如此，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "即便覺得可疑，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也只能選擇參加了！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再說鈴莓",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還幫我把舊衣服改造成這～麼美麗的禮服，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要是沒有談成比平時還多一倍的合約量，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就太不划算了！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這次的戰場是",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "蘭德索爾廣場！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我要卯足全力",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "參加囉！　",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀──！！！！！",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……該不會。",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔～呵呵呵！",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n果然是咲戀！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳那身禮服",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "很適合妳喔！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃的禮服也很適合喔。",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我本來還以為妳又要從空中出現了……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "搭乘",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那輛豪華馬車來的人",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是秋乃嗎？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是呀。",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "其實是",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "美冬她帶著一臉非常嚴肅的表情來找我，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n說著「【墨丘利財團】",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要動員全公會人員",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "去打工！」，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "結果就把飛空艇也一起開走了……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我只好非不得已",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "搭馬車來。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來如此。",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然是全公會人員，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那為什麼秋乃會在這裡？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我原本也打算要打幫忙，但……",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "她說「這工作",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對秋乃來說有點難」，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "於是",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "回絕了我。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就在那時，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我正好看到這封邀請函和胸針，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "便來參加了。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "被人宣告在戰力之外，",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "讓我很不甘心……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我要在派對中宣傳公會，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "並同時與所有參加者談成生意，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n拿出不輸給美冬她們的成果！！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真不愧是秋乃，",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也不能輸給妳呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵♪",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖然早有料想，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但咲戀果然也抱持同一個目的呀！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既然如此，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要不要來比賽……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n誰能夠談成更多的合約呢？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和我嗎？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……好啊。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也想看看秋乃",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "露出不甘心的表情呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那句話是我要說的！",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……啊，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳看那裡！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n能看到雪人的裝飾了！",
        "unit_id": 114411
    },
    {
        "type": "still",
        "still": "505400001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那裡就是會場嗎？",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來是呢。",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "信上寫著「若是迷路了，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請將雪人當作路標。」",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣的",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "附註呀。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……話又說回來，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還真是巨大的雪人呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n的確，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有此物當指標或許就不會迷路了……",
        "unit_id": 114511
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀，",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "現在可不是受到震撼的時候！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "比賽早已經開始！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n所以……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就由我先發制人囉───！！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等！！",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n……真是的，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她還是老樣子呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n秋乃！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那邊不是會場啦──！！",
        "unit_id": 114511
    },
    {
        "type": "background",
        "background": "500874"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "那麼，",
        "unit_id": 6211,
        "voice": "vo_adv_5054000_022"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "在派對開始前，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "先讓我和各位打聲招呼……",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "本次的活動",
        "unit_id": 6211,
        "voice": "vo_adv_5054000_023"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "由支撐著蘭德索爾的議員們募集資金，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "並以「聲援肩負蘭德索爾未來的年輕人們」",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "這項期許為主旨",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n所企劃而成。",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "希望能讓各位",
        "unit_id": 6211,
        "voice": "vo_adv_5054000_024"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n提早",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "享受一個",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "特別的聖誕節──",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}！",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人！",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我說啊，",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在不是高興的時候。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你來這裡一下……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是的。",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "秋乃‧紫藤",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在此參上。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我想你應該是有什麼理由才來參加，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但請先過來這裡一下。",
        "unit_id": 114411
    },
    {
        "type": "background",
        "background": "500874"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好了，",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這舞台後台的地方，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大概暫時也不會有人來吧，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們可要好好問個清楚了！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為什麼會在這種地方！？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "招待客人的打工？",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那也就是說……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也就是說，",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你是被僱用來",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "湊人數了呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但看你那個樣子，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你連工作內容都沒搞清楚",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就去應徵了對吧！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊啊，",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來是這個樣子呀！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "太好了……\n太好了呢……",
        "unit_id": 1,
        "voice": "vo_adv_5054000_034"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……呃、",
        "unit_id": 114411,
        "voice": "vo_adv_5054000_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我說「太好了」的意思是，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "除了我們之外",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n也有其他人因為誤會跑來參加，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "讓我覺得鬆了一口氣……！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒錯沒錯！",
        "unit_id": 114511,
        "voice": "vo_adv_5054000_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們也",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和你一樣呢！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……接下來",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "事情到底會怎麼發展……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "那麼，",
        "unit_id": 6211,
        "voice": "vo_adv_5054000_037"
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "請問各位準備好了嗎？",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "擁有財力、",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "地位和",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "名聲……",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "被挑選出來的100位年輕男女們，",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "\n全力以赴尋找自己命運之人的",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "相親活動……",
        "unit_id": 6211
    },
    {
        "type": "dialogue",
        "name": "薔薇假面",
        "words": "「名媛初登夢想秘境」，現在正式開始！！",
        "unit_id": 6211,
        "voice": "vo_adv_5054000_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "怎麼辦……？\n要怎麼辦呢……？　",
        "unit_id": 1,
        "voice": "vo_adv_5054000_039"
    }
]