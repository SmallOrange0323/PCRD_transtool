[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿正在為了{player}下廚。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下剛才從蔬果店",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "買了新鮮的蔬菜，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n立刻為您做成沙拉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請耐心稍候片刻。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽說自從上次那件事之後，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位農民先生",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n比以往還來得更加熱心栽種蔬菜呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且他還會在有空時，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "親自跑到蘭德索爾的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蔬果店去送蔬菜，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不再全部委託業者送貨了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n聽說他是想多和買自己種的菜",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的顧客們交流。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今日農夫先生並沒有來送貨，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但或許往後有機會，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能在蔬果店遇見他呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那道光是……",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "唉……",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_005"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呀嗚！",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_006"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人！？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真、",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_007"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真不好意思……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "讓您目睹在下難為情的模樣了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人也是",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_008"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "已經放學，準備回家嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "若是您",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_009"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "稍後有空，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n可以稍微",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "撥點時間給在下嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "感謝您。",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_010"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在此站著閒聊也不是辦法，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "可否請您和在下一起移動到別的場所去呢？",
        "unit_id": 105931
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這裡沒什麼人會來，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_011"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n應該能靜下心來慢慢閒聊。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "沒想到能於放學後",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_012"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "與主人共度片刻，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "簡直像在約會一般，令在下十分開心。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_013"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "差點忘記了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下想談的話題，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "絕非像討論約會那般愉快……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是學校所出的作文作業，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "讓在下有些煩惱……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "因此希望主人",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能給在下一些建言。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "作文題目是",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "「我將來想成為的人」……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "以前在下也和主人提過，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n米奈娃曾說過，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下將來",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "應有望成長為",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n足以與父親",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "並駕齊驅的人才。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "當時聽到那句話時，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下的胸中充滿雀躍，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n立即相信了她，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "並且一直以來對此未來深信不疑。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但是……",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "究竟，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下本身有沒有米奈娃所說的才能呢？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "當在面對本次的作文題目時，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下的心情突然感到停滯不前。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下並非是在懷疑主人、",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "米奈娃、",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還有自己的父親。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "只是……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下對自己並沒有自信。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "由於在下只有11歲，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "因此會對於太過遙遠的將來，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n感到一陣茫然及不安。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而目前在下的",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "作文稿紙上只寫了自己的名字，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "再這樣下去，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "恐怕會來不及在期限內繳交……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚哇～！",
        "unit_id": 231,
        "voice": "vo_adv_1805004_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "咦，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_022"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那名少女怎麼了……？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "該不會是，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "碰上了最近謠傳會在",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n椿丘附近出沒的變態人士吧？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "妳怎麼了嗎？",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_023"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "氣球飛走了～！",
        "unit_id": 231,
        "voice": "vo_adv_1805004_024"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n剛才我跌倒的時候……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "手上的氣球就……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n嗚哇～！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "看來她跌倒的時候",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_025"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不小心把氣球放走了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "唔姆……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "氣球卡在那邊的樹上了呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還請放心吧。",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_026"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下會去幫妳拿回來的。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "喝！",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_027"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呀！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "唔姆……",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_028"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下的",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "身高及跳躍力都不夠，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "連綁在氣球上的線",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "都勾不著呀……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就只差",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_029"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "一點點而已了……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "看似觸手可及，卻怎麼也摸不著，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真是令人相當不甘心哪。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "連個氣球也拿不回來，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_030"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下究竟真的有能力",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "辦到其他的事情嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為何米奈娃",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_031"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "會對這樣的在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "說出那種話呢……？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "照現在這樣，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下不認為自己將來能夠回應她的期待……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_032"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下對自己越來越沒自信了……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呀啊！？",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_033"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊、",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人！？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_034"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為何突然把在下揹到肩上……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下已經不是",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "會因為這種事開心的年紀……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "樹木的周遭",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_035"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有蝴蝶在飛呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n因為坐在主人的肩上，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下的視線與",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在空中飛舞的蝴蝶對上了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……而且，世界感覺變得更寬闊了。",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_036"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下的煩惱，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "對這個世界而言，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "或許根本微不足道也不一定。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不對。",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_037"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下不能繼續呆看著蝴蝶了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n得拿回氣球才行……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嘿呀！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "來，給妳。",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_038"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n要小心別再跌倒了喔。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "大姊姊，",
        "unit_id": 231,
        "voice": "vo_adv_1805004_039"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "謝謝妳～！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_040"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "感謝您的幫忙。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "若沒有主人",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_041"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "幫忙把在下揹在肩上，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下連拿回氣球都辦不到。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "果然主人",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_042"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "對在下而言，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是不可或缺的人……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……嗯？",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "180500401"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "哇……♪",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_043"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n剛才的蝴蝶",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "飛回來了呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n它拍打著那對美麗的翅膀，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "於在下身邊飛舞著。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下總有一天也想像蝴蝶一樣，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_044"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "自在地飛翔，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n飛得又高、又遠……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "唔姆……",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_045"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "即使是現在靠著自己的翅膀飛翔著的蝴蝶，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n剛出生時",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也是只能在地上爬行的小毛蟲。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "同樣道理，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_046"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "人也是伴隨著成長，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "其外表或",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能力會跟著產生變化的生物。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n也就是說，或許無須現在就感到焦急也不一定。",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "180500402"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_047"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您果然是和米奈娃所描述的一樣……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n託您的福，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下的內心輕鬆多了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "非常感謝您。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下雖然還只是毛蟲，",
        "unit_id": 105931,
        "voice": "vo_adv_1805004_048"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n不過或許總有一天會長出美麗的翅膀，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在那之前，也希望主人願意讓在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "陪伴在您身邊。",
        "unit_id": 105931
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊……",
        "unit_id": 190011,
        "voice": "vo_adv_1805004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可可蘿……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n太惹人憐愛了～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正你現在也聽不到我的聲音，",
        "unit_id": 190011,
        "voice": "vo_adv_1805004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我乾脆就來大聲呼喊對可可蘿的愛好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的……",
        "unit_id": 190011,
        "voice": "vo_adv_1805004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺這樣做有點寂寞，還是算了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了能再次見面，我會努力的，",
        "unit_id": 190011,
        "voice": "vo_adv_1805004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也和可可蘿一起加油吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是哪天我的聲音能傳達到了……",
        "unit_id": 190011,
        "voice": "vo_adv_1805004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n到時候",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就讓你好好聽聽",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我所想的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「可可蘿這地方最可愛了百選」吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1805004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再會囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您收到了愛梅斯大人的神諭嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔姆，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有如毛蟲般的在下，想成為蝴蝶……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這究竟是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼樣的內容呀。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說來……",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下隱約有印象，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當還在故鄉村裡的時候……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管記憶有些模糊，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下的確曾期許過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有天想如蝴蝶般，飛翔在天空中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下變身成「公主型態」時，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也獲得了",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "彷彿和蝴蝶一樣的翅膀呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原本被在下所遺忘在……",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "內心角落的心願，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如今",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被主人找了回來，一定是這樣的吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話雖如此，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下也",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才剛開始進行羽化。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還沒有把握",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否能充分發揮自己的力量……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下往後也願待在主人身旁，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_062"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "直到完全羽化，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "替您提供更多的支援。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好了，",
        "unit_id": 105913,
        "voice": "vo_adv_1805004_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沙拉完成了唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您享用吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
