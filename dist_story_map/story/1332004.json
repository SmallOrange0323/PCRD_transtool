        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n把那個給我！",
        "unit_id": 105331
    },
    {
        "type": "still",
        "still": "133200401"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咕，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_049"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好、",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好好吃……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n未經多餘加工的地瓜",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "本身帶有的甜味",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "與恰到好處的熱度，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n沁入寒冷的身體裡！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_050"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今天的烤地瓜",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "似乎還多了另一種美味。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要形容的話，沒錯，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是罪惡的味道。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然身為一個軍人",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_051"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我感到非常遺憾，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但這份美味",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不論是誰都無法否定。",
        "unit_id": 105331
    },
    {
        "type": "still",
        "still": "133200402"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就如閣下所說，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_052"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "休息也是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "軍人的任務。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這或許是上天的安排，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要我現在先養精蓄銳，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為下次的作戰做準備。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "無論平日再怎麼節制",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_053"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "與鍛鍊，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要是心靈和身體沒有餘裕，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就無法期待能有完美的工作表現。",
        "unit_id": 105331
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "133200403"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我自己一個人的話",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_054"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "或許會因為太過固執而失敗。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有閣下你在真是太好了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "謝謝你。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_055"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "謝謝招待。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "多虧了閣下讓我心中的迷惘也煙消雲散了，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就從現在開始",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "盡全力享受假期吧。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_056"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "即使太陽下山了",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還是有很多能玩的。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就算是遊戲我也不會手下留情的。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "走吧──！",
        "unit_id": 105331
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
