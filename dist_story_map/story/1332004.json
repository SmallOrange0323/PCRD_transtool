[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾繼續享受新年假期的莫妮卡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉著{player}的手專心地逛著攤販。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊哈哈，",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好好吃，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是有趣啊，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然陳列著各式珍奇異物的",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "吉歐‧格黑納交流祭也很有趣，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但在熟悉的場所，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "參加熟悉的祭典",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也很好呢！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "蘭德索爾的祭典",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "充滿著各種甜點。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n有水果糖葫蘆跟糖雕，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還有巧克力香蕉與迷你蜂蜜蛋糕，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n新年時",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還會有紅豆湯與甜酒，簡直毫無破綻。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "說來說去",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在吉歐‧格黑納也都是在吃甜食呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊啊，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "甜味滲透到了五臟六腑……！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔，",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到這樣的話會從你的口中說出來。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "確實",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是有點",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "吃太多甜食了。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也來吃點炒麵和炸雞塊好了。",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剛好從那邊",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "傳來了醬香味……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呃，",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼有點刺眼。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "又不是元旦日出……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不對，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這道光我以前也，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗚、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗚哇啊啊──！",
        "unit_id": 133212
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在寒假差不多快結束的寒冷日子裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在街上看見了莫妮卡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是──"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唉……",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊啊，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來是閣下嗎……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n沒有，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我只是又深刻地意識到我是個軟弱的人類。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "被新年的開心氣氛給吞噬，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n一直吃吃喝喝、懶散度日，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "疏於",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n每天的鍛鍊……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是這種放縱不健康的生活被本國知道的話……",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊啊，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "身為一個榮耀的軍人",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "實在太丟臉了！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不需要安慰我。",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然事已至此那也沒辦法。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "重要的是該如何從現在開始挽回。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "決定了。",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我要",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對生活亂七八糟的自己來個當頭棒喝！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "將新年一開始就失敗落後的部分",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "給追回來！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哦，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下你看。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剛好有個很適合的活動呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n新春健走大會，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "正好讓身體適度地動一動。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好像也可以中途參加。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "太好了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你那是什麼表情。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下當然也要一起參加啊。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "反正閣下",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "肯定也是吃飽睡、睡飽吃吧？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不用說也知道。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們走吧！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "走呀走呀走個不停，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "把身心的贅肉都給甩掉！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}就這樣被莫妮卡給拉著，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n去參加了健走大會。"
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哈、",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵呵，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雙腳累積乳酸的這個感覺，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還有側腹的痛楚。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n透過嚴格鍛鍊身體",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "逐漸找回來了呢！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下怎麼樣？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真沒出息，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這還只是剛開始啊。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你看，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那裡有補水站。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "即使是冬天也要好好補充水分，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "目標是走完全程！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不好意思，",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "請給我一杯。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什、",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼，這個……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是甜酒嗎！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這是怎麼一回事！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1332004_019"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "妳不知道就來參加了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "這是一邊享受冬季美食一邊走路的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "美食健走哦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你、",
        "unit_id": 105331,
        "voice": "vo_adv_1332004_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說什麼？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在這之後也……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "是啊，",
        "unit_id": 1,
        "voice": "vo_adv_1332004_021"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "關東煮與肉包，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "還有豬肉味噌湯，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "跟滿滿的美食喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n盡量吃吧！",
