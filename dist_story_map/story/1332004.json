    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好啦，",
        "unit_id": 190011,
        "voice": "vo_adv_1332004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "新年快樂新年快樂～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來你的寒假過得很愉快真是太好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為莫妮卡本身有著認真的軍人性格，",
        "unit_id": 190011,
        "voice": "vo_adv_1332004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以有時候會太過逞強呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟你這樣悠閒的人待在一起",
        "unit_id": 190011,
        "voice": "vo_adv_1332004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n剛好是最佳平衡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然說是軍人，",
        "unit_id": 190011,
        "voice": "vo_adv_1332004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也是正值青春年華的女孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該要好好享受這年紀女孩該有的樂趣才對，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "絕對沒錯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我能肯定，",
        "unit_id": 190011,
        "voice": "vo_adv_1332004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣的回憶會讓她變強。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話就說到這裡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "回去好好享受寒假吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再見囉～",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯……",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_062"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼啊……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咦，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難道我睡著了？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然會在白天的大街上睡著，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難道我鬆懈過頭了嗎……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_063"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我連在夢裡",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都在享受假期啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下也做了同樣的夢？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還真是稀奇呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過話說回來，",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_064"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "明明我期望的是那傢伙能有和平的新年，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n結果",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "卻連在夢裡都把他捲入了麻煩的事件裡……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "果然",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_065"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我的能力可能還不夠……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下……",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_066"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊，",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_067"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這傢伙",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "根本不需要我去操心，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是個即使面對困難",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也能樂在其中的男人。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然如此",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_068"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就不去想些有的沒的，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "照這樣子來享受新年吧！　",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，",
        "unit_id": 133212,
        "voice": "vo_adv_1332004_069"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你應該還有時間吧？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就像夢裡那樣，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在這之後",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也盡情地",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "享受新年假期吧！",
        "unit_id": 133212
    }
]