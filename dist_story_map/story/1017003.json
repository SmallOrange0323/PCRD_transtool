[
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘿咻～",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "拳擊☆",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "嗚啊啊啊！？",
        "unit_id": 811,
        "voice": "vo_adv_1017003_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～大家的動作挺遲鈍的呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你們肚子餓了嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是不介意的話，材料還剩很多可以煮給你們吃呦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "少、少看不起人！",
        "unit_id": 811,
        "voice": "vo_adv_1017003_003"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n這傢伙，絕對要宰了妳……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀，真是血氣方剛呢～果然是因為餓肚子在生氣呢～？　",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要吃點美食心情就會變好呦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家一起笑著當朋友吧～♪",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "煩死了！",
        "unit_id": 811,
        "voice": "vo_adv_1017003_005"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "可惡，這傢伙是怎樣！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n也太強了……！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～我的空手道可是世界最強的呀～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說回來，你們實在太丟臉了吧～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這麼多人包圍我們，還用了武器，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n卻一點都打不到人呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣下去的話在這段舞蹈結束之前，",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你們都會變成我空手道的手下敗將呦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "可惡，既然這樣的話……！",
        "unit_id": 811,
        "voice": "vo_adv_1017003_009"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "大哥，快來幫我們呀！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "搞啥？",
        "unit_id": 911,
        "voice": "vo_adv_1017003_010"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n你們從剛剛就在亂鬧什麼……？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n你們這些傢伙，我交代過不要靠近這邊的吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔喔～感覺像頭頭的人登場了呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "感覺好像有點麻煩呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說回來，這下實在有點寡不敵眾呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要是真步的話，應該可以用攻擊魔法一網打盡吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我要是有聽忠告，和大家待在一起就好了呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但是沒有抵抗就被抓住，可不知道會被怎麼樣呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "至少也得突破敵人的包圍，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n讓他逃走才行呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "畢竟保護一般人，可是我們【哞哞自衛隊】的使命呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_014"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "嗯嗯？",
        "unit_id": 911,
        "voice": "vo_adv_1017003_015"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n喂，妳這傢伙……在這邊吃什麼東西？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這叫做苦瓜雜炒～是我故鄉的料理呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n山賊大哥，不介意的話要不要嚐嚐看呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "喂，明明還在戰鬥妳也太放鬆了吧！",
        "unit_id": 811,
        "voice": "vo_adv_1017003_017"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n妳是想交出食物向我們求饒嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n現在可不是這種情況呀！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "兄弟們，拿這兩個傢伙來血祭吧～！",
        "unit_id": 811,
        "voice": "vo_adv_1017003_018"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "給我閉嘴。",
        "unit_id": 911,
        "voice": "vo_adv_1017003_019"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "啊，真是讓人懷念……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n這就是我追尋許久的料理呀！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "大哥，你在說什麼呀……？",
        "unit_id": 811,
        "voice": "vo_adv_1017003_020"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "嗯。我是以前一個到處旅行的流浪者，",
        "unit_id": 911,
        "voice": "vo_adv_1017003_021"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "以前我在某個國家裡吃過的料理讓我難以忘懷……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "所以才會在這邊憑著印象，試著栽種出當中的食材。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊～那個像苦瓜的東西……",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n原來是山賊大哥所種的蔬菜呀？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對不起～我擅自採收了這些蔬菜呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "沒關係，森林裡的植物不屬於任何人。",
        "unit_id": 911,
        "voice": "vo_adv_1017003_023"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n比起這件事……妳剛剛說的苦瓜雜炒，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "可以讓我也品嚐看看嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可以啊～不介意的話我也可以多做一些呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n食材還有很多，我可以多做一些其他的故鄉料理呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家都不用客氣，一起來品嚐吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "太感謝妳了！",
        "unit_id": 911,
        "voice": "vo_adv_1017003_025"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "你們這些傢伙，把武器放下來！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "誰敢對這位小姐動手我就宰了誰，",
        "unit_id": 911,
        "voice": "vo_adv_1017003_026"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "啊啊，這些料理真是太令我懷念了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n這是，我的青春呀……☆",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "嗄啊啊啊……？　",
        "unit_id": 811,
        "voice": "vo_adv_1017003_027"
    },
    {
        "type": "dialogue",
        "name": "山賊",
        "words": "\n大哥你到底在說啥呀？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，吃得真陶醉呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "山賊大哥可是花了許多力氣培育這個類似苦瓜的蔬菜呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "難道是從頭開始品種改良，創造出這種很罕見的食材嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "山賊大哥你這麼喜歡我故鄉的料理呀～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真開心，那我也要盡全力才行呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來吧，大家都請坐！",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一起唱歌跳舞炒熱氣氛啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "啊啊，這個苦味！",
        "unit_id": 911,
        "voice": "vo_adv_1017003_031"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n就是這個，真是讓人懷念！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "太美味了、太美味了……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "你們這些傢伙，",
        "unit_id": 911,
        "voice": "vo_adv_1017003_032"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "今天晚上要舉行宴會啦，哇哈哈哈！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈～聊過之後才知道大家都是好人呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_033"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為什麼大家要當山賊呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "沒有啦。我們是因為在城鎮裡待不下去，",
        "unit_id": 911,
        "voice": "vo_adv_1017003_034"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n才會到森林裡過著自給自足的生活。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "我們也自己開墾了農田……",
        "unit_id": 911,
        "voice": "vo_adv_1017003_035"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n什麼山賊的，單純是個誤會而已。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "對於那些侵入我們地盤的傢伙，",
        "unit_id": 911,
        "voice": "vo_adv_1017003_036"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n我們的確是會裝出壞人的樣子把他們趕跑。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n不過我們基本上可是和平主義者。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原來如此呀～那我去跟【哞哞自衛隊】報告這個情況～",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_037"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣應該能幫你們處理一些手續，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n以後就能做些販賣蔬菜之類的生意了啊～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是一直被當成山賊的話，搞不好哪一天會被討伐呦～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_038"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我也想要多吃一些故鄉的食材呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大哥覺得如何～這樣就能和平解決問題了吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "太感謝妳了！",
        "unit_id": 911,
        "voice": "vo_adv_1017003_039"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n像我們這種混混，居然還能夠回到社會裡呀！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "今天真是值得慶祝，讓我們為這小姐",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "乾杯吧……☆",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈～你們真是上道呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_040"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我也覺得開心起來了～來跳舞吧♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你也一起來唱歌跳舞吧～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_041"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "手牽手、轉圈圈～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "啊哈哈。",
        "unit_id": 911,
        "voice": "vo_adv_1017003_042"
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n這傢伙是小姐妳的戀人嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "山賊頭目",
        "words": "感覺妳跟他關係很好呢～？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_043"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎麼可能，他才不是我的戀人呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n對吧？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯、嗯！",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_044"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n沒有錯～我們只是陌生人啦！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～這麼直接被說是「陌生人」……",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_045"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n總覺得也有點寂寞呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為什麼呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，朋友？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_046"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒有錯～我們可是一起開心地採收那些像苦瓜的東西呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呵呵。雖然我和你是初次見面，",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_047"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過感覺我們可以當更好的朋友呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "四海之內皆朋友呀～啊哈～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～不管怎麼說。",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_048"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天吃到了美味的料理又開心地跳了舞，真是太棒了啦～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天能夠遇到大家，",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_049"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我要向故鄉的神靈們致上感謝之意～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "將舞蹈與歌聲奉獻給神靈們，",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n希望明天也能夠賜與我們許多的幸福～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不管飲食、歌舞還是其他事物，都是獻給這個世界的供品～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不介意的話，你也和我一起同樂吧～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017003_051"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對吧～船到橋頭自然直呢～♪",
        "unit_id": 101711
    }
]