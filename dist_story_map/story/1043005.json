[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哼嗯哼哼～嗯……♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦，又有垃圾掉在那邊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "畢竟昨天的風很強呢～",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n從鎮上飛過來的東西滾來滾去的呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n像是看板，還有鞋子什麼的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "碎木片還有葉子也灑的到處都是呢……",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還有不知道哪個呆子亂丟沒吃完的食物和包裝紙。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，真是的。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n平常都很乾淨的埃斯特雷拉街道，怎麼都變得亂七八糟了啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我一個人把這些全部清掃乾淨可是很累人的。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過算了，這是我今天該做的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n一份撿垃圾的低薪工作。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "埃斯特雷拉街道就在城鎮外頭，",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是蘭德索爾是家，這裡就像是院子一樣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且還是我們【哞哞自衛隊】的地盤呢，",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n得好好打掃乾淨。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯哦？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那是什麼，有個奇怪的東西倒在那裡！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n難道說，是屍體！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔……如果是屍體就討厭了，我不想見到那種東西啦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過要是純粹倒在那邊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n只要快點帶去醫生那裡，說不定就能得救？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也不能當作沒看到呢……？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂、喂～？你還活著嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是你還活著，就快回答！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？咦，難道說……是{player}嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這不是{player}嗎！\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你這傢伙，為什麼會死在這種地方啊？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣啊，太好了太好了。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n因為你像一片垃圾一樣掉在這裡，我還以為是屍體呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你還活著真是太好了～沒事吧？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼會倒在這裡？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有哪裡受傷嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n讓我看看吧，我來替你處理傷口。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啥，",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我是有聽到傳聞，最近城鎮的附近有魔物出沒……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n竟然是真的呢，真是一場災難對吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哼。你明明就超弱的，",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還敢毫不介意地走到安全的城鎮外，才會有這種下場啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n雖然不清楚你是不是有事要辦，下次至少請個保鏢吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你受傷的地方，就讓我看看吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我來替你處理一下。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……喂。\n不要動啦，會害我不能紮上繃帶。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n消毒水滲進傷口會痛？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我忍耐啦～你是男生對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉呢。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n如果是優衣，應該就會更溫柔地替你處理吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n畢竟我就是笨手笨腳的～？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好，這樣就沒問題了。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不要太常碰到受傷的地方哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不用道謝啦，有困難就得互相幫助對吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "先別管那個。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n{player}，你在這種地方做什麼？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "埃斯特雷拉街道雖然比較安全……",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過平常也會有魔物出現哦，要是不小心真的會死的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我在做【哞哞自衛隊】的工作，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n在這裡撿垃圾哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，要是你有空能幫個忙嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看來只靠我一個人，就算做到天黑也可能處理不完呢～？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "當作回報，我就當{player}的保鏢吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n如果只是這裡的魔物，我都能輕鬆趕跑的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是互助合作的概念，怎麼樣？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n對彼此都有好處對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "ＯＫ？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好，那契約就成立了♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，你既然受傷了，就不要逞強哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我去收集一些垃圾過來，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你就負責分類，裝進垃圾袋裡。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "欸，你不知道垃圾該怎麼分類？",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你啊，真的什麼都不知道……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n啊對了，你喪失了記憶對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n真沒辦法，我就從頭來教你吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，討厭，真的好麻煩……",
        "unit_id": 104311,
        "voice": "vo_adv_1043005_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，撿到一個不得了的東西呢♪",
        "unit_id": 104311
    }
]