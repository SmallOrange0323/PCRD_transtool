[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "受到凱留等人襲擊而逃亡的\n{player}一行人移動到了其他的據點，\n為了對抗王宮而舉行了作戰會議。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "差不多該休息了吧。",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "吃飯囉，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "吃飯！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n肚子餓了也會沒力氣喔！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "矛依未小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_1061002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果要找主人的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他現在出去外面了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "外面？",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我知道了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我去稍微看看。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可可蘿。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以拜託妳和靜流她們一起",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幫忙準備一下飯菜嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 105913,
        "voice": "vo_adv_1061002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……矛依未小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下準備料理的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人就拜託您關照了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "事到如今還說些什麼。",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我早就在關照他了吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來去找那傢伙吧！",
        "unit_id": 106112
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……喔！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有了有了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唷！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼了？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在看星星嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我叫諾維姆啦！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "開玩笑的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "用那個名字叫我也沒差啦，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在的話。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼了？",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "個頭啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我聽說你一個人不知跑去哪裡，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我才跑來找你的！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可可蘿好像很擔心你喔。",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好好振作點啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "主人！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然你可能還無法馬上就振作起來，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但可可蘿也是吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是啊……",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總是在一起的同伴，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "突然變成敵人還分開，\n又要相互戰鬥，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你跟她現在可能還是很難受……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是從很久以前就已經習慣了啦！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我和尾狗刀他們一起",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "背叛了七冠，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也曾在敵人手下臥底過！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有當時面對可能成為同夥的你們，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n其實是想成為夥伴的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但卻仍是以敵對的身份戰鬥著！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以你別擔心！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我這麼說，但你啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n其實早就決定好想怎麼做了吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛剛也說過了吧？",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果被通緝的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一回王都就會立刻被捕喔？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且你們打算",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼幫助貪吃佩可呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n王宮的警備非常森嚴喔？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且你說兩人……",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你果然",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也想救那個叫凱留的女孩子啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說在前頭，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們可沒有餘力再救她喔。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要做的話打倒真那才是優先的事。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "打倒真那，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把奇怪的世界恢復原狀。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這才是我們現在該做的事。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是我",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "希望能幫助你和可可蘿。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "特別是",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不想把你那公主騎士的力量放著不管。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你可能會覺得我很任性，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但我會把心裡所想的全說出來。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在變得無法說出口之前。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝謝啊！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也想幫助貪吃佩可。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但事情能否順利進行，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在都還是未知數……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果連你也被抓起來的話就糟了，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以其實不太想要分頭行動的呢～……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抓好時機就好了吧……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……快想想辦法啊。",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就像曾是敵人的他和尾狗刀一樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要不斷思考，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一定會知道該做的事！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我和他都",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有事要去王宮。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們攻擊和他們潛入的時間",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n得在同日、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "同時開始才有意義……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……只要確保聯絡方式",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該就沒問題了吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我說啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們能用通訊魔法之外的聯絡方式嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為若是使用魔法可能會被察覺，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n若有其他方法的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想應該就沒問題了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "動物嗎！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也就是說既不用魔力也不用魔法囉！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如此一來就不會有被察覺的問題了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可可蘿好樣的！",
        "unit_id": 106112
    },
    {
        "type": "still",
        "still": "106100201"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就這麼決定囉！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你和可可蘿，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "從明天開始和我們分頭行動！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們先回王都，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "探查一下其中的情況！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們在那段期間裡",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會做好各種準備！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我還會準備其他的聯絡方式，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n安心的去王都吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也許我們和你們，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n都不知道對方在做什麼反而剛剛好！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果做出難以搞懂的行動，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n敵人應該也無法解讀我們的行動！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是那樣！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且啊……",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "之前你讓我打起了精神，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這次換我來讓你恢復精神了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "夥伴不在身旁的難受與寂寞，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我非常懂……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不希望讓你這麼樣的好人，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也嘗到那種痛苦滋味。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別擔心！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有我們啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n可可蘿、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大吾、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真軌、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "克莉絲提娜、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "璃乃、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "靜流！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這個世界上的大家，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都是你的夥伴！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我也沒立場這麼說，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但失敗這種事",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就別多想了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那種事情，",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等真的失敗後再想就好了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在只要",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "做想做的事就好。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們都一樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算遇到失敗，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也一定會學到些什麼吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "連以為不會再見的你都再次遇到了……",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n沒有什麼事情",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是不可能的！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也會加油的！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也要加油啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n主角！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不用加小！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我叫諾維姆！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n都決定好了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就和可可蘿他們一起討論吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "走吧！",
        "unit_id": 106112,
        "voice": "vo_adv_1061002_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――矛依未伸拳碰了一下{player}的胸口，\n拉著他的手腕一起回到據點。"
    },
