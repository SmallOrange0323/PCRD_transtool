[
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鳳凰與{player}用出乎意料的方式拯救了農村。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雖然鳳凰吃飽回到了吉歐‧格黑納──"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我想起來了！",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_000"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我想起來了啊～～～",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "騎士先生！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "多虧我吃了很多米，",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_001"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "才能想起重要的事情！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "呵呵呵，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你可別嚇到喔……？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "心臟做好準備了嗎？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "呵呵呵。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我在這個吉歐‧格黑納，",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_002"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n有一座美得舉世無雙，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "甚至美得難以描繪的庭園！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "其名為──",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "「鳳凰的庭園」！！",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_003"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "沒錯沒錯～",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_004"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "小小的庭園裡",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "有隻小雞──",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "才不是啦～～～！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "誰是小雞啊！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n不要像真陽一樣說那種話！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咳咳，",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_005"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "總之，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我也會邀請騎士先生去那個庭園。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "只要去了那裡，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我的神力想必",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "也會恢復",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "更多更～多！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "好了，",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_006"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "跟我來吧～！",
        "unit_id": 134712
    },
    {
        "type": "background",
        "background": "502090"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "啊啊啊啊啊啊啊啊啊～～～！！",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_007"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n怎麼會～～～～～～？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n為什麼",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "事情會變成這樣～！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那壯麗且美麗，",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_008"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "簡直有如我的心一般純淨的庭園！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n變成只剩",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "融化的岩石跟沒融化的岩石",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "的慘狀了～！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不、",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_009"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不可原諒……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不可原諒啊……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n竟敢這樣捉弄",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "淨化的",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "神鳥，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "非常偉大的我……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n竟敢這樣",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "捉弄我～！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "啾啾啾──！",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_010"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "所以就說我不是小雞了！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "總之不可原諒！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我要找犯人！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n被我找到",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "就要拳頭伺候！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "朝著臉拳頭伺候20下！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "讓對方見識見識！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……不、",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_011"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不對，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "算了，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "被拳頭伺候太可憐，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n所以還是彈額頭之類的好了，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "才、",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_012"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "才不溫柔！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "現在的我",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "可是鬼神！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "已經化為復仇之鬼了！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "來吧，騎士先生，",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_013"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "要來找犯人了喔！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n就先從打聽開始！",
        "unit_id": 134712
    },
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "啊啊，",
        "unit_id": 50811,
        "voice": "vo_adv_1347002_014"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "那座庭園的話──",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n不久前被失控的萬花菲尼克斯燒掉了喔，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n連點痕跡都不剩。",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "犯人",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_015"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不就是我自己嗎～～！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗚嗚嗚。",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_016"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "騎士先生，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "請",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "彈我的額頭吧……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n輕輕地喔，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "輕輕地……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "啊！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "好痛好痛！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "麻、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "麻煩用小指～～～！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "這悲嘆可真誇張。",
        "unit_id": 50811,
        "voice": "vo_adv_1347002_017"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n那座庭園確實",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "美得簡直不像是這世上的東西呢。",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "我還想再多看看啊。",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "就是說啊……",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_018"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "就是說啊啊啊……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那是一座非常棒的庭園……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "既華麗又繽紛……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n我明明",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "想讓騎士先生看看的……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗚嗚……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你、",
        "unit_id": 50811,
        "voice": "vo_adv_1347002_019"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你願意幫忙嗎？",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "也、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "也對呢，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我才不能喪氣。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我們再重新蓋一座「鳳凰的庭園」吧！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "真努力呢。",
        "unit_id": 50811,
        "voice": "vo_adv_1347002_020"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "很好，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "我中意小姑娘妳！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n告訴妳一個我珍藏的好地點吧！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我不是小姑娘啦……",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_021"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不過算了！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "謝謝你♪",
        "unit_id": 134712
    },
    {
        "type": "background",
        "background": "502070"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯……",
        "unit_id": 134712,
        "voice": "vo_adv_1347002_022"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "是這邊嗎？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n這裡長著各式各樣茂密的植物，以這點來看，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
