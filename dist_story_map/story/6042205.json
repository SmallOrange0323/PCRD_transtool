    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "愛麗絲真的",
        "unit_id": 113011,
        "voice": "vo_adv_6042205_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "很厲害呢。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那麼可愛的她",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "竟然正在為了拯救世界而戰鬥著……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也要加把勁，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可不能輸給她了。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 113011,
        "voice": "vo_adv_6042205_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我這才不算什麼呢！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……而且，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真正努力的人，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n是一直以來幫助著大家的前輩才對……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "正因為前輩是這樣的人，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我才",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "最、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "最最、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "最喜……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "欸欸！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真是的，我剛剛差點說了什麼呀！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 113011,
        "voice": "vo_adv_6042205_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩也這麼覺得嗎？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也就是說，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "如果我穿了愛麗絲風格的服裝……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我什麼都沒說！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這麼說來，",
        "unit_id": 113011,
        "voice": "vo_adv_6042205_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩和往常一樣……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n也、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也請別失望到",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "跌坐在地板上呀！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這種時候該怎麼安慰……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好乖好乖唷。",
        "unit_id": 113011
    }
]