[
    {
        "type": "background",
        "background": "500362"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "玄關的打掃結束了，",
        "unit_id": 109711,
        "voice": "vo_adv_5017101_000"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n剩下的就是打掃房間",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "和整理倉庫了……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "妳看起來沒什麼精神呢，",
        "unit_id": 109811,
        "voice": "vo_adv_5017101_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "怎麼了嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雷姆。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n在妳去叫巴魯斯起床之前明明還那麼有精神，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n是因為看到巴魯斯的蠢臉不開心嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不，",
        "unit_id": 109711,
        "voice": "vo_adv_5017101_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "姊姊。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴的睡臉",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "非常可愛，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆看一整天都不會膩……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "其實",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆一直有一種很不好的預感。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而且，",
        "unit_id": 109711,
        "voice": "vo_adv_5017101_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "總覺得宅邸也散發出一股不好的氣息……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n明明魔獸的事情才剛結束，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "應該不會有甚麼問題才對啊。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這樣啊……",
        "unit_id": 109811,
        "voice": "vo_adv_5017101_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是令人擔心。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n那麼，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "把經常惹是生非的巴魯斯",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "綁起來丟出去就是",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "最好的辦法。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "――",
        "unit_id": 109911,
        "voice": "vo_adv_5017101_005"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真是的，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "拉姆每次都這樣",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n故意講一些很壞心的話。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "早安，",
        "unit_id": 109711,
        "voice": "vo_adv_5017101_006"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911,
        "voice": "vo_adv_5017101_007"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "早安。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那個，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雷姆怎麼了嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的。",
        "unit_id": 109711,
        "voice": "vo_adv_5017101_008"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "好像有",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "什麼不好的預感……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這樣啊，",
        "unit_id": 109911,
        "voice": "vo_adv_5017101_009"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "原來雷姆也是？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n其實我也……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我感覺到的",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n不單是那種很討厭的焦躁感。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不單是很討厭的感覺而已……",
        "unit_id": 109811,
        "voice": "vo_adv_5017101_010"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911,
        "voice": "vo_adv_5017101_011"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "的確因為不好的預感",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "而有焦躁感，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "在那之上卻有種",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "非常、",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "非～常美好的邂逅",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n似乎即將就要出現的",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "期待感！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "下一回",
        "unit_id": 1,
        "voice": "vo_adv_5017101_012"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「Re:從零開始聚集的異世界餐桌」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500362"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "美好的邂逅……",
        "unit_id": 109811,
        "voice": "vo_adv_5017101_013"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "原來如此。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n愛蜜莉雅大人也來到這個年紀了呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n看來，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "巴魯斯要心碎了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咦？",
        "unit_id": 109911,
        "voice": "vo_adv_5017101_014"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n為什麼昴要心碎呢？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴……",
        "unit_id": 109711,
        "voice": "vo_adv_5017101_015"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n有時候連雷姆",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "都覺得他好可憐……",
        "unit_id": 109711
    }
]