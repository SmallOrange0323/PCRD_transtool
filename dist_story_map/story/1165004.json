[
    {
        "type": "background",
        "background": "500891"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和祈梨眺望著夕陽，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一起吃著飯糰。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "工作完以後吃的飯別有一番風味呢！",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n畢竟連只有撒鹽的飯糰，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "吃起來都會這麼好吃！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦！？",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你連茶都有準備好嗎！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不愧是我未來的親信！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是貼心！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……呼～",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是洗滌身心啊。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不管是茶，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還是小哥背後那耀眼的夕陽……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不對，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再怎麼說都太耀眼了吧！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你的身體又在發光了！！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該不會",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又是這個套路吧──！？",
        "unit_id": 116511
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚……",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚嗚……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我本來是不參加網聚主義的人，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n都特地空出時間去參加了……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "他們居然露出「這傢伙比想像中還要無趣呢」的表情，",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n後來直到最後",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都把我當作空氣對待，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是一群混蛋人渣……！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……啊嗚！？",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "痛痛……",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對不起撞到你了…………",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……咦，",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是小哥！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我真是白道歉了！！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……！",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才沒有在哭呢！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這是，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "夕陽有一點刺眼……！！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總而言之，",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我今天",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經不想和任何人說話了。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你就放著我，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "別管我了……！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不、",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不要再盯著我看了……！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你這樣",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很多管閒事啦……！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你要是再煩下去，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就叫警察喔！！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "欸妳看那邊……",
        "unit_id": 1,
        "voice": "vo_adv_1165004_012"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "發生什麼事了啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n我們是不是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "該出手幫她比較好？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "欸，",
        "unit_id": 1,
        "voice": "vo_adv_1165004_013"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "那女生在哭欸，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "你該不會……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "對她做了什麼吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n如果真是如此的話──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊嗚！？",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n又、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又是這個發展……！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我說，",
        "unit_id": 1,
        "voice": "vo_adv_1165004_015"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "妳沒事嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n妳看起來很害怕。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不是的……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "……？",
        "unit_id": 1,
        "voice": "vo_adv_1165004_017"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n總之，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我們一起去警察局──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就說了！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n真、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真的沒什麼啦……！！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "啊！",
        "unit_id": 1,
        "voice": "vo_adv_1165004_019"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "她走掉了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n感覺她態度怪怪的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "是個有點奇怪的女生呢……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "那個，",
        "unit_id": 1,
        "voice": "vo_adv_1165004_020"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "先生，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "對不起喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n看來是我們搞錯了！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510121"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……呼，呼。",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我絕對",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又被當作是「奇怪的傢伙」了……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這一切都是因為……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的！",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n為什麼小哥你也跟來了！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說到頭來！",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我不是不擅長說話，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n而是嘴巴跟不上",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "思考的速度而已啊！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說話吞吞吐吐的，",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聲音會越來越小，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n還常常低下頭，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這些都是我的特色……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我可不是被戲弄、",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "被嘲笑、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "被無言以對、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "被無視……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "被做了這些事以後還不會受傷的，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那麼奇怪的人啊……！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚嗚……",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼我今天",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一直遇到這種事啊。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我只是",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為他們說「想和妳當朋友」才會去參加網聚的，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n他們都是些不尊重人的混蛋，好討厭！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然要遭受這種待遇，",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我不如一直待在家裡玩阿斯特朗還比較好！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我一個人獨處，",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比這好上百億萬倍！！！！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……你為什麼不說話？",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然都露出那麼傷腦筋的表情了，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你只要生氣",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "或是離開不就好了嗎！！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你也是吧，其實你心裡",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n也是覺得我──",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！？",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_031"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你在開玩笑嗎！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n為什麼我得陪小哥你玩──",
        "unit_id": 106631
    },
    {
        "type": "still",
        "still": "116500401"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來吧！",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_032"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥你也",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一起來唱歌！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……因為你是音癡所以不想唱？",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_033"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我不接受！！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你都說著「去使盡全力紓解壓力吧！」，強拉我來唱歌，",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_034"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n還讓我Cosplay成我最喜歡的動畫角色了！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你多少也來傷一下腦筋吧！",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "拿起麥克風！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘿嘿！",
        "unit_id": 106631,
        "voice": "vo_adv_1165004_036"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n下一首我點了櫻井望的新歌！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這首歌要和其他人一起唱，才嗨得起來呀！",
        "unit_id": 106631
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1165004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n祈梨她啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一開始我還擔心會變成怎麼樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但最後她好像有盡全力在玩耍，真是太好了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在想想，",
        "unit_id": 190011,
        "voice": "vo_adv_1165004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子一直都在尋找棲身之處呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就像她在阿斯特朗世界裡有順利找到歸屬一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1165004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在現實之中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其實棲身之處也就在她身邊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n希望她總有一天會察覺到這點。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "直到那天為止，",
        "unit_id": 190011,
        "voice": "vo_adv_1165004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你都要有耐心地照顧那孩子喔！",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500891"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……啊！？",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_041"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛、",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛才那是怎麼一回事！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然是個很讓人不開心的夢，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是最後──",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……小哥一如往常，是個愛多管閒事的傢伙呢。",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_042"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也並不討厭",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你這樣的個性啦！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……咦，",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_043"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經這麼晚了！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "糟糕了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是太晚還在外面遊蕩，我就會被扣零用錢！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……對了，",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_044"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就說我是為了照顧小哥，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不知不覺就拖到很晚好了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以小哥，",
        "unit_id": 116511,
        "voice": "vo_adv_1165004_045"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你就以證人身分跟著我來吧！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是{player}被祈梨從背後推拉著，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n離開了傍晚的小巷。"
    }
]