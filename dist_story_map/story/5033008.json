[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接受街上人們的聲援，從絕望的險境中復活的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n魔法偵探Misty★霞、魔法獵人Purely★栞。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因為兩位魔法少女的力量，蘭德索爾再次恢復了和平。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，又過了一段時間——"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天街上也沒有異常呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n從那之後已經過了好幾天，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看起來危機真的解除了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "之前幾乎每天都會出現的反逆獸，",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n沒想到會這樣突然就消失不見呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟源頭已經被切斷了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果還繼續出現的話會很困擾呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……靜流小姐",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她已經沒有那時候的",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n記憶了吧？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原本想問她",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n和反逆獸相遇時的事情之類的呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "她的狀況怎麼樣了呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會想起她衝向{player}",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的樣子呢……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唉呀唉呀。",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也已經觀察好幾天了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣可以算是正式——",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "解除職務了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……摩拉",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "到底跑去哪裡了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "牠跑到哪裡去都不重要了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n打倒了反逆獸，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "代表摩拉的使命也已經完成了吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就算是這樣……",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也不用這樣默默走掉吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明都還沒有好好道別……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我不覺得有什麼問題喔。",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不如說因為可以不用再打扮成那樣了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我鬆一口氣了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助、",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我才沒有",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說過那種話喔！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "霞明明是名偵探，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n卻很不擅長撒謊呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是的，",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你們兩個！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不要再捉弄我了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是，",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我覺得……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很落寞呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不管是摩拉走掉的事情……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n還是我們",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "已經沒辦法變身成魔法少女的事情。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……我、",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也很難過，",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這種話",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我說不出口啊……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊。",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這附近對吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n第一次跟摩拉見面的地方……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我記得是在這附近",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽到了聲音……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂～",
        "unit_id": 1,
        "voice": "vo_adv_5033008_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有誰在嗎～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯沒錯，",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像這樣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後我就這麼說了：",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「嗯？　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳有沒有聽到什麼聲音？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "栞」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "誰來～",
        "unit_id": 1,
        "voice": "vo_adv_5033008_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "救救我啊～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對，",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就像這樣呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後我好像是回妳",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「是的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好像有人在叫我們的樣子……」",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "吧……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "喂～",
        "unit_id": 4211,
        "voice": "vo_adv_5033008_023"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "小霞、",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "小栞、",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "騎士大人！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n不要在那邊聊天，快點來救救我啦！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "摩拉！？",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "摩拉！？",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_025"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "嗨大家，",
        "unit_id": 4211,
        "voice": "vo_adv_5033008_026"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "好久不見啊！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "最近還好嗎？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "最近還好嗎，",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "才——",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才不是問什麼「最近還好嗎？」",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的時候吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n讓人留下那麼難為情的回憶，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n卻突然消失不見，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你到底是什麼意思啊！　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我才不聽你解釋！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "哇哇哇！？　",
        "unit_id": 4211,
        "voice": "vo_adv_5033008_029"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "小霞",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "超級生氣的！？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "對、",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "對不起！　",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "可是，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我有必須要趕時間的原因！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……有原因",
        "unit_id": 103811,
        "voice": "vo_adv_5033008_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個原因讓你就這樣一聲不吭地走掉嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "啊，",
        "unit_id": 4211,
        "voice": "vo_adv_5033008_031"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "小栞也默默地在生氣嗎？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "真的非常抱歉……！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "可是真的糟糕了！",
        "unit_id": 4211,
        "voice": "vo_adv_5033008_032"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n蘭德索爾的危機",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "還沒有結束啊！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦……？",
        "unit_id": 101411,
        "voice": "vo_adv_5033008_033"
    },
    {
        "type": "dialogue",
