        "voice": "vo_adv_5128007_034"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這下",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "就真的要說再見了。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
