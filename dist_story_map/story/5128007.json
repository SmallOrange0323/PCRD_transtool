    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "\n",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "我們會和陛下、",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "還有每位國民，",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "一同努力。",
        "unit_id": 1214
    },
    {
        "type": "background",
        "background": "502060"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明歷經了那麼大的騷動，",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n大家卻看起來生氣勃勃的呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我似乎能夠明白",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你會說沒問題的理由了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "呵呵呵，",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_033"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我沒說錯吧。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n很高興你們能相信我說的。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "那麼，",
