        "voice": "vo_adv_5128007_037"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我是精靈，所以不會感冒的。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "不過，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "謝謝妳們。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "啊，",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_038"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "往東方去的馬車要出發囉。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "那麼各位……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "請多多",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "保重！",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好的，",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "改天有緣再相見了！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然這段期間充滿波瀾，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是我非常開心哦。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_5128007_040"
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "這樣真的好嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "\n你如果想跟著那些人一起走也沒關係吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "不了，",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_041"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "因為我還有很多不了解的事情。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我還想要更了解這個國家的事物。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "是咲戀姐姐、",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_042"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "流夏姐姐……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "不，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "是大家教會了我。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我有了想做的事……",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_043"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n我現在",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "想去了解這個國家的每個人。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我想知道我不在",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "的這段",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "非常長久的日子裡的事情！",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "所以",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_044"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "國王陛下，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "關於我不在的這段期間的大小事。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n請通通告訴我吧。",
        "unit_id": 5313
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "宮殿和城牆……",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n都已經",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "變得那麼小了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "旅途的結束",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_046"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總是這樣呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果會感到不捨，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就代表這是一趟很好的旅行。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……是啊。",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳說的沒錯。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這對我來說，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "確實是一趟……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "難以忘懷的超棒旅行。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說起來，",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_048"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這次",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我的關係，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n把流夏也捲進來了呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳不必在意。",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_049"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我自己",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也得到了不少收穫。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不知道我之前有沒有跟妳提過……",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們公會",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "正在尋找「暮光之都」。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "流夏的公會……",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是【暮光流星群】嗎？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是啊。",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_052"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是說",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個國家在過去……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n製造了許多",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "強大的魔導具嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然多數",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都已經失傳了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_053"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就試著在城鎮調查了一下。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "結果妳猜怎麼樣？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒想到那個沙漠之國，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n過去也被稱作是「日落之國」。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "由蘭德索爾望去，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_054"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "正好坐落於太陽西沉處的沙漠之國……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "被封印在那都城的",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是這次的魔法神燈……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要說是偶然的話，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不覺得未免也太剛好了嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_055"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也就是說……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那個國家",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和流夏在尋找的",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「暮光之都」",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有所關聯嗎？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "──我只是想說，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_056"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是有就好了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不過，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也無法保證這個推測是正確的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "畢竟我到現在都還沒有找到真正有關聯",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的線索過。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不想要太過期待，結果到頭來只是一場空，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_057"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n所以回去之後",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我會耐心地繼續調查的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣啊。",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "流夏也有所收穫真是太好了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是單方面讓妳吃虧，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會過意不去的。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我說，",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是很好的一家人對吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……是啊，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_060"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然是宛如海市蜃樓般的時光。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但作為一晚的美夢",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "倒是還不賴。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拿著的那包是什麼？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是有禮貌的孩子呢。",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_062"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n明明不用那麼費心也沒關係的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀，",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "除了伴手禮之外……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有一封信？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n好像是那孩子",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "寫給我和流夏的。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我看看，上面寫了……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……咲戀？",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_064"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "信裡寫了什麼？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n妳不唸出來我們可不知道啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……拿去。",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_065"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳看了就知道了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我實在沒有勇氣把這個",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唸出來。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……啊啊，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_066"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唉……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真不曉得該說他貼心還是怎樣……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "果然",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是一位幫人實現願望的精靈呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼！你、你不准看啦！？",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_067"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對啊，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_068"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這可是給我和咲戀的信，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥你不准看──",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊。",
        "unit_id": 127612
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "給咲戀姐姐",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_069"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "和流夏姐姐。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "哪天有機會，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "請再和{player}哥哥\n一起",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "過來旅行哦。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "為了",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_070"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "在那天到來之前，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "可以好好地擔任嚮導，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n我會努力學習關於這個國家的知識。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "──希望下次",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_071"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "會是你們",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "真正的新婚旅行。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n到時候，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "為了讓你們玩得盡興，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我也會幫忙的。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以一張飄落的信紙為開端，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n駛向蘭德索爾的馬車內，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n又掀起了一場小小的騷動。"
    }
]