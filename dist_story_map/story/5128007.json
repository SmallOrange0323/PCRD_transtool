[
    {
        "type": "background",
        "background": "501240"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "沙漠之國的騷動告一段落後，又過了一段時間──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就在{player}等人返回蘭德索爾的日期將近之時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們收到了國王的傳喚。"
    },
    {
        "type": "dialogue",
        "name": "咲戀、流夏",
        "words": "打算將魔法神燈封印起來……！？",
        "unit_id": 1,
        "voice": "vo_adv_5128007_000"
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "嗯……",
        "unit_id": 1,
        "voice": "vo_adv_5128007_001"
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "這次發生這場騷動，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "\n導致國家陷入混亂，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "責任都要歸咎於老夫。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "為了讓人民幸福，",
        "unit_id": 1,
        "voice": "vo_adv_5128007_002"
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "老夫選擇了幫大家實現願望，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "\n這種隨便的做法……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "輕信每個人都能克制自己的慾望。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "\n結果，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "就造成了讓盜賊們為所欲為的慘況。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "為了不再重蹈覆轍，",
        "unit_id": 1,
        "voice": "vo_adv_5128007_003"
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "\n我們在商量過後",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "國王",
        "words": "得出了這個結論。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我……",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_004"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "仔細思考了",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "哥哥對我說的那番話。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "如果有不想實現的願望",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "就不用去實現。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "究竟什麼願望可以實現，",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_005"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "什麼願望不該實現。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "在我明白這些之前，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我想這是最好的解決辦法。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……可是，",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算是這樣。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "那個，",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_007"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這只是將我的本體，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n也就是將神燈安置在地下保管……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我本身並不會在地下長眠唷。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "雖然沒辦法使用神燈本體的魔力，",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_008"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n我的魔法",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "就會變得非常弱，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "但你們看，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我還是能像這樣出來外面。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼……",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼嘛，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來是這樣啊。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n太好了……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可是，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原本不就是因為封印神燈的事情，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n導致這個國家",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一分為二，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "長年爭吵不休嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這方面",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒問題嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這點我想是沒問題的。",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_011"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n就算……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "不靠我的魔法也一定能順利解決。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "對了，",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_012"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "原本說好要帶你們遊覽這個國家的對吧。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n雖然還在重建中，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "但是要不要一起去到處看看呀？",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n我想你們親眼看過之後，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "就會相信我所說的了。",
        "unit_id": 5313
    },
    {
        "type": "background",
        "background": "502060"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喂～",
        "unit_id": 1,
        "voice": "vo_adv_5128007_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "把那邊的石頭抬上來～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是驚人……",
        "unit_id": 127512,
        "voice": "vo_adv_5128007_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n城牆竟然已經",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "修復到這個程度了啊。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這裡原本",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_015"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "就是因採礦而繁榮的國家。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n石頭的加工技術",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "可是非常厲害的。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這點從我在的時候起",
        "unit_id": 5313,
        "voice": "vo_adv_5128007_016"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "就不曾變過……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "當時的國王",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "遵守了和我之間的約定呢。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，",
        "unit_id": 104811,
        "voice": "vo_adv_5128007_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "各位。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "已經要出發了嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "各位，",
        "unit_id": 104211,
        "voice": "vo_adv_5128007_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們好。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "兩位",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來替我們送行了啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n美冬應該還要打工吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是啊。",
        "unit_id": 104811,
        "voice": "vo_adv_5128007_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如你們所見，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我在幫忙修理城牆和建築物。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個魔像造成的損害很大，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n現在似乎到處都缺人手呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只要有需求的地方就會有我的身影",
        "unit_id": 104811,
        "voice": "vo_adv_5128007_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唷♪",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n千歌也暫時",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還會留在這裡對吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，",
        "unit_id": 104211,
        "voice": "vo_adv_5128007_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個國家",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有許多我沒見過的樂器\n和耐人尋味的傳說……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想在有空的時間裡，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "去調查看看。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 104211,
        "voice": "vo_adv_5128007_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家這麼努力地在重建城鎮，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n或許有什麼",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我可以幫上忙的也說不定。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呵，",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們就要在這分道揚鑣了呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯。",
        "unit_id": 104811,
        "voice": "vo_adv_5128007_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "回到蘭德索爾之後，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們再一起喝個茶吧。",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500660"
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "哎呀，",
        "unit_id": 1214,
        "voice": "vo_adv_5128007_026"
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "你們已經要離開了嗎？",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "\n",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "總覺得有些寂寞呢……",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "託各位的福，",
        "unit_id": 1012,
        "voice": "vo_adv_5128007_027"
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "我才能夠擁有像這樣幸福的日子。",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "\n",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "真的是",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "感激不盡。",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看你們過得好像很幸福是不錯啦……",
        "unit_id": 127612,
        "voice": "vo_adv_5128007_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不過",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你為什麼要拿著鋤頭耕田呢？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "這是法莉達的提案。",
        "unit_id": 1012,
        "voice": "vo_adv_5128007_029"
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "\n",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "不僅要拉近國家的兩個派系，",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "\n",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "也要拉近和人民間的距離，",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "為此希望能和大家站在相同的角度。",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "兩派想要走到徹底和解的那天，",
        "unit_id": 1012,
        "voice": "vo_adv_5128007_030"
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "\n想必會花上很長一段時間……",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "但是沒有問題。",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "\n你們為我們帶來了改變，",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "薩依德",
        "words": "我一定會守護好這個國家的。",
        "unit_id": 1012
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "大家也請",
        "unit_id": 1214,
        "voice": "vo_adv_5128007_031"
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "務必再過來玩。",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "\n",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "法莉達",
        "words": "在那之前，",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "法莉達",
