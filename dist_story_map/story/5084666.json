    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別無他法。",
        "unit_id": 111011,
        "voice": "vo_adv_5084666_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "能想到的對策，也全數嘗試過了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在此事態下",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可謂門外漢的我，或許已經束手無策了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哼……",
        "unit_id": 111011,
        "voice": "vo_adv_5084666_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼名譽博士，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我根本不夠格。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n儘管被吹捧為學院創校以來最厲害的才女，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n真的有事發生時，卻連一個後輩都救不了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "…………呼，",
        "unit_id": 111011,
        "voice": "vo_adv_5084666_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我再試著掙扎看看吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "OK羅塞塔，",
        "unit_id": 111011,
        "voice": "vo_adv_5084666_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "顯示地圖。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n自己所沒有的知識，也只能去尋求。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n既然如此，就去翻遍鎮上的書庫吧。",
        "unit_id": 111011
    }
]