[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隕石騷動過後的隔天，也就是元旦……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}等人來到了森神的祠堂。"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "再怎麼感謝你們都不夠。",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_000"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "都是因為儂會錯意，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "差點就造成了\n極為嚴重的事態……",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯嗯。",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n下次要為某個人實現願望時，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n記得先向本人好好確認後再執行喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "就是啊，",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_002"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "妳說的一點都沒錯。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "儂在此",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "再次向你們致歉。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說，",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "供品感覺是不是變多啦？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "除了我們，知道這座祠堂的人",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n扣掉栞栞的話，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就只有【暮光流星群】那兩人吧？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "關於這點……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我請被惠理子小姐抓住的",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "幫派成員幫忙調查時，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n簡單地解說了一下事情的來龍去脈。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當時或許還是半信半疑，",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不過隕石真的在除夕夜墜落了嘛。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "等平靜下來之後，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他們到處向幫派成員說出真相",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也不奇怪呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "雖然不太明白，",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_006"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "不過這就是所謂的高朋滿座吧！",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "其實只要誠心祭祀就會得到保佑，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "但儂被當成了要是隨便對待，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n就會扔下隕石的不妙神明，而變得很受歡迎呢！",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看妳開心的樣子，",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是這樣不就有一半的原因是被視為邪神嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "……是嗎，",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_008"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "或許是呢。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "看來這次",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "必須藉由保佑人們，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "來慢慢改善評價啊。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯嗯！",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n希望妳以後能夠為了大家的幸福，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n正確地使用力量呢～☆",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "嗯！",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_010"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "哎呀，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "對了，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "差點忘了。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "新年已經到來，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "許願次數也被重置了。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也就是說，",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又能夠實現三次願望了是嗎！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我想馬上變有錢……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "祈梨。",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n話先說在前頭，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這次事件中該反省的",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n並不是只有森神大人，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這點妳應該明白吧？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥啊？",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼要道歉啊！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣不就連我都必須認錯了嗎！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不不，",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請妳老老實實地認錯反省。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再說了，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳不是從真步那裡得到了工作應得的報酬嗎？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那些幾乎都被嘉夜夜沒收了啦！",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說是反正我多半會全都亂花掉，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以替我保管！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她越來越像老大了啦，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈，",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "簡直就像媽媽呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過我想，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "她一定是為了祈梨著想才這麼做。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n等哪天真的有需要，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "她應該會把錢還給妳的。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我現在真的很需要啊！",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既想買漫畫，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也想買遊戲，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還想買東西吃！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼就是不讓我隨意使用呢！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想聊回正題。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那三次願望，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "森神大人",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "打算怎麼使用呢？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "儂想用來答謝你們。",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_019"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n有什麼願望就說出來吧。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "對了，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "得好好地許下願望哦。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "不要說些",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "難以理解的話啊。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "該怎麼辦呢？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你有什麼",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "想要實現的願望嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "畢竟",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大家都好好地平安迎接新年了嘛！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小初音的願望是～～～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想到了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也算是決定好了。",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n祈梨妳怎麼樣？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想妳的願望內容會「善用自己的反省」就是了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這我當然曉得！",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "錢我是已經放棄了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "會請祂幫忙實現其他願望。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "那麼，",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_024"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "儂要問了。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n妳們想實現什麼樣的願望呢？",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這一年，",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "希望大家能夠健健康康地度過！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為重要的人們能夠常保活力，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就是小初音的幸福！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希望城鎮能夠維持和平。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有許多人",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在蘭德索爾生活。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不希望這樣的地方",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "發生重大事故或事件呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的話",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "希望能夠別被麻煩事波及。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就是所謂的遠離厄運啦。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比方說",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大暫時不要回來也沒關係。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "……嗯───────",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_028"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n儂所能夠實現的，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "是將能夠具體描述的物品實體化，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n或者是賦予特殊力量之類的。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "你們剛剛說的那類願望儂無法實現。",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_029"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "就不能許些",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "世俗一點的願望嗎？",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不，",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣就可以了。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "確實，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "許下想要錢財、物品，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "或是強大力量等願望後，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n或許是能得到它們……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是超出自身能力範圍的願望，",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只會造成不好的結果。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這就是我們學到的教訓。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_032"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如果有想要的東西就不該拜託神明，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n而是靠自己的力量獲取。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不去依靠像妳這種邪神什麼的，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而是",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要變成神明啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "這樣啊。",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_033"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n那麼",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "儂就不多說什麼了。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "就當儂單純聽過了你們的願望吧。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "再會了，",
        "unit_id": 5413,
        "voice": "vo_adv_5134007_034"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "知足的人們啊。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "千萬別忘記",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "這種心境哦……",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉──",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n稍微對祂謙虛點，祂就高高在上地說教！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那傢伙",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真的有反省嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "森神大人",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "搞不好",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "肩負著\n施予「懲戒」的職責也說不定呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯？",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這是什麼意思？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳仔細想想，",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請森神大人實現願望的\n難度",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "非常地低對吧？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯。",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_039"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n雖然說需要進行儀式，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但也只是在新年玩遊戲而已呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對於想輕易實現願望的人來說，",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n她原本該是位非常便於祈求的神明。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然而她的信仰之所以會中斷，",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_041"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就是因為裝作誤解願望，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對貪心之人施予懲罰才導致的……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這個假設如何呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯──",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_042"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "她看起來不像那麼恐怖的神明啊？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然了。",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以這就只是",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想像而已。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在我們有所欲求的情況下，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要為了解決事態而努力，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就願意出手幫忙。從這點來看，她確實很有良心。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不要看著我說這些話啦！",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_044"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "做出對已經過去的事情記仇",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這種和我家老大一樣的舉動，還是饒了我吧。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過呢，",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_045"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我認為最重要的是，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n她教導了我們",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "能夠",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "像這樣迎接新年到來呢☆",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是啊。",
        "unit_id": 128511,
        "voice": "vo_adv_5134007_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那麼我們就過去神殿吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "栞她們在等著我們呢。",
        "unit_id": 128511
    },
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103813,
        "voice": "vo_adv_5134007_047"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊！",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n妳有向森神大人",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好好打過招呼了嗎？",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！",
        "unit_id": 128411,
        "voice": "vo_adv_5134007_048"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我有好好地參拜，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也說出自己的願望了～☆",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……為了保險起見問一下，",
        "unit_id": 124711,
        "voice": "vo_adv_5134007_049"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳這次沒有再說什麼不必要的話吧？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一個個都這麼嘮叨是怎樣啊！？",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_050"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我只許了正經八百的願望，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n已經不會再引發麻煩事了啦──！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_5134007_051"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "改天要是又捅了婁子，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這次我一定會把妳砍成爛泥……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請做好心理準備哦。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫噫！？",
        "unit_id": 128311,
        "voice": "vo_adv_5134007_052"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不要在我什麼都沒有做的時候，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣子嚇唬人啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的是",
        "unit_id": 101011,
        "voice": "vo_adv_5134007_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "辛苦大家了～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
