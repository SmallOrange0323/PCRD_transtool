[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「傳說的聖獸」……",
        "unit_id": 106011,
        "voice": "vo_adv_9039155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙的力量",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓貪吃佩可和可蘿仔",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都喪失鬥志了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我不會輕易放棄的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我一定會得到那1000萬盧幣的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為此……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先是貪吃佩可！",
        "unit_id": 106011,
        "voice": "vo_adv_9039155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就在這個地方！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再一次複誦妳的欲望！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 105811,
        "voice": "vo_adv_9039155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "隊長！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我最喜歡吃魔物的肉！",
        "unit_id": 105811,
        "voice": "vo_adv_9039155_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n尤其喜歡可以品嚐到野生滋味的生肉！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我最喜歡霜降肉和油花分布均勻的烤肉了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下一個！",
        "unit_id": 106011,
        "voice": "vo_adv_9039155_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_9039155_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "隊長。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下最喜歡",
        "unit_id": 105911,
        "voice": "vo_adv_9039155_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照顧主人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下喜歡餵拿不了筷子的主人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吃飯。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下喜歡陪睡不著的主人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起睡覺。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看來妳們的欲望已經高昂起來了。",
        "unit_id": 106011,
        "voice": "vo_adv_9039155_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "非常好！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那麼，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看看那座湖！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在那裡泡水的目標物",
        "unit_id": 106011,
        "voice": "vo_adv_9039155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不擇手段的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n想淨化我們的欲望，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓我們喪失鬥志。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們並不是想成為",
        "unit_id": 106011,
        "voice": "vo_adv_9039155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "擺脫欲望的高尚人類！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒錯……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我想要1000萬盧幣！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們想要充滿欲望而閃閃發亮嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "是的！",
        "unit_id": 1,
        "voice": "vo_adv_9039155_010"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "隊長！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106011,
        "voice": "vo_adv_9039155_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很好，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "時機成熟了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "作戰開始！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "走走走！！",
        "unit_id": 106011
    }
]