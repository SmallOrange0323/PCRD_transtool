    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "除了看著以外，什麼都做不到嗎……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才沒那回事。",
        "unit_id": 101411,
        "voice": "vo_adv_5012301_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "步未\n並不是只能看著而已，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳是以自己的意志站在這的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再來就是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳想在這裡做什麼了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我想做什麼……",
        "unit_id": 105511,
        "voice": "vo_adv_5012301_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我……我想保護前輩……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n為了這個，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我什麼都做得到……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我的想法和妳一樣。",
        "unit_id": 101411,
        "voice": "vo_adv_5012301_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了保護助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我們一起戰鬥吧！",
        "unit_id": 101411
    }
