    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天就要離開薩拉薩利亞了。",
        "unit_id": 127511,
        "voice": "vo_adv_5128431_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒想到最後",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會變成一趟充滿意外的驚奇之旅呢。",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是啊，",
        "unit_id": 127611,
        "voice": "vo_adv_5128431_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "希望下次來這裡時",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們可以悠哉地度過呢。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我可不想再經歷",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種打打殺殺的激鬥了。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳說的沒錯。",
        "unit_id": 127511,
        "voice": "vo_adv_5128431_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這次旅行",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "受到流夏和你很多的幫助呢，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真的是",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很謝謝你們。",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 127611,
        "voice": "vo_adv_5128431_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果有幫上忙就好了。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "俗話不是說只要結果好，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一切都好嗎。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒錯，",
        "unit_id": 127511,
        "voice": "vo_adv_5128431_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這句話說的太好了。",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為了給旅途「劃下完美的句點」，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拜託你們一件事……",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拜託你們！",
        "unit_id": 127511,
        "voice": "vo_adv_5128431_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能不能陪我一起採購",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要給孩子們的伴手禮？",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n他們要求要禮物，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我完全忘記這件事了……",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "馬車出發的時間就快到了啊……",
        "unit_id": 127611,
        "voice": "vo_adv_5128431_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這趟旅行直到最後一刻",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也不得閒呢。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好吧，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們要先去哪裡？",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "搬行李的人",
        "unit_id": 127611,
        "voice": "vo_adv_5128431_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然是多多益善，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為了給這趟旅行「劃下完美的句點」，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你肯定",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "願意來幫忙的吧？",
        "unit_id": 127611
    }
]