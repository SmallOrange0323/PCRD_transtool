[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大消息，",
        "unit_id": 105913,
        "voice": "vo_adv_9008005_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "本節目收到了第一封聽眾來信。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請容在下介紹。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是筆名",
        "unit_id": 105913,
        "voice": "vo_adv_9008005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「過於美麗的我」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽眾的來信。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「請幫幫擁有傾國傾城",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "美貌的我。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n天生麗質的苦惱，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凡人或許難以理解，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但為了將這份能使魔物都癡迷的美",
        "unit_id": 105913,
        "voice": "vo_adv_9008005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傳遍全世界，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能請你們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n協助我追求更上一層樓的美嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟還有沒有什麼辦法，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能將\n我的美永遠保存下來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並讓世上所有人欣賞呢……」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "節目時間有限，剩下內容跳過……！",
        "unit_id": 1,
        "voice": "vo_adv_9008005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……考量本節目流程，",
        "unit_id": 105913,
        "voice": "vo_adv_9008005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剩餘的內容請容在下省略。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對此，您的看法如何呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莉莉小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這位",
        "unit_id": 125812,
        "voice": "vo_adv_9008005_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「我過於美麗」聽眾，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "似乎擁有傾國傾城",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n的美貌呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "想必也是藉由各式各樣的鍛鍊來維持美麗的吧。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……聽起來和",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雪小姐很相似呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "儘管有著想讓",
        "unit_id": 125812,
        "voice": "vo_adv_9008005_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "自身美貌永久不滅的大膽想法，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但又感覺得出有想要他人幫助",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "的迫切懇求隱藏在其背後。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我想",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這位聽眾肯定過得很辛苦吧。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還請您對自己有信心……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "莉、",
        "unit_id": 106012,
        "voice": "vo_adv_9008005_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "莉莉……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是把事情想得有點太嚴重了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對方確實也有可能是過得有一點點辛苦啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913,
        "voice": "vo_adv_9008005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "本人應該是十分認真地在煩惱此問題吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓我們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起替這位聽眾思考解決方案吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好的。",
        "unit_id": 125812,
        "voice": "vo_adv_9008005_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "一切都是為了正煩惱的聽眾……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "或許目前我能力有所不及，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過仍願一同努力絞盡腦汁。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話雖這麼說，",
        "unit_id": 106012,
        "voice": "vo_adv_9008005_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我們能為這個來信聽眾做的事，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n頂多也只有吐槽而已吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "例如「這是能怎麼辦啊～」",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之類的吐槽。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "吐槽……",
        "unit_id": 125812,
        "voice": "vo_adv_9008005_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這便是",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n牧場的真陽小姐曾提過，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n在搞笑中不可欠缺的重要環節對吧。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那麼，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "恕我失禮……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「這是能怎麼辦啊～」",
        "unit_id": 125812,
        "voice": "vo_adv_9008005_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……請問",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "像這樣可以嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可沒叫妳真的照做啊！",
        "unit_id": 106012,
        "voice": "vo_adv_9008005_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "更何況，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明都沒弄懂意思就不要先行動啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "嗚嗚……",
        "unit_id": 125812,
        "voice": "vo_adv_9008005_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好的……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n果然",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "像我如此不成氣候的人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是沒辦法替「過於美麗的我」聽眾做些什麼事的嗎……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莉莉小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_9008005_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有這回事！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來將我們的心意",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實傳達給",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「過於美麗的我」聽眾吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請和在下一起說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「這是能怎麼辦啊～」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "這是能怎麼辦啊～！\n這是能怎麼辦啊～！",
        "unit_id": 1,
        "voice": "vo_adv_9008005_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可、",
        "unit_id": 106012,
        "voice": "vo_adv_9008005_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼連妳也一起攪和起來了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913,
        "voice": "vo_adv_9008005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐也一起吧！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n心裡想著「過於美麗的我」聽眾，並說……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "這是能怎麼辦啊～！",
        "unit_id": 1,
        "voice": "vo_adv_9008005_019"
    }
]