[
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "亢奮狀態下的席茲，不斷追著\n離開了村子的{player}一行人。"
    },
    {
        "type": "dialogue",
        "name": "席茲",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 10111
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好強的風壓……席茲光是振翅就有這麼強的威力……",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊啊！",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "席茲",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 10111
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "果然這樣的風壓，",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "箭矢是射不過去的――！",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哈哈哈……那隻鳥，看起來相當的憤怒呢……",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "必須趕緊想到對策才行……",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_003"
    },
    {
        "type": "background",
        "background": "500212"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼、呼……你們兩個，沒事吧！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯嗯……我沒事，唔……",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞！因為你持續在活動的緣故吧……稍微休息一下如何？",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊我沒事的……就剩下一隻了……",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，這一隻可無法用普通的方法對付呢……",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "由於振翅產生出的風壓，用正常方式射出的箭矢是攻擊不到它的。",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這和之前的魔物相比強太多了……該怎麼辦才好……",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "席茲",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 10111
    },
    {
        "type": "dialogue",
        "name": "初音・栞",
        "words": "呀――",
        "unit_id": 1,
        "voice": "vo_adv_5001006_009"
    },
    {
        "type": "dialogue",
        "name": "初音・栞",
        "words": "！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小、小栞！我用魔法來強化小栞的攻擊吧！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n如此一來就不會輸給風壓了吧！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是姊姊。這樣的風壓我沒辦法好好瞄準！",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一旦射偏的話，就會受到席茲的攻擊了！",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎麼會！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "　那該怎麼辦才──",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那、那可不行！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是啊，太危險了！誘餌的話由我來……",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……{player}……",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我知道了……",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不過，",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你真的不要太勉強自己……",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……我知道了，我相信你。",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要是情況過於危險一定要逃走喔！我不要你死掉！",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500212"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "該怎麼辦──！",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇哇哇哇！突、突然力量湧現了出來！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n是因為他嗎！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事吧……非常感謝你，這樣一來的話！",
        "unit_id": 103812,
        "voice": "vo_adv_5001006_019"
    },
    {
        "type": "still",
        "still": "500100601"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姐姐──！",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "魔法，滿載！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "可以了小栞！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就這樣……結束掉！",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "給它瞧瞧♪我們的火力全開！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_024"
    },
    {
        "type": "dialogue",
        "name": "初音・栞",
        "words": "上啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_5001006_025"
    },
    {
        "type": "still",
        "still": "500100602"
    },
    {
        "type": "dialogue",
        "name": "席茲",
        "words": "──嘰哦哦哦哦哦！",
        "unit_id": 10111
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "打中了！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們三人的力量，是不會輸給風的！",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_027"
    },
    {
        "type": "dialogue",
        "name": "席茲",
        "words": "──嘰哦哦哦哦哦！",
        "unit_id": 10111
    },
    {
        "type": "background",
        "background": "500212"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "用術式……",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "將封印……完成了。",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "辦到了……太好了太好了！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n小栞妳太厲害了！我剛才看到了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞的箭矢和我的魔法啪咻地一下！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好厲害好厲害！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，多虧了有姊姊和{player}的力量……",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的太謝謝你們了。這麼一來，圖鑑便能恢復原狀了……咦？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎麼了小栞？",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不……箭矢被射到沒辦法回收的地方了……",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n箭矢上還綁著書籤……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……啊啊啊啊啊啊啊！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎、怎麼辦姊姊，如果不拿回來萬一魔物又出現了的話！",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "交、交給我吧小栞！",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n姐姐我馬上就去拿回來！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊！姊姊！",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……走掉了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是姊姊她……知道位置嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_5001006_039"
    },
    {
        "type": "background",
        "background": "500512"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚哇！雖然可以用瞬間傳送，但書籤在哪裡啊！？",
        "unit_id": 101211,
        "voice": "vo_adv_5001006_040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，初音因為拼了命尋找書籤而陷入了窘境。"
    }
]