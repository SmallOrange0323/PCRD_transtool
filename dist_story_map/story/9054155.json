[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔～嗯……",
        "unit_id": 105811,
        "voice": "vo_adv_9054155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "照這張地圖上寫的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "目標應該就在附近了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但無論怎麼看都只有",
        "unit_id": 105911,
        "voice": "vo_adv_9054155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沙、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沙、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沙……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "眼前只有一片",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無邊無際的沙漠跟沙丘呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「惡魔將在沙塵暴捲起之時出現」，",
        "unit_id": 106411,
        "voice": "vo_adv_9054155_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個古代遺跡",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "似乎有此傳聞。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "聽說其是由好幾塊巨石堆砌而成，外觀看起來像神殿……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連個影子都沒有嘛。",
        "unit_id": 106011,
        "voice": "vo_adv_9054155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n花凜那傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是給錯地圖了啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先別下定論，",
        "unit_id": 105811,
        "voice": "vo_adv_9054155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也才剛開始調查啊！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別心急，放輕鬆點，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "稍微吃些東西，慢慢找吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_9054155_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說得有道理。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就定下心來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仔細調查吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106011,
        "voice": "vo_adv_9054155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們調查艾爾皮斯島也很久了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒想到像這種偏僻的邊境地方，也有遺跡在呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯。",
        "unit_id": 106411,
        "voice": "vo_adv_9054155_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "自從我跟妳們會合後，就一直在沙漠中四處探索……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也發生了不少事、嚐到不少料理呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n世界真的很大！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總令人感到好雀躍呀。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_9054155_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正因為如此，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "冒險才是如此值得挑戰之事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105811,
        "voice": "vo_adv_9054155_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來小雪菲也很享受冒險之旅嘛☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我聽了也跟著感到好開心♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開始熟悉冒險是好事啦，",
        "unit_id": 106011,
        "voice": "vo_adv_9054155_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但可不要大意喔？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟說不準接下來會發生什麼事。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "得提高警覺──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼回事……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "四周突然一片模糊……",
        "unit_id": 106411,
        "voice": "vo_adv_9054155_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沙塵暴……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難道",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是傳說中的──",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喵……！",
        "unit_id": 106011,
        "voice": "vo_adv_9054155_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不要突然抓緊我啦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你哪位啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留！？",
        "unit_id": 106411,
        "voice": "vo_adv_9054155_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我懂了，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不提高警覺，就會像妳這樣嗎……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯沒錯，",
        "unit_id": 106011,
        "voice": "vo_adv_9054155_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看我這個冒險老手怎麼親身做示範──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最好是啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難不成這傢伙",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n想吃掉我！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚喵啊啊啊啊～！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不會讓你吃掉小凱留的！",
        "unit_id": 105811,
        "voice": "vo_adv_9054155_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n把我們的寶貝小貓咪還來！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "少趁亂把別人當成寵物叫啦！",
        "unit_id": 106011,
        "voice": "vo_adv_9054155_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "住手住手！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不好吃啦～！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐！",
        "unit_id": 105911,
        "voice": "vo_adv_9054155_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下馬上來相救！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大家，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "準備上吧！",
        "unit_id": 105911
    }
]