        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這談吐的方式可說是如同我的天性一般。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n同時，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "贊恩您是我們【憤怒‧軍團】的",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n公會長的這件事，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "也同樣是事實。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "關於此事，",
        "unit_id": 191711,
        "voice": "vo_adv_2102007_063"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "才正是虛有其表。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "甚至以我的立場，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "關於現今的狀況，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n還更是想要請教年長者的意見。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……嗯。",
        "unit_id": 191911,
        "voice": "vo_adv_2102007_064"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "以贊恩您為首，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "此公會的戰鬥能力與其他地方完全無法相提並論。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n不僅如此再加上，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "贊助商的支援也堅若磐石。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "若說有何懸念那果然……",
        "unit_id": 191911,
        "voice": "vo_adv_2102007_065"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "便是我們之間的信賴關係太過薄弱了吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "那還真是",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "如同粗糙的偽幣一般薄弱呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "是。",
        "unit_id": 191711,
        "voice": "vo_adv_2102007_066"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n我們一行人，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "不過就是被『實現願望』此誘餌給聚集……",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "說穿了就是群烏合之眾。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "將無數玩家的悲嘆當成了引線",
        "unit_id": 191711,
        "voice": "vo_adv_2102007_067"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "所能實現的願望，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "『現在』只有一個。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n若是要避免同伴自相殘殺，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "那麼增加願望是必須的……",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "正是。",
        "unit_id": 191911,
        "voice": "vo_adv_2102007_068"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n正如同卡里莎所講的，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n誰都不想額外操心有誰會偷跑的可能性呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "卡里莎直言不諱。",
        "unit_id": 191711,
        "voice": "vo_adv_2102007_069"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n關於這一點，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "正巧能補上我們所欠缺的不足。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵呵，",
        "unit_id": 191911,
        "voice": "vo_adv_2102007_070"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "您說的是。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n能截長補短彼此的缺點固然是件好事",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "然而……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我們【憤怒‧軍團】",
        "unit_id": 191911,
        "voice": "vo_adv_2102007_071"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "有五人。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n並且若各個皆抱持著相異的願望——",
        "unit_id": 191911
    },
    {
        "type": "still",
        "still": "210200701"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "那麼該獵捕的七冠，",
        "unit_id": 191711,
        "voice": "vo_adv_2102007_072"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "就還需四人。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n——便是這麼一回事吧。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是。",
        "unit_id": 191911,
        "voice": "vo_adv_2102007_073"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n『每多獵捕一名七冠，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "能夠實現的願望就能再增添一個』——",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我們的贊助商，",
        "unit_id": 191911,
        "voice": "vo_adv_2102007_074"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "便是擁有如此力量之人。",
        "unit_id": 191911
    },
    {
        "type": "still",
        "still": "end"
    }
]