[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "才剛開始做送信工作的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n某天因為找不到最後一封信件的收件者，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在蘭德索爾市內四處奔走。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……？",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你好～",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你在找什麼嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這一帶是幫派的地盤，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "危機四伏，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n最好別單獨一個人在這裡閒晃喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還是說，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你是來找人的嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哇啊～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是巧！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你要找的帆稀，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就在這裡喔～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "答對了～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你送信過來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "送信員♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，我來簽收……",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣就可以了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n好了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "到底是誰寄來的信件呢～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯……",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒有署名耶。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你知道是誰──",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "怎麼了！？",
        "unit_id": 811,
        "voice": "vo_adv_1067001_007"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "上門鬧事嗎！？",
        "unit_id": 6311,
        "voice": "vo_adv_1067001_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咳、",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咳……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎喔！",
        "unit_id": 1,
        "voice": "vo_adv_1067001_010"
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呼……",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是危險呢，拉格。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你沒事吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有沒有受傷？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n雖說我有幫你施展了防禦魔法。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣啊～",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒事就好☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "突然發生爆炸，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想必你也嚇一大跳吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "老大！",
        "unit_id": 811,
        "voice": "vo_adv_1067001_013"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "到底發生了什麼事！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "出了點意外。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這孩子送來的信件爆炸了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "妳說什麼！？",
        "unit_id": 6311,
        "voice": "vo_adv_1067001_015"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "喂，你這小子！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "別以為你可以活著回去啊！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你們兩～位。",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這件事跟這孩子無關，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別對他發脾氣。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "他若知道自己會被爆炸波及到的話，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就不會一直站在我身邊了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "雖然老大這麼說也是……",
        "unit_id": 6311,
        "voice": "vo_adv_1067001_017"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n不過，他也可能是豁出去了，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "萬一──",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就算是這樣，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也不能再對他發脾氣了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n要是再出聲責備他，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我可要生氣囉。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "知道嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "是的！",
        "unit_id": 6311,
        "voice": "vo_adv_1067001_019"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "知道了！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "老大，",
        "unit_id": 811,
        "voice": "vo_adv_1067001_020"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "這會是哪個傢伙搞的鬼啊？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯……",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "若從最近跟我們作對的組織來思考，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n很快就有眉目了呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之～",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就先去確認看看吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "既然這樣，",
        "unit_id": 811,
        "voice": "vo_adv_1067001_023"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "我們也要一起去！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "老大，",
        "unit_id": 6311,
        "voice": "vo_adv_1067001_024"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "我們會跟著妳到天涯海角的！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你們～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們這就去……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "回個禮吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哎呀～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你沒聽見我剛才說的話嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯！",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為你被不認識的壞人所利用，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n剛剛差點",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就丟了小命呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這種狀況～",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一定要好～好譴責對方♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是你在這裡放過犯人，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n說不定他們下一次還會再利用其他人。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哪怕對方是衝著我而來的，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你被捲入也是事實。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然如此，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n現在就去把這件事解決掉比較好喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我還沒自我介紹吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我是掌控這一帶的幫派",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「龍骨家族」的老大，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n名叫帆稀♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還請多指教～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這孩子是拉格。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是隻很可愛、很可愛的龍喔☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "拉格，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "打聲招呼吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎喔～！",
        "unit_id": 1,
        "voice": "vo_adv_1067001_034"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "老大！",
        "unit_id": 811,
        "voice": "vo_adv_1067001_035"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "那邊就是那些傢伙們的據點！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "請小心點，老大。",
        "unit_id": 6311,
        "voice": "vo_adv_1067001_036"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "要是有什麼危險，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "我們會為妳挺身擋下！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "用不著這麼擔心，沒問題的～",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "話說回來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你們太過血氣方剛，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這孩子會被嚇到的，是吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這時候更應該冷靜下來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "保持微笑才對♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "午安～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_038"
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "唔！？",
        "unit_id": 1111,
        "voice": "vo_adv_1067001_039"
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "妳、",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "妳怎麼會……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊哈哈♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n謝謝你這麼簡單明瞭的反應～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "帆、",
        "unit_id": 911,
        "voice": "vo_adv_1067001_041"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "帆稀！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳怎麼……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好了，暫～停♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_042"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你可別問我：「妳怎麼還活著？」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這種",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "無聊的問題喔？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "唔",
        "unit_id": 911,
        "voice": "vo_adv_1067001_043"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "術式的完成度不差呢～",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "威力若不增強點，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是沒辦法擊倒我的☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "即便如此，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "竟然施加了那等爆破威力的魔法，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你根本不在乎一般人會不會遭受波及，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "哼！",
        "unit_id": 911,
        "voice": "vo_adv_1067001_046"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "要殺妳哪能放水啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n妳這個、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "怪物……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真～過分！",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_047"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別把人說得像魔物一樣～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……退個一百步說，即使我可以允許你們衝著我來，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_048"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但是，你那即便送信員會受到波及也毫不在乎的想法，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我絕不能原諒呢～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為要是認同了你這樣的想法，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_049"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我就成了與你們同樣程度的人渣了",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是嗎。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊啊，不過，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_050"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這孩子一樣正正當當地過活的人們眼中，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們大～家大概都跟人渣沒兩樣吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳……",
        "unit_id": 911,
        "voice": "vo_adv_1067001_051"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "到底想怎麼樣？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個嘛……",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_052"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請你道歉♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "啥？",
        "unit_id": 911,
        "voice": "vo_adv_1067001_053"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以說～",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_054"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請你道歉♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖說我們這邊並不想把事情鬧大，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但也不能對把一般人也捲進來的事件視而不見，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以希望",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你能為這件事好好地道歉～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "這樣啊……",
        "unit_id": 911,
        "voice": "vo_adv_1067001_055"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "既然這樣，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n就讓我們這邊的年輕小夥子來賠罪吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "這樣就行了吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "喂，我說你啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "還不快道歉！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_056"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為何你不親自道歉呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "因為這並不是我做的事啊。",
        "unit_id": 911,
        "voice": "vo_adv_1067001_057"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n雖然我曾說過他們要給帆稀好看，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "但並沒有想讓事情變成這樣……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "這次",
        "unit_id": 1111,
        "voice": "vo_adv_1067001_058"
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "真的很抱歉！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "\n我誠心誠意地",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "賭上性命向您表達",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "十二萬分的歉意！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……這樣啊，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_059"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以說呢，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n該怎麼處置這個人，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以由你來決定喔？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "例如，為了表示誠意，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_060"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看是要現在就當場",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "取了他的性命，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n或是在你有需要的時候",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "使喚他來幫忙♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不管你想要他做什麼都行喔。",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_061"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，你想怎麼做呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哦……",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_062"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣啊～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也不能讓他們什麼都不做，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不如把你的權利",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓給我……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒問題吧♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真遺憾～！",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_063"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看來這個人的道歉",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一點價值也沒有呢！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們希望能由地位再高點的人……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也就是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "最偉大的人來道歉喔☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "啥！",
        "unit_id": 911,
        "voice": "vo_adv_1067001_064"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "別開玩笑了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_065"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "除了道歉外，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n導致我們雙方相互敵對的地盤，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你也得負起責任，把它讓給我♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "聽妳在那邊鬼扯！",
        "unit_id": 911,
        "voice": "vo_adv_1067001_066"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n我幹嘛要這麼做！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為小嘍囉的賠罪解決不了問題，這也是沒辦法的事～",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_067"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來讓一般人捲入幫派之間的鬥爭，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "事情就會變成這樣呢～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n啊啊～真是可怕哪！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳以為這番鬼話行得通嗎！",
        "unit_id": 911,
        "voice": "vo_adv_1067001_068"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n我絕對……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不道歉？",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_069"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這就沒辦法了～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "得讓蘭德索爾市內的人們都知道這件事才行",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……知道這邊的幫派，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n會為了爭奪地盤而把一般人捲進來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很～危險",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這件事。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳、",
        "unit_id": 911,
        "voice": "vo_adv_1067001_070"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳這是……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "反正被捲入的人現在還活得好好的，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_071"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不如現在就來寫封請願書，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n送到【王宮騎士團】那裡去吧♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "之後，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_072"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你們就會受到騎士團非常嚴格的控管，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n別說是地盤了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "搞不好……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n組織本身就會整個瓦解呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "唔……！",
        "unit_id": 911,
        "voice": "vo_adv_1067001_073"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "帆稀……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳這傢伙～！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好～啦，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_074"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你要怎麼做呢～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我想在場的每個人，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該都希望事情能和平解決吧……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你難道不是嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是我猜錯了，那就抱歉囉～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "……我知道了。",
        "unit_id": 911,
        "voice": "vo_adv_1067001_075"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n這位小哥，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "我做了對不起你的事，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "在此向你賠罪。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "還有，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "那塊地盤就讓給妳了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "隨妳處置吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_076"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那麼，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「這次」就原諒你們……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "下次可不會這麼簡單囉。",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500891"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "各位，辛苦了～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_077"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大家不但能平安無事地回來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "甚至連地盤也要到手了☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "妳辛苦了！",
        "unit_id": 811,
        "voice": "vo_adv_1067001_078"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n我們的老大果然是最強的！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "今後",
        "unit_id": 6311,
        "voice": "vo_adv_1067001_079"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "我們也會跟隨妳一輩子的！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_080"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今後也得仰賴你們的努力，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還請多指教☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我還有些話要跟這孩子說，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你們就先回去吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好了……",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_081"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真抱歉～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓你捲入了幫派之間的鬥爭。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你覺得很可怕吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，託你的福，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也獲益不少呢♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n希望下次有機會",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以好好地向你賠罪和道謝☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那當然～！",
        "unit_id": 106711,
        "voice": "vo_adv_1067001_082"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "下次見囉。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n回去的路上要多加小心喔～！",
        "unit_id": 106711
    },
