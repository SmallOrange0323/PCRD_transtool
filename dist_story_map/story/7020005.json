        "voice": "vo_adv_7020005_064"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥先前",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為了找回記憶曾登上了塔。",
