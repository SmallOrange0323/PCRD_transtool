        "voice": "vo_adv_7020005_063"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼一回事啊喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說清楚點喵。",
