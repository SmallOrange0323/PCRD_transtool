        "voice": "vo_adv_7020005_065"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這麼重要的事為什麼不先說啊喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這比製作鯛魚燒重要多了喵！",
        "unit_id": 104611
