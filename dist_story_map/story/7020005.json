        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今後我會把妳視為搭檔候補，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "引導妳走上搞笑之路的啦！",
