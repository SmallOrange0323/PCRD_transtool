    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "珠希果然很適合走搞笑路線！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不管妳說什麼，我都不會走搞笑這條路的喵！",
        "unit_id": 104632,
        "voice": "vo_adv_7020005_057"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……不過，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我很欣賞真陽喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我平常就在這裡做鯛魚燒，歡迎下次再來喵。",
        "unit_id": 104632,
        "voice": "vo_adv_7020005_058"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "希望妳能告訴我北海道有哪些美味的食材喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這、",
        "unit_id": 103332,
        "voice": "vo_adv_7020005_059"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是當然的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘿嘿，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也交到了老哥以外的朋友啦！",
        "unit_id": 103332
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯……",
        "unit_id": 104611,
        "voice": "vo_adv_7020005_060"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼會在這種地方睡著了喵？",
