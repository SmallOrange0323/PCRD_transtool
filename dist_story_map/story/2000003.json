[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………。"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "早安",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抱歉抱歉，把你吵醒了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你可以繼續睡沒關係，反正我也想要集中精神工作……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n現在可沒有功夫陪你呢",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯？你怎麼露出『妳是誰呀？』的表情呢，",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我可是很清楚你的說……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看到你像是第一次看到我的樣子，內心還是會覺得有點難過。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的名字是……嗯，你就叫我愛梅斯好了。",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n最近大家都是這樣稱呼我的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不用勉強記住也沒關係喔，反正你大概馬上就會忘記了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為，",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這也像是，類似夢境之類的東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如你所見我現在已經渾身是傷完全損壞了，",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在自我修復完成之前都沒有辦法活動。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也無法干涉現實。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我派出了一位代理人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n由她負責擔任你的『嚮導』。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她是你的人生、也就是現實裡的領航員。",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n詳細的內容你就去問她吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對不起，看來這一次的碰面差不多就只能到這裡了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我還有好多好多話想跟你說呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現實是很殘酷的。",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過我們也不能夠老是做夢呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，再見囉。",
        "unit_id": 190011,
        "voice": "vo_adv_2000003_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我會祈禱你的人生、和你的現實裡都充滿了幸福。",
        "unit_id": 190011
    }
]