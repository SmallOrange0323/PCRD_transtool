        "voice": "vo_adv_1210001_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "思念你的少女的故事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是與你一起被困在",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「人工世界」的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "貪吃佩可的故事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "仔細看看她有多麼",
        "unit_id": 190011,
        "voice": "vo_adv_1210001_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "思念著你吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要錯過她們的身影，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好好體會她們的思念。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是現在的我",
        "unit_id": 190011,
        "voice": "vo_adv_1210001_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "傾盡全力能給你的禮物，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜託你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天，貪吃佩可從幸福的夢中醒來──"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼嚕呼嚕……",
        "unit_id": 1,
        "voice": "vo_adv_1210001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "漢堡和壽司……",
        "unit_id": 1,
        "voice": "vo_adv_1210001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肉醬直麵和",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "特大份的特製軟泥怪蓋飯……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我已經吃不下了～～～！！！！",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡是……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我為什麼會在長椅上……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還在作夢嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咕嚕嚕嚕嚕嚕嚕～～！！"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這股飢餓是真實的……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我好像不是在作夢……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是說仔細想想，",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我昨天應該是睡在王宮中的寢室。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃過宵夜後，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我刷了牙",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就鑽進棉被裡……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是在睡覺時被綁架了嗎！？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "老人1",
        "words": "我說老爺爺，",
        "unit_id": 1,
        "voice": "vo_adv_1210001_010"
    },
    {
        "type": "dialogue",
        "name": "老人1",
        "words": "今天的天氣也很不錯啊～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "就是說啊～",
        "unit_id": 1,
        "voice": "vo_adv_1210001_011"
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "\n好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "就再",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "散步一會兒吧～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但以綁架案來說，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得好和平啊……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "哇～！",
        "unit_id": 1,
        "voice": "vo_adv_1210001_013"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "等我等我──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗚哇～！",
        "unit_id": 1,
        "voice": "vo_adv_1210001_014"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不要過來──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說到底，",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是蘭德索爾嗎……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這些建築物和附近的人們身上的衣服……",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像有在哪裡看過……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "了！",
        "unit_id": 105831
    },
    {
        "type": "still",
        "still": "201201401"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在愛梅斯大人帶領我們",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "進入的小凱留心裡，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是這樣的風景……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我記得",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是叫「現實世界」吧……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那時候",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿跟{player}也一起來了，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但現在我身旁沒有其他人……",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說，",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這並不是愛梅斯大人帶領我",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "進入的某個人的內心嗎……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在不認識的地方，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就只有我自己一個人……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼辦呢……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不過，",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "坐在這裡思考",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也不是辦法啊。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了找出回到蘭德索爾的線索，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就來四處走走吧～！",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！？",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_021"
    },
    {
        "type": "dialogue",
        "name": "駕駛員",
        "words": "這個笨蛋！",
        "unit_id": 1,
        "voice": "vo_adv_1210001_022"
    },
    {
        "type": "dialogue",
        "name": "駕駛員",
        "words": "走路要看路啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "駕駛員",
        "words": "\n現在",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "駕駛員",
        "words": "是紅燈耶！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對、",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起～～！！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉……",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛才的交通工具",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是什麼啊……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n既不是馬車，也不是古代兵器……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我沒在蘭德索爾看過那個耶。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "它行駛的速度非常驚人，",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果撞上去，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那可就不好了。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "撞上去的衝擊說不定能讓我飛到蘭德索爾……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我說說的，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "天底下哪有這麼剛好的事情。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉～",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡果然",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和蘭德索爾完全不一樣啊……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的衣服和平常不同，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身上也沒有皇家裝備。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個世界有一堆我不懂的事情，",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我在行動時",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得要多加小心……！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咕嚕嚕嚕嚕～～～！！"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊嗚……",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子餓扁了～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再不吃飯，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就要倒在路邊了……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗯？",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗅嗅……！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔",
        "unit_id": 105831,
        "voice": "vo_adv_1210001_031"
    },
    {
        "type": "dialogue",
