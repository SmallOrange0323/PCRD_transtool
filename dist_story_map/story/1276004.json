[
    {
        "type": "background",
        "background": "501370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在薩拉薩利亞萬里無雲的天空下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n流夏與{player}在綠洲過著只有兩人的時光。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話又說回來……",
        "unit_id": 127612,
        "voice": "vo_adv_1276004_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "今天發生了很多事呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然這是精靈的好意，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就讓我們悠閒地度過吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯……！",
        "unit_id": 127612,
        "voice": "vo_adv_1276004_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒什麼。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n綠洲在陽光的照射下，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "顯得格外地閃閃發光呢……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦？",
        "unit_id": 127612,
        "voice": "vo_adv_1276004_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "該不會",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "發光的其實是你？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔、",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "眼睛……！",
        "unit_id": 127612
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被流夏約出來的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了商店街。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你來了啊。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n在這裡。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真不好意思。",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n雖然答應了要幫忙商店街的活動，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但是我實在不懂這方面的事情，正為此傷腦筋呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對Cosplay很了解嗎？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是我提問的方式不太好。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "問題並不是我有沒有興趣……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊～",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n應該",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說是變裝才對呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "馬上就要到萬聖節了不是嗎？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這個商店街",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也打算要舉辦適合小孩子",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n參加的變裝遊行，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是這次包含幫忙的人在內，所有人都必須變裝。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我對這方面的事情一竅不通啊……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以才把你找來了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1276004_009"
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "這個人就是流夏的Cosplay老師嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "Cosplay老師是什麼啊……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "他是幫手。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "以年輕女生來說，",
        "unit_id": 1,
        "voice": "vo_adv_1276004_011"
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "我沒怎麼看過流夏打扮呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "\n你要好好幫她挑選",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "適合她的Cosplay喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不需要這麼有幹勁啊……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "答得好。",
        "unit_id": 1,
        "voice": "vo_adv_1276004_013"
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "\n那麼之後",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "工商會會員",
        "words": "就交給你們兩個年輕人囉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等等，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那種說法……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唉，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "她的人是不壞，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n只是有時候會有點太過雞婆。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一直盯著我的臉看。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "算了，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "現在更重要的是你快點聽我說。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我姑且",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也有試著想了提案，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是被商店街的大家反對了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我還有嘗試畫了圖，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你看看。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我是覺得很可愛啦。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就像你看到的，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是很有魚店風格的魚布偶裝。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "像這樣從魚嘴的地方露出頭，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "手再從鰓的地方穿出來……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說「但是」，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就表示你應該也有什麼想法吧？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n說來聽聽看吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦咦？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是這樣嗎？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我覺得設計得還不錯啊……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "製作也需要花費時間和人力",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是嗎。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是這種服裝",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在商店買會很貴吧？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n該怎麼辦才好……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔～",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拿現有的東西改造是嗎？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n制服之類的？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你還真會想呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……等一下。",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你剛才說什麼？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n制服……？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不不不不！",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我才不穿什麼學生時期的制服喔。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有沒有",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "其他方向，但同樣有變裝感的點子呢？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "像是奇幻類，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "或是非日常感",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的那些……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼說來，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我記得有那個人從國外帶回來給我當伴手禮的衣服……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你等我一下，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我回家去拿。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "說完後便跑走的流夏，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n很快地又帶著裝了異國服裝的袋子回來。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我記得這好像",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是從肚皮舞的發源地帶回來的伴手禮……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "奇怪？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這個是男生穿的嗎？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後這邊有女生穿的啊。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n說起來，對方好像有說過服裝是男女成對的，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且很便宜……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呃，這個……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不會有點難為情嗎？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這和制服是不同方向的。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話雖這麼說，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但目前有的選擇",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只有制服和這套衣服啊……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦咦！？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n好吧，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然你這麼說的話……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我知道了，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我也做好心理準備吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就當天見了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n麻煩你囉。",
        "unit_id": 105631
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，時間來到商店街萬聖節遊行的當天……"
    },
    {
        "type": "still",
        "still": "127600401"
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "不給糖就搗蛋！",
        "unit_id": 1,
        "voice": "vo_adv_1276004_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好喔。",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_034"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這是我給你們的，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n拿去吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "哇～",
        "unit_id": 1,
        "voice": "vo_adv_1276004_035"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝大姐姐！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我已經把該給的給你們了，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_036"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n可別對我惡作劇喔。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "呿～",
        "unit_id": 1,
        "voice": "vo_adv_1276004_037"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "真是沒辦法。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n那這次換找這邊的大哥哥要糖果吧！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯！",
        "unit_id": 1,
        "voice": "vo_adv_1276004_038"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "預～備！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "不給糖就搗蛋！",
        "unit_id": 1,
        "voice": "vo_adv_1276004_039"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "咦～",
        "unit_id": 1,
        "voice": "vo_adv_1276004_040"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "你沒有帶嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "既然這樣……",
        "unit_id": 1,
        "voice": "vo_adv_1276004_041"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那我們要惡作劇啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好好好，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_042"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "先等一下。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這位大哥哥的份也由我來給你們，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可以放過他嗎？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "什麼啊，",
        "unit_id": 1,
        "voice": "vo_adv_1276004_043"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "這樣不會太狡猾了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這個就是",
        "unit_id": 1,
        "voice": "vo_adv_1276004_044"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "所謂的「共同財產」嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那是什麼意思？",
        "unit_id": 1,
        "voice": "vo_adv_1276004_045"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "就是夫妻！",
        "unit_id": 1,
        "voice": "vo_adv_1276004_046"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n他們穿著情侶裝，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "而且還很年輕，所以是新婚夫妻吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_047"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳居然知道這麼難的詞彙啊。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那個，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這樣啊～",
        "unit_id": 1,
        "voice": "vo_adv_1276004_048"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那麼好吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n我們家也是媽媽給過以後，爸爸就不會再給了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "這樣啊，",
        "unit_id": 1,
        "voice": "vo_adv_1276004_049"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "既然是新婚夫妻，那就沒辦法了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "比起這個，繼續待在這裡沒關係嗎？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你們還要去其他地方吧？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n如果不快點去，糖果就要沒囉。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "糟糕！",
        "unit_id": 1,
        "voice": "vo_adv_1276004_051"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我都忘記了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n我們趕快走吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1276004_052"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "等等我啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n再見了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "新婚的大姐姐！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_053"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小孩子真的是",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對什麼事都很感興趣呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "差點要反應不過來了呢……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_054"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話又說回來……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "被人那樣揶揄，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真虧他還能保持平靜。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_055"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不行不行。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n現在還在幫忙呢……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "得集中精神才行。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_056"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也要先準備好之後要發的糖果喔。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "商店街萬聖節遊行，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "糖果在這裡也有喔～！",
        "unit_id": 105631
    },
    {
        "type": "background",
        "background": "510291"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "時間來到了傍晚，萬聖節遊行結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n商店街又恢復到往常的平靜氛圍。"
    },
    {
        "type": "still",
        "still": "127600402"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_057"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "剛才的小孩子就是最後了吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還真是抱歉啊。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我原本只是打算和你討論衣服的事情，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_058"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n沒想到還讓你像這樣在當天到服務台來幫忙。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_059"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你為了不讓我感到難為情，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n還特地跟我穿了成對的衣服。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯～～～！",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_060"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之辛苦你了！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_061"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果是站著的話，要我站多久都行，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是擔任服務台人員要一直坐著才行呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n肩膀都有點僵硬了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_062"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n站在那種地方……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呀唔？",
        "unit_id": 105631
    },
    {
        "type": "still",
        "still": "127600403"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "欸？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_063"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要幫我按摩肩膀？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不用啦，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不需要做到那種程度……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯嗯！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_064"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不是覺得痛……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不是那樣……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯嗯！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_065"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "肩膀很僵硬？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那麼，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就麻煩你好了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯嗯……",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_066"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你力氣還滿大的呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這力道剛剛好。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_067"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那裡……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n可以再大力一點。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯嗯！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_068"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不會痛……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不是說這個，是說今天在服務台幫忙的事嗎？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然是會有點累，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但是這沒有什麼好不好的問題吧？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你問我有比較不害怕",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_069"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "鬼怪了嗎……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不不不，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那只是小孩子的變裝吧？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n別看我這樣，我很喜歡小孩的。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼可能會感到害怕。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼說來，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_070"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有個小孩不是要糖果，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而是叫我交出布丁呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "明明有聽到聲音卻沒看到人，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是有嚇了我一跳。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n是因為對方長得太嬌小，我才沒有看到人嗎？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了？",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_071"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你的手停下來了呢……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣啊。",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_072"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不管怎麼說，我都欠了你一個大人情。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n如果你有遇到什麼麻煩，儘管來找我。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n無論是哪裡我都會為你趕過去的。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊，",
        "unit_id": 105631,
        "voice": "vo_adv_1276004_073"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在那之前……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這次換我來幫你按摩肩膀吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n來，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了，你就坐下吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n作為今天的回禮，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我會好好幫你按摩的。",
        "unit_id": 105631
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1276004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "陪小孩子很辛苦呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我懂……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話又說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1276004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你透過陪流夏一起Cosplay，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在背後推了她一把呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就稱讚你",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "做得很好吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……雖然我覺得不太可能，",
        "unit_id": 190011,
        "voice": "vo_adv_1276004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但你應該不是單純想Cosplay",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才這麼做的吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，這無所謂……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過流夏她乍看之下很成熟而且個性直爽，",
        "unit_id": 190011,
        "voice": "vo_adv_1276004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒想到",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "居然會這麼在意被人說是新婚夫妻……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看來她也有相當少女的地方呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要好好注意到她這樣的地方喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1276004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼這次就到此為止。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "新婚的丈夫♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "薩拉薩利亞依舊是烈日當空，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與流夏在綠洲中醒了過來。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦……",
        "unit_id": 127612,
        "voice": "vo_adv_1276004_079"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們兩個都睡著了嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n感覺自己好像做了一段很長的夢……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過太陽還高掛在天空中呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的，",
        "unit_id": 127612,
        "voice": "vo_adv_1276004_080"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這還真是奇妙啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n又或者",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這說不定也是精靈的好意呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過",
        "unit_id": 127612,
        "voice": "vo_adv_1276004_081"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "現在就坦率地接受他的好意吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "盡情享受這美麗的景色，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "與寧靜的時光吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我覺得自己的旅行經驗滿豐富的，",
        "unit_id": 127612,
        "voice": "vo_adv_1276004_082"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但還是第一次見到這樣的地方。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n雖然陽光非常地強，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但這裡的人個性爽朗，空氣很清新，是不錯的地方呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "回到城鎮的話，",
        "unit_id": 127612,
        "voice": "vo_adv_1276004_083"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想必會受到熱烈歡迎吧……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就先暫時繼續待在這裡悠閒地",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n度過我們夫妻的時光",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "吧♪",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人相視而笑，綠洲的徐風輕輕拂過他們的臉頰。"
    }
