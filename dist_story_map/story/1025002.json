[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊……",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我為什麼會這麼冒失呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "前陣子，我不小心",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "用魔法把育幼院的牆壁轟飛了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "另外，我還犯了許多大大小小的錯誤。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "關於育幼院的牆壁，大小姐雖然也說了……",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "「因為壁材有受損的地方，所以剛好",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n省下了拆除的工夫」之類的話。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但那絕對是為了體諒我才這麼說的吧……",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為了翻修新的牆壁，讓大小姐多了額外的開銷啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我只會添麻煩呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚，我沒有資格當女僕。",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我完全派不上用場，還讓大小姐操心……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，不行，變得消沉也無濟於事！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "至少牆壁的修繕費用，",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不……我要把至今搞砸的事都抵銷！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓我為了大小姐努力工作吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "首先，順利完成大小姐委託的採購吧！",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n外出跑腿我應該也能做到！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，這附近好像有量販店……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，啊啊？",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n呀啊啊！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好痛……",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n被、被什麼東西絆倒了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "幸好是在購物之前被絆倒！",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要是提著雞蛋等易碎的東西，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "現在就全部都毀了呢～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這、這是什麼……？",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有好幾尊像是地藏的石像並列在一起呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為沒注意到它們，所以絆倒了呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，那個，地藏……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你們沒事吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒有受傷吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯嗯。總覺得地藏非常髒呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n它們一直被擱置在這個廣場……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "飽受風吹雨打，沒有人來幫它們打掃呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好。",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n作為撞到你們的賠禮，讓我將你們擦得閃閃發光吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我很擅長將污垢擦乾淨，因為我是女僕……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哼哼哼～擦乾淨擦乾淨吧……♪",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀？",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n感覺好像只有這個地藏莫名地柔軟……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，呀啊啊？",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不不不、不是地藏！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是、是人類吧！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是說，我記得你是……{player}？",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，前幾天好像給你添麻煩了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，{player}",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為什麼會一屁股坐在地藏旁邊呢……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊……",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嗯，真是奇怪的興趣呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，沒關係！",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我不會瞧不起你的！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我不太懂哪裡有趣，",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但是我覺得有各種興趣也無妨♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，你怎麼了？",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n肚子痛嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還是說，你被施展了不能動的咒語？",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "或許排在這邊的地藏，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就是受到那個詛咒的人類們悲慘的下場！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……啊，是。",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不是這樣嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，我的理解能力太低了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……？",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難道你是因為肚子餓而動不了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "從剛剛你的肚子就一直在叫。",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟現在是午餐時間呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}好像不能動……",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我到那邊的攤販買點東西回來吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請稍等一下。",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n當然，路邊攤的費用由我來付♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不要客氣。",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就當作前陣子給你添了不少麻煩的賠禮。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我很冒失，",
        "unit_id": 102511,
        "voice": "vo_adv_1025002_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總是造成其他人的困擾，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以我想要好好地道歉……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，我覺得我要承擔責任♪",
        "unit_id": 102511
    }
]