    {
        "type": "dialogue",
        "name": "雪",
        "words": "一副游刃有餘的樣子，",
        "unit_id": 100811,
        "voice": "vo_adv_9100119_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼回事啊？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n是發瘋了嗎～？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n──啊！",
        "unit_id": 100811
