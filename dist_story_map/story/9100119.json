        "name": "貴族",
        "words": "哈──哈哈哈！",
        "unit_id": 2511,
        "voice": "vo_adv_9100119_013"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n我哪可能會發瘋！",
        "unit_id": 2511
