        "type": "dialogue",
        "name": "院長",
        "words": "嘿嘿嘿，",
        "unit_id": 512,
        "voice": "vo_adv_9100119_018"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "那種程度的監獄，",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "要逃脫簡直易如反掌。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n我打算好好報答",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "那個摧毀我醫院的女人，",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n因此千里迢迢地來到蘭德索爾……",
        "unit_id": 512
    },
