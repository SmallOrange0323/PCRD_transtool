        "type": "dialogue",
        "name": "院長",
        "words": "\n",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "呀哈哈……",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "這也是個好機會……！",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "深月！",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "我要把妳",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "跟這個世界一起轟得煙消雲散！",
