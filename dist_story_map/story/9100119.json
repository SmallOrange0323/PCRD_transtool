        "type": "dialogue",
        "name": "院長",
        "words": "沒想到全世界",
        "unit_id": 512,
        "voice": "vo_adv_9100119_019"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "都開始燃燒了起來！",
        "unit_id": 512
    },
