        "type": "dialogue",
        "name": "院長",
        "words": "正是如此。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n好久不見了呢，",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "「深月醫生」。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……哎呀。",
        "unit_id": 105111,
        "voice": "vo_adv_9100119_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "竟然在這種奇怪的地方見到你呢，",
        "unit_id": 105111
