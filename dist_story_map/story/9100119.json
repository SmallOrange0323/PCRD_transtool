        "voice": "vo_adv_9100119_025"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "怕到說不出話了嗎！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哈哈哈哈……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這下你們明白了吧！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n叫來救兵的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "可不是只有你們啊！！",
