[
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "竟敢一而再，再而三地",
        "unit_id": 14912,
        "voice": "vo_adv_5068308_000"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "妨礙我……！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我很感謝妳們……",
        "unit_id": 14912,
        "voice": "vo_adv_5068308_001"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n是妳們找到我，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "為我製作成為這個身體的1000位同胞……！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n不過，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "那個感謝也到此為止！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "絕交吧！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 116713,
        "voice": "vo_adv_5068308_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們不會跟你絕交……",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "絕對不會……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不管你說什麼，",
        "unit_id": 116713,
        "voice": "vo_adv_5068308_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們都不會放棄……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n只要不放棄……",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要一直為你著想，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我們就絕對不會讓你跟我們絕交……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "說得好，",
        "unit_id": 7311,
        "voice": "vo_adv_5068308_004"
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "碧！",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，大家要小心……",
        "unit_id": 116911,
        "voice": "vo_adv_5068308_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看那個樣子……",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "玩具王比之前還要認真喔！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要說認真的心意，",
        "unit_id": 116713,
        "voice": "vo_adv_5068308_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們也不會輸給它……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這次絕對要跟它和好……！",
        "unit_id": 116713
    }
]