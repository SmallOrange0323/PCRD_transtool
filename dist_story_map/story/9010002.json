    {
        "type": "dialogue",
        "name": "米亞",
        "words": "呼呼……",
        "unit_id": 51611,
        "voice": "vo_adv_9010002_000"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "嘿、",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "嘿、",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "嘿咻～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "真是的～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不要讓文官做體力活啦皇女殿下～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是丟臉呀。",
        "unit_id": 129711,
        "voice": "vo_adv_9010002_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n雖為文官，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "一兩三個大木桶，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n連哼著歌搬運都做不到成何體統。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在吉歐‧格黑納，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以涅妃‧涅羅為中心"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n眾人聚在一起挑選賀禮。"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "呼～",
        "unit_id": 51611,
        "voice": "vo_adv_9010002_002"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不管是哪個世界，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "大家都很喜歡祭典這類的東西呢～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "雖然很開心是好事～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "但預定要帶去的伴手禮的數量可不得了啊皇女殿下～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是、",
        "unit_id": 129711,
        "voice": "vo_adv_9010002_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n若為祝賀結緣周年之宴席，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "贈與眾人的賀禮，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "份量加重亦乃理所當然。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吉歐‧格黑納自豪的硬玉軟玉、",
        "unit_id": 129711,
        "voice": "vo_adv_9010002_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "金藝銀藝……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n宴席不可或缺的肉類料理及魚類料理，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "飲品也得都帶上。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……不，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "思量貪吃佩可公主等人旺盛的食慾，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "似是稍顯不足──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我回來了，",
        "unit_id": 126012,
        "voice": "vo_adv_9010002_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "涅妃‧涅羅小姐、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "米亞小姐。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我和安涅默涅小姐一起",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "收集了很多回來喔！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──皇女。",
        "unit_id": 129612,
        "voice": "vo_adv_9010002_006"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n妳委託的肉──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這些",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "夠嗎。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n巨型蜥蜴、",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "熔岩水妖和其他魔物。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚好、",
        "unit_id": 129711,
        "voice": "vo_adv_9010002_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚好。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n可璃亞閣下",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦前來相助，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實在令人萬分感激。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "謝謝妳，",
        "unit_id": 51611,
        "voice": "vo_adv_9010002_008"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "可璃亞小姐～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "對了對了，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "妳是說想要做「咖哩」對吧？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "鍋子、菜刀、香料那些，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "都準備好囉～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "謝謝妳♪",
        "unit_id": 126012,
        "voice": "vo_adv_9010002_009"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這樣就可以做",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "若菜小姐教我的特製咖哩了！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我想來參加派對的各位，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "一定都會很開心的♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 126012,
        "voice": "vo_adv_9010002_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對了♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n安涅默涅小姐也可以幫忙嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "一起做咖哩。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──我、",
        "unit_id": 129612,
        "voice": "vo_adv_9010002_011"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "嗎。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "但是──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "料理，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我完全不懂。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "派對也",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "沒打算要參加──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那個……",
        "unit_id": 126012,
        "voice": "vo_adv_9010002_012"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "如果學會做料理了，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也許以後派得上用場喔？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "怎麼樣♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "………………",
        "unit_id": 129612,
        "voice": "vo_adv_9010002_013"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅呀，",
        "unit_id": 129711,
        "voice": "vo_adv_9010002_014"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無須蹙眉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n汝為近侍，若能習得料理技術，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家的餐食",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也將增添風采。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n再加上──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "贈與蘭德索爾的賀禮堆積如山，",
        "unit_id": 129711,
        "voice": "vo_adv_9010002_015"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "搬運也是一大辛勞。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n即使米亞用不存在的雙足長途跋涉，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "人手也遠遠不足，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這點是顯而易見的。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這樣的話──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對吧？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "拜託妳了安涅默涅小姐～！",
        "unit_id": 51611,
        "voice": "vo_adv_9010002_016"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n一起來吧，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "來啦、",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "來啦！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n只靠我一個人會被壓垮的～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "妳只是──",
        "unit_id": 129612,
        "voice": "vo_adv_9010002_017"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "很期待去蘭德索爾而已吧，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n皇女。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵，",
        "unit_id": 129711,
        "voice": "vo_adv_9010002_018"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "何須多言。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "自然是滿懷期待啊？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無論是能夠見到異國的公主們，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還是能和汝一同參加宴席。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──既然皇女",
        "unit_id": 129612,
        "voice": "vo_adv_9010002_019"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "都這麼說了。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那麼安涅默涅小姐，",
        "unit_id": 126012,
        "voice": "vo_adv_9010002_020"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n出發前迅速完成料理吧♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "先從削馬鈴薯皮開始！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……唉。",
        "unit_id": 129612,
        "voice": "vo_adv_9010002_021"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "真是強硬呢──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n……可璃亞小姐。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，吉歐‧格黑納一行人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "也出發前往參加慶祝宴會。"
    }
]