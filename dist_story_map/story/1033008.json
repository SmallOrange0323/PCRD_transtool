[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～\n果然還是不行嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是不熟悉牧草的種類，\n就沒辦法懂這個哏了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我的理想，可是從老到少聽了都會哈哈大笑的相聲的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就算對我來說很稀鬆平常啦……",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對於生活在城鎮的一般人來說，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這就是專業知識了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯嗯",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "，\n很值得參考。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝{player}，",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n願意陪我一起想哏。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "話說回來，明明老哥沒有送信的工作，\n還是會常常來牧場啊？",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為前陣子我沮喪到臥床不起，\n所以擔心我嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我很清楚的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n好歹我也是【伊麗莎白牧場】的經營者。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有在確實掌握郵件分量和內容的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒有任何郵件時，",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}也這樣待在牧場……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是說我自戀啦！\n我想～老哥應該是因為擔心我，所以來看看我的吧？",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對，老哥也可能是\n來看【伊麗莎白牧場】的其他孩子。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "或許老哥只是順便來看看我……",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就算是這樣，我還是高興得不得了♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝啦，{player}。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n託你的福，我恢復得差不多了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然還多少有點彆扭的感覺，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但我開始漸漸可以想得到哏啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這和牛隻的牛乳分泌量減少時候一樣。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對我來說，能不能想到哏，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就是健康和精神狀態的指標。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然離最棒的狀態還差得遠，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想到要下山去城鎮還會有點害怕。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但總有一天，",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我會捲土重來的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}有時候\n也會帶來城鎮人們的問候。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好像也滿多人說",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n期待再看到我的相聲表演～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來我一直以來的努力沒有白費。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就算不多，至少我給人帶來了歡笑……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能有這種感受，真的很幸福♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？{player}也",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n很期待再看到我的相聲表演？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n很喜歡看我搞笑？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈～\n過度誇獎的話，我可是會臭屁起來的啦♪",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "。\n沒問題的，我很快就會復原的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那時候我就會一直表演相聲，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "表演到讓老哥覺得煩、讓老哥笑到要喘不過氣來……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想要大喊「別再說了」♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇哇！？",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n之前就說了，拜託不要突然出現那麼刺眼的光的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼回事啊！？實在是讓人有點難以理解的表演耶……",
        "unit_id": 103311
    },
    {
        "type": "background",
        "background": "510140"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哼哼哼～哼♪",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸嘿嘿。",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n謝謝老哥又約我來動物園啊。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是我得好好練習短劇才行啊～\n因為要參加搞笑比賽的敗部復活賽。",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，算了，\n",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "每件事情都會對表演有所幫助的啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……只是啊，",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n說到這座動物園有日本最漂亮的牛這件事～",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的假的啊？\n我還有點半信半疑的啊。",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不可能有比我們伊麗莎白還漂亮的牛啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，我們快點去看看啊。",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那頭牛好像就在前面的體驗廣場的啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，是那個嗎？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔喔、喔喔喔喔！？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這、這這這、這真是超正點的花美牛啊！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "漂、漂亮到光看著牠就好興奮呀！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，你說和普通的牛一樣？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥的眼睛長哪去了啊？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看仔細啦。\n",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那完美的嘴型，健康的舌頭，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n還有那柔和的腿部曲線……！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊～想不到居然有這樣的牛……？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不愧是大都市，真銷魂啊！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n怎麼了，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔喔，",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在有擠牛奶的體驗活動？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n咦，想試試看嗎？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，好啊好啊。",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……老哥希望我先示範？",
        "unit_id": 103332
    },
    {
        "type": "still",
        "still": "103300801"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好，交給我吧！",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_040"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就讓老哥看看我的實力的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只是我第一次見到這頭牛\n就擠牠的奶，這樣好嗎～？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀，會緊張的啦♪",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對。",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_042"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n應該說這是很光榮的事。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那我就全神貫注地擠牛奶啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "瞧瞧我專業的實力啦！",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_043"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要上囉～嘿呀☆",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "來吧，擠好擠滿的啦～！",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_044"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哼哼，我從小就開始擠牛奶可不是白擠的啊♪",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過啊，這頭牛\n不只漂亮，也很多奶的啦。",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_045"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這頭牛太可愛啦，我很喜歡的啦♪",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_046"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n妳也很喜歡我嗎？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈，那妳要不要嫁到我家來呀～♪",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "…………",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_047"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊、",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_048"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊啊！？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n糟糕，我在做什麼！？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我、我竟然花心了……",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_049"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n實在太對不起伊麗莎白了……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我竟然對外頭的牛這樣心花怒放的……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦，",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_050"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n{player}很了解伊麗莎白嗎？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不，嗯……",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_051"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為我老是說伊麗莎白的事，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n所以老哥也變得很了解她了呢。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過啊，就像你說的。",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_052"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "伊麗莎白可是牛美心也美，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n一定會原諒我的♪",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，\n什麼意思？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_053"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊、",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_054"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我放著伊麗莎白不管，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n和{player}搭檔搞笑，或是去約會……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要說是花心，\n",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_055"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "的確是花心的啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只是，牛和",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_056"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n人類男性是不一樣的啦……？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……喔喔？\n不知不覺",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_057"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n聚集了好多圍觀觀眾的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是因為我擠牛奶的技術太厲害，\n引起大家的興趣嗎？",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_058"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這、",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_059"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這可是表演相聲的機會……！\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}，來表演我們經典的哏吧♪",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為了我身邊與我有關聯的人……",
        "unit_id": 103332,
        "voice": "vo_adv_1033008_060"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天我要為他們帶來一些歡笑的啦♪",
        "unit_id": 103332
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "太好了～\n真陽似乎變得有精神多了呢……",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原本的她，\n真的沮喪到讓人笑不出來呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下令把城鎮上的搞笑藝人或吟遊詩人\n一口氣逮捕起來的國王……",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n到底在想什麼呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就我所知道的王室，\n應該不會施行如此暴政才對……",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總覺得～有些不對勁呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，\n那些難懂的事先擱在一旁……",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}，\n你就盡心盡力地拯救眼前的人的心吧。\n不，是要為她帶來笑容。",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "突然談拯救世界，\n或是拯救人類，",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那種大事是不可能一時半刻就辦到的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過沒辦法讓身邊的人幸福，\n就沒有成為英雄的資格呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想真陽她，\n",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也很理解這一點的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她總是思考著\n如何讓身旁的人感到幸福。",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總是努力帶給大家歡笑。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是值得尊敬的大人呢。\n你也要好好學習唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對。\n基本上你也是那樣的人對吧……",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不論何時，\n你都要像那樣，當個溫柔又高尚的搞笑藝人喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦，你不記得自己什麼時候變成搞笑藝人了？",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼啊……你不已經是真陽的搭檔了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這樣就是很傑出的搞笑藝人啦？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就試著精通此道，不是也很好嗎～\n說不定能發揮什麼作用唷？",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "搞笑藝人還滿受女孩子歡迎的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵。\n好吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1033008_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就先這樣，掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦……\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_077"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "起來了嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥突然睡著了，嚇了我一跳的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_078"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，雖然只有幾秒鐘而已。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇？\n抱歉，拜託不要亂動。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_079"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不然我會發出奇怪的聲音……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "直接睡在地上怪可憐的，\n所以我就先讓老哥躺在我大腿上了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_080"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_081"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥可以再睡一下，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "睡到爽為止喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "每天從早到晚……",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_082"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "都不停工作的話，可是會發瘋的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有時候就該\n在這種牧場悠閒地享受慢活的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_083"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但如果只是一直懶洋洋地躺著，\n的確也會出問題。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_084"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "人生總有酸甜苦辣啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_085"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然我還不夠成熟，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但我應該也能為別人帶來一點心靈上的放鬆啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這就是我搞笑的目標。\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_086"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這就是我的使命。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……{player}？\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_087"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，睡得可真香啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈，口水都流出來啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_088"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n老哥有時候～還真像個小嬰兒呀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "乖喔、",
        "unit_id": 103311,
        "voice": "vo_adv_1033008_089"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "乖喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}真是個好孩子的啦……♪",
        "unit_id": 103311
    }
]