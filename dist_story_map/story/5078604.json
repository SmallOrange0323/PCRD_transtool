[
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "テレフェスには模擬店もいっぱい出てましたね。",
        "unit_id": 116311,
        "voice": "vo_adv_5064604_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "「きよらか」側は不正の温床だったがな。",
        "unit_id": 116411,
        "voice": "vo_adv_5064604_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "結果として",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "来賓の覚えは高かったようだが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そりゃあそうだろうとしか言いようがない。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いえいえ",
        "unit_id": 116311,
        "voice": "vo_adv_5064604_002"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "「しとやか」の模擬店だって、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n素人ながら負けちゃいませんでしたよ？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "クロエ先輩のツンデレメイドカフェとか！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 116411,
        "voice": "vo_adv_5064604_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "他には？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "他には……",
        "unit_id": 116311,
        "voice": "vo_adv_5064604_004"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ま、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "とくに印象に残ってないですけども。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "やれやれ、",
        "unit_id": 116411,
        "voice": "vo_adv_5064604_005"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "来年はすべての店にクロエ君を派遣するか。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いいですね！",
        "unit_id": 116311,
        "voice": "vo_adv_5064604_006"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "今年は半袖ミニスカのキュート全振りバージョンでしたけど、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n来年はシックでクラシカルな正統派メイド服を着せましょう！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なに勝手なこと言ってんだあいつら……",
        "unit_id": 110813,
        "voice": "vo_adv_5064604_007"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110813
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "とりま来年のテレフェスはバックレ確定だな。",
        "unit_id": 110813
    }
]