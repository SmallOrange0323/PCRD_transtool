[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人為了尋找消失的人們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n從背面世界「吉歐‧提格尼亞」來到了「吉歐‧格黑納」。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而──"
    },
    {
        "type": "background",
        "background": "502072"
    },
    {
        "type": "dialogue",
        "name": "恐龍型魔物",
        "words": "──嘶啊啊啊啊啊！",
        "unit_id": 50411
    },
    {
        "type": "dialogue",
        "name": "巨大怪獸",
        "words": "──吼喔喔喔喔喔！",
        "unit_id": 50511
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "快逃啊～！！",
        "unit_id": 1,
        "voice": "vo_adv_2205001_000"
    },
    {
        "type": "dialogue",
        "name": "小飯糰",
        "words": "嗶咕唔唔唔！！",
        "unit_id": 9611,
        "voice": "vo_adv_2205001_001"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不管到哪裡，",
        "unit_id": 125812,
        "voice": "vo_adv_2205001_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都充滿了魔物……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "而且",
        "unit_id": 126012,
        "voice": "vo_adv_2205001_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "火勢也一直在擴散！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這已經不能說是天氣熱了，",
        "unit_id": 105812,
        "voice": "vo_adv_2205001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是火很熱！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小飯糰都要變成烤飯糰了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……呼……",
        "unit_id": 105913,
        "voice": "vo_adv_2205001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們也會",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變成烤精靈跟烤貓的……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不要變成烤貓──",
        "unit_id": 106012,
        "voice": "vo_adv_2205001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那裡有個池塘耶♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "池水有點濁，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過就先跳進去──",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "不行。",
        "unit_id": 126112,
        "voice": "vo_adv_2205001_007"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "跳進去的魔物",
        "unit_id": 126012,
        "voice": "vo_adv_2205001_008"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "在溶化……！？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本是個強酸池嘛！",
        "unit_id": 106012,
        "voice": "vo_adv_2205001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "差點就小命不保了！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而且酸液之中",
        "unit_id": 125812,
        "voice": "vo_adv_2205001_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還出現了鱷魚魔物……！？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈啊──！",
        "unit_id": 105911,
        "voice": "vo_adv_2205001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！？",
        "unit_id": 105911,
        "voice": "vo_adv_2205001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這些精靈",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還真是粗暴……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "火已經燒到附近了！",
        "unit_id": 105812,
        "voice": "vo_adv_2205001_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們跑吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "好！",
        "unit_id": 1,
        "voice": "vo_adv_2205001_014"
    },
    {
        "type": "background",
        "background": "502070"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "……呼、",
        "unit_id": 1,
        "voice": "vo_adv_2205001_015"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "呼……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看來",
        "unit_id": 125812,
        "voice": "vo_adv_2205001_016"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "總算甩掉那些魔物了……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過",
        "unit_id": 105913,
        "voice": "vo_adv_2205001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也險些去了半條命呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您沒有受傷吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說，",
        "unit_id": 106012,
        "voice": "vo_adv_2205001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從中途開始，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那些恐龍感覺也都在拚死逃離大火。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過我們也是因此才得救啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "有點，",
        "unit_id": 126112,
        "voice": "vo_adv_2205001_019"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n燒焦了。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "小樂",
        "words": "噗嗚～",
        "unit_id": 9511,
        "voice": "vo_adv_2205001_020"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "跟充滿",
        "unit_id": 126012,
        "voice": "vo_adv_2205001_021"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "點心糖果",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n與可愛動物的",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "吉歐‧提格尼亞不同，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這個叫做",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "吉歐‧格黑納的世界",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "到處都是魔物呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是啊。",
        "unit_id": 105812,
        "voice": "vo_adv_2205001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然在充滿食物這方面，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩個世界好像沒有不同……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "莉莉、小樂",
        "words": "「咦？」\n「噗！？」",
        "unit_id": 9511,
        "voice": "vo_adv_2205001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且",
        "unit_id": 105913,
        "voice": "vo_adv_2205001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡的魔物不只數量多，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且體型都很巨大，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "個性也很凶暴……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不管怎麼說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺都很不好對付。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "連可可蘿小姐",
        "unit_id": 125812,
        "voice": "vo_adv_2205001_025"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這種身經百戰的冒險者都有這種感覺，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那肯定不會錯了……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最麻煩的就是",
        "unit_id": 106012,
        "voice": "vo_adv_2205001_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會從空中撒下火苗的那個大得嚇死人的鳥魔物吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其他魔物",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實都很強，也很棘手，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但那傢伙的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔力之類的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺起來就是不同層級。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那隻火鳥……",
        "unit_id": 126012,
        "voice": "vo_adv_2205001_027"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是像鳳凰、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "菲尼克斯、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不死鳥，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那一類",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "存在於傳說中的魔物嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n雖然很難以相信",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不管死去多少次都會再次復活這種事……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先不論牠會不會再次復活，",
        "unit_id": 105913,
        "voice": "vo_adv_2205001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一旦被捲入那個不死鳥引發的火炎風暴中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們就逃不過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當場死亡的命運了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們一開始逃過來的方向，",
        "unit_id": 125812,
        "voice": "vo_adv_2205001_029"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n看起來",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "已經幾乎變成一片焦土了。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "除此之外，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "大火似乎也在到處延燒……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不知道這個世界有多遼闊，",
        "unit_id": 106012,
        "voice": "vo_adv_2205001_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但這個火勢再燒下去，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "轉眼間",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n整個世界就會被燒到只剩灰跟炭了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼！？",
        "unit_id": 105812,
        "voice": "vo_adv_2205001_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "全都烤焦的話會很傷腦筋耶～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……凶惡至極的魔物，",
        "unit_id": 125812,
        "voice": "vo_adv_2205001_032"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "殘酷的自然環境，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還有那烈火……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看來我們似乎",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n來到了一個可怕的世界。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "吉歐‧提格尼亞是步調很悠閒的世界，",
        "unit_id": 126012,
        "voice": "vo_adv_2205001_033"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n所以我有點大意了，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
