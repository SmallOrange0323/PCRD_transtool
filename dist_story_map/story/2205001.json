    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "天知道會發生什麼事，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就保持著最大的警戒往前進吧！",
