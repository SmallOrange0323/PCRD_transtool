        "unit_id": 105812,
        "voice": "vo_adv_2205001_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "找個地方休息吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "普蕾西亞，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳知道哪個方向的魔物氣味比較少嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……（嗅嗅）",
        "unit_id": 126112,
        "voice": "vo_adv_2205001_036"
    },
    {
        "type": "dialogue",
