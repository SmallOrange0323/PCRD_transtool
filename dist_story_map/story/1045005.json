[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天{player}也陪著空花練習跳舞了。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生手上拿的是什麼東西啊？",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n雖然有點像傳單……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……空花也想看，可以嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這是……舞蹈大會的通知單嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸欸！",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n要空花參加這場大會嗎！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不行的啦……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花對跳舞還沒有自信……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "而且很害羞。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生打算看空花出醜的樣子，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "然後引以為樂吧？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "即使因為羞恥而痛苦的空花，",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n也依然無法違抗虐待狂先生的命令……流口水。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這是欲擒故縱對吧……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生真是高手！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n被虐待狂先生這樣強迫的話，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花也就沒辦法再抵抗了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "既然虐待狂先生都這樣說了……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花知道了。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花參加舞蹈大會！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……欸？正式上場之前，做更多練習？",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……要變得更加激烈對吧。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n流口水。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好、好的、空花很期待……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哦不是、空花會加油！",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "舞蹈大會，當天──"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "已已已、",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "已經是正式上場的時候了嗎！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花還沒有什麼自信說……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼──麻煩下一位！",
        "unit_id": 311,
        "voice": "vo_adv_1045005_012"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n空花小姐請上台。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "輪到空花了嗎！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生……空花這次還是退出……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n不、不要推空花！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n被這樣用力推的話！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "接下來是空花小姐上場！",
        "unit_id": 311,
        "voice": "vo_adv_1045005_015"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n那麼請為我們跳舞吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸欸欸欸欸！",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生硬把空花推上台……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n已經逃不了了……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊、啊……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n在眾目睽睽之下做這種事！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n實在是太害羞了，空花整個人都變得不對勁！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "酒館的店員",
        "words": "空花──！",
        "unit_id": 411,
        "voice": "vo_adv_1045005_018"
    },
    {
        "type": "dialogue",
        "name": "酒館的店員",
        "words": "\n加油──！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊，同事們也來為空花加油……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "像這樣……被這麼多熟人看著……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花要丟臉丟到家了！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！該不會這些都是虐待狂先生的計畫……！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "目的是為了羞辱空花對吧……嘻嘻。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「妳喜歡一邊做一邊被別人注視吧」",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這樣？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……虐待狂先生的特訓也超狂野的。",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n即使做到腰都站不直了，也硬要繼續……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n就算達到極限了也一直做一直做……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "看著空花痛苦的表情，應該很享受吧。",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_022"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n不愧是虐待狂先生！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻……嘻嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "酒館店員１",
        "words": "她、",
        "unit_id": 411,
        "voice": "vo_adv_1045005_023"
    },
    {
        "type": "dialogue",
        "name": "酒館店員１",
        "words": "她好像一邊跳舞，一邊念念有詞……？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員１",
        "words": "\n那個男的對空花做了什麼特訓？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "酒館店員２",
        "words": "但是，你看！",
        "unit_id": 1211,
        "voice": "vo_adv_1045005_024"
    },
    {
        "type": "dialogue",
        "name": "酒館店員２",
        "words": "\n空花跳得比平常更好呢！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "喔喔喔喔喔！！",
        "unit_id": 1,
        "voice": "vo_adv_1045005_025"
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "\n這舞蹈跳得多麼熱情啊！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊！！",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊啊！！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n一想起和虐待狂先生做的練習，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n身體自然而然就有反應了！！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚嗚……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花盡力了，不過只得到參加獎……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n難得虐待狂先生陪空花做了這麼多練習……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸？",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "很很很、很美！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "居然給空花這樣直白的讚賞……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生說空花很美……",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_029"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這……這，也就是說……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "喜、喜歡空花──",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊哇哇哇哇哇！",
        "unit_id": 104511,
        "voice": "vo_adv_1045005_030"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n太、太害羞了啦啦啦！！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一臉不可思議地，\n直望著滿臉通紅逃跑的空花……"
    }
