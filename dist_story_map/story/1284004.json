        "words": "早安～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "遊俠的裝扮",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "很適合妳喔～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，",
        "unit_id": 125414,
        "voice": "vo_adv_1284004_050"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "早安，",
