[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接下新年第一份工作的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與初音一起在郊外等候栞。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "遊俠裝扮的小栞",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的很帥氣呢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n怎麼還不快來呢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對啊～",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你忘記委託內容了嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過畢竟才剛開工，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還沒收心也是難免的嘛～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你記得，",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "【森林守衛】和遊俠要在今天進行聯合調查嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n為了管理山林的自然環境，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "需要借助雙方的知識和見聞。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以說，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞今天是遊俠喔～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說人人到，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "她就在那邊了……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n奇怪？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那好像不是小栞……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是不是有點刺眼啊！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚哇啊啊～",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "510103"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總算找到你了～！",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "新年快樂！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今年也請多多指教唷！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不瞞你說，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我寫了賀年卡喔！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是我卻不知道最重要的住址，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "只好到處找你了～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "聽說最近",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好像很少人會寄賀年卡了，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我就是想親筆寫一張送給你。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n而且當面交給你的話，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還能看見你有什麼反應呢！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以說呢，",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n送你小初音的親筆賀年卡！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿～",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我就是想看你這個笑容～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n不枉費我絞盡腦汁地寫了呢！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你要現在開始寫嗎？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我要看我要看！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我跟你一起回去～",
        "unit_id": 101231
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "打、",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "打擾了。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喔～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你的房間長這樣啊。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我好像是第一次",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "進到男生的房間耶……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說，",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你整理得真乾淨。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看來你有認真地",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大掃除呢！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n果然厲害～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼？",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我嗎？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不是，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你想嘛，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我絞盡腦汁才寫好了賀年卡……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "比起這個，",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來寫賀年卡吧！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼大掃除",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "都是無關的事，不准再提囉！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "面對桌子坐好！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "專心專心！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "首先，",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要想些點子才行呢～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你想好要做成",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼樣的賀年卡了嗎？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "竟然不告訴我……！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說得也是啦。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我就只好等你完成了……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "可是，",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣小初音會很無聊的～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有沒有什麼我能幫忙的地方呢？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喔！",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你想要建議是吧！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "賀年卡",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "確實不能少了喜氣的感覺呢！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "包在我身上～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "幫你按摩肩膀嗎？",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "可是，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小初音的按摩費用很貴喔？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你確定嗎？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不收你錢，但你要寫張美美的賀年卡給我喔！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我按我按……",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎麼樣？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒想到我是按摩好手吧？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n放鬆下來後，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是不是有浮現好點子啦？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼？",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你絞盡腦汁也想不出該怎麼表現喜氣感……？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小初音就陪你一起想吧！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想想喔～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n最經典的話，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "試著放上一富士二鷹三茄子如何？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "希望可以稍微加點巧思呢。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難得都要親筆寫了。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這",
        "unit_id": 101231,
        "voice": "vo_adv_1284004_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "樣",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
