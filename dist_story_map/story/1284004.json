    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "剛才聽到妳在說夢話，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是做了什麼夢呢？",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺妳",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看起來非常地開心耶。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對對對，",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_051"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我做了一個夢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我想一下喔，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒記錯的話，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你好像",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "寫了新年的問候信給我！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯？",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_052"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你怎麼突然打開包包？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n有東西一直忘記要給我們……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼！？",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_053"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你寫了賀年卡要給我們嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我好開心喔～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你。",
        "unit_id": 125414,
        "voice": "vo_adv_1284004_054"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我記得",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "賀年卡",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是東國文化中的信對吧。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n下次我們",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也來寫賀年卡回送給你♪",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我做的夢成真了……",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_055"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這樣的話，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "剛才做的就是預知夢囉？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果是這樣，",
        "unit_id": 101211,
        "voice": "vo_adv_1284004_056"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "希望那個夢中夢",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也可以成真就好了。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞變得很健康，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "然後大家一起去環遊世界冒險……",
        "unit_id": 101211
    },
    {
