        "name": "初音",
        "words": "早安！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "睡得真舒服～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我怎麼會睡著啊！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難道又只有我被看到睡覺的樣子嗎～！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我應、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "應該沒有睡到流口水之類的吧……！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事的。",
        "unit_id": 103813,
        "voice": "vo_adv_1807004_062"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n再說，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們也是",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "剛剛才醒過來而已。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n大家似乎都睡了一覺。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是嗎，",
        "unit_id": 101211,
        "voice": "vo_adv_1807004_063"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "原來是這樣～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那我就放心了……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "天都黑了呢～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我們有睡了這麼久啊？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或許吧。",
        "unit_id": 103813,
        "voice": "vo_adv_1807004_064"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "風吹得很舒服……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你們看，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這裡的夜空",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也很美呢……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……真的耶～！",
        "unit_id": 101211,
        "voice": "vo_adv_1807004_065"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n天空的",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "月亮和星星就像一片花海～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "月亮倒映在湖面上……",
        "unit_id": 103813,
        "voice": "vo_adv_1807004_066"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n花朵也在月光中浮現出身影……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是啊，",
        "unit_id": 101211,
        "voice": "vo_adv_1807004_067"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這可是新發現",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "希望今後也能不斷地找到許多",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們還不知道的事物！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，",
        "unit_id": 103813,
        "voice": "vo_adv_1807004_068"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就是說啊，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我想一定",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以的……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們一定可以找到多到兩手數不完的新鮮事……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒錯～！",
        "unit_id": 101211,
        "voice": "vo_adv_1807004_069"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總覺得好令人雀躍喔♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好啦，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然有點依依不捨，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們也差不多該回去了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "下次再一起來吧。",
        "unit_id": 101211,
        "voice": "vo_adv_1807004_070"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這是",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們之間的約定喔。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n{player}也會來，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我很期待！",
        "unit_id": 103813,
        "voice": "vo_adv_1807004_071"
    },
    {
        "type": "dialogue",
