[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束王宮工作的凱留，\n正在蘭德索爾中散步。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "離天色暗下來",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有不少時間呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正有空，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要不再去做調教魔物的打工好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過前陣子……",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把「怪獸大賽」的會場",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n給弄得半毀了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會很尷尬吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "歸根究柢都要怪{player}。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都怪他解開了我的束縛……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過那只是我的疏失就是了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咿呀！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　又、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又是{player}！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的拜託你別再這樣了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "每次每次都要嚇人……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　你沒有那種意思？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也正好在想事情，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就原諒你吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我說，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你依然還是一副呆樣耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一臉就像是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "前陣子的事情你都忘得一乾二淨了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "？",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吶，{player}。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像有東西黏在你背後了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是紙片嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像是被風吹到你身上的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我幫你拿下來。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼……",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "彩券？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你真是笨蛋耶，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那怎麼可能啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "肯定是沒中啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n否則",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能會像這樣子被人丟掉啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你也正常想想吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，喂，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你拿著彩券要去哪啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要去看公告欄確認？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真受不了你，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明不需要這麼麻煩――",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "中、",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "中、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "中獎了～！！！！？？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不會吧？",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　騙人的吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　怎麼可能！！？？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n中了10億盧幣的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "頭獎！！？？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……………………",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不好不好。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一思考10億",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底有幾個0",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就不小心恍神了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，{player}！",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　這個！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　這張彩券！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n發現的人是我，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以我也有得到獎金的權利",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你真是好人耶！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也不是這麼惡鬼。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n獎金分你一半！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　感謝我吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明失去記憶了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻還對錢很執著？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吧，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那獎金一人一半就這麼說定了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼～",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來也會有這種事呢！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒想到只是撿張紙片",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就能變成億萬富翁……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在不是去打工的時候了！",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點，{player}，去兌獎處吧！",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂喂，{player}，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你看那衣服！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是蘭德索爾有名的高級品牌喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從材質到整件衣服來看，果然層級就是不同呢～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨。",
        "unit_id": 2511,
        "voice": "vo_adv_1060010_022"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "不愧是客人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "眼光真高。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n請慢慢欣賞。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "抱歉，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒什麼時間。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等我們事情辦完，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放在那架子上衣服，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我全部都要了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先幫我留下來。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "咦？",
        "unit_id": 2511,
        "voice": "vo_adv_1060010_024"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "　我、",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "我明白了～！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "非常謝謝您！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n我會耐心等候您回來～！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種程度的衣服價格，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n對現在的我們來說",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是零頭呢！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貴族們御用的餐廳呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看起來好好吃，味道好香！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和魔物料理就是不一樣～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然禮儀讓人覺得綁手綁腳的又很麻煩，",
        "unit_id": 106012,
        "voice": "vo_adv_1060010_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
