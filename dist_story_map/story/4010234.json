    {
        "type": "dialogue",
        "name": "真璃",
        "words": "抱歉，{player}。",
        "unit_id": 132331,
        "voice": "vo_adv_4010234_000"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n放假還叫你到學校來。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "其實今天",
        "unit_id": 132331,
        "voice": "vo_adv_4010234_001"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "是我生日。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "哎呀，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "你當然不會知道啊。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n我搬過來之後都還沒機會告訴你嘛。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "比起這個，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "我因為想見你就這麼任性叫你過來……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "對不起。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "咦，",
        "unit_id": 132331,
        "voice": "vo_adv_4010234_002"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "生日禮物？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "啊哈哈，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "不用準備啦。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "光是能像這樣",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "跟你一起過生日，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n我就",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "非常高興了。",
        "unit_id": 132331
    },
