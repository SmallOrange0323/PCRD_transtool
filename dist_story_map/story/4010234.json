    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "今天就是命中註定的那一天！？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n一輩子都不會忘的、",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "兩人第一次的紀念日……！？",
