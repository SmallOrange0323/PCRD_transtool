    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "這是為什麼呢？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "因為我長大了一點嗎……？　",
