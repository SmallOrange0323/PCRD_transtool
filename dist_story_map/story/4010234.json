    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……好，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "拿出勇氣來……！　",
