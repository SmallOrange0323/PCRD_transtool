[
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看來你還因為頭被球打到的事",
        "unit_id": 113511,
        "voice": "vo_adv_5046321_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在生氣呢～",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n對不起，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很痛吧……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好孩子，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "冷靜下來好嗎？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "美里老師，",
        "unit_id": 113411,
        "voice": "vo_adv_5046321_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "氣氛跟剛剛完全不一樣了～！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好像真的很生氣，",
        "unit_id": 113411,
        "voice": "vo_adv_5046321_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為牠把我們當成強敵了嗎！？",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不注意一點的話可能會很危險……！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀～",
        "unit_id": 113511,
        "voice": "vo_adv_5046321_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可以的話真想和牠好好相處……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看來我們只能",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "戰到小魔物滿意為止了呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n如果這樣你就會乖乖的……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那我們動手吧，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "初音！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
