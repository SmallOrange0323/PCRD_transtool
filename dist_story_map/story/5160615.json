        "words": "咲戀！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "莫妮卡來了喔。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我也整理好房間裡的行李了……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "歡迎妳來，莫妮卡。",
        "unit_id": 133512,
        "voice": "vo_adv_5160615_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們兩個，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "穿上這個。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "這是，",
