        "voice": "vo_adv_5160615_003"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "圍裙？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "為什麼要給我們這個……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "莫妮卡去幫忙準備料理。",
        "unit_id": 133512,
        "voice": "vo_adv_5160615_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "梅杜莎，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就拜託妳跟小孩子們一起去端菜吧。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "什、",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_005"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "什麼啊啊！？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我要幫忙嗎──！？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我是聽說",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_006"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "今天是我的歡迎派對才對啊？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊。",
        "unit_id": 133512,
        "voice": "vo_adv_5160615_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在育幼院",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算是派對的主角也要工作。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "天下沒有白吃的午餐喔。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我們這邊人數很多，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以去幫忙是理所當然的喔。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 133212,
        "voice": "vo_adv_5160615_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳教育得很好呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只要努力準備的話，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就能早點吃到飯，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在工作後吃的飯",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會變得更好吃喔。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "俗話說",
        "unit_id": 133512,
        "voice": "vo_adv_5160615_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "入鄉隨俗啊。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就拜託",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們兩個了喔。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會去幫鈴莓的。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "唉，",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_010"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "為什麼我要做這種事情……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "因為我平常沒有照顧人過，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "所以很麻煩啊……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "咲戀媽媽！",
        "unit_id": 111,
        "voice": "vo_adv_5160615_011"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "我擦完桌子了喔！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "我排好盤子了！",
        "unit_id": 211,
        "voice": "vo_adv_5160615_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你們兩個",
        "unit_id": 133512,
        "voice": "vo_adv_5160615_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很努力了呢。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼接下來，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以請你們去幫別的孩子嗎？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好～！",
        "unit_id": 111,
        "voice": "vo_adv_5160615_014"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……明明連那種小不點",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_015"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "都毫無怨言地工作著，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我卻一直在抱怨。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "這樣很遜呢。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "咲戀！",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_016"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我這邊結束了喔！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n接下來要做什麼才好？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝妳。",
        "unit_id": 133512,
        "voice": "vo_adv_5160615_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼接下來",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幫我去拿追加的木柴。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，準備順利進行著，餐桌上擺上了一個大鍋子。"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "這是",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_018"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "火鍋……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "用大鍋子",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "將食材煮熟而已的料理。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n然後大家圍著它一起吃……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "小孩子你一言我一語的很吵鬧，",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_019"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n跟我和姊姊們一起住時的",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "優雅晚餐差了非常多。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "但是……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我完全",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_020"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "不討厭這樣，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "不對，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我覺得很有趣！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n跟大家一起吃的飯，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "居然這麼好吃啊……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "梅杜莎，",
        "unit_id": 133212,
        "voice": "vo_adv_5160615_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳的碗空了喔。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來吧，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我幫妳撈料吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "謝謝妳。",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_022"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "幫我裝很多肉吧！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂，",
        "unit_id": 133212,
        "voice": "vo_adv_5160615_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "孩子們也要吃啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "稍微自重一點啦。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "相對的，我會幫妳撈很多蔬菜的。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "啊！",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_024"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "真得很過分，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "妳這樣是在虐待蛇啊，虐待蛇！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈，",
        "unit_id": 133512,
        "voice": "vo_adv_5160615_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為肉也還有很多，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以放心吧。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要先從蔬菜好好吃起喔。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先吃蔬菜",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像對美容也很有效喔。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_026"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "真沒辦法呢。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "約好了喔。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "姊姊，",
        "unit_id": 133612,
        "voice": "vo_adv_5160615_027"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "吃火鍋很有趣喔。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n等將來我們再會的時候，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我會做給妳們吃的！　",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，變得在育幼院生活的梅杜莎，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n度過了時隔許久的愉快的晚餐時間。"
    }
