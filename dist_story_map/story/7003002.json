[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "之前的時裝秀……",
        "unit_id": 101611,
        "voice": "vo_adv_7003002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "由於身體狀況不佳，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還真是累死我了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過",
        "unit_id": 101611,
        "voice": "vo_adv_7003002_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看見了粉絲們的笑容，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "聽見了他們的聲音，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我便完全忘記了自己的身體狀況",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "很平常地走在伸展台上了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102911,
        "voice": "vo_adv_7003002_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我十分能體會那種感覺！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也在發高燒時依然進行了演唱會活動，",
        "unit_id": 102911,
        "voice": "vo_adv_7003002_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當我一踏上舞台，發燒的事情便在我腦海中煙消雲散了一般。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，",
        "unit_id": 102911,
        "voice": "vo_adv_7003002_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一從舞台退下身體便完全使不上力了……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "隔天，就只能待在被窩裡甚麼也不能做了呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈，",
        "unit_id": 101611,
        "voice": "vo_adv_7003002_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真好笑～♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我們真的是很相似呢！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸，",
        "unit_id": 101611,
        "voice": "vo_adv_7003002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼了秀才？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼一副可怕的表情……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102911,
        "voice": "vo_adv_7003002_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n只有我們兩個太興奮過頭了嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 101611,
        "voice": "vo_adv_7003002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "　……我們兩個，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要好好愛惜自己的身體是嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什、",
        "unit_id": 102911,
        "voice": "vo_adv_7003002_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什麼嘛～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "別嚇我嘛——",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102911,
        "voice": "vo_adv_7003002_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也是呢……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然大家都會關心我，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過會這麼為我操心的，\n也只有{player}了呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我也是呢，",
        "unit_id": 101611,
        "voice": "vo_adv_7003002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺你能讓我的心情更加放鬆了呢！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "果然秀才的人真的很好呢―♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後一陣子，兩人的笑容許久都沒有消失。"
    }
]