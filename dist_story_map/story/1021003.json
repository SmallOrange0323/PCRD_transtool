    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "{player}哥哥，你好……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "今、今天，哥哥也要和我一起買東西嗎……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我又被派出來跑腿了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果哥哥可以，幫我拿東西的話…",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我就告訴{player}哥哥，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一些能夠順利買到東西的建議唷……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會、會不會有點自以為是呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是那個，哥哥……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥看起來，還不太習慣買東西的樣子……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我只是想，教哥哥很多很多的事情……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，唉呀……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n沒、沒有讓哥哥感到困擾嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "太好了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻，真拿哥哥沒辦法……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥明明就是個大人了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n卻還沒辦法、一個人好好買東西呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那麼，我就來教哥哥很多很多的事……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這個意思是說不用教哥哥買東西的方法之類的，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也沒關係嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥很喜歡拿東西提行李嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不對，是哥哥很貼心對吧……♪",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我要買晚餐的材料……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為也有生鮮的食材，要是放到壞掉就不好了……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們就先買哥哥要買的東西吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "然後，再買我要買的東西……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這樣，就不會讓食材壞掉了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻，我是不是很聰明呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n為、為什麼要摸我的頭呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、不要摸我……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚，對不起……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我、很容易被嚇到……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "並不是討厭被哥哥摸啦……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n話說回來，哥哥要買什麼東西呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "介紹打工的，資訊雜誌……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為伙食費和住宿費之類的，",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一直都是由和哥哥一起住的孩子出錢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以想說自己賺錢，減輕那個孩子的負擔……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我懂的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n因為我也是，借住在【咲戀育幼院】裡……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要是一直受別人照顧，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會覺得很不好意思對吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是，如果是打工資訊雜誌的話……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不用特地去買，在廣場之類的地方都有免費發送唷……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "地點就在回家的途中，到時應該就拿得到……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥連這件事都不知道，真的能夠打工嗎……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，對不起，不小心說了自以為是的話……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我沒有惡意，原諒我吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻。",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥真的是什麼都不知道呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n好、好可愛……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "打工要加油喔……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我會幫哥哥加油的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "假如我將來，一不小心，成為大人物的話……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我會雇用哥哥的唷……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻嘻……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，如果哥哥沒有其他想買的東西了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我可以買自己要買的東西了嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我剛才，看到了一條很可愛的蝴蝶結髮飾……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我呀，很喜歡蝴蝶結……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，就是這條……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥你看，這個蝴蝶結明明這麼可愛卻很便宜……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "即使是用我的零用錢，也勉強能買得起……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚。我是從咲戀媽媽那裡，拿到零用錢的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n等我以後長大了，我想要好好工作來還錢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不然總是拿錢的話，很不好意思呀……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "女孩",
        "words": "買啦買啦買啦！",
        "unit_id": 211,
        "voice": "vo_adv_1021003_030"
    },
    {
        "type": "dialogue",
        "name": "女孩",
        "words": "\n媽媽，買那個蝴蝶結給我啦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n啊、啊嗚？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個孩子，是不是想要這個髮飾呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "不行喔～",
        "unit_id": 411,
        "voice": "vo_adv_1021003_032"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n妳看，那個姐姐好像已經把最後一個買走了呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "已經賣完了，所以忍耐一下吧。",
        "unit_id": 411,
        "voice": "vo_adv_1021003_033"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n今天的晚餐，媽媽會煮妳喜歡吃的漢堡排喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女孩",
        "words": "不要不要不要，買給我啦！",
        "unit_id": 211,
        "voice": "vo_adv_1021003_034"
    },
    {
        "type": "dialogue",
        "name": "女孩",
        "words": "\n我想要那個蝴蝶結～不要啦啊啊啊！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真是的，不要這麼任性！",
        "unit_id": 411,
        "voice": "vo_adv_1021003_035"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n我們家可沒有會一直說「不要」的孩子！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "趕快過來，不然我就要把妳丟掉囉？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女孩",
        "words": "不要啦啊啊！",
        "unit_id": 211,
        "voice": "vo_adv_1021003_036"
    },
    {
        "type": "dialogue",
        "name": "女孩",
        "words": "\n買啦買啦買啦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女孩",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女孩",
        "words": "不買給我那個蝴蝶結的話我就不回去！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真是個任性的孩子……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我曾經失去了全部……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是，咲戀媽媽……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n還有大家，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "都一點一點的給予我新的東西……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就算有想要的東西，也都一直一直努力地忍耐……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n用慢慢存起來的零用錢，想買這個髮飾……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "難道說連這種事情，對我來說都太奢侈嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "難道我不值得擁有任何東西嗎……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "妳不是……",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_042"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "妳不是，還有媽媽嗎……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……那個，",
        "unit_id": 102111,
        "voice": "vo_adv_1021003_043"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個髮飾，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就讓給妳們吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "咦？唉呀，這樣沒關係嗎？",
        "unit_id": 411,
        "voice": "vo_adv_1021003_044"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "妳不用這麼客氣的喔～？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "雖然我們家的孩子現在在鬧脾氣……",
