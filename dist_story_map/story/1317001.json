    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你那副疲憊的表情是怎樣啦。",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我都難得來鎮上了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就陪我到最後吧。",
