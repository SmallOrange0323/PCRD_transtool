        "voice": "vo_adv_1317001_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拿過來吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後，",
