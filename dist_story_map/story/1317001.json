[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "季節是夏天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n陽光強烈地照射，熱浪扭曲空氣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對此，愛梅斯仍事不關己地在平時的場所進行著工作。"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這邊的記憶……",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "考量到關聯性，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "整合在那邊會比較好吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是……",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是暑假的記憶吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n把作業放到最後一天，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了逃避現實而開始大掃除了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n移動到捉弄資料夾，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過……",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這傢伙在海邊玩的記憶也太多了吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而且還大多是跟女孩子一起。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都是因為光做這些事",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才會忘了作業啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "夏天……",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "海……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是跟我無緣的話題呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總覺得有點不爽，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要來新增一個資料夾整理他在海邊闖禍的事跡嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我不住手♪",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……話說，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼{player}會理所當然地在這啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n又擅自進來了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是什麼道理？",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "上次我還想說也有這種事啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後就忽略了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但要是會發生好幾次，我可不能視若無睹。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有什麼",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像是讓你來到這裡的契機嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n告訴我是什麼狀況才變成這樣的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……想著",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我的事？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呃，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那是指……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那不可能吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟是{player}嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我知道，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我是知道的喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但這是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "保險起見問問。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……具體而言，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你想著我的什麼？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………………………………………………………………………",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哦～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼突然想去海邊啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可沒說",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想去海邊什麼的喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為是夏天？",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我不知道啦，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟這裡又沒有季節感這種東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你只因為是那種季節，就什麼也沒多想地開口邀人了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也明白你為什麼會有非常多海邊的記憶了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我可是很忙的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n約其他人如何？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她們一定會很開心的喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……你說",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開心？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……那是怎樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼回事啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "莫名強勢呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……因為我最近偶爾開始出門了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你約我是讓我很高興，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但果然不行啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這翅膀之類的很引人注目吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n最重要的是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你想想，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我又沒有泳裝那些的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……一起……",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那是指……",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}要幫我選的意思？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "由你來選",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我的泳裝啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像有點有趣嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真拿你沒辦法呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就現在去買吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就由我來確認",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的品味吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……果然",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被盯著看呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也難怪啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我這副身軀",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很引人注目吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還想說晶那些人大概已經很引人注目了，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但畢竟她們沒長翅膀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊──好的好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的天然發言出現了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我不會因為那種話怦然心動之類的啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼要跟我競爭啊……？",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是你偶爾會出現的莫名其妙部分呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，我們快走吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再這樣下去只會白白引起不必要的關注。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是那邊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你走錯路了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "精品店的路",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是這邊啦，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這邊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說我對路很熟……",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那是當然的吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
