    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……咦？",
        "unit_id": 190011,
        "voice": "vo_adv_1317001_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "問我這樣",
