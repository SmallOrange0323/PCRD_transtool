[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下！？",
        "unit_id": 106011,
        "voice": "vo_adv_5058321_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼突然冒出一大堆！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 105911,
        "voice": "vo_adv_5058321_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這莫非是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不小心走進了",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那隻魔物的地盤嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「哎呀」",
        "unit_id": 106011,
        "voice": "vo_adv_5058321_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啦可蘿仔！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳怎麼可以這麼冷靜啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看看那一大群！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來像是隨時會朝我們衝來的樣子啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冷靜點冷靜點，小凱留。",
        "unit_id": 105811,
        "voice": "vo_adv_5058321_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這種時候",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要換個想法就好了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "例如這樣……♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天可以盡情大吃了呢☆",
        "unit_id": 105811,
        "voice": "vo_adv_5058321_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳打算吃掉嗎！？",
        "unit_id": 106011,
        "voice": "vo_adv_5058321_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳打算把那一大群全部吃掉嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我絕對不要！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且這下不管贏了還是輸了都沒什麼好事吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n輸了被魔物踩扁，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "贏了就撐破肚皮不是嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這時候就乖乖逃跑吧？",
        "unit_id": 106011,
        "voice": "vo_adv_5058321_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n吶，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在還來得及",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想點辦法──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105911,
        "voice": "vo_adv_5058321_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請看看貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 105811,
        "voice": "vo_adv_5058321_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一決勝負！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來吧，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "超大份燒肉定食～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊……",
        "unit_id": 106011,
        "voice": "vo_adv_5058321_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就戰鬥吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過相對的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳絕對要全部吃完喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可不會幫忙吃啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這個白癡佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐、凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_5058321_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位都充滿幹勁呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也助上一臂之力吧……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……♪",
        "unit_id": 105911,
        "voice": "vo_adv_5058321_011"
    }
]