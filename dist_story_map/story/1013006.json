[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和七七香\n為了擊退魔物的工作而來到普拉諾平原。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "開頭就退場辛苦你啦──",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_000"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼回事，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個在一開始的草叢就已經練到100等的感覺。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "零手感。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是什麼限制條件玩法？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喂，",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "比起這個呀！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我呀，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最近學會了一個有趣的咒語呦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以試用看看吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我沒想參考你的回答──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如何？",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如何？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔、喔、喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對吧？",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太棒了──成功！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼哼哼，",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "被下這個咒的人，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n會變得突然想吃甜食喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我為這個咒語取了名字！",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……叫做",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「甜點」呦……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然的啦！",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在戰鬥最熱烈的時候，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n能讓對手突然想吃甜食不是嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哇，",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好想吃甜食……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "趁他這麼想時攻擊就對了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊啊，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我果然是天才♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對吧對吧──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種魔法才能感覺到浪漫！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只要施在敵人身上，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在他變得想吃甜食時就會出現破綻了呢♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯──♪",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我果然是……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "天才♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "來、",
        "unit_id": 1,
        "voice": "vo_adv_1013006_011"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "來人啊──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯喵？",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有人往我們這裡直奔而來？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喂──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "發生什麼事了嗎──？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "啊啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1013006_013"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "你們！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "救、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "救救我們啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔喔，",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總之先冷靜冷靜。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "請詳細說明發生了什麼事。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "呼呼，",
        "unit_id": 1411,
        "voice": "vo_adv_1013006_015"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "我、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "我們是專門買賣魔法道具的商家，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n……在前往王都的途中時，我們非常重要的商品連同馬車一起被搶走了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說什麼──！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這可是大事件啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "對呀！",
        "unit_id": 311,
        "voice": "vo_adv_1013006_017"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n而且裡面還包括了非常貴重的魔導書之類的商品……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "貴重的魔導書！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那真！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "那、",
        "unit_id": 311,
        "voice": "vo_adv_1013006_019"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "那真……？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不行啊！",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不知不覺情緒就高昂起來了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "別在意呀啾咪！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "小、",
        "unit_id": 311,
        "voice": "vo_adv_1013006_021"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "小姐妳的用語可真是奇怪呀……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "嗯？",
        "unit_id": 1411,
        "voice": "vo_adv_1013006_022"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "說到奇怪……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "那些傢伙，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n都在使用著沒見過的魔法呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "啊啊……",
        "unit_id": 311,
        "voice": "vo_adv_1013006_023"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "那應該是「黑暗收藏家」的黨羽吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "叔叔也知道「黑暗收藏家」嘛！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "不，",
        "unit_id": 311,
        "voice": "vo_adv_1013006_025"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "我也不清楚詳情……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "只有聽過傳聞……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n但是啊，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "既然使出沒看過的魔法，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "也只能聯想到這個了呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "男子的弟子們將貴重的魔導書……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "叔叔，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "馬車是往哪個方向走的呢？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "咦？",
        "unit_id": 1411,
        "voice": "vo_adv_1013006_027"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "我記得是往前方",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "洞窟的方向走……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "該、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "該不會",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "妳要幫我找回來嘛！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然！",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "請交給我！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為我絕不允許有人用魔法做壞事！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且，",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若和「黑暗收藏家」有關的話更要弄清楚了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "請放心交給魔法少女七七香吧♪",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "商人大叔所說的是這個洞窟吧──",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_030"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "喂，",
        "unit_id": 911,
        "voice": "vo_adv_1013006_031"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "這本魔導書……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "來看看吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在耶在耶，",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "竟然在這裡悠哉悠哉地看魔導書。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等著你的可是很恐怖的處罰喔～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "好了，",
        "unit_id": 811,
        "voice": "vo_adv_1013006_033"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "那麼就快開始──",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "登登、",
        "unit_id": 101311,
        "voice": "vo_adv_1013006_034"
    },
    {
