        "voice": "vo_adv_1211002_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只有我們兩個……",
