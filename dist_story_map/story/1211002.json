    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說是看顧，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n其實也沒什麼事好做就是了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果，",
