    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n他應該會毫不猶豫親吻我吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然，",
