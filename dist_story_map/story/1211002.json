        "voice": "vo_adv_1211002_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "克蕾琪塔和似似花，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也都不曉得該怎麼喚醒這傢伙啊。",
