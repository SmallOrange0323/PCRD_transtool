[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嚼嚼嚼嚼嚼♪",
        "unit_id": 100711,
        "voice": "vo_adv_2007007_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好好吃喲～☆",
        "unit_id": 100711,
        "voice": "vo_adv_2007007_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子看上妳了喲，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "給妳滿分喲～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "姐～姐，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可以讓妳擔任宮子專屬的布丁大廚喲♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是我的榮幸呢～",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是材料也很好的關係，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為有新鮮的牛奶和雞蛋呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵。",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是因為咱們和",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "附近的牧場有交易呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這個時代，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若光只是窩在城裡也不太好過呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "且前陣子，",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牧場似乎因為遭到大量破壞魔法直擊的關係，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n正相當頭疼的樣子呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "向她們買了很多食品之類的產品，",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n或許多少也能對他們的重建幫上一些忙吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳又變回了小孩子了呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一下大人一下又變回小孩，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底是怎麼辦到的啊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯～",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有點難解釋呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不如說，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "調查這到底是怎麼一回事，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也成為了我們公會的目的之一。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這世上本來",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就存在許多不可思議的事。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔……",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看來這公會裡的所有成員，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都有一兩件",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可思議的煩惱或狀況呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是有意思呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這不是今天要討論的重點就是了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "姐～姐～",
        "unit_id": 100711,
        "voice": "vo_adv_2007007_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "還要還要！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n想要吃",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "更多的布丁喲～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然事到如今才覺得奇怪，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳明明是個幽靈",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是怎麼把東西吃下肚的呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正常來想，",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃進去的布丁，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該會直接掉往地面上才對吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這也是吾等，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一直都覺得不可思議的一個問題吶。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "當宮子要吃布丁之類的時候，",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n她能刻意讓自己實體化，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n而且似乎可以自由切換為",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "實體",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "或靈體的狀態。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但畢竟宮子本身",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是個超乎常理的存在，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以吾等對其原理還是摸不著頭緒呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾等的公會，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還真是聚集了",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "許多奇奇怪怪的傢伙啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "正因如此，",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n吾等才能應對",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那些不合乎世間道理的神秘狀況。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾等簡直是",
        "unit_id": 104412,
        "voice": "vo_adv_2007007_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "處理這些荒唐無稽之事的專家呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有問題就儘～管提出來吧♪",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是可靠呀～，",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光是眼前的事件，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就已經弄得翻天覆地了呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若能得到大家的協助，",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或許真能夠反擊也說不定呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "除了布丁以外，還做了不少其他的小點心唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家也不用客氣儘管吃吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再等一下，餅乾也差不多要烤好囉～",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "敬請期待♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵。",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在應該不是悠哉聊天的時候吧？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你們不是有什麼事情",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想跟我們商量嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2007007_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎還埋頭在做點心的樣子，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以就由",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下來代答吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然經過通訊魔法，",
        "unit_id": 105913,
        "voice": "vo_adv_2007007_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經大略傳達過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "事情的概要就是了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯嗯。",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是想要詢問，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有關於前幾天那大量破壞魔法的事吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而我預知到那造成了慘絕人寰結果的魔法……",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果讓你們有所期待就不好了，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以必須事先聲明……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然是名占卜師，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是我並沒有辦法正確地預知未來。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那是，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "殘存在凡人之軀的奇蹟。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但如果是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "超越人類的存在，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或是……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就另當別論了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我能做到的，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過就只是占卜的程度罷了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n明天是不是會",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "下雨呢，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n又或是今天",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "會不會遭遇到",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "點不幸之類的事……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "頂多如此而已，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n只是一種縹緲",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "又不切實的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「預感」罷了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "未來總是搖擺不定的，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是深埋於濃密的霧靄之中的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而我，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "並未擁有那能看透看穿全貌的強大力量。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不僅是我，無論",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是誰，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "照理來說都無法辦到。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說也是呢～",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但據說「那男人」……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像能夠相當準確地預知到未來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能夠預知到箭矢即將飛來，",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後輕而易舉地閃開之類的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯……",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這有",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "兩種可能。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如我方才",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所述……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n其中一個可能性是，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那位名為尤絲蒂亞娜的人物",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "能夠行使超越常理的奇蹟。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "另外一個可能性是，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n她所擁有的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "權力及實力，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n足以讓未來",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如她所願扭曲。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這兩種可能性有什麼不同呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "打個比方。",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n五秒之後",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}的手，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n將會被叉子給刺穿",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……假設我做了",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如此的預知。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "若是如剛才所說明的",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "兩種情況中的前者，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那麼這將會是誰都無法顛覆，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "必然會發生的命運。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不論做再怎麼多無謂的掙扎，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}的手，終將會被",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "叉子給刺穿。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若、",
        "unit_id": 105913,
        "voice": "vo_adv_2007007_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是發生這樣的事態，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下可沒辦法就這麼算了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由在下來守護。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼？　",
        "unit_id": 105913,
        "voice": "vo_adv_2007007_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有的事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您何需道謝……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n保護主人的一切，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是在下的使命。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇！",
        "unit_id": 105913,
        "voice": "vo_adv_2007007_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嚇死了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為這不過是個譬喻而已唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該不需要那麼緊張才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵。",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_045"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n無論是誰又做了再多的努力，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都完全沒辦法改變。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這正為所謂的，命運。",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_046"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而這也是預知未來的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "正確意思。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就算是妳再怎麼盡心盡力地，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_047"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n去保護{player}也一樣……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或許是從個誰也想不到的地方，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_048"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "飛來了一隻叉子也說不定。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n無論是什麼不幸意外，都",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "必定能",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "預知成功的情況。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然而，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_049"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "後者是。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n和前者不同，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "並非絕對會發生的未來。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_050"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "預知到此事的人，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n刻意採取行動，為使未來如預知一般發展。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "舉例來說……",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_051"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "將想要守護{player}的妳給殺害，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n然後再悠悠哉哉地，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n用",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "叉子將{player}的手給刺穿。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或者花大筆錢去買兇，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_052"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "又或者使上美人計，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n甚至直接下達命令……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為了要用叉子刺穿{player}的手掌，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_053"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而用盡任何手段與辦法。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不管如何，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_054"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "預知都是正確的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n雖然兩者都會發生",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如預知所說的未來。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n結果相同，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但兩者發生結果的過程卻不同。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那名為",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_055"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "尤絲蒂亞娜的人物，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "若真的能夠預知事物……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "究竟是前者還是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "後者的情況，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也不能夠輕易斷言。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然妳提到的",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_056"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那名人物預知",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "並躲過飛來的箭矢……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也有可能是",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_057"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "擁有著相當優異的危機感，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n在箭矢飛來的頃刻間",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "便察覺並閃過。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "又或者是，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_058"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "早就將那名射手給收買了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n事先就已經非常清楚",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "何時會從何處飛來箭矢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以即使並非是擁有奇蹟般的預知未來的能力，",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_059"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也能夠充分解釋。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "以我的立場來說……",
        "unit_id": 103111,
        "voice": "vo_adv_2007007_060"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n若正確的預言真的存在，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那我也沒辦法做生意了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以較支持後者的理論。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔呣。",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然很想知道，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n尤絲蒂亞娜那神奇預知能力的箇中道理。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若是前者就真的拿他一點辦法也沒有了，",
        "unit_id": 105812,
        "voice": "vo_adv_2007007_062"
    },
    {
        "type": "dialogue",
