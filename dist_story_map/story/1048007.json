[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}像往常一樣被叫到平原。\n但是，美冬一副非常嚴肅的表情。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝你來呢……",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "從前陣子我就一直在想這件事……",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "今天我要向你挑戰！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我也不知道……但我最近很奇怪。",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只要你在我身邊，我就沒辦法保持平常心！",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "變得想要展現好的一面給你看，而勉強自己……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有時卻又會想向你撒嬌、變得想依賴你。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總之，沒有任何理由的只是想跟你在一起……",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這種心情還是第一次，一點效率都沒有。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我要打敗你，回到原來的自己！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我要出手了喔！",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_005"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "擋下了……？",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼，這招如何！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "又被擋回來了……",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你進步了呢！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n真高興！ ",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喝啊啊啊啊啊啊啊！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，在長時間的戰鬥後仍未分出勝負，\n兩人同時用盡全力，累倒在地上。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "噗哈！ ",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼，今天就到此為止吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n你進步了呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n沒有分出高下……勝負就留到下次吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "師徒關係也暫時繼續吧。",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵呵，謝謝你呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……喂……只要一下下……",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你能聽我說自己的事嗎……？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一直以來呢……我無論和男性或女性",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n都不是很要好。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然和公會成員的關係不錯，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但有一半是因為工作。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "考慮到所有事情的效率，傭兵必須是孤獨的。",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n若是有了想守護的事物，就會變弱。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……我擅自這麼認為呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喂……我可以靠過去一點嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這樣躺著就好……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵……",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這裡有一塊碎布。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……你覺得這是什麼？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看起來像嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "的確是這樣沒錯……",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……這個呢，忘了是什麼時候，",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n有次我和魔物戰鬥而弄破衣服時，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n你為了讓我遮住身體而送我的斗篷。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "已經變得破破爛爛了，我還留著這種碎布，",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n真是一點效率也沒有……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但總覺得無法捨棄。很、奇怪嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵呵……謝謝。",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "聽你這麼說，我也……很高興喔。",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喂，你。",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n如果以後你真的贏了我……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們不再是師徒關係的話，你……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "即使這樣，你還是會在……我的身邊嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "欸嘿嘿……謝謝你呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_024"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好――，",
        "unit_id": 104811,
        "voice": "vo_adv_1048007_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼明天就一起",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n前往受託探索的地牢吧！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n目標是在最短時間內完成委託喔―――！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美冬邊和{player}這麼說著，邊自然地搭起肩。\n兩人今後一定會被比單純的師徒關係\n更強烈的羈絆所聯繫吧……"
    }
]