[
    {
        "type": "background",
        "background": "500164"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在午餐的尖峰時段結束後，{player}一行人\n來到沙灘上休息。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒想到會有那麼多的客人上門。",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這全都要感謝純呢。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我什麼都沒做啊……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然妳那麼說，",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我認為在沙灘上穿著鎧甲的模樣",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是很罕見的。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不只是其他的客人，",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "連我們家的小朋友也非常感興趣。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "咲戀媽媽，",
        "unit_id": 213,
        "voice": "vo_adv_1136002_005"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "妳跟那個人認識嗎？",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "好奇怪的打扮～",
        "unit_id": 113,
        "voice": "vo_adv_1136002_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喂，",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要那樣說人家！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你們不用害怕，純可是個好人喔？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要用跑的！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要在我看得到的地方玩喔──！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好──！",
        "unit_id": 213,
        "voice": "vo_adv_1136002_008"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我知道──！",
        "unit_id": 113,
        "voice": "vo_adv_1136002_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵……",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "純？",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有什麼好笑的嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有啦，",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然早就聽妳說過了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我還是第一次看到",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀像這樣",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n照顧小孩子的模樣。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……我看起來，",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有好好照顧到他們嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "光是像這樣在一旁觀看，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就能強烈感受到\n孩子們都",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很仰慕妳的事實。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真不愧是小咲戀。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這當然",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不是我一個人的力量。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是有許多人的幫助，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我才能像這樣照顧他們。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "發生什麼事了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "孩子們好像在那裡爭執……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我也要沙灘球啦──！",
        "unit_id": 213,
        "voice": "vo_adv_1136002_017"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "才不要，",
        "unit_id": 113,
        "voice": "vo_adv_1136002_018"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我要拿這個代替游泳圈來游泳！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉喲，",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你們兩個是怎麼啦？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚～",
        "unit_id": 213,
        "voice": "vo_adv_1136002_020"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "都怪他獨占玩具啦……",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我也不願意啊，",
        "unit_id": 113,
        "voice": "vo_adv_1136002_021"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "誰叫它只有一個！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這下頭痛了……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n玩具數量很少，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你們要一起玩才行喔？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這件事可以交給我處理嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你們兩個",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "聽好囉？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你們好不容易才能來海邊玩。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n自己一個人玩不是很可惜嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可是～",
        "unit_id": 113,
        "voice": "vo_adv_1136002_025"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "她就不會游泳啊～",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "既然她不會，",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那你教她怎麼游如何？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你們難得來海邊一趟，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n大家一起游泳會",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "比較快樂吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "連來海邊都要照顧妹妹嗎──",
        "unit_id": 113,
        "voice": "vo_adv_1136002_027"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "好吧，是沒差啦。",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n妳",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "要練習嗎？",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "哥哥教超爛的，我才不要！",
        "unit_id": 213,
        "voice": "vo_adv_1136002_028"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "對了，",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "鎧甲大姐姐陪我一起玩吧！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是很想陪妳玩啦……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等等。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "摸我會有危險喔！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "咦──？",
        "unit_id": 213,
        "voice": "vo_adv_1136002_030"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "為什麼──？",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "呀！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "這個鎧甲好燙喔──！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我一直待在外面啊。",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "太陽的高熱",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "把鎧甲烤得很燙。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這很危險的，最好不要亂摸。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉，",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這我辦不到。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟是家訓。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "咦～",
        "unit_id": 213,
        "voice": "vo_adv_1136002_033"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "妳這樣很無趣耶──！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "來──",
        "unit_id": 1,
        "voice": "vo_adv_1136002_034"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "大家現在看到的就是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "這次比賽的最大獎，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "特大美人魚游泳圈──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n其他還有很多豪華的獎品！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "敬請踴躍參加──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "咦？",
        "unit_id": 113,
        "voice": "vo_adv_1136002_035"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那是什麼？",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "好大一個！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好棒──！",
        "unit_id": 213,
        "voice": "vo_adv_1136002_036"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好可愛──！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "是美人魚游泳圈──！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n好好喔──！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "好大──！",
        "unit_id": 113,
        "voice": "vo_adv_1136002_037"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "如果是那麼大的游泳圈，",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就能大家一起坐了！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀，",
        "unit_id": 104711,
        "voice": "vo_adv_1136002_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那是？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼說來，",
        "unit_id": 110311,
        "voice": "vo_adv_1136002_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我聽說沙灘上經常會舉辦各種活動……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不好意思，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請問這是什麼樣的活動呢？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "喔，",
        "unit_id": 1,
        "voice": "vo_adv_1136002_040"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "這位姐姐也要參加嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n特大美人魚游泳圈是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
