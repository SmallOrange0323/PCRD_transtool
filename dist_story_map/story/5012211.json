[
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "呵呵，",
        "unit_id": 11111,
        "voice": "vo_adv_5012211_000"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "意外的很行嘛。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n我以為妳會連一點勇氣都拿不出來，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n被絕望淹沒呢。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為、",
        "unit_id": 105511,
        "voice": "vo_adv_5012211_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為了保護前輩，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就算是我也會鼓起勇氣的……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "呵呵……",
        "unit_id": 11111,
        "voice": "vo_adv_5012211_002"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "真的是這樣嗎？",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n我看的出來喔。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n你的懦弱……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "和你心中的黑暗……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "你什麼都沒改變。",
        "unit_id": 11111,
        "voice": "vo_adv_5012211_003"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "心中感到恐懼，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n現在也很想逃開……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "但是",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "因為有夥伴的幫助，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n所以努力擠出一點點的勇氣站在這裡……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "是吧？",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那……",
        "unit_id": 105511,
        "voice": "vo_adv_5012211_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那是……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "沒有夥伴就什麼事都做不成的愚者啊……",
        "unit_id": 11111,
        "voice": "vo_adv_5012211_005"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "那麼！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n我就將最適合你的絕望賜給你！！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "霞、",
        "unit_id": 105511,
        "voice": "vo_adv_5012211_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "霞……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真琴……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "香織、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還有真步……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "讓只會靠夥伴來保護自己的愚者，",
        "unit_id": 11111,
        "voice": "vo_adv_5012211_007"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n與樣貌和夥伴一樣的那些傢伙們對峙時……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n有辦法能夠戰勝自己的懦弱嗎？",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 105511,
        "voice": "vo_adv_5012211_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我們約定好了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我們要一起守護前輩。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為了這個目標、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就算是我也會奮戰到底！",
        "unit_id": 105511
    }
]