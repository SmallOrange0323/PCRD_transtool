    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_9007008_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "問題是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要往哪去。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n要說到魔物感覺會出現的地方……",
        "unit_id": 104412
    },
