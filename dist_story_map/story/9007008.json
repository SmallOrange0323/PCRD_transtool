    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好～！",
        "unit_id": 100611,
        "voice": "vo_adv_9007008_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是要怎麼辦呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n既然沒辦法問到情報，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那是不是離開鎮上會比較好呢～？",
