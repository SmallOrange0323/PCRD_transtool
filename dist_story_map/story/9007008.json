    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過有道理。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總之咱們先離開鎮上，",
        "unit_id": 104412,
        "voice": "vo_adv_9007008_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "去找沒有居民的地方看看好了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "說不定魔物為了擺脫追兵，會藏在那種地方。",
