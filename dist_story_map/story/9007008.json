    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊？",
        "unit_id": 104412,
        "voice": "vo_adv_9007008_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "宮子，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳在說什麼？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "還有什麼說什麼來的！",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_026"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "已經發現了喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "既然這個世界有這麼多布丁，",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_027"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那肯定也會存在布丁堆成的島嶼喲！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "如果是島嶼的話，吃掉了也不會有人生氣來的……！",
