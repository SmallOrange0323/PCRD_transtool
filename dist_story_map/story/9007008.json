    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想到這裡",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總有一天也會成為妾身支配的土地，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就算走遠一點也心甘情願呢♪",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，",
        "unit_id": 100611,
        "voice": "vo_adv_9007008_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就決定要出去囉！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要去哪裡好呢～？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "森林？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "海邊？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "去島嶼好像也不錯呢～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "耶嘿嘿♪",
        "unit_id": 100611,
        "voice": "vo_adv_9007008_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這個世界的島嶼，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "會是長什麼樣的呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n難不成",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也是用甜點堆成的嗎～？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "甜點堆成的、",
