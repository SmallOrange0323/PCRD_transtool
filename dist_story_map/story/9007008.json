        "voice": "vo_adv_9007008_028"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n別在這邊瞎耗了，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "快點去找布丁島嶼喲～！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂！",
        "unit_id": 104412,
        "voice": "vo_adv_9007008_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咱們要找的是魔物，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不是布丁島嶼……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呃，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她根本聽不下去了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哎、",
        "unit_id": 100611,
        "voice": "vo_adv_9007008_030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哎呀沒關係啦……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "說不定在布丁的島嶼上，",
        "unit_id": 100611
    },
    {
