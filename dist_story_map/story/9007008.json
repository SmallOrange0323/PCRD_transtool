        "unit_id": 100611,
        "voice": "vo_adv_9007008_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒有任何人在的，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "安靜的地方……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔、",
        "unit_id": 104412,
        "voice": "vo_adv_9007008_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然妾身不知道",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳為何要紅著臉，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n還壓低聲音說這些話……",
