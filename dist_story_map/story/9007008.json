    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊莉亞、茜里和宮子三人，為了尋找5.5周年的魔物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n開始在街上打聽情報，然而──"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "布、",
        "unit_id": 9211,
        "voice": "vo_adv_9007008_000"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "布丁妖怪啊～！",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n布丁妖怪出現了～！",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……氣氣氣，",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇～",
        "unit_id": 100611,
        "voice": "vo_adv_9007008_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好厲害哦～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "鎮上的居民",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一看到宮子就全部逃走了呢～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為什麼來的──！",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子只是",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要來捉魔物的喲──！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "即使妳這麼說……",
        "unit_id": 104412,
        "voice": "vo_adv_9007008_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟妳把鎮上所有的布丁都吃光了啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "會被居民認為是危險存在也無可厚非。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊哈哈……",
        "unit_id": 100611,
        "voice": "vo_adv_9007008_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "原本想在鎮上打聽魔物的所在地，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這樣看來是不行了～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "很過分來的！",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不可原諒來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n如果不想要人家吃掉布丁的話，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n打從一開始",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就別用布丁建房子來的──！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那種……",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那種",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "搖來搖去、抖來抖去的城牆……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一看到",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "又變得好想吃來的～～～！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不、行！",
        "unit_id": 104412,
        "voice": "vo_adv_9007008_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不是說好不能再吃了嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真傷腦筋，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "宮子怎麼老是長不大呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子是幽靈，",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以已經不會長大了喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "也不需要長大了喲～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦～？",
        "unit_id": 100611,
        "voice": "vo_adv_9007008_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "長大的話……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也會有好事情哦～？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯？",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "比如像什麼來的──？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "討厭～♪",
        "unit_id": 100611,
        "voice": "vo_adv_9007008_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里怎麼好意思說呢～♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯嗯～？",
        "unit_id": 100711,
        "voice": "vo_adv_9007008_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是什麼、",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是什麼來的～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "很在意來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "茜里",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "別再扭來扭去的，快說出來喲～～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊～",
        "unit_id": 104412,
        "voice": "vo_adv_9007008_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們兩個！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別再吵了！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n咱們是來",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "捉魔物的！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n沒空在這邊瞎耗！",
