    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊嗯……",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_000"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "哇，",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好好吃。",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呵呵，",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好久沒吃漢堡了。",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n以前姊姊偶爾會買回來，",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n但在店裡吃的話熱騰騰的真好吃。",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "在平時已經該回去準備晚餐的時間還待在店裡，",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也稍微有點",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "在做壞事的感覺呢？",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……而且",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "還是跟「學長」",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "兩個人一起……",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嘿嘿……",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "謝謝你。",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n居然可以像這樣聽到你的祝福，",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "生日真不錯呢。",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊和布武機",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然也會幫我慶祝",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但實在太特別了……",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "咦？",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_003"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n這是……",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "禮物？",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可、",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可以收下嗎？",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嘿嘿……",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_004"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嘿嘿嘿……",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "謝謝你。",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n我高興到",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不禁懷疑真的可以這麼幸福嗎。",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "感覺今天睡醒時心情會很好……♪",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "居然在放學後約會的情境收到禮物，",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_005"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "生日還真是讓我做了個美夢……♪",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_006"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不，",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "沒什麼啦？",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那個，",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呃……",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……如果，",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_007"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n如果你不介意的話……",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可以再",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n繼續和我一起慶祝嗎？",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "現在",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_008"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "打開禮物的話",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "感覺有點可惜……",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "因為打開之後",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就會醒來了。",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……嘿嘿。",
        "unit_id": 130131,
        "voice": "vo_adv_4010175_009"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "謝謝你，",
        "unit_id": 130131
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "「學長」♪",
        "unit_id": 130131
    }
]