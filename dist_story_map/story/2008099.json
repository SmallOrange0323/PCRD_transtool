[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎怎怎、",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼辦呀？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n到底發生了什麼事 ！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}！\n你聽得到我的聲音嗎？\n聽到的話就應一聲啊！",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗚……",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼回事……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n怎麼會突然，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就看不到{player}他了呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難不成，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}他死了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "除非他被轟的灰飛煙滅，不然應該還會留有點連接才對！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是被什麼給遮蔽了？",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是誰用上了能夠暫時將我和{player}之間的連接切斷，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n類似這樣的魔法嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "，這種事真的辦得到嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n從來",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就沒有發生過這樣的事啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再怎麼說我也不是神……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是無法躲過這世界的法則、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無法躲過程式編碼的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是哪個查覺到我的存在的人物，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對我和{player}之間的連接進行了妨礙……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "除此之外也沒有其他可能了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊可惡！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊嗚！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n啊啊，{player}！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你沒事嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是太好了♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話又說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "愛梅斯『大人』是怎樣呀？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n突然就規矩了起來……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我和你之間都是什麼關係了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "敬稱什麼的就不用了啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這件事先放一邊。",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n欸，到底是發生了什麼事？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "把你現在所面臨的狀況，趕緊說明給我聽！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不知為何一時之間，完全看不到你的任何狀況了啊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以，我完全不知道到底發生了什麼事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯嗯，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原來如此……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從矛依未那聽來了各式各樣的事情，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而你也終於開始逼近那世界之謎了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n單單這件事，就相當值得讓人高興呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是在進行說明的途中，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你們卻被看起來怪怪的凱留，所領著的魔物和軍隊給襲擊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而你也陷入了窮途末路的危機之中呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "連能夠防範空間跳躍的陷阱都用上了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n敵人這一次，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來是沒打算放水全力攻了過來呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "極有可能，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能夠給你助言的我的存在，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也被誰給查覺到……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以才在一時之間，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將我們間的連接給切斷了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這完全被擺了一道啊。",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n敵人這回是認真的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想要把你們所有人給擊潰……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然勉勉強強能夠保住小命，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經是謝天謝地了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但在這之後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "似乎也只會有更加嚴峻的戰鬥不斷上演啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說來貪吃佩可她呀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n實在很可憐，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "似乎是被敵人給抓到了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然看起來一開始就決定好要活捉了，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以暫時似乎不會有生命的危險吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也不能過於樂觀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而你們雖然和矛依未一行人，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n成功逃往到安全的區域了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但這之後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "敵人也會對你們更加窮追猛打吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在短時間內，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想要安穩的過日子看來是免談了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也別因此而喪志。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n敵人……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管是叫尤絲蒂亞娜還千里真那的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他也不是什麼神。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是魔力還是什麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也不都是無窮無盡的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "目前也就只能咬緊牙關，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "靜待反擊之時伺機而動。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我能和你說的也就只有這些了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對不起，{player}。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如此的無力，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n連你也沒辦法保護好……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對這樣的自己，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感到慚愧呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不。",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不該是在這說喪氣話的時候呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我這裡也會盡我能力所及。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不管得用上什麼手段，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也會成為你的助力的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也別因此氣餒，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要再加把勁唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別就此放棄了。",
        "unit_id": 190011,
        "voice": "vo_adv_2008099_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不論什麼時候，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我都會與你站在同一邊唷。",
