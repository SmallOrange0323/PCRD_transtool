[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我回來了～♪",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，嚇我一跳！？",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐～歡迎回來♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "您比原先告訴我的時間還要早回來呢。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為您突然回來，讓我吃了一驚呢，",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還以為心臟要停了～……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，嚇了妳一跳呢。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這玄關的門……安裝得不好，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n似乎每次開閉都會發出噪音。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我也很想修理。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還沒有餘裕處理這些枝微末節的事情呢～？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是啊～。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為那位先生是男性，",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n說不定很擅長木工之類的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我稍後就去問他能否想想辦法♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那傢伙，他不是失憶了嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不知道能否記得起那種事情呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嘛，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真的不行的話再請專門業者就好，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果他『能做到』就最好囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "您今天的工作已經順利解決了吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我剛好正在準備晚飯……",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就一起準備大小姐的份吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，我應該沒時間吃晚餐。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n現在還在工作到半途，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只是抽空回來一下。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有些必要的文件放在育幼院裡呢。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我只是回來拿它們。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "此外我也很想看看大家的樣子呢。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "小朋友們的狀況如何？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n都相處融洽嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n【咲戀育幼院】今天也相當和平♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那位先生和可可蘿也很乖巧聽話……",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "孩子們似乎相當親近那兩人。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家今天一直快樂地一起玩耍喔～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來如此……",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣就好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "特別是那傢伙，在一整群女孩子中只有他是男孩子呢。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有些擔心會不會被排斥呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n失去記憶，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n似乎反而比較幸福呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "與其說大家將他當作男性對待，",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n倒不如說是『不可思議的生物』還比較貼切喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "覺得他很稀奇，或是認為他是寵物。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這樣也是有點那個呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比起這個，鈴莓，不好意思……",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可以幫我從我的書房裡，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n把文件拿給我嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把從右邊數來第三個金庫裡面的東西，全部拿給我呦。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就用這段時間稍微跟小朋友們打個招呼吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "知道了，大小姐～♪",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n話說，只是要拿文件的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n若是聯絡我，我就可以送過去給您啊？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸～……",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n請妳幫我拿重要文件這件事，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n令我感到很不安呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要誤會喔。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n並不是不信任妳呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳比較冒失，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還擁有一個無緣無故招惹麻煩的體質呀",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唔～",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n您說的沒錯……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀，",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看您似乎很急的樣子，我趕緊去把文件拿過來吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請交給鈴莓，大小姐～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，拜託妳了呦。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "接下來嘛，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n小朋友們呢……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "～……♪",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啦。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真難得妳心情不錯呢～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n胡桃♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "噫……？",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，噫……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個那個，嗯……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n抱歉抱歉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嚇了妳一跳呢，還好嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來妳正在做料理呢，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有切傷手指嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我……沒事！",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "歡迎回來，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咲戀媽媽……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，我回來了。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～好香的味道♪",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個是在煮什麼啊？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇……",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不可以偷吃……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "太貪吃了喔，咲戀媽媽……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊真抱歉～",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我肚子已經餓扁了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我從一早開始就在過去的老巢【王宮騎士團】那裡，\n參加會議的關係呀。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "壓力大而胃痛，什麼都吃不下呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "前幾天，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那裡與【哞哞自衛隊】發生糾紛時，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我插手介入了呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為這件事，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有一點糾纏不清呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果不會一直被這種麻煩的因緣纏身就好了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這種事情跟胡桃說也是於事無補呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真不好意思呢，對妳吐苦水。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒關係的……",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_047"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咲戀媽媽，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果向我抱怨後會舒服一點的話……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如、如果能幫上忙的話，",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_048"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我很開心……♪",
        "unit_id": 102111
    },
    {
        "type": "still",
        "still": "300300201"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝呢。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_049"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n嗯～胡桃真是個好孩子呢！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n乖呦～乖呦～♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀哇、哇……？",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_050"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n危險，正、正在用火呢……！？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊～好奸詐！",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_051"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n只有胡桃向咲戀媽媽撒嬌！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也要摸頭摸頭～",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_052"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n咲戀媽媽♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我聽鈴莓說了喔，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n今天大家都是乖寶寶呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓我來誇獎一下大家吧，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n綾音也來，乖～呦，乖～呦……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗚哇☆",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_055"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也給噗吉摸頭啦！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啦好啦。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n噗吉也來，乖呦乖呦♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喂喂，只有摸我的頭很隨便呢？",
        "unit_id": 2111,
        "voice": "vo_adv_3003002_057"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n要多放點感情摸頭啊，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n咲戀大小姐？』。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來我很受歡迎呢。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_058"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……綾音不做料理嗎。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n站在廚房裡的只有胡桃嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "其他孩子都在哪裡呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我可沒有在偷懶呢？",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_060"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n只是因為抱著噗吉很難做料理！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我有在一旁讀出食譜和幫忙試味道♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對了，",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_061"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n因為廚餘滿了，\n所以哥哥拿去丟了喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為食材不足，",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_062"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以可可蘿出去買了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "育幼院裡雖然有其他小朋友，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但大家都還很小呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都是由已到足以負擔工作的年齡的孩子們，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_064"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n互相分工完成各種家務呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_065"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "如果把家務交給鈴莓的話，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就會變成災難了呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "今天中午也是，鈴莓在庭院除草時，",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_066"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "喚醒了地下的魔物，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真的是非常嚇人呢？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是、是這樣呀……",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_067"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在城鎮裡面，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就連「親眼看到」魔物這件事也是很罕見的呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼機率渺茫的可能性，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_068"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n鈴莓也能不偏不倚的碰上呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種「冒失」，會不會也是一種才能呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總、總覺得大小姐好像在說我的壞話～！？",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_069"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是在誇獎妳呀。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_070"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓妳的動作真快呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有幫我把文件都拿來了嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_071"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為大小姐的辦公桌整理得井井有條，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "幫了大忙。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是這些文件沒錯吧？",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_072"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓我確認一下。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_073"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n嗯……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "ＯＫ，就是這些了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "乖呦乖呦，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_074"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n鈴莓是聰明的孩子呢～♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請、請不要摸我的頭！",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_075"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我又不是小孩子！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_076"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不好意思呢，一不注意就……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好～，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_077"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只要填妥這些文件然後送出去的話……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嘛，或許氣氛可以變得更開放一點吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也真是的。",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_078"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不知是否因為交涉對象的【王宮騎士團】，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是一個歷史長久的公會……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "每次只要發生事情就會要求提出文件之類，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_079"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n很討厭呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那裡呀，真是個被傳統和規矩層層束縛的公會呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈，",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_080"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n真是辛苦您了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……咦，你也回來啦？",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_081"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝你幫忙丟垃圾♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請到那邊的洗手台洗手吧。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_082"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "接著，等可可蘿回來之後……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "將添購的食材放進鍋內，就大功告成～了吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀，嗚……？",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_083"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n鈴、鈴莓姐，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不可以碰鍋子……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚～我也想要做菜……",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_084"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我絕對不會再冒冒失失的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好啦好啦♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不可以……",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_085"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對、對不起……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "光是這個月，",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_086"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐就已經讓廚房爆炸三次，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n弄壞十個鍋子了……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我會努力的，",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_087"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n交給我吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唔～……",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_088"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也好啦，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果大家都學會做家事，也算是幫了大忙。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比起這個，大小姐……",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_089"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "若是時間許可的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還是一起吃晚飯吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "餐桌，\n還是要大家圍坐在一起才更有『幸福的感覺』。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_090"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_091"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這個食譜，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也有記載類似的句子♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "喔，",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_092"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "連這種句子都有記載啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "順帶一提，這個食譜是那位先生請認識的人幫忙寫的。",
        "unit_id": 102511,
        "voice": "vo_adv_3003002_093"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n即使是初學者，也能簡單做出料理喔～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯、嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_094"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n似乎連我都能做出美味的料理……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃，很擅長做料理呢！",
        "unit_id": 102311,
        "voice": "vo_adv_3003002_095"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n意外地任何料理都很拿手～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也必須好好學習♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音也是，只要嘗試就能做到喔……",
        "unit_id": 102111,
        "voice": "vo_adv_3003002_096"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "明天一起做吧……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_097"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我明天也得早點回來才行呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果在用餐時同時攝取『幸福的感覺』，",
        "unit_id": 102811,
        "voice": "vo_adv_3003002_098"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n工作的疲憊也會",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "飛到九霄雲外呢♪",
        "unit_id": 102811
    }
