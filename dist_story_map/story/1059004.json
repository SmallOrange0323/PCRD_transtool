[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝招待。",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀。",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人您沒吃完喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "挑食的話『壞壞』喔，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真拿您沒辦法……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，您的肚子不舒服是吧。",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莫非是昨晚跟佩可小姐她們一起去吃的奇特料理店的食物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓您的腸胃無法消化嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這該怎麼辦。",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下胃口也很小，而且已經吃飽了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒辦法為您吃完剩飯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，您不用勉強自己吃完喔。",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請店裡的人幫我們打包外帶就好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n打包的食物可以作為應急食品，拿來餵傳信鴉也不錯呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇？",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是什麼，散發出不可思議的光芒……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這難道是愛梅斯小姐的天啟……",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人請放心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這光芒應該不是什麼危險的東西。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那邊的人，不好意思……",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可以耽誤您一點時間嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請問。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n恕在下冒昧，請問您是在下的主人嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀，您怎麼一臉驚訝。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您不是在下的主人嗎？真可惜。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在下感受到不可思議的緣分。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n原以為您是在下理想中的主人呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊，失敬了。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_011"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下是棗 可蘿。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n就讀小學五年級。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "以後還請多指教。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_012"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……您真的不是在下的主人嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "果然……",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_013"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊，在下終於與您相遇了♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯……說不定您只是還沒察覺自己就是在下的主人，",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n那樣的話也沒辦法。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然在下覺得很可惜、很寂寞，但礙於立場也不能強迫您。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然可能會讓您感到不舒服……",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n可否容許在下稱呼您為主人呢？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "若您能把這個稱呼當作外號就再好不過了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n主人，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "看來在下是迷路了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這種事情還蠻常發生的……",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n心不在焉、漫無目的行走，不知不覺就迷路了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "已經很晚了，在下想回家了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您說很擔心，所以要送在下回家？",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人真是溫柔呢……♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不過只要主人告訴在下車站的位置，在下就能自己回家的。　",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n車站是在那個方向啊。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您說車站的位置很偏僻所以要帶在下過去嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "非常感謝您，主人。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下不會忘記您的恩情。",
        "unit_id": 105931,
        "voice": "vo_adv_1059004_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "如果有一天主人迷路的話，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下會帶主人到主人想去的地方喔。",
        "unit_id": 105931
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呀啊啊啊☆",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n出現啦～，可可蘿！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "稱呼初次見面的男性為『主人』，",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可可蘿也太不可思議了吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是宇宙第一可愛……♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯？",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n啊抱歉……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還是該做一些說明呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖如此。",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n剛剛那是如同夢境一般的情景唷。所以現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和可可蘿……",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在『那邊』好像幾乎沒有交集呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "倒不如說你要趕快想起各種事情……",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我希望你跟『那邊』的可可蘿相遇、相親相愛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n然後給她幸福。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而我只能祈禱而已。",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如同你剛剛所見，",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在『那邊』的世界觀下，可可蘿的言行舉止明顯地奇怪。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可以說是有點被孤立的感覺，總之好像過得很辛苦就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以……",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看到『這邊』的可可蘿幸福生活的樣子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我覺得那樣就很好了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是也不能老是做夢。",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不能聊太久呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這也沒辦法，因為我還沒完全恢復。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然有點不捨，這次就先失陪啦。",
        "unit_id": 190011,
        "voice": "vo_adv_1059004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可可蘿就麻煩你囉，掰～掰♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、主人？",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您怎麼了嗎，一直在發呆……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要是正如愛梅斯小姐的天啟所言，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感覺就像是做了白日夢吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "順便一提。",
        "unit_id": 105913,
        "voice": "vo_adv_1059004_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們剛剛吃完飯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在兩人正在回旅館的路上喔。",
        "unit_id": 105913
    },
    {
