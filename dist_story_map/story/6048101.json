    {
        "type": "dialogue",
        "name": "依里",
        "words": "這、",
        "unit_id": 113811,
        "voice": "vo_adv_6048101_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這是怎麼回事啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n明明說會實現願望的，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這不是只有身體變了嗎？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那孩子",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "到底想要做什麼啊……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "蘭德索爾這地方",
        "unit_id": 113811,
        "voice": "vo_adv_6048101_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然有很多怪人，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n但是她",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "特別神秘啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只不過，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "卻也是個讓人無法討厭的孩子呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n感覺像是",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "非常需要照顧的妹妹吧？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你認識的人裡面",
        "unit_id": 113811,
        "voice": "vo_adv_6048101_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好像有個很愛惡作劇的孩子吧？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "像是這套衣服",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就做得很用心呢，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是不是和那孩子有什麼關係……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不可能有那種事吧？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才沒有呢！",
        "unit_id": 113811,
        "voice": "vo_adv_6048101_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要說這單純只是小孩子的惡作劇……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "感覺也不太一樣呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然很不可靠，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但她確實",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是很認真的吧？",
        "unit_id": 113811
    }
]