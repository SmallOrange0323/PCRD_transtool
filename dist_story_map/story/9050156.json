[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下吃飽了。",
        "unit_id": 105913,
        "voice": "vo_adv_9050156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肉和蔬菜",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的都非常美味。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也請主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盡情享用……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位，",
        "unit_id": 105812,
        "voice": "vo_adv_9050156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "飯後甜點時間到囉～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所謂的甜點……",
        "unit_id": 106012,
        "voice": "vo_adv_9050156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是指妳手裡那個",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "淡粉紅色的玩意？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來是冰冰涼涼的沒錯，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是又不像冰淇淋……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那是什麼啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿～♪",
        "unit_id": 105812,
        "voice": "vo_adv_9050156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是剛剛那隻魔物的花瓣！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然被它的本體逃走了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但我先奪下了花朵部分！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "它的肉質厚實又香甜，",
        "unit_id": 105812,
        "voice": "vo_adv_9050156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我拜託小雪菲",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n把它做成了雪酪！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快趁融化前一起吃♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我處理得讓它看上去是像普通的雪酪沒錯……",
        "unit_id": 106412,
        "voice": "vo_adv_9050156_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "材料是魔物耶……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……提",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "提起勇氣，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只吃一口看看好了……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 106412,
        "voice": "vo_adv_9050156_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……好清爽而溫和的甘甜味……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太好了！",
        "unit_id": 105812,
        "voice": "vo_adv_9050156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留要不要試看看？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冰冰涼涼的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常好吃哦☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既、",
        "unit_id": 106012,
        "voice": "vo_adv_9050156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然妳都這麼說了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就沒辦法啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊呣……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_9050156_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "配得上妳的推薦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "味道確實不錯。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……在這沙漠裡",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真想不到還吃得到冰涼的甜點呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要不去思考材料來源就……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 105913,
        "voice": "vo_adv_9050156_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也請享用……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這可說是沙漠的恩惠呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃",
        "unit_id": 105812,
        "voice": "vo_adv_9050156_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……{player}你怎麼了？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼突然抱著頭……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下，",
        "unit_id": 106012,
        "voice": "vo_adv_9050156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你還好嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會說……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "做雪酪用的花瓣",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有毒是嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n快點吐掉！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105913,
        "voice": "vo_adv_9050156_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這真是太糟糕了……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得馬上使用恢復魔法……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "先別急。",
        "unit_id": 106412,
        "voice": "vo_adv_9050156_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你剛剛嘴裡塞滿了雪酪對吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會不會是突然吃下太多冰涼的食物後，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n突然感到一陣頭痛那種啊！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 106012,
        "voice": "vo_adv_9050156_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……就只是這樣？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……看來",
        "unit_id": 106412,
        "voice": "vo_adv_9050156_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就只是那麼回事呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼嘛，",
        "unit_id": 106012,
        "voice": "vo_adv_9050156_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "害我白擔心一場。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別嚇唬人好嗎，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "受不了耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人。",
        "unit_id": 105913,
        "voice": "vo_adv_9050156_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算再怎麼好吃，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也絕對不能一口氣",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吃下那麼多冰涼的食物。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "反正還有很多，",
        "unit_id": 106412,
        "voice": "vo_adv_9050156_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "別著急慢慢吃吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的！",
        "unit_id": 105812,
        "voice": "vo_adv_9050156_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不慌不忙，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起多吃點吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}也一起……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊──☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都說別一口氣吃太多了，",
        "unit_id": 106012,
        "voice": "vo_adv_9050156_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n幹嘛還塞那麼大一口給他啦──！",
        "unit_id": 106012
    }
]