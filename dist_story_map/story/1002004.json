    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──主角一如往常，\n和優衣一起修行。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，辛苦你了呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你今天也和我一起修行。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "請等一下。其實我的腿剛才不小心受傷了……",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "馬上就能治好的，沒關係呦。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該不是這麼強力的魔法呀……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "光芒變得越來越刺眼……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這、這是怎麼回事……！",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──這個號碼的座位是……",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這裡呀。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（上高中後第一次交換座位……",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和真琴的座位離得遠遠的呀……）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（雖然有點緊張，",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果能和附近座位的人變成好朋友就好了呢……）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（如果可以的話希望是他……開玩笑的，",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這麼巧合的事情，怎麼可能發生呢）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（啊！隔壁座位的人過來了！要好好的打招呼！",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "先冷靜一下……不要慌張，只要慢慢說話就沒問題……）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "請多多指教啊",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……咦？",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你怎麼會在這裡……？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是這樣呀！？",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……是喔，是這樣呀。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……真不好意思。",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為我很怕生，所以很高興能和同一間中學的人一起坐……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "今後請多多指教呢。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（我可沒有說謊呢……",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……雖然真正感到高興的原因，是能坐在你隔壁這一點）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（為了不浪費這機會，我得努力多搭話攀談才是！）",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那、那個……！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃……",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "今天天氣不錯呢！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n還有少許櫻花……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真美麗啊……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……沒事了！",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n抱歉打擾了……！",
        "unit_id": 100231
    },
    {
        "type": "background",
        "background": "510221"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（嗚嗚……",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "結果還是因為緊張，完全沒有好好說到話呀……）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（差不多該回家了呢……",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "至少，要打聲招呼才行呀……）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……明天見呦。",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然今天說了些奇怪的話，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n請你不要在意……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就這樣！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……？你太客氣了！",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我才想要謝謝你，今天願意聽我說話呢。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……因為在中學時期，都沒有好好地和你說過話呀。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那個，如果可以的話，",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n明天開始，也能像今天一樣和你閒聊嗎……？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝……今後也請多指教呢。",
        "unit_id": 100231,
        "voice": "vo_adv_1002004_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那，我就先告辭囉！",
        "unit_id": 100231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊哈哈～！",
        "unit_id": 190011,
        "voice": "vo_adv_1002004_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "　太有趣了～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "　這是我給你的禮物！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛才，",
        "unit_id": 190011,
        "voice": "vo_adv_1002004_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是我依照你和優衣的『記憶碎片』所創造，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n由我特製的『夢』喔，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是『夢』呢！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有沒有嚇一跳呀？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過呀，優衣真是對你……",
        "unit_id": 190011,
        "voice": "vo_adv_1002004_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……說得太明白就沒意思了，就此打住吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼嘛！那種程度的事情你該自己察覺呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1002004_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "優衣怎麼會對你這樣的人……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的『記憶碎片』，",
        "unit_id": 190011,
        "voice": "vo_adv_1002004_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做『夢』的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和許多女孩在一起的『夢』做得越多……",
        "unit_id": 190011,
        "voice": "vo_adv_1002004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就可以藉此還原世界的真實面貌。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……這裡是？",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……對了，剛才治療腳傷時突然覺得光芒刺眼……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "傷口呢……已經痊癒了呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。我們兩人，到剛剛為止都是在一個從沒看過的地方對吧？",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n是一個像學校的地方，那會是我的錯覺嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果可以像剛才那樣，和騎士先生一起讀同一間學校的話，",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "肯定是非常快樂呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然像現在這樣一起修行也十分愉快，",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但很想試試兩人一同在放學後到哪裡去遊玩的體驗呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛、",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛才的是以作為同班同學的身分來說的！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不、不是指想成為朋友或戀、戀人的意思……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對！是指作為夥伴，想一起嘗試各式各樣的新鮮事呀！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……無論是開心的時候，或是傷心的時候，都希望能一同面對呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002004_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以，如果有什麼事情歡迎隨時與我分享呦。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我呀，會靜靜等待的……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
