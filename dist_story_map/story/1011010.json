        "voice": "vo_adv_1011010_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "結果卻跑到滿遠的地方來了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n從地圖上來看，",
        "unit_id": 101112
