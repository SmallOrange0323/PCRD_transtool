    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與璃乃為了尋求素材\n而前往魔物的棲息地。"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "本來是想趁準備考試之餘來放鬆一下，",
