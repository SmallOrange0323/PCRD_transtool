        "type": "dialogue",
        "name": "璃乃",
        "words": "還以為是更鄰近的地方……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒想到必須繞過山路才來得了……",
