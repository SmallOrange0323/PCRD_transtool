    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美咲在某棟建築物前，\n苦惱地來回徘徊。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我一個人進去還是會很突兀吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一定會被",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "投以異樣眼光的。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但是，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "身為一位成熟的淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我很想參加一次看看……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n因為",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總有一天、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我會和某人發展成那種關係也說不定……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哎呀？",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在那裡的人是……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "{player}。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對了。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想到一個好主意了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果是那傢伙的話……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "外表也不算差，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "找他或許不錯喔♪",
        "unit_id": 105011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "喂，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我有點事要找你。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你現在",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很閒吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你一定",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很閒吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你等一下",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "跟我去一個地方！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "現在開始我們兩個人……",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要出門去參觀",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "結婚會場喔♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼啦，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼一副啞口無言的表情。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什、",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你問什麼時候簽了結婚同意書！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是嗎！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是笨蛋嗎！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n誰、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "誰在說是要和你結婚啊……！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你不要誤會了！",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我只是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "參加了觀摩結婚會場的抽獎活動！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n然後，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就碰巧抽中了而已！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為你看嘛，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "像我這般如此有魅力的",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "成熟淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可不知道何時",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "會有人來向我求婚喔？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以就是為了這樣要去觀摩。",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還有就是……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "結婚會場是什麼樣的地方，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我很想",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "去一次看看。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "當、",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "當然啦，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就是那個啊？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然想和我一起去",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "參觀婚禮的男人多的是，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但很不巧的今天",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "剛好沒有人有空！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果是你的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "應該說你比起",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "其他人稍微好一點……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "或者是說你也不錯啦……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總、",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總之！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我准許你和我一起去，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n但你可千萬別誤會了唷！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "吵死了！",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我可是在邀請你喔！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你就心懷感激地",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "跟我去吧！！",
        "unit_id": 105011
    },
    {
        "type": "still",
        "still": "105000601"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哇──",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好～棒！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒想到，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "居然還能穿上婚紗！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "裝飾的花朵",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也可愛極了，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n彩繪玻璃也",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好漂亮♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊～",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "婚禮真的會讓人很憧憬呢♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而且這個會場的大小",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也很剛好呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想我",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "最少也要請、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一百位……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不對，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要請兩百位賓客！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "吶，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果是你的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你想辦什麼樣的婚禮？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呵呵，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你的想法和我一樣呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我的夢想",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也是想要邀請眾多朋友來，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n舉辦一場盛大的婚禮呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊……",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_021"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "和你結婚的人，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "或許會有點可憐。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你啊，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "其實頗受女孩子歡迎的吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n邀請參加結婚典禮的朋友",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "或許都是女孩子……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊～啊，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你的新娘好可憐。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你啊，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為什麼會那麼",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n受女孩子歡迎呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是不可思議呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……原來如此。",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_024"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n不同人會有",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不同的想法呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_025"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你很珍惜家人這一點，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n頗有大人風範，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我覺得不錯。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說回來，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_026"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "結婚典禮果然很美好呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n真的令人好憧憬。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "吶，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你來一下。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你要不要試試看來站在我旁邊？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "接下來",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_028"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是婚禮預演喔。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "像我這麼有魅力的淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "何時會結婚都不奇怪，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n所以我必須先做好心理準備吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來吧，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "首先是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雙方互戴戒指。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "然後接著是，",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_030"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "誓、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "誓約之吻……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "欸！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_031"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你的臉為什麼真的靠過來啦！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "笨蛋、笨蛋、笨蛋！！",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n夠了，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "預演結束了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚……",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n雖然說是只預演，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但男生的臉",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "靠得那麼近……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒、",
        "unit_id": 105011,
        "voice": "vo_adv_1050006_034"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒事啦！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們要回去了，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "笨蛋！！",
        "unit_id": 105011
    }
]