[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦囉。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "忙到大半夜的，還真苦了你呀。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，在千鈞一髮之際算是逃出了險境呢，太好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……我就只能在這看著，總會讓人冷汗直流呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "言而總之。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你這次",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是遇到可怕的怪奇現象了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "姑且先補充一下……",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在那之後，你們全都安全地逃了出去，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並成功與咲戀她們會合，且接受了她們的保護，所以就安心吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來，終於可以稍微休息了一下啦。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，算是可以鬆口氣了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，於隔日一早整理寢具時，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也同時接受了咲戀的『某個請求』……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在那之後，不知道怎麼搞的得獨自爬山就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過嘛，現在就暫不多說了。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這是之後，不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是等你醒來後，再好好去享受吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "比起這個。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在你們所遭遇到的怪奇現象才是問題唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最近在這個世界中，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n發生了許多無法用常理說明，可說是相當不可思議的現象。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且，這些事正逐步威脅著人們和平的日常唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算是你，大概多少也聽過這些事了吧？",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在那些怪奇現象之中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n較有名的就是『闇影』和『消失』了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所謂的『闇影』，就是這一次，你們所遭遇到的傢伙唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是宛如鬼怪一樣，奇妙的存在……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "普遍來看，多被歸類為魔物的一種呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而到了最近，『闇影』的被目擊情報急遽增加了許多呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "基本上雖看起來令人害怕，但大多是無害的樣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，也有少數人類被襲擊的案例。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就像是，這次你們遭遇的事情一樣呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而這又是個不知來頭的存在呢，似乎連生物都稱不上。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被刀劍砍傷時不會流血，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也不用吃不用睡，就只是個無止盡地到處徬徨徘徊的存在呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，乍看之下還是讓人頭皮發麻……",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n『闇影』好像也會和真實存在的某個人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有著一模一樣的外貌的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對被『闇影』，模仿的本人來說，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可能也無法坐視不管了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次你們所遇上的，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是和綾音與咲戀長得一模一樣的『闇影』呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就連聲音，都幾乎一模一樣吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那種東西，在各地大量冒了出來。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明不該存在於這個世界上的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n竟不知為何的不計其數地出現了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而相反的，這世界上也剛好有什麼消失了的情形。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一種怪奇現象，則被稱為『消失』呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一般來說，無論是誰都會擁有雙親呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當一對父親與母親相愛並且結合，而產下了孩子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是自然界中的定理，是人類……不，是哺乳類的基礎呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不知道為什麼，卻發生了很多無法確認某些孩子的雙親的存在的事件唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而這件事，就是被稱為『消失』的怪奇現象唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有些人類彷彿打從開始就不存在一般，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就這麼樣消失了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論是被當成戶籍的公會所屬記錄，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還是那人們之間的記憶中，有些人就這麼消失了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若只是單純記錄上的消失不見，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還能以是單一文件的缺失等等來說明。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但卻就連在記憶之中，也都消失了。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明只要是孩子就一定會有雙親，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但對父母的記憶與紀錄，卻全都不見了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "必然該存在的事物，卻不存在。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以『消失』這種現象才會為人所知唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而沒有父母，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就連記錄和記憶也沒有的孩子們，就這樣繼續生活下去了呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一般來說會覺得很奇怪吧？",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但不知道為什麼，誰也沒有因此感到疑惑。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而從『消失』這個現象開始被認知，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n且開始進行調查以後……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被判定不自然消失的人們，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻又被確認存在了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若只是一兩件的話，也許還能解釋。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能以雙親捨棄了孩子並且鬧失蹤，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n甚至周全地把記錄也徹底消除。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "且孩子，也因為傷心而在記憶上出現了障礙之類的來做為解釋。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但若這種事件出現了數百件以上，只能說是怪奇現象囉。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這就是──『消失』……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而和你感情還算不錯的那位胡桃，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像也是因為這種奇妙的現象而找不到雙親呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管是『闇影』還是『消失』，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "至今無論是誰都沒辦法提出明確的解釋，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是謎一般的現象。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其他還有不少尚未被發現，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但也可說是怪奇的現象正在各處發生唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而這些怪奇現象的原因，我是明白的。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為這個世界受到扭曲、病了，所以變得奇怪喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論『闇影』還是『消失』，都是因此而產生的漏洞唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是世界不自然的扭曲狀態下，所造成的副產物，或該說是壞影響呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，若不去導正這世界的扭曲，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不管是『闇影』還是『消失』都無法徹底解決。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "胡桃，也將永遠見不到自己的雙親……",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，是依舊連想都想不起來呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若是這樣，不覺得很可憐嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明是位這麼善解人意的乖孩子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然如此",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那就由你來，將這個世界的扭曲導正吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能夠達成這件事的鑰匙，就散落在你的周遭唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將它們，一把一把的給收集起來唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後把世界之謎給解開，將扭曲的原因給徹底去除。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是徹底去拯救這個世界唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這件事，大概只有你辦得到呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我對你抱著很大的期待，也會支持你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油吧，",
        "unit_id": 190011,
        "voice": "vo_adv_2003010_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "主人公……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "過去曾拯救世界的英雄—{player}。",
        "unit_id": 190011
    }
]