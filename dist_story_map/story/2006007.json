[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後……\n{player}一行人搭上了智準備的馬車，\n非常順利地抵達了牧場。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呼。",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這次順利地，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n連爆炸之類的狀況也沒遇上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就搭著馬車到達目的地了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此一來就放心了。",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是這麼常遇到爆炸，也很讓人困擾就是了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總覺得小可蘿妳們人生，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n處處都充滿著刺激呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是{player}所說的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n果然和平還是最好的呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……如果有什麼煩惱的話，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n隨時都能夠和我聊聊哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽了我說的話以後，沒有嘲笑我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且還願意相信我。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n光是這樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就讓我感到很開心了……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵呵～、",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n朋友真是很棒的存在呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以請您別從背後抱上來好嗎，",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那沉重的肉團放在在下的頭上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總覺得十分的屈辱。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我最近胖了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為使用『皇家裝備』還蠻消耗卡路里的，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我就想說沒有減肥的必要，想不到竟然大意了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只不過……",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【伊麗莎白牧場】看起來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n已經差不多恢復原本的面貌了呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就好像是，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n未曾受到魔物襲擊過一般呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不。",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這附近的草叢及樹木，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到處都有燒焦及倒落的痕跡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與其說從未曾發生過魔物襲擊的事實，",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n倒不如說",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的恢復速度太過不自然了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然說，",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並非所有東西都已恢復原樣了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但能回到比想像中還要和平的狀態，",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為應該就沒問題了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家臉上的表情",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也都很開朗呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是堅強呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n牧場的人們。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不好意思插個話。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我待會得多次往來於城鎮與牧場之間",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n進行搬運物資的工作才行。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以暫時",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "得先失陪了哦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然在馬車上，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n有稍微聊到了一些狀況……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但希望之後還有機會",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n約個時間來交換各種情報呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n到時候我也會先預約好餐廳的哦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還真是讓人期待！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我聽說有一間高級餐廳，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是只有在王宮內工作的人才能夠進去的……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊……",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "與其說是在王宮內工作的人，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n應該說只有貴族才能進去。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我也只是庶民出身，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n想預約到那間餐廳應該蠻困難的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會盡量試試看的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真讓人期待～。",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝妳，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳能用馬車把我們送到這裡來，真是幫大忙了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來在【王宮騎士團】裡，\n也是有好人在呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就是為了能讓大家都這麼想，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我和純對此都一直努力著。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "無論怎麼說，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們都是『正義的夥伴』呢，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n對於牧場的重建作業，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也會盡最大努力幫忙的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也是這麼想！",
        "unit_id": 100511,
        "voice": "vo_adv_2006007_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　我會好好幫忙的～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n小智姐～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "謝謝妳。",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但說真的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我也很不希望讓像妳這麼小的孩子也來幫忙。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過人手實在不足，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這也是不得已的呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為克莉絲提娜被關到監獄裡，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以她那派的人馬全一起叛變了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【王宮騎士團】的戰力，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n幾乎可說是減半了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n克莉絲提娜就是那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺很華麗，又很厲害的那個人嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她人也在我被捲入的那場",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大爆炸之中……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來她平安活下來了啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我覺得她\n是那種想殺也殺不死的人就是了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但被逮捕又是怎麼回事？",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "做了什麼壞事嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊……",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不好意思，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n詳細狀況無法和非相關人士說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉哦，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_037"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們是個有不少",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n機密事項和特別規矩的公會。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果很在意的話，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就雇個情報商，自己著手調查吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "克莉絲提娜阿姨被逮捕了，",
        "unit_id": 100511,
        "voice": "vo_adv_2006007_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這就表示",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她是一個壞人對吧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我從以前就覺得很奇怪了，",
        "unit_id": 100511,
        "voice": "vo_adv_2006007_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n光看她那副樣子就知道了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "以貌取人是不好的哦，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_041"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我也不認為\n她是個好人就是了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為要逮捕她的時候，她大鬧了一番，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_042"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以讓我們的戰力更加被削弱了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "造成連像我這種半調子……",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_043"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還有茉莉這種見習生，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n都得出動的事態。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "現在可不是個適合援助其他公會的情況呢，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_044"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "老實說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果現在王宮發生了什麼事，可能根本就無法處理。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_045"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只要有純在，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也沒這麼容易攻進城就是了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔嗯……",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也就是說想潛進王宮裡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "解決那個『冒牌貨』的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在是個絕佳的機會是吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我好像不小心說溜嘴了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我話先說在前面哦，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_048"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n說到底，我們公會本來的目的就是守護王宮。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要是妳們想對王宮出手的話，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_049"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n勢必會再兵戎相向。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "屆時我是不會放水的哦。",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_050"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可別以為今天看見的那些，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就是御久間流的所有招式了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的好的。",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我不會做些太超過的事情。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟我也不想和乖孩子戰鬥呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使腐敗但仍是王宮……",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n想必戒備很森嚴吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n若真要出手時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也得做好相對應的準備才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起這個，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳不趕快出發沒問題嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n馬車的馬夫，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都等得不耐煩在抖腳了哦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_054"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感謝忠告。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來是我太過享受",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n和年長的人一起聊天了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "走吧茉莉，",
        "unit_id": 103711,
        "voice": "vo_adv_2006007_055"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還有很多事情要忙呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好的！",
        "unit_id": 100511,
        "voice": "vo_adv_2006007_056"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "當大家遇到困難，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就是英雄應該登場的時候！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……走掉了。",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩位都是很特別的孩子呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該說是很不像\n隸屬於【王宮騎士團】的人呢還是…",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過她剛才也提到自己是庶民出身了嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n接下來該怎麼辦呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得先去找那位咲戀小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n告訴她我們平安無事對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牧場的人應該也很擔心才對呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟她們可能以為",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們失蹤了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得趕快讓她們看見我們有精神的樣子，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓她們放心才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟經歷了牧場被魔物襲擊，心情應該很低落才對，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想為她們帶來一些好消息呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "？",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛才在馬車裡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是坐著休息很久了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}真的很貧弱呢，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不多鍛鍊一點可不行哦～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "打起精神一起過去吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難不成，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你那是在指想去廁所之類的意思吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對、對不起我都沒有注意到！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我這樣可不行啊～",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n神經怎麼",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼大條。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～……",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總而言之我們雖然已經在找咲戀小姐了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但都找不到呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她會在哪裡呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牧場如此遼闊，",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_068"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來往的人也都參雜在一起……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣找起來",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在是很辛苦呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是能遇到認識的人的話，",
        "unit_id": 105913,
        "voice": "vo_adv_2006007_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就能詢問她可能會在的地方了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哼哼哼～♪",
        "unit_id": 105211,
        "voice": "vo_adv_2006007_070"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不好意思，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "借過一下哦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我要通過了～！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 105812,
        "voice": "vo_adv_2006007_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個又白又毛茸茸的人……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喂～，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我記得妳是【伊麗莎白牧場】的人吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？",
        "unit_id": 105211,
        "voice": "vo_adv_2006007_072"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n啊，{player}！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n旁邊那位是叫做貪吃佩可對吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太好了～，",
        "unit_id": 105211,
        "voice": "vo_adv_2006007_073"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳們也都平安無事啊？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "聽說妳們下落不明，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們很擔心呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
