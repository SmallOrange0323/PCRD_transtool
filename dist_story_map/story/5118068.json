    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]就連七七香這樣很懂分寸的宅宅，",
