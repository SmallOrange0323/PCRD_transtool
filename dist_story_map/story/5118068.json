        "voice": "vo_adv_5118068_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]隨時都可以……！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n聽到這種話會害人家不小心當真！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]會想連續好幾天都來找妳！",
