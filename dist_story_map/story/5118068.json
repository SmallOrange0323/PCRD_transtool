    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]等等，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]這手套好長！",
