        "voice": "vo_adv_5118068_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]愛──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]妳的反應很不錯呢♪",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_022"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哎呀，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]差點忘記一件重要的事！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]七七香，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]和我握手吧！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]這是初次見面的招呼唷！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]我我我",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]我很樂意！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n請稍等一下，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
