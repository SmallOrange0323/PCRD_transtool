    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]{player}，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]幫我脫一下手套～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]幾分鐘後──"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]哎呀～",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]真的是感激不盡！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n多虧有妳，我現在精力飽滿！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
