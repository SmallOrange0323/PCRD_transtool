        "voice": "vo_adv_5118068_025"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n用不著那麼做，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]只要再來和我握手就好了呀！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]歡迎妳隨時再來見我唷♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]隨、",
