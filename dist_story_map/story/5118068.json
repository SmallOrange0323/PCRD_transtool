    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]碧卡拉美眉根本是大放送呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n連對我的錢包都這麼親切，反而會令人過意不去啊～～！",
