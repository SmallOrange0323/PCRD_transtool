    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]某一天，正當{player}帶著碧卡拉"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n在蘭德索爾的大街上逛時──"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_000"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n這裡望過去的景色很不錯呢！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]可以將蘭德索爾的城鎮一覽無遺！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]原來{player}知道這麼棒的地點呀。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]而且……",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_001"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗯，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]這裡和鎮上比起來，清靜多了。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n很適合想要靜下來思考的時候呢♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那當然囉！",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_002"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]就讓我把這地點追加進",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我腦內的蘭德索爾觀光地圖中吧！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哪天真的出版來販售好了？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]………………",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]哈哇！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗯？",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_004"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那個，我問你喔？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n對面有個人一直緊盯著這邊看……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是你認識的人嗎？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]…………",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]不不不不……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]咦？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]不不不不，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]不可能不可能……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]對、",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_006"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]對方一邊唸唸有詞一邊快步逼近了喔！？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n而且身體幾乎沒有因此產生起伏啊！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]她是你認識的人吧？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]拜託快說你認識呀！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]當真嗎、",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]這真的是現實嗎……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]也就是說，真的真的…………",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]如果是那樣，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]糟糕不行了，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]要去了要去了……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]呃、",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_008"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那個……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗨～♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]──",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]是真正的鼠耳巫女啊──────！！",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_010"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]咦？",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]沒想到竟能在蘭德索爾路邊這種地方",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]遭遇到東國的巫女，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]噢呵，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]就算跟今天早上的七七香說這件事，她肯定也不會相信吧……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]吞口水……",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]這、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]這就是傳聞中的巫女裝嗎……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]啊啊，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]果然不是角色扮演啊……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]是真正巫女的真貨服裝啊。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]這個神聖感，和以前我曾經",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]弄到手過的劣質品根本不能比……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]雖、",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_014"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]雖然妳好像自己講得很開心，但可以打擾一下嗎？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n妳的名字……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是七七香沒錯吧？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]嗚吱！",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]不對，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]沒錯！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]我太過興奮，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n[FFFFFFFF]差點變成最可愛大猩猩啦，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]啊哈哈！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]果然是這樣嗎。",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_016"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗯，我稍微放心一點了。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]讓我做個自我介紹吧！",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_017"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我是碧卡拉！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]妳的推理沒錯，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我是東國的巫女喔！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]妳有聽說過鼠神宮嗎？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]嗚喔──",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]鼠神宮！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]來啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]我知道，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]當然知道！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n是守護著東國北方的",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]超靈驗又能帶來好運的神社對吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118068_019"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n原來妳知道的還不少嘛！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n謝謝妳，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我很開心唷！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]噢",
        "unit_id": 101311,
        "voice": "vo_adv_5118068_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]呼！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n這、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]這衝擊力真是不得了……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]這種撼動宅宅內心的",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]心跳加速感受……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]沒錯！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "[FFFFFFFF]那就是，",
