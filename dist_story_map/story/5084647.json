[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是啊，",
        "unit_id": 105111,
        "voice": "vo_adv_5084647_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那孩子還沒有醒呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "身為醫生和科學家，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我對這個狀況束手無策，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n還真讓人痛心呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "若是從前的我，明明會因為發現有意思的病症而興奮的，",
        "unit_id": 105111,
        "voice": "vo_adv_5084647_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在卻不可思議地沒有那種感受。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "被稱作「獨眼惡魔」的我居然會拋下研究，",
        "unit_id": 105111,
        "voice": "vo_adv_5084647_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n而是先去擔心他人。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……真沒辦法，",
        "unit_id": 105111,
        "voice": "vo_adv_5084647_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來開發使人甦醒的藥吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n畢竟實驗品一直在睡覺，真的很困擾啊。",
        "unit_id": 105111
    }
]