[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到普拉諾平原野餐的雷姆、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n──以及"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩個男生。"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "好寬闊！",
        "unit_id": 2711,
        "voice": "vo_adv_1097006_000"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "適度的高低差！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "而且還有瀑布！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n這景色真讓人興奮啊！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這比起野餐，",
        "unit_id": 2711,
        "voice": "vo_adv_1097006_001"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "更像是要展開冒險吧！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n天氣也很好，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "真是棒透了。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n我的少年心久違地蠢蠢欲動啊。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "哦，",
        "unit_id": 2711,
        "voice": "vo_adv_1097006_002"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "馬上就要來賽跑了嗎？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n可別小看還滿認真的",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "前劍道社員的雙腿喔～！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……哇！",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很危險耶！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n又不是小孩子了別在那亂跑啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真是的。",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他們興奮過頭了吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人跟昴先生",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經變得這麼要好了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為羅茲瓦爾大人的宅邸裡大多是女性。",
        "unit_id": 109711,
        "voice": "vo_adv_1097006_006"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n對昴來說，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "同年齡層的男性友人是很珍貴的。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我想",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "他一定覺得很高興。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然……",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這個樣子啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也是一樣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然認識的人很多，",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但說到同性的友人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n除了昴先生以外",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就幾乎沒有了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "原來如此……",
        "unit_id": 109711,
        "voice": "vo_adv_1097006_009"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這樣看來，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "他們對於彼此都是很寶貴的存在呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那麼……",
        "unit_id": 109711,
        "voice": "vo_adv_1097006_010"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "咳咳。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆要再次，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請妳們今後",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "也多多關照昴。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下才要請兩位多多指教。",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n希望能與主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "長久地友好相處。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……欸、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸欸。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們這是什麼，",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽起來像媽媽友人間的對話。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我聽著聽著",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺身體都癢～起來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "媽媽……？",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這怎麼敢當呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "乃是服侍主人的隨從。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n像這樣的稱呼，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在太僭越了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆也跟可可蘿一樣。",
        "unit_id": 109711,
        "voice": "vo_adv_1097006_016"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "只要昴他能夠開心就好了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是嗎。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "差不多快到中午了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要來準備用餐了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天的便當",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是特別精心製作的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是放入很多主人喜愛料理的得意之作。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然主人不管什麼料理",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都會好好吃完不挑食……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但如果有放入蝦子小香腸的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人會特別高興。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "除了之前教雷姆的那些以外",
        "unit_id": 109711,
        "voice": "vo_adv_1097006_021"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "居然還有這種形狀……！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這樣子……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "感覺昴應該也會很開心呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那個",
        "unit_id": 109711,
        "voice": "vo_adv_1097006_022"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "「蝦子小香腸」",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "的作法，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n下次也能教教雷姆嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然沒有問題。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的話，不知道能否稱作交換，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下學習雷姆小姐的料理食譜──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說……",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈囉哈囉？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "熱衷於媽媽友人間的對話，根本沒聽到我在叫她們……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是說，",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "寵溺成這樣連看的人都覺得不好意思了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們兩個",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的是，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有夠像的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雷姆、可可蘿",
        "words": "…………！",
        "unit_id": 1,
        "voice": "vo_adv_1097006_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們兩個，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼表情突然變得這麼嚴肅。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有什麼東西要過來了……",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_028"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……！",
        "unit_id": 109711,
        "voice": "vo_adv_1097006_029"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "在那個方向！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "過來？",
        "unit_id": 106012,
        "voice": "vo_adv_1097006_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n咦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼什麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是什麼東西！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1097006_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昴先生！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請待在那裡不要動！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "咦？",
        "unit_id": 2711,
