    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呀啊啊？",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真討厭，今天的風真大呢！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "糟糕，本來打算邊走邊檢查文件……",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "重要的文件卻被強風給吹走了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我這樣不行啊～ ",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明凡事都必須講求效率，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因此打算善用移動時間的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是就這樣弄丟了文件，我還得重新做，",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n反倒失去效率了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來我也沒有資格說鈴莓，和她一樣脫線呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "文件上還記載了個人資訊，",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以不能放任文件被風吹著到處飛……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "必須找回來收好才行。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉唉，又得多花一些時間，",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是又不得不做。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n等一下……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那邊的先生，有事嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你在這種地方做什麼？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡是國王陛下居住的王宮哦，一般人禁止進入。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在這裡悠閒地散步可是會被衛兵逮捕的哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是受不了，",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【王宮騎士團】到底在做些什麼……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "警備太鬆懈了嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過最近這裡很和平，說不定是因此放鬆了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但要是陛下有個三長兩短，那就會演變成國家大事了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉……雖然我和【王宮騎士團】已經分道揚鑣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n說實在這都和我沒關係了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但也不能坐視不管嘛。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，我還得把文件找回來才行。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拿在手上的是……文件？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那、那些！",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是我的！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我正好在找呢，是你幫忙撿起來的是吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝，剛好省下找的時間。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": " ……你看到了嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯…… ",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看起來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你才剛撿到文件的樣子呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對你有點抱歉。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過你能把文件翻到背面再交給我嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "上面記載了個人資訊，",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以不太想讓毫無關係的第三者看到。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也不想太為人所難，",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是你直接了當給我就幫上大忙了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什、什麼？",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n內褲？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在說什麼呀，下流！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算風再怎麼強勁，",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不讓裙襬飄起可是淑女的訣竅！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我可是很小心的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你沒有……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看到對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真討厭，明明是初次見面，還真是沒禮貌的人呢？",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算、算了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你能把文件交給我嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，謝謝。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話說回來，文件還放在信封裡呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好，裡面的文件也沒事。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼一來似乎就沒有問題了，我也不用再花時間重寫♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你的幫忙。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你叫什麼名字？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我現在非常忙……",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "過幾天會再向你道謝的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能不能告訴我，你有沒有加入哪間公會？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯哼。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n名字是{player}？\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還沒有找公會加入？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你是不是來自別的國家呢？",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在蘭德索爾如果沒加入公會，做什麼都不方便哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果不知道如何登錄，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就當作答謝，我是可以教你喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，不過這也得改天再……",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我還得趕時間，就先走囉？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有給你一個忠告，",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在這裡會被人當作可疑人物的……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n最好不要在王宮附近閒晃哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉呀。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "失禮了，我也得報上名號。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我叫咲戀。",
        "unit_id": 102811,
        "voice": "vo_adv_1028001_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n擔任公會【咲戀育幼院】的公會長。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有緣再會吧……{player}♪",
        "unit_id": 102811
    }
]