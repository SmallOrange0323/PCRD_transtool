[
    {
        "type": "background",
        "background": "500334"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "根據{player}的主意，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人前往遠離蘭德索爾的各個村莊展開兜售。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "靠過來",
        "unit_id": 119211,
        "voice": "vo_adv_5080003_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看過來，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "正於蘭德索爾舉辦的",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "聖誕節甜點大賽參賽點心，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n來巡迴販賣啦～",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我們帶來了很多可口的點心喔。",
        "unit_id": 7912,
        "voice": "vo_adv_5080003_001"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n請務必過來看看。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "…………",
        "unit_id": 119911,
        "voice": "vo_adv_5080003_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好了，",
        "unit_id": 119311,
        "voice": "vo_adv_5080003_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "宮子。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n別一直賭氣了，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "打起精神叫賣吧。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n妳不是都吃好多布丁了嗎。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是……",
        "unit_id": 119911,
        "voice": "vo_adv_5080003_004"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "哎呀，",
        "unit_id": 411,
        "voice": "vo_adv_5080003_005"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "看起來很好吃呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "\n那我買",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "這個巧克力蛋糕好了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳真有眼光！",
        "unit_id": 119311,
        "voice": "vo_adv_5080003_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這家店的巧克力，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n以取自於可可亞烏拉這種魔物的",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "特殊可可亞",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "製作而成，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n非常好吃喔！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "啊，",
        "unit_id": 411,
        "voice": "vo_adv_5080003_007"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "我好像有聽過。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "\n連這麼少見的東西，在蘭德索爾也有普通在賣啊……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "並不普通喔。",
        "unit_id": 7912,
        "voice": "vo_adv_5080003_008"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這是這家店講究的特色。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "如果妳喜歡的話，",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "來蘭德索爾的時候",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "請再去",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "購買吧。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "好的，",
        "unit_id": 411,
        "voice": "vo_adv_5080003_009"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "謝謝！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "婆婆",
        "unit_id": 119911,
        "voice": "vo_adv_5080003_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不賣自己的點心，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n只顧著推薦別人店裡的點心。",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子不明白這麼做有什麼意思。",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唉，我也理解宮子的心情就是了。",
        "unit_id": 119311,
        "voice": "vo_adv_5080003_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當老婆婆說出",
        "unit_id": 119311,
        "voice": "vo_adv_5080003_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要盡可能將",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "參加比賽的其他店家的點心",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一起帶來的時候，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也覺得",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很困惑呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "抱歉，",
        "unit_id": 7912,
        "voice": "vo_adv_5080003_013"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "要大家接受我",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "任性的要求。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我心想既然要去遙遠的村莊，",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n那我想把蘭德索爾的慶典氣氛",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "也一起帶去。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真的！",
        "unit_id": 119911,
        "voice": "vo_adv_5080003_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n明明好不容易獨占了客人，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "全都泡湯了！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～",
        "unit_id": 119311,
        "voice": "vo_adv_5080003_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果只考慮比賽，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n宮子的想法",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "應該是對的，但是……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "哎呀～",
        "unit_id": 1,
        "voice": "vo_adv_5080003_016"
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "沒想到你會帶這麼棒的伴手禮回來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "村民3",
        "words": "有好多只在傳聞中聽過的名店甜點！",
        "unit_id": 1,
        "voice": "vo_adv_5080003_017"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哎呀，",
        "unit_id": 4911,
        "voice": "vo_adv_5080003_018"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這真的是巧合的結果。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n應該要感謝的是他們幾位，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n願意特地過來這種鄉下地方啊。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為大家看起來都很開心，",
        "unit_id": 119311,
        "voice": "vo_adv_5080003_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓我覺得",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有這樣做真好。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家一點也不懂好在哪裡！",
        "unit_id": 119911,
        "voice": "vo_adv_5080003_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n沒贏得勝利就沒有宣傳效果喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不不，",
        "unit_id": 119211,
        "voice": "vo_adv_5080003_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "像這樣巡迴各種地方也是",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "很好的宣傳啊。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就是先混個臉熟，讓人對點心味道留下印象",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且妳沒注意到嗎？",
        "unit_id": 119211,
        "voice": "vo_adv_5080003_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n老婆婆的點心的銷售情況，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比起在蘭德索爾的時候賣得好喔？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是嗎……？",
        "unit_id": 119911,
        "voice": "vo_adv_5080003_023"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "但如果是那樣，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒有其他點心應該會賣得更好喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這",
        "unit_id": 7912,
        "voice": "vo_adv_5080003_024"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "很難講。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我的點心並不華麗，",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n如果只有我的點心，",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "大概賣不出去吧？",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "感覺華麗的點心與樸實的點心",
        "unit_id": 119211,
        "voice": "vo_adv_5080003_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在互相襯托，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n相得益彰呢。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在像蘭德索爾那種華麗的氣氛中，",
        "unit_id": 119211,
        "voice": "vo_adv_5080003_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n無論如何都會是",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "花俏的東西更暢銷，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但在這樣的地方兜售，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搭配起來就變得剛剛好啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……啊！？",
        "unit_id": 119311,
        "voice": "vo_adv_5080003_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難道妳是為了獲得加乘作用",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而讓其他店的產品寄賣！？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真不愧是老婆婆！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這就叫辣椒還是比薑辣吧！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳要說的是",
        "unit_id": 119211,
        "voice": "vo_adv_5080003_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "薑還是老的辣",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "辣椒感覺當然",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比薑更辣就是了。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "如果我說",
        "unit_id": 7912,
        "voice": "vo_adv_5080003_029"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "從一開始就有這個打算，",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "聽起來大概很像那麼回事，",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n但我連想都沒想過",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "那種事。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我只在蘭德索爾做過生意，",
        "unit_id": 7912,
        "voice": "vo_adv_5080003_030"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n所以也不像真陽一樣",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "有關於兜售的智慧與經驗。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "只是，",
        "unit_id": 7912,
        "voice": "vo_adv_5080003_031"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "要怎麼說呢。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
