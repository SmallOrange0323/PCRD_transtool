        "voice": "vo_adv_1120004_048"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n來拍張照",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "當做紀念吧。",
