    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你很吵耶！！",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_050"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我知道了啦！！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我很可愛！！",
        "unit_id": 106031
    },
    {
        "type": "still",
        "still": "112000402"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "咦！？",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_051"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n剛、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "剛才的拍下來了！？",
