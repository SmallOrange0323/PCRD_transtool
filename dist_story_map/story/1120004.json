[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新年題字大會結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到了公會小屋的{player}和凱留，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n享受了短暫的休息時間。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼──",
        "unit_id": 112011,
        "voice": "vo_adv_1120004_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新年才剛開始就活動過頭了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我差不多想休息了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不知道是不是因為太疲勞的關係，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得異常地刺眼……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！",
        "unit_id": 112011,
        "voice": "vo_adv_1120004_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我說你，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎又在發光了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這道光是……！",
        "unit_id": 112011
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "才剛過年而已你就要做配送郵件的打工？",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_002"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你真的很喜歡工作耶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗯，",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_003"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "新年快樂。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過沒什麼值得祝賀的事就是了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你問我在做什麼？",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_004"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "沒什麼。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只是跟家人說我要去新年參拜就出來了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "然後就這樣到處閒晃而已。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不管去到哪都是人，真的很煩。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不說這個了，",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_005"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "既然你都這麼賣力工作了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那你肯定有錢吧？　",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "請我吃東西吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊？　",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_006"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "為什麼你可以毫不猶豫地把現金交出來啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真是莫名其妙。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然感覺你就會這麼說，",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_007"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但你現在是被逼著要請客耶，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n好歹也露出一點困擾的表情啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊～真是的！　",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_008"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "算了、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "算了！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我說請客只是在開玩笑，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你別當真啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你問我想吃什麼？",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_009"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我說你",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "到底是有多爛好人啦！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "給我適可而止一點啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "說是",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_010"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我在向你討錢，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n感覺更像是我被你施捨一樣，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真讓人不爽。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼？　",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_011"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那要不要一起去吃",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "免費的年糕紅豆湯嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "免費的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是可以啦……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "中年女性",
        "words": "新年快樂。",
        "unit_id": 1,
        "voice": "vo_adv_1120004_012"
    },
    {
        "type": "dialogue",
        "name": "中年女性",
        "words": "\n來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "中年女性",
        "words": "這是年糕紅豆湯。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然是免費的，但還滿好吃的，",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_013"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "身體也暖和起來了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你別那麼開心地看著我啦。",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_014"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你什麼也沒做吧……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然是我不讓你做的就是了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唉……",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_015"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這樣仔細一看，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "穿和服的人果然很多呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你問我要不要也去穿和服？　",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_016"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是很想穿，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但媽媽不會幫我出那種錢的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "而且因為媽媽的關係，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我打工也都做不久……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "…………不了，",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_017"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你做到這種程度，真的很嚇人耶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "怎麼？　",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_018"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你在打什麼壞主意嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "如果是那樣的話，感覺反而還比較正常……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但你不是那種人對吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我不會跟你拿錢的。",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_019"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "如果你可以不花錢就讓我穿到和服，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那我是可以穿啦，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n但那是不可能的吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只要是真的免費就沒關係，",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_020"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n但你知道哪裡有免費的嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "而且，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "大家都說沒有什麼東西比免費的更可怕了……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "喂！？",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_021"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n也不聽人說話就自己先走了！！",
        "unit_id": 106031
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你把我帶到這種地方來要做什麼？",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_022"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n這裡只是一般的住宅區嘛。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "幹嘛啊？　",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_023"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "要我仔細看？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼？　",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就算要我仔細看……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n有個攝影工作室的看板呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只是有看板而已，",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_024"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但怎麼看都像是一般的住宅啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你把我帶到這種地方來，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "該不會是想做什麼奇怪的事吧！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊──！　",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_025"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你還按下電鈴了！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "來了來了，",
        "unit_id": 1,
        "voice": "vo_adv_1120004_026"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "久等了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n哎呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我剛才已經收到賀年卡囉……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "怎麼，",
        "unit_id": 1,
        "voice": "vo_adv_1120004_027"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "是客人嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n哦，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "怎麼了？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "嗯。",
        "unit_id": 1,
        "voice": "vo_adv_1120004_028"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n你希望能",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "讓那邊的小姐穿上和服嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "哎呀哎呀……！",
        "unit_id": 1,
        "voice": "vo_adv_1120004_029"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你、",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_030"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你看！　",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "人家這不是很困擾嗎！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你突然在說什麼啊！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n給我道歉！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不是，",
        "unit_id": 1,
        "voice": "vo_adv_1120004_031"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不是的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我並沒有覺得困擾喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "咦……？",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_032"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我打算再過不久就要收掉工作室了。",
        "unit_id": 1,
        "voice": "vo_adv_1120004_033"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n雖然已經用非常便宜的價格來出租和服和替人拍攝，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n但還是完全沒有客人來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那間車站前的工作室",
        "unit_id": 1,
        "voice": "vo_adv_1120004_034"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "把客人都搶走了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n要說困擾應該是這件事比較令人困擾吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "雖然店都要收了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n但不覺得會想在最後",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "再拚一下看看嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是、",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_035"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是喔……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這樣的話就要用租的了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n果然不是免費",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "的吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "妳什麼都沒聽說嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1120004_036"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "雖然因為新年已經開始，現在算是有點晚了，",
        "unit_id": 1,
        "voice": "vo_adv_1120004_037"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n但我有在找",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "能夠幫忙穿和服宣傳的女孩子喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n當然，我也會出打工費，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "還可以免費穿喜歡的和服。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這些話是",
        "unit_id": 1,
        "voice": "vo_adv_1120004_038"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我在他送信過來時，跟他聊到的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n沒想到他竟然會連我這種老人家所說的無聊話",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "都記得這麼清楚呢……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "喂，我說你！",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_039"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n既然是這樣的話，就好好說明過後再帶人過來啊！",
