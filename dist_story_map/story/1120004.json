        "type": "dialogue",
        "name": "希留耶",
        "words": "不、",
        "unit_id": 106031,
        "voice": "vo_adv_1120004_040"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n既然能穿和服……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "又拿得到打工錢……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那我現在就可以幫忙去宣傳了……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "哦哦！",
        "unit_id": 1,
        "voice": "vo_adv_1120004_041"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n真的嗎！？",
