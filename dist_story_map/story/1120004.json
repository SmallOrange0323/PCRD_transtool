        "voice": "vo_adv_1120004_044"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可愛！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我只有問你有沒有哪裡很奇怪啦！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n很、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "很可愛",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是什麼啦！！",
