        "voice": "vo_adv_1008007_047"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "……不，不行！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n一知道你是男的，我就不想要你當我的妻子了！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這代表你的愛就只有那種程度而已呀。",
        "unit_id": 100811,
        "voice": "vo_adv_1008007_048"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果要和我交往，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就得是即便知道我是男的還能繼續愛著我的人。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這樣啊……",
        "unit_id": 911,
        "voice": "vo_adv_1008007_049"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n看來我，配不上你呢。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n我就放棄你吧……",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，太順利了呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008007_050"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你假裝我的戀人裝得不錯唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "知道我是男的竟然就馬上放棄，",
        "unit_id": 100811,
        "voice": "vo_adv_1008007_051"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n真是失禮對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "和性別無關，我明明就這麼可愛呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是你，就算我是男的也沒關係對吧？",
        "unit_id": 100811,
        "voice": "vo_adv_1008007_052"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "竟然臉紅了，真可愛呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好了，快點回去吧。",
